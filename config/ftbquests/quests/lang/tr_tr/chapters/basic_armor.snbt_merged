	quest.10AA2B20D86747F7.quest_desc: ["&bFerricore&r, Demir ile aynı özelliklere sahip. Ancak Demir'in sahip olmayı dilediği başka yeteneklere de sahip! \\n\\nNeler yapabilecekleri hakkında daha fazla bilgi edinmek için Eşya açıklamalarına göz at!"]
	quest.1245126B4338C019.quest_subtitle: "Orman Konağı"
	quest.1245126B4338C019.title: "Sinirbozan Zırh Süslemesi "
	quest.13517D17E6BF015F.quest_desc: ["&bElmas Zırh&r ve birkaç &aInferium Eşyası&r ile &aInferium Zırhı&r yapabiliriz! \\n\\nAyrıca Tamirci Masası ile geliştirilebilirler!"]
	quest.13517D17E6BF015F.title: "&aInferium Zırh"
	quest.1366B946928C873B.quest_desc: ["Daha fazlasını öğrenmek için &6&lBumblezone&r Görev Sayfasına göz at!"]
	quest.1366B946928C873B.title: "Arı Zırhı 1"
	quest.15978093237448FE.quest_desc: ["&cNetherit&r'i, &6AllTheModium&r ya da &3Muhafız Zırhına&r yükseltmek varken neden başka bir şeye yükseltelim ki! \\n\\nYine de bunu yapmak için Muhafız'dan Düşen birkaç eşyaya ihtiyacın olacak!"]
	quest.15978093237448FE.title: "&3Muhafız Zırhı"
	quest.17A68C4E9E9EA2B7.quest_desc: ["&eAltın Zırh&r, Demir ve &7Deri&r arasında yer alır. Ancak Dayanıklılığı &7Deri&r'ye çok daha yakın. \\n\\nBirkaç &eAltın Zırh&r giyerken Piglin'lerin sana karşı Tarafsız olması dışında pek bir faydası yok."]
	quest.17A68C4E9E9EA2B7.title: "&eAltın Zırh"
	quest.19F58E291A543228.quest_desc: ["&d&lArs&r Zırhlarının, &eAltın&r versiyonu!"]
	quest.19F58E291A543228.title: "&5Sihirbaz'ın Kıyafetleri"
	quest.1A8440C0048EEB02.quest_desc: ["&cBlazegold&r, Demir ile aynı özelliklere sahip. Ancak Demir'in sahip olmayı dilediği başka yetenekleri de var! \\n\\nNeler yapabilecekleri hakkında daha fazla bilgi edinmek için Eşya açıklamalarına göz at!"]
	quest.1A8440C0048EEB02.title: "&cBlazegold Zırhı"
	quest.1C27C74722A19FC1.quest_desc: ["Bir ton, süper pahalı &l&5Mekanism&r Eşyasıyla &5Unobtainium Zırhı&r, &aMekaSuit&r'e yükseltebilirsin! \\n\\nArtık Enerji tutabilir ve hasar aldığında kalbinin gitmesi yerine Enerjin azalır. \\n\\nDaha da iyi hale getirmek için Yükseltme Birimlerini kullanabilirsin!"]
	quest.1C27C74722A19FC1.quest_subtitle: "Tedarik edebileceğin kadar Enerji"
