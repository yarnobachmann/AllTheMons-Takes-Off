	quest.28408BFAA54E4FC6.quest_desc: ["&7Deri Zırh&r elde edeceğin en kötü Zırh takımıdır. \\n\\nBunun nedeni çoğunlukla &c&lMojang&r'ın onu diğerlerinden önce elde etmeni beklemesidir. \\n\\nGerçi neredeyse hiç yapmıyorum çünkü o kadar çok &8İ&fn&8e&fk&r bulmakta zorlanıyorum, üzgünüm &c&lMojang&r!"]
	quest.28408BFAA54E4FC6.title: "&7Deri Zırh"
	quest.2A4FE9644F3B9DC1.quest_desc: ["&2Prudentium&r'un yükseltilmiş versiyonu."]
	quest.2A4FE9644F3B9DC1.title: "&cTertium Zırh"
	quest.2C387BFA6EE6FDB7.quest_desc: ["&cUtherium Crystal&r'ler, &2&lUndergarden&r'daki &cRotbeast&r'lerden düşer!"]
