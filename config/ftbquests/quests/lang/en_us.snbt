	quest.3512F47DADC07EAE.quest_desc: ["&5Unobtainium Armor&r but with buffs to &d&lArs Nouveau&r Spells!"]
	quest.3512F47DADC07EAE.quest_subtitle: "40"
	quest.3512F47DADC07EAE.title: "&5Unobtainium Arcanist Gear"
