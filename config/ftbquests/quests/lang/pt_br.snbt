	file.0000000000000001.title: "All The Mods Mons"
	quest.0000A88BB40B2149.quest_desc: ["Agora, antes de chegar à Ilha do Caos, recomendo que você se prepare. Ele pode se parecer com o Dragão do Ender, mas este é muito mais difícil. Você vai querer Armas ou Ferramentas Dracônicas que causem muito dano, pois elas facilitarão as coisas. Ele também causará uma tonelada de dano, então uma boa Armadura como a de Unobtainium ou o Meka-Suit é recomendada. Efeitos de Regeneração, Absorção e Resistência também ajudarão você a sobreviver. Não se preocupe, você sempre pode voltar para lutar outro dia se não estiver pronto."]
	quest.0000A88BB40B2149.title: "É difícil, você precisará se preparar"
	quest.00075A5F9AC120ED.quest_desc: ["Isso retirará os itens do seu baú de entrada."]
	quest.00075A5F9AC120ED.quest_subtitle: "Sempre Necessário"
	quest.001A348054127235.quest_desc: ["&5Ametista em Brotação&r pode ser útil para receitas de criação e até mesmo para cultivar &5Ametista&r!\\n\\nCom um &5Bloco de Ametista&r, &a60 Eterna&r, entre &c30% &fe &c50% Quanta&r, e &550% Arcana&r, podemos &d&lInfusionar&r um.\\n\\nPara obter todas essas estatísticas, podemos usar 15 &4Estantes Infernais Luminosos&r e 4 &2Estantes de Melancia&r."]
	quest.001A348054127235.title: "Fazendo &5Ametista em Brotação"
	quest.001C1881E9289566.quest_desc: ["&9Raro&r é o meio-termo das Raridades. \\n\\nAparece em todos os &lNíveis de Mundo&r, mas é mais comum no &lNível de Mundo: &eAscensão&r. \\n\\n&9Fragmentos de Cristal Luminoso&r são feitos usando &eItens&r &9Raros&r em uma &c&lMesa de Desmanche&r."]
	quest.001C1881E9289566.quest_subtitle: "&9Raro"
	quest.001C1881E9289566.title: "&9Fragmento de Cristal Luminoso"
	quest.001DE8028CAF0A08.quest_desc: ["As &5Máquinas&r do &5&lMekanism&r podem ser bem barulhentas!\\n\\nVamos parar com isso!"]
	quest.001DE8028CAF0A08.quest_subtitle: "shhhhh... alto demais...."
	quest.001DE8028CAF0A08.title: "Melhoria de &8Silenciamento"
	quest.002163B909070CF8.quest_desc: [
		"Permite que você veja detalhes sobre certos blocos/fluidos, mesmo através de paredes.\\n"
		"{image:atm:textures/questpics/pneumaticcraft/block_tracker.png width:150 height:150 align:center}"
	]
	quest.002163B909070CF8.quest_subtitle: "Máx: 1"
	quest.002D65E4D7E8F62B.title: "Catalisador Nivelador Nível 2"
	quest.00307A898A639191.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.003AA945CACCD641.quest_subtitle: "Feito com uma Mesa de Oferendas"
	quest.003AA945CACCD641.title: "&fAbelha das Profundezas"
	quest.003FF3813A864BA1.quest_subtitle: "Alimente uma Abelha de Lava com um Balde de Matéria Estranha"
	quest.003FF3813A864BA1.title: "&fAbelha de Matéria Estranha"
	quest.00453FF528AA0B1C.quest_desc: ["Esqueletos Lonestar são Mobs hostis que podem aparecer em qualquer lugar.\\n\\nEles têm 10 Corações e jogarão sua Espada em você para atacá-lo.\\n\\nAo morrer, eles podem dropar Ossos, Pepitas de Prata do Pântano, Espadas Quebradas e os drops adicionados por Corail para Mobs Mortos-Vivos."]
	quest.00453FF528AA0B1C.title: "Esqueletos Lonestar"
	quest.004D61425172324F.quest_desc: ["A &8Armadura de Malha&r é um pouco pior que a de Ferro. Seu uso principal no &l&2Minecraft&r era sua natureza elusiva, sendo obtida apenas através de Trocas e Drops de Mobs.\\n\\nClaro que isso é moddado, então agora podemos criá-la! O que tira seu propósito..."]
	quest.004D61425172324F.quest_subtitle: "12"
	quest.004D61425172324F.title: "&8Armadura de Malha"
	quest.0052E5592A6BBEC1.quest_desc: [
		"Isso é &2&lMinecraft&r, não posso te dizer como construir..."
		"{@pagebreak}"
		"Mas posso te dar dicas para isso!"
	]
	quest.0052E5592A6BBEC1.title: "&lDicas de Construção!&r"
	quest.005CC8A3325FE2BD.quest_desc: ["&bAço Gelado&r, &7Cloggrum&r e &eRegalium&r podem ser minerados.\\n&cUtheric&r e &aForgotten&r você precisa matar para conseguir.\\n\\nMais alguma pergunta?"]
	quest.005CC8A3325FE2BD.title: "Metais do &2&lUndergarden&r"
	quest.00611844AFD5C31E.quest_desc: ["Embora o &eInscritor&r e o &eCarregador&r aceitem nativamente &eRF/FE&r, a grande maioria de uma &eRede ME&r usa seu próprio sistema de energia dedicado chamado AE.\\n\\n&eRF/FE&r pode ser convertido para o &bAE&r nativo na proporção de 2:1 RF:AE, seja diretamente através de um &bControlador ME&r, ou através do &bAceitador de Energia&f, que pode ser conectado a qualquer parte da rede."]
	quest.00611844AFD5C31E.quest_subtitle: "Não aceito boleto, apenas energia!"
	quest.00611844AFD5C31E.title: "&cAceitador de Energia"
	quest.0072C4F028C327CB.quest_subtitle: "Magmatic + Nomad"
	quest.0072C4F028C327CB.title: "&fAbelha de Blaze"
	quest.00764A738DA6451C.quest_desc: ["Mate 4 &dEndermites&r.\\n\\nEstamos apenas matando tudo agora, não estamos?"]
	quest.007A11C49E06F15F.quest_desc: ["Estes podem ser Criados.\\n\\nO &9Crafting Component Blueprint&r é um dos &9Blueprints&r mais importantes.\\n\\nEle é usado para ajudar a &6Bancada do Engenheiro&r a fazer pequenos Componentes Mecânicos mais baratos do que nas Bancadas de Trabalho.\\n\\nTambém pode ser usado para Criar Itens únicos como Lâmpadas e Circuitos!"]
	quest.007A11C49E06F15F.title: "&9Crafting Component Blueprint "
	quest.0089A394566B0F3B.quest_desc: ["&aIncomum&r é a segunda Raridade. \\n\\nComeça a aparecer no &lNível de Mundo: &9Refúgio&r, é mais abundante no &lNível de Mundo: &2Fronteira&r e para no &lNível de Mundo: &4Pináculo&r. \\n\\n&aTecido Gasto pelo Tempo&r é feito usando &eItens&r &aIncomuns&r em uma &c&lMesa de Desmanche&r."]
	quest.0089A394566B0F3B.quest_subtitle: "&aIncomum"
	quest.0089A394566B0F3B.title: "&aTecido Gasto pelo Tempo"
	quest.008D186B4E0ED14F.quest_desc: [
		"O Steam Oven é outra máquina que usa Vapor para algo útil.\\n\\nAo colocar Vapor no Steam Oven, ele agirá como uma fornalha para quaisquer itens dentro dele. Fazendo Barras de Minérios e cozinhando itens de comida.\\n\\nÉ uma máquina de 2x2x2 de blocos de Steam Oven."
		"{image:atm:textures/questpics/railcraft/rail_oven.png width:100 height:100 align:center}"
	]
	quest.008D186B4E0ED14F.title: "Steam Oven"
	quest.008E65AF545A706E.quest_desc: [
		"Embora seja uma das &5Máquinas&r mais caras do &5&lMekanism&r, não é tão difícil de usar! \\n\\nPrimeiro, depois de construí-la, precisaremos abastecê-la com &aPolônio&r. Conecte alguns com &cTubos&r em uma das &dPorta do AFS&r porque precisaremos carregar nosso &aPolônio&r em &dAntimatéria&r! \\n\\nPara carregá-la, precisaremos alimentar nossas &dBobinas Supercarregadas&r! Conecte &aCabos&r &mcom&r quantidades massivas de &aEnergia&r nas &dPortas do AFS&r para que elas possam movê-la para as &dBobinas Supercarregadas&r. \\nCada &dBobina Supercarregada&r pode receber apenas uma certa quantidade de &aEnergia&r, então para eficiência ideal, use 2! Sim, você pode usar 1, mas vamos lá, precisamos de &dAntimatéria&r este ano, não no próximo! \\n\\nAssim que tivermos bombardeado o &aPolônio&r com &mmilhões&r de FE suficientes, obteremos nossa &dAntimatéria&r. Espere, isso é &cAntimatéria&r &dQuímica&r?!?! Precisamos..."
		"{@pagebreak}"
		"{image:atm:textures/questpics/mek/mek_sps1.png width:100 height:75 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps2.png width:100 height:90 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps3.png width:120 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps4.png width:120 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps5.png width:120 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps6.png width:110 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps7.png width:100 height:100 align:center}"
		"{@pagebreak}"
	]
	quest.008E65AF545A706E.quest_subtitle: "&d&lAFS"
	quest.008E65AF545A706E.title: "&d&lAlterador de Fase Supercrítica"
	quest.0095422BC87AA135.quest_desc: [
		"De novo? Cara, nós queremos &7Barras&f, não &7Aglomeradas&f e não &7Fragmentos&r! &7BARRAS&r!\\n\\nJogue esses &7Fragmentos de Minério&r em uma &b&lCâmara de Purificação&r com &bOxigênio&r (provavelmente do nosso &9&lSeparador Eletrolítico&r anterior) para fazer &7Aglomerados de Minério&r.\\n\\nAgora, apenas repetimos os passos do Tier anterior. &4Triture&f os &7Aglomerados&f para obter &7Pó Sujo&r.\\n\\n&dEnriqueça&f o &7Pó Sujo&r para limpá-lo.\\n\\nEntão, &6Funda&f o &7Pó&f para obter nossos &7Barras&r!"
		"{image:atm:textures/questpics/mek/mek_tier3_3.png width:250 height:100 align:center}"
	]
	quest.0095422BC87AA135.quest_subtitle: "Processamento de Minério Tier 3"
	quest.0095422BC87AA135.title: "&7Fragmento&f, para &7Aglomerado&f, para &7Pó&f, para &7Barra"
	quest.00A17728A387B426.quest_desc: ["Ninhos de Madeira são usados para atrair Abelhas Carpinteiras e a Abelha de Faixa Azul.\\n\\nNinhos de Carvalho Escuro atraem 3 abelhas diferentes.\\n\\nEstes podem ser colocados em qualquer Bioma do Mundo Superior."]
	quest.00A17728A387B426.quest_subtitle: "Pode ser usado em qualquer bioma do Mundo Superior"
	quest.00A17728A387B426.title: "&fNinhos de &#deb887Madeira"
	quest.00A6020BC979947F.quest_desc: ["Com seu &9Marid Triturador&r recém-invocado, você pode quebrar um Fragmento de Eco e um Lingote de Iesnium, que, quando combinados com uma Bolsa de Tinta Luminosa, criam o Giz Ciano."]
	quest.00A6020BC979947F.title: "&3Giz Ciano"
	quest.00A91BD731486644.quest_subtitle: "Ébano do Ceilão + Cerejeira Ácida"
	quest.00B7DD3AFC94B037.quest_subtitle: "Beech + Alder"
	quest.00C0536DE2878A36.quest_desc: [
		"Aumento de Nível para 53."
		""
		"O Item de Assinatura é Augurita Preta."
	]
	quest.00C0536DE2878A36.title: "&7Chefe Zeph"
	quest.00C95A190BE2CBF9.quest_desc: ["Para obter &#994ABAEstireno&r, você deve reagir &#C2C969Pó de Ferro&r com &#69C9B6Etilbenzeno&r e Vapor. &#69C9B6Etilbenzeno&r é o produto da destilação de &#CDCF95Nafta Craqueada a Vapor&r."]
	quest.00C95A190BE2CBF9.title: "&fDestilação Avançada"
	quest.00CB8D60E7831A57.quest_desc: ["Catacumbas são estruturas subterrâneas massivas feitas de Tijolos de Pedra Profunda. Elas podem ter uma parte saindo do chão que você pode encontrar.\\n\\nDentro do enorme labirinto há &7Forgottens&r, Baús escondidos e o chefe: &aGuardião Esquecido&r.\\n\\nEspero que esteja preparado para isso!"]
	quest.00CB8D60E7831A57.title: "Catacumbas"
	quest.00D7BCC68D971A53.quest_desc: ["Criaturas vivas próximas serão rastreadas automaticamente, mesmo através de paredes. Se for um mob agressivo, você receberá um aviso quando ele o alvejar."]
	quest.00D7BCC68D971A53.quest_subtitle: "Máx: 1"
	quest.00DB5495C3A44999.quest_desc: ["Shift + Clique Direito em um inventário para esvaziar."]
	quest.00DEFA26F2B896D6.quest_subtitle: "Silver Lime + Oak/Birch"
	quest.00E19377BAE5DD6A.quest_desc: ["Este adiciona &7Tesouras&r à nossa &dMeka-Tool&r! \\n\\nNão podemos usá-lo com a &2Unidade de Cultivo&r ou a &5Unidade de Teletransporte&r."]
	quest.00E19377BAE5DD6A.quest_subtitle: "Socorro Chavinho!"
	quest.00E19377BAE5DD6A.title: "&eUnidade Esmagadora"
	quest.00E1F1279F97557B.quest_desc: ["Similar ao Extrusor MK1, mas este é mais evoluído! Pode ser usado com Padrões para que, quando os Blocos forem colocados, eles sigam esse padrão!"]
	quest.00E4E946891014D9.quest_desc: ["Para poder &5Terastalizar&r, precisamos de permissão. Não pergunte o porquê, eu não sei a resposta. \\n\\nA maneira de conseguirmos permissão é usando um &5Orbe Tera&r. \\n\\nVocê precisará de Fabrique. Curiosamente, ele é feito apenas com itens &2&lVanilla&r. \\n\\nVocê pode simplesmente clicar com o botão direito com ele para equipar ou usar sua Tela de Acessórios."]
	quest.00E4E946891014D9.title: "&5Orbe Tera"
	quest.00F00B0B66059996.quest_desc: [
		"Certo, outro &lMultibloco&r! Este exigindo mais portas do que qualquer Base Naval já viu! \\n\\nPrecisaremos de &bEntrada &fde Fluido e &bSaídas&r, e &eEntrada &fde Itens e &eSaídas&r. \\n\\nAgora precisamos seguir uma longa lista de coisas, então preste atenção! \\n\\nPrimeiro, precisaremos de Almas Líquidas Não Refinadas que vêm do uso de um Extrator de Fluido (do &lIF&r) em uma Árvore de Almas. \\n\\nEntão, podemos usar o &b&lCrucible Rúnico&r para combinar Almas, Almas Líquidas Não Refinadas e &dFonte Liquefeita&r para obter Almas Líquidas! \\n\\nPrecisaremos usar um &cMisturador Mecânico &6Aquecido&r para combinar &5Fragmentos de Ametista&r com &aGemas de Experiência Maiores&r para fazer &dFonte Liquefeita&r! \\n\\nEm seguida, usaremos as Almas Líquidas, &dFonte Liquefeita&r e alguns Itens do &l&5Mekanism&r para finalmente criar &5Obsidiansteel&r."
		"{@pagebreak}"
		"{image:atm:textures/questpics/chap3/creative_crucible1.png width:125 height:100 align:center}"
		"A primeira camada do &l&bCrucible Rúnico&r tem uma &6Gilded Chiseled Polished Darkstone&r no meio, ao redor dela há &9Pedra Sombria Polida&r. Então, nas laterais teremos &9Escadas de Pedra Sombria Polida&r de cabeça para baixo, com &7Blocos de Runas&r nos cantos."
		"{image:atm:textures/questpics/chap3/creative_crucible2.png width:125 height:100 align:center}"
		"Bem no meio, colocaremos um &bCristal Arcano&r com &9Escadas de Pedra Sombria Polida&r ao redor. Nas laterais estarão &6Pilares de Pedra Sombria Polida Arcana&r, &9Pedra Sombria Polida&r que serão substituídos por Alçapões, e &6Pedra Sombria Polida Arcana&r."
		"{image:atm:textures/questpics/chap3/creative_crucible3.png width:125 height:100 align:center}"
		"Basta colocar &bBlocos de Cristal Arcano&r em cada canto e pronto!"
		"{image:atm:textures/questpics/chap3/creative_crucible4.png width:125 height:100 align:center}"
		"Finalmente, com um bloco de espaço, coloque o &7Injetor Quântico&r acima do &bBloco de Cristal Arcano&r do meio."
		"{image:atm:textures/questpics/chap3/creative_crucible5.png width:150 height:100 align:center}"
		"{image:atm:textures/questpics/chap3/creative_crucible6.png width:150 height:100 align:center}"
		"Os &9blocos de Pedra Sombria Polida&r na camada do meio são onde colocaremos nossos Alçapões!"
	]
	quest.00F00B0B66059996.title: "&b&lCrucible Rúnico"
	quest.00FD36C207845895.quest_desc: ["Coloque um &5Ninho de Obsidiana&r no &eEnd&r para atrair esta abelha."]
	quest.00FD36C207845895.quest_subtitle: "Um dragão em miniatura?"
	quest.00FD36C207845895.title: "&fAbelha &8Dracônica"
	quest.00FF2CA7BA326007.quest_subtitle: "Mandarin + Wild Cherry"
	quest.01046CFBD7411AA6.quest_subtitle: "Nível: &54"
	quest.010607466D565B53.quest_desc: ["Tipo, entre em contato com a Mãe Natureza, cara.\\n\\nCom as &aBotas Enraizadas&r, a natureza é sua melhor amiga! Ao ficar em cima da Grama, você regenerará Corações. Além disso, quando você come comida enquanto está na Grama, agirá como se você tivesse usado Farinha de Osso nela."]
	quest.010607466D565B53.quest_subtitle: "Pés"
	quest.010607466D565B53.title: "&aBotas Enraizadas"
	quest.0108F3EFDFD6DFD0.quest_desc: ["O Link de Armazenamento permite que você conecte múltiplos armazenamentos que não estão ligados a um Controlador de armazenamento ou a quaisquer blocos conectados a ele.\\n\\nEntão é uma maneira de conectar sem fio um \"multibloco\" de armazenamentos sem precisar clicar com o botão direito em cada um deles.\\n\\nO alcance de 14 blocos ainda se aplica."]
	quest.010A970FC91BD617.quest_subtitle: "Feito na Fundição de Ligas"
	quest.010A970FC91BD617.title: "&fAbelha de Soularium"
	quest.011B8BD02D80DDD4.quest_desc: ["Você pode encontrar &#6E2D6ETungstênio Bruto&r facilmente pelo mundo. Ao quebrá-lo, você obterá &#A140A1Tungstênio Bruto&r."]
	quest.011D8CADA29C9C70.quest_desc: ["&eOIQ Drives&r determinam o armazenamento dentro das &e&lMatrizes de unidade OIQ&r. \\n\\nElas são colocadas no inventário das &5Máquinas&r para serem usadas. Você pode colocar até 12 delas. \\n\\nAs &eDisco do OIQ&r armazenam os &eItens&r e preencherão automaticamente a primeira &eDisco do OIQ&r em ordem. \\n\\nCada uma delas tem um limite de &eArmazenamento de Itens&r e um limite de &eTipo de Item&r. Quanto melhor a &eOIQ Drive&r, mais &eItens&f e &eTipos de Itens&r você obterá! \\n\\n&aOIQ Drive&r: é a mais básica, com 16k Itens e 128 Tipos. Esta é a única que não precisa de um &2&lReator de Fissão&r para ser Criada. \\n\\n&cDisco Hiper-Denso do OIQ&r: e todas as seguintes precisarão do &2&lReator de Fissão&r. Esta armazena 128k Itens e 256 Tipos de Itens. \\n\\n&bDisco Dilatador do Tempo do OIQ&r: pode armazenar 1.048k Itens e 1.024 Tipos de Itens. \\n\\n&dDisco Supermassivo do OIQ&r: precisará de &dAntimatéria&r para ser Criado, mas obviamente fornecerá o maior Armazenamento. Permitindo 16 bilhões de Itens e 8.192 Tipos de Itens."]
	quest.011D8CADA29C9C70.title: "&eOIQ Drives"
	quest.011F787E620DE9E8.quest_desc: ["Para definir o Filtro de Criatura, basta clicar no Mob que você nunca mais quer ver, ou evite matar acidentalmente, com o Filtro de Criaturas..\\n\\nCada Filtro pode conter apenas 1 Mob, então se você não quer mais que Zumbis, Esqueletos, Aranhas, Creepers e Endermen apareçam, você precisará de 5 Filtros de Mob.\\n\\nVocê pode trocar o Mob nele simplesmente clicando em um Mob diferente com ele."]
	quest.011F787E620DE9E8.quest_subtitle: "Ele não foi convidado!"
	quest.012A8C905608C86E.quest_desc: ["&cCentros Pokémon&r agora são Estruturas próprias, fora das Vilas. \\n\\nBem, se você não estava jogando antes do Lançamento Público, você não saberia disso... \\n\\nEles são grandes construções feitas principalmente de Concreto Branco. Assim que você vir a &cPoké&rbola de Vidro no topo, você os reconhecerá! \\n\\n&cCentros Pokémon&r aparecem por todo o seu Mundo. Neles haverá Aldeões e muitas Máquinas, como..."]
	quest.012A8C905608C86E.title: "&cCentro Pokémon"
	quest.0133DA323E24A455.quest_desc: ["Falando em substituir coisas (&6Traje de Anti-Radiação&r por &aUnidade de Proteção contra Radiação&r), vamos substituir o &eTraje de Mergulho&r! \\n\\nCom esta &7Unidade de Módulo&r adicionada ao nosso &a&lCapacete Meka-Traje&r, poderemos nadar &9debaixo d'água&r e respirar! \\n\\nSe tivermos um &cJetpack&r em nosso &a&lMeka-Traje&r, ela fornecerá &7Hidrogênio&r quando estiver na &9Água&r."]
	quest.0133DA323E24A455.quest_subtitle: "Capacete"
	quest.0133DA323E24A455.title: "&9Respiração Eletrolítica"
	quest.0145727E40D7F674.quest_subtitle: "Cempedack + Breadfruit"
	quest.01516BC726013B7C.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.0152938EE5651409.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.015EC0ACDA0BB5F8.quest_desc: ["A cor da &6Metade de Bolota&r determina qual &bTampa&r recebemos. Além disso, ganhamos Corante dela! \\n\\nSe fundirmos uma &bTampa de Bola&r, podemos obter uma Tampa de Bola Vazia. Estas podem ser tingidas em outras &bTampas&r. "]
	quest.015EC0ACDA0BB5F8.title: "&bTampas de Bola"
	quest.01612963DBBAC9A1.quest_desc: ["Com sorte, isto deve te proteger."]
	quest.01612963DBBAC9A1.title: "Peitoral Caótico"
	quest.019CA0E35F888222.quest_subtitle: "Mais Opções de Filtragem"
	quest.019CA0E35F888222.title: "&eMelhoria Avançada de Reabastecimento"
	quest.01A0612C516B4F7F.quest_subtitle: "Aumenta a Produtividade das Abelhas em 150%"
	quest.01A0612C516B4F7F.title: "&fMelhoria de &6Produtividade Beta"
	quest.01A90E2541C91DB2.quest_desc: ["A maioria das &5Máquinas&r, pelo menos as simples, pode usar &8Melhorias&r!\\n\\nAs &8Melhorias&r ficam no canto superior direito da GUI. Esta tela pode ser confusa, mas não se preocupe, eu explico!\\n\\nPrimeiro, a parte inferior mostra as &8Melhorias Suportadas&r. As &8Melhorias&r claras são &aSuportadas&r, enquanto as mais transparentes &4não são&r! Você também pode passar o mouse sobre elas para ver seus nomes e se são &aSuportadas&r.\\n\\nAs &8Melhorias&r são adicionadas através do Slot Superior, elas então aparecerão à Direita. Aqui você pode Clicar nelas para ver quantas estão na Máquina e ver seu Efeito!\\n\\nSe quiser retirar nossas &8Melhorias&r, Clique na que você quer retirar e aperte o botão Desinstalar. Isso moverá a &8Melhoria&r para o Slot Inferior."]
	quest.01A90E2541C91DB2.title: "&8Melhorias de Máquina"
	quest.01ABEC296643443F.quest_desc: [
		"Sem Aumento de Nível..."
		""
		"O Item de Assinatura é Gema Elétrica."
	]
	quest.01ABEC296643443F.title: "&aLíder Galavan"
	quest.01AFC11EAAB6CB3B.quest_desc: ["A &eArmadura de Réptil de Osso&r é feita de &eOssos de Koboleton&r, &eMetal Ancestral&r, e para o Capacete um &eCrânio de Kobolediator&r.\\n\\nEles não parecem fazer nada de especial, apenas dão estatísticas muito boas para uma Armadura barata!"]
	quest.01AFC11EAAB6CB3B.title: "&eArmadura de Réptil de Osso"
	quest.01B13BBB41BBB460.quest_desc: ["A &cArmadura de Utherium&r tem os mesmos status que a Armadura de Netherita!\\n\\nSem precisar de um Molde de Ferraria!"]
	quest.01B13BBB41BBB460.title: "Armadura de &cUtherium&r"
	quest.01B2DDD81065B4EF.quest_subtitle: "Jungle + Cherry"
	quest.01B54F372558DCE5.quest_desc: [
		"Aumento de Nível para 65."
		""
		"O Item de Assinatura é Gema de Água. Acho que estou vendo um padrão aqui também."
	]
	quest.01B54F372558DCE5.title: "&aLíder Tessy"
	quest.01C0DC225CB25A0C.quest_subtitle: "O Addon de Caçador permite que o laser mire em criaturas"
	quest.01C0DC225CB25A0C.title: "Machucando Criaturas"
	quest.01C169A7FA424F6E.quest_subtitle: "Nível: &a2"
	quest.01C5D8357D8B0D62.quest_desc: ["Se você sabe como funciona um Trilho Detector, este Módulo será autoexplicativo para você.\\n\\nBasicamente, se um certo Item estiver no Roteador, ele emitirá um Sinal de Redstone para fora do Roteador.\\n\\nNo Módulo, você pode definir o Item, de onde o Sinal vem e quão forte é o Sinal."]
	quest.01CF1A9D9F29AFF7.quest_subtitle: "Pomelo + Orange"
	quest.01ECFBB5F0574C24.quest_desc: [
		"Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. "
		""
		"Como todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. "
		""
		"Esta missão está intencionalmente oculta; se você está vendo isso, está no modo de edição."
	]
	quest.01EE2526B43B6502.quest_subtitle: "Nível: &b3"
	quest.01F18150EC923482.quest_desc: ["&3Refined Storage&r (RS ou RS2) é um mod de armazenamento em massa que oferece um sistema de armazenamento em rede.\\\\n\\\\nPara começar com o mod, você precisará criar o &3Controller&r.\\\\n\\\\nO Controller é o 'núcleo' da sua rede de armazenamento. Quando energizado, ele dá vida a todos os componentes RS conectados. Cada rede pode ter apenas um Controller."]
	quest.01F18150EC923482.quest_subtitle: "Versão 2"
	quest.01F18150EC923482.title: "&3Refined Storage"
	quest.01F322AEFCC6109E.quest_desc: ["Tangled Skulls podem ser dropados de... bem, Tangled Skulls.\\n\\nEles podem ser usados como um projétil, como uma Cabeça de Wither lançada por um Wither.\\n\\nEle será consumido quando você fizer isso, no entanto."]
	quest.01F3F0C25BA72BDA.quest_desc: [
		"Além do armazenamento de itens e fluidos, o AE2 também oferece uma maneira nativa de armazenar &eestruturas&f inteiras dentro de células de armazenamento, não muito diferente do mod Compact Machines."
		""
		"A &bPorta de E/S Espacial&f permite que estruturas contidas em uma &bEstrutura de Contenção Espacial&f sejam capturadas dentro de uma célula de armazenamento especialmente projetada, ativada por um sinal de redstone."
		""
		"Se um mob ou jogador estiver dentro da &6ECE&r enquanto o espaço está sendo capturado, eles também serão transportados para onde o resto do espaço vai, ou seja, para uma dimensão dedicada. Apenas certifique-se de ter uma maneira de voltar e entrar se for você quem está sendo capturado."
	]
	quest.01F3F0C25BA72BDA.title: "&bEspacial E/S"
	quest.01F51EBFEC660549.quest_subtitle: "Silver Lime + European Larch"
	quest.01F7F3589EBD8872.quest_subtitle: "Alimente uma Abelha de Cogumelo com um Cogumelo Marrom"
	quest.01F7F3589EBD8872.title: "&fAbelha de Cogumelo Marrom"
	quest.020E6AF37A0421C8.quest_desc: [
		"O Tanque de Água é como ter um barril do lado de fora. Só que este barril é muito maior. Ele coleta água e pode armazenar água para Locomotivas a Vapor.\\n\\nA quantidade de água que ele produz depende do bioma e da visibilidade do céu.\\n\\nÉ feito por blocos de Tanque de Água 3x3x3 com o centro oco."
		"{image:atm:textures/questpics/railcraft/rail_tank.png width:100 height:100 align:center}"
	]
	quest.020E6AF37A0421C8.title: "Tanque de Água"
	quest.022C38096F79EF07.quest_desc: ["&6&lForbidden \\& Arcanus&r é sobre usar o Arcano para fazer rituais com a Forja para se tornar mais forte!\\n\\nOu o que a maioria conhece, Eternal Stella. Há mais no Mod, você sabe!"]
	quest.022C38096F79EF07.title: "&6&lForbidden \\& Arcanus"
	quest.02315D55EB638E3C.quest_subtitle: "Faça biomassa para usá-la"
	quest.023BF4B6D80621EA.quest_desc: [
		"Aumento de Nível para 34."
		""
		"O Item de Assinatura é Gema Sombria."
	]
	quest.023BF4B6D80621EA.title: "&aLíder Vega"
	quest.024BD22824C7F53A.quest_desc: ["Destilar &#F0C87DNafta Craqueada a Vapor&r nos dará &#8FD5E3Tolueno&r."]
	quest.0252B8F77A038D17.title: "Módulo de Autoalimentação Wyvern"
	quest.02593CD4B4AE814C.quest_desc: [
		"O &bSal&r é importante para incubar &eEnxofres Alquímicos&r!\\n\\nPara obter &bSal&r, precisaremos cozinhar alguns Itens. Itens diferentes produzem &bSais&r diferentes. Os &bSais&r têm diferentes níveis, que aumentam quanto mais raros eles são.\\n\\nPara extrair o &bSal&r, precisamos colocar os Itens no Forno e usar uma fonte de calor para aquecê-lo. Em seguida, retire o &bSal&r do Forno!"
		"{image:atm:textures/questpics/theurgy/theurgy_oven.png width:100 height:100 align:center}"
	]
	quest.02593CD4B4AE814C.title: "Desalination Plant"
	quest.02643BAD1AE747C6.quest_desc: ["O &3Compressor de Líquido Avançado&r funciona da mesma forma que o Compressor de Líquido, só que muito melhor!"]
	quest.026C63594F813BCC.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		""
		"Remove todos os debuffs negativos do jogador quando ativada, possui um tempo de recarga."
	]
	quest.0272E58516A0C284.quest_desc: [
		"Melhorias Válidas:"
		"- Ore Miner"
		"- Ore Scanner &4&lDISABLED&r&f"
		"- Lawnmower"
		"- Sky Sweeper"
		"- Tree Feller"
		"- Leaf Breaker"
		"- Auto Smelter"
		"- Hammer"
		"- Drops Teleporter"
	]
	quest.027EF5C8A74B1596.quest_desc: [
		"As principais armas das &6A&8b&6e&8l&6h&8a&6s&r são seus Ferrões.\\n\\nEntão, por que não usamos isso para nossa própria Arma! Você pode criar, encontrar ou trocar pela Lança de Ferrão e ela funciona como um Tridente.\\n\\nSó que muito mais fraca e inflige Veneno nos Mobs!"
		"{image:atm:textures/questpics/bumblezone/bumble_spear.png width:100 height:150 align:center}"
	]
	quest.027FD9135DEC4949.quest_subtitle: "Atrai Abelhas Fantasmagóricas quando colocado no Nether e recebe Lágrimas de Ghast"
	quest.027FD9135DEC4949.title: "&fNinho de &#984d30Areia das Almas"
	quest.0287136D3E986317.quest_desc: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, você está no modo de edição."]
	quest.0298A17C2AAC5765.quest_desc: ["Aumenta o tamanho da pilha na Mochila em 8."]
	quest.0298A17C2AAC5765.title: "&bMelhoria de Pilha Nível 3"
	quest.029AA03790F055E8.quest_subtitle: "Abelha Cristalina + Abelha Construtora"
	quest.029AA03790F055E8.title: "&fAbelha de Ouro"
	quest.02B0CCD5607FF3B5.quest_desc: ["O acessador de jogador atua como um baú que interage com o inventário do jogador. Usando a GUI, os lados do acessador de jogador podem ser configurados para interagir com o inventário, mão secundária ou slots de armadura do jogador."]
	quest.02B574B09AB45D09.quest_desc: [
		"Freezes funcionam de forma semelhante aos Blazes, eles voam para cima e atiram uma bola em você.\\n\\nSó que os Freezes jogam apenas 1 bola e ela vai te deixar com frio em vez de quente.\\n\\nEles têm 16 Corações e droparão Tubos Congelados ao morrer."
		"{image:atm:textures/questpics/eternal/starlight_freeze.png width:150 height:100 align:center}"
	]
	quest.02B574B09AB45D09.title: "Congelar"
	quest.02B8F50721F12CFF.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:"
		""
		"Impede que o jogador sofra dano de queda."
	]
	quest.02C6132919DEAF2A.quest_desc: ["Antes de começarmos a gerar &aEnergia&r, vamos espalhar nosso Vapor por todo o lugar. Podemos fazer isso cercando o &9Complexo Rotacional&r com &9Dispersores de Pressão&r! \\n\\nAcima dessa camada, precisaremos de uma nova camada, desta vez cheia de &aBobinas Eletromagnéticas&r. Eles serão movidos por causa do &9Complexo Rotacional&r, e o movimento deles em conjunto é o que gera &aEnergia&r através de suas Forças Magnéticas. A mesma coisa acontece com Usinas Hidrelétricas! \\n\\nAcima das &aBobinas Eletromagnéticas&r, podemos usar &9Condensadores Saturantes&r, que irão reciclar nosso Vapor de volta em &9Água&r! A &9Água&r será extraída através das &9Ventilações&r."]
	quest.02C6132919DEAF2A.title: "Gerando &aEnergia&r com uma &9&lTurbina&r"
	quest.02D45E3FB37ED0AD.quest_subtitle: "Nível: &63"
	quest.02F23D223E792587.quest_desc: ["Você já deve saber como funciona! \\n\\nVença! \\n\\nAquele! \\n\\n&4Treinador&r!"]
	quest.02F23D223E792587.title: "Vença aquele &4Treinador&r!"
	quest.02F2DF9D9DA7833A.quest_desc: ["Para obter nossas &9Almas Corrompidas&r, precisaremos fazer um pouco de &5Encantamento&r!\\n\\nEstamos procurando pelo &5Encantamento de Saque de Alma&r. Ele vai em Armas, e toda vez que você mata um Mob, ele tem a chance de gerar uma &9Alma Corrompida&r.\\n\\nEstas podem então ser mortas para obtê-las como Itens. Tente fazer isso rapidamente, pois elas gostam de voar para longe.\\n\\nTalvez elas saibam que você quer matá-las?"]
	quest.02F2DF9D9DA7833A.title: "&5Encantamento de Saque de Alma"
	quest.02F3133A9006BC1E.quest_subtitle: "Despeje Aço Derretido sobre um Ovo de Gerador de Abelha Ferro/Carvão"
	quest.02F3133A9006BC1E.title: "Abelha de Aço"
	quest.02F4C3BEBD8427AD.quest_desc: [
		"Confie em mim, você saberá quando vir. \\n\\nDúzias de Jardins pendurados no teto da Colmeia. Contendo centenas de flores e árvores diferentes, caramba, até mesmo algumas de mods diferentes como Eternal Starlight ou Regions Unexplored!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_garden.png width:200 height:100 align:center}"
	]
	quest.02F4C3BEBD8427AD.title: "Jardins Suspensos"
	quest.0306D25C7407FE88.quest_desc: ["Outra parte que precisaremos para realmente iniciar o &c&lReator de Fusão&r é &6Calor&r! Podemos usar tanto &4Lasers&r quanto &ctransportar &6Calor&r para dentro dele. \\n\\nNós vamos apenas usar &4Lasers&r aqui. Mais especificamente, um &4Amplificador Laser&r disparando uma certa quantidade para dentro da &cMatriz Focal do Laser&r. \\n\\nPrecisaremos de um &4Amplificador Laser&r com o equivalente a 1GFE de &aEnergia&r para ser disparado na &cMatriz Focal do Laser&r. Parece muita &aEnergia&r, mas não se preocupe, nós a receberemos de volta! \\n\\nSeguindo a Missão do &4Amplificador Laser&r, precisaremos disparar &4Lasers&r no &4Amplificador Laser&r. Mas cada um fornece apenas cerca de 1MFE a cada poucos segundos... \\n\\nEm vez de esperar um ano, podemos usar múltiplos &4Lasers&r disparando em múltiplos &4Amplificadores Laser&r que, por sua vez, disparam naquele que está mirando na &cMatriz Focal do Laser&r. \\n\\nPosicione os &4Amplificadores Laser&r de forma que fiquem um atrás do outro, enquanto todos eles recebem disparos de 4 &4Lasers&r das outras direções!"]
	quest.0306D25C7407FE88.title: "&cMatriz Focal do Laser"
	quest.03164C4C7813CE2B.quest_desc: [
		"O Computador Quântico é uma poderosa CPU de Crafting. Ele é capaz de executar trabalhos de crafting ilimitados e compartilhar threads de coprocessamento entre eles, desde que tenha armazenamento disponível para usar."
		""
		"Deve ser um cuboide de pelo menos 3x3x3 e no máximo 7x7x7. Alternativamente: Um Núcleo de Computador Quântico é capaz de ser um Computador Quântico por si só."
		""
		"Um Multibloco de Computador Quântico requer o seguinte:"
		"- Nenhum espaço vazio pode estar presente no multibloco. Eles podem ser preenchidos com Unidade de Crafting Quântica para nenhum benefício adicional."
		"- Exatamente um Núcleo de Computador Quântico"
		"- No máximo um Entrelaçador de Dados Quântico"
		"- No máximo um Multi-Threader de Computador Quântico"
		"- Todos os blocos na camada externa devem ser Estrutura de Computador Quântico"
		"- Nenhum bloco no interior pode ser Estrutura de Computador Quântico."
		""
		"Espero que você esteja pronto para fazer muitas Singularidades."
	]
	quest.03164C4C7813CE2B.title: "Trabalhos de Crafting Infinitos: O Computador Quântico"
	quest.03250A0202C25E80.quest_desc: ["Depois de matar com sucesso o Demônio &9Marid Desacorrentado&r que você invocou com &4Atração de Tibira&r, você pode usar a &9Essência de Marid&r que ele dropa para criar o Giz da cor \"mais alta\", o Giz Azul."]
	quest.03250A0202C25E80.title: "&9Giz Azul"
	quest.0328E5E416D0F785.quest_desc: ["&nForte&r \\n\\n&aInseto&r \\n&2Grama&r \\n&bGelo&r \\n&7Aço&r \\n\\n&nVulnerável&r \\n\\n&6Pedra&r \\n&6Terra&r \\n&bÁgua&r"]
	quest.0328E5E416D0F785.title: "&cFogo"
	quest.032B654201E71618.quest_desc: ["Estes &cKits de Trilhos&r são para usar entidades com seus &7Carrinhos&r (Entidades, também conhecidas como Mobs).\\n\\nO &cKit de Embarque&r pegará quaisquer Mobs próximos e os colocará em um &7Carrinho&r.\\nO &cKit de Desembarque&r descarrega Mobs dos &7Carrinhos&r.\\nO &cKit de Despejo&r derrubará os mobs nos &7Carrinhos&r abaixo dos &6trilhos&r em que está."]
	quest.032B654201E71618.title: "&cKits de Trilhos&r para mover entidades"
	quest.0338E3A881A6DD98.quest_desc: ["&6Remédio&r é feito Fundindo uma Raiz Grande. \\n\\nÉ um Item que pode ser dado a um &cPokemon&r dentro ou fora da Batalha para restaurar Vida (não em troca de &dAmizade&r). \\n\\nVocê pode Criar com ele para fazer &6Remédios&r ainda melhores!"]
	quest.0338E3A881A6DD98.title: "&6Remédio"
	quest.0342248394E40B6A.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.0346A5856EBC22FB.quest_desc: ["Ele aumentará seu Limite de Nível, mas apenas até o 31. \\n\\nSeu Item de Assinatura é a &9Concha de Náutilo&r."]
	quest.0346A5856EBC22FB.title: "&aLíder de Ginásio Wake"
	quest.034A9FBCA6D79BB6.quest_desc: ["O Pylon Colheitadeira precisa de uma Enxada para funcionar.\\n\\n(Enxadas que não quebram funcionarão para sempre, enxadas que quebram precisarão ser substituídas)."]
	quest.034AB493E1EC2E63.quest_desc: [
		"Os Núcleos da Matriz Montadora são o que determinam a capacidade de padrões, trabalhos de crafting e a velocidade do multibloco."
		""
		"Núcleos de Crafting adicionam 8 trabalhos de crafting paralelos máximos ao multibloco."
		"Núcleos de Padrão adicionam 36 slots de padrão ao multibloco."
		"Núcleos de Velocidade funcionam como uma Placa de Aceleração, aumentando a velocidade dos trabalhos de crafting. Instalar mais de 5 Núcleos de Velocidade não tem efeito na velocidade de cada trabalho de crafting."
	]
	quest.034AB493E1EC2E63.title: "Núcleos da Matriz Montadora"
	quest.034DB3C64F24C7B7.quest_desc: ["&6&lAllTheOres&r é um mod feito internamente para ajudar a unificar minérios.\\n\\nCom isso, vêm muitos blocos decorativos muito úteis!\\n\\n&dFluorita&r e &9Safira&r ambos parecem muito legais!"]
	quest.034DB3C64F24C7B7.title: "&fBlocos de &l&6AllTheOres"
	quest.034F2CDF0830254B.quest_desc: [
		"Funciona exatamente como o Importador de Itens, coloque o &eImportador de Fluidos&r em um Tanque com Líquido. Em seguida, a &eInterface de Fluidos&r onde você quer que ele vá e conecte com Cabos Lógicos. Finalmente, Cartão Variável como antes!\\n\\nTambém pode puxar Líquidos no Limite de Inteiro.\\n\\nNão coloca ou retira Fontes de Fluido do mundo, ele apenas move Fluidos de um Tanque para outro."
		"{image:atm:textures/questpics/logistics/id_fluid.png width:200 height:50 align:center}"
	]
	quest.034F2CDF0830254B.title: "&eImportação de Fluidos"
	quest.035495984F84FB44.quest_subtitle: "Feito na Fundição de Ligas"
	quest.035495984F84FB44.title: "&fAbelha de Liga Pulsante"
	quest.03564837ECB5CC79.quest_desc: ["Outro Ritual, claro, este sendo o &2Encantamento de Ihagan&r. (A propósito, para sacrificar um Cavalo, você precisa dele por perto enquanto faz o ritual)\\n\\nUma vez feito, você receberá um Ovo de Invocação para um &2Familiar Dragão&r. Estes podem ser usados na criação para obter a &6&lEstrela ATM&r, ou você pode invocar o &2Familiar&r.\\n\\nEste irá segui-lo e pode ser acariciado usando Shift + Clique Direito nele."]
	quest.03564837ECB5CC79.title: "Ovo de Invocação de &2Familiar Dragão&r"
	quest.035C52EF63AD23A7.quest_desc: ["Daí o nome do mod, &lRailCraft&r, e em torno do que ele gira, &5Trens&r, os &6Trilhos&r são muito importantes.\\n\\nOs &2Vanilla&r funcionam para muitas dessas coisas, mas vamos lá, todos nós sabemos que eles são ruins. Os aprimorados precisarão de alguns itens mais especiais para suas receitas! Crie-os! (Eles podem exigir o uso de máquinas para fazer os itens, então confira essa parte da missão!)"]
	quest.035C52EF63AD23A7.title: "&6&lTrilhos&r!"
	quest.036D5767E07005BC.quest_desc: ["Os &bDrenos&r são o que usaremos para extrair os &7Metais Líquidos&r. Sim, infelizmente está muito quente para nossas Mãos ou Baldes.\\n\\nConecte a &7Torneira&r da &c&lFundição&r ao &bDreno&r, para drenar os &7Metais Líquidos&r ao Clicar com o Botão Direito na Torneira.\\n\\nVocê também pode ver as quantidades de Líquidos na &c&lFundição&r ao visualizar o &bDreno&r!"]
	quest.036D5767E07005BC.title: "&bDrenos&r da &c&lFundição"
	quest.037415D5B965E214.quest_desc: ["Esta melhoria faz com que a Mochila não possa morrer."]
	quest.037488EF1F3581CE.quest_desc: ["Por padrão, uma &bRede ME&r por si só tem apenas um buffer interno de &a800AE&r sem um &bControlador ME&r, com o controlador adicionando &a8kAE&r extras por bloco. Para redes suficientemente grandes, isso pode ser insuficiente e pode fazer com que uma rede desligue intermitentemente ao tentar recuperar energia para quaisquer dispositivos conectados.\\n\\nA &bCélula de Energia&f permite que uma &bRede ME&r armazene significativamente mais energia, adicionando outros &a200kAE&r por &bCélula de Energia&r regular e &a1.6MAE&r por &bCélula de Energia Densa&r. Elas também podem ser colocadas em qualquer lugar da rede para fornecer o buffer de energia aumentado."]
	quest.037488EF1F3581CE.quest_subtitle: "Sem energia? Pluga mais uma dessas e fé!"
	quest.037488EF1F3581CE.title: "&a&lCélula de Energia"
	quest.037E0DAA5ECC5AB8.quest_desc: ["Acerte 24 Mobs diferentes com &eSopros de Pólen&r.\\n&6A&8b&6e&8l&6h&8a&6s&r são as mais divertidas de acertar com eles!"]
	quest.037FBF06E59E1027.quest_subtitle: "Feito em Clibano"
	quest.037FBF06E59E1027.title: "&fAbelha de Deorum"
	quest.03840E4C74731E0C.quest_desc: ["Escutem, eu tenho dito a vocês para usarem &9Bombas Elétricas&r na maioria das Missões do &5&lMekanism&r. \\n\\nMas, para ser honesto, eu tenho que deixar vocês se formarem. Os &2&lReatores&r precisarão de mais &9Água&r, então eu lhes concedo a &9Pia&r! \\n\\nA &9Pia&r tem &9Água&r Infinita e pode ser &bcanalizada&r para fora usando praticamente qualquer Mod. Eu recomendo usar o &9&lID&r, se estiver disponível, pois ele consegue puxar mais de 2 Bilhões de mB de &9Água&r por Tick! \\n\\nA razão pela qual eu estava usando as &9Bombas Elétricas&r não é porque eu não confio em vocês com &9Pias&r, mas sim por estas razões. 1. ela se mantém para Modpacks que não têm &9Pias&r e 2. ela é do &5&lMekanism&r. "]
	quest.03840E4C74731E0C.title: "&9Water &bCoolant"
	quest.038812A14456236C.quest_desc: ["Combinando alguns Processadores, uma Célula de Energia e qualquer Cabo Denso, obtemos o Anel Quântico ME.\\n\\nNormalmente, nós o usaríamos para conectar nosso sistema ME através de Dimensões, mas nós só nos importamos com a &6&lEstrela ATM&r!"]
	quest.03B40AB768FC0161.quest_desc: [
		"Rios Cintilantes são rios amigáveis. Estes não farão de tudo para te matar.\\n\\nEles às vezes conectam Mares e atravessam Florestas.\\n\\nClaramente eles têm Água, mas dentro da Água há muitos bens!"
		"{image:atm:textures/questpics/eternal/starlight_river.png width:200 height:100 align:center}"
	]
	quest.03B40AB768FC0161.title: "Rio Cintilante"
	quest.03C40D6A5D722543.quest_desc: ["Cartões Variáveis são necessários para iniciar Interações como Importar Itens. Você os colocará em um dos slots do Importador para adicioná-los.\\n\\nA partir daí, você pode editar tudo através do botão +. Você pode alterar quanto é importado, qual Slot de Item, qual Canal, praticamente tudo com apenas esse Cartão.\\n\\nSe você for como eu, querendo apenas mover itens, nada muito extravagante, basta colocá-lo e talvez alterar o Limite de quanto é movido."]
	quest.03C54B07106091DD.quest_desc: ["O &cPrisma de Fundição&r é provavelmente o Item mais usado desses Rituais, assim como é necessário para a &6&lEstrela ATM&r!\\n\\nVocê precisará de 4 &cPós de Blaze&r, 2 &8Carvões&r e um bloco de &bCristal Arcano&r para fazê-lo. E não se esqueça da Relíquia de &3Elementarium&r!\\nObviamente, e o que você provavelmente mais quer do &cPrisma de Fundição&r, é a &6&lEstrela ATM&r. Ele também pode ser usado com Ferramentas para Fundir os Itens que elas quebram: Minério Bruto em Barras, Troncos em Carvão Vegetal, Areia em Vidro.\\n\\nVocê também pode usá-lo como Combustível de Fornalha, mas é meio ruim. O que é bobo, porque o nome sugere que seria melhor!"]
	quest.03C54B07106091DD.title: "&cPrisma de Fundição"
	quest.03C78165C5CBD9E1.title: "&aParte de Armazenamento de 16k"
	quest.03E05018D64DDEE1.quest_desc: ["O &eNível 5&r é basicamente apenas para Minério de Allthemodium, não muito mais."]
	quest.03E05018D64DDEE1.title: "&eColheita Nível 5"
	quest.03E605A91496B257.quest_desc: ["&7Peat&r é na verdade um Item muito barato de Criar! \\n\\nAgora apenas espere por uma Lua Cheia e dê a um Ursaring para &bEvoluí-lo&r para um &6Ursa&rluna. \\n\\nTenho quase certeza que isso significa lua urso!"]
	quest.03E605A91496B257.title: "&bEvoluindo&r o Ursaring"
	quest.03E6FA4DCB71162E.quest_desc: ["O &bAplicador de Cor&f é uma ferramenta carregável que permite a tingidura de cabos no mundo. Ele funciona mais ou menos como uma &ecélula de armazenamento&f especializada a ser carregada com corantes vanilla ou &ebolas de tinta&f para cores específicas, juntamente com &ebolas de neve&f para lavar as cores e transformar os cabos de volta em sua variante Fluix.\\n\\nAplicar cor a um cabo consome &a100AE&r de energia de sua bateria interna, para um total de 3400 segmentos de cabo em uma única carga."]
	quest.03E6FA4DCB71162E.title: "Aplicador de Cor"
	quest.03E8FB54B87524E1.quest_desc: ["A &9Pedra da Lua&r irá &bEvoluir&r &dClefairy&r para &dClefable&r e Jiggly&dpuff&r para Wiggly&dtuff&r."]
	quest.03E8FB54B87524E1.title: "&9Pedra da Lua"
	quest.03ED9B0DFE8B4574.quest_desc: [
		"Melhorias Válidas:"
		"- Mind Fog"
		"- Stupefy"
		""
		"Intrinsic Ability:"
		"- Lava Repair"
	]
	quest.041365A540BF5A03.quest_desc: ["O &7Dicionário&r não é útil para o Jogador médio: ele não Mina, Coloca Blocos, Cria, Funde, realmente interage com nada.\\n\\nEm vez disso, ele é usado para encontrar Tags!\\n\\nPodemos Clicar com o Botão Direito em um Bloco com o &7Dicionário&r na Mão e as Tags do Bloco aparecerão no Chat. Podemos fazer o mesmo com Entidades.\\n\\nIsso não é suficiente? Bem, também podemos Shift + Clique Direito para abrir nosso &7Dicionário&r!\\n\\nAqui podemos ver os Itens em nosso Inventário e verificar todas as diferentes Tags para eles. De Tags de Item, a Poção, a Encantamento, nada pode se esconder do &7Dicionário&r!"]
	quest.041365A540BF5A03.quest_subtitle: "Talvez sagrado..."
	quest.041365A540BF5A03.title: "&7Dicionário"
	quest.041CDB45450A67E0.quest_subtitle: "Combine Ovo de Gerador de Abelha de Platina com Ovo de Gerador de Abelha Ancestral"
	quest.041CDB45450A67E0.title: "Abelha de Duratium"
	quest.041D16DA96BC4253.quest_desc: [
		"Os &e&lPilares Polinizados&r são o que conecta os &e&lCampos Polinizados&r às &6&lParedes da Colmeia&r.\\nEles são uma boa mistura de ambos! Enormes paredes íngremes de &6Mel&r enquanto são cobertos com &ePólen&r!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_pollenpillar.png width:200 height:100 align:center}"
	]
	quest.041D16DA96BC4253.title: "&e&lPilares Polinizados"
	quest.041ED280691BB05D.quest_desc: ["&9Aço Gelado&r é um Minério comum nos Biomas Frios do &2&lUndergarden&r."]
	quest.041ED280691BB05D.quest_subtitle: "18"
	quest.041ED280691BB05D.title: "Armadura de &9Aço Gelado"
	quest.04212A285952402C.quest_desc: ["Corte-a jogando-a através da &6Serra Mecânica&r, operando uma &eSerraria&r ou &cForja de Fragmentos&r. Ou até processe através de uma &8Linha de Montagem&r completa! Além disso, tem Magia, Magia é sempre legal. \\n\\nO que quer que você faça, pegue suas &6Bolotas&r e corte-as ao meio."]
	quest.04212A285952402C.title: "Metade de &6Bolotas&r de Metal &6&lAllthemodium&r"
	quest.0450060852F290CA.quest_desc: [
		"As &9Terras Profundas&r são muito semelhantes ao &3Deep Dark&r. \\n\\nElas estão cheias de &3Sculk &fjuntamente com &3Emissores &fe &3Sensores&r, que sim, ainda podem gerar o &9&lWarden&r. \\n\\nAqui você também encontrará mais &3Criaturas de Sculk&r e Plantas, e até mesmo a única Estrutura que o &3&lOutro Lado&r possui!"
		"{image:atm:textures/questpics/deepndark/dnd_land.png width:200 height:100 align:center}"
	]
	quest.0450060852F290CA.title: "&9Terras Profundas"
	quest.0460DDEEFDEB0AAF.quest_desc: ["Varas de Adivinhação são nossas Ferramentas que usamos para contatar os espíritos para encontrar certos Itens.\\n\\nPrimeiro, você precisará selecionar o Bloco ou Item, seja Shift + Clicando com o Botão Direito nele com a Vara, ou criando a Vara com seu &eAlchemical Sulfur&r!\\n\\nAo segurá-las e segurar o Botão Direito, a Vara procurará por um Item selecionado. Ela fará um barulho e a Vara acenderá para indicar o quão perto o Bloco ou Item está.\\n\\nSe estiver perto o suficiente, um orbe pode aparecer mostrando o caminho para o Item."]
	quest.0460DDEEFDEB0AAF.title: "Varas de Adivinhação"
	quest.0465094C2D31B898.quest_subtitle: "Ferro + Creebee"
	quest.0465094C2D31B898.title: "&fAbelha de Uraninita"
	quest.04665EFC3A37250E.quest_desc: ["Mate 8 &7Traça&r."]
	quest.04695DA1BD3BF1B2.title: "Módulo de Dano Caótico"
	quest.046C417B2ADF3AA7.quest_desc: ["Os cartões têm seus limites. A Extração de Itens só pode extrair 8 itens por Operação. A Extração de Fluidos apenas 5 Baldes. Deus sabe com Químicos e Energia.\\n\\nIsso é &2&lMinecraft&r Moddado, esses limites não serão suficientes, precisamos fazer Overclock neles.\\n\\nJogue alguns Overclockers no canto superior direito do Cartão e ele aumentará o limite que eles podem transferir!"]
	quest.046C417B2ADF3AA7.quest_subtitle: "Máx: 4"
	quest.047F3F99035CE623.quest_subtitle: "Eu anseio pelas Minas"
	quest.0480DF316ACF12DA.quest_subtitle: "Tsuga do Oeste + Selva"
	quest.0484051446480B54.quest_desc: ["Causa muito dano e derruba árvores! O que mais você precisa?"]
	quest.0484051446480B54.title: "&6Machado de &5Liga de &3Allthemodium"
	quest.0496E8E786262464.quest_desc: ["Eu realmente preciso te explicar o &2Mundo Superior&r?"]
	quest.0496E8E786262464.title: "&2Mundo Superior&r: Terra de &m3 4&r 5 chefes"
	quest.0498A578D0EC3254.quest_desc: ["O último dos Itens Infundidos importantes é o &aCircuito de Controle Básico&r.\\n\\nEstes são feitos combinando 20mB de &4Redstone&r com um &7Barra de Ósmio&r.\\n\\nConfira a &cMissão da Liga Infundida&r para aprender como adicionar &4Redstone&r ao &9&lInfusor Metalúrgico&r!"]
	quest.0498A578D0EC3254.quest_subtitle: "O Circuito de Controle Básico"
	quest.0499A372F55D04C8.title: "Módulo de Velocidade de Projétil Dracônico"
	quest.04A1D582003A0D9A.quest_desc: [
		"Melhorias Válidas:"
		"- Run Speed"
		"- Walk Speed"
	]
	quest.04A7AA70C23830FF.quest_desc: ["Foices, ferramentas que podem ser usadas para limpar grandes quantidades de materiais orgânicos. As foices quebram blocos em uma área ao redor do bloco que você minera."]
	quest.04B31A600004F7CB.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.04B40BB107F14330.quest_desc: ["O &4Meat Shredder&r é uma arma corpo a corpo que você pode fazer de &4Witherita&r.\\n\\nEle tem dois ataques, usando o Clique Esquerdo ou o Clique Direito.\\n\\nQuando você Clica com o Esquerdo, ele usará o &4Meat Shredder&r como um Machado, acertando-os uma vez de uma distância razoável.\\n\\nQuando você Clica com o Direito, ele irá triturá-los repetidamente com sua Serra, causando Dano muito mais rápido de perto."]
	quest.04B40BB107F14330.quest_subtitle: "Direto da DLC de Fallout 3, The Pitt"
	quest.04B40BB107F14330.title: "&4Meat Shredder"
	quest.04B6E31120663EB2.quest_subtitle: "Nível: &a2"
	quest.04BE9F63E6003475.quest_desc: ["O &3GLP&r pode ser usado para fazer Plástico Derretido."]
	quest.04BE9F63E6003475.quest_subtitle: "O que precisamos"
	quest.04BE9F63E6003475.title: "GLP"
	quest.04BF68E4554D69AA.quest_desc: [
		"O último e melhor, Nível 8! Você precisará de 378 Blocos de Draconium Despertado e 786 Blocos de Barra de Draconium! Vale a pena?"
		"{image:atm:textures/questpics/draconic/draconic_core_8off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_8on.png width:100 height:100 align:1}"
	]
	quest.04BF68E4554D69AA.quest_subtitle: "Armazena: Quase Infinito"
	quest.04BF68E4554D69AA.title: "Nível 8"
	quest.04D0543FE2820F64.quest_desc: ["A Linha de Linho pode ser usada no lugar da Linha normal."]
	quest.04D0543FE2820F64.quest_subtitle: "Quem precisa de Aranhas, afinal?"
	quest.04D0543FE2820F64.title: "Linha de Linho"
	quest.04D0FAEF00F88A15.quest_desc: ["Lembra da &bEvolução&r por &3Troca&r? Deveria, foi a Missão logo antes desta! \\n\\nIsso funciona exatamente da mesma forma, mas alguns &cPokémon&r precisarão Segurar um Item enquanto são &3Trocados&r para poder &bEvoluir&r. \\n\\nSim, meus caros jogadores Solo, podemos usar o &3Linking Cable&r para simular a &3Troca&r. \\n\\nEu não vou listar cada &bEvolução&r que você pode obter com isso..."]
	quest.04D0FAEF00F88A15.title: "&3Trocando&r com um Item na Mão"
	quest.04D9F6587EF8D9B7.quest_desc: ["O &9Pote de Poções&r armazena até 100 poções. Você pode removê-las usando uma garrafa vazia ou um frasco de poção no pote.\\n\\nWixies usarão esses potes durante a Autocriação de Poções."]
	quest.04D9F6587EF8D9B7.quest_subtitle: "Armazenando Poções"
	quest.04DD3F761C210822.quest_desc: [
		"A &c&lForja de Fusão Crú&r é nossa forma bem simples (e crua) de produzir &8Aço&r. \\n\\nVocê precisará alimentá-la com um &7Lingote de Ferro&r e ou &0Carvão Vegetal&r ou &0Coque&r. \\n\\nCada &8Lingote de Aço&r leva 60 segundos para assar. &0Carvão Vegetal&r nos dá 15 segundos, enquanto &0Coque&r nos dá os 60 segundos completos. Estes também podem ser multiplicados com suas formas em Bloco. \\n\\nTambém obtemos Escória... é bem inútil."
		"{@pagebreak}"
		"Este é outro 3x3x3, agora com &cBlocos de Fusão&r."
		"{image:atm:textures/questpics/immersive/immersive_crude1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_crude2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_crude3.png width:100 height:100 align:center}"
		"Outra vez em que clicarmos com o botão direito no Bloco do Meio na Frente com o nosso confiável &6Martelo&r!"
		"{image:atm:textures/questpics/immersive/immersive_crude.png width:100 height:100 align:center}"
	]
	quest.04DD3F761C210822.title: "&l&cAlto-forno Primitivo"
	quest.04DEC6E210F06D65.quest_subtitle: "Balsa + Cocobolo"
	quest.05056CAA64E3971B.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Faz com que flechas disparadas pelo Arco apliquem um efeito de poção com base no seu Recipiente de Poção."
	]
	quest.050CCE5D1DD6B21E.quest_desc: [
		"Um dos &lMultiblocos&r mais importantes, principalmente porque precisamos dele para os outros &lMultiblocos&r. \\n\\nAqui você precisará de &bEntrada de Fluido&r (cada &bEntrada&r pode conter apenas 1 tipo de &bFluido&r, então você precisará de várias), &cEntrada de Energia&r, e Alçapões de Entrada e Saída de &eItens&r. \\n\\nUsando esses Alçapões, podemos inserir todos os &eItens&r, &bFluidos&r e &cEnergia&r e ele criará nossos Itens, como os outros &5Controladores Multibloco&r! \\n\\nOu criará nossos Itens necessários para as &6Partes Estelares&r! Você precisará de muito &4Sangue&f, &bAureal&f, Almas e &cEnergia&r para eles!"
		"{@pagebreak}"
		"{image:atm:textures/questpics/chap3/creative_forge1.png width:150 height:100 align:center}"
		"A primeira camada é bem simples. Apenas alguns &9Blocos de Pedra Sombria Polida &fe &9Escadas&r. Junto com os &7Blocos de Runas&r e &6Pedra Sombria Polida Arcana&r. Ah, espere, eu quase esqueci o Bloco mais importante! O &5Bloco de Forja&r"
		"{image:atm:textures/questpics/chap3/creative_forge2.png width:150 height:100 align:center}"
		"A próxima camada terá mais &9Pedra Escura&r em &9Blocos&f, &9Escadas&f e &9Lajes&r, e até &6Pedra Sombria Polida Arcana Dourada&r e &6Pedra Escura Arcana Polida Cinzelada&r. Não podemos esquecer os 4 &bObeliscos de Cristal Arcano&r!"
		"{image:atm:textures/questpics/chap3/creative_forge3.png width:150 height:100 align:center}"
		"Este é muito fácil! Apenas um quadrado de &9&lForja Nível 5 &6no centro com 8 &6Pedestais de Pedra Escura&r a 2 Blocos de distância."
		"{image:atm:textures/questpics/chap3/creative_forge4.png width:150 height:100 align:center}"
		"Vamos pular uma camada porque nada é adicionado lá! Em vez disso, com um Bloco de espaço entre eles. Coloque o &7Injetor Quântico&r acima da &9&lForja Nível 5 &6."
		"{image:atm:textures/questpics/chap3/creative_forge5.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/chap3/creative_forge6.png width:200 height:100 align:center}"
		"Por último, é colocar mais alguns Alçapões! Precisaremos deles!"
	]
	quest.050CCE5D1DD6B21E.title: "&c&lForja Automática de Hefesto"
	quest.050CD33E92601651.quest_desc: [
		"&c&lTier 1&r não é suficiente para você? Então, você precisará aprimorá-la!\\n\\nColoque uma Tábua de Edelwood no Slot central da &6&lForja&r e coloque 4 &bCristais Arcanos&r e 4 Sucatas de Spawner nos Pedestais.\\n\\nBata com um Martelo e seu &c&lTier 1&r será aprimorado para uma &3&lForja Tier 2&r!\\n\\nAgora, novos Rituais estarão disponíveis, a &6&lForja&r pode conter mais Essências, e você pode usar uma segunda Relíquia!"
		"{image:atm:textures/questpics/forbidden/forbidden_tier1.png width:100 height:100 align:center}"
	]
	quest.050CD33E92601651.title: "&6Forja &l&3Tier 2"
	quest.050D8480EE9D8E62.quest_desc: [
		"Florestas de Wigglewood são florestas como todas as outras.\\n\\nSó que estas Árvores gostam de ir como bem entendem."
		"{image:atm:textures/questpics/undergarden/undergarden_wiggle.png width:200 height:100 align:center}"
	]
	quest.050D8480EE9D8E62.title: "Floresta de Wigglewood"
	quest.0518551637F76C50.quest_desc: ["Para a melhoria &9Ecoante&r, precisaremos de alguns Itens diferentes.\\n\\Velas, que são relativamente fáceis de obter! E &9Fragmentos de Eco&r... que definitivamente não são...\\n\\nA melhor chance de obtê-los é saqueando uma &6Cidade Ancestral&r, mas você pode criá-los com alguns Rituais diferentes.\\n\\n(Ou até mais tarde com &5Encantamento&r!)\\n\\nA &9Estante Profunda Ecoante&r dará muito mais &5Arcana&r, com &515%&r! Além de aumentar o máximo de &aEterna&r para &a75&r."]
	quest.0518551637F76C50.title: "&9Estante Profunda Ecoante"
	quest.052BE1D845794702.quest_subtitle: "Teak + Acácia"
	quest.052E261F934AB439.quest_desc: ["Também pode fazer Caminhos!"]
	quest.052E261F934AB439.title: "Pá Caótica"
	quest.053483E3349B2F8A.quest_desc: [
		"Esta estrutura se parece com os Jardins Suspensos, mas há apenas um Jardim e ele é massivo. Você saberá que é o &bSantuário Sempiterno Azul&r pelo &bAzul&r na &bCera Ancestral Luminescente&r.\\n\\nEntre na estrutura e siga o caminho para a sala inferior (cuidado com os Vigias Sentinelas), lá você encontrará &bEssência Azul&r.\\n\\nEntre nela e prepare-se para prender a respiração. Você precisará lutar contra hordas de Afogados, Guardiões e Guardiões Anciões debaixo d'água. Quando todos estiverem mortos, você receberá..."
		"{image:atm:textures/questpics/bumblezone/bumble_blue1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_blue2.png width:200 height:100 align:center}"
	]
	quest.053483E3349B2F8A.title: "&bSantuário Sempiterno Azul"
	quest.0539AF15A10B2859.quest_desc: ["As &lMáquinas Compactas&r permitem que você entre em uma dimensão compactada. Depois de colocar uma &lMáquina Compacta&r, você pode entrar nela usando o Dispositivo de Encolhimento Pessoal.\\n\\nO tamanho da &lMáquina Compacta&r depende da receita, variando de 5x5x5 a 45x45x45!\\n\\nVocê não pode quebrar as paredes da &lMáquina Compacta&r, e pode sair clicando com o botão direito no Dispositivo de Encolhimento Pessoal."]
	quest.0539AF15A10B2859.title: "&lMáquinas Compactas"
	quest.05422E444126FDA6.quest_subtitle: "Ferro + Blaze"
	quest.05422E444126FDA6.title: "&fAbelha de Ferro Carmesim"
	quest.05428EA120583BD0.quest_subtitle: "Feito com energizador"
	quest.05428EA120583BD0.title: "&fAbelha de Cristal Nitro"
	quest.0542FE108089A0A2.quest_desc: ["&l&6Theurgy&r é a arte de usar Magia para Alquimia! Ou, em nosso sentido, usar Máquinas e Itens para fazer mais ou diferentes Itens!\\n\\nMuitas das Máquinas que precisamos para &l&6Theurgy&r precisam de Cobre, então comece por aí!"]
	quest.0542FE108089A0A2.title: "&l&6Theurgy"
	quest.054F3A0499F8A0D8.quest_subtitle: "Castanha-doce + Cupuaçu"
	quest.056E1E3B1ED14917.quest_subtitle: "Teca + Carvalho Escuro"
	quest.0573B6F1BE5110FD.quest_desc: ["As Abelhas do &2&lMinecraft&r são adoráveis, mas as coisas limitadas que o Mel nos dá não justificam o trabalho para obtê-lo.\\n\\nBem, a menos que você possa obter quase tudo das Abelhas, então seria diferente!"]
	quest.0573B6F1BE5110FD.title: "&e&lProductive Bees&r"
	quest.0576C32B0FB360B0.quest_desc: [
		"A Monstruosidade Lunar tem 200 Corações e só receberá 1 de dano por golpe, a menos que você use Fogo.\\n\\nEla tem alguns ataques, incluindo Espinhos do Chão, Projéteis e Cabeças Emaranhadas Explosivas!\\n\\nQuando você a mata, ela dropa Flechas, Barras, Tangled Skulls, Pétalas Tenazes, Almas Aprisionadas e uma chance de uma Arma rara!"
		"{image:atm:textures/questpics/eternal/starlight_lunar.png width:100 height:125 align:center}"
	]
	quest.0576C32B0FB360B0.title: "Monstruosidade Lunar"
	quest.0583862ED0114442.quest_subtitle: "&f4 de &cДano de Ataque"
	quest.0584073A7383E0EA.quest_desc: [
		"Algumas das Missões da &5Abelha Rainha&r podem parecer irritantes porque não há muitos lugares para farmar &dEndermites&r e &7Traça&r.\\n\\nBem, não havia até as atualizações recentes! Bem-vindo à Fortaleza dos Ácaros!\\n\\nNas enormes estruturas pontiagudas de &7Pedra&r você encontrará &7Traça&r em abundância (além de saques, especialmente dentro da &5Obsidiana&r).\\n\\nNo meio da estrutura, com tudo de cor &5Roxa&r, haverá &dEndermites&r.\\n\\nA propósito, você sabia que as &8A&6b&8e&6l&8h&6a&8s&r atacarão &dEndermites&r e &7Traça&r! Entre na batalha com elas para conquistar o coração de sua &5Rainha&r!"
		"{image:atm:textures/questpics/bumblezone/bumble_mite.png width:200 height:100 align:center}"
	]
	quest.0584073A7383E0EA.title: "Fortaleza dos Ácaros"
	quest.05850541675B2493.quest_desc: ["Sim.\\n\\nVocê criou a &6&lEstrela ATM&r, isso significa que você zerou o modpack!\\n\\nE agora?"]
	quest.05850541675B2493.quest_subtitle: "Isso significa que você venceu?"
	quest.05850541675B2493.title: "&6&lEstrela ATM"
	quest.0591CAFD665CE151.quest_subtitle: "Nível: &b4"
	quest.0596F6C70758EEC0.quest_desc: ["Apesar de serem os mais caros, também são os mais bonitos!\\n\\nE é isso que importa para as Construções!"]
	quest.0596F6C70758EEC0.title: "&7Blocos de &fMetal&r \\& &bGemas"
	quest.05A4496705B6C6AF.quest_desc: [
		"Os Beehemoths são &6A&8b&6e&8l&6h&8a&6s&r únicas que são mais semelhantes a um Cavalo Voador Selvagem.\\n\\nEles podem ser domados alimentando-os com &6Mel&r líquido, seja em uma Garrafa ou Balde.\\n\\nEles têm um nível de amizade que determina se são domados por você e quão rápido eles vão e quanta saúde eles têm! Alimentá-los fará o nível subir, enquanto se eles sofrerem dano, o nível diminuirá.\\n\\nUma vez que o nível de amizade esteja no máximo, eles se tornarão uma &5Abelha Rainha Beehemoth&r!\\n\\nEles seguirão &6Baldes de Mel&r como Vacas seguem Trigo (tente também usar Geleia Real com eles)."
		"{image:atm:textures/questpics/bumblezone/bumble_beehemoth.png width:100 height:100 align:center}"
	]
	quest.05A4496705B6C6AF.title: "Beehemoth"
	quest.05B0A7D0B991050F.title: "Reator (Reforçado)"
	quest.05B5E640F1B68A28.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_golem.png width:100 height:150 align:center}"]
	quest.05B5E640F1B68A28.title: "&3Aço de Golem&r"
	quest.05B6DB75AEC01187.quest_desc: ["O RFTools Power tem &9Células de Energia&r para armazenar energia, que são unidades de armazenamento multibloco que podem ser personalizadas e aprimoradas para armazenar energia.\\n\\nVocê precisará de uma Chave Inglesa para determinar as entradas e saídas de energia."]
	quest.05B6DB75AEC01187.title: "&9RFTools Power: &cCélulas de Energia"
	quest.05D8C6EF8FCD6250.quest_desc: [
		"Geleia Primogel é o primeiro nível de geleia adicionado pelo JDT e requer materiais básicos do Mundo Superior para ser criada."
		""
		"Criações Desbloqueadas:"
		"- Ferricore"
		"- Carvão Primal"
		""
		"Exemplo de Espalhamento de Geleia:"
		""
		"{image:atm:textures/questpics/justdirethings/goo_spread_ferricore.png width:200 height:200 align:center}"
	]
	quest.05DA7F48E2A1B77F.quest_desc: ["Conheça o &a&lRobit&r! Ele é seu novo Companheiro Robótico! \\n\\nColoque-o sobre uma &aChargepad&r para definir o local como seu Lar! Isso é importante, pois o &a&lRobit&r precisa de &aEnergia&r para se mover e trabalhar. Ele pode armazenar 40kFE. \\n\\nPodemos Clicar com o Botão Direito nele para abrir sua INTERFACE (com a permissão dele, é claro!). No meio, veremos uma Tela que nos informa fatos sobre ele: seu Nome, sua &aEnergia&r, sua Função e seu Dono! \\n\\nNa esquerda, temos alguns Botões. Em ordem, de Cima para Baixo: Teleportar para o Lar o levará para sua &aChargepad&r, Renomear altera seu Nome de Mob, e Aparência são itens cosméticos para o &a&lRobit&r! \\n\\nAbaixo do &aSlot de Energia&r, há Botões para definir sua Função. Coletar: permitirá que o &a&lRobit&r colete &eItems&r do chão e os coloque em seu Inventário. Seguir: fará com que o &a&lRobit&r siga você ou pare onde ele está. \\n\\nNa extrema direita, há ainda mais Botões! O primeiro abrirá o menu principal do &a&lRobit&r. Criação abrirá uma Bancada de Trabalho dentro do &a&lRobit&r! Inventário abrirá o Inventário do &a&lRobit&r. Aqui você pode armazenar &eItems&r ou para onde os &eItems&r coletados irão. Fundir usará &aEnergia&r para Fundir &eItems&r como uma Fornalha. Reparar permitirá que você combine dois &eItems&r para Reparar sua Durabilidade."]
	quest.05DA7F48E2A1B77F.quest_subtitle: "Ele não late, mas te segue pra todo lado! 🤖"
	quest.05DA7F48E2A1B77F.title: "&a&lRobit"
	quest.05DE9E1CDFBC22DE.quest_desc: ["As &dFlechas Dispersoras do Vazio&r são Criadas com uma Flecha Espectral e uma &dMandíbula do Vazio&r.\\n\\nElas podem ser disparadas por qualquer Arco ou Besta. Quando atingem qualquer Mob ou Bloco, elas se quebram.\\n\\nQuando se quebram, muitas partes são lançadas pela área, danificando o que quer que atinjam!"]
	quest.05DE9E1CDFBC22DE.title: "&dFlechas Dispersoras do Vazio"
	quest.05E668CE6687AC64.quest_desc: ["O &bSímbolo da Alegria&r é o primeiro Símbolo que você deve criar, os símbolos são materiais de criação importantes para itens no &aNature's Aura&r."]
	quest.05E668CE6687AC64.title: "&bSímbolo da Alegria"
	quest.05F428C34DD00B61.quest_subtitle: "Céu Azul + Salgueiro Ondulante"
	quest.05F8458AB4A6950B.quest_subtitle: "Alimente a Gosma Voidshimmer para a Abelha Diamante"
	quest.05F8458AB4A6950B.title: "&fAbelha de Celestigem"
	quest.06044B4452A6B720.quest_desc: ["Quando colocado em um Bioma do Deserto, o Ninho de Areia atrairá a Abelha Mineira de Chocolate ou a Cinzenta."]
	quest.06044B4452A6B720.quest_subtitle: "Atrai abelhas em Biomas do Deserto"
	quest.06044B4452A6B720.title: "&fNinho de &eAreia"
	quest.06094615950AC062.title: "Outras Melhorias de Esteira"
	quest.061A51A0EC13CA0F.quest_desc: ["Agora que temos um &aControlador&r, &bDrenos&r e &4Tanques&r, precisaremos de mais alguns Blocos.\\n\\nPrimeiro, são as &6Bobinas de Aquecimento de Líquido&r. Elas formarão o chão da &c&lFundição&r e são necessárias para aquecer a &c&lFundição&r.\\n\\nPor último, são as Janelas da &c&lFundição&r ou &cTijolos Refratários&r. São eles que usaremos para o resto da estrutura! Os blocos de construção, literalmente.\\n\\nA &c&lFundição&r não precisará da estrutura construída, então cada canto pode permanecer vazio; mas deve ter 4 Paredes e um Chão para ser concluída. O &aControlador&r lhe dirá onde falta um Bloco, se houver um.\\n\\nA &c&lFundição&r pode ser tão pequena quanto 1x1 por dentro, desde que tenha um &aControlador&r, &6Bobinas de Aquecimento de Líquido&r e as outras Paredes preenchidas!\\n\\nNão recomendo fazer uma tão pequena, no entanto, pois quanto maior a &c&lFundição&r, mais espaço ela tem!\\n\\nVocê saberá que a &c&lFundição&r está construída quando o &aControlador&r acender como uma Fornalha e as &6Bobinas de Aquecimento de Líquido&r ficarem &6Laranja&r."]
	quest.061A51A0EC13CA0F.title: "Construindo a &c&lFundição&r"
	quest.06210B6FD0F9989B.quest_desc: ["O &d&lTier Supremo&r é o melhor que podemos obter do &5&lMekanism&r! Bem, pelo menos no Sobrevivência.\\n\\nEstes darão o maior número de Slots, conterão o maior número de &eItens&r e moverão o maior número de &eItens&r!\\n\\nCada &d&lNível Supremo&r precisará de &dLigas Atômicas&f, &dCircuitos de Controle Supremos&f e &bDiamantes&r.\\n\\nAs &dLigas Atômicas&r precisarão de &5Obsidiana Refinada&r para serem criadas, siga a &7Missão do Compressor de Ósmio&r para obtê-las. Mas basicamente, precisaremos Infundir uma &bLiga Reforçada&r com 20mb de &5Obsidiana Refinada&r.\\n\\nEntão, combine 2 &dLigas Atômicas&r com 1 &bCircuito de Controle de Elite&r para fazer o &dCircuito de Controle Supremo&r!"]
	quest.06210B6FD0F9989B.title: "&d&lTier Supremo"
	quest.062AA943A1629A86.quest_desc: ["Você explodiu a &zFornalha de Arco-íris&r?!?! Apenas colocou TNT bem ao lado dele? Você ficou louco? Isso levou tantas Fornalhas e recursos e você simplesmente explodiu isso!!! Pelo menos você conseguiu algo bom com isso? &zCarvão de Arco-íris&r? Carvão que dura muito tempo? Na verdade, isso vale a pena."]
	quest.062AA943A1629A86.title: "&zCarvão de Arco-íris"
	quest.063241B72BB3403E.quest_desc: ["O &0&lEscudo de Chapas Pesadas&r é usado como um Escudo normal, segure-o em sua Mão Secundária e use-o para se defender.\\nO &0&lEscudo de Chapas Pesadas&r tem muito mais Durabilidade e protege de mais Dano.\\n\\nAh, sim, ele também tem Melhorias! Essas melhorias podem ser adicionadas com a &6Bancada do Engenheiro&r.\\n\\nO Escudo pode conter 2 Melhorias."]
	quest.063241B72BB3403E.title: "&8&lEscudo de Chapas Pesadas"
	quest.0650996C7818ADB5.quest_desc: ["O &6&lGerador a Calor&r tem 2 modos para gerar &aEnergia&r.\\n\\nPassivo: Cercar o &6&lGerador&r com &cFontes de Lava&r ou blocos fluindo cria &aEnergia&r passiva, gerando &cCalor&r.\\n\\nColoque uma &cFonte de Bloco de Lava&r no topo e deixe fluir pelas laterais.\\n\\nCertifique-se de conectar &bCanos&r primeiro!\\n\\nAtivo: Colocar materiais combustíveis como &0Carvão&r ou &6Madeira&r no &6&lGerador&r queimará o combustível para criar &aEnergia&r.\\n\\nAgora ele cria 320FE/t."]
	quest.0650996C7818ADB5.quest_subtitle: "Geração de Energia Básica"
	quest.0650996C7818ADB5.title: "&6&lGerador a Calor"
	quest.065196033249A0AA.quest_subtitle: "Combine Bipolímero Bruto com um Ovo de Gerador de Abelha de Ferro"
	quest.065196033249A0AA.title: "&fAbelha de Bioaço"
	quest.0661E9669E639621.quest_desc: ["Algumas mudas não podem ser polinizadas. Essas mudas têm uma chance aleatória de crescer em outra árvore.\\n\\nPor exemplo, se você quiser obter uma &4Muda de Murta-de-crepe Vermelha&r, primeiro cultive uma Muda de Murta-de-crepe Roxa. Você terá uma chance de obter uma &4Árvore de Murta-de-crepe Vermelha&r a partir dela.\\n\\nA chance de mutação é baixa, então continue cultivando a árvore repetidamente."]
	quest.0661E9669E639621.quest_subtitle: "Autoreprodução?"
	quest.066B8A75B299AED8.quest_desc: [
		"O &9&lEspremedor&r é uma Máquina simples que espreme &eItens&r para fazer outros &eItens&r ou &bFluidos&r.\\n\\nPodemos usar as 2 Portas na parte de trás para &9Entrada de &eItens&r. Precisaremos então usar a Porta do lado direito dos Barris para &6retirar&r &eItens&r. A Porta abaixo dessa &6Saída de &bFluidos&r.\\n\\nIsso será usado principalmente para espremer Óleo Vegetal de Sementes de Culturas como Sementes de Trigo ou Sementes de Cânhamo!\\n\\nAlgumas Sementes dão mais Óleo, verifique o &6Guia&r para ver o que cada uma dá.\\n\\nTambém precisaremos usar o &9&lEspremedor&r para obter &0Pó de Grafite HOP&r de 8 &0Pó de Coque&r."
		"{@pagebreak}"
		"Literalmente o mesmo começo que o &2&lFermentador&r."
		"{image:atm:textures/questpics/immersive/immersive_squeezer1.png width:100 height:100 align:center}"
		"Assim como o &2&lFermentador&r também, só que em vez de Caldeirões, use Barris!"
		"{image:atm:textures/questpics/immersive/immersive_squeezer2.png width:100 height:100 align:center}"
		"Acima do Barril, entre o &eBloco de Engenharia Leve&r e o &4Bloco de Engenharia de Redstone&r, coloque um Pistão. Em cima dos outros 3 Barris, coloque &8Cerca de Aço&r!"
		"{image:atm:textures/questpics/immersive/immersive_squeezer3.png width:100 height:100 align:center}"
		"Clique com o botão direito do &6Martelo&r no barril abaixo do pistão, muito fácil."
		"{image:atm:textures/questpics/immersive/immersive_squeezer.png width:100 height:100 align:center}"
	]
	quest.066B8A75B299AED8.title: "&9&lEspremedor"
	quest.066F78936C8F943B.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.0672462DA3599484.quest_subtitle: "512.000mb"
	quest.06767BA0AFE8C1EE.quest_desc: ["1... 2... há um 4 em algum lugar também.\\n\\nPara definir um Número, coloque o Item e então você pode Clicar com o Esquerdo ou Direito para mudar a quantidade. Shift e faça o mesmo para ir de 10 em 10. Quando tiver um Número definido, jogue-o em um Cartão!\\n\\nEle então esperará até que o Número definido de Itens esteja lá para começar a pegar Itens. Ele também deixará essa quantidade no primeiro Inventário."]
	quest.067AB3E4C4492F0D.quest_desc: [
		"Não quer mais minerar um monte de Minérios que você pegou? Por que não deixar os Roteadores fazerem isso por você?\\n\\nVocê pode usar um Colocador para colocar os Minérios, e então deixar um Quebrador Encantado minerar os Minérios. O Quebrador precisa que a Picareta usada para criá-lo seja Encantada primeiro, o Módulo em si não pode ser Encantado.\\n\\nVocê pode precisar de outro Roteador para pegar os Minérios dropados."
		"{image:atm:textures/questpics/router/router_break.png width:150 height:80 align:center}"
	]
	quest.067AB3E4C4492F0D.title: "Roteadores para Mineração"
	quest.068128395837AF4F.quest_subtitle: "Igual ao do vapor"
	quest.068128395837AF4F.title: "&5Misturador Elétrico"
	quest.068294A7C21DE550.quest_desc: ["&cKits de Trilhos&r são usados para criar com &6trilhos&r para fazer &6trilhos&r especiais.\\n\\nEsses &6trilhos&r serão úteis para tudo relacionado a &5Trens&r, como: parar o &5Trem&r, mover o &5Trem&r e emitir redstone."]
	quest.068294A7C21DE550.title: "&c&lTrilhos&r!"
	quest.0682DC1F2417DAEB.quest_desc: ["Functional Storage é um mod de armazenamento que adiciona vários itens úteis para ajudar com o armazenamento e maneiras de armazenar pilhas dos mesmos itens.\\n\\nIsso pode ser útil para itens como Pedregulho, Terra e mais."]
	quest.0682DC1F2417DAEB.quest_subtitle: "Parente Distante das Gavetas de Armazenamento"
	quest.0682DC1F2417DAEB.title: "Functional Storage"
	quest.0691BDE968724213.quest_subtitle: "Feito na Fundição de Ligas"
	quest.0691BDE968724213.title: "&fAbelha de Liga Vibrante"
	quest.06A7A3FC8634D2DA.quest_subtitle: "Tier: &c5"
	quest.06AC44758A00C280.quest_desc: [
		"Aumento de nível para 21. "
		""
		"Pode ser encontrado aleatoriamente em &9Ginásios&r que geram em &a#minecraft:village&r"
	]
	quest.06AC44758A00C280.title: "&aLíder Brock"
	quest.06AD25DB96F3A1CC.quest_desc: [
		"Como um Termômetro, estes contêm &cMercúrio&r!\\n\\nSejam &cCristais de Mercúrio&r ou &cFragmentos&r, ele contém &cMercúrio&r."
		"{image:atm:textures/questpics/theurgy/theurgy_vessel_1.png width:100 height:125 align:center}"
	]
	quest.06AD25DB96F3A1CC.title: "Recipiente de &cMercúrio&r"
	quest.06B182C3FCCA6C02.quest_desc: ["&cNetherita&r é único entre todos os minérios do &2&lMinecraft&r. \\n\\nPrimeiro, minere &cDetritos Ancestrais&r. Eles são gerados por todo &c&lO Nether&r, mas é mais seguro minerar profundamente abaixo da superfície por causa dos &cLagos de Lava&r. \\n\\nDepois, funda &cDetritos Ancestrais&r para obter &cSucata Ancestral&r. Combine 4 &cSucatas Ancestrais&r com 4 &eLingotes de Ouro&r para fazer um &eLingote de Netherita&r! \\n\\nEspere, nosso trabalho ainda não acabou. Precisamos do &cMolde de Ferraria de Melhoria de Netherita&r. Estes são gerados em baús em Bastiões de Piglin..."]
	quest.06B182C3FCCA6C02.title: "Obtendo &cNetherita"
	quest.06B352AE90DD0D3E.quest_desc: ["Uma &8Abelha de Blaze&r polinizando um &4Ovo de Gerador de Abelha Obsidiana&r irá convertê-lo em um &2Ovo de Gerador de Abelha Infinita&r."]
	quest.06B352AE90DD0D3E.title: "&fAbelha do Infinito"
	quest.06B6786122F3DAF9.quest_desc: ["Afeta o momento do dia em que uma abelha pode trabalhar. Existem 3 níveis disso: &aDiurno&r, &dNoturno&r, &cMetaturno&r. Abelhas &aDiurno&r só podem trabalhar durante o dia, abelhas &dNoturno&r só podem trabalhar durante a noite e abelhas &cMetaturno&r podem trabalhar em qualquer momento do dia. &cMetaturno&r é o que estamos procurando. A BeeBee naturalmente possui o traço &cMetaturno&r, mas, como mencionado na missão &a&lProductivity&r, ela está de férias, então precisaremos buscar algumas medidas alternativas.\\n\\nPrecisaremos laçar algumas abelhas em uma cerca durante a noite para torná-las &dNoturno&r, e depois deixar essas abelhas em uma cerca durante o dia para torná-las &cMetaturno&r. Podemos pular uma dessas etapas com uma Abelha Fantasmagórica ou Abelhas Cogumelos, que são naturalmente &dNoturno&r."]
	quest.06B6786122F3DAF9.quest_subtitle: "O sono é para os fracos!"
	quest.06B6786122F3DAF9.title: "&e&lComportamento"
	quest.06B9D8973E9C6A2C.quest_desc: ["Você pode estar se perguntando: Por que há um item do Ars Nouveau no capítulo do Occultism? Isso é porque temos o Ars Ocultas, para unir os dois mods. Particularmente, Espíritos, como nosso Triturador Foliot, podem trabalhar nessas jarras. Você pode até inserir itens nas jarras via tubos para os espíritos interagirem, e eles os enviarão para inventários adjacentes (descobri que a parte inferior da jarra é o lugar mais confiável para onde eles enviam). Se eles não puderem enviar para um inventário, eles jogarão os itens no mundo."]
	quest.06B9D8973E9C6A2C.quest_subtitle: "Espíritos podem trabalhar em Jarras de Contenção"
	quest.06B9D8973E9C6A2C.title: "Ars Ocultas: Jarras de Espírito"
	quest.06D13E319C26C949.quest_desc: [
		"O Pântano de Cogumelos de Sangue é o lar dos gigantes Cogumelos de Sangue.\\n\\nSangue me deixa desconfortável, então acho que vou manter esta descrição curta."
		"{image:atm:textures/questpics/undergarden/undergarden_blood.png width:200 height:100 align:center}"
	]
	quest.06D13E319C26C949.title: "Pântano de Cogumelos de Sangue"
	quest.06EA86F9F6C9DECF.quest_subtitle: "Ameixa + Pêssego"
	quest.06EAA74E0A10CBB6.quest_subtitle: "Alcance: &b36&r Blocos"
	quest.06EAA74E0A10CBB6.title: "&9Aceleradores de Crescimento de Imperium"
	quest.06F84E2C484FAC5B.quest_desc: ["Já ouviu falar de um gerador de pedregulho? A Fábrica de Cantaria funciona como um, mas leva isso para o próximo nível. Você pode configurá-la para triturar pedra em cascalho, areia, silício, pode configurá-la para fundir em pedra, pode fazer Obsidiana com ela, e qualquer outra coisa que o JEI mostrar para esta máquina."]
	quest.06FFBB12CFA87815.quest_desc: ["Os Troncos do &2Vanilla &lMinecraft&r, encontradas nos diferentes Biomas &2Vanilla&r!\\n\\nNão preciso explicar mais do que isso!"]
	quest.06FFBB12CFA87815.title: "&fTroncos do &2Vanilla&r"
	quest.07016F654CFFAA20.quest_desc: [
		"Se você quer uma surpresa sobre qual &6Fóssil&r dá o quê, então não vire a página!"
		"{@pagebreak}"
		"&eFóssil Espiral&r - &6Oma&bnyte&r \\n&eFóssil Cúpula&r - &6Kab&buto&r \\n&6Fóssil de Âmbar Velho&r - &6Aero&9dactyl&r \\n&aFóssil Raiz&r - &6Lil&2eep&r \\n&aFóssil Garra&r - &6Ano&arith&r \\n&cFóssil Crânio&r - &6Cranidos&r \\n&cFóssil Armadura&r - &6Shiel&7don&r \\n&5Fóssil Casca&r - &9Tirt&6ouga&r \\n&5Fóssil Pluma&r - &6Arc&9hen&r \\n&7Fóssil Mandíbula&r - &6Tyr&9unt&r \\n&3Fóssil Crista&r - &6Ama&bura&r "
		"{@pagebreak}"
		"Os últimos 4 &6Fósseis&r funcionam de forma diferente. Você precisa combinar 2 desses &6Fósseis&r para obter 1 &cPokémon&r. \\n\\n&6Pássaro&r + &aDracônico&r = &eDraco&9zolt&r \\n&6Pássaro&r + &5Dino&r = &eArcto&bzolt&r \\n&bPeixe&r + &aDracônico&r = &bDraco&9vish&r \\n&bPEIXE&r + &5Dino&r = &bArctovish&r"
	]
	quest.07016F654CFFAA20.title: "&6Fósseis"
	quest.07084582F9562740.quest_desc: ["&5&lMekanism&r tem algumas &5Máquinas&r feitas especialmente para Coloração! \\\\n\\\\nExistem 3 &5Máquinas&r que precisaremos usar, e sim, em ordem! \\\\n\\\\nO &c&lExtrator de Pigmento&r vai extrair a Cor dos Blocos &cC&e&ao&bl&6o&5r&3i&1d&4o&r e criar um Pigmento! Pigmentos são &cQuímicos&r e são usados como outros &cQuímicos&r: movidos por &cTubos&f e armazenados em &cTanques Químicos&r. \\\\n\\\\n&e&lMisturador de Pigmento&r combinará 2 Pigmentos em um novo Pigmento de Cor. Isso pode até criar novas Cores feitas para &5&lMekanism&r &eItens&r! \\\\n\\\\n&b&lMáquina de Pintura&r vai usar esses Pigmentos e aplicá-los em Blocos e Itens que podem ser &cC&e&ao&bl&6o&5r&3i&1d&4o&r, para &cC&e&ao&bl&6o&5r&3i&1d&4o&r-los. Isso até funciona em Itens que já estão &cC&e&ao&bl&6o&5r&3i&1d&4o&r, você &4não&r consegue fazer isso no &2&lMinecraft Vanilla&r!"]
	quest.07084582F9562740.quest_subtitle: "Cores de montão!"
	quest.07084582F9562740.title: "&cC&eo&ar&be&ds&r e Pigmentos"
	quest.0709CE22181A74BB.quest_desc: ["A 3ª pessoa a derrotar é o &a&lMitinho Player&r. \\nBasta procurar por uma &aEsmeralda&r nas costas da skin dele, isso ajudará você a encontrá-lo. \\n\\nAlém disso, nem todos os Criadores de Conteúdo têm o inglês como língua primária! É verdade, o &6&lATM&r se espalha além da barreira linguística!"]
	quest.0709CE22181A74BB.title: "&a&lMitinho Player"
	quest.070CAEAD49B8DBA3.quest_desc: ["Por 8 Pilhas de &7Blocos de Ferro Comprimido&r e uma &6&lEstrela ATM&r você pode obter o &5Bloco de Ferro Comprimido &7Criativo&r!\\n\\nEste pode ser definido para qualquer temperatura que você queira, que pode então ser usada em suas Máquinas.\\n\\n8 Pilhas de &7Blocos de Ferro Comprimido&r equivalem a 4.608 &7Barras de Ferro Comprimido&r... boa sorte!"]
	quest.070CAEAD49B8DBA3.title: "&5&lBlocos de Ferro Comprimido &7Criativos"
	quest.070F8045CC14B50D.title: "Módulo de Penetração de Projétil Dracônico"
	quest.072329284468B14C.quest_desc: ["O último cara a derrotar da Região de Borrius, &6Treinador Blue&r. \\\\n\\\\nSe você jogou &4&oRadical Red&r, deve se lembrar do &6Treinador Red&r, ele é muito parecido. \\\\n\\\\nEle é um Lutador Opcional, então não possui um Item de Assinatura, em vez disso, você precisa encontrá-lo em certos Biomas, também com Cidades do End. \\\\n\\\\nSe você conseguir derrotá-lo, receberá toneladas de Recompensas, além de se tornar a Lenda de Borrius!"]
	quest.072329284468B14C.title: "&6Treinador Blue"
	quest.072FBEB0F6F1BC48.quest_desc: ["Usado para ligar Gavetas a um Controlador e para ligar Gavetas do End.\\n\\nPara ligar Gavetas ao Controlador, clique com o botão direito no bloco do Controlador para iniciar a configuração. Clicar com o botão direito nas Gavetas as adicionará à rede.\\n\\nSegurar a ferramenta mostrará quais Gavetas estão conectadas ao Controlador."]
	quest.07392142A0166032.quest_desc: [
		"Preservado no tempo jazem os restos de um Esqueleto Preservado. \\n\\nAo redor dos Ossos haverá &7Cascalho Suspeito&f e &eAreia&r. "
		"{image:atm:textures/questpics/pokemon/find_skeleton.png width:200 height:100 align:center}"
	]
	quest.07392142A0166032.title: "Esqueleto Pré-histórico Preservado"
	quest.073BA8470EA37A00.quest_desc: [
		"Outro Mar, só que este é muito mais frio."
		"{image:atm:textures/questpics/undergarden/undergarden_icy.png width:200 height:100 align:center}"
	]
	quest.073BA8470EA37A00.title: "Mar Gelado"
	quest.0741FABE57CA1A7D.quest_desc: ["&9Hippocamtus&r são poderosos guerreiros Cavalo-marinho que guardam &9Acropolis&r. \\n\\nEles usam muita Armadura e seguram uma Lança e um Escudo. \\n\\nEles têm 85 &4Corações&r e 18 Pontos de Armadura. \\n\\nO Escudo deles irá proteger contra Dano e a Lança será usada para te Matar. Eles podem balançar, esfaquear e até fazer um movimento especial em você. Esse movimento vai te prender no lugar onde o &9Hippocamtus&r vai te esfaquear repetidamente. \\n\\nAssim como o &9Cindaria&r, estes vão soltar &9Lacrima&r."]
	quest.0741FABE57CA1A7D.title: "&9Hippocamtus"
	quest.074EC1E636CD6605.quest_desc: ["A &cArmadura de Netherita&r é o melhor que o &l&2Vanilla&r pode oferecer. Ela tem os mesmos Pontos de Armadura que a de &bDiamante&r, mas mais Resistência de Armadura.\\n\\nProvavelmente porque você precisa de &bDiamante&r para fazê-la!"]
	quest.074EC1E636CD6605.quest_subtitle: "20"
	quest.074EC1E636CD6605.title: "Armadura de &cNetherita"
	quest.07564DBB023EE2A6.quest_subtitle: "Nível: &b4"
	quest.0759CA52EECF3B49.quest_desc: ["O &6Arado Mecânico&r arará através de qualquer coisa em seu caminho! Bem, que ele possa mover, pelo menos.\\n\\nBlocos com conexões fracas quebrarão imediatamente quando o &6Arado&r os atingir. Blocos como Tochas, Botões e Vinhas.\\n\\nQuando usado sobre Terra ou Grama, ele fará Farmland! Perfeito para Mega-Fazendas!\\n\\nVocê também pode usar o &6Arado&r para mover Mobs sem matá-los. Bem, o &6Arado&r não os matará, o que quer que eles atinjam pode matar."]
	quest.0759CA52EECF3B49.title: "&6Arado Mecânico"
	quest.07655CA904354E9E.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:"
		""
		"Quebra grama e flores próximas quando ativado."
	]
	quest.076A648E3E3245C9.quest_desc: ["Taxa muito rápida de geração de Energia a partir de Combustível, o que o torna muito eficiente. O único problema é que não pode mais ser atualizado. Ainda usa Combustível de Fornalha normal."]
	quest.076A648E3E3245C9.title: "&aGerador de Esmeralda"
	quest.077216EA10FA4AA4.quest_desc: [
		"Dependendo se suas Chapas estão Carimbadas ou não determina qual Máquina você pode usar. \\n\\nSe estiver Carimbada, você pode usar a &6Prensa Mecânica&r para fazer as &7Bases de Bola&r. \\n\\nSe não, tente estas!"
		"{@pagebreak}"
		"A &8Linha de Montagem&r conecta diferentes Máquinas de Montagem para trabalharem juntas no processamento de Itens. \\n\\nColoque o Controlador de Montagem, Broca de Montagem e as Unidades de Entrada e Exportação para criar nossa Linha de Montagem. \\n\\nVocê também precisará de Baús ao lado das Unidades de Entrada e Exportação para os Itens. \\n\\nQuando estiver pronto, dê um pouco de Pressão ao Controlador de Montagem e ele começará a funcionar. "
		"{@pagebreak}"
		"A &5Forja Atômica&r é uma máquina da &6&lOritech&r muito chique. \\n\\nColoque a &5Forja&r e cerque-a com Estruturas de Máquina. Então, clique com o Botão Direito na &5Forja&r para construí-la. \\n\\nA &5Forja Atômica&r não recebe &cEnergia&r de forma normal, porque por que seria fácil? Em vez disso, você precisará de &2Lasers Enderic&r! \\n\\nConstrua um &2Laser Enderic&r, ligue-o, então use um Designador de Alvo com Shift + Botão Direito tanto na &5Forja&r quanto no &2Laser&r para configurá-lo."
	]
	quest.07751E1BE48C6024.quest_subtitle: "Nível: &b4"
	quest.07753C5D94312A50.quest_desc: [
		"&3Aumento&r: Gerador é o oposto do &3Aumento&r: Fábrica, em vez de usar Energia para Fundir, ele Funde para Energia. Você não fundirá mais itens nele, todo o Combustível usado será transformado em Energia!"
		""
		"(Me pergunto se é melhor conectar um Gerador e Fornalhas de Fábrica em vez de apenas usar Combustível em uma)"
	]
	quest.07753C5D94312A50.title: "&3Aumento&r: Gerador"
	quest.077A214422FEFF02.quest_subtitle: "&f6.5 &cDano de Ataque"
	quest.077B2D62FA7650FB.quest_subtitle: "Alcance: &627&r Blocos"
	quest.077B2D62FA7650FB.title: "&cGrowth Accelerators de Tertium"
	quest.0785CE63067DBE78.quest_desc: ["&6Allthemodium&f, &3Vibranium&f, e &5Unobtainium&r &cPoke&rbolas são &cBolas&r especiais, então precisaremos de &7Mecanismos&r especiais para elas! "]
	quest.0785CE63067DBE78.title: "Mecanismos de Metal &6&lAllthemodium&r"
	quest.078B69E9362A5496.quest_desc: ["Sim, o &5&lMekanism&r é grande assim! \\n\\nSe você quer seus &2&lReatores&r e uma Armadura Invencível, então você está no lugar certo! \\n\\nPrimeiro, precisaremos de um &2&lReator de Fissão&r, e para isso é necessário &2Combustível Fóssil&r. Para fazer o &2Combustível Fóssil&r, precisaremos de &cTrióxido de Enxofre&r. \\n\\nComece colocando &eEnxofre&r em um &c&lOxidificador &eQuímico&r para criar &eDióxido de Enxofre&r. \\n\\nDepois, crie um pouco de &bOxigênio&r processando &9Água&r em um &9&lSeparador Eletrolítico&r. \\n\\nAgora podemos &ctransportar&r esse &bOxigênio&r e o &eDióxido de Enxofre&r por tubos para dentro de um &c&lInfusor Químico&r para criar nosso &cTrióxido de Enxofre&r."]
	quest.078B69E9362A5496.title: "&5&lMekanism: Reatores"
	quest.078C5B50CDC174CB.quest_desc: ["Os &aMechanical Bearings&r são as formas mais simples de movimento de &aEngenhoca&r.\\n\\nQuando recebem &dPotência Rotacional&r por baixo, eles girarão quaisquer Blocos acima na mesma Velocidade e Direção.\\nOs Blocos serão automaticamente &aColados&r ao &aMechanical Bearings&r, mas quaisquer outros Blocos precisarão ser &aColados&r a esse Bloco para se moverem também!\\n\\nSe você usar um &aMechanical Bearings&r dentro de uma &aEngenhoca&r, ele tentará manter o Bloco anexado parado em vez de Girar."]
	quest.078C5B50CDC174CB.title: "&aMechanical Bearings"
	quest.0790D3BB481162A6.quest_desc: [
		"Precisa de uma Bancada de Trabalho portátil? Que tal uma Mesa de Ferraria portátil?"
		""
		"O &l&8Crafting On A Stick&r adiciona versões portáteis de algumas das suas estações de trabalho favoritas! Isso é indispensável no início do jogo."
	]
	quest.0790D3BB481162A6.quest_subtitle: "Menos Colocar, mais Criar"
	quest.0790D3BB481162A6.title: "Criação... em um Graveto!"
	quest.079A415488A32076.quest_desc: ["Blaze Ember é um novo material adicionado pelo JDT. Blaze Ember é adquirido realizando a Disseminação de Geleia em Blocos de Carvão Primal usando geleia de nível dois ou superior. O Minério de Blaze Ember é afetado pela fortuna."]
	quest.07BEB974DF1E5AD3.quest_desc: ["Gera Energia na mesma taxa que um &aGerador de Esmeralda&r, mas tem uma Taxa de Transferência muito maior. Também é indiscutivelmente mais barato, pois leva menos itens, mas esse item também é &5Netherita&r, então..."]
	quest.07BEB974DF1E5AD3.title: "&5Netherite Generator"
	quest.07BEE6FEC14765DC.quest_desc: ["Receita bem simples, precisando de Argila, Ferro, Bolas de Slime e mais...\\n\\nMagnetitas são melhores para saquear, Mods adicionam estas em Poças de Saque por todo o &c&lNether&r, então não crie uma, apenas encontre uma!\\n\\nCera é um novo Item adicionado pelo &6&lForbidden \\& Arcanus&r, que é uma mistura de Garrafa de Mel e Bolas de Slime!\\n\\nVocê pode usá-la em um &6Pedestal de Pedra Escura&r para obter &7Pedestais Magnetizados&r que funcionam em conjunto com Funis (e Itens semelhantes a Funis, como Canos).\\n\\nVocê também pode usá-la com Botas para aumentar a proximidade com que os Itens podem ser arrastados para o seu Inventário!"]
	quest.07CC809B6482AB09.quest_subtitle: "Tier: &a2"
	quest.07E5B0BF7D8E055A.quest_subtitle: "+30% de Chance de Evasão"
	quest.07F142663892007B.quest_desc: [
		"4 das formas de cortar as Metades são as mesmas. A única nova é a..."
		"{@pagebreak}"
		"&5Forja Atômica&r! Uma máquina muito legal e plana. \\n\\nAgora precisando de 8 Estruturas de Máquina. \\n\\nA &5Forja Atômica&r não recebe Energia como máquinas normais, em vez disso, ela precisa que seja enviada via Laser! \\n\\nCom &2Lasers Enderic&r. Ligue um &2Laser Enderic&r e use o Designador de Alvo com Shift + Botão Direito na &5Forja Atômica&r e depois no &2Laser Enderic&r. \\n\\n(Se) funcionar, você pode jogar suas &6Metades de Bolotas&r para obter alguns &6Fragmentos&r."
	]
	quest.07FDA46D83F8360D.quest_desc: ["Por 4 &6Pepitas de Allthemodium&r e uma Pérola do End, você obtém uma Plataforma de Teletransporte.\\n\\nColoque-a em uma das dimensões do Minecraft para se teletransportar para uma dimensão diferente.\\n\\nPara se teletransportar, você precisa shift + clique direito com as mãos principal e secundária vazias! Isso é importante, leia!\\n\\nAMBAS as mãos precisam estar VAZIAS!"]
	quest.07FDA46D83F8360D.title: "Plataforma de Teletransporte"
	quest.0813CEDCC201216A.quest_subtitle: "Kapok + Fustete Velho"
	quest.0817FD6E45C127E8.quest_desc: ["Tecnicamente, isto é opcional, mas recomendado! Você pode usar mais Pilares para inserir e remover mais OP!"]
	quest.0817FD6E45C127E8.title: "Mais Pilares - opcional"
	quest.081DC030A0546549.quest_desc: ["O &2Biocombustível&r é feito &4Triturando&r algumas &2Plantas&r! Todos os tipos de &2Plantas&r diferentes, cada uma dando uma quantidade diferente!\\n\\nA &6Torta de Abóbora&r dá o máximo de &2Biocombustível&r, mas as &aFatias de Melancia&r são mais eficientes.\\n\\nO &2Biocombustível&r pode ser usado de várias maneiras! Podemos &aAlimentar&r um &2&lBiogerador&r, &9&lInfundir&r Itens com &2Biocombustível Químico&r, ou..."]
	quest.081DC030A0546549.title: "&4Triturando &2Plantas&f para obter &2Biocombustível"
	quest.08245411AFDB63DB.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.0830195863384CF0.quest_desc: ["&bStrata&r é o primeiro e mais básico, criado a partir de blocos regulares como Pedra ou Areia ou Obsidiana.\\n\\nVocê pode usar 5 &bStrata Salt&r para criar &bSal Mineral&r."]
	quest.0830195863384CF0.title: "&bStrata Salt"
	quest.083ABBA1C45FF960.quest_subtitle: "Apenas um Cortador de Grama"
	quest.083D458032F0325C.quest_desc: ["O &bPonto de Exportação ME&f periodicamente ejeta itens de seu filtro de lista branca para qualquer armazenamento externo que o Ponto esteja voltado. Ao contrário do Ponto de Importação, o Ponto de Exportação não pode funcionar sem ser filtrado."]
	quest.083D458032F0325C.quest_subtitle: "O entregador mais eficiente do mundo ME!"
	quest.083D458032F0325C.title: "&bPonto de Exportação"
	quest.08457BEED799E600.quest_desc: ["Estes novos &7Carrinhos&r são principalmente para colocar &6Trilhos&r.\\n\\nO &7Colocador de Trilhos&r coloca &6Trilhos&r, enquanto o &7Removedor de Trilhos&r remove &6Trilhos&r.\\n\\nO &7Recolocador de Trilhos&r substitui os &6Trilhos&r por outros diferentes e o &7Corta-trilhos&r substitui os blocos sob os &6Trilhos&r."]
	quest.08457BEED799E600.title: "&7Carrinhos&r e &6Trilhos"
	quest.0848056FDD3F9BDA.quest_desc: ["Uma &9Singularidade&r é um ponto teorizado de densidade máxima. Os cientistas acreditam que o Universo em que vivemos já foi uma &9Singularidade&r. Cada molécula em nosso Universo, em um único ponto menor que um grão de areia.\\n\\nClaro, com o &l&bAE2&r flutuando na linha das ciências teóricas, eles têm sua própria &9Singularidade&r.\\n\\nExistem 2 maneiras de criá-la, mas cada uma requer a condensação de uma infinidade de Itens em um único ponto!"]
	quest.0848056FDD3F9BDA.title: "&9Singularidade"
	quest.0850F88E2205623F.quest_desc: ["As &3Gavinhas de Sculk&r (&3Sculk Tendrils&r) são como &bCipós Retorcidos&r... só que de &3Sculk&r. \\n\\nElas aparecem raramente nas &9Terras Profundas&r."]
	quest.0850F88E2205623F.title: "&3Gavinhas de Sculk"
	quest.0853917693A259C2.quest_desc: ["&3O Aniquilador&r é uma arma muito divertida feita de &3Cursium&r e Aço Preto.\\n\\nVocê pode bater nos inimigos com ela o dia todo! Mas sabe o que é mais divertido do que um &3Aniquilador&r?\\n\\nDois &3Aniquiladores&r!\\n\\nSe você tiver um &3Aniquilador&r em cada Mão, pode Segurar o Botão Direito para dar um poderoso golpe no chão, danificando todos ao seu redor!"]
	quest.0853917693A259C2.title: "&3O Aniquilador"
	quest.0854AD352218E1C3.quest_desc: ["Você não odeia quando tem todo esse poder, mas nenhum Aquecimento?\\n\\nAgora você pode mudar isso com o Emissor de Fluxo Calórico! Shift + Clique Direito com ele para vinculá-lo a uma Máquina. Em seguida, coloque-o e energize-o para enviar Calor.\\n\\nNão pode ser definido para várias Máquinas!"]
	quest.0854AD352218E1C3.quest_subtitle: "Como?"
	quest.0854AD352218E1C3.title: "Calor Sem Fio"
	quest.08697EB269B011FD.quest_desc: [
		"Com o &dContato de Ronaza&r, você pode aprimorar sua &bTigela Ritualistica de Iesnium&r para o &5Cálice de Eldritch&r. Quando usado em um ritual, reduz o tempo que leva para completar... inteiramente."
		""
		"Sim, o &5Cálice de Eldritch&r faz com que todos os rituais se completem instantaneamente!"
	]
	quest.08697EB269B011FD.title: "Cálice Eldritch"
	quest.087F6C09CB5B2D1A.quest_desc: ["Os &bCanos de Fluido Inteligentes&r nos darão Filtragem para os &bCanos de Fluido&r.\\n\\nQuando colocados na Máquina de onde os &bCanos&r estão extraindo, podem ser configurados para retirar apenas um &bFluido&r. Isso é definido adicionando um Balde cheio desse &bLíquido&r no Slot de Filtro.\\n\\nVocê pode colocar o &bCano de Fluido Inteligente&r mais adiante no &bsistema de Canos&r para enviar apenas aquele &bFluido&r específico através dos &bCanos&r depois dele.\\n\\nIsso é útil para a classificação em massa de um monte de &bTanques de Fluido&r!"]
	quest.087F6C09CB5B2D1A.title: "&bCano de Fluido Inteligente"
	quest.088CA7B6D4899846.quest_desc: [
		"A &#65C2A6Empacotadora&r é usada para fabricar &#53E67BCabos&r, &#53E67BBarras Duplas&r, &#53E67BPós&r, &#53E67BChapas Grande&r, &#53E67BBarras em Blocos&r e &#53E67BLâminas&r. "
		""
		"Além disso, há muitos outros usos para a máquina, mas esses serão os principais para você."
	]
	quest.088CA7B6D4899846.title: "&fO &7Empacotador"
	quest.088FCB5267CB7A89.quest_desc: ["Este cinto dará efeitos de poção positivos aleatórios por uma curta duração. Estes variarão em força."]
	quest.0893EFCAC7031FEA.quest_desc: ["Hora de fazer um bolo, se você tiver leite e ovos prontos."]
	quest.0893EFCAC7031FEA.quest_subtitle: "Tenha seu Bolo e Coma-o Também"
	quest.0894EB1F3FCFCECA.quest_desc: ["Os &3Draugrs&r são semelhantes aos &5Deeplings&r, pois possuem classificações. As classificações dos &3Draugr&r são: &3Draugr&r, &3Draugr Real&r e &3Draugr de Elite&r.\\n\\nOs &3Draugr&r normais têm 14 &4Corações&r e carregam Espadas e Machados de Aço Preto. Eles dropam Carne Podre, Ossos e raramente Pepitas de Aço Preto.\\n\\nOs próximos na linha são os &3Draugr Reais&r. Estes têm 15 &4Corações&r e carregam Targes de Aço Preto junto com as Espadas e Machados. Eles dropam os mesmos Itens que os &3Draugrs&r normais.\\n\\nPor último, está o &3Draugr de Elite&r. Estes alternam entre Espadas de Aço Preto e Bestas, dependendo de quão longe você está deles. Eles têm 16 &4Corações&r e dropam, claro, o mesmo saque!"]
	quest.0894EB1F3FCFCECA.title: "&3Draugrs"
	quest.089B1B9837AF4938.title: "Ferramentas de &5Unobtainium"
	quest.08A3292277D2FDE2.quest_subtitle: "Fabricado com Aparelho de Encantamento"
	quest.08A3292277D2FDE2.title: "&fAbelha de Essência da Água"
	quest.08AC2D81A1004984.title: "&6Tridente de &5Liga de &3Allthemodium"
	quest.08B60D8A25008CCC.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.08C6B7D2DAE87222.quest_subtitle: "Carvalho + Bétula"
	quest.08C870DC50CA49FC.quest_desc: [
		"O &#5C5C5CPetróleo Bruto&r por si só não tem muita utilidade para nós, mas quando processado em uma destilaria, obtemos subprodutos que podem ser usados para muitos e muitos propósitos."
		""
		"Podemos produzir &#C4C241Combustível Pesado Sulfúrico&r, &#CECC5FCombustível Leve Sulfúrico&r e &#D9D782Nafta Sulfúrica&r com ele."
	]
	quest.08C870DC50CA49FC.title: "&#5C5C5CProcessamento de Petróleo Bruto"
	quest.08CE14FFED813992.quest_subtitle: "13 Blocos Rosa Escuro Molhados"
	quest.08D1CC753F6B4283.quest_desc: ["O Guardião Ancião era considerado um terceiro Chefe para o Minecraft antes do Warden, mas eu o considero um Minichefe.\\n\\nOs Guardiões Anciões aparecem em Monumentos Oceânicos. Três deles aparecem lá e infligirão Fadiga de Mineração em qualquer um por perto.\\n\\nSe você quer os tesouros do Monumento Oceânico, precisará encontrá-los e matá-los! (Dica: sempre encontrei 1 na Sala do topo, 1 no extremo esquerdo e 1 no extremo direito!)\\n\\nEles têm 80 Corações e atacam como Guardiões normais, Lasers e Espinhos!\\n\\nAo morrer, eles droparão: Esponjas, Prismarinho e o almoço deles..."]
	quest.08D1CC753F6B4283.title: "&fMate um &7Guardião Ancião"
	quest.08D9C809CF4062E8.quest_desc: ["Coma-os crus, asse-os, coloque-os em um Espeto.\\n\\nO que você não pode fazer com Underbeans!"]
	quest.08DB91D079C5B715.quest_subtitle: "Bordo Vermelho + Mogno"
	quest.08DDE018A804BFE7.quest_desc: ["A &d&lCâmara de Enriquecimento&r &dEnriquecerá&r &eItens&r que passam por ela. Basta colocar os &eItens&r nos &4Slots Vermelhos&r e os &dItens Enriquecidos&r sairão dos &9Slots Azuis&r.\\n\\nO que é um &dItem Enriquecido&r? Ou o que acontece quando um &eItem&r é &dEnriquecido&r? Ou obtemos mais dos &eItens&r em que pode ser transformado, ou mudamos os &eItens&r em si!\\n\\nPodemos obter 2 Pós de 1 Minério. Podemos obter mais Corantes de uma Flor. Podemos até mudar os Estágios do &6Cobre&r ou remover &2Musgo&r de &7Pedregulho&r!\\n\\nCom Níveis posteriores de &d&lCâmaras de Enriquecimento&r, obtemos ainda mais Slots para &dEnriquecer&f mais &eItens&r de uma vez.\\n\\nTambém ganhamos a habilidade de Classificar Automaticamente. Com o pressionar deste Botão! Podemos configurá-lo para que as Pilhas de &eItens&r sejam distribuídas uniformemente para cada Slot, para que a &d&lMáquina&r seja mais Eficiente."]
	quest.08DDE018A804BFE7.quest_subtitle: "Quebra Minérios Brutos em Pós"
	quest.08DDE018A804BFE7.title: "&d&lCâmara de Enriquecimento"
	quest.08E47A27EFFB7C6B.quest_subtitle: "5 Blocos Rosa Secos"
	quest.0903F0D8642449B7.quest_desc: ["Saindo da &6Circuitaria Analógica&r, agora podemos processar mais de 2 bits de informação. Isso abre horizontes para algumas novas máquinas"]
	quest.0903F0D8642449B7.title: "&5Circuito Eletrônico"
	quest.090B564935D7A8F5.quest_desc: ["Não gosta de pegar suas &5Máquinas&r para Aprimorá-las? Por que não usar um &eItem&r!\\n\\nCom os Instaladores de &7Nível&r, você pode apenas usar o &eItem&r na &5Máquina&r para Aprimorá-las!\\n\\nJogue o &a&lInstalador de Nível Básico&r em uma &5Máquina&r padrão para aprimorá-las para o &a&lNível Básico&r.\\n\\nNão, você não pode pular aprimoramentos. Não pode transformar um &a&lBásico&r em &d&lSupremo&r com um &dInstalador&r."]
	quest.090B564935D7A8F5.title: "Instaladores de &lNível&r"
	quest.0910C28A609ECBC1.quest_desc: ["A &6Bússola de Mel&r é uma ferramenta muito útil adicionada pelo &6&lBumblezone&r.\\n\\nVocê pode criar uma ou trocá-la.\\n\\nVocê pode Shift + Clique Direito em uma &eColmeia&r para rastrear aquela &eColmeia&r (incluindo &lColmeias Produtivas&r) ou Clique Direito no Ar para localizar um Labirinto de Células."]
	quest.0910C28A609ECBC1.title: "&6Bússola de Mel"
	quest.09223F02621781BF.quest_subtitle: "Ferro + Pedreiro"
	quest.09223F02621781BF.title: "Abelha de Prata"
	quest.0923C941A9696122.quest_desc: ["Caso você precise levar 256 Milhões de Itens em uma Aventura com você!\\n\\nVocê precisará de alguns Itens simples como &8MEGA Item Cell Housing&r, &5Baú ME&r e uma &5Dense Energy Cell&r.\\n\\nE então precisaremos do &d256M MEGA Storage Component&r... este é muito mais difícil de fazer.\\n\\nSe a Criação repetitiva te faz odiar o &2&lMinecraft&r, então você pode querer Criar a &2Carcaça à Prova de Explosão&r!\\n\\nPrecisaremos de 2 Células de Item Portátil de 256M, 2 &2Carcaças à Prova de Explosão&r, ou uma mistura de ambos para Criar o &3&lDispositivo de Probabilidade Improvável&r."]
	quest.0923C941A9696122.title: "256M Portable Item Cell"
	quest.09282E3864752CEE.quest_subtitle: "Nível: &63"
	quest.092A23FDA5D50812.quest_subtitle: "Nível: &a2"
	quest.092BB595F75D5536.quest_desc: ["Bem-vindo ao &6&lForbidden \\& Arcanus&r!\\n\\nPara começar este Mod, precisaremos começar a minerar no subsolo... bem no fundo do subsolo.\\n\\nComo no Nível Y 1 e abaixo."]
	quest.092BB595F75D5536.quest_subtitle: "Hora de Forjar!"
	quest.092BB595F75D5536.title: "&6&lForbidden \\& Arcanus"
	quest.093D21D44BE4D923.quest_desc: ["Savanas, Ermos e Cavernas Exuberantes são onde você deve procurar por &cPedras do Sol&r. \\n\\nSe isso não for suficiente, você também pode encontrá-las em Desertos."]
	quest.093D21D44BE4D923.title: "Encontrando &cPedras do Sol"
	quest.0945EC53626F58E6.quest_desc: ["Além de itens e fluidos, o &3Refined Storage&r também pode ser usado para armazenar &aQuímicos&r, graças ao mod Refined Storage - Mekanism Integration.\\n\\nVocê também pode armazenar &4Energia&r, &5Fonte&r e &9Almas&r, graças ao mod Refined Types."]
	quest.0945EC53626F58E6.title: "&5Outras Peças de Armazenamento"
	quest.0947B4ED95B0267E.quest_desc: ["Reveste um item e ferramentas.\\n\\nA netherita é um ótimo material de revestimento."]
	quest.0947B4ED95B0267E.quest_subtitle: "Totalmente não apenas para Netherita"
	quest.09485B63483B7A15.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:"
		""
		"Faz com que mobs hostis próximos percam temporariamente o agro para o jogador, possui um tempo de recarga."
	]
	quest.094D28B7A0170039.quest_desc: [
		"Irá coletar itens e trazê-los de volta para sua colmeia."
		""
		"Não é tão boa quanto uma Abelha Acumuladora."
	]
	quest.094D28B7A0170039.quest_subtitle: "Alimente uma Abelha do Vanilla com um Funil"
	quest.094D28B7A0170039.title: "&fAbelha Coletora"
	quest.09733948CBCB3FB9.quest_desc: ["&dTier 6&r é o nível mais alto, qualquer coisa que seja quebrável pode ser minerada com ele, incluindo Vibranium e Unobtainium."]
	quest.09733948CBCB3FB9.title: "&dNível de Coleta 6"
	quest.097DE7038A746847.quest_subtitle: "Surge de um Ninho de Cana"
	quest.097DE7038A746847.title: "&fAbelha de Cana"
	quest.097FDC136BC843A7.quest_desc: ["O &lNível de Mundo: &6Cume&r exigirá que você aprimore sua &eArmadura&r e &eFerramenta/Arma&r de &aIncomum&r para &9Raro&r (ou melhor)! Você também precisará matar &0&lO Wither&r. \\n\\n&0&lO Wither&r não precisa ser um &4Invasor&r e, honestamente, será mais fácil se ele não for. \\n\\nEm &6&lCume&r, &eItens &f&5Épicos&r e &2Gemas&r serão os mais comuns, e para &eItens&r agora você pode obter &6Míticos&r e com &aGemas&r pode encontrar &zPerfeitas&r. Novamente, ambos sendo extremamente raros! \\n\\nAgora obteremos 75% de Experiência Ganhada e 50% de Sorte. \\n\\n&4Monstros&r também serão fortalecidos para obter 12 Pontos de Armadura, 10 de Resistência de Armadura, 15 de Perfuração de Armadura e 10 de Perfuração de Proteção. \\n\\nÉ impressão minha ou as melhorias deles são melhores que as nossas?"]
	quest.097FDC136BC843A7.title: "&lNível de Mundo: &6Cume"
	quest.0980661B2F7FBC10.quest_desc: [
		"Pule sobre e por cima das Velas para chegar ao topo!\\n\\nLá em cima você pode encontrar alguns Casulos de Mel.\\n\\nNão queime seus pés.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_candle.png width:200 height:100 align:center}"
	]
	quest.0980661B2F7FBC10.title: "Parkour de Velas"
	quest.09830BB2A23E94B4.quest_desc: ["Algumas &5Máquinas&r usarão &cQuímicos&r especialmente para adicionar a &eItens&r. Pense em &9&lInfusor Metalúrgico&r, &c&lInjetor Químico&r e &b&lPurificadores&r. \\n\\nEssas basicamente usarão menos &cQuímicos&r para as mesmas Tarefas! \\n\\nNão posso prometer que funcionará com todo &eItem&r e &5Máquina&r. E não, eu não vou testar com toda Máquina!"]
	quest.09830BB2A23E94B4.title: "&cMelhoria &8Química"
	quest.09936F8FCEA72C5C.quest_desc: [
		"O &aCart Assembler&r pode ser colocado sobre trilhos. Qualquer coisa que você construir em cima dele será pega por um &7Carrinho de Minas&r se o &aMontador&r tiver um &4sinal de Redstone&r."
		""
		"Os Blocos devem ser &aColados&r juntos e quaisquer Blocos que requeiram &dEnergia Rotacional&r funcionarão automaticamente."
		""
		"Para \"desmontar\" os Blocos do &7Carrinho de Minas&r, simplesmente desligue o &4sinal de Redstone&r e deixe o &7Carrinho de Minas&r passar."
	]
	quest.09936F8FCEA72C5C.title: "&aCart Assembler"
	quest.09955CF85F579E0F.quest_desc: ["Você vai conseguir isso eventualmente, é literalmente o Bloco mais abundante em &2&lMinecraft&r."]
	quest.09955CF85F579E0F.title: "&fBlocos de Pedra"
	quest.099B7F8D13868CCD.quest_desc: ["Ela aumentará seu Limite de Nível para 20. \\nSeu Item de Assinatura é a &cLente Ampla&r."]
	quest.099B7F8D13868CCD.title: "&7Comandante Mars"
	quest.099C2A9B9CA138F8.quest_desc: ["&6Míticos&r são alguns dos melhores que podemos obter! \\n\\n&6Míticos&r são encontrados apenas no &lNível de Mundo: &6Cume&r e no &lNível de Mundo: &4Pináculo&r, onde são mais comuns. \\n\\n&6Pérolas Forjadas por Deuses&r são feitas usando &eItens&r &6Míticos&r em uma &c&lMesa de Desmanche&r."]
	quest.099C2A9B9CA138F8.quest_subtitle: "&6Mítico"
	quest.099C2A9B9CA138F8.title: "&6Pérola Forjada por Deuses"
	quest.09BA45CBBFB4AE26.quest_desc: ["O próximo estágio deste mod requer que você configure &3Linhas de Montagem&r. O componente principal de uma &3Linha de Montagem&r é o &3Controlador de Montagem&r.\\n\\nÉ aqui que a pressão será aplicada."]
	quest.09BA45CBBFB4AE26.quest_subtitle: "Sempre Necessário"
	quest.09BE81548CD81068.quest_desc: ["Você finalmente chegou aos componentes necessários para o &#FFEB6EEstrela de AllTheMods&r!!"]
	quest.09C82CDDA800D8C9.quest_desc: ["O Wither é o segundo Chefe do Minecraft, sendo este mais eletivo.\\n\\nVocê terá que construir o Wither para invocá-lo. Usar 4 Areias das Almas em forma de T e colocar 3 Crânios de Esqueleto Wither no topo irá invocá-lo!\\n\\nEle tem 300 Corações e voará por aí atirando Crânios de Wither em Jogadores ou Mobs.\\n\\nQuando chegar à metade da vida, ele ganhará um escudo contra Projéteis e precisará ser morto com uma Espada ou Machado.\\n\\nQuando você o matar, ele dropará: Estrela do Nether, chance de uma Alma Wither e um monte de Itens Corail."]
	quest.09C82CDDA800D8C9.title: "&fMate o &8Wither"
	quest.09D18512037386C1.quest_desc: ["Para inserir Efeitos de Poção, você precisará preencher um Filtro de Poção.\\n\\nPara fazer isso: tenha um Efeito de Poção em você, então clique com o botão direito com o Filtro de Poção para removê-lo de você e adicioná-lo ao Filtro, e repita até que esteja cheio e ativo.\\n\\nIsso também funciona com Efeitos de Poção de mods ou aqueles que você normalmente não consegue através de Poções, como Pressa ou Resistência."]
	quest.09D2137B4F42006E.quest_desc: ["Eclipse Ember é um novo material adicionado pelo JDT. Eclipse Ember é adquirido realizando a Disseminação de Gosma em Blocos de Carvão Voidflame usando gosma de nível quatro. O Minério de Eclipse Ember é afetado por fortuna."]
	quest.09D76E9B8CABC31E.quest_desc: ["Para a &5&lEssência Criativa&r você precisará de 4 &5Blocos de Essência de Insanium&r. Cada Bloco equivale a 9 &5Essências&r, agora deixe-me fazer as contas...\\n\\nVocê precisará de 9.216 &aEssências de Inferium&r para obter apenas um desses Blocos. Então, você precisará de 36.864 &aEssências de Inferium&r no total!"]
	quest.09D76E9B8CABC31E.title: "4 &5Blocos de Insanium"
	quest.09D7D3CF61E156B1.quest_desc: ["Os &2Conjuntos de Combustível de Fissão&r são o que compõe o armazenamento para o &2Combustível Fóssil&r. Eles também ajudam a determinar a Eficiência. \\n\\nOs &2Conjuntos de Combustível de Fissão&r precisarão ser colocados no &2&lReator de Fissão&r para poderem funcionar. \\n\\nEles podem ser empilhados uns sobre os outros e uns ao lado dos outros, mas cada pilha precisará de um... \\n\\n&2Conjunto da Haste de Controle&r em cima dela! Os &2Conjuntos da Haste de Controle&r não alteram nada como a Eficiência, mas o &2Conjunto de Combustível de Fissão&r não funcionará se não houver um &2Conjunto da Haste de Controle&r acima dele dentro do &2&lReator de Fissão&r!"]
	quest.09D7D3CF61E156B1.quest_subtitle: "Empilhe com cuidado… ou tudo vai pelos ares."
	quest.09D7D3CF61E156B1.title: "Armazenamento e uso do &2Combustível Fóssil&r"
	quest.09E25B1CD6CABD5A.quest_desc: ["Esta melhoria torna o Roteador semelhante a um Bloco Emoldurado.\\n\\nAgache e clique com o botão direito em um Bloco para mudar a aparência do Roteador para a dele.\\n\\nSó não o perca!"]
	quest.09E34E1F9C751458.quest_desc: ["A &dCaixa de Engrenagens Vertical&r é como a &dCaixa de Engrenagens&r normal se alguém a tivesse girado.\\n\\nEla tem 4 &8Eixos&r internos, só que desta vez, em vez das Direções Cardeais, eles são (de onde você a coloca) Frente, Trás, Cima e Baixo.\\n\\nAssim como a &dCaixa de Engrenagens&r normal, ela manterá a Velocidade e as Unidades de Estresse do &8Eixo&r original!"]
	quest.09E34E1F9C751458.title: "&dCaixa de Engrenagens Vertical"
	quest.09F43EB79DDBD127.quest_desc: [
		"O Entrelaçador de Dados Quântico permite que itens sejam armazenados em múltiplas dimensões, multiplicando efetivamente o armazenamento de crafting em um Multibloco de Computador Quântico por 4. Por exemplo, um armazenamento de crafting quântico de 256M agora fornecerá 1G de Armazenamento de Crafting."
		""
		"&lVocê só pode ter 1 destes em um Multibloco de Computador Quântico."
	]
	quest.09F43EB79DDBD127.title: "Armazenamento Desnecessariamente Grande: Entrelaçador de Dados Quântico"
	quest.09F49ED309152E24.quest_desc: ["&l&cChisel Reborn&r é outro Mod baseado no &lChiseled&r.\\n\\nA essência do Mod é usar a Ferramenta Chisel para mudar os designs de alguns Blocos.\\n\\nVocê pode clicar com o botão direito com o Chisel para abrir sua GUI, lá você pode colocar até um pack de Blocos, então escolher um design que você quer, e retirá-lo. Ou você pode mantê-lo no Chisel, embora eu não veja por que você iria querer fazer isso.\\n\\nVocê também pode clicar com o botão esquerdo em um Bloco com o Chisel para mudar seu design sem abrir a INTERFACE do Chisel!\\n\\nNão se preocupe, este não tem Durabilidade."]
	quest.09F49ED309152E24.title: "&l&cChisel Reborn"
	quest.09FD3D0B9BCAEB5A.quest_desc: [
		"O Ninho de Cascalho atrairá abelhas em um bioma de Rio ou Praia."
		""
		"Ele atrai a Abelha Mineradora Cinzenta, a Abelha Mineira de Chocolate e a Abelha Escavadora."
	]
	quest.09FD3D0B9BCAEB5A.quest_subtitle: "Atrai abelhas em biomas de Rio e Praia"
	quest.09FD3D0B9BCAEB5A.title: "&fNinho de &7Cascalho"
	quest.0A02DBE226C3F44E.quest_desc: [
		"Melhorias Válidas:"
		"- Mind Fog"
		"- Stupefy"
		"- Night Vision"
		"- Debuff Remover"
		"- Mental Obliteration"
	]
	quest.0A0A991BAC99092C.quest_desc: [
		"O Pântano de Cogumelos Índigo é um pântano muito mais cheio que o Pântano de Cogumelos de Sangue.\\n\\nClaro que tem Cogumelos Índigo, mas também mini Árvores de Smogstem e lagoas de Mistura Virulenta. O que será que faz..."
		"{image:atm:textures/questpics/undergarden/undergarden_indigo.png width:200 height:100 align:center}"
	]
	quest.0A0A991BAC99092C.title: "Pântano de Cogumelos Índigo"
	quest.0A11725B41AB45F6.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, está no modo de edição."]
	quest.0A1ABE9CF7740AAA.quest_desc: ["Os Anéis de Desconto fornecem um pequeno bônus à mana máxima e à regeneração de mana. Também reduzem o custo total para lançar um feitiço."]
	quest.0A1ABE9CF7740AAA.title: "Anéis de Desconto"
	quest.0A1C2A7A8617D3E4.quest_subtitle: "Speedrunners Amam Isso"
	quest.0A1C2A7A8617D3E4.title: "Trigo"
	quest.0A1D4228271DECA3.quest_desc: ["Para onde você foi?\\n\\nAh, você está apenas com metade do seu tamanho anterior. Pequeno o suficiente para caber sob um vão de 1 Bloco."]
	quest.0A1D4228271DECA3.quest_subtitle: "Colar"
	quest.0A1D4228271DECA3.title: "&5Amuleto do Encolhimento&r"
	quest.0A1D6E233C0ECC8E.quest_desc: [
		"&dNargoyles&r são Mobs desagradáveis e hostis que aparecem no subterrâneo.\\n\\nEles têm sete corações e meio e tentarão incansavelmente te matar.\\n\\nEles não dropam nada e servem apenas como um obstáculo para aqueles que tentam minerar pacificamente."
		"{image:atm:textures/questpics/undergarden/undergarden_nargoyle.png width:100 height:100 align:center}"
	]
	quest.0A1D6E233C0ECC8E.title: "&dNargoyle&r"
	quest.0A21773B773F34F8.quest_desc: ["A cor é uma das partes mais importantes para tornar uma Construção mais viva!\\n\\nEla dá vida, personalidade e cor!\\n\\nComece com os Corantes!"]
	quest.0A21773B773F34F8.title: "&fBlocos &cC&6o&el&ao&br&9i&dd&5o&ds"
	quest.0A25276925EB0CBA.quest_desc: [
		"Depois de reunir todos os Gizes coloridos e o Giz de Fundação, você pode realizar o segundo tipo de ritual &dsem Demônios&r, o &dContato de Ronaza&r. Este é o ritual supremo, usando tudo o que você aprendeu até agora!"
		""
		"Ele tem usos limitados, mas tudo criado com este ritual é super poderoso!"
	]
	quest.0A25276925EB0CBA.quest_subtitle: "Com este tesouro sagrado, eu invoco..."
	quest.0A25276925EB0CBA.title: "&dContato de Ronaza"
	quest.0A354B4707894A62.quest_subtitle: "Até +3 de Altura de Pulo"
	quest.0A3C464EF7CDD5F6.quest_desc: [
		"As &4Estante de Livro Infernais&r são sua introdução à &cQuanta&r, elas dão &c3% de Quanta&r e &a3 de Eterna&r.\\n\\nMelhor que as Estantes normais, certo?\\n\\nVocê vai querer 16 delas para o próximo passo, 15 &4Estante de Livro Infernais&r ao redor da &5Mesa de Encantamento&r, com 1 no seu Inventário.\\n\\nFaça as primeiras 11 e eu lhe darei as últimas 5 &4Estante de Livro Infernais&r!"
		"{image:atm:textures/questpics/apothic/enchant_hellshelf.png width:100 height:100 align:center}"
	]
	quest.0A3C464EF7CDD5F6.title: "&4Estante de Livro Infernal"
	quest.0A43FD0B5C76C1C5.quest_desc: [
		"&l&7RailCraft&r adiciona uma Alto-forno multiblock para transformarmos Ferro em Aço!\\n\\nPara construí-la, você precisará de 34 Tijolos de Alto-forno. Terá 3 blocos de largura, 3 blocos de comprimento e 4 blocos de altura. Os dois blocos no centro exato precisam estar ocos. Você saberá que está pronto quando tudo se formar e permitir que você acesse sua GUI.\\n\\nLá você pode colocar Ferro, em qualquer forma, para obter Aço e Areia Granulada."
		"{image:atm:textures/questpics/railcraft/rail_furnace.png width:100 height:100 align:center}"
	]
	quest.0A43FD0B5C76C1C5.title: "Alto-forno (Aço)"
	quest.0A467A0CFFCF1490.quest_subtitle: "Faia + Sorte"
	quest.0A4962728C98DAD9.quest_desc: ["&eCofres de Itens&r, embora não sejam novos, serão muito usados na nova Atualização!\\n\\n&eCofres de Itens&r funcionarão como Baús, só que não podemos colocar e tirar &eItens&r tão facilmente quanto em Baús...\\n\\nPara mover &eItens&r, precisaremos usar &eFunis&r! Anexe-os aos &eCofres&r &fpara enviar &eItens&r para dentro e para fora. Preferencialmente &eFunis de Latão&r para mais Filtragem de &eItens&r.\\n\\nCada &eCofre&r tem muito armazenamento, mas também podemos colocá-los um ao lado do outro para combinar seus Inventários.\\n\\nPodemos colocá-los em 1x1, 2x2 ou 3x3 e seu comprimento pode ser até 3 vezes sua largura! Então, o maior que podemos ter é 3x3x9."]
	quest.0A4962728C98DAD9.title: "&eCofres de Itens"
	quest.0A64D0937A5F7513.title: "Vara de Pescar de Ouro"
	quest.0A7B0D0B81E138DE.quest_desc: ["A &e&lCaixa de Ferramentas do Engenheiro&r funciona como um Shulker segregado.\\n\\nTem seções: Comida, onde você só pode colocar Comida. Ferramentas, que pode conter Ferramentas &8&lIE&r ou outras Ferramentas, mas não &bBaldes&r. &cFiação&r, que pode ter &cFios&r, &cConectores&r ou &cRelés&r. E Qualquer Coisa, que não discrimina. Tente ser mais como a seção Qualquer Coisa!\\n\\nAlguns Itens não podem ser guardados nela, como &bBaldes cheios de Fluidos&r ou Mochilas Acumuladoras.\\n\\nVocê pode Agachar e Clicar com o Botão Direito para colocar a &e&lCaixa de Ferramentas&r para que ela aja como um Baú, e então pode fazer o mesmo para pegá-la de volta."]
	quest.0A7B0D0B81E138DE.title: "&e&lCaixa de Ferramentas do Engenheiro"
	quest.0A8F44B9B3C8FC0F.quest_subtitle: "Tier: &63"
	quest.0A912B2E2BE34920.quest_desc: [
		"Embora você possa encontrar Petróleo Bruto na superfície, perfurar é uma ótima maneira de obter muito óleo. Primeiro, use um &3Sensor Sísmico&r até encontrar petróleo abaixo de você, depois use seu &3Elevador a Gás&r cheio de tubos de perfuração para extrair óleo. (Isso requer pressão para funcionar).\\n"
		"{image:pneumaticcraft:textures/patchouli/oil_pumping.png width:200 height:200 align:right fit:true}"
	]
	quest.0A912B2E2BE34920.quest_subtitle: "Perfurando por Petróleo"
	quest.0A9ADDE68342B987.quest_desc: [
		"Para fazer &#43DEC2Polietileno&r, você deve seguir a cadeia de produtos químicos da seguinte forma:"
		""
		"&8Petróleo bruto&r -> &#D2CD2DCombustível Leve Sulfúrico&r -> &#DBD658Combustível Leve&r -> &#E2DF78Combustível Leve Craqueado a Vapor&r -> &#44D1DBEtileno&r -> &#43DEC2Polietileno&r."
	]
	quest.0A9D5C5D2F4CDCC3.title: "&5Maça de Unobtainium"
	quest.0AA9EF3981E9BA37.quest_desc: ["&aTablets de Energia&r não estão segurando &aEnergia&r suficiente? Então, você precisará de alguns &aCubos de Energia&r!\\n\\n&aCubos de Energia&r podem ter &aEnergia&r entrando e saindo por cabos. Cada um tem uma quantidade definida de armazenamento para &aEnergia&r que é determinada pelo seu &5Tier&r.\\n\\nTodos os lados de um &aCubo de Energia&r podem receber ou enviar &aEnergia&r, o que é determinado se os Cabos estão Empurrando ou Puxando.\\n\\n&a&lBásico&r: armazenará 1,6mFE.\\n\\n&c&lAvançado&r: armazenará 6,4mFE.\\n\\n&b&lElite&r: armazenará 25,6mFE.\\n\\n&d&lUltimate&r: armazenará 102,4mFE."]
	quest.0AA9EF3981E9BA37.title: "&aCubos de Energia"
	quest.0AABCD95FABC6025.quest_desc: ["&5Pedras do Crepúsculo&r podem ser encontradas em Taigas e raramente em Pântanos."]
	quest.0AABCD95FABC6025.title: "Encontrando &5Pedras do Crepúsculo"
	quest.0ABB2264CBB82470.quest_desc: ["Armadura de Ferro da Armadura &d&lArs&r."]
	quest.0ABB2264CBB82470.quest_subtitle: "15"
	quest.0ABB2264CBB82470.title: "&5Traje de Arcanista"
	quest.0AC4ACDF3D6B9BC2.quest_desc: ["Estes Mods usam suas próprias maneiras exclusivas de &cEnergia&r e &eLogística de Itens&r! \\n\\n&6&lCreate&r é focado em Força Rotacional. Você precisará de Geradores como Moinhos de Vento ou Rodas d'Água para criar um pouco para &cEnergizar&r Máquinas. \\n\\n&7&lPneumaticCraft&r usa Pressão de Ar para a maioria das Máquinas e Processamento. &eItens&r movem-se normalmente, apenas todos precisam de Pressão de Ar para funcionar. \\n\\n&8&lImmersive Engineering&r é outro Mod de Multiblocos. Apenas estes Multiblocos são alimentados por Fios e Conectores em vez de Tubos ou apenas colocar 2 Blocos próximos um do outro."]
	quest.0AC8FE3B59D1B09D.quest_desc: ["O Apanhador Quântico é uma Ferramenta muito útil para mover Mobs.\\n\\nSimplesmente clique com o botão direito em um Mob para \"capturá-los\", depois clique com o botão direito novamente para soltá-los.\\n\\nVocê precisará de uma quantidade definida de &bAureal&r em você para usá-lo, isso depende da Vida do Mob. Mais Vida, mais &bAureal&r necessário! Não custará nada para soltar Mobs, isso é de graça.\\n\\nAh, espere, eu provavelmente deveria te dizer como Criá-lo! Você precisará de um &7Núcleo Quântico&r que é criado com &7Runas&r, &cPó de Mundabitur&r e &8Sílex&r!\\n\\nOs Fragmentos de Spawner são drops ao Minerar um Spawner sem Toque Suave, então quebrará o Spawner."]
	quest.0ACC0092A8F722C6.quest_desc: ["A maioria das Máquinas em &8&lIE&r precisará de &cEnergia&r para funcionar, e os &cFios&r são como a movemos!\\n\\n&cFios&r são anexados clicando com o botão direito em uma parte com a &cBobina de Fio&r, e depois clicando com o botão direito na segunda parte com a mesma &cBobina&r. O caminho deles não pode ser obstruído, senão não conectará.\\n\\nPara pegar &cFios&r, podemos quebrar o que eles estão conectados, ou usar nosso fiel &6Corta-fios&r!\\n\\nOs diferentes Níveis de &cFios&r afetam o quanto eles transferem, com &5HV&r movendo o máximo."]
	quest.0ACC0092A8F722C6.title: "&cBobinas de Fio"
	quest.0ACE573560A19309.quest_desc: ["Quase toda &5Máquina&r usará &aEnergia&r, e quando temos dezenas delas... definitivamente não é fácil para nossas Redes.\\n\\nSe adicionarmos &aMelhorias de &8Energia&r, as &5Máquinas&r farão a mesma Tarefa, só que agora exigindo menos &aEnergia&r para completar!\\nSe ao menos pudéssemos colocar isso no &d&lT.F.S.&r!"]
	quest.0ACE573560A19309.title: "&aMelhoria de &8Energia"
	quest.0AD2B11565B484E7.quest_desc: ["Você precisará de todas as Fornalhas antes da de &5Netherita&r para estas. Sim, todas, até a de &6Cobre&r! Até a de &7Prata&r! Até a de &3Cristal&r!"]
	quest.0AD2B11565B484E7.title: "&zChapa de Arco-íris"
	quest.0ADBE90B33ACC9FB.quest_desc: ["O &zGerador de Arco-íris&r é uma melhoria para o &zFornalha de Arco-íris&r enquanto utiliza a &3Aumento&r: Gerador. Se todos os outros 9 Fornalhas (sem contar as Fornalhas de AllTheModium e superiores) estiverem ao redor do &zFornalha de Arco-íris&r, tiverem &3Aumento&r: Gerador, e estiverem ativamente gerando Energia (com combustível e não cheio), eles darão um impulso ao &zFornalha de Arco-íris&r que tem &3Aumento&r: Gerador e está em funcionamento. Isso fará com que ele gere 2kFE a mais por tick!"]
	quest.0ADBE90B33ACC9FB.title: "&zGerador de Arco-íris"
	quest.0ADFE26AD63EC714.quest_desc: ["Para encontrar um &4Treinador&r específico, você pode usar a Seta Direita para ver cada Bioma em que eles Aparecem. \\n\\nSe você não tem um milhão de anos livres para vagar pelo &2&lMinecraft&r, então eu recomendo Criar um &4Gerador de Treinador&r! \\n\\nOnde você pode ver os Biomas para encontrar &4Treinadores&r de &4&oSérie&r, você também pode encontrar um Item Característico. Este Item precisará ser colocado dentro do &4Gerador de Treinador&r. \\n\\nUma vez configurado, dê ao &4Gerador&r um &4Sinal de Redstone&r e ele fará aquele &4Treinador&r da &4&oSérie&r aparecer magicamente na sua frente, pronto para a Batalha! \\n\\nEspero que ele não estivesse fazendo nada importante antes de você invocá-lo..."]
	quest.0AE28C998A3BF136.quest_subtitle: "531.441 Netherrack"
	quest.0AE4F79296B6A4E4.quest_desc: [
		"Aumento de nível para 85."
		""
		"Item de Assinatura é &3Lenço da Escolha&r."
	]
	quest.0AE4F79296B6A4E4.title: "&6Treinador Brendan"
	quest.0AE6AD813928DE4F.quest_desc: ["O Aquecedor Externo pode ser usado com Fornalhas, como as da &2&lVanilla&r, não a &c&lAlto-forno Bruta&r!\\n\\nEle recebe &cEnergia&r pela parte inferior e a usa para Calor.\\n\\nO Calor sai pelos outros lados, para Blocos adjacentes.\\n\\nTecnicamente, é usado para a &4&lAlto-forno Melhorada&r, ao Criar os Pré-aquecedores, mas eu não conto isso!"]
	quest.0AE83A6CC21F96D4.quest_desc: ["Eletrólisar uma &#3127F5Singularidade&r produzirá &#DA27F5Matéria UU&r. Nesse processo, a &#3127F5Singularidade&r &n&aNÃO&r é consumida."]
	quest.0AE8B51D63327EC3.title: "Módulo de Recuperação de Escudo Caótico"
	quest.0AE930BA037DC565.quest_desc: ["Confira os Módulos para aprender mais sobre como usar e aprimorar os itens do DE! Funciona como um Arco normal, atirando flechas. Cada tiro consome uma quantidade de Energia do próprio Arco, então sim, você precisará de pelo menos Módulos de Energia."]
	quest.0AE930BA037DC565.title: "Arco Wyvern"
	quest.0AEAEA976ED0C470.quest_desc: ["A &3Estação de Carregamento&r é usada para carregar várias ferramentas e dispositivos em &aPneumaticCraft&r usando pressão."]
	quest.0AEAEA976ED0C470.quest_subtitle: "Onde está o cabo?"
	quest.0AEC181F5E21A299.quest_desc: ["Se você já ouviu alguém falando sobre \"Poder do Melão\", é isso. O &dGerador a Gás&r do Mekanism pode produzir uma boa quantidade de energia bombeando &9Etileno&r feito de Fatias de Melão.\\n\\nPara produzir &dEtileno&r, comece triturando materiais orgânicos em um &eTriturador&r para criar &6Biocombustível&r. Fatias de Melão são normalmente usadas para isso! Isso é então bombeado para uma &dCâmara de Reação Pressurizada&r (PRC para abreviar).\\n\\nA PRC precisa de Água, Biocombustível e um pouco de Hidrogênio para criar Etileno. Você pode obter o Hidrogênio separando a água em um &9Separador Eletrolítico&r.\\n\\nDepois de começar a produzir o Etileno, bombeie-o para o Gerador a Gás para começar a gerar energia!"]
	quest.0AEC181F5E21A299.quest_subtitle: "PODER DO MELÃO!"
	quest.0AEC181F5E21A299.title: "&9Mekanism: &dGerador a Gás"
	quest.0AF2460579C6BD8C.quest_subtitle: "Ósmio + Obsidiana"
	quest.0AF2460579C6BD8C.title: "&fAbelha de Obsidiana Refinada"
	quest.0AF5FB1B5AA5AA11.quest_subtitle: "Tier: &b4"
	quest.0B0BDC37185AF9EC.quest_desc: [
		"Aros Ancestral são torres altas feitas de Cera Ancestral.\\n\\nNo topo pode haver Aros com Ar Ventoso fluindo por eles.\\n\\nÉ lá também que você encontrará Casulos!\\n\\nParece um ótimo lugar para usar a Élitros!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_hoops.png width:200 height:100 align:center}"
	]
	quest.0B0BDC37185AF9EC.title: "Aros Ancestral"
	quest.0B11EAB8D76529E0.quest_desc: [
		"A &6Cidade Ancestral&r é apenas a Estrutura mais perigosa do &2&lMinecraft Vanilla&r. Então, é claro que isso é apenas o começo para &3&lDeeper and Darker&r! \\n\\nAqui podemos encontrar &3Sculk&r em abundância, juntamente com Saques e o &9&lWarden&r. Também encontraremos a Estrutura do Portal feita de &8Ardosiabissal Reforçada&r. \\n\\nMas até lá, saqueie tudo o que puder! E tenha cuidado com o..."
		"{image:atm:textures/questpics/allthemodium/all_city.png width:200 height:100 align:center}"
	]
	quest.0B11EAB8D76529E0.title: "Visite uma &6Cidade Ancestral&r"
	quest.0B1DF8A040826D87.quest_desc: ["Agora que você tem &cRossinita&r, pode misturá-la com &aBenitoíta&r para criar Barras de &dInsanita&r.\\n\\nO &aMinério de Benitoíta&r pode ser encontrado no Nether."]
	quest.0B1DF8A040826D87.title: "Insanita"
	quest.0B218DD73FE8D985.quest_desc: ["Se você fez a última missão corretamente, deve ter transformado aquela singularidade em um par de &5Singularidades Quanticamente Entrelaçadas&f. Essas novas singularidades são usadas para conectar um dispositivo em forma de anel conhecido como &ePonte de Rede Quântica&f.\\n\\nQuando dois desses anéis individuais são conectados usando as &5Singularidades Quanticamente Entrelaçadas&r e inicializados com um pouco de energia AE (por exemplo, uma célula de energia), uma Rede ME pode ser expandida sem fio do outro lado da ponte, seja por longas distâncias ou até mesmo entre dimensões."]
	quest.0B218DD73FE8D985.title: "Ponte de Rede Quântica"
	quest.0B35172E47705205.quest_desc: ["Sim, o &bIndustrial Foregoing&r tem processamento de minério também. Este usa &6Carne Líquida&r para converter um minério em Carne de Minério Bruta. Eu não sou um médico de minérios, então não posso fazer exatamente nada com esta Carne de Minério Bruta. Talvez dar para a Estação de Fermentação?"]
	quest.0B35172E47705205.quest_subtitle: "Processamento de Minério: Passo 1"
	quest.0B37355262121DD5.quest_desc: ["O &aAltar de Infusão&r é como você faz todas as sementes. Coloque o Altar primeiro e ele mostrará onde colocar os Pedestais depois.\\n\\nPara que a Infusão comece, o Altar requer um &4sinal de Redstone&r."]
	quest.0B37355262121DD5.quest_subtitle: "Criando Sementes"
	quest.0B37355262121DD5.title: "&4Altar de Infusão"
	quest.0B3EA604C5172D98.quest_desc: [
		"Para especificarmos qual &c&mDemônio&r &9Amigo&r queremos invocar, precisaremos fazer um &bLivro de Vinculação&r específico.\\n\\nPara fazer isso, você precisará purificar um pouco de Corante Preto em &dFogo Espiritual&r para obter Tinta Purificada. Com isso, vamos fazer nosso primeiro Livro de Vinculação que invocará um Demônio &aFoliot&r."
		""
		"Alternativamente, você pode fazer um Livro de Vinculação Vazio, que pode ser tingido mais tarde para se adequar a qualquer nível de ritual que você precise."
	]
	quest.0B3EA604C5172D98.title: "&bLivros de &dVinculação"
	quest.0B485DB737A036E9.quest_desc: ["O Copiador de Configurações de Máquina permite que os jogadores copiem as configurações entre as máquinas."]
	quest.0B4CE3969067FA31.quest_desc: [
		"A Armadura Quântica pode ser aprimorada com uma variedade de diferentes melhorias."
		""
		"Para aprimorar sua Armadura Quântica, abra o Menu de Configuração da Armadura Quântica pressionando sua respectiva tecla de atalho (N por padrão)."
	]
	quest.0B4CE3969067FA31.title: "Melhorias para Armadura Quântica"
	quest.0B60DA8F65E5DF06.quest_desc: ["Você pode triturar o &#A140A1Tungstênio Bruto&r de várias formas para obter &#C452C4Pó de Tungstênio&r."]
	quest.0B6D35F5B3A11FD2.quest_desc: ["O &9Cache de Aura&r pode ser usado para armazenar &aAura&r!"]
	quest.0B6D35F5B3A11FD2.quest_subtitle: "Depositando!"
	quest.0B6D35F5B3A11FD2.title: "&9Cache de Aura"
	quest.0B70D40FA951E13B.quest_subtitle: "Carvalho + Bétula"
	quest.0B718FC37699B822.quest_desc: ["Os &aTroncos de Eco&r são feitas de &aÁrvores de Eco&r que aparecem na &5Floresta Ecoante&r... há um eco aqui, por que ouço tanto isso? \\n\\nAs &aÁrvores de Eco&r têm &5Folhas Roxas&r e Brilho de Sculk dentro delas. Enquanto suas Toras têm uma &7Casca Cinza Clara&r e uma cor de &aTronco Verde muito Clara&r. \\n\\nTodas as Tábuas e Itens de Madeira feitos a partir dela são todos da &aCor Verde Clara&r, quase como Menta. \\n\\nOs Alçapões e as Portas têm padrões únicos e legais!"]
	quest.0B718FC37699B822.title: "&aÁrvores de Eco"
	quest.0B7A76864B36BB51.quest_desc: [
		"Aumento de nível para 82."
		""
		"Item de Assinatura é &7Ovo da Sorte&r."
	]
	quest.0B7A76864B36BB51.title: "&6Rival Terry"
	quest.0B7F2B63D867D221.quest_desc: ["Para encontrar estes, precisaremos de um pouco de arqueologia!\\n\\nNo poço gigante que você pegará para chegar ao &e&lRemanescente Ancestral&r, existem 3 salas nas laterais dele.\\n\\n2 dessas salas têm Areia Suspeita que você pode usar um Pincel para obter Saque! Incluindo o &eColar do Deserto&r.\\nEntão, clique com o botão direito no &e&lRemanescente Ancestral&r com o &eColar do Deserto&r para ressuscitá-lo!"]
	quest.0B7F2B63D867D221.quest_subtitle: "Ressuscitando um Remanescente Ancestral"
	quest.0B7F2B63D867D221.title: "&eColar do deserto"
	quest.0B9BBE2A764631BF.quest_desc: ["O trocador simples pode teletransportar itens, blocos, mobs ou jogadores acima dele para outro trocador simples ao qual está ligado. Para ligar os trocadores, use a chave Ferricore."]
	quest.0BB367839D28607D.quest_desc: ["Estes &8Geradores a Carvão&r são alguns dos geradores mais fáceis de fazer.\\n\\nEles são muito simples de usar e criam uma quantidade decente de energia com base no material combustível que você coloca. Eles também distribuem energia automaticamente para blocos adjacentes."]
	quest.0BB367839D28607D.quest_subtitle: "Combustíveis Fósseis"
	quest.0BB367839D28607D.title: "&8Geradores a Carvão"
	quest.0BB42C5861B22D32.quest_desc: ["O &bReator Micelial&r consiste em todos os Geradores Miceliais funcionando ao mesmo tempo, perto do bloco do reator, e produz um total de &a25MFE/t&r.\\n\\nTudo parece bom, mas você precisa automatizar algumas coisas para fazê-lo funcionar, veja o que cada Gerador Micelial consome para funcionar e automatize, a maioria das coisas é simples, mas outras, nem tanto... &oolhando para o Gerador Micelial de Desencantamento&r.\\n\\nMas depois que você automatizar tudo, não precisa parar em um, pode fazer mais reatores."]
	quest.0BB42C5861B22D32.quest_subtitle: "Não é o Seu Reator Micelial"
	quest.0BB42C5861B22D32.title: "&9Industrial Foregoing: &bReator Micelial"
	quest.0BB562FB44B0AAA7.quest_desc: ["Os cartões não são os únicos com limites, então eles também não são os únicos com Overclockers!\\n\\nEstes vão para o próprio &cNó&r no canto inferior direito e aumentam a velocidade com que ele realiza Operações."]
	quest.0BB562FB44B0AAA7.quest_subtitle: "Máx: 8"
	quest.0BB8D556305EB307.quest_desc: [
		"O Rio de Éter é algo que você saberá quando vir.\\n\\nÉ luminoso, muito luminoso e pode aparecer vermelho no seu Mapa, isso é um bug, ignore."
		"{image:atm:textures/questpics/eternal/starlight_ether.png width:200 height:100 align:center}"
	]
	quest.0BB8D556305EB307.title: "Rio de Éter"
	quest.0BCCDE24D378F260.quest_subtitle: "Nível: &d3"
	quest.0BCCDE24D378F260.title: "&dChassi de Máquina Avançado"
	quest.0BD6365534BF04D5.quest_desc: [
		"Com o Giz de Lima, é hora de mergulhar nos &5Rituais de Possessão&r. Esses rituais são um pouco diferentes dos outros porque todos exigem um sacrifício vivo, geralmente mobs pequenos como Galinhas, Abelhas, Morcegos, etc. No entanto, à medida que os rituais se tornam mais complicados, eles exigirão sacrifícios cada vez maiores."
		""
		"Mesmo que você tenha colocado todos os itens necessários e o Livro de Vinculação na Tigela Sacrificial Dourada, o Ritual não começará até que você mate o sacrifício em cima das runas."
		""
		"Recomenda-se que você faça algum tipo de item de captura de mob, como uma Gema de Alma Vazia, Jarra, Ferramenta de Aprisionamento de Mob ou Apanhador Quântico!"
		""
		"O primeiro nível de &5Rituais de Possessão&r é a &eAtração de Heidryn&r, que é usada apenas para obter itens mundanos como Crânios de Esqueleto e Pedra do End. Por causa disso, você pode pular diretamente para o segundo nível de ritual, o &aFascínio de Ihagan&r."
	]
	quest.0BD6365534BF04D5.quest_subtitle: "Quem você vai chamar?"
	quest.0BD6365534BF04D5.title: "&aFascínio de Ihagan"
	quest.0BD70EAB43DBD003.quest_desc: ["Ele aumentará seu Nível novamente! Só que desta vez para 39. \\n\\nSeu Item de Assinatura agora é uma &bPedra da Alvorada&r."]
	quest.0BD70EAB43DBD003.title: "&6Treinador Pokemon Cedric"
	quest.0BD908937BC6E97B.quest_subtitle: "Kapok + Rosewood"
	quest.0BE2E7C9454058C3.quest_desc: [
		"Parte do belo &d&lPrado Floral&r é uma &dCerejeira&r muito mais velha e maior que as outras.\\n\\nAs &6A&8b&6e&8l&6h&8a&6s&r parecem ter gostado dessas &dÁrvores&r e montaram mini &eColmeias&r ao lado delas, cheias de seus filhotes!"
		"{image:atm:textures/questpics/bumblezone/bumble_cherry.png width:200 height:100 align:center}"
	]
	quest.0BE2E7C9454058C3.title: "&dCerejeira Veterana"
	quest.0BE6CE2C264140AD.quest_subtitle: "Tier: &a2"
	quest.0BFAF1499415DD68.quest_subtitle: "Silver Lime + Cherry"
	quest.0C096EE635645E43.quest_desc: ["A Besta de Cristal é fabricada como uma Besta Mecânica, só que com Cristais em vez de gravetos.\\n\\nEla atira Flechas e causa o mesmo dano que uma Besta normal, mas esta causa Infecção de Cristal. A Infecção de Cristal causa 1 de dano a cada segundo com os Cristais que aparecem neles! E sim, isso os matará."]
	quest.0C1D55AA9CC902BD.quest_desc: [
		"Melhorias Válidas:"
		"- Lawnmower"
		"- Sky Sweeper"
		"- Auto Smelter"
		"- Hammer"
		"- Drops Teleporter"
	]
	quest.0C229BE9B57269EF.quest_desc: ["O &#EBA844Pó de Kanthal&r deve ser fundido em um &#816DF7Alto-forno Elétrico&r."]
	quest.0C2EC56133D3CC6C.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		""
		"Torna o jogador temporariamente imune a danos quando ativada, possui um tempo de recarga."
	]
	quest.0C72FEE8AF6A3DDC.quest_desc: [
		"Sem Aumento de Nível."
		""
		"O Item de Assinatura é Feitiço."
	]
	quest.0C72FEE8AF6A3DDC.title: "&3Elite dos Quatro Elias"
	quest.0C7491BA5857AA00.quest_subtitle: "Teak + Jungle"
	quest.0C7D96DB3573EF9C.quest_desc: [""]
	quest.0C7D96DB3573EF9C.quest_subtitle: "&oHabilidade de criar vida."
	quest.0C7D96DB3573EF9C.title: "&5&lEssência Criativa"
	quest.0C8180524757B238.quest_desc: [
		"&7Flutuadores&r não são tecnicamente estruturas nos arquivos do Minecraft, mas ainda são em termos leigos.\\n\\nEles podem aparecer em qualquer Bioma, mas sempre e abundantemente nas &7&lConstruções Uivantes&r!\\n\\nSão estruturas flutuantes em forma de disco feitas de Cera Ancestral. Se você ainda não usou a Essência de Abelhas, receberá Fraqueza, Lentidão e Fadiga de Mineração ao tocar na Cera Ancestral. Há também &6Casulos de Mel&r ou &5Cristais&r neles!"
		"{image:atm:textures/questpics/bumblezone/bumble_floaters.png width:200 height:100 align:center}"
	]
	quest.0C8180524757B238.title: "&7Flutuadores"
	quest.0C856BBB1679A7DD.quest_desc: ["Nesta página, você encontrará alguns itens úteis e informações para ajudá-lo em sua jornada!"]
	quest.0C856BBB1679A7DD.quest_subtitle: "E Outros Itens Úteis!"
	quest.0C92029DF6B9080A.quest_desc: [
		"Aumento de nível para 79."
		""
		"Pode ser encontrado aleatoriamente em &9Ginásios&r que geram em &a#minecraft:village&r"
	]
	quest.0C92029DF6B9080A.title: "&aLíder Blaine"
	quest.0C93D7A607AB8B83.quest_desc: ["Para reivindicar chunks, abra seu mapa usando &6M&r, então clique no ícone &aChunks Reivindicadas&r no canto superior esquerdo.\\n\\nPara reivindicar um chunk, clique com o botão esquerdo e arraste para reivindicar.\\n\\nPara carregar um chunk à força, use shift+clique esquerdo no chunk. Se feito corretamente, você verá linhas atravessando o chunk."]
	quest.0C94D76B87E49FFD.title: "&fProcessamento de &7Ferro"
	quest.0C98503A2F20484D.quest_desc: [
		"Perto dos Campos de Gelo, você pode encontrar Florestas de Smogstem Congeladas.\\n\\nSão como os Campos de Gelo, só que com Árvores de Smogstem!"
		"{image:atm:textures/questpics/undergarden/undergarden_frostytrees.png width:200 height:100 align:center}"
	]
	quest.0C98503A2F20484D.title: "Floresta de Smogstem Congelada"
	quest.0C9C5639D76FDF65.quest_desc: ["Salve 12 &6A&8b&6e&8l&6h&8a&6s&r recolocando seu Ferrão.\\n\\nQuando uma &6A&8b&6e&8l&6h&8a&6s&r atinge um Mob ou até mesmo você, ela perde seu Ferrão, o que lhe dá um Veneno Fatal.\\n\\nSe você clicar com o botão direito nela com um Ferrão, pode recolocá-lo e salvá-la!"]
	quest.0C9DD8E53A1B92C0.quest_desc: [
		"Melhorias Válidas:"
		"- Ore Miner"
		"- Auto Smelter"
		"- Hammer"
		"- Drops Teleporter"
		"- X-Ray"
		"- Instant Break"
	]
	quest.0C9F9196CA49FF8D.quest_subtitle: "Encontre minério de níquel para começar sua jornada"
	quest.0C9F9196CA49FF8D.title: "O Início no Oritech"
	quest.0CB92F8E8C685159.quest_desc: ["A &cPedra do Sol&r irá &bEvoluir&r &2Glo&5om&r para &2Bellossom&r, &2Sunkern&r para &2Sunflora&r, &2Cotto&dnee&r para &2Whimsi&dcott&r, e &2Petilil&r para &2Lilligant&r."]
	quest.0CB92F8E8C685159.title: "&cPedra do Sol"
	quest.0CBFE2CE53DCACD5.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Aumenta a altura do pulo do jogador."
	]
	quest.0CC0632E8276C787.quest_desc: ["Coloque a Plataforma de Teleporte no &l&cNether&r para ir para &b&lO Outro&r."]
	quest.0CC0632E8276C787.title: "&c&lO Nether"
	quest.0CC48C2AA553A314.quest_desc: ["&3Brocas&r podem ser usadas em uma Britadeira Pneumática."]
	quest.0CD04A00529FE1C9.quest_desc: ["O Baú de Cobre pode ser feito, mas não é necessário para fazer um Baú de Ferro, pode ser usado se você quiser economizar um pouco de Ferro."]
	quest.0CD04A00529FE1C9.title: "&6Baú de Cobre"
	quest.0CD36928116E868E.quest_desc: ["&#F783F3Cloreto de Vinila&r pode ser misturado com &#9683F7Pó Pequeno de Chumbo&r ou &#FEA8FFPó Pequeno de Cromo&r para obter &#F36EF5Policloreto de Vinila&r."]
	quest.0CD6F30BBEE20E15.quest_subtitle: "Pedra Luminosa + Ósmio"
	quest.0CD6F30BBEE20E15.title: "&fAbelha de Pedra Luminosa Refinada"
	quest.0CE236731DF15DFF.quest_desc: ["Por que esperar? Geralmente, os itens dropados no Minecraft precisam de um segundo no chão para serem pegos novamente.\\n\\nMas por que esperar?\\n\\nEsta melhoria permite que o Módulo de Vácuo não espere e pegue os itens imediatamente.\\n\\nMuito bom para menos lag!"]
	quest.0CE62B46FD2C48FE.quest_desc: [
		"Como literalmente todos os outros passos, existem várias maneiras de formar nossos &7Mecanismos&r. \\n\\nVocê pode usar &6Implementadores&r para bater em uma &7Base de Bola&r primeiro com uma Pepita, depois com um &8Eixo&r, e então com a outra &7Base de Bola&r para criar um &7Mecanismo&r completo. "
		"{@pagebreak}"
		"Também temos a &7Câmara de Pressão&r do &8&lPneumaticCraft&r. \\n\\nVocê precisará de uma Interface da Câmara de Pressão, 2 Válvulas, e Paredes ou Vidros de Câmara de Pressão. \\n\\nO Interface é como você coloca Pressão dentro da Câmara de Pressão, sim, será necessária Pressão para fabricá-lo. \\n\\nAs Válvulas são por onde os Itens entram (pelo Lado Azul) e saem (pelo Lado Laranja). \\n\\nAs Paredes ou Vidros preencherão o restante da estrutura além do centro. Este precisa ser oco."
		"{@pagebreak}"
		"A &cMontadora&r (diferente da &8Linha de Montagem&r) é perfeito para nossas Receitas de Fabricação 2x2 detalhadas. \\n\\nPrimeiro, precisaremos fazer nossa Máquina. Coloque a &cMontadora&r com 3 Revestimento de Máquinas em um design 1x2x2. Então, Clique com o Botão Direito na &cMontadora&r para montá-la. \\n\\nAgora podemos dar a ela um pouco de &cEnergia&r e ele fará nossos &7Mecanismos&r!"
	]
	quest.0CE62B46FD2C48FE.title: "Implantando"
	quest.0CF69DBA9573A7B3.quest_desc: [
		"A Mesa de Esquemas lerá e escreverá estruturas de/para seus esquemas."
		""
		"Você pode usá-la para copiar construções ou para compartilhá-las com outros!"
	]
	quest.0CFF4E3560CFFB49.quest_desc: ["Cada &cPokémon&r precisa de sua &bMega Pedra&r específica para se tornar &bMega&r. \\n\\nÉ bem fácil saber de quem é cada uma, porque geralmente elas são nomeadas com o nome do &cPokémon&r seguido de \"ita\". \\n\\nCada uma precisa de uma &bMega Pedra&r, 2 Lingotes de Ferro, um &bDiamante&r e um item único para aquele &cPokémon&r. \\n\\nAlém disso, Charizard e Mewtwo possuem duas formas de &bMega&r com X e Y."]
	quest.0CFF4E3560CFFB49.title: "&bMega Pedras&r Específicas"
	quest.0D18BBB04693885A.quest_desc: ["A Ligação Superior de Strigeor é o segundo nível dos &6Rituais de Infusão&r. É usado para muitas coisas diferentes, mas as principais coisas que precisaremos são a Picareta Infundida e a Pasta Cinza."]
	quest.0D18BBB04693885A.quest_subtitle: "O Ritual \"de Tudo\""
	quest.0D18BBB04693885A.title: "&aLigação Superior de Strigeor"
	quest.0D212038C0A45E0B.quest_desc: ["Cartuchos Casull são as Balas padrão. Eles causam 5 Corações de Dano, e é só!\\n\\nCartuchos Perfurantes de Armadura terão uma chance maior de ignorar Pontos de Armadura. Isso é perfeito contra Mobs como o Bulwark.\\n\\nCartuchos de Chumbo Grosso, em vez de atirar 1 Projétil, atirarão múltiplos Projéteis. Use a curta distância para melhores efeitos!\\n\\nCartuchos de Prata agirão como Cartuchos Casull, mas com maior Dano aos Mobs Mortos-Vivos: Zumbis e Esqueletos!"]
	quest.0D212038C0A45E0B.title: "Projéteis Comuns"
	quest.0D26E5EF6CFCFDBF.quest_desc: ["Durabilidade maior que uma Adaga, mas dano e velocidade menores."]
	quest.0D26E5EF6CFCFDBF.quest_subtitle: "Perfurante"
	quest.0D2D1F99945BA209.quest_desc: ["Supostamente, deve Equipar seu &8&lEscudo Pesadamente Banhado&r quando você Toca Duas Vezes em S... ênfase no supostamente.\\n\\nLembre-se que o &8&lIE&r ainda está em Beta! O desenvolvimento de Mods leva muito tempo e esforço, seja respeitoso com isso!"]
	quest.0D2DD9AA960843A3.quest_desc: ["O Detector de Mobs detectará entidades em sua área de trabalho e emitirá um sinal de redstone atrás dele com força igual à quantidade de entidades na área de trabalho.\\n\\nEsta máquina suporta Adicionais de Alcance."]
	quest.0D2F5CC96269F9E3.quest_desc: ["O próximo passo na fabricação de PCBs envolve o uso do &3Tanque de Corrosão&r com Ácido de Corrosão. Requer calor para funcionar."]
	quest.0D2F5CC96269F9E3.quest_subtitle: "É Hora da Corrosão!"
	quest.0D31CD79BE6CC8D2.quest_desc: ["Por que o Pão normal não precisa de Fermento?"]
	quest.0D31CD79BE6CC8D2.quest_subtitle: "O Fermento dos seus Problemas"
	quest.0D31CD79BE6CC8D2.title: "Fermento"
	quest.0D330FAD6C993DBC.quest_desc: ["Esta é a próxima melhoria para o seu Livro de Feitiços!\\n\\nIsso aumentará sua mana geral e regeneração de mana, além de permitir que você crie e use Glifos de Nível 2."]
	quest.0D4C64DD58567758.quest_desc: ["Adiciona um tanque à Mochila."]
	quest.0D4FE97640F2CA60.quest_desc: ["O &bDestruidor Ultra&r tem 36 espaços para filtros, funciona 5x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.0D4FE97640F2CA60.title: "&bDestruidor Ultra"
	quest.0D5015B8FF482D0A.quest_desc: [
		"Precisaremos encomendar algumas coisas da &3Amadron&r usando o &3Tablet Amadron&r para continuar a progressão. Para usá-lo, segure shift e clique com o botão direito em um Baú e um tanque de Fluido, coloque sua moeda em um contêiner vinculado (Esmeraldas, etc) e faça um pedido. Você verá um Amadrone descer para pegar seu dinheiro e outro Amadrone vir para entregar o que você pediu."
		""
		"{image:atm:textures/questpics/pneumaticcraft/amadron_drone.png width:300 height:150 align:center}"
	]
	quest.0D5015B8FF482D0A.quest_subtitle: "Será que eles têm entrega em 1 dia?"
	quest.0D5015B8FF482D0A.title: "Amadron"
	quest.0D501F8E9C5EC0B4.quest_desc: ["&9Pedras da Água&r são encontradas abaixo de Oceanos, Rios e Pântanos. \\n\\nSe isso não for suficiente para você, tente Selvas!"]
	quest.0D501F8E9C5EC0B4.title: "Encontrando &9Pedras da Água"
	quest.0D50BDEFA0319EA1.quest_desc: ["Isso irá dropar o produto final no seu baú de saída."]
	quest.0D50BDEFA0319EA1.quest_subtitle: "Sempre Necessário"
	quest.0D5691403AEC25A8.quest_desc: [
		"Roteadores também podem ser usados para Agricultura!\\n\\nPrimeiro comece com uma Fazenda simples. Depois, você precisará de um Módulo Ativador e direcioná-lo para as Colheitas. Depois disso, coloque um Módulo de Vácuo em seu Roteador para coletar as Colheitas. Finalmente, coloque tudo no Roteador, energize-o com Redstone e deixe-o cultivar!"
		"{image:atm:textures/questpics/router/router_farm.png width:60 height:150 align:center}"
	]
	quest.0D5691403AEC25A8.title: "Roteadores para Agricultura"
	quest.0D5D76B3551CD5A7.quest_desc: ["Sim, é chamada de Abelha de Alumínio."]
	quest.0D5D76B3551CD5A7.quest_subtitle: "Crystalline + Ashy Mining"
	quest.0D5D76B3551CD5A7.title: "&fAbelha de Alumínio"
	quest.0D6D45DBA64E612D.quest_desc: [
		"O &9Atraso Máximo de Spawn&r é o tempo máximo que pode levar para &9Gerar Mobs&r.\\n"
		"Assim como o &9Mínimo&r, ele pode ser tão baixo quanto &e20&r e tão alto quanto &e32.767&r.\\n"
		"Cada Relógio modifica a velocidade do gerador em &e10&r.\\n"
		"A velocidade é expressa em ticks, sendo que &e20 ticks&r equivalem a 1 segundo.\\n"
		"Então, o menor atraso de spawn seria &e1 segundo&r entre cada geração."
	]
	quest.0D6D45DBA64E612D.title: "&fAtraso Máximo de Spawn"
	quest.0D888A4C5EF0073E.quest_subtitle: "Mogno + Kapok"
	quest.0D8B4DAB82ABEF9D.quest_desc: ["Aceleradores Quânticos adicionam 8 threads de coprocessamento cada ao multibloco do Computador Quântico. É importante notar que todos os trabalhos de crafting sendo executados pelo Computador Quântico podem compartilhar todos os coprocessadores, então é uma boa ideia investir em uma grande quantidade deles."]
	quest.0D8B4DAB82ABEF9D.title: "Esquecimento do Coprocessamento: Acelerador de Computador Quântico"
	quest.0D91A6B36BD2F526.quest_desc: ["Melhore seu &7Machado de Batalha de Cloggrum&r para fazer a melhor arma que o &2&lUndergarden&r pode oferecer!"]
	quest.0D91A6B36BD2F526.title: "Arma Suprema!"
	quest.0D9560C8E247F9E7.quest_desc: ["Clique com o botão direito em algum lugar e você poderá encontrar o caminho de volta. Se estiver perto o suficiente e tiver uma rota direta, um caminho aparecerá."]
	quest.0D9560C8E247F9E7.quest_subtitle: "Máx: 1"
	quest.0D97CDE92F3B1A83.quest_subtitle: "Despeje Endério Derretido sobre um Ovo de Gerador de Abelha de chumbo/diamante/platina"
	quest.0D97CDE92F3B1A83.title: "&fAbelha de Endério"
	quest.0DAF5D42694EA8C9.quest_desc: [
		"O &9Martelo de Forja&r é o começo da sua jornada. Ele tem muitos usos, como obter um &#B53A3Amelhor rendimento&r dos seus minérios até fabricar &#DBD25Acomponentes&r para receitas futuras."
		""
		"O &9Martelo&r que você fabricou não é necessário para nenhuma receita, mas fornecerá um melhor rendimento nos &#DBD25Acomponentes&r que você fabricar."
	]
	quest.0DAF5D42694EA8C9.title: "&9Martelo de Forja"
	quest.0DC8B68CDF945348.quest_desc: ["O Roteador dá e o Roteador tira.\\n\\nEste Módulo é útil para Construtores ou até mesmo Mineradores! Ele pode ser configurado para enviar itens de seu Buffer para seu Inventário ou pegar itens do seu Inventário para seu Buffer.\\n\\nPerfeito para Mineração em Faixa, faça com que ele pegue todo o Pedregulho e Ardósia Profunda do seu Inventário e coloque em uma Lixeira."]
	quest.0DF4B01CC5B49E4E.quest_desc: ["Com este Molde, você pode fazer a espada básica! Dano confiável e velocidade confiável."]
	quest.0DF4B01CC5B49E4E.quest_subtitle: "O bom e velho confiável"
	quest.0E02CE4469FCA4C9.quest_desc: [
		"A &cAtivação por Redstone&r dá ao seu spawner um interruptor de ligar/desligar.\\n"
		"&2Sem Energia&r de Redstone, ele não gerará mobs."
	]
	quest.0E02CE4469FCA4C9.title: "Ativo por Redstone"
	quest.0E03F5EAE4963ECB.quest_subtitle: "8 Blocos Verdes Secos"
	quest.0E057B7F76401421.quest_subtitle: "A Primeira Melhoria"
	quest.0E057B7F76401421.title: "&6Mochila de Cobre"
	quest.0E06F323BF8C1D73.quest_desc: [
		"Dada a inevitabilidade da decomposição do Fluix Entroizado em Drusa, você pode querer outras maneiras de cultivá-los automaticamente."
		""
		"Felizmente, existe uma abelha para isso."
	]
	quest.0E06F323BF8C1D73.quest_subtitle: "Para quando você não consegue lidar com a decomposição"
	quest.0E06F323BF8C1D73.title: "Automatizando Cristais Entro"
	quest.0E0CAA31480EC0A1.quest_desc: ["Permite que a Mochila colete itens."]
	quest.0E0CAA31480EC0A1.quest_subtitle: "Permite que a mochila colete itens."
	quest.0E175356D43E6A10.quest_desc: [
		"Bom, bom, agora temos &eCloro&r. O que mais precisamos para o &3Cloreto de Hidrogênio&r? Ah, sim, Hidrogênio!\n\nAlimente um pouco de &9Água&r a um &9&lSeparador Eletrolítico&r, como no Nível 1, para obter Hidrogênio e &bOxigênio&r. Só que desta vez precisamos guardar o Hidrogênio.\n\nCom nosso &a&lInfusor Químico&r podemos combinar Hidrogênio e &eCloro&r para fazer &3Cloreto de Hidrogênio&r.\n\nCanalize esse &3Cloreto de Hidrogênio&r para uma &c&lCâmara de Injeção Química&r para &cInjetar&r em &7Minérios&r para obter &7Fragmentos&r.\n\n&7Blocos de Minério&r darão 4 &7Fragmentos de Minério&r enquanto 3 &7Minérios Brutos&f darão 8 &7Fragmentos de Minério&r."
		"{image:atm:textures/questpics/mek/mek_tier3_2.png width:150 height:100 align:center}"
	]
	quest.0E175356D43E6A10.quest_subtitle: "Processamento de Minério Tier 3"
	quest.0E175356D43E6A10.title: "&cInjetando &3Cloreto de Hidrogênio"
	quest.0E1ABCAA87120367.quest_subtitle: "Tier: &c5"
	quest.0E20A9B79D1C6637.quest_desc: ["O Warden é um chefe adicionado na 1.20.\\n\\nEle aparece quando 3 Sculk Shriekers que surgem naturalmente são ativados em sequência, ou quando qualquer Shrieker é ativado após a aparição do primeiro Warden.\\n\\nEle é o Mob mais poderoso adicionado pelo Minecraft, com 500 Corações e mais de 20 Corações de dano com seus ataques.\\n\\nSeus ataques incluem te atingir e Explosões Sônicas para os mais distantes.\\n\\nSua única fraqueza é ser cego, mas como o Demolidor, isso apenas tornou seus outros sentidos muito mais fortes! Se você estiver perto, ele pode te cheirar e cuidado ao fazer barulho!\\n\\nSe de alguma forma você matá-lo, ele dropará: Catalisadores de Sculk, Carapaça de Warden e Coração das Profundezas."]
	quest.0E20A9B79D1C6637.title: "&fMate o &3Warden"
	quest.0E2515424291BB59.quest_desc: ["Versão de &bDiamante&r das Armaduras &d&lArs&r!"]
	quest.0E2515424291BB59.quest_subtitle: "20"
	quest.0E2515424291BB59.title: "&5Traje de Mago de Batalha"
	quest.0E2AD156E5EF263A.quest_desc: ["Usado para inscrever feitiços com a Mesa do Escriba."]
	quest.0E32DB6B8E023764.quest_desc: ["&6&lProductive Bees&r? O que vocês estão fazendo aqui?\\n\\nÀs vezes, ao longo das &6&lHive Walls&r ou &6&lPillars&r, você pode encontrar depósitos de Combs das &l&6Productive Bees&r!\\n\\nMeio como minerar Minérios no &2Mundo Superior&r."]
	quest.0E32DB6B8E023764.title: "Crossover?"
	quest.0E345B5B625E6235.quest_subtitle: "Fabricado com Aparelho de Encantamento"
	quest.0E345B5B625E6235.title: "&fAbelha de Essência da Terra"
	quest.0E3FDD8BB6D17A30.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		""
		"Quebra folhas próximas quando ativada."
	]
	quest.0E487EACA837EA9B.title: "Módulo de Controle de Escudo Caótico"
	quest.0E4DA8EE961D443F.quest_subtitle: "Sicômoro + Bordo-de-açúcar"
	quest.0E5AE195158CF344.quest_subtitle: "Melhoria de Armazenamento x32"
	quest.0E5AE195158CF344.title: "&dMelhoria de Netherita"
	quest.0E65BE9460B74000.quest_desc: [
		"As Estruturas Logísticas precisam se conectar a um &3Módulo de Logística&r para funcionar."
		""
		"{image:pneumaticcraft:textures/patchouli/logistics_module.png width:100 height:100 align:left fit:true}"
	]
	quest.0E716B90E60C486B.quest_desc: ["Às vezes, a melhor maneira de lutar, não é lutar... é fugir!\\n\\nCom o &4Colar do Pânico&r, ao ser atingido, você receberá o Efeito de Velocidade por um curto período. Tempo suficiente para fugir!"]
	quest.0E716B90E60C486B.quest_subtitle: "Colar"
	quest.0E716B90E60C486B.title: "&4Colar do Pânico&r"
	quest.0E7C79861D18D885.quest_desc: ["&4&oBrilliant Diamond and Shining Pearl&r é a campanha para a Região de Sinnoh. \\n\\nComece-a como qualquer outra &4&oSérie&r. Encontre um &4Associado de Treinador&r em Vilas ou Gerando aleatoriamente quando você segura seu &4Cartão de Treinador&r na mão, se ele não tiver uma &4&oSérie&r. \\n\\nNegocie com ele para começar a &4&oSérie BDSP&r. \\n\\nVocê precisará passar por esta &4&oSérie&r para desbloquear outras &4&oSéries&r, incluindo a &4Série&r &6&oATM&r!"]
	quest.0E7C79861D18D885.title: "&4&oBrilliant Diamond and Shining Pearl"
	quest.0E809747193ED3A9.quest_desc: ["O terceiro Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e16777216&f (16384k) bytes de armazenamento."]
	quest.0E809747193ED3A9.quest_subtitle: "x4^2"
	quest.0E809747193ED3A9.title: "&5Componente de Armazenamento de 16M"
	quest.0E8647B8EB4AAC41.quest_desc: ["Mobs Passivos -> Mais &#FF69B4Slime Rosa&r\\nMobs Hostis -> Mais &6Carne&r"]
	quest.0E8647B8EB4AAC41.title: "Slime Rosa \\& Carne Líquida"
	quest.0E9CE6241CDBC420.quest_desc: ["A &9Bomba de Longo Alcance&r é tão especial que tem seu próprio Mod!\\n\\nA &9Bomba&r coletará &9Fontes de Água&r abaixo dela e as substituirá por Pedra.\\nEla precisa de Energia para funcionar, mas vale a pena, tem um alcance enorme!\\n\\nA &9Água&r coletada nela precisará ser bombeada para fora."]
	quest.0E9CE6241CDBC420.title: "&l&9Bomba de Longo Alcance"
	quest.0EA327E405EDFF02.quest_desc: ["A mistura de &#9C6C35Acetileno&r com &#DEAB6DAcido Clorídrico&r resultará em &#F783F3Cloreto de Vinila&r."]
	quest.0EA9E52B67B533DF.quest_desc: ["Quando a Borracha é fundida, ela se transforma em Plástico, que é o recurso principal no Industrial Foregoing."]
	quest.0EADCEA9AB001FC7.quest_desc: [
		"Fonte de Calor muito simples. Coloque sob a Máquina e alimente com Combustível de Fornalha: Carvão, Troncos, Blocos de Algas Secas."
		"{image:atm:textures/questpics/theurgy/theurgy_brazier.png width:100 height:100 align:center}"
	]
	quest.0EADCEA9AB001FC7.title: "Calor tipo Fornalha"
	quest.0EB6ED88895366D0.quest_desc: ["Lembra quando era só Pedra e Pedregulho?"]
	quest.0EB6ED88895366D0.title: "&fPedras do &2Vanilla&r"
	quest.0EBE20E44A7AEC7E.quest_desc: ["Estas &7Unidades&r deixarão seus Pés, e praticamente suas Pernas inteiras, mais longos e mais fortes! \\n\\nVocê consegue dar Saltos em Corrida mais altos e subir degraus mais altos. \\n\\nVocê pode Pular e subir degraus mais altos com mais &7Unidades&r Instaladas, e pode alterar as Configurações da &7Unidade&r para ir ainda mais alto!"]
	quest.0EBE20E44A7AEC7E.quest_subtitle: "Tô grandin!"
	quest.0EBE20E44A7AEC7E.title: "&eUnidade de Propulsão Hidráulica"
	quest.0EC0F93FA4B4BE49.quest_desc: ["Esta máquina só pode ser energizada por &5Lasers Endéricos&r. Usada para fabricar itens de alto valor."]
	quest.0EC0F93FA4B4BE49.quest_subtitle: "Máquina de fabricação suprema"
	quest.0EC2053B191C55C6.quest_desc: ["Extrai Látex de troncos, funciona mais rápido quando recebe energia.\\n\\nVerifique o JEI para troncos aceitáveis e quantidades de Látex. O melhor tronco para usar é Acácia ou Mangue."]
	quest.0EE0946240B41A00.quest_desc: ["&bIgnitium&r é uma melhoria para Netherita. Você precisará de uma &bMelhoria de Ignitium&r que é Criada, e um &bLingote de Ignitium&r que é dropado do &b&lIgnis&r.\\n\\nO &bCapacete de Ignitium&r permite que você veja claramente sob a Lava.\\n\\nO &bPeitoral de Ignitium&r pode ser combinado com uma Élitros.\\n\\nAs &bCalças de Ignitium&r não nos tornam à prova de chamas, mas sim fazem com que os Fogos que cobrem nossos corpos se apaguem mais rápido!\\nAs &bBotas de Ignitium&r nos permitem andar sobre a Lava. Como as Botas de Couro sobre Neve Fofa, você pode Segurar Shift para descer na Lava."]
	quest.0EE0946240B41A00.title: "&bArmadura de Ignitium"
	quest.0EE5B550E4752CF2.quest_desc: ["O Ditto é um verdadeiro casanova, todos o amam! \\n\\nO Ditto pode ser usado para &dCruzar&r com qualquer &cPokemon&r que possa &dCruzar&r, servindo como substituto para um &cPokemon&r ausente. Ele pode até &dCruzar&r com alguns &cPokemon&r que normalmente não podem! \\n\\nQuando você usa um Ditto, o &cOvo&r será da mesma espécie que o &cPokemon&r com o qual o Ditto &dcruzou&r."]
	quest.0EE5B550E4752CF2.title: "&dCruzamento&r com Ditto"
	quest.0EF1ABF3185E4C47.quest_desc: [
		"Aumento de Nível para 28."
		""
		"O Item de Assinatura é Alho-poró Medicinal."
	]
	quest.0EF1ABF3185E4C47.title: "&aLíder Mirskle"
	quest.0EF9C391EE42824A.quest_desc: ["Este é um pouco mais caro, mas também um pouco mais divertido!\\n\\n&bDiamantes&r podem ser obtidos através de praticamente qualquer Mod.\\n\\n&7Sílex&r pode ser obtido de várias maneiras de processar Cascalho: Espremendo, Triturando, Enriquecendo...?\\n\\nDripstone e Blocos de Dripstone (que são apenas 4 Dripstones) podem ser criados a partir de Extratores ou Misturadores, ambos precisam de Dripstones originais para fazer mais."]
	quest.0EF9C391EE42824A.title: "&7Prisma Terrastomp"
	quest.0EF9F10A2178451F.quest_desc: ["Todas as partes da &c&lFundição&r (exceto Torneiras, Bancada de Fundição e Bacias) podem ser tingidas com qualquer &zCor&r, seja do Minecraft Vanilla ou do Dyenamics. &zCores&r são intercambiáveis em uma &c&lFundição&r, também, então você pode ter Fundições multicoloridas, se desejar."]
	quest.0EF9F10A2178451F.title: "&zPartes de &c&lFundição&r &zTingíveis"
	quest.0EFD0A4AE82153E8.quest_desc: ["Você precisará criar esses Tokens também para outros itens."]
	quest.0EFD0A4AE82153E8.title: "Outros Tokens"
	quest.0EFEDB0DD90DFC81.quest_desc: ["O Colhedor pode colher plantações automaticamente e replantá-las. Os itens coletados pelo Colhedor são colocados em seu inventário interno."]
	quest.0EFF1AA37772156B.quest_desc: ["Este bloco fornece água para a cozinha multi-bloco.\\n\\nEle também pode fornecer água infinita bombeando água para fora através de cabos ou canos."]
	quest.0EFF1AA37772156B.quest_subtitle: "1 Bloco resolve o problema!"
	quest.0EFF1AA37772156B.title: "A Pia = Água Infinita"
	quest.0F00BBDF3618B3BA.quest_desc: ["A &3Grade de Fabricação&r permite que você acesse seu armazenamento, mas com uma interface de criação!\\n\\nSejamos honestos, ninguém usa &3Grades&r comuns."]
	quest.0F00BBDF3618B3BA.title: "&3A c Melhor"
	quest.0F03E75CF79BADD7.quest_desc: ["MEGA Cells&f oferece a &bCélula de Armazenamento de Itens em Massa&f personalizada, que é limitada a no máximo &oum&r tipo de item armazenável por célula, mas pode armazenar um número praticamente &6&lINFINITO&e*&r daquele tipo de item. Antes que possa aceitar um tipo de item, deve ser filtrada antecipadamente usando uma Bancada de Células.\\n\\n*&oTecnicamente \"comprimento máximo\". Se você sabe, você sabe.&r"]
	quest.0F03E75CF79BADD7.quest_subtitle: "Atacado e corte"
	quest.0F03E75CF79BADD7.title: "&eArmazenamento de Itens em Massa"
	quest.0F0D41F29386333A.quest_desc: ["As Árvores Escarlates variam em tamanho e forma e às vezes até caem!\\n\\nMas todas têm folhas rosas! Incluindo as que estão no chão."]
	quest.0F0E227FC3EC0D90.quest_desc: ["Estes são geradores fornecidos por mods além do Apothic Spawners."]
	quest.0F14270F0A718C01.quest_desc: ["&cMagma&r- 1300 K\\n&cLava&r- 1300 K\\n&aUrânio&r- 2000 K"]
	quest.0F14270F0A718C01.title: "&cItens Quentes"
	quest.0F16498769DFB3B0.quest_desc: ["Para que precisaremos de todo esse &8Andesito&r? Precisaremos de &8Ligas de Andesito&r!\\n\\n&8Ligas de Andesito&r são feitas combinando 2 &8Andesitos&r com 2 &7Pepitas de Ferro&r ou 2 &7Pepitas de Zinco&r.\\n\\n&8Ligas de Andesito&r não fazem muito sozinhas, mas são o Ingrediente de Criação para quase todas as Máquinas e Itens. Então, sim, precisaremos de algumas."]
	quest.0F16498769DFB3B0.title: "&8Ligas de Andesito"
	quest.0F1CA44520BDEFEA.quest_subtitle: "6.561 Blocos de Diamante"
	quest.0F1D6F4729CC38F3.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_rib.png width:100 height:150 align:center}"]
	quest.0F1D6F4729CC38F3.quest_subtitle: "Fortaleza do Nether"
	quest.0F1D6F4729CC38F3.title: "Ornamento de Armadura de Costela"
	quest.0F326EEEC2EBE4E5.quest_desc: [
		"Usando a &d&lCâmara de Enriquecimento&r, você pode &dEnriquecer &eItens&r para convertê-los em variantes &dEnriquecidas&r."
		""
		"Esses &dItens Enriquecidos&r dão 8x a quantidade de mb em um &9&lInfusor Metalúrgico&r."
		""
		"&dCarvão &0Enriquecido&r ajudará a fazer mais &8Aço&r. &dRedstone &4Enriquecida&r ajudará com &cLigas Infundidas&r e &aCircuitos de Controle Básico&r. E &dObsidiana &5Refinada Enriquecida&r ajudará a fazer Itens &dUltimate&r!"
	]
	quest.0F326EEEC2EBE4E5.quest_subtitle: "Enriqueça seus itens primeiro!"
	quest.0F326EEEC2EBE4E5.title: "&dItens Enriquecidos"
	quest.0F3A0A4DC18E5E55.quest_desc: ["&aEterna&r define o &5Nível de Encantamento&r, que determina quais &5Encantamentos&r você pode ou irá obter!\\n\\nO padrão é &a0&r e o máximo é &a100&r.\\n\\nQuase todas as &7Estantes de Livros&r darão &aEterna&r, mas cada uma tem um máximo que pode definir."]
	quest.0F3A0A4DC18E5E55.title: "&aEterna"
	quest.0F412542271B6254.quest_desc: ["Antes de prosseguirmos com &dOccultism&r, é hora de aprendermos sobre como melhorar cada tipo de Pentáculo. Cada pentáculo se baseia no anterior desse tipo.\\n\\nIsso significa que, em vez de construir Pentáculos separados para cada nível de Ritual (ou seja, um pentáculo separado para invocar &aDjinnis&r e para invocar &aFoliots&r), você pode ter um pentáculo que lida com vários níveis de Rituais. Por exemplo, &9Atração Incentivada de Fatma&r se baseia em todos os pentáculos de Invocação anteriores.\\n\\nPor causa disso, sugiro preparar 4 áreas de 19x19 para cada Pentáculo. Uma para Invocação, uma para Infusão, uma para Possessão, uma para os rituais Diversos (Selvagem e Eldritch)."]
	quest.0F412542271B6254.title: "Prefácio sobre Pentáculos"
	quest.0F4783FA019C4567.quest_desc: ["Amaranto é encontrado raramente ao descascar Troncos de Torreya.\\n\\nPode ser transformado em Barras para fazer Armaduras e Ferramentas ou usado em outras receitas como uma fogueira que lhe dará regeneração!"]
	quest.0F49E9167B5E97C9.quest_desc: ["Qualquer dano que você sofrer ao cair (ignorando a armadura) também será causado a mobs próximos."]
	quest.0F49E9167B5E97C9.quest_subtitle: "Máx: 1"
	quest.0F5549B02D1B383B.quest_desc: ["Mate 16 Aranhas da Caverna.\\n\\nNão se preocupe, há muitas coisas do &6&lBumblezone&r para ajudar com Veneno."]
	quest.0F55D0B4D5094EDB.quest_desc: ["Enquanto fazia muitas das &elinhas de missões&r para o &eATM7&r, o &9Aldeão Comerciante&r achou que seria engraçado me empurrar constantemente na tela de missões.\\n\\n\"Acabe com eles. Todos eles.\"\\n\\n- AlfredGG\\n\\n\"Eu concordo com isso!\"\\n\\n- Toshiba"]
	quest.0F55D0B4D5094EDB.quest_subtitle: "\"Isso é Pessoal\" - AlfredGG"
	quest.0F55D0B4D5094EDB.title: "&fMate o &9Aldeão Comerciante&f e Suas&9 Lhamas&f Irritantes"
	quest.0F7BB4ECCA5C082C.quest_desc: [
		"É aqui que você colocará o &eAlchemical Sulfur&r.\\n\\nQualquer Item que esteja no &eAlchemical Sulfur&r será transformado de volta naquele Item da Incubação!"
		"{image:atm:textures/questpics/theurgy/theurgy_vessel_3.png width:100 height:125 align:center}"
	]
	quest.0F7BB4ECCA5C082C.title: "Recipiente de &eEnxofre&r"
	quest.0F89BFD4A3F63A48.quest_desc: [
		"Alguns mobs (principalmente monstros) precisam de certos &3Níveis de Luz&r para aparecer.\\n"
		"Os hostis precisando de níveis mais baixos e os passivos precisando de níveis mais altos.\\n"
		"Usar uma &bLanterna das Almas&r faz com que você nunca precise se preocupar com os &3Níveis de Luz&r, pois ela os ignora! Isso não ignora outros requisitos para o surgimento, como animais de criação que precisam de Grama."
	]
	quest.0F89BFD4A3F63A48.title: "&bIgnorar Luz"
	quest.0F8F0F7880235BA2.quest_desc: [
		"&cO Ferreiro das Almas&r reside no Nether&r. Não o subestime pensando que é um Bastião, é muito pior.\\n\\nVocê pode encontrar Ouro, Blackstone e Netherita aqui.\\n\\nO único Mob hostil que aparece aqui é o chefe... a &c&lMonstruosidade de Netherita&r!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_blacksmith.png width:200 height:100 align:center}"
	]
	quest.0F8F0F7880235BA2.title: "&cFerreiro das Almas&f: Lar da &c&lMonstruosidade de Netherita&r"
	quest.0F8F37D7E12078F5.quest_subtitle: "Complete todas as dicas!"
	quest.0F97EFAFD6E68F8D.quest_desc: ["Com esta &7Unidade&r, a &dMeka-Tool&r irá Minerar Blocos muito mais rápido! \\n\\nQuanto mais você tiver, mais rápido ela fica! \\nAssim como o Encantamento de Eficiência."]
	quest.0F97EFAFD6E68F8D.quest_subtitle: "Que intenso!"
	quest.0F97EFAFD6E68F8D.title: "&eUnidade de Intensificação de Escavação"
	quest.0FA77C28A57E06F1.quest_desc: ["Cogumelos com Véu só podem ser encontrados em seu Pântano.\\n\\nEles têm Chapéus Marrons que, se houver Ar abaixo, gerarão Véus de Cogumelo. Daí o nome!"]
	quest.0FAAA8628228ABA4.quest_desc: ["&nForte&r \\n\\n&8Sombrio&r \\n&2Grama&r \\n&dPsíquico&r \\n\\n&nVulnerável&r \\n\\n&cFogo&r \\n&9Voador&r \\n&6Pedra&r"]
	quest.0FAAA8628228ABA4.title: "&aInseto"
	quest.0FAAE744E156D8EF.quest_desc: ["O &bReator Micelial&r consiste em todos os Geradores Miceliais trabalhando ao mesmo tempo, perto do bloco do reator, e produz um total de &a25MFE/t&r.\\n\\nTudo parece bom, mas você precisa automatizar algumas coisas para fazê-lo funcionar, veja o que cada Gerador Micelial consome para funcionar e automatize-o, a maioria das coisas é simples, mas outras, nem tanto... &oolhando para o Gerador Micelial de Desencantamento&r.\\n\\nMas depois de ter tudo automatizado, você não precisa parar em um, pode fazer mais reatores."]
	quest.0FAAE744E156D8EF.quest_subtitle: "Reator Micelial, hã?"
	quest.0FAF274ADA65B26A.quest_desc: ["O Fluido do Portal é um misterioso fluido verde vital na operação da Arma de Portal Avançada.\\n\\nLargar o Catalisador de Fluido do Portal em Fluido Polimórfico criará Fluido do Portal Instável, MAS o Fluido do Portal Instável só pode existir no End. Realizar a Propagação de Gosma com gosma de nível três ou superior converterá o Fluido do Portal Instável em Fluido do Portal."]
	quest.0FB1FC640471363A.quest_subtitle: "Lápis + Esmeralda"
	quest.0FB1FC640471363A.title: "&fAbelha de Experiência"
	quest.0FD26FD88E801C0E.quest_desc: ["Você pode criar um grande número de mobs da Vanilla com o &2Altar do Nascimento&r. &dEspíritos do Nascimento&r são feitos ao reproduzir animais em áreas com grandes quantidades de aura."]
	quest.0FD26FD88E801C0E.quest_subtitle: "Fazendo Bebês com Magia"
	quest.0FD26FD88E801C0E.title: "&2Altar do Nascimento"
	quest.0FD62827710F0AC6.quest_desc: ["O &cMagmator&r irá gerar FE quando abastecido com Lava."]
	quest.0FD638380EECFFBD.quest_desc: [
		"{image:atm:textures/questpics/forbidden/forbidden_forge1.png width:100 height:100 align:center}"
		"Para começar a fazer sua Forja, coloque nossa &9Pedra Sombria Polida&r, &6Pedra Sombria Polida Arcana Cinzelada&r e &6Gilded Chiseled Polished Darkstone&r neste padrão."
		"{image:atm:textures/questpics/forbidden/forbidden_forge2.png width:100 height:100 align:center}"
		"\"Em seguida, coloque nossa Mesa de Ferraria na &6Gilded Chiseled Polished Darkstone&r interna e bata nela com &cPó de Mundabitur&r, você obterá a &6&lForja de Hefesto&r!\\n\\nPor último, coloque nossos &6Pedestais de Pedra Escura&r em cima das 8 &6Gilded Chiseled Polished Darkstone&r externas!\""
	]
	quest.0FD638380EECFFBD.title: "Construindo a &6&lForja"
	quest.0FE30548F25FEDB1.quest_desc: ["Se você é como eu e não gosta de viver em uma Caixa (isso me lembra muito a Escola), então você vai gostar de ter Vidro em suas Construções para ver o lado de fora.\\n\\nEmbora os normais da Vanilla sejam bons, claro que podemos fazer muito melhor!\\n\\nPodemos até obter algum uso disso!"]
	quest.0FEAD3CA2CC4A8B1.title: "Catalisador de Carregador de Luz Estelar Nível 3"
	quest.0FF050EC1EA6EAED.quest_desc: ["O &3Funil de Líquido&r é um Funil, mas para líquidos. Não é um substituto para canos."]
	quest.0FF050EC1EA6EAED.quest_subtitle: "Quem precisa de canos?"
	quest.0FFF2BEE5D8EBE12.title: "Reator (Niótico)"
	quest.10098A4B38BBF0B1.quest_subtitle: "Tier: &a2"
	quest.100ACB5C8A359BF0.quest_desc: ["Cruze uma &cAbelha de Redstone&r com uma &bAbelha de Listra Azul&r para obter uma &9Abelha de Lápis-lazúli&r!"]
	quest.100ACB5C8A359BF0.quest_subtitle: "Um lápis ou uma abelha?"
	quest.100ACB5C8A359BF0.title: "&fAbelha de &9Lápis-lazúli"
	quest.10162AD188CB3327.quest_subtitle: "Ameixa + Maçã Red Delicious"
	quest.101E3A21FEE00E3F.quest_subtitle: "Combine Ovo de Gerador de Abelha de Níquel com Ovo de Gerador de Abelha de Fluxita"
	quest.101E3A21FEE00E3F.title: "Abelha Energita"
	quest.1036837C9AD3F301.quest_desc: ["O &#6E6D6DMartelo de Forja&r permitirá que você esmague facilmente &#FFAC3BCobre&r, seja em forma de barra ou minério, transformando-o em pó."]
	quest.103728F2BAD5AE84.title: "&5Componentes Avançados"
	quest.103834774B57D611.quest_desc: ["O Mini Portal do End precisará de algumas &dEstantes do End&r. Estas são as últimas camadas de Estantes que você obterá do &5&lApotheosis&r. Você precisará de &dSopro do Dragão Infundido&r para criá-las.\\n\\nDepois disso, você só precisará de Olhos do Ender, que você precisará ter feito para realmente obter as &dEstantes do End&r.\\n\\nSe de alguma forma você chegou ao &d&lThe End&r e conseguiu as Estantes sem Olhos do Ender, então estou impressionado!"]
	quest.104049993CC62E7F.quest_desc: ["O Carregador de Itens Avançado é tudo o que o normal é, mas pode ser usado de qualquer lugar perto do &6Trilho&r. Ao lado, acima, ao lado do outro lado. Use o &4Pé de Cabra&r para mudar sua direção."]
	quest.104049993CC62E7F.title: "Carregador de Itens Avançado"
	quest.104BF57D4A006688.quest_subtitle: "Alimente um Bloco Sculk para uma Abelha Escavadora"
	quest.104BF57D4A006688.title: "&fAbelha de Sculk"
	quest.104EBBC08B4733F5.quest_desc: ["A &dCâmara de Simulação&r é a máquina principal dentro do HNN.\\n\\nQuando recebe energia, ela executa simulações com base no &bModelo de Dados&r que é colocado dentro. A energia necessária também depende do Modelo de Dados colocado dentro e pode ser vista na dica de ferramenta do Modelo.\\n\\nA máquina também requer pelo menos uma &9Matriz de Previsão&r para executar uma simulação.\\n\\nO resultado da simulação será exibido na Matriz. As simulações sempre produzirão algum tipo de &ePrevisão Generalizada&r, que pode ser usada em várias receitas de criação. Elas também variam dependendo da origem do mob no Modelo de Dados.\\n\\nSe a simulação for bem-sucedida, você receberá uma &dPrevisão de Mob&r baseada no modelo. Quanto maior o nível do Modelo de Dados usado, maior a taxa de sucesso de uma simulação."]
	quest.104EBBC08B4733F5.title: "&aSimulando Mortes"
	quest.1054168AFD8520D4.quest_desc: [
		"O &aGuardião Esquecido&r é um Golem massivo feito de &aBarras Esquecidas&r.\\n\\nEle irá mirar no Jogador e fará o que for necessário para matá-lo.\\n\\nEles têm 80 Corações e se você conseguir matá-los, eles droparão &aPepitas Esquecidas&r."
		"{image:atm:textures/questpics/undergarden/undergarden_guardian.png width:100 height:200 align:center}"
	]
	quest.1054168AFD8520D4.title: "&aGuardião Esquecido&r"
	quest.105442DA79829777.quest_desc: ["Com 8 &7Livros&r e uma Bigorna, podemos fazer o &8Tomo da Desmontagem&r. Bem, na verdade, 8 deles, mas você entendeu!\\n\\nAo combinar um Item com o &8Tomo&r em uma Bigorna, podemos retirar metade dos &5Encantamentos&r do Item.\\n\\nIsso acabará quebrando e anulando o Item depois de concluído. Não recomendo usá-lo, mas sim melhorá-lo!"]
	quest.105442DA79829777.quest_subtitle: "Metade dos Encantamentos, quebra Itens"
	quest.105442DA79829777.title: "&8Tomo da Desmontagem"
	quest.10605FEAF8C94237.quest_desc: ["Como eu defino um Mod de &dMagia&r? \\n\\nTodos começam de forma diferente, todos têm propósitos diferentes e objetivos finais... \\n\\nBem... todos giram em torno de &dMagia&r! \\n\\nAlguns sobre acessar a &dMagia&r através da Natureza como &a&lNature's Aura&r e &c&lReliquary&r. Outros com Rituais como &6&lForbidden \\& Arcanus&r ou &b&lOccultism&r! "]
	quest.10605FEAF8C94237.title: "&dMagia"
	quest.10672B5991E5FC34.quest_desc: ["É meu, não toque.\\n\\nSó você pode usar e mexer no Roteador depois de colocar a Melhoria."]
	quest.106884349C9FF3BA.quest_desc: ["Cara, algumas Fontes de Luz são tão feias!\\n\\nVamos mudar isso!"]
	quest.106884349C9FF3BA.title: "&fLuzes &l&bChipped&r"
	quest.10690FDB9E892250.quest_desc: ["Confira os Módulos para aprender mais sobre como usar e aprimorar os itens do DE! Balance-a e acerte algo com ela. Vamos lá, é uma espada, não posso explicar mais do que isso."]
	quest.10690FDB9E892250.title: "Espada Wyvern"
	quest.1069244EB72F64CA.quest_desc: ["Leva mais Energia com os Módulos de Energia!"]
	quest.106C552DDD95543C.quest_subtitle: "&f10.5 de &cDano de Ataque"
	quest.106D08542AAFA166.quest_desc: [
		"A primeira fase da luta envolve quebrar os Cristais que sustentam o Escudo do Guardião do Caos. Você não pode feri-lo até que eles sejam destruídos. Destruir esses cristais não é uma tarefa fácil sem uma arma Dracônica. As bolas de fogo do Guardião do Caos podem enfraquecer este escudo, permitindo que você o destrua. (Sim, ele precisará atirar em você/acertar os cristais). Você notará partículas sendo produzidas quando ele estiver vulnerável a danos e, ao ser atingido, fará um barulho. Quanto mais perto da destruição, mais grave será o som e mais fraco o Cristal ficará. Uma vez que eles forem destruídos, você pode finalmente causar dano a ele!"
		"{image:atm:textures/questpics/draconic/draconic_end_crystal.png width:150 height:100 align:1}"
	]
	quest.106D08542AAFA166.title: "Localize e Destrua 14 Cristais Guardiões"
	quest.109310AF19AAC482.quest_desc: ["O &4Lança-Chamas&r é uma das Armas de Longo Alcance que o &5&lMekanism&r oferece. \\n\\nAssim como o &cJetpack&r, ele usa Hidrogênio como Combustível e é carregado da mesma forma que o &cJetpack&r. \\n\\nPodemos pressionar (N) para trocar seus modos. \\n\\n&eCombate&r: coloca Mobs em &6Chamas&r e causa Dano, mas não queima Blocos nem Itens. \\n&6Calor&r: pelo que parece, faz a mesma coisa. \\n\\n&4Inferno&r: Queima tudo!"]
	quest.109310AF19AAC482.title: "&4Lança-chamas"
	quest.109953B8F559AE06.quest_desc: ["Agora isso é \"Cultivo\" de Materiais! \\n\\nSubterraneamente você pode encontrar &aEssência de Inferium&r. Estas são a espinha dorsal do &2&lMystical Agriculture&r. Então você precisará de bilhões delas. \\n\\nCom &aEssência de Inferium&r e outros Itens, podemos fazer &2Sementes&r. &2Sementes&r que crescem o quê? Praticamente tudo!"]
	quest.109953B8F559AE06.title: "&2&lMystical Agriculture"
	quest.109AD73F016D576B.quest_desc: ["Usando o método da vanilla, vá em frente e faça uma &9Colmeia&r para ter sua própria pequena instalação!\\n\\nElas podem abrigar 3 Abelhas cada, mas não as usaremos por muito tempo...\\n\\nAs abelhas só criarão Mel e Favos de Mel se tiverem as flores certas. As abelhas da vanilla podem usar qualquer flor, mas a maioria das abelhas no mod exigirá um bloco específico! Certifique-se de verificar o JEI para mais informações."]
	quest.109AD73F016D576B.title: "Sua Primeira Colmeia"
	quest.10A2E758D7743DD0.quest_desc: ["O &5&lEternal Starlight&r é o lar de muitos Itens, Mobs e Blocos únicos.\\n\\nÁrvores também!\\n\\nVocê pode encontrar essas Árvores por toda a Dimensão em quase todos os Biomas."]
	quest.10A2E758D7743DD0.title: "Árvores do &5&lEternal Starlight&r"
	quest.10AA2B20D86747F7.quest_desc: ["&bFerricore&r tem os mesmos status que Ferro, mas tem outras habilidades que o Ferro gostaria de ter!\\n\\nConfira as descrições dos Itens para saber mais sobre o que eles podem fazer!"]
	quest.10AA2B20D86747F7.quest_subtitle: "15"
	quest.10AA2B20D86747F7.title: "Amor de Ferricore"
	quest.10AB188AC6FB24D3.quest_desc: [
		"O Starlight Golem tem 220 Corações e 2 Modos.\\n\\nO 1º modo é o seu modo de ataque, aqui ele não pode ser danificado, em vez disso, você terá que esperar que seus ataques terminem antes de atingi-lo. Ele ataca com Bolas de Fogo, Batida no Chão ou um devastador Raio Laser!\\n\\nSeu 2º modo é o seu modo de carregamento; neste, ele começará a pegar energia dos Blocos de Energia, que precisarão ser desligados para poder danificá-lo.\\n\\nAo morrer, ele dropará muitas Barras e Flechas, Aço de Golem, Ornamento de Armadura de Forja e talvez até a Espada de Energia!"
		"{image:atm:textures/questpics/eternal/starlight_golem.png width:150 height:100 align:center}"
	]
	quest.10AB188AC6FB24D3.title: "Starlight Golem"
	quest.10C1718C792F3ABB.quest_desc: [
		"A &aMáquina de Cura&r restaurará a Vida e os Pontos de Ataque de qualquer &cPokémon&r quando colocado dentro. Ela também Reviverá &cPokémon&r que Desmaiaram. \\n\\nEla pode conter 6 &cPokémon&r por vez e tem uma Carga. \\n\\nToda vez que é usada, consome um pouco de Carga. Ela ganha Carga com o tempo, obviamente quando não está em uso. \\n\\nVocê não conseguirá pegar as dos &cCentros Pokémon&r, em vez disso, você tem que Fabricar uma! \\n\\nPolítica antiroubo..."
		"{image:atm:textures/questpics/pokemon/poke_heal.png width:100 height:100 align:center}"
	]
	quest.10C1718C792F3ABB.title: "&aMáquina de Cura"
	quest.10DF9DE4B6C03D6B.quest_subtitle: "Fabricado com Altar da Natureza"
	quest.10DF9DE4B6C03D6B.title: "&fAbelha de Ouro Corrompido"
	quest.10E025288BB00657.quest_desc: [
		"Os &bLodos&r aparecem nas &bCavernas Floridas&r e agem como Slimes! \\n\\nSua maior forma tem 8 &4Corações&r e causa muito Dano. Ao morrer, eles gerarão 2-4 &bLodos&r Médios. \\n\\nSuas formas médias têm 2 &4Corações&r e causam muito menos Dano. Ao morrer, eles gerarão 2-4 &bLodos&r pequenos. \\n\\nA forma pequena tem apenas meio &4Coração de Vida&r e não causará nenhum Dano."
		"{image:atm:textures/questpics/deepndark/dnd_sludge.png width:100 height:100 align:center}"
	]
	quest.10E025288BB00657.title: "&bLodos"
	quest.10E4ADA1D0063EB7.title: "Módulo de Velocidade de Projétil Caótico"
	quest.10E8BC20D406D9FB.quest_subtitle: "Faz vários Materiais do Nether"
	quest.1102B27CBF564127.quest_desc: ["Agitadores de Gerador são diferentes dos outros itens de Modificação listados, este é fornecido pelo PneumaticCraft em vez do Apothic Spawners. Sem o mod Apothic Spawners no Modpack, ter um Agitator em um Gerador fará com que ele gere criaturas não importa onde o Jogador esteja. Com o Apothic Spawners, que sim nós temos, isso não mudará, mas sim evitará que as criaturas geradas sumam caso você saia das chunks."]
	quest.1102B27CBF564127.quest_subtitle: "Não sumam de mim, Criaturas"
	quest.110BF3A2BE85F911.quest_desc: ["Esta Missão foi escrita pela equipe &6AllTheMods Staff&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não tem permissão para ser usada em quaisquer pacotes públicos não lançados pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você estiver vendo isso, está no modo de edição."]
	quest.110D27EA86CDA62B.quest_desc: ["Puxa itens para dentro da Mochila."]
	quest.111649D7E16D869F.quest_desc: ["A &9Varinha do Conjurador&r aceita apenas um único feitiço e é inscrita usando a Mesa do Escriba.\\n\\nOs feitiços da varinha sempre começam com Projétil > Acelerar, e DEVEM ser inscritos com um feitiço que não tenha outro método (como toque, si mesmo, etc).\\n\\nIsso permite que você lance feitiços além do limite de 10 feitiços. Se você quiser usar Quebrar, basta inscrever a varinha com Quebrar por si só."]
	quest.111E4ACF7D570EE8.quest_desc: [
		"Somente a estrutura mais resistente do &#2EC987&lMinecraft Vanilla&r. Então é claro que é lá que você terá que procurar por &#FAC343Allthemodium&r!\\n\\nVocê pode encontrar facilmente o minério nas paredes das cavernas ao redor das &#5F32C7Cidades Ancestrais&r, ele é &#E3D249Luminoso&r, então será fácil de ver — só é muito raro! Você sempre o verá na superfície exposta ao ar.\\n"
		""
		"Desligue sua &#19D602Visão Noturna&r para encontrar os minérios luminosos com mais facilidade. Além disso, esse minério também poderá encontrá-lo em qualquer &5Bioma das Profundezas Sombrias&r"
		""
		"{image:atm:textures/questpics/allthemodium/all_city.png width:200 height:100 align:center}"
	]
	quest.111E4ACF7D570EE8.title: "Cidade Ancestral"
	quest.113087E13651BFAB.quest_desc: ["&nForte&r \\n\\n&5Fantasma&r \\n&dPsíquico&r \\n\\n&nVulnerável&r \\n\\n&8Sombrio&r \\n&5Fantasma&r"]
	quest.113087E13651BFAB.title: "&5Fantasma"
	quest.11374A3B5BD644F5.quest_desc: ["&lIndustrial Foregoing&r é um Mod de Tecnologia com toneladas de Máquinas e Ferramentas. Todas seguindo o mesmo Código de Cores!\\n\\nVocê precisará começar com Borracha e sim, existe uma página de Missão para isso!"]
	quest.11374A3B5BD644F5.title: "&lIndustrial Foregoing"
	quest.114D668C691A2BDF.quest_subtitle: "Mineira Cinzenta + Cristalina"
	quest.114D668C691A2BDF.title: "&fAbelha de Ferro"
	quest.114EACA9B32B32FB.quest_subtitle: "Você já sabe como funciona..."
	quest.117241986C99E475.quest_desc: ["Com a &6Abelha Luminosa&r, cruze-a com a &8Abelha Mineira de Chocolate&r para obter uma &4Abelha de Redstone&r!"]
	quest.117241986C99E475.quest_subtitle: "Hmmm... Chocolate que espeta..."
	quest.117241986C99E475.title: "&fAbelha de &cRedstone"
	quest.11742FC5C5EDBCBD.quest_desc: ["Agora você pode &l&6Fabricar&r quase qualquer &cBola&r que quiser. Algumas podem ser mais caras! \\n\\nSe você quiser &cBolas Ancestrais&r, precisará usar &8Mecanismos de Bola Ancestral&r e &6Tampas de Bolota de Madeira&r. \\n\\nTodas essas &cBolas&r também são inteiramente idênticas às &cBolas&r normais, apenas você as fez em vez de encontrá-las!"]
	quest.11742FC5C5EDBCBD.title: "&cPoke&rbolas!"
	quest.1178E4123E8818E2.quest_desc: ["Desculpe, você não pode mais usar isso, agora são apenas Itens!\\n\\nClicando com o botão direito com eles, 2 &eTempestades de Areia&r surgirão. As &eTempestades de Areia&r circularão ao seu redor e se moverão com você.\\n\\nO que for atingido por elas será Danificado e Repelido."]
	quest.1178E4123E8818E2.title: "&eGarrafa de Tempestade de Areia"
	quest.117ADB40CE01CE07.quest_desc: ["Por algum motivo, nossos &cPokémon&r precisam que usemos &eAnéis&r especiais para podermos usar &eMovimentos Z&r. \\n\\nNão tenho certeza do porquê... mas precisaremos de uma Pedra Brilhante para fabricá-los. Além de alguns outros itens. \\n\\nO tipo de &eAnel&r não importa, apenas muda a aparência. Eu gosto mais dos &dAnéis da Olivia&r!"]
	quest.117ADB40CE01CE07.title: "&eAnéis Z"
	quest.1187F9D4F4E0D254.quest_desc: ["A &3Chave Inglesa&r é uma ferramenta que pode fazer duas coisas:\\n- Rotacionar blocos.\\n- Quebrar coberturas do Refined Storage.\\n\\nSimplesmente agache + clique com o botão direito ao usar a Chave Inglesa."]
	quest.1187F9D4F4E0D254.quest_subtitle: "Você me gira sem parar"
	quest.1187F9D4F4E0D254.title: "&3Chave Inglesa"
	quest.1190BB433EFA3945.quest_desc: ["O Estilingue é uma arma muito divertida adicionada pelo &2&lUndergarden&r. Ele tem 4 Munições que podem ser disparadas:\\n\\nGosma Cintilante pode ser disparada e, ao atingir um Mob, dará a ele o Efeito Pegajoso.\\n\\nPedras das Profundezas são apenas projéteis normais.\\n\\nFrutas Pustulentas Podres explodirão no impacto.\\n\\nE &eGronglets&r não causam dano, eles apenas fazem barulho e são disparados!"]
	quest.119242549BD21764.quest_desc: [
		"&eBrutos&r aparecem em alguns Biomas e são Neutros.\\n\\nSe atingidos, todos na área o atacarão. Semelhante a Lobos ou Porcos-zumbis.\\n\\nAo morrer, eles podem dropar suas Presas, que podem servir como substituto para Ossos!"
		"{image:atm:textures/questpics/undergarden/undergarden_brute.png width:100 height:100 align:center}"
	]
	quest.119242549BD21764.title: "&eBrutos&r"
	quest.119BED334E331C25.quest_desc: [
		"O primeiro e mais simples &lProcessamento de Minério&r são apenas 2 &5Máquinas&r! &d&lEnriquecedores&r e &6&lFornalhas&r! \\n\\nPodemos usar &7Blocos de Minério&f para obter o dobro de &7Pó &fou &7Minério Bruto&r para obter 1/3 a mais. Então 3 &7Minérios Brutos&f para obter 4 &7Pós&r. \\n\\nJogue o &7Minério&r no &d&lEnriquecedor&r e você obterá &7Pó&r! Então, &6Funda&r esse &7Pó&r para obter &7Barras&r! \\n\\nParabéns, você acabou de &lProcessar Minério&r!"
		"{image:atm:textures/questpics/mek/mek_tier1_1.png width:150 height:50 align:center}"
	]
	quest.119BED334E331C25.quest_subtitle: "Processamento de Minério Tier 1"
	quest.119BED334E331C25.title: "&dEnriquecer &fe depois &6Fundir"
	quest.11A0593C0E2E6A35.quest_desc: ["Usando a &eCompulsão Espectral de Eziveus&r, podemos imbuir uma miríade de diferentes blocos da natureza para formar uma &2Pasta da Natureza&r. Combine esta Pasta com um pouco de Giz Branco Impuro para criar Giz Verde."]
	quest.11A0593C0E2E6A35.title: "&2Giz Verde"
	quest.11A4C57600E692EC.quest_subtitle: "Aumenta a capacidade de energia da máquina"
	quest.11B0B93D725ABE43.quest_desc: ["O equipamento do Silent Gear pode ser reparado usando um &9Kit de Reparo&r.\\n\\nPara reparar um item, coloque o Kit de Reparo em uma grade de criação e, em seguida, coloque os materiais necessários para reparar a ferramenta junto com ele. Isso irá \"encher\" o Kit de Reparo.\\n\\nPara reparar a ferramenta, combine o Kit de Reparo cheio com a ferramenta que você gostaria de reparar em uma grade de criação."]
	quest.11B0B93D725ABE43.quest_subtitle: "Não são necessárias Bigornas"
	quest.11B1FB0AB2677902.quest_subtitle: "Balsa + Silver Lime"
	quest.11C43962B06D5092.quest_desc: ["Isso é necessário?"]
	quest.11C43962B06D5092.title: "&fAgora você está só se exibindo"
	quest.11C5F17C6BB1237B.quest_desc: ["Enquanto usa o &5Withered Bracelet&r, Ataques Corpo a Corpo têm uma chance de aplicar o Efeito Wither.\\n\\nDesculpe, usuários de Arco!"]
	quest.11C5F17C6BB1237B.quest_subtitle: "Pulsos (Mãos)"
	quest.11C5F17C6BB1237B.title: "&5Withered Bracelet&r"
	quest.11D09E918015355C.quest_desc: ["O Mekanism's &cHeat Generator&r é uma abordagem diferente para a produção de energia básica. Ele tem dois modos de criar energia:\\n\\n&9Passivo:&r Cercar o gerador com blocos de fonte de Lava ou corrente cria energia passiva ao longo do tempo através do calor. Coloque um bloco de fonte de Lava no topo e deixe-o escorrer pelos lados. Certifique-se de ter Canos conectados para energia primeiro!\\n\\n&9Ativo:&r Colocar materiais combustíveis como Carvão ou Madeira no gerador queimará o combustível para criar energia. Isso não é muito eficiente."]
	quest.11D09E918015355C.title: "&cHeat Generator"
	quest.11D4EEAC61C7E530.quest_desc: ["A Melhoria de Coletor fará com que a Gaveta aspire itens de um dos lados."]
	quest.11D57C768032E3F7.quest_subtitle: "Mais Opções de Filtragem"
	quest.11D57C768032E3F7.title: "&eMelhoria de Ímã Avançado"
	quest.11E957CDEFA0CAAB.quest_desc: ["Bem-vindo ao &5&lThe Beyond&r!\\n\\nNão há nada aqui!\\n\\nVocê pode querer um Angel Block."]
	quest.11E957CDEFA0CAAB.title: "&5&lThe Beyond"
	quest.11EBB510A604026A.quest_desc: ["Esta revanche aumentará seu Limite de Nível para 49. \\n\\nSeu Item de Assinatura desta vez é um &9Fragmento de Eco&r. Isso não é barato, Cyrus!"]
	quest.11EBB510A604026A.title: "&7Revanche do Chefe da Equipe Galáctica Cyrus"
	quest.120572510F525930.quest_desc: [
		"A &6&lPlanta de Evaporação Térmico&r é um Multiblock que pega &9Água&r, e usa &6Calor&r para transformá-la em &eSalmoura&r. Ela também usará &6Calor&r para transformar &eSalmoura&r em &6Lítio Líquido&r!\\n\\nPara começar, você precisará de muitos &6Blocos de Evaporação Térmica&r. A base é 4x4 e sempre 4x4 de &6Blocos de Evaporação Térmica&r.\\n\\nAs Paredes precisam ter pelo menos 3 Blocos de altura e no máximo 18. O interior e o topo devem estar ocos como a maioria dos Multiblocks. A &9Água &fe a &eSalmoura&r precisam ser mantidas em algum lugar.\\n\\nDentro das Paredes (não nos cantos) podemos colocar nossas &6Válvulas &fe nosso &6Controlador&r! O &6Controlador&r é como acessamos a INTERFACE da &6&lPlanta de Evaporação Térmico&r. Lá podemos ver o &6Calor&r que ela tem. Precisaremos apenas de 1 &6Controlador&r.\\n\\n&6Válvulas&r são como movemos &9Água &fe &eSalmoura&f para dentro, &eSalmoura &fe &6Lítio Líquido&r para fora, e opcionalmente &6Calor&r para dentro! Você não precisará configurar as &6Válvulas&r, apenas os &bTubos &fe &6Condutores&r precisam ser configurados.\\n\\nA camada superior da &6&lPlanta&r não pode ter os cantos preenchidos com &6Blocos de Evaporação Térmica&r. Você pode adicionar &e&l&oGeradores Solares Avançados&r nos cantos da camada superior, se quiser mais &6Calor&r!"
		"{@pagebreak}"
		"{image:atm:textures/questpics/mek/mek_thermal1.png width:125 height:100 align:center}"
		"Faça uma base de 4x4 de &6Blocos Térmicos&r."
		"{image:atm:textures/questpics/mek/mek_thermal2.png width:125 height:100 align:center}"
		"Esta parte pode ser de qualquer tamanho, desde que a &6&lPlanta de Evaporação Térmico&r tenha entre 3 e 18 Blocos de Altura. É também onde colocamos nossas &6Válvulas &fe &6Controladores&r."
		"{image:atm:textures/questpics/mek/mek_thermal3.png width:110 height:100 align:center}"
		"Os Cantos devem estar Vazios ou preenchidos com &l&e&oGeradores Solares Avançados&r no Nível Superior."
		"{image:atm:textures/questpics/mek/mek_thermal4.png width:110 height:100 align:center}"
		"Você saberá que está pronto quando o &6Controlador&r acender!"
	]
	quest.120572510F525930.title: "&6&lPlanta de Evaporação Térmica"
	quest.1207E5C3E7BD0584.title: "Padrão de Estandarte de Abelha"
	quest.120B403D56EE5C79.title: "Módulo de Energia Wyvern"
	quest.120BDCB70AD352AC.quest_desc: [
		"Se você quer transformar sua Fazenda de Abelhas em uma fábrica de recursos, precisará começar gerando Abelhas com &6Ninhos&r."
		""
		"Os ninhos devem ser colocados em biomas específicos, que você pode encontrar no JEI (procure o ícone 'i' no topo)."
		""
		"Para atrair uma Abelha para o Ninho, clique com o botão direito nele com uma &6Guloseima de Mel&r. Os &cNinhos&r não funcionarão sem as &6Guloseimas&r!!"
		""
		"&9Nota Importante&r: Certas Abelhas só viverão em Ninhos e não entrarão em &eColmeias Avançadas&r. Se elas não produzem &6Favo de Mel&r, precisam viver em um Ninho."
	]
	quest.120BDCB70AD352AC.quest_subtitle: "Guloseimas de Mel Necessários"
	quest.120DCA89A919C7AF.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Concede ao jogador Visão Noturna."
	]
	quest.122282C288EAD366.quest_subtitle: "&f6 de &cDano de Ataque"
	quest.12274935C3D20C74.quest_desc: ["Como em toda a seção de Dicas de Construção do &6&lATMons&r, não posso te ensinar como projetar seu &5Trem&r... mas posso dar Dicas!\\n\\nHá toneladas de Blocos de Construção diferentes que você pode usar, muitas das Cascas do &6&lCreate&r parecem limpas e os Concretos podem ajudar a dar uma aparência mais elegante.\\n\\nVocê também pode usar Portas e Alçapões dentro do &5Trem&r, que também podem ser usados quando o &5Trem&r está em movimento.\\n\\nE que tal deixá-lo bonito? Bem, Escadas, Lajes e Alçapões ajudam a dar Forma a ele, assim como o Volante ou as &dEngrenagens&r dão bordas arredondadas agradáveis.\\n\\nCaramba, você pode até colocar uma Fogueira nele para fazer uma Máquina a Vapor!"]
	quest.12274935C3D20C74.title: "Decorando seu &5Trem&r"
	quest.122E6E7CABCB17E7.quest_desc: ["Por alguma razão, Creepers têm medo de Gatos. Creepers também são extremamente burros e acreditam que os Gatos que suas &7Pantufas&r parecem são reais.\\n\\nTodos os Creepers fugirão de você e não serão hostis quando estas &7Pantufas&r forem usadas.\\n\\nTambém faz barulhos de gatinho quando você leva dano! (Não posso garantir que você sempre cairá de pé)."]
	quest.122E6E7CABCB17E7.quest_subtitle: "Pés"
	quest.122E6E7CABCB17E7.title: "&7Pantufas de Gatinho&r"
	quest.122EDEC12C9A05D2.quest_desc: ["Eu esqueci de mencionar que tudo pode explodir? ...\\n\\nFelizmente, há uma solução fácil! A &3Melhoria de Segurança&r, quando colocada em uma máquina, garante que elas não explodam, coloque-as em todas as máquinas que puderem recebê-las."]
	quest.122EDEC12C9A05D2.quest_subtitle: "Se ao menos houvesse uma Solução fácil..."
	quest.122EDEC12C9A05D2.title: "Prevenindo Explosões?"
	quest.122FBF5110E4CFF2.quest_desc: ["A Pioria de Ferro irá rebaixar o espaço máximo da Gaveta para um pack. Isso pode ser útil para manter itens em estoque, mas não muitos."]
	quest.123807F4BBE75120.title: "&bParte de Armazenamento de 16384k"
	quest.123C0417D85B9DB2.quest_desc: ["As &eUnidades de Recarga &7Solar&r vão nos &a&lCapacetes do Meka-Traje&r e carregarão o &a&lMeka-Traje&r! \\n\\nQuanto mais você adicionar, mais FE serão gerados. \\n\\nSim, funciona como um &eGerador Solar&r normal... &eDurante o dia&r e se estiver exposto ao &bCéu&r!"]
	quest.123C0417D85B9DB2.quest_subtitle: "Capacete"
	quest.123C0417D85B9DB2.title: "&eUnidade de Recarga Solar"
	quest.12449D23295CF9ED.quest_desc: [" Em algum lugar nas profundezas, uma estranha &6relíquia&r aguarda o &9Colar de Água-viva&r. Um item curioso que parece carregar a essência de uma &bcriatura&r viva. Você pode encontrá-lo dentro de &6baús&r em &9biomas aquáticos&r. \\n\\n - &lPossui 2 habilidades:&r \\n\\n 1. &bRegeneração Aquática&r: \\nEnquanto submerso em &9líquido&r ou sob a &9chuva&r, o colar fortalece seu portador, aumentando a &cvida&r máxima e impulsionando a &aregeneração&r. \\n\\n 2. &9Descarga Elétrica&r \\nA &6relíquia&r armazena &eenergia elétrica&r ao longo do tempo. Uma vez carregada, tocar em uma criatura viva libera um choque poderoso que &eempurra&r inimigos próximos, &eparalisa-os&r por um curto período e envia &eeletricidade&r em cadeia através de &aalvos&r próximos. \\n\\n- Uma &6relíquia&r nascida do &3mar&r... e um lembrete de que algumas &bcriaturas&r são melhor admiradas de &3distância&r."]
	quest.12449D23295CF9ED.quest_subtitle: "Talvez os oceanos estejam escondendo mais do que apenas peixes..."
	quest.12449D23295CF9ED.title: "&9Colar de Água-viva"
	quest.1245126B4338C019.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_vex.png width:100 height:150 align:center}"]
	quest.1245126B4338C019.quest_subtitle: "Mansão da Floresta"
	quest.1245126B4338C019.title: "Ornamento de Armadura de Vex"
	quest.12469CC0CCFBA1C5.quest_desc: ["A melhor Espada, mais a Picareta mais rápida, mais a Pá?!?! O que mais você poderia querer!"]
	quest.12469CC0CCFBA1C5.title: "Cajado Caótico"
	quest.124CD4B8876B81F6.quest_subtitle: "Armazene a energia que você gera"
	quest.124CD4B8876B81F6.title: "Armazenando Energia"
	quest.1256F280F3669DDA.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		""
		"Faz com que as Flechas se encadeiem para inimigos próximos."
	]
	quest.12749A25600C7FF3.quest_desc: [
		"O Criador Quântico é um auto-criador poderoso e configurável. Com um inventário inteiro de uma rede ME ao seu alcance, criar sem parar se torna uma tarefa trivial. Ele é capaz de executar trabalhos de crafting em um ritmo muito rápido. Também é capaz de realizar substituições de fluidos, bem como criações recursivas (como a Duplicação de Molde de Ferraria)."
		""
		"Você também pode regular a quantidade de cada ingrediente que deseja manter, e até quantos do produto você deseja manter em estoque."
		""
		"No entanto, não aceitará solicitações de crafting de Provedores de Padrão."
	]
	quest.12749A25600C7FF3.title: "Crafting Totalmente Automatizado: O Criador Quântico"
	quest.127D085D6C9DB690.quest_desc: ["O salitre pode ser encontrado em qualquer lugar subterrâneo, mas é muito comum no Bioma de Costa Quente.\\n\\nÉ preciso uma Picareta de Pedra para minerá-lo e, quando minerado, ele dropa um pouco de Pó de Salitre. Sim, Fortuna funciona nele!\\n\\nO Pó pode ser usado como substituto para outros Nitratos."]
	quest.127F9EAC7C305BF5.quest_desc: ["Confie em mim quando digo, você vai precisar de uma &6Chave Inglesa&r!\\n\\nA &6Chave Inglesa&r é a ferramenta perfeita tipo Canivete Suíço para o &6&lCreate&r. Você pode girar Blocos, quebrá-los, definir suas configurações, o que você não pode fazer com ela!\\n\\nPara quebrar Blocos, basta Agachar e Clicar com o Botão Direito em qualquer Bloco do &6&lCreate&r e ela os quebrará.\\n\\nPara Girar um Bloco, basta Clicar com o Botão Direito normal neles com a &6Chave Inglesa&r. Infelizmente, isso não nos dá &dEnergia Rotacional&r gratuita, mas ainda é útil para deslizes!\\n\\nEla também será útil para configurar &aEngenhocas&r, mas isso é para mais tarde."]
	quest.127F9EAC7C305BF5.title: "&6Chave Inglesa"
	quest.128A14A3842325FE.quest_desc: ["Quando instalado em uma Colmeia Avançada, as abelhas não saem mais fisicamente da colmeia. Uma viagem até o bloco de flor delas será simulada.\\n\\nCertifique-se de colocar o bloco de flor necessário ou uma Laje de Alimentação na frente da colmeia contendo os blocos de flor ou itens necessários para a abelha dentro da colmeia. Para ver como configurar corretamente, confira a missão da Laje de Alimentação.\\n\\nRecomendo fortemente pegar isso para que suas abelhas não desapareçam e para poder colocar e tirar abelhas da colmeia com mais facilidade."]
	quest.128A14A3842325FE.quest_subtitle: "As Abelhas ainda são reais?"
	quest.128A14A3842325FE.title: "&fMelhoria de &6Simulador"
	quest.129E09C03E40BA57.quest_desc: ["O Reator usa Draconium Despertado como Combustível, não se preocupe, é eficiente! A Conversão de Combustível determina quando o Draconium Despertado se transformará em Caos. Ele pode receber apenas 8 Blocos por vez e só pode ser Abastecido ou Reabastecido quando o Reator estiver desligado. O modo SAS ajuda a tornar isso mais fácil! Além disso, o Combustível vai nos Slots inferiores direitos."]
	quest.129E09C03E40BA57.title: "Combustível para nosso Reator"
	quest.12A43F82FC67A289.quest_desc: ["Para armazenar seus itens, você precisará criar discos, que podem ser guardados dentro de &9Disk Drives&r conectados à sua rede.\\n\\nEles têm 8 espaços para Discos de Armazenamento"]
	quest.12A43F82FC67A289.quest_subtitle: "Hora do Disquete!"
	quest.12AE2856444996F6.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.12BDE512C734D19A.quest_desc: ["Núcleos de Draconium são um Ingrediente vital em muitas receitas do Draconic Evolution. Especialmente para itens de Nível Básico."]
	quest.12BDE512C734D19A.title: "Núcleo Básico (Draconium)"
	quest.12D3C7FC4B3DAB23.quest_desc: ["O &bOlho Ambiental&r pode ser feito usando o &aRitual da Floresta&r e pode ser usado em seu slot de Amuleto para monitorar os níveis de aura no canto superior esquerdo da tela."]
	quest.12D3C7FC4B3DAB23.quest_subtitle: "Um Olho no meio ambiente"
	quest.12ED1EE85E146A4B.quest_desc: ["Pilão Colhedor funcionam como uma Fazenda Automática muito simples. Coloque o Pilão sobre ou dentro da Fonte de Água e ele irá colher e replantar automaticamente as Plantações que estiverem totalmente crescidas na área definida ao seu redor. \\n\\nA área pode ser definida para 3x3, 5x5, 7x7 ou 9x9 Blocos ao redor do Pilão. \\n\\nEle precisará de uma Enxada para usar nas Plantas e precisará de um Inventário como um baú acima dele para colocar os Cultivos. Faça tudo isso e, se estiver ligado, ele começará a cultivar!\\n\\n(Cuidado ao usar muitos modificadores com ele, como Vitórias-régias ou fertilizantes, pois quando a colheita fica muito rápida, pode ser um sugador de TPS)."]
	quest.12EF38830108D02B.quest_desc: ["Mate 32 Aranhas normais."]
	quest.12F9705ACB8FB300.quest_desc: [
		"A &#EDD653&nMáquina de Corte&r permite fazer muitos itens. Os mais importantes são os Parafusos. "
		""
		"A &#EDD653&nMáquina de Corte&r funciona com &#E3993DLubrificante&r, que é obtido usando a &#EDD653&nMisturadora&r."
	]
	quest.12F9705ACB8FB300.title: "&fA &#ED9553Máquina de Corte&r"
	quest.12FB3990CA1653A4.quest_desc: [
		"A &#DBA15BBroca a Vapor&r será sua melhor amiga na mineração no início do jogo. Ela pode minerar uma área de &53 por 3&r blocos e também possui &#EEF768Toque Suave&r ativável."
		""
		"Você pode alternar o modo &53 por 3&r pressionando a tecla de atalho \"Alternar Mineração 3x3\", que por padrão é &9'Y'&r."
		""
		"O &#EEF768Toque Suave&r pode ser ativado com &9Shift + Clique Direito&r com a Broca a Vapor."
		""
		"Para abastecer a &#DBA15ABroca a Vapor&r, segure-a sobre um &6combustível&r no seu inventário e &9Clique com o Botão Direito&r. A &9Água&r pode ser adicionada clicando com o botão direito em uma fonte ou carregando um &9Balde de Água&r."
	]
	quest.12FB3990CA1653A4.title: "&fA &#DBA15BBroca a Vapor&r"
	quest.130577AD1A1A8222.quest_desc: ["&7Cloggrum&r tem status um pouco piores que a Armadura de Ferro, mas praticamente cresce em Árvores, então acho que é justo. \\n\\nAs Botas também ajudam a atravessar a Scintling Goo!"]
	quest.130577AD1A1A8222.title: "Armadura de &7Cloggrum&r"
	quest.1310C1E14C259807.quest_desc: ["Quer ter Gavetas personalizadas? Não procure mais, estas podem imitar a textura de um bloco por fora e uma diferente na frente.\\n\\nSiga a dica na descrição para saber como fazer."]
	quest.13124A7E22999850.quest_subtitle: "Tier: &e1"
	quest.131AA933D59D3017.quest_desc: [
		"O Nível 5 precisa de 90 Blocos de Barra de Draconium e 80 Blocos de Redstone, juntamente com 4 Estabilizadores Avançados ou 36 Estabilizadores."
		"{image:atm:textures/questpics/draconic/draconic_core_5off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_5on.png width:100 height:100 align:1}"
	]
	quest.131AA933D59D3017.quest_subtitle: "Armazena: 59.300.000.000 RF"
	quest.131AA933D59D3017.title: "Nível 5"
	quest.131ACE9712128876.quest_desc: ["O &3PokeLocalizadores&r faz exatamente o que o nome sugere! Ele fornece um mapa de &cPokémon&r perto de você e vem com filtros para encontrar &cPokémon&r específicos. \\n\\nVocê pode abrir seu &3PokeLocalizadores&r para digitar os filtros. A espécie que você deseja, Aspectos e Marcadores. \\n\\nQuando os filtros estão configurados, apenas aqueles que se encaixam nos filtros serão mostrados no mapa. \\n\\nAtivar Filtros Estritos significa que, quando houver múltiplos Aspectos ou Marcadores, ele procurará apenas por &cPokémon&r com todos os Aspectos ou Marcadores listados."]
	quest.131ACE9712128876.title: "&3PokeLocalizadoress"
	quest.131EC039435B8878.quest_desc: [
		"Em Productive Bees, você não passa a maior parte do seu tempo voando por aí tentando encontrar certas abelhas."
		""
		"Em vez disso, você as gera usando Ninhos com &6Guloseimas de Mel&r."
		""
		"Com estes, você criará alguns Ninhos e clicará com o botão direito neles com as guloseimas para atrair Abelhas. Alguns Ninhos requerem itens especiais em vez de &6Guloseimas de Mel&r, então certifique-se de verificar no JEI para mais informações!"
		""
		"Certifique-se de verificar em qual bioma você precisa estar para atrair as Abelhas certas!"
	]
	quest.131EC039435B8878.title: "&6Guloseimas de Mel"
	quest.1322907FDFF08ADA.quest_subtitle: "Nogueira + Cerejeira-brava/Tília-prateada"
	quest.132DF9ECEFFB3B71.quest_desc: ["O &3Cartão de Expansão de Módulo&r torna o Módulo de Carregamento ainda melhor."]
	quest.132F4671E121C7B8.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Aumenta a velocidade de caminhada."
	]
	quest.133CA315A1443A49.quest_desc: ["As &bBombas Mecânicas&r usarão Energia Rotacional para mover &bFluidos&r através de &bTubos&r. \\n\\nPrimeiro, substitua um &bTubo&r pela &bBomba Mecânica&r. Em seguida, certifique-se de que ela está virada para o lado certo que você quer que os &bFluidos&r sejam movidos. As Setas ao lado da &6Engrenagem&r interna indicarão a direção do movimento, você pode mudar isso com uma Chave Inglesa. \\n\\nDepois, alimente-a com &dEnergia Rotacional&r com uma &6Engrenagem&r perto dela. A direção não muda nada, mas a Velocidade afetará a rapidez com que os &bFluidos&r são movidos. \\n\\nAs &bBombas Mecânicas&r também serão necessárias para outras Máquinas como a &bPolia com Mangueira&r!"]
	quest.133CA315A1443A49.title: "&bBomba Mecânica"
	quest.134608BB2B04D96E.quest_desc: ["Baús têm 27 espaços e podem ser transformados em um baú duplo para armazenar o dobro dessa quantidade."]
	quest.134608BB2B04D96E.quest_subtitle: "O Baú"
	quest.134608BB2B04D96E.title: "Armazenamento Vanilla"
	quest.13471E64CDE49D27.quest_desc: [
		"A &a&lRefinaria&r pegará 2 &bFluidos&r e os combinará e refinará em 1 &bFluido&r melhor! \\n\\nOs 2 &bFluidos&r podem ser &9Inseridos&r pelas Portas e pelos lados Esquerdo e Direito. A Saída de Fluido sairá pela Porta Frontal. \\n\\nVocê pode usar &bBaldes&r para depositar &bFluidos&r nos Tanques também! Não se esqueça de Clicar com o Botão Direito na &a&lRefinaria&r para abrir sua GUI. Lá precisaremos colocar um Catalisador, para iniciar a Máquina. \\nJunto com um Catalisador, ela precisará de &cEnergia&r que pode ser adicionada pela Porta de Trás!"
		"{@pagebreak}"
		"Para começar, faça uma linha de 5 &bTubos de Fluido&r. No meio, coloque um &eBloco de Engenharia Leve&r de um lado e um &7Bloco de Engenharia Pesada&r do outro. Ao lado do resto dos &bTubos de Fluido&r, coloque &8Andaimes de Aço&r."
		"{image:atm:textures/questpics/immersive/immersive_refinery1.png width:150 height:100 align:center}"
		"Coloque mais Blocos de Engenharia sobre os anteriores. À direita do &7Bloco de Engenharia Pesada&r, pule 1 Bloco e coloque um &4Bloco de Engenharia de Redstone&r. Ao lado do &eBloco de Engenharia Leve&r coloque 2 2x2 de &7Chapas de Ferro&r."
		"{image:atm:textures/questpics/immersive/immersive_refinery2.png width:150 height:100 align:center}"
		"Agora apenas mais algumas &7Chapas de Ferro&r!"
		"{image:atm:textures/questpics/immersive/immersive_refinery3.png width:150 height:100 align:center}"
		"Para este, precisaremos Clicar com o Botão Direito no &7Bloco de Engenharia Pesada&r de cima com nosso &6Martelo&r."
		"{image:atm:textures/questpics/immersive/immersive_refinery.png width:100 height:100 align:center}"
	]
	quest.13471E64CDE49D27.title: "&l&aRefinaria"
	quest.1348995F64A94396.quest_desc: ["O &bMonitor de Fabricação&f exibe o item geral sendo criado, junto com a quantidade restante desse item que ainda está sendo criada.\\n\\nTanto o monitor base do &9AE2&r quanto o monitor &5MEGA&r funcionam de forma idêntica, mas são fornecidos para fins estéticos."]
	quest.1348995F64A94396.quest_subtitle: "Baixe mais VRAM"
	quest.1348995F64A94396.title: "&eMonitor de Fabricação"
	quest.13517D17E6BF015F.quest_desc: ["Com &bArmadura de Diamante&r e alguns &aItens de Inferium&r, podemos criar a &aArmadura de Inferium&r! \\n\\nEles também podem ser melhorados com Modificações!"]
	quest.13517D17E6BF015F.quest_subtitle: "21"
	quest.13517D17E6BF015F.title: "Armadura de &aInferium"
	quest.1351D0594F1E6551.quest_desc: ["Esses &#55EDA4Componentes Básicos&r nos levarão ao próximo avanço no processamento."]
	quest.1351D0594F1E6551.title: "&5Componentes de Circuito"
	quest.135A16EDEEE27FA9.quest_desc: ["Tudo relacionado a &cFios&r e &cenergia&r em &8&lIE&r pode ser dividido em Tiers. &6Baixa Tensão&r (&6LV&r), &eMédia Tensão&r (&eMV&r), e &5Alta Tensão&r (&5HV&r). \\n\\nQuanto maior a Tensão, mais &cEnergia&r pode ser movida e usada. Algumas Máquinas precisarão de Tensão mais alta para serem usadas. \\n\\nPara transferir diferentes Tensões, você precisará de &cTransformadores&r, confira a Missão deles!"]
	quest.135A16EDEEE27FA9.title: "Tensão em Tiers"
	quest.1366B946928C873B.quest_desc: ["Confira a Página de Missões da &6&lBumblezone&r para saber mais!"]
	quest.1366B946928C873B.quest_subtitle: "10"
	quest.1366B946928C873B.title: "Armadura de Abelha 1"
	quest.13681866CE6A831C.title: "Padrão de Estandarte de Espadas"
	quest.13A0714444BA79AB.quest_desc: ["O &bImportador Ultra&r tem 36 espaços para filtros, funciona 5x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.13A0714444BA79AB.title: "&bImportador Ultra"
	quest.13A5748DF69D832E.quest_desc: ["A &e&lMatriz de Drives OIQ&r não faz muita coisa sozinha, em vez disso, precisaremos adicionar um &ePainel OIQ&r! \\n\\nO &e&lPainel OIQ&r, como todos os &eItens relacionados ao &lOIQ&r, precisa ser configurado para a mesma Rede. \\n\\nQuando estiver finalmente pronto, poderemos depositar e acessar &eItens&r em nosso &e&lSistema OIQ&r. \\n\\nVamos começar com as partes mais importantes! Os Slots no meio são onde os &eItens&r podem ser colocados, armazenados e retirados. Podemos aumentar quantos Slots são exibidos com os Botões à esquerda para Aumentar ou Diminuir a Altura. De 2 para 7 Fileiras. \\n\\nAcima dos Slots fica a Barra de Pesquisa para procurar nomes de &eItens&r, Tags e Mods. Abaixo dos Slots há uma opção de Organização. Seja de Itens de A a Z ou da menor para a maior quantidade de &eItens&r em um pack. \\n\\nO Botão da Direita fará com que, ao abrirmos o &ePainel OIQ&r, nossa digitação comece no &lEMI&r ou na Barra de Digitação do &e&lOIQ&r. \\n\\nAgora, outra parte útil do &e&lSistema OIQ&r, a Criação! Na Esquerda, temos um Botão de Criação! Isso abrirá até 3 Janelas de Criação. Cada uma delas tem uma Grade de Criação 3x3 que podemos usar. \\n\\nO Botão abaixo do Botão de Criação afeta o ato de Clicar com Shift nos &eItens&r do nosso Inventário. Ou ele os enviará para a Janela de Criação aberta, ou para dentro do &e&lSistema OIQ&r. \\n\\nO último Botão é usado com o &lEMI&r para configurar Receitas automaticamente. Os Blocos substituídos serão colocados ou em seu Inventário, ou de volta no &e&lSistema OIQ&r."]
	quest.13A5748DF69D832E.title: "&ePainel OIQ"
	quest.13AA91D39A2CABF2.quest_desc: ["Bem-vindo ao &6Productive Bees&r!\\n\\nPara começar com o mod, você primeiro precisará encontrar alguns Favos de Mel e Garrafas de Mel! Encontre uma Colmeia e deixe as abelhas fazerem seu trabalho por um tempo. Tosquiá-la quando estiver cheia lhe dará favos de mel, e garrafas de vidro lhe darão Garrafas de Mel!\\n\\n&9Nota Importante&r: Com as missões de abelhas que requerem favos, as receitas não serão mostradas. Certifique-se de procurá-las no JEI se precisar delas!"]
	quest.13AA91D39A2CABF2.quest_subtitle: "Abelhas que produzem até nosso café! Por quê não?!"
	quest.13AA91D39A2CABF2.title: "&6Productive Bees&f!"
	quest.13AEBC331F29BC3D.quest_desc: ["A &eLogística de Itens&r é importante para o &6&lCreate&r. &6Mós&r precisam de &eItens&f, &6Ejetores &fprecisam de &eItens&f, &6Misturadores Mecânicos&f precisam de &eItens&r, e assim por diante. \\n\\nAgora, como o &6&lCreate&r quer que movamos &eItens&r? Com &eEsteiras&r! \\n\\n&eEsteiras&r podem ser anexadas a dois &8Eixos&r para conectar e mover-se com eles. Se o primeiro &8Eixo&r estiver se movendo no &e&oSentido Horário&r, o segundo se moverá na mesma Velocidade e Direção. \\n\\nO mesmo com as &eEsteiras&r que são colocadas nesses &8Eixos&r, elas se moverão na mesma Velocidade e Direção que os &8Eixos&r entre os quais são colocadas. \\n\\nAo colocar &eEsteiras&r, elas podem ser colocadas perfeitamente na Horizontal, Vertical ou diagonal em ângulos de 45%. \\n\\nUma vez colocadas e movendo, quaisquer &eItens&r ou Entidades serão movidos com a &eEsteira&r. Entidades podem sair das &eEsteiras&r, então cuidado com isso. Felizmente, &eItens&r não podem sair ou mesmo desaparecer quando estão nela! \\n\\nOs &eItens&r serão então levados para onde a &eEsteira&r for. Se ela terminar abruptamente, os &eItens&r serão simplesmente Soltos. Se for para um &eDepósito&r, o &eItem&r será colocado em um &eDepósito&r. Se for para baixo de uma &6Máquina&r, a &6Máquina&r o usará. \\n\\nSe você quiser pegar &eItens &fda &eEsteira&r, pode simplesmente Clicar com o Botão Direito nela!"]
	quest.13AEBC331F29BC3D.title: "&e&lLogística de Itens"
	quest.13AF35A3108B02AF.quest_desc: ["Tem que ir rápido!"]
	quest.13AFCD3B6F62B986.quest_desc: ["Fornece receitas de Gelo e Neve!"]
	quest.13AFCD3B6F62B986.quest_subtitle: "Gelo, gelo, neném!"
	quest.13AFCD3B6F62B986.title: "Melhoria de Gelo"
	quest.13B338F377951032.quest_desc: ["Você já desejou poder usar a &bExplosão Sônica&r do &9&lWarden&r? \\n\\nBem, com o &bCajado Sonoro&r você pode! Simplesmente Segure o Botão Direito para carregá-lo, depois solte para enviar uma &bExplosão Sônica&r. \\nHá um pequeno tempo de recarga e ele tem Durabilidade, então use por sua conta e risco! \\n\\nPara criar um, você precisará de um &9Coração das Profundezas&r do &9&lWarden&r, 2 &3Cristais de Alma&r do &3&lStalker&r e 2 &3Ossos de Sculk &fdos &3Estilhaçados&r."]
	quest.13B338F377951032.title: "&bCajado Sonoro"
	quest.13BB75A7E1973488.quest_desc: ["A Monstruosidade Lunar é o primeiro Chefe adicionado em Eternal Starlight. \\n\\nEste vive no meio do Jardim Amaldiçoado, boa sorte para encontrá-lo e lutar contra ele!"]
	quest.13BB75A7E1973488.title: "&fMate a &3Monstruosidade Lunar"
	quest.13C5C06278DD9C95.quest_subtitle: "Combine um Ovo de Gerador de Abelha de Diamante com um Ovo de Gerador de Abelha de Níquel"
	quest.13C5C06278DD9C95.title: "&fAbelha de Adamant"
	quest.13CAD46F4B229AB4.quest_subtitle: "Fabricado com Altar da Natureza"
	quest.13CAD46F4B229AB4.title: "&fAbelha de Aço Infundido"
	quest.13D5F689E6884281.quest_desc: ["&eKobolediadores&r são um dos dois mini-chefes dentro da &ePirâmide Amaldiçoada&r. \\n\\nEles permanecerão dormentes até que um Jogador (no Sobrevivência, demorei um pouco para descobrir isso) passe perto deles e eles acordarão. \\n\\nEles têm 540 &4Corações&r e infligirão Fadiga de Mineração em você. \\n\\nEles balançarão sua Espada em você se você chegar muito perto! Se você se distanciar deles, eles avançarão em você como se estivesse segurando uma Bola de Futebol Americano e correndo para a endzone! \\n\\nNa morte, eles droparão Ossos de Koboleton, Barras de Metal Ancestral e sua Caveira!"]
	quest.13D5F689E6884281.title: "&eKobolediator"
	quest.13E3DE157B89E847.quest_desc: [
		"Uma estrutura muito simples, algumas &6a&8b&6e&8l&6h&8a&6s&r e outras coisas foram congeladas em um picolé."
		"{image:atm:textures/questpics/bumblezone/bumble_ice.png width:200 height:100 align:center}"
	]
	quest.13E3DE157B89E847.title: "Monólito de Gelo"
	quest.13EB9A996928ED60.quest_desc: ["Por último, mas certamente não menos importante, está o &5&lNofaxu&r! \\nSe você o derrotar, 1. dê um tapinha nas suas próprias costas porque você acabou de vencer um cara com mais de um Milhão de Inscritos no Youtube! E 2. você terá terminado a &4&oSérie&r. \\n\\nMas ei, se você começar a sentir arrependimento e culpa por destruir impiedosamente seus Criadores favoritos no &l&cAll&7The&fMons&r, sabe, aqueles que passaram suas carreiras inteiras ajudando você a entender melhor e aproveitar os jogos que você tanto ama... você pode compensar isso conferindo os canais deles!"]
	quest.13EB9A996928ED60.title: "&l&5Nofaxu"
	quest.13F68CA518CD287C.quest_desc: ["&3Diesel&r pode ser usado para fazer mais Querosene ou para fazer Lubrificante."]
	quest.13F68CA518CD287C.quest_subtitle: "Pobre Sel"
	quest.13F68CA518CD287C.title: "Diesel"
	quest.13FDC88F09F96D0F.quest_desc: ["Ainda continua? Sim... você precisará de uma revanche com todos eles novamente. \\n\\n&3Aaron&r aumentará para 81. \\n\\n&3Bertha&r para 83. \\n\\n&3Flint&r para 85. \\n\\n&3Lucian&r para 88."]
	quest.13FDC88F09F96D0F.title: "Hora da revanche de novo!"
	quest.1403D677CF2815C3.quest_desc: ["A &5&lMesa de Reforja&r faz tudo que a &9&lSimples&r faz, mas melhor! \\n\\nEla pode nos dar &eAfixos&r &5Épicos&r e &6Míticos&r, juntamente com os anteriores!"]
	quest.1403D677CF2815C3.title: "&5&lMesa de Reforja&r (Melhor)"
	quest.1404BB8956D5F8C7.quest_desc: ["Afeta a capacidade de uma abelha de trabalhar em condições climáticas severas. Existem 3 níveis disso: &aNenhum&r, &dChuva&r, &cQualquer&r. &cQualquer&r é o que estamos procurando. Você poderia amarrar a abelha a uma cerca durante uma tempestade, se quisesse, mas vamos lá, isso é só crueldade.\\n\\nEu ofereço uma solução mais fácil. Pesca. Isso mesmo, você pode pescar abelhas. Abelhas de Água ou Prismarina naturalmente vêm com a habilidade de tolerar qualquer condição climática. Podemos aproveitar isso!"]
	quest.1404BB8956D5F8C7.quest_subtitle: "A menor das grandes"
	quest.1404BB8956D5F8C7.title: "&9&lTolerância Climática"
	quest.1409C17773B6A131.quest_desc: ["Todas as Melhorias aumentam a quantidade que os &e&lPipez&r movem e também concedem mais opções para usar com o &e&lPipe&r. \\n\\nA Melhoria Básica permite Ativação por Redstone com os &e&lPipez&r, para alterar a distribuição entre: Primeiro o mais Próximo, Primeiro o mais Distante, Round-Robin, ou Aleatório, e para adicionar Filtros.\\n\\nAs melhorias Aprimorada, Avançada e Ultimate não concedem nada novo, elas apenas movem mais!"]
	quest.1409C17773B6A131.title: "&9Pipez: &aMelhorias"
	quest.140DADB32EF10D58.quest_desc: ["Sementes de Ovo de Dragão requerem um Crux de Ovo de Dragão colocado abaixo para que possam crescer."]
	quest.140DADB32EF10D58.quest_subtitle: "Tier: &56"
	quest.140DE53DC0FCD9F4.quest_desc: [
		"O &bPlano de Aniquilação ME&f pode ser usado para quebrar automaticamente quaisquer blocos à sua frente e retornar qualquer coisa dropada pelo bloco diretamente para a Rede ME."
		""
		"Como um bônus adicional, o Plano de Aniquilação pode ser encantado da mesma forma que uma ferramenta de escavação comum, afetando os drops de blocos da mesma maneira que a ferramenta encantada faria. Isso o torna ideal para processar blocos de minério quando encantado com Fortuna, por exemplo."
		"Quaisquer encantamentos adicionados aumentam significativamente a quantidade de energia usada pelo plano toda vez que um bloco é quebrado. Encantar o plano com &eEficiência&f diminuirá o uso geral de energia incorrido por todos os outros encantamentos, enquanto o encantamento &eInquebrável&f dá ao plano a chance de usar energia apenas às vezes, de forma semelhante a Inquebrável em ferramentas comuns."
	]
	quest.140DE53DC0FCD9F4.quest_subtitle: "ENTRA AÍ"
	quest.141681FE9E524FB0.quest_desc: [
		"&7Esquecidos&r são guerreiros que aparecem na Estrutura da Catacumba. \\n\\nEles usam Armadura Ancestral e seguram Ferramentas de Cloggrum, tudo o que pode ser dropado na morte. \\n\\nEles também atacarão e matarão &cMobs Pútridos&r."
		"{image:atm:textures/questpics/undergarden/undergarden_forgotten.png width:100 height:200 align:center}"
	]
	quest.141681FE9E524FB0.title: "&7Esquecido&r"
	quest.141D68BAD039784B.quest_desc: ["Nossa &6&lCaldeira Termoelétrica&r pode ser usada para receber &6Sódio Superaquecido&r e &9Água&r e reciclá-los em Sódio e Vapor! \\n\\nMas como colocamos nosso &6Sódio Superaquecido&r e &9Água&r para dentro da &6&lCaldeira&r? \\n\\nCom as &6Portas da Caldeira&r! Nós precisaremos usar um &3Configurador&r nelas para alterar as configurações das &6Portas&r. \\n\\nNosso &6Sódio Superaquecido&r e &9Água&r serão adicionados através de Portas de Entrada (Portas de Entrada separadas). \\n\\nO Sódio resfriado será retirado através de uma Porta de Saída. E o Vapor ganha sua própria Porta de Saída de Vapor!"]
	quest.141D68BAD039784B.title: "&6Portas da Caldeira"
	quest.1427B3AB09510D20.quest_desc: ["Crie sua Placa de Circuito Impresso Desmontada com 2 Capacitores e 2 Transistores para obter uma &3Placa de Circuito Impresso Finalizada&r."]
	quest.1427B3AB09510D20.quest_subtitle: "Você conseguiu!"
	quest.142C67218BD16867.quest_desc: ["Carregue sua Minigun com esta &3Munição de Minigun&r para usá-la."]
	quest.14385D3D359224BC.quest_desc: ["A &dMeka-Tool&r é a melhor Ferramenta que o &5&lMekanism&r oferece, daí o nome! \\n\\nEla pode fazer tudo que o &bDesintegrador &cAtômico&r faz, só que melhor! Em termos de quebrar blocos, com mais Dano e Velocidade de Ataque. \\n\\nEm vez de ter Modos, no entanto, ela pode usar Unidades de Modificação! Confira as Missões delas. \\n\\nEmbora ela use o &3Configurador&r em sua fabricação, ela não o replica de forma alguma."]
	quest.14385D3D359224BC.quest_subtitle: "Se fosse um carro, seria um Transformer."
	quest.14385D3D359224BC.title: "&dMeka-Tool"
	quest.143AE6889BDA9EF5.quest_desc: ["Módulos têm um número limitado de espaços para Itens Filtrados, se precisar de mais, use isto! Filtro de Item em Massa. \\n\\nVocê pode colocar muito mais Itens para a Lista Branca ou Lista Negra nele. Depois, jogue-o onde os Filtros normais vão! \\n\\nSerá necessário para criar Filtros mais únicos!"]
	quest.144BB025516E0994.quest_desc: [
		"&3Vibranium&r é o próximo minério depois do &6Allthemodium&r, então, claro, requer uma &6Picareta de Allthemodium&r (ou do mesmo tier) para minerá-lo.\\n\\nVocê pode encontrá-lo raramente no &c&lNether&r ou abundantemente no &b&lOutro&r.\\n\\nTambém é recomendado Processar o Minério para obter mais.\\n\\nInfelizmente, embora seja um minério ATM de cor legal, ele tem menos usos para Itens diferentes."
		"{image:atm:textures/questpics/allthemodium/all_2.png width:100 height:100 align:center}"
	]
	quest.144BB025516E0994.title: "Barra de &3Vibranium&r"
	quest.144ECED643031A9A.quest_desc: ["Cogumelos Luminosos são enormes plantas de Cogumelo que você pode encontrar nas Florestas Escarlates! \\n\\nEles funcionam como Cogumelos Marrons ou Vermelhos, só que estes Brilham muito mais! \\n\\n(Se você não sabia, Cogumelos Marrons e Vermelhos na verdade emitem uma fonte de Luz de nível 1)."]
	quest.145C8235BCCB9BA8.quest_desc: [
		"Se quisermos coletar todos os Gizes, precisaremos invocar e matar um &cAfrit&r não tão amigável."
		""
		"Mesmo que este não seja um &5Ritual de Possessão&r, você precisará de um sacrifício vivo para este ritual. Neste caso, sacrificaremos uma Vaca. Desculpe, Mimosa!"
	]
	quest.145C8235BCCB9BA8.quest_subtitle: "D.E.P. Mimosa"
	quest.145C8235BCCB9BA8.title: "&cGiz Vermelho"
	quest.145E7D1A88B83DDD.quest_desc: ["Onde você foi?"]
	quest.145E7D1A88B83DDD.quest_subtitle: "Cachecol (Colar)"
	quest.145E7D1A88B83DDD.title: "&9Cachecol da Invisibilidade&r"
	quest.14623D25561BA61B.quest_desc: ["Principalmente para o Apanhador."]
	quest.14623D25561BA61B.quest_subtitle: "Aumenta o Alcance de uma Máquina"
	quest.14623D25561BA61B.title: "&fMelhoria de &6Alcance"
	quest.148A33CC36B2563A.quest_desc: ["A &dPrateleira Dracônica&r é a última Prateleira que precisaremos para a configuração perfeita. \\n\\nPode dar apenas &aEterna&r, mas tem o máximo de &aEterna&r de &a100&r. \\n\\nPara criá-la, precisaremos de 5 &3Pérolas do End&r e uma &dCabeça de Dragão&r. É isso que a torna &dDracônica&r! \\n\\nPara obtê-las, você pode usar &a&lMA&r ou encontrá-las em &dNavios do End&r. Os &dNavios do End&r são Estruturas no &d&lO End&r, na proa (frente) fica a &dCabeça de Dragão&r."]
	quest.148A33CC36B2563A.title: "&dPrateleira do End Dracônica"
	quest.149BD1A9F82FA19A.quest_subtitle: "&f6 de &cDano de Ataque"
	quest.149C260C10B34BB0.quest_subtitle: "5/5"
	quest.149C260C10B34BB0.title: "Parte Esquerda da &6&lEstrela ATM&r"
	quest.14B3542ECB59869C.quest_desc: ["O &5Fabricante de Tesouros&r é a máquina que te dá aquele saque docinho das Previsões de Mob.\\n\\nQuando recebe energia e uma Previsão de Mob bem-sucedida, você poderá escolher qual item gostaria de obter do Modelo de Dados daquele mob. A máquina lembrará sua escolha, para que possa ser automatizada.\\n\\nExemplos de Previsões de Mob:\\n\\n- &dDragões do End&r para &dOvos de Dragão\\n - &2Zumbis&r para Ferro\\n - &0Withers&r para &5Estrelas do Nether"]
	quest.14B3542ECB59869C.title: "Criando &dSaques"
	quest.14B7EEBE0F6C2776.quest_desc: ["&dBafo de Dragão Infundido&r é obtido... bem, Infundindo &dBafo de Dragão&r. \\n\\nVocê pode usar 2 &9Soul-Touched Sculkshelves&r, 3 &bHeart-Forged Seashelves&r, 8 Estantes de Livros normais e 1 &6Estante de Livros de Estabilidade Encapsulada em Geodo&r. \\n\\nTambém será necessário para outras receitas, mas não falamos sobre isso!"]
	quest.14B7EEBE0F6C2776.title: "&dBafo de Dragão Infundido"
	quest.14C27D44D3C8EDF5.quest_desc: ["1. Você provavelmente irá apenas saquear as &dCidades do End&r por isso. \\n\\n2. Para automatizar, você precisará obter todos os itens. \\n\\nFarinha de Osso, &7Pólvora&r, &4Redstone&r, &cPó de Blaze&r e Membrana de Phantom podem ser automatizados com &b&lHNN&r ou &2&lMA&r. \\n\\n&bCristais Arcanos&r precisarão de &6&lAbelhas&r ou &2&lMA&r para obtê-los e depois fundi-los em &bPó&r."]
	quest.14C27D44D3C8EDF5.title: "Pó de &cMundabitur"
	quest.14D9C071E184DE3B.quest_subtitle: "Murta-de-crepe Roxa + Sorte"
	quest.14DB8A515CA50932.quest_desc: ["A &9Espada do Encantador&r permite que você anexe um Feitiço de Toque à espada. \\n\\nTodos os feitiços na Espada ganham 1 aumento de Amplificação adicional ao último efeito do feitiço. \\n\\nPara aplicar um feitiço à espada, use uma Mesa do Escriba. Crie o feitiço sem usar uma forma."]
	quest.14E5349DD740D026.quest_desc: [
		"Para inserir combustível no reator, você precisará escolher um dos lados que tenha uma &9Porta de Acesso Sólido ao Reator&r e bombear &eUrânio&r de um inventário.\\n\\nA maneira mais fácil de fazer isso é usar algo como uma &aGaveta de Armazenamento&r ou até mesmo um &aBaú&r com um &9Tubo de Item&r conectado na parte superior, como na imagem mostrada abaixo.\\n"
		"{image:atm:textures/questpics/extremereactors/importexample.png width:150 height:150 align:1}"
	]
	quest.14E5349DD740D026.title: "Abastecendo nosso Reator Passivo"
	quest.14F6ED7F0C1DC503.quest_desc: ["Beba 8 &6Garrafas de Mel&r. \\n\\nEsta é a mais difícil para mim, não suporto o barulho de beber &6Garrafas de Mel&r."]
	quest.14F7F256DA863280.quest_subtitle: "Faz vários Materiais da Twilight Forest"
	quest.14F856E0D32FBB5B.quest_subtitle: "Teca + Balsa"
	quest.14FC9E4A3C80C0AE.quest_desc: [
		"A Câmara de Reação é capaz de acelerar várias Reações no Mundo dentro de si, usando um fluido catalisador и grandes quantidades de energia. Devido ao ambiente controlado, esta máquina é capaz de tornar essas reações mais eficientes, permitindo que você obtenha mais material delas."
		""
		"Esta máquina consome bastante energia, no entanto, uma boa geração de energia e células de energia em sua Rede ME são altamente recomendadas."
		""
		"Esta máquina também é necessária para receitas relacionadas à Quântica no Advanced AE."
	]
	quest.14FC9E4A3C80C0AE.title: "Eficiência de Reação: A Câmara de Reação"
	quest.15007DCAF701B361.quest_desc: ["Carrega outros itens pressurizáveis em seu inventário a partir do armazenamento do peitoral."]
	quest.15007DCAF701B361.quest_subtitle: "Máx: 6"
	quest.150FB369BEFFCBBF.quest_subtitle: "Despeje Lúmio Derretido sobre um Ovo de Gerador de Abelha de Prata/Estanho"
	quest.150FB369BEFFCBBF.title: "&fAbelha de Lúmio"
	quest.1515B32545F51266.quest_desc: ["Permite que você conecte energia ao Fogão."]
	quest.1515B32545F51266.title: "Melhoria de Aquecimento"
	quest.151648179684B088.quest_desc: ["Giz Rúnico é usado para desenhar Runas permanentes no chão. Essas runas lançarão feitiços em entidades que passarem sobre elas. \\n\\nPara anexar um feitiço a uma runa, inscreva um &ePergaminho de Feitiço&r usando uma Mesa de Escriba.\\n\\nNota: A Runa precisará de Fonte para operar."]
	quest.151648179684B088.quest_subtitle: "Feitiços Posicionáveis"
	quest.15195F456D8AD4C8.quest_desc: ["Quando Éter toca Água, Tioquartzo se formará. Isso pode acontecer naturalmente com a geração aleatória ou você pode fazer acontecer! \\n\\nNão é assim que conseguimos Fragmentos, no entanto, esses vêm do Tioquartzo em Brotação!"]
	quest.151D836C7B0E6FAF.title: "Escudo de &3Vibranium"
	quest.15279CAC2FFE6B35.quest_subtitle: "Tier: &c5"
	quest.15288215A4BA2596.quest_subtitle: "Alimente uma Abelha Diamante com um Bloco de Quartzo Rosa"
	quest.15288215A4BA2596.title: "&fAbelha de Quartzo Rosa"
	quest.1533D98B3B2A758E.quest_desc: ["Espadas Estilhaçadas podem ser dropadas de Esqueletos Lonestar ou criadas usando as Lâminas dropadas. \\n\\nA Espada Estilhaçada é usada mais como um Tridente do que como uma Espada, em vez de bater, você a arremessa. Então, você pode Clicar com o Botão Direito para trazer a Lâmina de volta como um Tridente com Lealdade, e Clicar com o Botão Direito novamente para recarregá-la, se necessário."]
	quest.1540A9CDE2ED77E8.quest_subtitle: "Feito com energizador"
	quest.1540A9CDE2ED77E8.title: "&fAbelha de Cristal Vibrante"
	quest.154D9EA863FD2A32.title: "Módulo de Penetração de Projétil Caótico"
	quest.15551AC6C68E12E0.quest_desc: ["Basicamente o gerador de mobs do &bIndustrial Foregoing&r. Ele usa &aEssência&r junto com um mob em uma Ferramenta de Prisão de Mob para gerar uma cópia desse mob.\\n\\nChefes e outros mobs que não podem ser colocados em um gerador* estão na lista negra do Duplicador de Mobs também.\\n\\n*&8Com algumas exceções, segure SHIFT em um Ovo de Gerador enquanto as dicas avançadas (F3 + H) estiverem ativadas para ver se consegue encontrar a tag de Lista Negra do Duplicador de Mobs."]
	quest.15564C11744D6AA0.quest_desc: ["Depois de obter um conjunto completo das &ePrensas de Inscrição&r necessárias, é hora de começar a fazer alguns &eProcessadores&f. Eles são um ingrediente de criação importante usado para fazer a grande maioria dos dispositivos conectados à ME."]
	quest.15564C11744D6AA0.quest_subtitle: "O cérebro por trás da bagunça digital."
	quest.15564C11744D6AA0.title: "&eProcessadores"
	quest.1556777B07BD7C2B.quest_subtitle: "Lariço Europeu + Bordo de Açúcar"
	quest.155A843A562DB7C4.quest_subtitle: "Tier: &63"
	quest.1568CBFA09827137.quest_desc: ["A mesma coisa que o Programador Lógico, só que este pode ser usado em qualquer lugar."]
	quest.156FF8B7B724DC38.quest_desc: ["Adiciona um filtro para itens sendo bombeados para dentro ou para fora da Mochila."]
	quest.15849165CA8C00F9.quest_desc: [
		"A última e mais poderosa &6&lForja&r, claro que isso significa que é a mais cara! \\n\\nVocê precisará de 2 &5Estrelas do Nether Escuras&r, que são feitas combinando 4 &5Obsidiansteel&r e uma Estrela do Nether. \\n\\n2 &dEscamas de Dragão&r que são dropadas quando o &dDragão do End&r morre. \\n\\n4 &3Catalisadores de Sculk&r que são dropados do &3Warden&r, ou podem ser obtidos com Toque Suave no Deep Dark. \\n\\nE um &2Bloco de Estelarita&r que são apenas 9 &2Fragmento de Stellarita&r! \\n\\nIsso permite ainda mais Essências e Receitas de Fim de Jogo."
		"{image:atm:textures/questpics/forbidden/forbidden_tier5.png width:100 height:100 align:center}"
	]
	quest.15849165CA8C00F9.title: "&6Forja &l&9Tier 5"
	quest.158B24939A269D83.quest_desc: ["A Melhoria de Ponta é usada para aumentar o nível de mineração de uma ferramenta.\\n\\nPor exemplo: Se você tem uma Picareta de Ferro, com 1 Diamante, você pode fazer uma Melhoria de Ponta de Diamante e colocá-la na sua picareta. Isso permitirá que ela mine Obsidiana, além de dar um aumento de status."]
	quest.158B24939A269D83.quest_subtitle: "Para quando você não encontra 3 Diamantes"
	quest.158F872A3A2C3650.quest_desc: ["Agora que temos nosso máximo de &aEterna&r de &a80&r, podemos começar a &d&lInfundir&r &dBafo de Dragão&r! \\n\\nO &dBafo de Dragão&r pode ser obtido ao lutar contra o &d&lDragão do End&r. Quando ela está pousada sobre seu ninho, ela pode atirar uma névoa &dRosa&r em você. Quando estiver nela, você pode Clicar com o Botão Direito com uma Garrafa Vazia para obter &dBafo de Dragão&r! \\n\\nA melhor maneira de obter nossos Níveis é com 4 &9Echoing Sculkshelves&r, 4 &9Soul-Touched Sculkshelves&r e 6 &6Estantes de Livros de Estabilidade Encapsuladas em Geodo&r. \\n\\nIsso nos dará &a80 Eterna&r, &c25% Quanta&r e &5100% Arcana&r. Perfeito para &d&lInfusão&r!"]
	quest.158F872A3A2C3650.title: "&dBafo de Dragão Infundido"
	quest.1591013DDD4766E1.quest_desc: ["&l&cCooking for Blockheads&r é sobre fazer da Cozinha o seu lar. \\n\\nRecomendo usar tudo o que ele oferece, pois cada Item tem um uso e parece incrível!"]
	quest.1591013DDD4766E1.title: "&l&cCooking for Blockheads&r"
	quest.15978093237448FE.quest_desc: ["Por que atualizar &cNetherita&r para &6Allthemodium&r ou até mesmo qualquer outra coisa quando podemos atualizá-la para &3Armadura do Warden&r! \\n\\nVocê precisará de alguns Drops do Warden para fazê-la, no entanto!"]
	quest.15978093237448FE.quest_subtitle: "24"
	quest.15978093237448FE.title: "Armadura do &3Warden"
	quest.159FAAE66F20FB4F.quest_desc: ["As &cPoke&rBolas &2Amiga&f, &8Luxo&f e &dCura&r ajudam seu &cPokémon&r após ser capturado! \\n\\nA &2Bola Amiga&r inicia seu &cPokémon&r com 150 Pontos de Amizade (soa como manipulação, não uma Amizade real!). \\n\\nOs &cPokémon&r em &8Bola Luxo&r ganharão Amizade duas vezes mais rápido que &cPokémon&r em outras &cBolas&r. \\n\\nE a &dBola Cura&r agirá como se o &cPokémon&r tomasse um bom banho na &aMáquina de Cura&r após você Capturá-los. É, apenas aquela vez, não constantemente."]
	quest.159FAAE66F20FB4F.title: "&cBolas&r que ajudam &cPokémon"
	quest.15A8F04BC10E619E.quest_desc: [
		"Algumas pessoas odeiam explorar muitos Biomas diferentes para obter todas as diferentes Mudas de Árvore. \\n\\nClaramente o Desenvolvedor do &2&lUndergarden&r odiava, então ele colocou a maioria delas na Floresta Densa!"
		"{image:atm:textures/questpics/undergarden/undergarden_dense.png width:200 height:100 align:center}"
	]
	quest.15A8F04BC10E619E.title: "Floresta Densa"
	quest.15C9CCCC8E06D430.quest_subtitle: "Alimente uma Abelha Cristalina com um Bloco de Quartzo Negro"
	quest.15C9CCCC8E06D430.title: "&fAbelha de Quartzo Negro"
	quest.15CD4BFDC56E9510.quest_subtitle: "Mais Opções de Filtragem"
	quest.15CD4BFDC56E9510.title: "&eMelhoria Avançada de Troca de Ferramentas"
	quest.15D355EB164EBE68.quest_subtitle: "Necessário para Chapas de Circuito Impresso Finalizadas"
	quest.15D355EB164EBE68.title: "Capacitores"
	quest.15D764CAF047EA7A.title: "Armadura de &cTertium"
	quest.15DC6770B112EE69.quest_desc: [
		"A Câmara de Dissolução é uma Máquina adicionada pelo &l&7Industrial Foregoing&r. É também como combinaremos &3Vibranium&r e &5Unobtainium&r. \\n\\nVocê precisará de &dLimo Rosa&r, que você obtém da Fábrica de Abate de Mobs, que é outra Máquina adicionada pelo IF. \\n\\nVocê também precisará de Lava da Alma, que é encontrada no &b&lOutro&r, comum na Vila Piglin. \\n\\nDepois disso, você precisará colocar suas Barras e Corações de Piglich na ordem exata, energizá-lo, e estará pronto!\\n"
		"{ \"text\": \"LINHA DE MISSÕES INDUSTRIAL FOREGOING\", \"color\": \"#55FF55\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"193F91842D2ED7D9\" } }"
	]
	quest.15ECBC8E174FA39B.quest_desc: ["Permite que você acesse o armazenamento da sua rede sem fio."]
	quest.15ECBC8E174FA39B.quest_subtitle: "Grade Portátil"
	quest.15FEA03A2CDBA33B.quest_desc: ["&b&lO Outro&r passou por dezenas de mudanças ao longo dos anos, mas sempre foi um reino para aventureiros! \\n\\nHá dezenas de novos biomas, blocos e, claro, estruturas! \\n\\nAs Estruturas são: Vila Piglin, Pirâmide Ancestral e Masmorra. Todas contendo saques incríveis com algumas coisas sendo únicas para sua estrutura! \\n\\nVocê também pode minerar &3Vibranium&r (e outros minérios!) ou encontrá-lo e coisas melhores nas estruturas! \\n\\nVocê não pode montar Pedreiras ou muitos blocos no &b&lOutro&r, no entanto, sem explorar falhas aqui."]
	quest.15FEA03A2CDBA33B.title: "&l&bO Outro&r"
	quest.15FF9D19FBC873CF.quest_subtitle: "Ameixa + Pêssego"
	quest.1609BF52108238B0.quest_subtitle: "Tier: &e1"
	quest.160BD0185954C891.quest_desc: ["Em vez de usar &6Guloseimas de Mel&r, esta colmeia requer &eBarras de Ouro&r para atrair Abelhas."]
	quest.160BD0185954C891.quest_subtitle: "Atrai uma Abelha de Ouro quando colocada no Nether"
	quest.160BD0185954C891.title: "&fNinho de Ouro do &cNether"
	quest.161878AB4236C58B.quest_subtitle: "&f6.5 de &cDano de Ataque"
	quest.161A90E134592D0E.quest_desc: ["Como a Carne Crua normal, você pode cozinhar a &cCarne Eterna&r para obter &4Bife Eterno&r!\\n\\nFunciona como a &cCarne Eterna&r, mas com mais Pontos de Fome e Saturação."]
	quest.161A90E134592D0E.quest_subtitle: "Único"
	quest.161A90E134592D0E.title: "&4Bife Eterno"
	quest.161E7D934A21F849.quest_desc: [
		"Reforma é transformar um &eAlchemical Sulfur&r em outro ou usar &3Nitrato Alquímico&r para se transformar em mais! \\n\\nO primeiro passo é o Pedestal da Fonte, é aqui que você coloca o &eEnxofre&r que você quer que seja transformado em outro."
		"{image:atm:textures/questpics/theurgy/theurgy_reform_1.png width:100 height:100 align:center}"
	]
	quest.161E7D934A21F849.title: "Passo 1: Pedestal da Fonte"
	quest.161EDD68FF1A7F1B.quest_subtitle: "Funciona com lava"
	quest.16255FB20F35A9D9.quest_desc: ["O &3Snorkel&r lhe dá uma pequena quantidade de Respiração Aquática quando você entra na &9Água&r. Semelhante a um Casco de Tartaruga! Cuidado, pois ele se esgota."]
	quest.16255FB20F35A9D9.quest_subtitle: "Cabeça"
	quest.16255FB20F35A9D9.title: "&3Snorkel"
	quest.162807D14C173CB4.quest_desc: [
		"A &#5599EDCentrífuga&r confirmou nossa teoria: se girarmos algo rápido o suficiente, um novo material simplesmente aparece. "
		""
		"Ela tem muitos usos, mas você vai precisar principalmente para o processamento de &#F2AAE5Cromo&r e &#AD3497Monazita&r."
	]
	quest.162807D14C173CB4.quest_subtitle: "Você me deixa tonto, tonto.."
	quest.162807D14C173CB4.title: "&5Centrífuga"
	quest.162955874B77F4F6.quest_desc: ["Temos nossas &bTampas&r e nossos &7Mecanismos&r, vamos finalmente fazer nossas &cPoke&rbolas! \\n\\nOs únicos Itens extras que precisaremos são uma Tampa Vazia e uma &7Vara de Ferro&r. \\n\\nPodemos usar &6Implantadores&r, uma &7Câmara de Pressão&r, ou uma &8Linha de Montagem&r para juntar tudo. Vamos lá, a esta altura você já deve saber como usá-los!"]
	quest.162955874B77F4F6.title: "Combinando tudo para fazer nossa..."
	quest.16299B9AE87257DC.quest_desc: ["O &bTerminal Sem Fio&f funciona de forma idêntica a um terminal comum, mas sem fio.\\n\\nAntes que possa ser usado para acessar uma rede, ele deve primeiro ser &econectado&f à rede, colocando-o no slot superior direito do &ePonto de Acesso Sem Fio&r. Se não estiver conectado a uma rede, ou estiver fora de alcance ou sem energia, o terminal não funcionará.\\n\\nTerminais sem fio também podem ser atualizados com &eCartões de Energia&f para fornecer uma bateria interna maior."]
	quest.16299B9AE87257DC.quest_subtitle: "É por isso que você está aqui"
	quest.16299B9AE87257DC.title: "Terminais Sem Fio"
	quest.162CE44400A63575.quest_desc: ["A primeira e mais importante &5Máquina&r é o &9&lInfusor Metalúrgico&r! \\n\\nO &9&lInfusor Metalúrgico&r combinará um &eItem&r e um &cQuímico&r para Criar novos &eItens&r e Ligas. \\n\\n&cProdutos Químicos &fou &aTipos de Infusão&r irão para o &eQuadrado Amarelo&r e aparecerão na &eBarra&r à esquerda dele. \\n\\nO &4Quadrado Vermelho&r conterá o Item que será Infundido. \\n\\nO &9Quadrado Azul Escuro&r será onde o produto vai! \\n\\nÀ direita, o &aSlot Verde Claro&r e a &aBarra&r são para &aEnergia&r! \\n\\nSe você precisar de espaço na &eBarra Química&r, use o botão &lDUMP&r. Isso ejetará todos os &cProdutos Químicos&r dela!"]
	quest.162CE44400A63575.quest_subtitle: "A Máquina Inicial"
	quest.162CE44400A63575.title: "&9&lInfusor Metalúrgico"
	quest.162D2286A69D6E07.quest_desc: [
		"Status semelhantes à &6Armadura de Allthemodium&r normal, mas esta vem com seus próprios Bônus de Mana, Regeneração e Poder de Feitiço para Feitiços da Ars!"
		"{image:atm:textures/questpics/allthemodium/all_armor_allarcane.png width:100 height:175 align:center}"
	]
	quest.162D2286A69D6E07.title: "Armadura Arcanista de &6Allthemodium"
	quest.1630CFBFB562C43B.quest_subtitle: "Use combustível líquido para gerar energia"
	quest.16359196D49A6223.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_froststeel.png width:100 height:150 align:center}"]
	quest.16359196D49A6223.title: "&bAço Gelado&r"
	quest.1636F3F12E92CAEA.quest_desc: [
		"Para usar um Regador, você precisará enchê-lo com Água clicando com o botão direito em uma fonte de água. Uma vez cheio de Água, você pode segurar o botão direito sobre uma plantação para regar as plantações dentro da área de efeito do Regador."
		""
		"Regadores de Essência têm a capacidade de regar automaticamente. Apenas clique com shift-direito no Regador no ar para ativar ou desativar a rega automática. Parecerá que o Regador está encantado quando estiver ligado."
	]
	quest.164BBBD98163F64C.quest_desc: ["Confira os Módulos para aprender mais sobre como usar e aprimorar os itens do DE! Ela pode criar terra arada ou pegar seu dinheiro. Ah, espere, Enxada do Minecraft, desculpe, estava pensando em outra coisa."]
	quest.164BBBD98163F64C.title: "Enxada Wyvern"
	quest.164EA8EE10CA1583.quest_desc: ["&fO &#ED9553Macerator&r transforma &6minérios brutos&r em pós. Ele também pode reciclar todos os tipos de &6materiais&r, transformando-os em pó."]
	quest.164EA8EE10CA1583.title: "&fO &#ED9553Macerador de Bronze"
	quest.165030137EF59299.title: "Módulo de Área de Efeito Wyvern"
	quest.1659A59303C15CC9.quest_desc: ["Barris funcionam da mesma forma que Baús, só que não podem ser combinados. Mas eles são legais."]
	quest.1665D7A3BDC93BEA.quest_desc: [
		"Sem aumento de nível. "
		""
		"Item de Assinatura é &cGuizo &7Calmante&r."
	]
	quest.1665D7A3BDC93BEA.title: "&6Rival Terry "
	quest.166971866A9234C7.quest_desc: ["Um dos 3 Itens fundidos mais importantes é a &cLiga Fundida&r. \\n\\nPara fazê-la, precisaremos Infundir um &6Barra de Cobre&r com 10mB de &4Redstone&r. \\n\\nComo conseguimos 10mB de &4Redstone&r, você pergunta? Colocando um &4Item de Redstone&r no &eQuadrado Amarelo&r do &9&lInfusor Metalúrgico&r! \\n\\nPerderemos o &4Item de Redstone&r e diferentes &4Itens&r dão quantidades diferentes. &4Pó de Redstone&r dá 10mB, &4Redstone Enriquecida&r dá 80mB e um &4Bloco de Redstone&r dá 90mB."]
	quest.166971866A9234C7.quest_subtitle: "A Liga Básica para Criar Itens"
	quest.166971866A9234C7.title: "Liga &cFundida"
	quest.166CE4243896A0CD.quest_desc: ["Não gosta das suas &aGemas&r? Então, mude-as! \\n\\nPara mudar a Raridade da sua &aGema&r, você precisará usar esta &a&lMesa&r. \\n\\nUsando 2 &aGemas&r iguais e Materiais de Raridade, você pode aumentar a Raridade de suas &aGemas&r e isso aumenta seu poder."]
	quest.166CE4243896A0CD.title: "Obtendo &aGemas&r melhores"
	quest.166D2A191871F80E.quest_desc: ["Versão aprimorada da Picareta Wyvern."]
	quest.166D2A191871F80E.title: "Picareta Dracônica"
	quest.167E1474644C9908.quest_desc: [
		"O Quartzo faz o oposto do que o outro item faria no &9Modificador de Gerador&r.\\n"
		"Com o Quartzo na mão secundária e o outro item de modificação de gerador na mão principal, ele fará o oposto da função original.\\n"
		"Por exemplo, com Quartzo e &cBastões de Blaze&r, em vez de aumentar o &9Alcance de Geração&r, ele o diminuirá.\\n"
		"Com Quartzo e Lágrimas de Ghast, ele reduzirá o número máximo de entidades e pro assim vai."
	]
	quest.167E1474644C9908.title: "Dia do Contrário"
	quest.1684D52FDAAC894B.quest_desc: ["Lembra daquele cara Não-Médico-de-Minérios? A Fábrica de Lavagem substitui ele, para lidar com a Carne de Minério Bruta da Fábrica de Lavagem, transformando-a em Carne de Minério Fermentada. Esta máquina tem 4 modos.\\n\\n1. Taxa de processamento de minério 2x, 5 segundos para processar.\\n2. Taxa de processamento de minério 3x, 45 segundos para processar.\\n3. Taxa de processamento de minério 4x, 120 segundos para processar. Usa &#FF69B4Slime Rosa&r como catalisador.\\n4. Taxa de processamento de minério 5x, 300 segundos para processar. Usa &bGás de Éter&r como catalisador."]
	quest.1684D52FDAAC894B.quest_subtitle: "Processamento de Minério: Passo 2"
	quest.1690E9F6BBF820D1.quest_desc: ["Para &5Terastalizar&r &cPokémon&r, precisaremos de muitos &5Fragmentos Tera&r. \\n\\nVamos facilitar o transporte de muitos desses &5Fragmentos Tera&r usando uma Bolsa! \\n\\nA Bolsa Tera pode guardar um pack de cada tipo de &5Fragmento Tera&r."]
	quest.1697CC05D08B388D.quest_subtitle: "Delicioso Frango Frito!"
	quest.1697CC05D08B388D.title: "As Galinhas Devem Partir"
	quest.1698565EBB68DC85.quest_desc: [
		"O &6Trilho em Y&r é o segundo trilho feito usando uma Malha de Cravos. Ele direciona dois &6Trilhos&r em um. Se você tem um &6Trilho&r intersectado por outro, o &6Y&r moverá &7Carrinhos&r no primeiro &6Trilho&r para o trilho que o intersecta."
		"{image:atm:textures/questpics/railcraft/rail_wye.png width:100 height:100 align:center}"
	]
	quest.1698565EBB68DC85.title: "Trilhos em &6Y"
	quest.16987C41D4F5BA47.quest_subtitle: "Feito na Fundição de Ligas"
	quest.16987C41D4F5BA47.title: "&fAbelha de Liga de Cobre"
	quest.16A04B2FC3F0D902.quest_desc: ["As Ferramentas de &7Cloggrum&r agem como as Ferramentas de Ferro, só que estas parecem mais com Lama do que com Ferro! \\n\\nA Espada causa mais dano do que uma Espada de Ferro, no entanto."]
	quest.16A04B2FC3F0D902.title: "Ferramentas de &7Cloggrum&r"
	quest.16A2CC83C99B1F86.quest_desc: [
		"Os &9Peixes-pescadores&r aparecem em &9Lagos de Água&r dentro das &bCavernas Floridas&r. \\n\\nEles agem como Peixes normais, obviamente precisando de &9Água&r para respirar. \\n\\nEles têm 3 &4Corações&r e irão te atacar quando você estiver perto. \\n\\nInfelizmente, eles não dropam nada ao morrer... desculpem, peixinhos!"
		"{image:atm:textures/questpics/deepndark/dnd_fish.png width:100 height:120 align:center}"
	]
	quest.16A2CC83C99B1F86.title: "&3Peixe-pescador"
	quest.16AAC61729C44881.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, está no modo de edição."]
	quest.16B06A4C0B9F8DFB.quest_desc: [
		"Dentro de Pântanos você pode encontrar Poços Enraizados. \\n\\n&8Lama &fe &2Raízes&r com um pouco de &7Cascalho Suspeito&r."
		"{image:atm:textures/questpics/pokemon/find_root.png width:200 height:100 align:center}"
	]
	quest.16B06A4C0B9F8DFB.title: "Poço Enraizado Pré-histórico"
	quest.16B0C1F7B951C19D.quest_desc: ["Agora que temos nosso &eEmpacotador&r, podemos ter &ePacotes&r! \\n\\nHá 4 variantes, mas isso não muda nada neles além da aparência. É totalmente aleatório qual você recebe. \\n\\n&ePacotes&r são &eItens&r e, quando Colocados no Chão, se tornam Entidades. Você pode Clicar com o Botão Direito neles depois de Colocados para pegá-los, ou Quebrá-los para tirar os &eItens&r de dentro. Você também pode movê-los como qualquer outra Entidade! \\n\\n&ePacotes&r também podem ser usados para interagir com outras &6Máquinas&r. Como serem colocados em &8Esteiras de Corrente&f ou &eEsteiras&r!"]
	quest.16B0C1F7B951C19D.title: "&ePacotes de Papelão"
	quest.16B88F46021E956D.quest_desc: ["&l&6Theurgy&r tem Máquinas, então é claro que precisa de Logística!\\n\\n(Confira a Página de Logística Básica para saber mais sobre logística).\\n\\nCom &cMercúrio&r, você pode mover Itens e Fluidos de um lugar para outro usando &cFios de Mercúrio&r e outros Itens! Os Fios são o que realmente moverão os Itens."]
	quest.16B88F46021E956D.title: "Logística com &cMercúrio&r"
	quest.16C74B5F99AD6724.quest_desc: ["&8Comum&r é a Raridade mais básica. Isso a torna mais comum no início do jogo, mas também a mais fraca. \\n\\n&8Comum&r aparece mais no &lNível de Mundo: &9Refúgio&r, e deixará de aparecer após o &lNível de Mundo: &6Cume&r. \\n\\n&8Metais de Sucata Misteriosos&r são feitos usando &eItens&r &8Comuns&r em uma &c&lMesa de Desmanche&r."]
	quest.16C74B5F99AD6724.quest_subtitle: "&8Comum"
	quest.16C74B5F99AD6724.title: "&8Metais de Sucata Misteriosos"
	quest.16D0F1E3CEB60ABF.title: "Vara de Pescar de Ferro"
	quest.16DDAE318535D0F9.quest_desc: ["O &bDesintegrador &cAtômico&r é a Paxel do &5&lMekanism&r! \\n\\nEle pode Minerar quaisquer Blocos que uma &6Paxel de AllTheModium&r consegue! Também pode ser usado como uma Espada... bem, mais como um Machado, já que não tem o encantamento Alcance. \\n\\nEle tem diferentes Modos, cada um com Eficiência e uso de &aEnergia&r diferentes. Podemos alterná-los segurando Shift e rolando o scroll do mouse. \\n\\nNormal: é o Modo padrão. Com uma Eficiência de 20, o que equivale a aproximadamente Eficiência II. \\n\\n&eLento&r: é como uma Paxel sem Eficiência, mas usará menos &aEnergia&r por uso! \\n\\n&eRápido&r: usa muito mais &aEnergia&r, mas é bem mais rápido! Como Eficiência V. \\n\\n&4Desligado&r: não quebrará Blocos, em vez disso, seu único propósito é MATAR!"]
	quest.16DDAE318535D0F9.quest_subtitle: "Cuidado: pode causar inveja em picaretas comuns!"
	quest.16DDAE318535D0F9.title: "&bDesintegrador &cAtômico"
	quest.16DFD50997856CFA.quest_desc: ["A &5Pedra do Crepúsculo&r irá &bEvoluir&r &9Murkrow&r para &9Honchkrow&r, &5Misdreavus &fpara &5Mismagius&r, &5Lamp&cent&r para &5Chande&clure&r, e &7Doub&5lade&r para &7Aegis&5lash&r."]
	quest.16DFD50997856CFA.title: "&5Pedra do Crepúsculo"
	quest.16E02F671FBE9148.quest_desc: ["A Arma de Portal é um item que usa energia para criar dois portais para se teleportar entre dois pontos. Clique Esquerdo atira um portal azul, Clique Direito um portal laranja e Shift Clique Direito remove ambos os portais."]
	quest.16E0E86A19015F2A.quest_desc: ["Para ativar a &bMega Pedra&r, precisaremos de um &bBracelete Mega&r. \\n\\nSim, sim, sim, eu sei que nem todos são &bBraceletes&r. \\n\\nBracelete, Anel, Tiara, o que for! Desde que caiba no &bEspaço de Mega&r, use-o."]
	quest.16E0E86A19015F2A.title: "&bBraceletes Mega"
	quest.16E3031D800B40D5.quest_desc: ["O Spawner de Sôulio usa essências de mob para gerar mobs. Por exemplo, se você colocar um pouco de Essência de Ghast, pode gerar um Ghast."]
	quest.16FA120455D36B58.quest_subtitle: "Laranja + Mangue"
	quest.16FF2219F110F50A.quest_desc: ["O Módulo Imortal age como a coisa que o cria, o Totem da Imortalidade! Quando seus corações chegam a 0, em vez de morrer, o Módulo será ativado, dando a você Absorção e Regeneração, salvando sua vida. Ele tem um tempo de recarga e precisa usar OP para se recarregar. Tente não morrer durante esse tempo! Aprimoramentos melhores significam tempos de recarga menores."]
	quest.16FF2219F110F50A.title: "Módulo Imortal Wyvern"
	quest.170118E3C3C072E5.quest_desc: [
		"A &6Junção&r é o último &6Trilho&r feito pela Malha de Cravos. Ele age como uma intersecção normal para &6Trilhos. &7Carrinhos&r continuam indo na mesma direção de antes, mas agora os &6Trilhos&r podem se cruzar. O que acontece se 2 &7Carrinhos&r se chocarem nela? ELES EXPLODEM!!! Estou brincando, mas as &eLocomotivas Elétricas&r explodem."
		"{image:atm:textures/questpics/railcraft/rail_junction.png width:100 height:100 align:center}"
	]
	quest.170118E3C3C072E5.title: "Trilhos de &6Junção"
	quest.1705175C20CE91DD.quest_desc: ["A Liga do Eclipse é um novo material adicionado pelo JDT. A Liga do Eclipse é adquirida realizando a Propagação de Gosma em Blocos de Netherita usando gosma de tier quatro. O Minério de Liga do Eclipse é afetado por fortuna."]
	quest.1705175C20CE91DD.title: "Liga do Eclipse"
	quest.170C31F3BAF050BC.quest_subtitle: "Feito em Reprocessador"
	quest.170C31F3BAF050BC.title: "&fAbelha de Blutônio"
	quest.1710B3D05215A71E.quest_desc: [
		"&bP2P&f (ponto a ponto) é um sistema poderoso dentro do AE2, permitindo a transferência de itens, fluidos e muito mais sem a necessidade de qualquer armazenamento ME intermediário."
		""
		"Clicar com o botão direito em um túnel &bP2P&f com certos itens irá &esintonizar&f o túnel em um capaz de transferir outra coisa, como itens através de tubos, energia através de cabos, sinais de redstone e (por padrão) até mesmo conexões ME."
		""
		"&dTúneis P2P&f devem ser ligados uns aos outros com o uso de um &eCartão de Memória&f, detalhado na próxima missão."
	]
	quest.1710B3D05215A71E.quest_subtitle: "Elimine o intermediário"
	quest.1710B3D05215A71E.title: "&dTúneis P2P"
	quest.1712C3B3CF158843.quest_desc: ["Para fazer o &eMecanismo de Precisão&r, precisaremos de 3 &6Ejetores&r, 3 &eDepósitos&f/&eEsteiras&r, 1 &eChapa de Ouro&r, 5 Engrenagens, 5 Rodas Dentadas Grandes e 5 &7Pepitas de Ferro&r, além de sorte! \\n\\nPegue sua &eChapa de Ouro&r (que pode ser feita Prensando uma Barra de Ouro) e coloque-a sob cada um dos Ejetores em ordem. \\n\\nO primeiro precisará de uma Engrenagem, o segundo de uma Roda Dentada Grande e o terceiro de uma Pepita de Ferro. \\n\\nEntão, uma vez que tenha sido processado por todos os 3, repita! E faça isso 5 vezes seguidas. \\n\\nNo final, há apenas 80% de chance de que realmente dê certo. Os outros 20% verão todo o seu trabalho virar FUMAÇA!"]
	quest.1712C3B3CF158843.title: "&eMecanismo de Precisão"
	quest.171DB70D0D19A942.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Funde automaticamente itens dropados de blocos minerados."
	]
	quest.172D2A634E849562.quest_desc: ["Com nossa habilidade de colher &cIesnium&r, podemos chamar os Demônios para fazer nosso trabalho nas minas... Quer dizer... nos ajudar a coletar minérios. Definitivamente não estamos explorando Demônios nem nada.\\n\\nPara isso, precisaremos criar um &dPoço de Mina Dimensional&r para acessar o Mundo de Mineração Demoníaco. Você também precisará de um Demônio Minerador confinado em uma lâmpada, que você colocará dentro do Poço de Mina para que funcione. Embora qualquer tier complete esta missão, tiers mais altos trabalham mais rápido e têm uma chance maior de minerar Iesnium para você.\\n\\nOs Poços de Mina não exportam por conta própria. Você precisará extrair os itens usando Funis, Demônios Transportadores ou algum outro método como Tubos de Itens. Ele anulará quaisquer itens acima de seu limite de armazenamento."]
	quest.172D2A634E849562.title: "&cMineração Demoníaca"
	quest.173541B0765DA13E.quest_desc: ["Este eu diria que é o mais fácil de automatizar. \\n\\nMembranas de Phantom, Penas e Lã podem ser automatizadas via &b&lHNN&r. \\n\\nSomente a &7Asa de Morcego&r é mais difícil, precisando ser farmada via spawners!"]
	quest.173541B0765DA13E.title: "Prisma do &fRedemoinho"
	quest.173DE446B07004C8.quest_desc: ["A &bGrande Bola de Fogo&r precisará de sua &bTampa&r, uma Tampa Vazia, um &5Mecanismo Robusto&r e uma &7Vara de Ferro&r para ser criada. \\n\\nUma vez que todos sejam combinados através de qualquer processo que você escolher, você finalmente a terá. \\n\\nEsta Bola tem uma Chance de 2x em quase todos os tipos de &cPokemon&r, exceto por 50x para &cTipos Fogo&r e 0x para &bTipos Água&r. \\n\\nÉ, não é a melhor para capturar &bMudkips&r..."]
	quest.173DE446B07004C8.title: "&bGrande Bola de Fogo"
	quest.17419401147B5C02.quest_desc: [
		"Além de atrair abelhas com ninhos, a maioria das abelhas requer &eCruzamento&r ou &9Conversão&r para serem criadas. (Não, isso não é um erro de digitação.)"
		""
		"O &eCruzamento de Abelhas&r requer 2 abelhas e itens específicos dados a elas para que acasalem."
		""
		"A &9Conversão de Abelhas&r requer que você alimente uma abelha com um item específico para convertê-la em uma nova Abelha."
	]
	quest.17419401147B5C02.quest_subtitle: "Você curte jazz? - Não, não é uma referencia."
	quest.17419401147B5C02.title: "&fCriando e Convertendo &6Abelhas"
	quest.1744E700CF742CE2.quest_desc: ["&5O Coralssus&r atua como um Guarda e Montaria para a &5Cidade Submersa&r. \\n\\nEles podem ser montados por &5Deeplings&r para se moverem mais rápido e atacarem juntos! \\n\\nEles têm 160 &4Corações&r e ataques básicos. Seus ataques são apenas bater e te arremessar. \\n\\nQuando morto, ele dropará Pedaços de Coral que podem ser usados para fazer o &5Sacrifício Abissal&r."]
	quest.1744E700CF742CE2.title: "&5Coralssus&r"
	quest.1745124F83D033B9.title: "&5Componentes Básicos"
	quest.174D18D9D732EC10.quest_subtitle: "8 Blocos Verdes Molhados"
	quest.17542D7633FBF098.quest_desc: [""]
	quest.17542D7633FBF098.quest_subtitle: "&oPena que o Bob Esponja não é uma Estrela."
	quest.17542D7633FBF098.title: "&d&lPatrick &aEstrela&r"
	quest.175509632CBF8631.quest_desc: ["Melhora o rendimento em todas as receitas de pulverização."]
	quest.175509632CBF8631.quest_subtitle: "Um pulverizador melhor"
	quest.1756F81ACFC56C58.quest_subtitle: "Tier: &e5"
	quest.1759A4E2AF0D2C88.quest_desc: ["Pense no &eLight Engineering Block&r, agora apenas torne todos os seus componentes muito mais difíceis de fazer! \\n\\n1º precisamos de &eElectrum&r, que é uma Liga de &eOuro&r e &7Prata&r feita na &6&lFornalha de Liga&r. \\n\\n2º precisamos de 4 &8Chapas de Aço&r, que como a &7Chapa de Ferro&r, precisam de 4 &8Placas&r combinadas. \\n\\n3º são nossos &8Componentes Mecânicos de Aço&r, que são um &6Lingote de Cobre&r e 4 &8Placas de Aço&r em uma Mesa de Criação, ou feitos mais baratos na &6Bancada do Engenheiro&r."]
	quest.1759A4E2AF0D2C88.title: "Bloco de Engenharia &7Pesada"
	quest.175D943160C10646.quest_desc: [
		"&l&7RailCraft&r usa muitas máquinas para coisas diferentes, mas principalmente para a criação de recursos."
		""
		"Todas elas começam com Iron Ingots!"
	]
	quest.175D943160C10646.title: "Máquinas &l&7"
	quest.176A1CC43467EF23.quest_desc: [
		"Melhorias Válidas:"
		"- Assistência de Passo"
		"- Impulso de Salto"
		"- Pisão no Chão"
		""
		"Habilidade Intrínseca:"
		"- Reparo com Lava"
	]
	quest.176ACC61DC206E55.quest_desc: ["Você pode encontrar essas abelhas nas Florestas Carmesins. O seu ninho também pode ser obtido ao cultivar Fungos Carmesins, com uma chance de 2%."]
	quest.176ACC61DC206E55.quest_subtitle: "Alimente uma Abelha de Cogumelo com um Fungo Carmesim"
	quest.176ACC61DC206E55.title: "&fAbelha de Cogumelo Carmesim"
	quest.177199FED92C3B5B.quest_subtitle: "Alimente uma Abelha de Diamante com um Diamante Infundido"
	quest.177199FED92C3B5B.title: "&fAbelha Dimensional"
	quest.177396B9C4F9B3E2.quest_desc: ["Por que esperar? Ah, você tem razões válidas para esperar? Como itens que podem desaparecer. Huh, não estava pensando nisso. \\n\\nCom o Pickup Delay Augment, o Vacuum Module esperará 10 ticks com cada Augment nele para coletar itens dropados!"]
	quest.17920C436DDBBD07.title: "&2Parte de Armazenamento de Fluido de 262kB"
	quest.1796E08BBDC09B84.quest_desc: ["&b&lTanques &cDinâmicos&r são Multiblocos que podem ser feitos em qualquer tamanho, desde que seja pelo menos 3x3x3! \\\\n\\\\n&b&lTanques &cDinâmicos&r armazenam uma grande quantidade de um único &bFluido &fou &cQuímico&r. Quantos Baldes desse &bFluido &fou &cQuímico&r o &c&lTanque&r pode conter? Isso depende do tamanho. \\\\n\\\\n&b&lTanques &cDinâmicos&r são feitos com &bBlocos de &cTanque &fDinâmico&r, com o interior da estrutura sendo oco. As Paredes podem ser feitas com Vidro de Estrutura ou Vidro de Reator, mas a armação precisará ser feita com Blocos de &bTanque &cDinâmico&r. \\\\n\\\\nVocê também precisará de Portas de &bTanque &cDinâmico&r nas Paredes para realmente inserir e extrair Fluidos e Químicos. Se elas inserem ou extraem depende se estão configuradas para Empurrar ou Puxar. "]
	quest.1796E08BBDC09B84.quest_subtitle: "Cabe mais que o oceano!"
	quest.1796E08BBDC09B84.title: "&cTanques &b&lDinâmicos &rMultiblocos"
	quest.17989643018D00C1.quest_desc: ["As Colmeias te irritam quando gotejam? Se sim, você está com sorte, porque há uma solução fácil.\\n\\nVocê pode colocar uma &eEsponja&r no slot de Garrafa de uma Colmeia Avançada para impedi-la de gotejar."]
	quest.17989643018D00C1.quest_subtitle: "Você não tem Estilo"
	quest.17989643018D00C1.title: "&fImpedindo o Gotejamento"
	quest.179C2D15E2E93CB6.quest_desc: ["Meio que parece que tem dois olhos... \\n\\nDois olhos furiosos..."]
	quest.179C2D15E2E93CB6.title: "&bTampa da Grande Bola de Fogo"
	quest.17A322C3B309A4D4.quest_subtitle: "Parece que as Abelhas de Ouro gostam de Discos de Música"
	quest.17A322C3B309A4D4.title: "Abelha de Regalium"
	quest.17A68C4E9E9EA2B7.quest_desc: ["A &eArmadura de Ouro&r está entre a de Ferro e a de &7Couro&r. Mas sua Durabilidade é muito mais próxima da de &7Couro&r. \\n\\nNão há muito uso para ela, além de fazer com que os Piglins fiquem neutros em relação a você quando estiver usando alguma &eArmadura de Ouro&r."]
	quest.17A68C4E9E9EA2B7.quest_subtitle: "11"
	quest.17A68C4E9E9EA2B7.title: "&eArmadura de Ouro"
	quest.17A9D2CA160561D9.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Fornece assistência de passo ao jogador."
	]
	quest.17B18040EFA37F86.quest_subtitle: "Alimente uma Abelha Radioativa com uma Pastilha de Polônio"
	quest.17B18040EFA37F86.title: "&fAbelha Radioativa Contaminada"
	quest.17C2C8F64B4AE6EE.quest_desc: [
		"&2Habitantes&r são as Vacas do &2&lUndergarden&r. \\nEles são Passivos e droparão Couro e Carne de Habitante na morte. \\n\\nGraças a Deus eles não podem ser ordenhados, não quero nenhum leite que esses &2Habitantes&r fazem."
		"{image:atm:textures/questpics/undergarden/undergarden_dweller.png width:100 height:100 align:center}"
	]
	quest.17C2C8F64B4AE6EE.title: "&2Habitante&r"
	quest.17C4F6EC1AFBC3AA.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		"Destaca mobs próximos com partículas quando ativado."
	]
	quest.17CA9D80D8EC3EF7.quest_desc: [
		"&4&lO Arauto&r se inspira muito no que o fortalece, a Estrela do Nether. \\n\\nEle tem 4,680 &4Corações&r e atacará todos os Mobs e Jogadores que vir que não aparecem na &4Fábrica Ancestral&r. \\n\\nEle voará por aí e até mesmo investirá contra você. Como &0O Wither&r, &l&4O Arauto&r quebrará quase todos os Blocos em seu caminho. \\n\\nPara atacar, ele pode atirar &4Mísseis Wither&r em você, que podem lhe dar &0Efeito Wither&r, ou atirar &4Howitzers Wither&r de suas costas, que dispararão em todas as direções. \\n\\nEle também tem &4Lasers&r que pode atirar em você, &4Gatlings de Laser&r e um &4grande raio da boca&r. \\n\\nEle tem uma grande fraqueza, como as outras máquinas vivas, ele é fraco aos &4EMPs&r! Se você usá-los nele, ele ficará atordoado, incapaz de se mover ou lutar por alguns segundos."
		"{image:atm:textures/questpics/cataclysm/cataclysm_harbinger.png width:100 height:100 align:center}"
	]
	quest.17CA9D80D8EC3EF7.title: "&4&lO Arauto&r"
	quest.17CADE883895E1C4.quest_desc: [
		"Aumento de nível para 46."
		""
		"Pode ser encontrado aleatoriamente em &9Ginásios&r que geram em &a#minecraft:village&r"
	]
	quest.17CADE883895E1C4.title: "&aLíder Erika"
	quest.17D7D34F519F7E5F.quest_desc: ["Para criar o último tier do seu Livro de Feitiços, você precisará ter matado a &6Quimera Wilden&r. \\n\\nEste é um Ritual que você precisará completar usando um &9Braseiro Ritualístico&r."]
	quest.17D82EEA20D02EC8.quest_desc: ["Forrando o fundo do mar está o Cascalho Empoeirado. \\n\\nEle pode ser usado como um substituto para o Cascalho normal e pode raramente dropar Cacos Empoeirados que podem fazer outros Blocos!"]
	quest.17DC77F7F8C68AE6.quest_desc: ["Lixeiras agem como uma forma de destruir itens, líquidos e energia indesejados."]
	quest.17DC77F7F8C68AE6.quest_subtitle: "Livrando-se do Excesso"
	quest.17DC77F7F8C68AE6.title: "Lixeiras"
	quest.17E2C05C48B03043.quest_desc: ["O Sódio pode ser usado como um &bFluido de Arrefecimento&r em vez de &9Água&r. O Sódio é mais Eficiente, atinge &6Temperaturas&r mais altas, mas é mais difícil de obter e reutilizar. \\n\\nAgora, como o obtemos? \\n\\nPrecisaremos de uma &6&lPlanta de Evaporação Térmica&r. Eu já fiz umas 3 Missões explicando como Construir e usá-las, esta não será a 4ª. \\n\\nUsaremos a &6&lPlanta de Evaporação Térmica&r para pegar nossa &9Água&r e transformá-la em &eSalmoura&r. \\n\\nEntão, podemos usar um &9&lSeparador Eletrolítico&r para decompor essa &eSalmoura&r para obter nosso Sódio! \\n\\nE outra &csubstância química&r, mas não nos importamos com ela!"]
	quest.17E2C05C48B03043.title: "&bFluido de Arrefecimento &bde Sódio"
	quest.17EC65B33AC5F0B4.quest_desc: [
		"Andarilhos da Sede são Mobs neutros que aparecem na superfície dos Desertos Cristalizados. \\n\\nQuando provocados, eles te baterão e te darão Fome. \\n\\nEles têm 20 Corações e podem dropar Dente da Fome na morte."
		"{image:atm:textures/questpics/eternal/starlight_thirst.png width:100 height:125 align:center}"
	]
	quest.17EC65B33AC5F0B4.title: "Andarilho da Sede"
	quest.17F3AC15ADCFB175.title: "&l&9Recompensa do End:&r&e Enderman"
	quest.17F7964611D893BE.quest_desc: ["O Carregador de Fluido será útil para manter suas &3Locomotivas a Vapor&r funcionando. Ele deve ser colocado alguns blocos acima dos &6Trilhos&r e irá descarregar fluidos na &5Locomotiva&r ou nos &7Carrinhos&r."]
	quest.17F7964611D893BE.title: "Carregador de Fluido"
	quest.17FE0C7748DD65CA.quest_desc: ["O &5Tier 4&r é o nível de ferramenta de Diamante, usado para obter Obsidiana e Netherita. Também alguns minérios de mods como Urânio e Platina."]
	quest.17FE0C7748DD65CA.title: "&5Tier de Coleta 4"
	quest.17FFBED5CC92ACF0.quest_desc: ["Usando um &6Implantador&r, podemos empurrar os &8Carimbos de Borracha&r em algumas &7Pepitas&r para carimbá-las! \\n\\nIsso será necessário para fazer os &7Mecanismos&r. \\n\\nA &5Chapa Robusta&r é feita processando &5Pó de Obsidiana&r primeiro despejando &cLava&r sobre ele e depois prensando-o, duas vezes!"]
	quest.17FFBED5CC92ACF0.title: "&7Pepitas Carimbadas"
	quest.18032636A60D0B2C.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		""
		"Uma versão atualizada do Scanner de Minério que renderiza minérios próximos quando ativado."
	]
	quest.180D7DB1038D3C03.quest_desc: ["Arqueologia ainda é importante, mesmo no &c&lAll&7The&fMons&r. \\n\\nFabrique um Pincel com um Graveto, Pena e &6Lingote de Cobre&r! \\n\\nCom o Pincel você pode Segurar o Clique Direito com ele em um Item para Pincelar o Item. Quando feito em certos Blocos Suspeitos, Itens sairão."]
	quest.180D7DB1038D3C03.title: "Arqueologia"
	quest.1815661333016983.quest_subtitle: "Date Palm + Black Cherry"
	quest.1815A439BA9879B7.quest_desc: [
		"A Costa Quente é um Bioma bem chato e serve principalmente para conectar o Mar Estrelado e a terra. \\n\\nTem Areia do Crepúsculo com Pedra por baixo. Eu também encontrei, mais do que o normal, Salitre aqui."
		"{image:atm:textures/questpics/eternal/starlight_shore.png width:200 height:100 align:center}"
	]
	quest.1815A439BA9879B7.title: "Costa Quente"
	quest.1823CC81D613892B.quest_desc: ["A Fábrica de Abate de Mobs &ldeleta&r mobs em sua área de trabalho e converte esse mob em &#FF69B4Slime Rosa&r e &6Carne Líquida&r.\\n\\nMobs Passivos -> Mais &#FF69B4Slime Rosa&r\\nMobs Hostis -> Mais &6Carne&r\\n\\nEsta máquina suporta Adicionais de Alcance."]
	quest.18246A48C20B29D8.quest_desc: ["O Pilão de Infusão funciona de forma semelhante a um Sinalizador, porém muito melhor e mais barato! \\nQuando um Efeito de Poção é inserido através de um Filtro de Poção, ele fornecerá continuamente o Efeito de Poção enquanto você estiver na área da Chunk definida."]
	quest.1827DEEA2DF1B144.quest_desc: ["Bem-vindo ao capítulo de Food and Farming!\\n\\nAqui, você encontrará diferentes maneiras de cultivar e fazer comida!"]
	quest.1827DEEA2DF1B144.title: "Food and Farming"
	quest.1830412AB77E9526.quest_desc: ["Com algo tão primitivo como um Arco, você не pode esperar uma precisão perfeita. Bem, você pode se usar esses Módulos. A Flecha tem muito mais probabilidade de atingir seu alvo e não desviar do curso."]
	quest.1830412AB77E9526.title: "Módulo de Precisão de Projétil Wyvern"
	quest.1831B35A3239B583.quest_subtitle: "Fazendo múltiplas receitas de uma vez"
	quest.1834B5C1F8435D7A.quest_desc: [
		"Mechanical Pipes são como o &5&lMeka&r permite que os Fluidos fluam.\\n\\nAlgumas Máquinas no &5&lMeka&r precisarão de Fluidos, como o Separador Eletrolítico precisando de Água ou as Evaporation Plants para fazer Lítio."
		"{image:atm:textures/questpics/logistics/meka_pipe.png width:200 height:50 align:center}"
	]
	quest.1834B5C1F8435D7A.quest_subtitle: "Fluidos"
	quest.183E4F5F940CBDEA.quest_desc: ["Também não aumentará seu Limite de Nível. \\n\\nSeu Item é uma &6Lente de Zoom&r."]
	quest.183E4F5F940CBDEA.title: "&7Comandante Saturn"
	quest.183F6A790EC006B8.quest_desc: ["Os &bCaules Floridos&r não são como Árvores, são mais como se o Chorus e o Bambu tivessem um bebê. \\n\\nEles aparecem dentro das &bCavernas Floridas&r e precisam de outros &bCaules Floridos&r para se manterem de pé! Esta é a única maneira de encontrá-los. \\n\\nVocê ainda pode Descascá-los ou fazer Tábuas com eles. As Tábuas têm uma &bcor Azul Clara&r, e tudo o que você fizer com elas também terá!"]
	quest.183F6A790EC006B8.title: "&bMadeira Florida"
	quest.1843C79133DFB024.quest_desc: ["O Gerador mais poderoso e eficiente, o Gerador de Estrela do Nether. Adivinhe o que ele usa para gerar Energia!"]
	quest.1848F431D0380DA9.quest_desc: [
		"Semelhante à função de reparo com Giz da &aLigação Superior de Strigeor&r, o &cConfinamento Permanente de Sevira&r pode ser usado para reparar itens usando o poder de um Demônio Afrit."
		""
		"Este ritual pode reparar praticamente qualquer coisa, então &eMineradores Demônios&r, ferramentas e armaduras podem ser restaurados à sua durabilidade original!"
		""
		"Todos os itens reparados com este ritual mantêm suas propriedades originais (afixos, encantamentos, etc), então não se preocupe com seus preciosos encantamentos!"
	]
	quest.1848F431D0380DA9.quest_subtitle: "Durabilidade grátis (ou quase)!"
	quest.1848F431D0380DA9.title: "Reparando Itens"
	quest.18499D33BA12A8A9.quest_desc: ["Sempre achou que os Planos de Formação agindo como uma Ponta de Armazenamento era muito pouco intuitivo para automação? Não procure mais, o Plano de Formação Ativo. Ele funciona como uma Ponta de Exportação ME, mas trata o mundo como seu meio. Você não precisa de uma sub-rede para este."]
	quest.18499D33BA12A8A9.quest_subtitle: "SAIA: Edição Ativa"
	quest.18499D33BA12A8A9.title: "Colocando Ativamente da Rede: O Plano de Formação Ativo"
	quest.184F98BE0F6710E2.quest_desc: ["Estes 2 &cKits de Trilho&r são para usar &7Carrinhos&r e Redstone.\\n\\nO &cKit Ativador&r ativará qualquer &7Carrinho&r que passar sobre ele. \\nO &cKit Detector&r ativará um sinal de redstone sempre que um &7Carrinho&r passar sobre ele. \\n\\nAmbos são semelhantes aos seus equivalentes &2Vanilla&r para &6trilhos&r regulares."]
	quest.184F98BE0F6710E2.title: "&cKits de Trilho&r para usar Redstone"
	quest.185074907753AE77.quest_desc: ["Se você está usando Roteadores, espero que tenha algum conhecimento do jogo. \\n\\nSó para garantir, anular um Item significa excluí-lo. \\n\\nQuaisquer itens que entrarem no Roteador serão excluídos para sempre! \\n\\nRecomendo usar Filtros com este..."]
	quest.185DBBDD252CBA0C.quest_desc: [
		"A &6&lForja&r é o Bloco mais importante em &6&lForbidden \\& Arcanus&r! Agora que você fez o Multibloco, pode quebrar o bloco da &6&lForja&r e movê-lo, embora ele só funcione enquanto estiver no Multibloco. \\n\\nVocê precisará preenchê-lo com todas as 4 Essências: &bAureal&r, Almas, &4Sangue&r e &aExperiência&r! \\n\\nEntão, coloque Relíquias se necessário. \\n\\nDepois disso, coloque o Item central da Receita no Slot do meio da &6&lForja&r, e os Itens externos nos &6Pedestais&r."
		"{image:atm:textures/questpics/forbidden/forbidden_gui.png width:135 height:100 align:center}"
		"{image:atm:textures/questpics/forbidden/forbidden_tier3.png width:100 height:100 align:center}"
	]
	quest.185DBBDD252CBA0C.title: "&6Forja &l&cTier 1"
	quest.18601369F049D10D.quest_subtitle: "Ébano do Ceilão + Murta-de-crepe Roxa"
	quest.186593EBCE3FE8D8.quest_desc: [
		"O &9Alcance de Nascimento&r é a área onde os mobs podem aparecer.\\n "
		"Quanto maior a área, mais espaço eles terão para nascer. Quanto menor a área, mais barata será a fábrica."
	]
	quest.186593EBCE3FE8D8.title: "Raio de Spawn"
	quest.186731580B14F9D2.quest_desc: ["Para interagir com nossa Turbina, precisaremos de várias &6Portas&r.\\n\\nA &9Porta de Fluido&r é usada para inserir vapores como &bVapor&r, ou extrair exaustão, como &9água&r. Por causa disso, você precisará de duas para sua Turbina.\\n\\nA &cTomada de Energia&r extrai energia e é necessária para completar o multibloco."]
	quest.186731580B14F9D2.title: "Portas da Turbina"
	quest.1873205CF5247E3E.quest_desc: [
		"A última e maior das &7Estantes&r, as &dEstantes do End&r! \\n\\nElas são criadas com 6 &eTijolos de Endstone&r, 1 &3Pérola do End&r, 1 &7Estante de Livros&r e, claro, o &dBafo de Dragão Infundido&r. \\n\\nSeus status não são os melhores atualmente, dando apenas 5 para cada. Mas seu máximo de &aEterna&r de &a90&r é incrível! \\n\\nAh, sim, e elas podem ser Criadas com outros Itens para atualizá-las!"
		"{image:atm:textures/questpics/apothic/enchant_endshelf.png width:100 height:100 align:center}"
	]
	quest.1873205CF5247E3E.title: "&dEstantes do End"
	quest.187816477B732517.quest_desc: ["O &3Dispositivo de Transferência&r age como um Funil que pode ser colocado entre blocos."]
	quest.187816477B732517.quest_subtitle: "Funil Menor"
	quest.18783C62009934DB.quest_desc: ["O &9&lSeparador Eletrolítico&r pega 1 &bFluido&r e o divide em 2 &cSubstâncias Químicas&r! \\n\\nO &bFluido&r entrará na &4Barra Vermelha&r e as &cSubstâncias Químicas&r aparecerão nas &9Barras &fAzul &fe &3Ciano&r. \\n\\nNós também temos dois Botões em cada um dos cantos inferiores da GUI. Eles alternam entre as funções das duas Barras de Saída. \\n\\nOcioso apenas atingirá o limite que pode e não aceitará mais nada. Então, se estiver cheio de Hidrogênio, não usará mais &9Água&r. \\n\\nDespejando Excesso chegará ao topo, mas despejará o suficiente para continuar produzindo cada &cSubstância Química&r. Isso é útil para quem precisa de muito &bOxigênio&r, mas não de Hidrogênio. \\n\\nDespejando irá deletar toda a &cSubstância Química&r que for produzida."]
	quest.18783C62009934DB.title: "&9&lSeparador Eletrolítico"
	quest.189018F641FBB44E.quest_desc: ["O &4Auto-fabricador Mega&r tem 54 espaços para Padrões, funciona 8x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.189018F641FBB44E.title: "&4Auto-fabricador Mega"
	quest.18914FDF9CF9EEA8.quest_desc: ["Os &aRolamentos de Relógio&r se moverão com base na Hora do Dia quando recebem &dEnergia Rotacional&r. \\n\\nO Bloco na frente do &aRolamento de Relógio&r será automaticamente &aColado&r a ele, mas outros Blocos podem ser &aColados&r àquele Bloco para se juntarem a ele! \\n\\nSe você quiser mais Ponteiros para o seu &aRelógio&r, adicione mais Blocos na frente do primeiro Bloco, mas certifique-se de que eles não estão &aColados&r juntos. \\n\\nVocê pode mudar qual Ponteiro é qual Segurando no &aRolamento&r para mudar se o primeiro Ponteiro (Bloco mais próximo) é o Ponteiro das Horas ou dos Minutos."]
	quest.18914FDF9CF9EEA8.title: "Rolamento de &aRelógio"
	quest.18A2F6BA778D96B1.quest_desc: ["Estes podem ser encontrados em baús dentro de Bastiões."]
	quest.18A2F6BA778D96B1.quest_subtitle: "Baús de Bastião"
	quest.18A2FBE2D4133FA2.quest_desc: ["Pedestais Arcanos são necessários para o Braseiro Ritualístico e para criar itens com um Aparato de Encantamento. \\n\\nFaça 8 deles!"]
	quest.18A2FBE2D4133FA2.quest_subtitle: "Mesas Chiques"
	quest.18A2FBE2D4133FA2.title: "Pedestais Arcanos"
	quest.18A9392BBCF5A871.quest_desc: ["Como todo Mod de Máquina, o &8&lImmersive Engineering&r precisa de uma maneira de mover &eItens&r, &bFluidos&r e mais! \\n\\nA maioria das Máquinas terá &6Saídas&r e &9Entradas&r definidas por padrão, mas estas podem ser configuradas, como com a &6Chave de Fenda do Engenheiro&r! Você também pode precisar usar um &6Martelo de Engenheiro&r, mas isso é diferente."]
	quest.18A9392BBCF5A871.title: "Logística do &8&lImmersive Engineering&r"
	quest.18C0EF38430C3E67.quest_subtitle: "A Era Digital"
	quest.18D4BE3AF7869DE2.quest_subtitle: "Ceylon Ebony + Persimmon"
	quest.18DB8C875F2331B2.quest_desc: [" Escondido dentro das &6masmorras misteriosas&r do &eEnd&r, o &dCinto Cinético&r aguarda aqueles dispostos a dominar o próprio movimento. \\n\\nEsta &6relíquia&r quebra as regras da física, respondendo não ao peso, mas ao movimento. Nas mãos certas, até o ar se torna algo que você pode &acontrolar&r. \\n\\n- &lPossui 2 habilidades:&r \\n\\n 1. &5Expansão de Arsenal&r: \\nAumenta o &6número máximo&r de amuletos que você pode &aequipar&r, permitindo combinações maiores de &cpoder&r. \\n\\n 2. &bPlanar&r: \\nAo segurar a &6tecla de pulo&r, você reduz a &9gravidade&r e a &9resistência do ar&r, permitindo que você plane pelo ar com maior impulso. O &edano de queda&r é &ereduzido&r ao planar, embora descidas mais rápidas o tornem menos eficaz. \\n\\n- &9Sinergia&r: &l&eArco Elétrico&r&r \\n\\nQuando o &dCinto Cinético&r é usado junto com o &9Colar de Água-viva&r, suas energias se combinam em algo muito mais &cperigoso&r. \\n\\nAo planar por uma &a&ocurta duração&r&r, o portador começa a deixar para trás um rastro de &ecorrentes elétricas&r que causam &cdano&r a qualquer alvo que entrar em contato com elas. \\n\\n&6Condições&r: \\n- &dCinto Cinético&r\\n- &9Colar de Água-viva&r \\n\\n- Uma &6relíquia&r para aqueles que se recusam a &fcaminhar&r... quando podem &bplanar&r pelo &7ar&r."]
	quest.18DB8C875F2331B2.quest_subtitle: "Nem todas as relíquias foram feitas para te manter no chão..."
	quest.18DB8C875F2331B2.title: "&dCinto Cinético&r"
	quest.18DFB25DC48D8BF7.quest_desc: [
		"A Estrutura de Contenção Espacial (&6ECE&r) consiste em uma gaiola de &bPilares Espaciais&f cobrindo o volume que você deseja encerrar em uma célula de Espacial E/S. No mínimo absoluto, uma ECE requer três linhas de blocos de pilar espacial, uma para cada dimensão do espaço sendo contido (comprimento, largura, altura)."
		""
		"No entanto, a &bEspacial E/S&r é um recurso extremamente faminto por energia, especialmente ao tentar capturar espaços muito maiores (até &6128x128x128&r). Ter mais pilares espaciais incluídos na &6ECE&r ao redor do volume desejado aumentará sua &eeficiência&f geral, permitindo que use menos energia para capturar."
		""
		"Além disso, esteja ciente de que cada pilar individual (independentemente de seu comprimento) ocupa um canal. Para espaços particularmente grandes, você pode querer construir uma rede dedicada com um controlador para acomodar todos os pilares necessários."
	]
	quest.18DFB25DC48D8BF7.title: "&6Pilão Espacial"
	quest.18E0F5A78F696FA3.quest_desc: ["&3Fragmentos de Eco&r concedem um efeito especial aos &3Spawners&r. Qualquer mob gerado por um &3Spawner&r afetado deixará mais itens ao ser derrotado, multiplicando a quantidade de saque dropada."]
	quest.18E0F5A78F696FA3.title: "&#11767DEcoante"
	quest.18EADBAFC932F864.quest_desc: ["Para tosquiar Ovelhas você precisa de Tesouras, você não conseguiria Lã de outra forma... certo?"]
	quest.18EADBAFC932F864.quest_subtitle: "Modo Pacifista"
	quest.18EADBAFC932F864.title: "É Hora de Tosquiar"
	quest.18EB2170CAC48E99.quest_desc: ["A &5Unidade de Teletransporte&r é uma &7Unidade&r bem única. \\n\\nCom nossa &dMeka-Tool&r com &5Teletransporte&r adicionado, podemos olhar para um Bloco e Clicar com o Botão Direito para nos Teletransportar até ele. \\n\\nEla usa &aEnergia&r e tem um alcance limitado, mas não se preocupe, o alcance ainda é bem grande! \\n\\nEsta &7Unidade&r não pode funcionar com a &2Unidade de Agricultura&r ou a &7Unidade de Tosquia&r."]
	quest.18EB2170CAC48E99.quest_subtitle: "SUMIU!"
	quest.18EB2170CAC48E99.title: "&5Unidade de Teleporte"
	quest.18EB86F91CBBCCC6.quest_desc: ["Nem todas as Masmorras do Cataclysm são tão fáceis de encontrar quanto as &ePirâmides Amaldiçoadas&r. \\n\\nEntão, um Olho específico pode ajudá-lo a encontrá-las! \\n\\nCada um dos diferentes Olhos o levará à sua estrutura definida; e não se preocupe, os Olhos raramente quebram."]
	quest.18EB86F91CBBCCC6.title: "Eu vejo você!"
	quest.18F948FF9FE015FB.quest_subtitle: "Dê TNT a uma Abelha Vanilla"
	quest.18F948FF9FE015FB.title: "&fAbelha Creeper"
	quest.18FAD56CDE05646A.quest_desc: ["Antes as Pedreiras na &7&lDimensão de Mineração&r costumavam minerar tudo, menos o &6Minério de Allthemodium&r. \\n\\nAgora ela Minera &6Allthemodium&r, mas Anula os drops... talvez queira ter cuidado com suas Pedreiras agora! \\n\\nRecomendo Minerar com Poções de Visão de Minério se você estiver procurando estritamente por &6Allthemodium&r!"]
	quest.191A7F3C9FBA4C13.quest_desc: ["Podemos Criar &bEstantes Marinhas Infundidas&r com &bCristais de Prismarinho&r para obter &bEstantes Marinhas Cristalinas&r. \\n\\nA &bEstante Marinha Cristalina&r manterá os mesmos &a5 Eterna&r, &55% Arcana&r, e agora terá &c3% Quanta&r. \\n\\nCom 12 delas, podemos obter Níveis suficientes para &d&lInfundir&r &9Estantes das Profundezas Dormentes&r em &9Estantes das Profundezas&r normais!"]
	quest.191A7F3C9FBA4C13.title: "Estante Marinha &bCristalina"
	quest.1922623A26E08078.quest_desc: ["Como &bTanques de Fluido&r, mas dane-se os &bFluidos&r, queremos todo o resto! \\n\\nTudo que os &cTubos Pressurizados&r podem mover, o &cTanque Químico&r pode conter. \\n\\n&a&lBásico&r: conterá 64 Baldes de Produtos Químicos. \\n\\n&c&lAvançado&r: conterá 256 Baldes de Produtos Químicos. \\n\\n&b&lElite&r: conterá 1.024 Baldes de Produtos Químicos. \\n\\n&d&lSupremo&r: conterá 8.192 Baldes de Produtos Químicos."]
	quest.1922623A26E08078.quest_subtitle: "Sabe o que é melhor que água? Ácido!"
	quest.1922623A26E08078.title: "&cTanques Produtos Químicos"
	quest.19341B01E048ACAB.quest_desc: ["O &a&lTier Básico&r é o mais simples, mais barato e pior &lTier&r de &5Máquinas&r e Blocos! \\n\\nBem, a menos que você conte as &5Máquinas&r Padrão como um &lTier&r totalmente novo, mas eu não conto. Eu apenas o conto com o &a&lBásico&r. \\n\\nAs &5Máquinas&r começarão no padrão e podem ser Atualizadas para &a&lBásico&r. Enquanto outros Blocos como &bTubos&f ou &aCubos de Energia&r começarão no &a&lBásico&r. \\n\\nTodos estes são feitos de &4Redstone&f, &aCircuitos de Controle Básicos&f, e às vezes &7Ferro&r!"]
	quest.19341B01E048ACAB.title: "&a&lTier Básico"
	quest.194DA601C17C50D5.quest_desc: ["&nForte&r \\n\\n&dFada&r \\n&2Grama&r \\n\\n&nVulnerável&r \\n\\n&6Terra&r \\n&dPsíquico&r"]
	quest.194DA601C17C50D5.title: "&5Veneno"
	quest.195729280394ABFB.quest_desc: ["A &7&lMáquina&r cria duas Barras muito fortes: &ePedra Luminosa Refinada&f e &5Obsidiana Refinada&r.\\n\\nEla &7Infunde&r um &eItem&r com &7Ósmio&r para criar um Barra mais poderoso. \\n\\nPrecisaremos colocar &7Osmium Ingots&f, &7Osmium Blocks&f, ou um &cTanque Químico&f com &7Produto Químico de Ósmio&r para alimentar o &l&7Compressor&r com &7Ósmio&r!"]
	quest.195729280394ABFB.quest_subtitle: "Realmente Só é Bom Para 2 Coisas"
	quest.195729280394ABFB.title: "Compressor de &7&lÓsmio"
	quest.196003E1486ABB31.quest_desc: ["Para aprimorar de &cNetherita&r para &9Equipamento do Warden&r, você precisará de um &9Molde de Ferraria&r! \\n\\nEles são encontrados em Baús nas &6Cidades Ancestrais&r. \\n\\nEles podem ser duplicados com 7 Diamantes e um &3Bloco de Sculk&r!"]
	quest.196003E1486ABB31.title: "&9Molde de Ferraria do Warden"
	quest.196312DF0D2E2CB6.quest_desc: ["&4Invasores&r são o que conhecemos como &4Chefes&r do &6&lApotheosis&r. \\n\\nSão Mobs que podem aparecer em qualquer Dimensão e eles sempre estarão fortalecidos e equipados com &eItens com Afixos&r. \\n\\nA maioria terá mais Corações, Dano e Efeitos do que os Mobs normais! Quando Mortos, eles droparão &eItens com Afixos&f e &aGemas&r. \\n\\nEles têm suas próprias Raridades alinhadas com as Raridades do &6&lApotheosis&r. Suas Raridades determinam com o que eles aparecem e seus atributos. \\n\\nSuas Raridades são determinadas pelo &lNível de Mundo&r! &lNíveis de Mundo&r são novas adições ao &6&lApotheosis&r, eles mudarão a Raridade dos Saques e &4Chefes&r que você pode encontrar. \\n\\nPara acessar o menu de &lNível de Mundo&r, Segure CTRL e pressione T."]
	quest.196312DF0D2E2CB6.title: "&4Invasores/Chefes&r e &lNíveis de Mundo"
	quest.196E55B64667AE35.quest_desc: [
		"Você pode colocar Flores em Lajes de Alimentação e determinados itens para a alimentação de cada tipo de Abelha, são colocadas na frente das Colmeias. "
		""
		"Como demonstrado na imagem abaixo.\\n"
		""
		"{image:atm:textures/questpics/bees/feeder.png width:175 height:100 align:center fit:true}"
	]
	quest.196E55B64667AE35.quest_subtitle: "Colocando uma Laje"
	quest.196E55B64667AE35.title: "&fLaje de Alimentação"
	quest.1972B36F72808D55.quest_desc: ["Apenas algumas dessas pedras estão lascadas."]
	quest.1972B36F72808D55.title: "&fPedra &l&bChipped"
	quest.1985CFD1F0425E88.quest_subtitle: "Mais Opções de Filtragem"
	quest.1985CFD1F0425E88.title: "&eMelhoria Avançada de Coleta"
	quest.198E9E90CC9606C4.quest_desc: ["Temos nossos Itens em Pedestais, temos nosso &bAureal&r, Almas, &4Sangue&r e &aExperiência&r... e não está terminando? Por que não está terminando? \\n\\nPara finalizar o Ritual, precisaremos usar um Martelo! \\n\\nEle funciona como uma Picareta, mas também tem um número limitado de usos para finalizar Rituais, basta Clicar com o Botão Direito na &6&lForja&r com ele!"]
	quest.198E9E90CC9606C4.title: "&eFinalizando o Ritual"
	quest.198EDBAC1D6E2339.quest_desc: ["Você precisará destes para as Abelhas do End."]
	quest.198EDBAC1D6E2339.quest_subtitle: "Impede que as Abelhas se Teleportem em uma Colmeia"
	quest.198EDBAC1D6E2339.title: "&fMelhoria de &6Anti-Teletransporte"
	quest.199388A311FAC14C.quest_desc: [
		"Melhorias Válidas:"
		"- Minerador de Minério"
		"- Scanner de Minério &4&lDESATIVADO&r&f"
		"- Forno Automático"
		"- Martelo"
		""
		"Habilidade Intrínseca:"
		"- Reparo com Lava"
	]
	quest.199932BF623A6785.quest_desc: ["O Guardião Esquecido é o Chefe do Undergarden. \\n\\nEle descansa na Estrutura da Catacumba."]
	quest.199932BF623A6785.title: "&fMate o &2Guardião Esquecido"
	quest.19A2016B54C6FA34.quest_desc: ["Algumas Máquinas em &l&6Theurgy&r precisam de Calor para começar! Exceto que &l&6Theurgy&r é muito ciumento com a forma como suas Máquinas obtêm Calor, você só pode usar estas duas Máquinas como fontes de Calor. \\n\\n(As Máquinas que usam Calor são: Caldeirão de Liquefação, Forno de Calcinação, Destilador de &cMercúrio&r e Incubadora.)"]
	quest.19A2016B54C6FA34.quest_subtitle: "Nossa, que calor!"
	quest.19A2016B54C6FA34.title: "Nossa, como você está Quente!"
	quest.19AAC139177442C1.quest_subtitle: "Tier: &63"
	quest.19B393433FB0C62F.quest_desc: ["O segredo do Strider para andar na &cLava&r está em suas Pernas. Então, tiramos suas Pernas e fizemos você usá-las! \\n\\nAo Agachar, você pode andar com segurança sobre a &cLava&r! Quando você parar de Agachar, você cairá na &cLava&r, no entanto. Elas também permitem que você ande com segurança sobre blocos de Magma e outros blocos quentes!"]
	quest.19B393433FB0C62F.quest_subtitle: "Pés"
	quest.19B393433FB0C62F.title: "Sapatos de &4Strider&r"
	quest.19B6649B049A402A.quest_desc: ["&6Allthemodium&r, &3Vibranium&r, e &5Unobtainium&r. Os três metais &6AllTheModium&r. \\n\\nEspero que você tenha passado pelo capítulo de missões deles antes de usar estas missões... \\n\\nPara fazer as &cPoke&rBolas, precisaremos de bastante desses Lingotes. Sim, é caro. \\n\\nPara os &7Mecanismos&r, você precisará transformar alguns desses Lingotes em Chapas para..."]
	quest.19B6649B049A402A.title: "Metais &6&lAllthemodium&r"
	quest.19C22C5B247F4D7D.quest_subtitle: "Ébano do Ceilão + Mafumeira"
	quest.19D02325579F2AA8.quest_desc: ["O Elo de Fonte Vulcânico gera Fonte consumindo itens combustíveis. Troncos de Arcomadeira gerarão Fonte bônus. \\n\\nÀ medida que queima itens, ele converterá pedra próxima em lava. \\n\\nIsso também gera Lírios de Lava."]
	quest.19DB78FD215E07A7.quest_desc: ["Armazenar &eItens&r é importante. Por favor, não os deixe apenas no chão! \\n\\nEm vez disso, coloque &eItens &fem &eBaús&r! Não tem espaço suficiente? Faça &lIron Chests&r ou &eDrawers&r! \\n\\nPrefere ter todos os seus &eItens&r acessíveis em uma única Rede de Armazenamento? Use &b&lAE2&r! \\n\\nSe precisar de &eItens&r em movimento, não procure por &dShulkers&r. Em vez disso, use &eMochilas&r ou &l&7Pocket Storage&r."]
	quest.19DB78FD215E07A7.title: "&eArmazenamento de Itens"
	quest.19DE6EBEA8219E8E.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, está no modo de edição."]
	quest.19DFAEB6D88F3580.quest_desc: ["A Melhoria de Empurrar permite que as Gavetas empurrem itens para qualquer lado."]
	quest.19E356E67EF17E4A.quest_desc: ["Apenas a melhor Ferramenta da história! Como um canivete suíço, mas melhor! \\n\\nMaior Tier de Mineração, derruba Árvores como manteiga, faz caminhos e, claro, bate muito para ser atingido!"]
	quest.19E356E67EF17E4A.title: "&6Paxel de &5Liga de &3Allthemodium"
	quest.19E6757F04098A0C.quest_desc: [
		"Melhorias Válidas:"
		"- Cortador de Grama"
		"- Varredor do Céu"
	]
	quest.19E678E6EF9539DC.quest_desc: ["Apenas um sensor simples que emite um sinal de redstone e tem um slot de filtro."]
	quest.19F58E291A543228.quest_desc: ["Versão de &eOuro&r das Armaduras do &d&lArs&r!"]
	quest.19F58E291A543228.quest_subtitle: "11"
	quest.19F58E291A543228.title: "Traje de &5Feiticeiro"
	quest.19FFD64154AFC89D.quest_subtitle: "Tier: &b4"
	quest.1A05C605A52A4218.quest_desc: ["&5Unobtainium&r combinado com &6Allthemodium&r!"]
	quest.1A05C605A52A4218.title: "Barra de Liga de &5Unobtainium&r - &6Allthemodium&r"
	quest.1A0672C7509271B3.quest_subtitle: "Alimente uma Abelha Diamante com Fluorita"
	quest.1A0672C7509271B3.title: "&fAbelha de Fluorita"
	quest.1A09AF508EFAE0EC.quest_subtitle: "Citron + Key Lime"
	quest.1A13039D6302ADA5.quest_desc: ["Você pode verificar Missões anteriores para aprender a construir alguns destes: &7Componentes Mecânicos de Ferro&r nos &eBlocos de Engenharia Leve&r e &8Chapas de Aço&r nos &7Blocos de Engenharia Pesada&r. \\nAs &eBobinas de Electro&r serão um pouco diferentes, no entanto... \\n\\nAs &eBobinas de Electro&r precisam de um Lingote de Ferro e 8 Bobinas de Fio MV. Para obter Bobinas de Fio MV, precisaremos cortar um pouco de &eElectrum&r com os Alicates de Fio de Engenheiro."]
	quest.1A13039D6302ADA5.title: "&6Generator Block"
	quest.1A20BBBAFBEDF911.quest_desc: [
		"O Multi-Threader de Computador Quântico multiplica as threads de coprocessamento no Multibloco de Computador Quântico por 4. Por exemplo: Um Acelerador de Computador Quântico dará 32 threads de coprocessamento com este bloco no multibloco."
		""
		"&lVocê só pode ter um Multi-Threader de Computador Quântico em um Multibloco de Computador Quântico.&r"
	]
	quest.1A20BBBAFBEDF911.title: "Coprocessamento ao Infinito: Multi-Threader de Computador Quântico"
	quest.1A2EA742FDED54FF.quest_desc: ["O &5Terra de Eco&r cobre o chão das &5Florestas Ecoantes&r. \\n\\nEles não agem como &2Grama&r ou Terra normais, além de permitir que &5Mudas de Eco&r cresçam neles. \\n\\nNenhuma Muda normal."]
	quest.1A2EA742FDED54FF.title: "&5Terra de Eco"
	quest.1A3CF2D85E20CA99.quest_desc: [
		"Sério &6Wayne&r, eu não me importo em lutar com você se você continuar esquecendo de aumentar meu nível!"
		""
		"O Item de Assinatura é Cabo de Ligação."
	]
	quest.1A3CF2D85E20CA99.title: "&6Rival Wayne"
	quest.1A3F053E0F693002.quest_desc: ["O Sistema de Lubrificação Avançado agirá como Inquebrável para nossas &8Cabeças de Broca&r e &8Lâminas de Serra Circular&r. \\n\\nEles perderão menos Durabilidade com o uso."]
	quest.1A3F053E0F693002.quest_subtitle: "Pare de rir do nome!"
	quest.1A46A97A00A31C03.quest_desc: [
		"O segundo passo é o Target Pedestal. É aqui que você coloca o &eEnxofre&r no qual você quer que o primeiro seja transformado. \\n\\nOu onde você coloca o &3Nitrato Alquímico&r."
		"{image:atm:textures/questpics/theurgy/theurgy_reform_2.png width:100 height:100 align:center}"
	]
	quest.1A46A97A00A31C03.title: "Passo 2: Target Pedestal"
	quest.1A4B1CA7EC15348E.quest_desc: ["Usando uma &aLinking Tool&r, você pode ligar 2 Gavetas do End para sincronizar seus conteúdos.\\n\\nIsso funciona como um Baú do End, mas como uma Gaveta.\\n\\nPara ligar, clique com o botão direito na primeira Gaveta do End com a &aLinking Tool&r, depois clique com o botão esquerdo no segundo Linking Tool do End."]
	quest.1A4B1CA7EC15348E.quest_subtitle: "Drawer Dimensional..."
	quest.1A4FAE5705B53753.quest_subtitle: "Fabricado com Aparelho de Encantamento"
	quest.1A4FAE5705B53753.title: "&fAbelha de Essência do Ar"
	quest.1A53B6544782442E.quest_desc: ["O Controle de Escudo altera o Escudo que você tem e quando ele se regenera."]
	quest.1A53B6544782442E.title: "Módulo de Controle de Escudo Wyvern"
	quest.1A609549BBCFFFAE.quest_desc: ["Alhos-porós Medicinais crescem nas &bÁguas&r de Rios, Lagos e Pântanos. Basicamente qualquer coisa exceto Água Salgada. \\n\\nPegue um Suporte de Poções, encha alguns Frascos com Água, e então Ferva os Alhos-porós neles para obter um..."]
	quest.1A67F4F87B3D456C.quest_desc: [
		"O Canhão de &6A&8b&6e&8l&6h&8a&6s&r pode ser Criado, encontrado em estruturas ou trocado com a &5Rainha Abelha&r. \\n\\nÉ bem simples: Clique com o Botão Direito em uma &6A&8b&6e&8l&6h&8a&r para carregá-la, e Segure o Botão Direito e solte para disparar a &6A&8b&6e&8l&6h&8a&r! \\n\\nElas não ficarão hostis por serem atiradas, não se preocupe, na verdade acho que elas gostam."
		"{image:atm:textures/questpics/bumblezone/bumble_cannon2.png width:75 height:150 align:center}"
	]
	quest.1A6A383B4EF26B20.quest_desc: ["A &4&lBroca de Mineração&r não tem muitas opções, temos uma &7Cabeça de Broca de Ferro&r ou uma &8Cabeça de Broca de Aço&r. \\n\\n&7Cabeças de Broca de Ferro&r Mineram em uma Área de 2x2 no Tier de uma &7Picareta de Ferro&r. Também causa 6 de Dano e tem menos Durabilidade que a... \\n\\n&8Cabeças de Broca de Aço&r Mineram em uma Área de 3x3 no mesmo Tier de uma &bPicareta de Diamante&r. Estas causam 7 de Dano e têm mais Durabilidade!"]
	quest.1A6A383B4EF26B20.title: "&8Cabeças de Broca"
	quest.1A739D36D5E3B1AD.quest_subtitle: "Mais Opções de Filtragem"
	quest.1A739D36D5E3B1AD.title: "&eMelhoria Avançada de Alimentação"
	quest.1A806C1A54B26EB5.quest_desc: ["Você não quer que tudo execute suas ações em um alcance maior? Você quer que seu Vácuo deixe algum espaço para dropar itens no seu Mundo? Então acho que você pode diminuir o alcance."]
	quest.1A815711703E4A24.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.1A83615B7E1D3540.quest_desc: ["Colocar &9Água&r em um &#45BF56Reator&r com combustível nos dará &#8F49C4Deutério&r. Há outras maneiras de obter isso também, mas &#45BF56Reatores&r fornecem a forma mais rápida possível."]
	quest.1A8440C0048EEB02.quest_desc: ["&cOuro de Blaze&r tem os mesmos status do Ferro, mas tem outras habilidades que o Ferro gostaria de ter! \\n\\nConfira as descrições dos Itens para saber mais sobre o que eles podem fazer!"]
	quest.1A8440C0048EEB02.quest_subtitle: "15"
	quest.1A8440C0048EEB02.title: "Armadura de &cOuro de Blaze"
	quest.1A84DF4478D55C41.quest_subtitle: "Igual ao do vapor"
	quest.1A84DF4478D55C41.title: "&5Cortador de Fios Elétrico"
	quest.1A8F2408970BFCCF.quest_desc: ["&eElectrum&r é uma Liga feita de &eOuro&r e &7Prata&r. \\n\\nVocê pode adivinhar pelo nome que é muito usado em tudo relacionado à eletricidade. Fios, Conectores, Transformadores, ETC!"]
	quest.1A8F2408970BFCCF.title: "Lingote de &eElectrum&r"
	quest.1A8F438DB8508276.quest_desc: [
		"A &3Prisão Congelada&r é uma enorme estrutura semelhante a um Castelo no topo e dentro das Montanhas Nevadas. \\n\\nDentro você encontrará dezenas de celas, arsenais e uma grande sala onde a &3Lápide Amaldiçoada&r se encontra. \\n\\nVocê pode encontrar muitos Baús cheios de Tesouros, incluindo Black Steel. Há Vasos Decorados por toda parte para pegar! \\n\\nE, claro, inimigos Mobs para ficarem no seu caminho: &3Draugrs&r e &3Aptrgangr&r."
		"{image:atm:textures/questpics/cataclysm/cataclysm_prison.png width:200 height:100 align:center}"
	]
	quest.1A8F438DB8508276.title: "&3Prisão Congelada&r: Lar do &3&lMaledictus"
	quest.1AA81C41431FD145.quest_desc: ["Puxe..! Puxe..! Puxe..! \\n\\nO Puxador é o oposto do Enviador, ele puxa itens de Inventários para o Buffer do Roteador. \\n\\nO Inventário tem que estar adjacente ao Roteador."]
	quest.1AAAD0BB67A94487.quest_desc: [
		"Ainda sem Aumento de Nível para nós."
		""
		"O Item de Assinatura é Rocha do Rei."
	]
	quest.1AAAD0BB67A94487.title: "&7Líder das Ruínas Aklove"
	quest.1AAF0B31B47AF23D.quest_desc: ["Dispositivos ME individuais também podem ser configurados para responder a sinais de redstone. Quando atualizados com um &bCartão de Redstone&f, um dispositivo pode ser configurado para funcionar apenas quando alimentado com redstone ou conforme necessário.\\n\\nEste comportamento também pode se aplicar a &oseções&r inteiras de uma Rede ME usando um &bPonto de Interruptor ME&f. Isso permite que uma seção da rede do outro lado do interruptor seja ativada apenas quando o interruptor é alimentado por redstone, ou desativada se estiver usando um &ePonto de Interruptor Invertido&r&f."]
	quest.1AAF0B31B47AF23D.title: "&eME Controlado por Redstone"
	quest.1AB17923F87AE264.quest_desc: [
		"O Yeti é um nome que causa medo em todos que exploram o Frio! Uma abominável criatura peluda que vive no clima mais frio e severo, comendo qualquer coisa que se atreva a se aventurar por lá! \\n\\nBem, não este Yeti, estes são fofos e amigáveis! Eles preferem rolar por aí do que te comer. \\n\\nEles nem mesmo revidam e só têm 10 Corações. \\n\\nNa morte, eles droparão sua Pele e Linha, a primeira pode ser usada como substituto para Lã."
		"{image:atm:textures/questpics/eternal/starlight_yeti.png width:100 height:100 align:center}"
	]
	quest.1AB17923F87AE264.title: "Yetis"
	quest.1AB8BB655AFA79E4.quest_desc: ["Ele aumentará seu Limite de Nível para 63. \\n\\nSeu Item de Assinatura é uma &cPedra do Fogo&r."]
	quest.1AB8BB655AFA79E4.title: "&3Elite dos Quatro Flint"
	quest.1ABD22AA58E093A6.quest_desc: ["Apenas as melhores das melhores &5Máquinas&r precisarão dos melhores Materiais. \\n\\nUse &d&lItens Supremos&r para fazer estas &5Máquinas&r e mais! \\n\\nSim, você vai querer estas &5Máquinas&r, elas valem o tempo e os Materiais!"]
	quest.1ABD22AA58E093A6.title: "Algumas das melhores &5Máquinas&r!"
	quest.1ABEC7DE47BD6286.quest_desc: ["&5Caixotes do End&r são &5Baús do End&r que podem ser usados para transportar itens.\\n\\n&5Oculares do End&r são versões portáteis dos &5Caixotes do End&r."]
	quest.1ABEC7DE47BD6286.quest_subtitle: "Aqui e Ali!"
	quest.1ABEC7DE47BD6286.title: "Caixotes e Oculares do &5End"
	quest.1AD87CB3226ED224.quest_desc: [
		"Lã só faz uma coisa com o gerador: &9Silenciá-lo&r. "
		"- Não gosta de ouvir os sons irritantes do &aGerador&r? Então use a Lã! Qualquer cor, espessura ou estampa serve!"
	]
	quest.1AD87CB3226ED224.quest_subtitle: "Tá, tá, tá e tá! Silêncio na sala! (Sem referências, juro!)"
	quest.1AD87CB3226ED224.title: "&fSilêncio, você vai acordar os mobs!"
	quest.1AEFF93A398B8BBF.quest_desc: ["O &b&lTier Elite&r vem logo após o &c&lAvançado&r. Estes têm os mesmos bônus que o &c&lAvançado&r... só que mais! \\n\\n&b&lElite&r são feitos com &bLigas Reforçadas&f, &bCircuitos de Controle Elite&f, e na maioria das vezes &eGold Ingots&r. \\n\\nVocê pode obter &bLigas Reforçadas&r infundindo uma &cLiga Infundida&r com 20mb de &bDiamante&r. Isso são 2 &bPós de Diamante&r ou 1/4 de &bDiamante Enriquecido&r! \\n\\nVocê pode então usar essas &bLigas Reforçadas&r (2 delas) com um &cCircuito de Controle Avançado&r para fazer o &bCircuito de Controle Elite&r."]
	quest.1AEFF93A398B8BBF.title: "&b&lTier Elite"
	quest.1B0087400B0B8B49.quest_desc: ["O &9Reator&r é um gerador multibloco de 3x4x3 que queima &aUrananita&r como combustível para produzir FE.\\n\\nPara construí-lo, você precisará fazer um total de 36 Blocos de Reator. Segurando 36 na mão, colocar um bloco construirá automaticamente o reator. Certifique-se de limpar um espaço primeiro!\\n\\nVocê precisará resfriar o reator para que ele crie mais FE, e pode fazer isso com &brefrigerante&r sólido ou líquido. Para usar um refrigerante sólido, você também precisará fornecer um pouco de refrigerante líquido. &bGelo Seco&r é um ótimo refrigerante sólido! (Nota: 1 Balde de Água serve).\\n\\nVocê também pode aumentar a geração de FE mantendo o buffer de combustível cheio, além de adicionar Carvão e Redstone ao Reator. Usar Blocos de qualquer um deles também funcionará!"]
	quest.1B0087400B0B8B49.title: "Reator (Inicial)"
	quest.1B06907584B3405B.quest_desc: ["&bPedras do Amanhecer&r são encontradas em Biomas de Picos: Rochosos, Nevados, quaisquer Picos! Basicamente qualquer Bioma que tenha Blocos perto do Limite de Altura. \\n\\Elas são raramente encontradas em Campos Floridos, Biomas Gelados ou Biomas de Colinas."]
	quest.1B06907584B3405B.title: "Encontrando &bPedras do Amanhecer"
	quest.1B173E7533E1171F.quest_desc: ["Apenas um coletor de fluido simples."]
	quest.1B182A30604655E2.quest_desc: ["Os &cQueimadores de Blaze&r são bem fáceis de Criar, você só vai precisar de algumas &7Chapa de Ferro&r com um único Bloco de &4Netherrack&r. \\n\\nEntão você precisará usar uma &oConversão Misteriosa&r para torná-lo menos Vazio! Isso é apenas Clicar com o Botão Direito em um &cBlaze&r com seu &cQueimador de Blaze Vazio&r. \\n\\nQuando o colocamos, no entanto, ele parece um pouco pequeno e... morno... \\n\\nPrecisaremos alimentá-lo! Não, não Bife, &cBlazes&r não gostam de Bifes. Ele precisará de Combustíveis de Fornalha como Madeira ou Carvão, ou seu favorito: os &cBolos de Blaze&r! \\n\\nO Combustível de Fornalha os deixará apenas um pouco Aquecidos, mas os &cBolos de Blaze&r os deixarão &bSuper-Aquecidos&r! Sim, &bSuper-Aquecido&r é mais quente que &6Laranja&r Quente. \\n\\nAlgumas Receitas e &6Máquinas&r precisarão ser Aquecidas, como &6Produção Automatizada de Poções&r, &6Mistura&r e a Caldeira a Vapor!"]
	quest.1B182A30604655E2.title: "Queimador de &cBlaze"
	quest.1B2BD489D5173B40.quest_subtitle: "Muitas maneiras de obter isso"
	quest.1B4CD5AC8F6C3307.quest_desc: ["O &#4497DBMódulo Overdrive&r mantém a eficiência da máquina mesmo quando a receita não está em execução. Em troca, ele bloqueia a máquina para essa receita."]
	quest.1B4CD5AC8F6C3307.title: "&5Módulo Overdrive"
	quest.1B4ED65C614B102F.quest_desc: ["O &bRevenant Aceso&r está em nosso caminho para matar o &b&lIgnis&r. \\n\\nO &bRevenant&r se parece e age como um Blaze, mas em vez de Varas, ele tem Escudos! \\n\\nEsses Escudos o tornam invulnerável a todos os ataques, você precisará esperar que ele os levante para atacá-lo! \\n\\nEle tem 640 &4Corações&r e 2 ataques: um onde ele se levanta no ar e joga Varas de Blaze por todo o lado, e outro onde ele gira seus Escudos como se estivesse fazendo Spinjitzu. \\n\\nNa morte, ele dropará as &bCinzas Ardentes&r."]
	quest.1B4ED65C614B102F.title: "&bRevenant Aceso&r"
	quest.1B5177A774FCEF64.quest_desc: ["Antes de começarmos a recrutar a ajuda de nossos amigos Demônios, precisaremos criar o item mais importante para os Rituais: &aGiz&r.\\n\\nHá várias cores de giz necessárias, com Rituais de nível mais alto exigindo várias para serem ativados. Para começar, o &bGiz Branco&r é o mais fácil de obter.\\n\\nComece jogando Pedra do Outro em uma fornalha e jogando Troncos do Outro Mundo no &dFogo Espiritual&r. Com os itens que você criar, poderá fazer o Giz Branco Impuro.\\n\\nPara purificar qualquer pedaço de Giz, simplesmente jogue-o no &dFogo Espiritual&r para limpá-lo. Usar o Giz Purificado no chão desenhará &mdemoníacos&r símbolos bonitos no chão. Estes são difíceis de remover, a menos, é claro, que você faça para si mesmo o &aPincel de Giz&r. Faça-o, vale a pena."]
	quest.1B5177A774FCEF64.title: "Preparando para um Ritual: &eGiz"
	quest.1B5C86AE05678420.quest_desc: ["Quando você clica com o botão direito em uma interface, ela exibe várias opções, eis o que todas elas fazem:\\n\\n&lDefinir Lado&r: Na parte superior da tela, você pode definir o lado em que a interface \"age\" como se estivesse. Pode ser útil para máquinas com lados de entrada/saída específicos.\\n\\n&lTiques/Operação&r: Se uma interface estiver definida para 10 tiques/operação, ela importará/exportará uma vez a cada 10 tiques (0,5 segundos).\\n\\n&lPrioridade&r: Envia itens para o inventário com a interface de maior prioridade.\\n\\n&lCanais de Item/Energia&r: Isso dividirá seu sistema em vários canais. Você pode empurrar e puxar de diferentes lugares em sua rede."]
	quest.1B686954D34A0F23.quest_desc: ["A &bChave de Quartzo&f faz o que qualquer chave de mod de tecnologia comum faria. Ela gira blocos e dispositivos na face em que você clica com o botão direito e os desmonta quando clicado com o botão direito enquanto se agacha.\\n\\nEsta Chave vem nas variedades de Quartzo Certus e Quartzo do Nether."]
	quest.1B686954D34A0F23.quest_subtitle: "Faz exatamente o que você esperaria"
	quest.1B686954D34A0F23.title: "Chave de Quartzo"
	quest.1B700DB77B970E35.quest_subtitle: "Tier: &b4"
	quest.1B72E95569B07E18.quest_subtitle: "Melhoria de Armazenamento x24"
	quest.1B72E95569B07E18.title: "Melhoria de &bDiamante"
	quest.1B79F794EDAA810A.quest_desc: ["A Câmera de Reprodução pode ser usada para fazer duas abelhas se reproduzirem automaticamente. Ela é capaz de reprodução própria, assim como a reprodução de 2 tipos de abelhas para criar um terceiro tipo (Exemplo: Mineração Enfumaçada + Cristalina -> Ferro). Se isso resultar em um conflito (Continuando o exemplo anterior, Mineração de Cinzas + Cristalina -> Alumínio), retire uma das abelhas e depois coloque-a de volta.\\n\\nForneça itens de reprodução em cada slot (geralmente flores, segure SHIFT em uma gaiola de abelha com um determinado tipo de abelha para ver qual item de reprodução ela usa (Abelhas Dracônicas, por exemplo, usam 2 Pó Dracônico)) e algumas gaiolas de abelha.\\n\\nSó...não faça...qualquer coisa para fazer com que a F.Bee.I. venha atrás de você. Eu garantirei que você seja adicionado ao Hall da Vergonha se elas realmente vierem atrás de você."]
	quest.1B79F794EDAA810A.quest_subtitle: "Fazendo Bebês 2: Beegaloo Elétrico"
	quest.1B90B94D07BBDD09.quest_desc: [
		"Para fazer todos esses dispositivos do ExtendedAE, o martelo e o alicate de uma Bancada de Trabalho não serão suficientes."
		""
		"É hora de atualizarmos para o Montador de Cristal, uma máquina capaz de lidar com essas operações complexas."
		""
		"Com ele, você pode montar os vários dispositivos do ExtendedAE."
		""
		"Ele também é capaz de lidar com Reações no Mundo, mas não tão bem quanto a Câmara de Reação, e também é capaz de montar processadores, 4 de cada vez."
		""
		"A face que tem uma tela não pode se conectar a uma Rede ME."
	]
	quest.1B90B94D07BBDD09.title: "Criador Complexo: O Montador de Cristal"
	quest.1BA11428DF7541AD.quest_desc: ["Como o &eCâmbio Sequenciado&r usa &eItens&r muito mais chiques, ele é claramente uma &6Máquina&r muito mais chique! \\n\\nA julgar por quão confusa é sua GUI, eu diria que sim... Espero poder ajudar a torná-la menos confusa! Sem promessas, no entanto. \\n\\nComo o &dCâmbio&r normal, ele precisará de um &4Sinal de Redstone&r para fazer o que for projetado. Precisaremos configurar sua INTERFACE para criar um \"script\". \\n\\nPrimeiro, são as Instruções, estas são as tarefas reais que ele executará. Aqui ele pode girar seu &8Eixo&r, afetar uma Polia, esperar ou simplesmente parar. Ele precisará parar no final, é inevitável. \\n\\nEm seguida, é o Ângulo. O Ângulo que o &8Eixo&r ou a Polia girará. De 360 a 1 grau! \\n\\nPor último, é a Velocidade e Direção. Muda a rapidez com que o Eixo ou a Polia se movem e se é no &e&oSentido Horário&r ou &9&oAnti-Horário&r."]
	quest.1BA11428DF7541AD.title: "Câmbio &eSequenciado"
	quest.1BA3D15FFE7DBE59.quest_desc: ["No &bIndustrial Foregoing&r, um dos principais recursos é o &fLátex.&r Ele é usado para criar Chassis de Máquina, necessários para fazer máquinas e melhorias.\\n\\nFazer Látex é bem simples, o &aExtrator de Fluidos&r extrai Látex de &6Troncos&r (Acácia e Mangue dão mais).\\n\\n------------------------\\n\\nAgora sobre fazer Plástico: O Plástico resulta da fundição da Borracha Seca - que é feita na &aUnidade de Processamento de Látex&r, que transforma Látex em Borracha Seca.\\n\\n&bEntão basicamente Látex -> Borracha Seca -> Plástico."]
	quest.1BA3D15FFE7DBE59.quest_subtitle: "Acho que não é a borracha da infância, mas quase!"
	quest.1BA3D15FFE7DBE59.title: "Látex e Plástico? Hã?"
	quest.1BAE1519E44E40CE.quest_desc: [
		"Imagine o Mar Ancestral. Ok, agora remova todas as Algas e remova todos os &bGwibs&r e &bGwiblings&r. \\n\\nEsse é o Mar Morto para você!"
		"{image:atm:textures/questpics/undergarden/undergarden_dead.png width:200 height:100 align:center}"
	]
	quest.1BAE1519E44E40CE.title: "Mar Morto"
	quest.1BC611E39465B026.quest_subtitle: "Wenge + Tília-prateada"
	quest.1BDB369FD243D4C6.quest_desc: [
		"Indiscutivelmente o item mais útil que você pode criar em Occultism, a &bBigorna de Iesnium&r é uma versão superpoderosa da Bigorna Vanilla."
		""
		"Criada usando a &9Torre Invertida de Uphyxes&r, ela:"
		""
		"- É inquebrável."
		"- Aumenta o nível máximo de todos os encantamentos para qualquer coisa combinada nela em um nível."
		"- Custa metade do xp que a estimativa diz (arredondado para baixo, então se diz 25, custará 12)."
		"- Tem um aumento menor no requisito de experiência para edições repetidas no mesmo item."
		"- Aumenta o nível máximo de xp no qual você pode editar itens (o ponto em que diz \"Muito Caro!\")."
	]
	quest.1BE26A00A420DAE3.quest_desc: ["Neste mod, você precisará de &aNúcleos de Fluxo&r e &aBlocos de Fluxo&r para criar as partes centrais da sua rede. Faça alguns de cada!"]
	quest.1BE26A00A420DAE3.quest_subtitle: "Claro que você precisa destes"
	quest.1BE26A00A420DAE3.title: "Os Materiais de Criação \"Centrais\""
	quest.1BE8F864AB9147C0.quest_desc: ["Minério de Atalfaita pode ser encontrado ao Minerar em qualquer lugar subterrâneo na Luz Estelar. \\n\\nNão pode ser transformado em Ferramentas ou Armadura, mas pode fazer diferentes tipos de Luzes!"]
	quest.1BF02D43986ABB03.quest_desc: ["&eEsteiras&r vêm em todas as formas, tamanhos e usos diferentes! \\n\\nPrimeiro, todas as &eEsteiras Transportadoras&r podem ser Criadas com &8Andaimes de Aço&r para dar-lhes coberturas. As &eEsteiras Cobertas&r farão com que os &eItens&r não possam ser pegos por Jogadores enquanto estiverem nela. \\n\\nA primeira e mais simples versão da &eEsteira&r é a &eEsteira Vertical&r. Ela simplesmente leva os &eItens&r para cima! \\n\\nAs &eEsteiras Divisoras&r... dividem as direções para onde os &eItens&r que entram, vão. Ela alternará para cada &eItem&r: 1 vai para a Esquerda, 1 vai para a Direita, 1 vai para a Esquerda, 1 vai para a Direita. \\n\\nAs &eEsteiras de Queda&r droparão os &eItens&r em um Inventário abaixo dela, ou se houver espaço aberto, ela apenas dropará os &eItens&r. Elas podem ser configuradas com &4Redstone&r para não dropar &eItens&r. \\n\\nA última é a &eEsteira Extratora&r, esta pegará automaticamente os &eItens&r de Inventários e os implantará em sua &eEsteira&r. Elas também podem ser usadas com algumas Máquinas!"]
	quest.1BF02D43986ABB03.title: "Tipos de &eEsteiras"
	quest.1BFE6745F49B4AB0.quest_desc: ["O Brilho de Sculk tem propriedades de Luzíola. Eles não precisam de uma Ferramenta para serem coletados, mas quebram mais rápido com uma Enxada. \\n\\nEles aparecem dentro das &5Árvores Ecoantes&r e raramente no subsolo."]
	quest.1C2309DB4B890E71.quest_desc: ["&bBicos&r são usados com sistemas para encher &eItens&r com &bFluido&r. \\n\\nPrimeiro, você precisará encher o &bBico&r &bTubulando Fluido&r para dentro dele! \\n\\nEntão, se houver um &eItem&r que retém &bFluido&r: Balde ou Garrafa, então ele será preenchido com o &bFluido&r no Bico. \\n\\nEle o encherá automaticamente, não precisa de Energia Rotacional, ele usa a Gravidade!"]
	quest.1C2309DB4B890E71.title: "&bBico"
	quest.1C232674CD04024D.quest_desc: ["A Dimensão &2&lUndergarden&r está cheia de Biomas diversos e nojentos, repletos de Vegetação, Mobs: amigáveis e hostis, e claro, Minérios e Itens. \\n\\nEspero que esteja pronto para uma luta!"]
	quest.1C232674CD04024D.title: "Bem-vindo ao &2&lUndergarden&r!"
	quest.1C273D9E046FD18A.quest_desc: ["Usado para energizar itens usando o Orbe Energizante."]
	quest.1C27C74722A19FC1.quest_desc: ["Com uma tonelada de Itens super caros do &l&5Mekanism&r, você pode atualizar a &5Armadura de Unobtainium&r para o &aMekaTraje&r! \\n\\nAgora ele pode conter Energia e, em vez de tirar corações de dano, ele tirará Energia. \\n\\nVocê pode usar Unidades de Melhoria para torná-lo ainda melhor!"]
	quest.1C27C74722A19FC1.quest_subtitle: "Tanta Energia quanto você puder fornecer"
	quest.1C27C74722A19FC1.title: "&aMekaTraje"
	quest.1C40B30823B2A254.quest_subtitle: "Basta pescar"
	quest.1C40B30823B2A254.title: "&fAbelha de Prismarinho"
	quest.1C474B46AECCCFE9.quest_subtitle: "Gerada usando um Ninho de Cascalho ou Pedra"
	quest.1C474B46AECCCFE9.title: "&fAbelha Escavadora"
	quest.1C4ABF4518638A82.quest_desc: ["Bônus:\\n\\n - Absorção II (3:00)\\n - Velocidade II (3:00)\\n - Resistência II (3:00)\\n - Regeneração II (3:00)\\n - Força II (3:00)"]
	quest.1C4ABF4518638A82.title: "Maçã de &4Supremium"
	quest.1C566975C4EC5D93.quest_desc: ["Honestamente, apenas use &2&lMA&r para este. É a maneira mais fácil de obter todos eles. \\n\\nPor favor, não faça criadores em massa de &2Tartarugas&r e fazendas de abate em massa de &bGuardiões&r. TPS é importante!"]
	quest.1C566975C4EC5D93.title: "Prisma do &9Mar"
	quest.1C5EA7D62BAF2108.quest_desc: ["Para lutar contra &5&lO Leviatã&r, você precisará de um sacrifício. O &5Sacrifício Abissal&r, para ser específico. \\n\\nOs Itens mais básicos necessários são os Blocos de Barras e Ametista, que são apenas Itens &2&lVanilla&r. \\n\\nEntão, você precisará de uma Concha de Nautilus e um Coração do Mar. Estes são Itens &2&lVanilla&r que são raros de obter... a menos que você mate &5Deeplings&r, que podem dropá-los! \\n\\nVocê também precisará de um Athame, que é uma arma usada por &5Feiticeiros Deepling &fe &5Sacerdotes&r e dropada por eles na morte. \\nA última parte nos dá uma escolha, ou Coral Cristalizado ou Pedaço de Coral. Ambos são drops de &5Golems de Coral&r e &5Coralssus&r."]
	quest.1C5EA7D62BAF2108.quest_subtitle: "Acordando O Leviatã"
	quest.1C5EA7D62BAF2108.title: "&5Sacrifício Abissal"
	quest.1C6B815C0F43312D.quest_desc: [
		"Uma mudança de ritmo para a &6&lBumblezone&r. \\n\\nO &d&lPrado Floral&r tem Grama, Cerejeiras e mais &dFlores&r do que se pode imaginar. (Isso me lembra, você deveria seguir Minty Meadow no Twitch). \\n\\nEspere, se as &6A&8b&6e&8l&6h&8a&6s&r têm &dFlores&r em suas &eColmeias&r, por que precisamos colocar &dFlores&r fora dela?!?!?!?!"
		"{image:atm:textures/questpics/bumblezone/bumble_meadow.png width:200 height:100 align:center}"
	]
	quest.1C6B815C0F43312D.title: "&d&lPrado Floral"
	quest.1C70D739CE464E25.quest_desc: ["Funciona exatamente como os &2Cartões de Item&r, você precisa de Cartões de Extração e Inserção. Só que desta vez você pega de Tanques contendo &9Fluidos&r para outro Tanque. Não, ele não move Fontes de &9Fluido&r para dentro ou fora do Mundo."]
	quest.1C70D739CE464E25.title: "Cartão de &9Fluido"
	quest.1C73E60FC70408D4.quest_desc: ["Finalmente um Gerador único! Culinária é o nome da arte da Comida. Estes Geradores não usam Carvão, Lava ou mesmo Troncos, eles usam Comida. Qualquer coisa com Pontos de Fome pode ser usada para gerar Energia, a quantidade que gera é baseada na quantidade de Pontos de Fome que a Comida consiste. Bife dará mais Energia do que uma Cenoura."]
	quest.1C76E244AE3582E6.quest_desc: [
		"O &5&lMontador&r, ao contrário da maioria das Máquinas, funciona principalmente em sua GUI. \\n\\nClique com o Botão Direito na Máquina и configure 3 Receitas, colocando-as nas Grades no topo da tela. A ordem em que estão é a ordem que seguirá para prioridade. \\n\\nVocê pode &9Inserir &eItens&r pelas &eEsteiras&r e eles &6Sairão&r pelas &aEsteiras&r de trás. Você também pode &6Inserir &bFluidos&r que serão usados para reabastecer &bBaldes&r ou &bTanques&r usados na Criação! \\n\\nVocê também precisará energizá-lo com &cEnergia&r pelo Topo."
		"{@pagebreak}"
		"Coloque 2 linhas paralelas de 3 &8Andaimes de Aço&r com um Bloco de espaço entre eles. Entre eles, coloque um &eBloco de Engenharia Leve&r no centro e &4Blocos de Engenharia de Redstone&r ao redor dele."
		"{image:atm:textures/questpics/immersive/immersive_assembler1.png width:100 height:100 align:center}"
		"Nos lados com &4Blocos de Engenharia de Redstone&r, coloque &7Chapas de Ferro&r. Então, acima do &eBloco de Engenharia Leve&r, claro que precisaremos de outro. Depois, coloque &eEsteiras Transportadoras&r indo para e através do &eBloco de Engenharia Leve&r!"
		"{image:atm:textures/questpics/immersive/immersive_assemble2.png width:100 height:100 align:center}"
		"Este pode ser confuso apenas pela visão; coloque &7Lajes de Chapa de Ferro&r sobre nossas &7Chapas de Ferro&r previamente colocadas. Então, entre elas, coloque &7Chapas de Ferro&r inteiras."
		"{image:atm:textures/questpics/immersive/immersive_assembler3.png width:100 height:100 align:center}"
		"Para construir nosso &5&lMontador&r, Clique com o Botão Direito na primeira &eEsteira Transportadora&r com nosso adorável &6Martelo&r!"
		"{image:atm:textures/questpics/immersive/immersive_assembler.png width:100 height:100 align:center}"
	]
	quest.1C76E244AE3582E6.title: "&5&lMontador"
	quest.1C8210712349A2E3.quest_desc: ["Premissa bem simples, Machados e Espadas podem causar mais Dano. Sim, ele acumula!"]
	quest.1C8210712349A2E3.title: "Módulo de Dano Básico"
	quest.1C829609915E0012.quest_desc: [
		"Coloque &cMercúrio&r para dentro, \\nTire Energia para fora. \\n\\nMF significa &cMercúrio&r Fluxo, não Cara de Metal ou uma frase vulgar para chamar alguém!"
		"{image:atm:textures/questpics/theurgy/theurgy_mercuryflux.png width:100 height:100 align:center}"
	]
	quest.1C829609915E0012.title: "Gerando Energia com &cMercúrio"
	quest.1C87535D3CDCDA5F.quest_desc: ["Os &4Amplificadores Laser&r têm seu próprio Armazenamento Interno de &aEnergia&r, mas eles não carregam como a maioria das &5Máquinas&r. \\n\\nA forma como os &4Amplificadores Laser&r funcionam é recebendo Carga de outros &4Lasers&r que disparam neles! \\n\\nSejam outros &4Amplificadores Laser&f ou &4Lasers&r, é assim que eles ganham &aEnergia&r. \\n\\nEles então usarão essa &aEnergia&r em um feixe mais focado de acordo com as Configurações que você definir em sua GUI: Atraso, Mínimo e Máximo. \\n\\nAtraso é quantos Ticks ele esperará após atingir a &aEnergia&r Mínima para disparar. A menor quantidade de Ticks é 0 e a maior é 9.999! \\n\\nMínimo é a quantidade de &aEnergia&r que ele acumulará antes de disparar um &4Laser&r ainda mais poderoso! O mínimo de FE que ele esperará é 800mFE, enquanto o máximo é 2GFE. \\n\\nMáximo funciona de forma similar com quanta energia ele acumulará antes de disparar o &4Laser&r. "]
	quest.1C87535D3CDCDA5F.title: "&4Amplificando o Laser"
	quest.1C9D3FC67D58AC02.quest_desc: ["O &#EDD653&nMisturador&r nos permitirá combinar itens e fluidos. Eles podem ser usados para tingir itens ou até mesmo duplicá-los."]
	quest.1C9D3FC67D58AC02.title: "&fO &#ED9553Misturador de Bronze"
	quest.1CA43B9A95159AD0.quest_desc: ["Gemas são Itens divertidos encontrados em Estruturas de &cPokémon&r e Blocos Suspeitos. \\n\\nVocê pode fazer seu &cPokémon&r segurá-la para Melhorar seu primeiro Movimento daquele Tipo. \\n\\nUma &bGema de Água&r fará o primeiro &bMovimento de Água&r melhor. A &cGema de Fogo&r Melhora o primeiro &bMovimento de Fogo&r, e assim por diante."]
	quest.1CACE201C6AA0913.quest_desc: ["Esta melhoria anulará itens extras que chegam quando asGavetas estão cheias.\\n\\nIsso pode ser útil para evitar transbordamento ou para impedir que uma configuração fique congestionada devido ao armazenamento estar cheio."]
	quest.1CBA0D7DA0558EBC.quest_desc: [
		"Melhorias Válidas:"
		"- Invulnerabilidade"
		"- Extinguir"
		""
		"Habilidade Intrínseca:"
		"- Reparo com Lava"
	]
	quest.1CC4F8570A7A99EB.quest_desc: ["A &dEssence&r é o ponto de partida para todas as suas necessidades de cultivo no Mystical Agriculture.\\n\\nA &eInferium Essence&r é o nível base de todas as essências. Você pode obtê-la minerando, matando monstros ou criando sementes para cultivá-las! \\n\\nPara fazer as essências maiores e melhores, você precisará criar um &9Infusion Crystal&r. "]
	quest.1CC4F8570A7A99EB.quest_subtitle: "Tier: &e1"
	quest.1CC4F8570A7A99EB.title: "&aInferium"
	quest.1CC627D3FB348C89.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_shaper.png width:100 height:150 align:center}"]
	quest.1CC627D3FB348C89.quest_subtitle: "Trail Ruins"
	quest.1CC627D3FB348C89.title: "Ornamento de Armadura Shaper"
	quest.1CD05CB4A3DB112A.quest_desc: ["A &c&lMesa de Desmanche&r pode finalmente te dar Materiais e &9Pó de Gema&r sem usar &7Bigornas&r. \\n\\nVocê pode reciclar &eFerramentas &fe &eArmaduras &fcom &eAfixos&r para obter seus Materiais. \\n\\nOs Materiais que você obtém são baseados na Raridade do Item, &eItens&r &8Comuns&r darão Materiais &8Comuns&r. \\n\\nE também desmonta Armadura de Cavalo/Cachorro por algum motivo."]
	quest.1CD05CB4A3DB112A.title: "&c&lMesa de Desmanche"
	quest.1CD2C6AFD788C35E.quest_desc: ["Compacta itens na Mochila para sua receita 2x2."]
	quest.1CD5ABD827CEB3AE.quest_subtitle: "Castanha-do-pará + Balsa"
	quest.1CE0095340328C08.quest_desc: ["Ainda não está satisfeito? Você precisa derrotar ainda mais Treinadores? \\n\\nO Campo de Batalha inclui ainda mais Treinadores Opcionais para lutar! Também alguns que Geram onde as Cidades do End Geram. \\n\\nSendo estes &5Battleground Alice&f, &5Battleground Benjamin&f, &5Battleground Big Mo&f, &5Battleground Mel&f, &5Battleground Mirskle&f, &5Battleground Tessy&f, e &5Battleground Vega&r. \\nDerrote todos eles e você vencerá o Campo de Batalha!"]
	quest.1CE0095340328C08.title: "Gladiador do Campo de Batalha"
	quest.1CE7B24E7E62C25B.quest_desc: [""]
	quest.1CE7B24E7E62C25B.quest_subtitle: "&oO desconhecido que, no entanto, é tudo o que conhecemos."
	quest.1CE7B24E7E62C25B.title: "&d&lPulsating &8Black Hole"
	quest.1CF8263756EE8F2A.quest_desc: ["Este &ePó&r especial é dropado pelo Wither e pelo Ender Dragon quando mortos por uma &dEssence Weapon&r encantada com &dMystical Enlightenment&r."]
	quest.1CF8263756EE8F2A.title: "&5Cognizant Dust&r"
	quest.1D1ABA9BD978E8A1.quest_subtitle: "Cidra + Cereja Silvestre"
	quest.1D1FAA2F86695781.quest_desc: ["Para o &l&2Fronteira&r, a Raridade dos &eAfixos&r não importava, mas agora para a &l&eAscensão&r, você precisará que tudo seja &aIncomum&r ou melhor. \\nVocê também precisará matar um &4Invasor&r, também conhecido como um Chefe &6&lApothic&r, para aprimorar seu &lNível de Mundo&r. A Raridade do &4Chefe&r não importa! \\n\\nOs &eAfixos&r irão apenas até &5Épico&r, mas agora o &9Raro&r é mais comum que o resto. Também podemos obter &aGemas&r &6Míticas&r... mas apenas com o Favor da Deusa Sorte! \\n\\nFalando em Sorte, nossa Sorte aumentará para 30% e a Experiência saltará para 55%. \\n\\nEm troca, os &4Monstros&r agora terão 8 Pontos de Armadura e 5 de Perfuração de Armadura."]
	quest.1D1FAA2F86695781.title: "&lNível de Mundo: &eAscensão"
	quest.1D2700821045CCF2.title: "&5Parte de Armazenamento de 65536k"
	quest.1D27EE427ECFD6CE.quest_desc: ["Versão aprimorada da &cTertium&r."]
	quest.1D27EE427ECFD6CE.quest_subtitle: "27"
	quest.1D27EE427ECFD6CE.title: "&9Armadura Imperium"
	quest.1D2EF12FD7FDD217.quest_desc: ["Galinhas botarão estes naturalmente. Acho que não é bem considerado naturalmente...\\n\\nAcho que as galinhas estão apenas se... &oOvo-rcitando!!!&r."]
	quest.1D2EF12FD7FDD217.quest_subtitle: "...ou será que estou?"
	quest.1D2EF12FD7FDD217.title: "Não vou fazer um trocadilho com Ovo"
	quest.1D31C515533DAD36.quest_subtitle: "Cave Dweller + Soul Tree"
	quest.1D39634260A47C9A.quest_desc: ["Se você usar &2Barra de Ferro Infundidos&r ou &6Barra de Ouro Corrompido&r na Mesa de Oferendas, você obterá &bBarra dos Céus&r."]
	quest.1D39634260A47C9A.title: "&bBarra dos Céus"
	quest.1D3E2363CFD4C5E0.quest_desc: ["A Criação por Fusão tem Níveis que são determinados pelos Injetores. Os Níveis seguem em ordem ascendente: Draconium (eu me refiro a ele como Básico para ajudar a diferenciar), Wyvern, Dracônico e Caótico. Os Injetores precisam ser colocados à Esquerda e à Direita do Núcleo de Criação por Fusão, a alguns blocos de distância dele. Eles podem ser colocados em forma de cruz, com um máximo de 5 de cada lado do Núcleo de Criação. Para fornecer Energia a eles, colocar Cristais de Relé IO conectados a eles funcionará, confira a Vinculação de Cristais para saber mais."]
	quest.1D3E2363CFD4C5E0.title: "Nível Básico"
	quest.1D3F11194EA3BB73.quest_subtitle: "Tier: &b3"
	quest.1D48298525EEADC9.quest_desc: ["Você já deve ter tudo o que precisa."]
	quest.1D48298525EEADC9.quest_subtitle: "Jogue um pouco de Açúcar em mim!"
	quest.1D48298525EEADC9.title: "Você é tão doce"
	quest.1D4973B187284CBB.quest_desc: ["Um item muito pacífico e útil, segure-o em sua mão secundária para usá-lo. Quando na sua mão secundária, ele fertilizará plantações e mudas. \\n\\nEle também curará Mobs domesticados e jogadores próximos. \\n\\nE removerá os efeitos de Veneno e Wither de jogadores e Mobs domesticados. Eu não sei como seus Mobs estão pegando o efeito Wither, mas agora podemos consertar! \\n\\nApós curar ou fertilizar o suficiente, ele terá um tempo de recarga de 10 minutos."]
	quest.1D4973B187284CBB.title: "&aEssência da Vida"
	quest.1D4E7F548431263A.quest_desc: ["De longe o mais simples destes blocos de fazer. \\n\\nFerro e &4Redstone&r você obterá da jogabilidade &2&lVanilla&r, o único item \"difícil\" é a &7Iron Sheetmetal&r."]
	quest.1D4E7F548431263A.title: "&4Redstone Engineering Block"
	quest.1D56D3B444A4B2D4.quest_desc: ["A &dGauntlet of &bBulwark&r age de forma diferente do que você suporia. \\n\\nEm vez de aproximar os monstros, ela os afasta ao segurar o botão direito do mouse e lhes dá o efeito &bBlazing Brand&r. \\n\\nEntão, quando você solta o botão direito, você avança na direção que está olhando. \\n\\nÉ feita fundindo a &dGauntlet of Guard&r com uma &bBulwark of Flame&r na &4Mechanical Fusion Anvil&r."]
	quest.1D56D3B444A4B2D4.title: "&dGauntlet of &bBulwark"
	quest.1D6FAF0E25A0D596.quest_subtitle: "Cravo + Pimenta-da-jamaica"
	quest.1D720AC88431BD70.quest_desc: ["Cruze a &eAbelha do End&r com uma &9Abelha de Lápis&r para criar uma &bAbelha de Diamante&r!"]
	quest.1D720AC88431BD70.quest_subtitle: "Uma abelha que tem potencial!"
	quest.1D720AC88431BD70.title: "&fAbelha de &bDiamante"
	quest.1D86B2E553503E53.quest_desc: ["A Dominion Wand é usada para controlar as criaturas que você pode encontrar no mundo! Cada ser responde de forma diferente à varinha, então certifique-se de ler o Worn Notebook!"]
	quest.1D86B2E553503E53.title: "Invocando Ajuda!"
	quest.1D87415343E65AA7.quest_desc: ["O &5Creative &8Compressor&r permite que você escolha qualquer Pressão em Bar que desejar! Positiva, Negativa, até mesmo 0! Ele pode ser usado dentro de Máquinas. \\n\\nVocê precisará de 4 stacks de Advanced Pressure Tubes, Advanced Liquid Compressor, Advanced Air Compressor, Electrostatic Compressor e um Flux Compressor. \\n\\nNão sei o que é mais difícil, obter a &6&lStar&r ou lembrar de todos os Itens que você precisa para fazer isto!"]
	quest.1D87415343E65AA7.title: "&5&lCreative &8Compressor"
	quest.1D91E37BFD8CC911.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_emerald.png width:100 height:150 align:center}"]
	quest.1D91E37BFD8CC911.title: "&2Esmeralda&r"
	quest.1D995548A159F291.quest_subtitle: "Alimente uma Abelha Fantasma com uma Adaga de Soulium"
	quest.1D995548A159F291.title: "Abelha de Soulium"
	quest.1D9A00C81C2A97F0.quest_subtitle: "Decepcionante"
	quest.1DAA5DD81EF96469.quest_desc: [
		"Melhorias Válidas:"
		"- Cortador de grama"
		"- Sky Sweeper"
		"- Forno Automático"
		"- Martelo"
		""
		"Habilidade Intrínseca:"
		"- Reparo com Lava"
	]
	quest.1DAEB18081B4F22B.quest_desc: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, você está no modo de edição."]
	quest.1DBF1D4061518B0B.quest_subtitle: "Transformando um em mais"
	quest.1DBF1D4061518B0B.title: "Refinando Minérios"
	quest.1DC407272D9D9CCE.quest_subtitle: "Fabricação Desperto"
	quest.1DC407272D9D9CCE.title: "&fAbelha de Supremium Desperto"
	quest.1DCAA0310AA55F1C.quest_desc: ["Mas ele geralmente fecha às 5, então quem se importa?"]
	quest.1DCAA0310AA55F1C.quest_subtitle: "Willy ficaria orgulhoso"
	quest.1DCAA0310AA55F1C.title: "O Início de um Pescador"
	quest.1DE0F289821F55D1.quest_desc: ["Agora que temos um Foliot Triturador, podemos &muse&r educadamente pedir que ele moa um pouco de &ePedra do End&r, &9Obsidiana&r e &7Calcita&r para nós. Nós os usaremos para fazer um novo Giz!"]
	quest.1DE0F289821F55D1.title: "&aDeu Branco"
	quest.1DF026030780AE96.quest_subtitle: "Extrai Genes de Abelhas em Colmeias"
	quest.1DF026030780AE96.title: "&fMelhoria de &6Coletor de Genes Pokey Pokey"
	quest.1DFC9F33D9FD6357.quest_subtitle: "Cacau + Noz-da-índia"
	quest.1E01E377A2091AA6.quest_desc: ["&5Fragmentos Estelares&r têm 1% de chance de cair quando qualquer &cPokémon&r é derrotado. \\n\\nQuando você usa 50 deles em um &cPokémon&r, ele irá &5Terastalizar&r para o &5Tipo Estelar&r. Esta é a única maneira de obtê-lo. \\n\\nO &5Tipo Estelar&r receberá um bônus para todos os ataques! Mas será fraco contra outros &5Tipos Estelares&r. Felizmente, eles são bem raros."]
	quest.1E01E377A2091AA6.title: "&5Fragmentos Tera Estelares"
	quest.1E0C6409B2573CCA.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		""
		"Uma versão aprimorada do Pulo no Chão que repele e desacelera mobs próximos, tem um tempo de recarga."
	]
	quest.1E0E07B8CCC48531.quest_desc: ["&aPedras do Trovão&r aparecem em Biomas de Colinas. \\n\\nÀs vezes em Selvas também."]
	quest.1E0E07B8CCC48531.title: "Encontrando &aPedra do Trovão"
	quest.1E0EF28175A7424F.quest_desc: ["Já que você já está produzindo vapor, por que não usá-lo para gerar eletricidade? Simplesmente coloque uma &#6363DBTurbina&r, insira &7vapor&r e retire &#DBDB63eletricidade&r."]
	quest.1E0EF28175A7424F.quest_subtitle: "Vapor -> Eletricidade"
	quest.1E0EF28175A7424F.title: "&5Turbina a Vapor"
	quest.1E0F92F07FDD162E.quest_desc: ["Você precisará de &bBases de Sementes de Prosperidade&r para criar culturas de recursos."]
	quest.1E0F92F07FDD162E.quest_subtitle: "Eu sou todo sobre essa Base (de Semente)"
	quest.1E0F92F07FDD162E.title: "&bBase de Semente de Prosperidade"
	quest.1E13D7CE5A9EFF74.quest_desc: [
		"Frostfields são um dos biomas frios no &2&lUndergarden&r. Você pode dizer que é frio pelos enormes sincelos, Neve em Pó e Deepturf Congelado! \\n\\nAlém disso, aqui, em vez do habitual Depthrock subterrâneo, você encontrará Shiverstone. \\n\\nShiverstone age mais como Gelo do que como Pedra de verdade. Pelo menos quando se está em cima dela!"
		"{image:atm:textures/questpics/undergarden/undergarden_frosty.png width:200 height:100 align:center}"
	]
	quest.1E13D7CE5A9EFF74.title: "Frostfields"
	quest.1E22A0D5F4B2EB0D.quest_subtitle: "Congelando Argônio com Hélio"
	quest.1E2A9446594638E2.quest_desc: [" Escondido dentro das terras estranhas do &6End&r, uma &6relíquia&r dobra o próprio espaço... o &5Cajado do Coro&r. \\n\\n Forjado a partir das misteriosas &5plantas do coro&r, este cajado detém o &5poder instável&r de &2teletransporte&r, permitindo que seu portador deslize pelo espaço em um piscar de &lolhos&r. \\n\\n- &lPossui 1 habilidade:&r \\n\\n &dTeletransporte&r: \\n Usar o cajado te &9teletransporta instantaneamente&r para frente por uma &a&ocurta distância&r. Esta habilidade &econsome cargas&r de um buffer interno, que se regenera &e&olentamente&r ao longo do tempo. \\n\\n- Uma &6relíquia&r de movimento... onde cada passo é um &9desaparecimento&r."]
	quest.1E2A9446594638E2.quest_subtitle: "Alguns caminhos não foram feitos para serem caminhados..."
	quest.1E2A9446594638E2.title: "&dCajado do Coro&r"
	quest.1E2B363E3365A62F.quest_desc: ["Sementes de Allthemodium requerem Solo Mágico colocado abaixo para poderem crescer."]
	quest.1E2B363E3365A62F.quest_subtitle: "Tier: &bMágico"
	quest.1E3E688B3B52C4D2.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_raiser.png width:100 height:150 align:center}"]
	quest.1E3E688B3B52C4D2.quest_subtitle: "Trail Ruins"
	quest.1E3E688B3B52C4D2.title: "Ornamento de Armadura Raiser"
	quest.1E40ACF3E69A4100.quest_desc: ["Você tem que beber? Sei lá, meio que fica lá e funciona... \\n\\nCom o &6Recipiente de Antídoto&r, os efeitos negativos (como Wither ou Veneno) terão suas durações reduzidas! Muito útil ao enfrentar Bruxas ou Esqueletos Wither."]
	quest.1E40ACF3E69A4100.quest_subtitle: "Cinto"
	quest.1E40ACF3E69A4100.title: "&6Recipiente de Antídoto&r"
	quest.1E414D285E7A5FE2.title: "&cFerramentas de Tertium"
	quest.1E41A5071854DEC8.title: "Módulo de Dano Wyvern"
	quest.1E499F94A2A193E1.quest_desc: ["Adiciona uma INTERFACE de Alto-forno à Mochila."]
	quest.1E4E462928F2A71C.quest_desc: [
		"O &7&nForno de Coque&r será usado para converter &#787777Carvão&r em &#696464Coque&r. O &#696464Coque&r é 4 vezes mais eficaz como combustível do que &#787777Carvão."
		""
		"O multibloco pode ser visualizado segurando uma &#D1D15EChave Inglesa&r na mão secundária ou principal. Segurando uma &#B4D95DEscotilha&r na mão indicará as possíveis posições para elas."
		""
		"O &7&nForno de Coque&r é um multibloco oco feito principalmente de tijolos."
	]
	quest.1E4E462928F2A71C.title: "&fO &#8C4715Forno de Coque"
	quest.1E535784A9D3DE89.quest_desc: ["Estas são coisas do ExtendedAE que não requerem Cristais Entro."]
	quest.1E7DC8E0493BE99E.quest_subtitle: "Tier: &e1"
	quest.1E81B903137BB62A.quest_desc: ["Ferramentas normais simplesmente não são suficientes, especialmente ao lidar com os Mobs perigosos no &2&lUndergarden&r. \\n\\nPodemos criar o &7Escudo de Cloggrum&r, que age como um escudo normal. \\n\\nMas precisaremos obter o &7Machado de Batalha&r como um drop raro dos &7Forgottens&r."]
	quest.1E81B903137BB62A.title: "Armas de &7Cloggrum&r"
	quest.1E9B2D814F50A265.quest_desc: ["O &6Ventilador Encapsulado&r é uma das máquinas mais subestimadas do &6&lCreate&r. \\n\\nVocê pode colocá-lo no chão e ele ficará virado para você, ou segurar Shift + botão direito para colocá-lo virado para o lado oposto. \\n\\nQuando recebe &dEnergia Rotacional&r no &e&osentido horário&r, ele sopra ar para longe. Quando recebe &dEnergia Rotacional&r no &9&osentido anti-horário&r, ele suga ar em sua direção. \\n\\nEsses sopros e sucções também afetarão &eItens&r e Entidades próximos a eles, e sim, quanto mais rápido gira, mais ele suga e sopra! \\n\\nTambém obtemos receitas extras que podemos fazer colocando um Bloco na frente do &6Ventilador&r. Isso afetará os &eItens&r que estão sendo soprados pelo &6Ventilador&r. \\n\\nPodemos usar &cLava&r para &6Assar&e Itens&r como uma Fornalha. Obtendo Barras de Minérios, Pedra de Pedregulho e Pepitas de Ferramentas. \\n\\nSe colocarmos Fogo na frente do Ventilador, podemos Defumar Itens. Como cozinhá-los! \\n\\nEm vez de Lava, também podemos colocar Água na frente dele. Isso lavará o que estiver na frente dele, como Pó de Concreto em Concreto. \\n\\nE por último, em vez de Fogo, podemos usar Fogo das Almas para assombrar Itens! Isso transformará os Itens em variantes do Nether ou em Itens totalmente diferentes."]
	quest.1E9B2D814F50A265.quest_subtitle: "Isso é um saco!"
	quest.1E9B2D814F50A265.title: "&6Ventilador Encapsulado"
	quest.1E9BD4B74DAEA9FC.quest_desc: ["Para atrair Abelhas para este ninho, você precisará de &5Fruta do Coro Cozida&r em vez de &6Guloseimas de Mel&r."]
	quest.1E9BD4B74DAEA9FC.quest_subtitle: "Atrai Abelhas do End quando colocado no End"
	quest.1E9BD4B74DAEA9FC.title: "&fNinho de &ePedra do End"
	quest.1EA02BA24AF02256.quest_desc: ["Os Moldes de Liga Eclipse são usados para aprimorar armaduras e ferramentas de Celestigem para Liga Eclipse, mantendo encantamentos e melhorias instaladas."]
	quest.1EABF2E7AE7B8F22.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_netherite.png width:100 height:150 align:center}"]
	quest.1EABF2E7AE7B8F22.title: "&8Netherite&r"
	quest.1EB04FE105ACA4BE.quest_desc: ["Quando um &9Warden&r morre, ele tem a chance de dropar um &9Coração das Profundezas&r. \\n\\nIsso pode ser usado para a &6&lEstrela ATM&r, ou para ativar o Portal na Cidade Ancestral! \\n\\nNão pode haver nada no Portal para ativá-lo, isso inclui &9Sculk&r!"]
	quest.1EB04FE105ACA4BE.title: "&9Coração das Profundezas"
	quest.1EB887F8072439A3.quest_desc: ["Após usar &9Atração Incentivada de Fatma&r para invocar um &9Triturador Marid&r ou &aChamado de Ophyx&r para invocar um &aTriturador Djinni&r, você pode transformar Gelo, Gelo Compactado e Gelo Azul em suas formas trituradas, e usá-las para criar Giz Azul Claro."]
	quest.1EB887F8072439A3.title: "&bGiz Azul Claro"
	quest.1EBD5E4410A6DF34.quest_subtitle: "Alimente uma Abelha Fantasmagórica com uma Adaga de Soulium"
	quest.1EBD5E4410A6DF34.title: "Abelha de Soulium"
	quest.1EBF234015B26F15.quest_desc: ["Armadura básica adicionada pelo &a&lRoots Classic&r, você precisará de um Ritual para obtê-la!"]
	quest.1EBF234015B26F15.quest_subtitle: "14"
	quest.1EBF234015B26F15.title: "&2Equipamento Silvestre"
	quest.1ECD4331DDFBBB52.quest_desc: ["As Árvores Torreya são árvores enormes, roxas/rosas, que têm cerca de 40 blocos de altura. \\n\\nAs folhas brotam em todas as direções e as Vinhas de Torreya pendem delas."]
	quest.1ECFA72CF2BA4B45.quest_desc: ["Um ejetor simples e você pode configurar a quantidade ejetada de uma vez."]
	quest.1F114EB0AAB86DB4.quest_desc: ["Mercados fornecem a você um aldeão que pode vender qualquer coisa se você tiver a quantidade certa de esmeraldas.\\n\\nSpoiler: Geralmente é apenas 1 Esmeralda por item, felizmente, eles têm TUDO."]
	quest.1F114EB0AAB86DB4.quest_subtitle: "O Aldeão tem mais de uma maneira de Nascer"
	quest.1F114EB0AAB86DB4.title: "Comprando Suprimentos Agrícolas"
	quest.1F139091C1B4E50B.quest_subtitle: "Um circuito normal"
	quest.1F146FE1002643B2.quest_subtitle: "Pau-brasil + Eucalipto-rosa"
	quest.1F18B64C84C8809D.title: "&l&9Recompensa do Mundo Superior:&r&e Aranhas"
	quest.1F1B4948FCC14BB4.quest_subtitle: "Abeto Prateado + Pinheiro"
	quest.1F21B578FAF4CCAC.quest_subtitle: "Igual ao do vapor"
	quest.1F21B578FAF4CCAC.title: "&5Empacotador Elétrico"
	quest.1F31EBF49079F9D3.quest_desc: ["&aCreeper Overhaul&r nos dá muitas variantes diferentes de Creepers para diferentes Biomas. \\n\\nCada um tem drops diferentes e alguns são até amigáveis! \\n\\nApesar de todos terem medo de &egatos&r..."]
	quest.1F31EBF49079F9D3.title: "&aCreepers Reformulados"
	quest.1F3E18129B871C49.quest_subtitle: "Igual ao do vapor"
	quest.1F3E18129B871C49.title: "&5Forno Elétrico de Ligas"
	quest.1F55A483008F74FE.quest_desc: ["O &bConstrutor Ultra&r tem 36 espaços para filtros, funciona 5x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.1F55A483008F74FE.title: "&bConstrutor Ultra"
	quest.1F66CDC9799B5DEC.quest_desc: ["Eu me senti irritado por não conseguir girar as máquinas do &bIndustrial Foregoing&r com a maioria das Chaves Inglesas. Para ajudar com isso, compilei uma lista de todas as chaves que consegui encontrar que são capazes de girar máquinas do &bIF&r. Elas foram testadas principalmente na Broca a Laser, então os resultados se concentrarão principalmente nisso. Algumas chaves podem não funcionar com outras máquinas.\\n\\nClique na tarefa nesta missão para ver todas as Chaves válidas para esta missão."]
	quest.1F6C8117F3CED939.title: "&6Arco de Allthemodium"
	quest.1F7591DB6D8EC1E7.quest_desc: ["Bônus:\\n\\n - Absorção II (3:00)\\n - Velocidade II (3:00)\\n - Resistência II (3:00)\\n - Regeneração II (3:00)\\n - Força II (3:00)\\n - Pressa II (3:00)"]
	quest.1F7591DB6D8EC1E7.title: "&5Maçã de Insanium"
	quest.1F7D147C9AF6A4FC.quest_desc: [
		"O Nível 4 é diferente. Primeiro, ele precisa de 26 Blocos de Redstone envolvendo o Núcleo. Então, acima da Redstone, ele precisa de 56 Blocos de Barra de Draconium."
		"{image:atm:textures/questpics/draconic/draconic_core_4off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_4on.png width:100 height:100 align:1}"
	]
	quest.1F7D147C9AF6A4FC.quest_subtitle: "Armazena: 9.880.000.000 RF"
	quest.1F7D147C9AF6A4FC.title: "Nível 4"
	quest.1F7DA060792D716A.quest_desc: [
		"O &d&lMisturador&r é como aqueles que sua mãe/avó usa para misturar ovos com farinha e açúcar para fazer qualquer guloseima deliciosa que elas estejam preparando! \\n\\nO &d&lMisturador&r misturará &eItens&r e &bFluidos&r. Para colocar &bFluidos&r, precisaremos usar a porta do lado esquerdo do &d&lMisturador&r. Para dar a ele &eItens&r, precisaremos usar as portas na parte de trás. \\n\\nPara funcionar, ele precisará de &cEnergia&r inserida pela porta na parte superior da frente do &d&lMisturador&r. \\n\\nDepois que ele misturar, nosso resultado sairá pela porta na frente da máquina!"
		"{@pagebreak}"
		"A primeira camada do &d&lMisturador&r é construída como um símbolo de Wi-Fi! Primeiro vem o &eBloco de Engenharia Leve&r, depois &bCanos de Fluido&r e &8Andaimes de Aço&r."
		"{image:atm:textures/questpics/immersive/immersive_mixer1.png width:100 height:100 align:center}"
		"Acima do nosso &eBloco de Engenharia Leve&r, colocaremos outro e um à esquerda do recém-colocado. No &8Andaime&r mais à direita, colocaremos um &4Bloco de Engenharia de Redstone&r. Em seguida, colocaremos um 2x2 de &7Chapa de Ferro&r na parte de trás da nossa máquina."
		"{image:atm:textures/questpics/immersive/immersive_mixer2.png width:100 height:100 align:center}"
		"No topo do terceiro &eBloco de Engenharia Leve&r, colocaremos uma única &8Cerca de Aço&r, e à direita dela haverá um quarto &eBloco de Engenharia Leve&r."
		"{image:atm:textures/questpics/immersive/immersive_mixer3.png width:100 height:100 align:center}"
		"Para criar o &d&lMisturador&r, clique com o botão direito na &7Chapa de Ferro&r entre nosso &eBloco de Engenharia Leve&r e o &4Bloco de Engenharia de Redstone&r com um &6Martelo de Engenheiro&r!"
		"{image:atm:textures/questpics/immersive/immersive_mixer.png width:100 height:100 align:center}"
	]
	quest.1F7DA060792D716A.title: "&l&dMisturador"
	quest.1F7DFA5AA65F2812.quest_desc: ["O &bCartão de Aceleração&f, dependendo do dispositivo sendo atualizado com ele, aumentará a velocidade com que o dispositivo opera ou permitirá que o dispositivo realize mais operações de uma só vez.\\n\\nNo caso do &eMontador Molecular&f, um conjunto completo de 5 cartões reduz o tempo necessário para o MM concluir uma fabricação de um segundo (sem cartões) para um &otick&r."]
	quest.1F7DFA5AA65F2812.title: "&fCartão de Aceleração"
	quest.1F81408C55EFC5DB.quest_desc: ["Ok, tecnicamente você não precisa carimbá-los. \\n\\nAlguns podem apenas ficar como Chapas normais."]
	quest.1F81408C55EFC5DB.title: "Chapas de Metal &6&lAllthemodium&r"
	quest.1F81EA5E45424308.quest_desc: ["Se você está procurando maneiras diferentes de obter energia de suas máquinas, é aqui que você pode encontrá-la!\\n\\nExistem várias opções, tanto &acom fio&r quanto &9sem fio&r, para transferir energia."]
	quest.1F81EA5E45424308.title: "&f&lTransferindo Energia"
	quest.1F88C697817A7680.quest_desc: ["Bônus:\\n\\n - Absorção II (3:00)"]
	quest.1F88C697817A7680.title: "&aMaçã de Inferium"
	quest.1F8B4F648EB5A0DC.quest_desc: ["&eCompartimentos (Caixas)&r não são seu estilo? Você prefere &eMochilas&r? Então você vai precisar de um &cBaú&r/&cBarril Pessoal&r! \\n\\nAmbos funcionarão da mesma maneira. Após a criação, clique com o botão direito com eles para se definir como seu usuário. \\n\\nEntão, apenas você poderá abrir este &cBaú&r/&cBarril&r. Ah, a propósito, você pode abri-lo do seu inventário ou colocando-o no chão como um &cBaú&r/&cBarril&r normal. \\n\\nEle tem 54 Slots, mas sem upgrades..."]
	quest.1F8B4F648EB5A0DC.quest_subtitle: "Somente MEU!"
	quest.1FA44E8FEE004AB4.quest_desc: ["Corda de Cânhamo e &8Cabos de Aço&r são colocados como &cFios&r normais em &cConectores&r e &cRelés&r, mas não transferem &cEnergia&r. \\n\\nEm vez disso, eles são para decoração ou para usar o &6&lGancho de Engenheiro&r!"]
	quest.1FA44E8FEE004AB4.title: "Seguro para uso com o &6&lGancho&r!"
	quest.1FAFDB20F504688E.quest_desc: ["O &5Encantamento&r recebe algumas mudanças com o &5&lApotheosis&r. \\n\\nPara resumir, 15 &7Estantes de Livros&r não serão suficientes agora. \\n\\nHá novas Estantes de Livros e ações que você pode fazer com &5Mesas de Encantamento&r agora e, com sorte, estas missões ajudarão você a entender."]
	quest.1FAFDB20F504688E.title: "&5&lEncantamento Apótico"
	quest.1FBF130C71A2112F.quest_desc: [
		"Sem aumento de nível aqui também."
		""
		"O Item de Assinatura é uma Pérola do End."
	]
	quest.1FBF130C71A2112F.title: "&7Chefe Zeph"
	quest.1FC7ABEAB5018E79.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_redstone.png width:100 height:150 align:center}"]
	quest.1FC7ABEAB5018E79.title: "&4Redstone&r"
	quest.1FC88A3BFCE6C9D7.quest_desc: ["Esta aqui é apenas o Encantamento Passos Rápidos... só que agora em uma &7Unidade&r!"]
	quest.1FC88A3BFCE6C9D7.quest_subtitle: "Calças"
	quest.1FC88A3BFCE6C9D7.title: "&8Unidade de Servo Motorizada"
	quest.1FCC474860587169.quest_desc: ["Para obter receitas posteriores, você provavelmente precisará de um &6Prisma de Fundição&r e não se preocupe, só precisamos de uma Forja de Nível 1 para obtê-lo! \\n\\nVocê pode verificar a quantidade de cada atributo na Forja que você precisa no JEI! Além disso, você precisará de 4 &6Pó de Blaze&r, 2 &8Carvões&r e um &bCristal Arcano&r. \\n\\nPor último, você precisará de &9Elementarium&r, que pode ser encontrado em Templos da Selva, Pirâmides do Deserto e Ruínas Subaquáticas!"]
	quest.1FCC474860587169.title: "&6Prisma de Fundição"
	quest.1FCF946B7BE3C0BD.quest_desc: ["As ferramentas de &cUtherium&r são semelhantes às ferramentas de Diamante, mas as armas são mais eficazes contra os &cMobs da Podridão&r! \\n\\nVocê usa o que eles fazem para causar mais dano a eles! Provavelmente há uma dúzia de referências da cultura pop que eu poderia fazer com isso, mas não consigo pensar em nenhuma..."]
	quest.1FCF946B7BE3C0BD.title: "Ferramentas &cUtéricas&r"
	quest.1FE052F643401232.quest_desc: ["Você precisará destes para fazer os Upgrades da Mochila."]
	quest.1FE052F643401232.quest_subtitle: "A Base para Upgrades"
	quest.1FE17B1C7C639F88.quest_desc: ["O Controlador de armazenamento permite que você trabalhe com múltiplos armazenamentos como se fossem um grande multibloco de armazenamento.\\n\\nIsso permite uma rede de armazenamento muito grande, que pode ser combinada com mods como Applied Energistics ou Integrated Dynamics, já que o Controlador de armazenamento atua como um ponto de entrada/saída para todos os armazenamentos conectados a ele.\\n\\nConectar qualquer um pode ser feito simplesmente colocando os armazenamentos ao lado do Controlador de armazenamento ou ao lado de outros que já estão conectados ao Controlador de armazenamento (isso funciona até 14 blocos de distância do controlador em todas as direções)."]
	quest.1FE47F03B5DF492D.quest_desc: ["{image:atm:textures/questpics/allthemodium/all_armor_unoarcane.png width:100 height:175 align:center}"]
	quest.1FE47F03B5DF492D.title: "&5Armadura Arcanista de Unobtainium"
	quest.1FE7C52491E7499B.quest_desc: [
		"Melhorias Válidas:"
		"- Assistência de Subida"
		"- Impulso de Salto"
		"- Pisada no Chão"
		"- Anular Dano de Queda"
	]
	quest.1FF82E21F1C0C73B.quest_subtitle: "Tier: &c5"
	quest.1FFA1DA6A5EA4E70.quest_desc: [
		"Melhorias Válidas:"
		"- Assistência de Subida"
		"- Impulso de Salto"
		"- Pisada no Chão"
		"- Anular Dano de Queda"
		"- Terremoto"
	]
	quest.1FFF00B5D90C3905.quest_desc: ["Você pode obter &cPó de Mundabitur&r de várias maneiras diferentes, então vou apenas dar uma rápida introdução aos &bCristais Arcanos&r! \\n\\nQue sim, são um ingrediente de criação se você quiser criá-lo. \\n\\nVocê terá que minerar por &bCristais Arcanos&r primeiro; depois, você pode usar &2&lMA&r ou &6&lAbelhas&r para fazer mais!"]
	quest.1FFF00B5D90C3905.title: "&bCristais Arcanos"
	quest.2002AB7D061007FA.quest_desc: ["A &6Relíquia do Artesão&r é encontrada dentro de alguns edifícios em aldeias. \\n\\nQuando usada no &l&bClibano&r, ela permitirá que você faça &5Obsidiansteel&r. \\n\\nQuando usada em &6&lForjas&r, ela lhe dará um desconto na &aExperiência&r usada!"]
	quest.2002AB7D061007FA.title: "&6Relíquia do Artesão"
	quest.2002C7EB13626AE7.quest_desc: ["A &6&lMesa de Aprimoramento&r precisa de um combustível diferente para funcionar, e esse combustível são os &6Símbolos do Aprimoramento&r. \\n\\nCada rerrolagem custará 1 &6Símbolo do Aprimoramento&r, enquanto cada Melhoria custará 2! \\n\\nVocê precisará de uma &6Pérola Forjada por Deuses&r para 4 deles."]
	quest.2002C7EB13626AE7.title: "&6Símbolo do Aprimoramento"
	quest.20054D077AFE3F56.quest_desc: ["Nós temos nosso &3Plutônio&r e o resto é o que já devemos ter! \\n\\nUma &2&lP.R.C.&r, &9Água&r e &dPó de Fluorita&r! \\n\\nCombine 1.000mB de &9Água&r com 1.000mB de &3Plutônio&r e 1 &dPó de Fluorita&r para fazer 1 &3Pastilha de Plutônio&r e 1.000mB de &8Rejeito Nuclear&r. \\n\\nO &dPó de Fluorita&r pode ser feito como qualquer Pó de Metal: no &4&lTriturador&r, na &d&lCâmara de Enriquecimento&r ou até mesmo com um Martelo de Minério!"]
	quest.20054D077AFE3F56.title: "&3Pastilhas de Plutônio"
	quest.2007EF64F0406090.quest_subtitle: "&f24 de &cDano de Ataque"
	quest.200ECDC70E97D254.quest_desc: ["O Recipiente dessas Barras ustível é um tanque que pode encher recipientes com o fluido que contém.\\n\\nO Recipiente dessas Barras ustível tem três modos de enchimento:\\n\\n - Nenhum\\n - Qualquer\\n - Apenas Coisas Diretas"]
	quest.2011638351B67396.quest_desc: ["Com 2 &9Essência da Tempestade&r e 3 &9Lacrima&r podemos criar &9Astrape&r. \\n\\n&9Astrape&r é uma combinação das Armas usadas pelo &9Hippocamtus&r e &9Cindaria&r. \\n\\nEla pode esfaquear como um Tridente, só que com mais Dano e Alcance. Além disso, você pode Segurar o Clique Direito para lançar &9Lanças de Raios&r, assim como o &9Cindaria&r! \\n\\nAs &9Lanças de Raios&r ainda ricocheteiam nas Paredes! Só que agora com um Tempo de Recarga..."]
	quest.2011638351B67396.title: "&9Astrape"
	quest.201E3E41018F9521.quest_desc: ["Os &6Cactos Resinados&r são como &2Cactos&r normais, só que estes aparecem nas &cColunas Nubladas&r. \\n\\nQuer dizer, eles gostam do Calor, não precisam de &9Água&r para crescer, machucam ao tocar, há alguma diferença? \\n\\nAh sim, estes podem ser Fundidos em &6Corante Laranja&r em vez de &2Verde&r!"]
	quest.201E3E41018F9521.title: "&6Cactos Resinados"
	quest.201EE3566D4D3123.quest_desc: [
		"Para minerar &6Allthemodium&r, você precisará de uma picareta de nível &cNetherite&r ou superior! \\n\\nQuando finalmente conseguir o Minério (primeiro recomendo processá-lo com Fortuna, Occultism ou Mekanism para obter mais), você terá algumas opções do que fazer com ele. \\n\\nRecomendo fazer 2 Plataformas de Teleporte com as &6Pepitas&r! Você pode usá-las para chegar à &7&lDimensão de Mineração&r para encontrar mais &6Allthemodium&r ou a &b&lOutra Dimensão&r para encontrar outras aventuras. \\n\\nDepois disso, recomendo aprimorar sua Picareta para que você possa minerar &3Vibranium&r. O resto depende de você!"
		"{image:atm:textures/questpics/allthemodium/all_1.png width:100 height:100 align:center}"
	]
	quest.201EE3566D4D3123.title: "&6Barra de Allthemodium"
	quest.201F9E2D3FF0533F.quest_desc: [
		"Sem Aumento de Nível."
		""
		"O Item de Assinatura é Broto de Bolota Preta."
	]
	quest.201F9E2D3FF0533F.title: "&7Admin Shadow Ivory"
	quest.202B1F54D3F06DAB.quest_desc: ["Esta é a Essência de Nível 6, feita combinando 4 Supremium com um Cristal de Infusão."]
	quest.202B1F54D3F06DAB.quest_subtitle: "Tier: &56"
	quest.202B1F54D3F06DAB.title: "&5Insanium"
	quest.203C91B992BA8CF9.quest_desc: ["Para recriar a &6&lEstrela ATM&r, precisaremos de uma &dEstrela &aPatrick&r Infundida, que também precisa de uma &dEstrela &aPatrick&r. Ambas são feitas através do &6&lAltar da Estrela Rúnica&r. \\n\\nOs outros itens necessários para fazer a &dEstrela &aPatrick&r Infundida são os 4 &5Livros de Reparação&r e o &dSopro do Dragão Infundido&r, que são obtidos através do &5&lEncantamento Rúnico&r. \\n\\n&6Fragmentos de Estrela&r, que obtemos de nossas Abelhas! \\n\\nE Barras de Liga: &3Vibranium&f-&6Allthemodium&r, &5Unobtainium&f-&6Allthemodium&r e &5Unobtainium&f-&3Vibranium&r. \\n\\nTodos os três são criados de maneiras únicas descritas no capítulo &6&lAllthemodium&r! \\n\\nJogue tudo isso em um &6&lAltar da Estrela Rúnica&r, mais 85MFE, e obteremos nossa &dEstrela &aPatrick&r Infundida!"]
	quest.203C91B992BA8CF9.title: "&dEstrela &aPatrick&r Infundida"
	quest.205DE46ABA1CCC8F.quest_subtitle: "Feito na Fundição de Ligas"
	quest.205DE46ABA1CCC8F.title: "&fAbelha de Liga Condutiva"
	quest.206918773B0BD7A0.title: "Um Último Primeiro Último"
	quest.2077D64428E9C067.quest_desc: [
		"Um conceito importante dentro do AE2 é uma técnica conhecida como '&esub-rede&f', na qual uma Rede ME extra separada (uma &esub-rede&f) atua em conjunto com a rede principal para executar alguma função ou processo especializado. "
		""
		"O que separa uma sub-rede de uma rede separada completamente desconectada é geralmente o uso da &bFibra de Quartzo&f como parte do cabo. Quando colocada entre dois comprimentos de cabo de outra forma não conectados, a &bFibra de Quartzo&f não transfere dados ou canais entre os dois, transmitindo apenas &aenergia&r. "
		""
		"Assim, uma sub-rede do outro lado da Fibra pode ser alimentada inteiramente pela fonte de energia da rede principal, sem exigir nenhuma geração de energia dedicada extra."
	]
	quest.2077D64428E9C067.quest_subtitle: "Isso tem um uso além de criar cabos."
	quest.2077D64428E9C067.title: "&eEsqueci de Mencionar"
	quest.207D96D22A9B97F1.quest_desc: ["De volta para vingança, agora eles aumentarão seu Nível para 42. \\n\\nSeu Item de Assinatura é uma &4Carga de Fogo&r."]
	quest.207D96D22A9B97F1.title: "&7Revanche da Comandante Mars"
	quest.2086C73688C8BA51.quest_subtitle: "Alimente uma Abelha de Lava com um Balde de Ácido Sulfúrico"
	quest.2086C73688C8BA51.title: "&fAbelha de Ácido Sulfúrico"
	quest.208F759905CF7744.quest_desc: [
		"Portos de drone são bem rápidos, mas requerem uma distância mínima de &450 blocos&r para funcionar."
		""
		"Para usar portos de drone, coloque 2 deles e &aShift + clique direito&r com seu &5designador de alvo&r em um deles para armazenar sua localização. Abra a interface do segundo e coloque seu &5designador de alvo&r nele."
		""
		"Agora, quando o porto de drone onde você colocou o &5designador de alvo&r tiver itens, ele lançará um drone para transportá-los. "
	]
	quest.208F759905CF7744.quest_subtitle: "Sim, existem drones"
	quest.2094D1CE4BA66091.quest_desc: ["A luz é uma parte muito importante de qualquer Base. \\n\\nEla impede que Monstros apareçam, ajuda a enxergar e até adiciona mais Cor e vida às suas Construções! \\n\\nOu você pode simplesmente usar Visão Noturna, mas onde está a graça nisso!"]
	quest.209DC1E9AD4C5A84.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.20A9DB41C6BDDE53.quest_desc: ["&nForte&r \\n\\n&8Sombrio&r \\n&9Dragão&r \\n&4Lutador&r \\n\\n&nVulnerável&r \\n\\n&5Veneno&r \\n&7Aço&r"]
	quest.20A9DB41C6BDDE53.title: "&dFada"
	quest.20C3AADEE2D4800D.quest_desc: [
		"Você também pode mover Fluidos de um Tanque para outro com &cMercúrio&r. \\n\\nConecte o Fluid Extrator de onde você quer que o Fluido seja retirado, como uma Pia. Em seguida, coloque o Fluid Inserter onde você quer que o Fluido vá, como um &dSal Ammoniac&r Accumulator. Conecte ambos com Fios e ele deve estar se movendo!"
		"{image:atm:textures/questpics/theurgy/theurgy_fluid.png width:200 height:75 align:center}"
	]
	quest.20C3AADEE2D4800D.title: "Movimento de Fluidos"
	quest.20D4568857887D38.quest_desc: ["Às vezes, um Roteador pode estar em uma situação perigosa, como ao invocar um Wither. \\n\\nPara protegê-lo, você precisará de um Upgrade de Explosão. \\n\\nTNT não o quebrará, o Wither não o quebrará, apenas você."]
	quest.20D8DA523E900A52.quest_desc: ["Os Links de Energia Sem Fio ajudam a fazer com que os Cristais Sem Fio possam carregar seus itens. Quanto mais módulos, mais OP ele pode receber e a uma taxa melhor."]
	quest.20D8DA523E900A52.title: "Link de Energia Sem Fio"
	quest.20DDAC076A2479A8.quest_subtitle: "Espiral Roxa + Cerejeira Luminosa"
	quest.20E5C888891FBCFE.quest_desc: ["Quando segurado em sua mão secundária, todos os Mobs próximos deixarão de ser hostis a você. \\n\\nSeja você quem os irritou ou se eles são inerentemente raivosos, eles não serão mais. \\n\\nTem 600 usos por vez e, após ser usado ou interrompido, precisará esperar 10 minutos em seu inventário para recarregar. \\n\\nPode ser interrompido se você sofrer dano com ele ativo ou se atingir um Mob."]
	quest.20E5C888891FBCFE.title: "&bEssência da Calma"
	quest.20EC8001A05CE2C8.quest_desc: ["O Calor Sem Fio é uma maneira divertida e fácil de alimentar Fornalhas. Primeiro, coloque o Transmissor de Calor Sem Fio e insira Energia nele. Em seguida, coloque o Receptor no Transmissor para vinculá-lo. Finalmente, coloque o Receptor na seção dessas Barras ustível da Fornalha para começar a alimentá-la!"]
	quest.20F9EF925DB1CE05.quest_desc: ["O &2Altar Natural&r é uma estrutura multibloco feita de 1 &2Altar Natural&r, 20 Tábuas, 16 Tijolos de Pedra, 8 &eTijolos de Pedra Dourados&r e 4 Tijolos de Pedra Cinzelados.\\n\\nO Altar Natural consumirá aura para cada receita e é necessário para continuar progredindo no mod.\\n\\nA imagem à direita desta missão mostra a configuração do multibloco."]
	quest.20F9EF925DB1CE05.title: "&2Altar Natural"
	quest.2103BA3C535DF02A.quest_desc: ["Os &aOlhos do Ender&r podem ser jogados e seguidos para encontrar a &7Fortaleza&r! \\n\\n&7Fortalezas&r são Estruturas abaixo do solo, labirintos de celas de prisão, biblioteca e a sala do portal. \\n\\nA sala do portal contém o &aPortal do End&r. Depois de colocar &aOlhos do Ender&r em cada &aMoldura do Portal do End&r, o Portal estará pronto. \\n\\nBasta pular para dentro!"]
	quest.2103BA3C535DF02A.title: "&l&dO End"
	quest.21147C8CBF98AEB4.quest_desc: [
		"Melhorias Válidas:"
		"- Derrubador de Árvores"
		"- Quebrador de Folhas"
		"- Forno Automático"
		""
		"Habilidade Intrínseca:"
		"- Reparo com Lava"
	]
	quest.211A39A0881A4E1A.quest_desc: ["Alguns &cPokemon&r foram extintos milhões de anos atrás... \\n\\nMas alguns sortudos foram preservados pela Fossilização! \\n\\nVamos encontrá-los! Pegue seu Pincel e vá para um Sítio de Escavação. "]
	quest.211A39A0881A4E1A.title: "&cPokemon&r Ancestral"
	quest.211FD55DEB635A98.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_copper.png width:100 height:150 align:center}"]
	quest.211FD55DEB635A98.title: "&6Cobre&r"
	quest.21281EC844F00D68.quest_desc: [
		"Um Oceano diferente desta vez! O Oceano de Corais. Ele vem com Fontes Hidrotermais Vibrantes. \\n\\nAo redor da estrutura você encontrará &eAreia Suspeita&r."
		"{image:atm:textures/questpics/pokemon/find_vibrant.png width:200 height:100 align:center}"
	]
	quest.21281EC844F00D68.title: "Fontes Hidrotermais Vibrantes Pré-históricas"
	quest.212EF8601746C500.quest_desc: ["Bônus:\\n\\n - Absorção II (3:00)\\n - Velocidade II (3:00)\\n - Resistência II (3:00)\\n - Regeneração II (3:00)"]
	quest.212EF8601746C500.title: "&9Maçã de Imperium"
	quest.21398F45428CD1D1.quest_desc: ["As &6Bagas Floridas&r crescem em &bCipós Brilhantes&r no teto das &bCavernas Floridas&r. \\n\\nDentro dos &bCipós Brilhantes&r, &6Bagas Floridas&r podem aparecer e esperarão que você as colha do &bCipó&r com o Botão Direito! \\n\\nEsta é a única Fonte de Comida no &3&lOutro Lado&r."]
	quest.21398F45428CD1D1.title: "&6Bagas Floridas"
	quest.2149833F65D523E5.quest_desc: [
		"Semelhante ao Canhão de &6A&8b&6e&rlha, o Canhão de Cristal pode ser: Criado, encontrado em estruturas, ou trocado com a &5Rainha Abelha&r. \\n\\nEste é usado como uma Besta, se você tiver &5Fragmentos de Cristal de Mel&r em seu inventário, segure o botão direito para carregar um &5Cristal&r e solte para atirar!"
		"{image:atm:textures/questpics/bumblezone/bumble_cannon1.png width:75 height:150 align:center}"
	]
	quest.2150D54D18BD85EE.quest_desc: ["Finalmente você pode lançar sua &cVara&r. Isso consumirá a &2Bolota&r. \\n\\nAssim que a boia começar a balançar, clique com o botão direito para puxar o &cPokémon&r para fora! \\n\\nIsso iniciará a batalha com esse &cPokémon&r. \\n\\nEntão, você terá que usar um turno na batalha para lançar uma &cPoke&rbola neles."]
	quest.2150D54D18BD85EE.title: "Hora da Pesca"
	quest.2156C00E30424844.quest_desc: ["Os &4Tanques&r são feitos para adicionar líquidos à nossa &c&lFundição&r. \\n\\nPrincipalmente combustível. \\n\\nPrincipalmente &cLava&r! \\n\\nEssa parece ser uma das únicas maneiras de realmente abastecer a &c&lFundição&r."]
	quest.2156C00E30424844.title: "&l&cTanques da &4Fundição"
	quest.2158A566C2F54AA9.title: "Módulo de Controle de Escudo Dracônico"
	quest.215AD616E6847E9A.quest_desc: ["Cada &5Pedra Preciosa de Insanium&r equivale a 2 &5Essências de Insanium&r. Portanto, cada &5Bloco de Pedra Preciosa&r equivale a 18 &5Essências de Insanium&r. \\n\\nIsso significa que podemos pegar nossas 9.216 &aEssências de Inferium&r para os &5Blocos de Insanium&r e dobrar para obter 18.432 &aEssências de Inferium&r apenas para os 4 &5Blocos de Pedra Preciosa de Insanium&r."]
	quest.215AD616E6847E9A.title: "4 &5Blocos de Pedra Preciosa de Insanium"
	quest.21624A6500545C42.quest_desc: [
		"&3Suportes de Cultivo&r podem ser colocados sobre suas plantações para fazê-las crescer mais rápido."
		""
		"{image:atm:textures/questpics/pneumaticcraft/crop_support.png width:200 height:100 align:center}"
	]
	quest.21624A6500545C42.quest_subtitle: "Cultivos Mais Rápidos"
	quest.21693C4DE6531D73.quest_desc: [
		"O Triturador é exatamente como o nome sugere. Ele pode triturar blocos para obter os materiais de criação, como tijolos de uma escada de tijolos, ou pós de barras. \\n\\nEle precisa de energia para funcionar! \\n\\nPara construir um, são 3x2x2 de blocos de Triturador."
		"{image:atm:textures/questpics/railcraft/rail_crusher.png width:100 height:100 align:center}"
	]
	quest.21693C4DE6531D73.title: "Triturador"
	quest.216DA9782EBDFF34.quest_desc: ["Acho que este Mod é irrealista. Não me importa que livros ou itens você tenha, não acho que o Demoníaco seguirá todos os seus comandos e trabalhará como um escravo para você. \\n\\nDe qualquer forma, você pode seguir as Missões para fazer isso."]
	quest.216DA9782EBDFF34.title: "&b&lOccultism"
	quest.2171DC0B13C4BD43.quest_desc: ["O &a&lRoots Classic&r pode parecer pequeno no JEI, mas posso prometer que há muito mais nele! \\n\\nO Roots é todo sobre usar os presentes da natureza para fazer rituais.\\n\\nConfie em mim, você encontrará esses itens por toda parte!"]
	quest.2171DC0B13C4BD43.title: "&a&lRoots Classic"
	quest.217DB12EA32E1724.quest_desc: ["O &bCristal de Infusão&r é necessário para \"subir o nível\" das sementes. Por exemplo, se você combinar o cristal com 4 Essências de Inferium, obterá 1 Essência de Prudentium.\\n\\nMais tarde, você poderá criar um Cristal de Infusão que não quebra."]
	quest.217DB12EA32E1724.title: "&bCristal de Infusão"
	quest.217DF3B66A07A8DE.quest_desc: [""]
	quest.217DF3B66A07A8DE.quest_subtitle: "&oJardim do Éden em uma única Semente."
	quest.217DF3B66A07A8DE.title: "&3&lSemente &2Dimensional"
	quest.2182492BCC1B33D8.quest_desc: ["Quando instalado em uma Colmeia, dá 5% de chance de uma nova Abelha bebê nascer toda vez que o mel é entregue.\\n\\nQuando colocado em um Apanhador, permite que o apanhador pegue apenas Abelhas bebês.\\n\\nVocê pode empilhar estes para uma chance maior."]
	quest.2182492BCC1B33D8.quest_subtitle: "Fazendo Bebês"
	quest.2182492BCC1B33D8.title: "&fMelhoria de &6Abelha Bebê"
	quest.2182F3E8D8696D6C.quest_desc: ["&cPedras do Fogo&r aparecem em Desertos, bem como em alguns Biomas no &c&lNether&r. \\n\\nMuito raramente em Praias também!"]
	quest.2182F3E8D8696D6C.title: "Encontrando &cPedras do Fogo"
	quest.2188C52C1F384DE4.quest_desc: [""]
	quest.2188C52C1F384DE4.quest_subtitle: "&oCombustível que queima para sempre (não de verdade)."
	quest.2188C52C1F384DE4.title: "&c&lCombustível do Filósofo"
	quest.219932CB19258C16.quest_desc: ["O terceiro Tier de Componente de Armazenamento, fornecendo &e16384&f bytes de armazenamento."]
	quest.219932CB19258C16.quest_subtitle: "x4^2"
	quest.219932CB19258C16.title: "&eComponente de Armazenamento 16k"
	quest.219A5BDA5A01A420.quest_desc: ["O &4Cristal de Infusão Mestre&r funciona da mesma forma que o Cristal de Infusão, mas nunca quebra."]
	quest.219A5BDA5A01A420.title: "&4Cristal de Infusão Mestre"
	quest.219AA017149C36E2.quest_desc: ["Os Tapetes de Comerciante Aprisionado matarão instantaneamente quaisquer Comerciantes Ambulantes que aparecerem perto deles!\\n\\nEstes podem ser os melhores itens de todo o pacote."]
	quest.219AA017149C36E2.quest_subtitle: "Chega de Comerciantes Irritantes!"
	quest.21A0FD474FBB49F7.quest_desc: [
		"Outra estrutura para cobrir a aridez do &5End&r, a &dCidadela em Ruínas&r. \\n\\nA &dCidadela em Ruínas&r é um palácio de &5Obsidiana&r, Pedra do End e &dPurpur&r. \\n\\nNo palácio, você encontrará Baús, Caixas de Shulker, Shulkers e até a única &dPedra do Vazio&r! \\n\\nSó tome cuidado com os já mencionados Shulkers, &dEndermaptera&r e &dGolems do End&r."
		"{image:atm:textures/questpics/cataclysm/cataclysm_citadel.png width:200 height:100 align:center}"
	]
	quest.21A0FD474FBB49F7.title: "&dCidadela em Ruínas&r: Lar do &d&lGuardião do End&r"
	quest.21A4FE1741E4E78C.quest_desc: [
		"A &#65C2A6Mineradora&r é um multibloco para gerar recursos. Ela precisa de &aBrocas&r e &7Vapor&r para funcionar."
		""
		"Cada iteração tem uma chance de consumir a &aBroca&r. &aBrocas&r melhores dão recursos melhores."
		""
		"A Mineradora a Vapor só pode usar &#DEA14BCobre&r e &#DE9531Broca de Bronze&r. Ela também pode usar &#8A5C1ETerra&r para gerar Pedras."
	]
	quest.21A4FE1741E4E78C.quest_subtitle: "Infinite Resources"
	quest.21A4FE1741E4E78C.title: "&fA &7Mineradora a Vapor"
	quest.21A90474590FCDB8.quest_desc: ["A \"Fornalha\" é uma versão aprimorada de uma fornalha vanilla que pode ser melhorada para maior velocidade e eficiência."]
	quest.21A90474590FCDB8.title: "\"Fornalha\""
	quest.21AB14A8553896E9.quest_desc: ["Pessoal, acho que não me ouviram direito, eu disse &e&lProductive Bees&r! Ah, espere, há outro Mod! \\n\\nEste está relacionado às &e&lProductive Bees&r, pois você precisará delas para cruzar Árvores. \\n\\nNão, as Árvores não usam Trigo para cruzar, elas usam Abelhas. \\n\\n&oAs Árvores e as Abelhas&r."]
	quest.21AB14A8553896E9.title: "&2&lProductive Trees"
	quest.21B8116BDADD7476.quest_subtitle: "Papaya + Cacao"
	quest.21B96130EA516B82.quest_desc: ["\"Eu sou o Ferro Comprimido Man!\" \\n\\nPode ser usado e atualizado com Ar comprimido!"]
	quest.21B96130EA516B82.quest_subtitle: "15"
	quest.21B96130EA516B82.title: "&8Armadura Pneumática"
	quest.21BEE9867796933A.quest_desc: [" Carregada por gerações por &6nômades&r e &6mensageiros&r, a &5Flauta do Cavaleiro&r produz um som familiar para qualquer &9animal de montaria&r. Uma única nota pode &cchamar&r uma montaria para o seu lado, enquanto outra sinaliza para que ela &cpause&r pacientemente até ser necessária. \\n\\n Seu poder misterioso permite ao portador &5armazenar&r até &c2 montarias&r dentro da flauta, prontas para serem &cliberadas&r ou &6chamadas&r à vontade. Alterne entre as montarias armazenadas ao se &cagachar&r e girar a roda do mouse. Para liberar completamente uma montaria, basta se &cagachar&r e clicar com o botão direito, dando ao cavaleiro controle total sobre seus &9companheiros&r. \\n\\n- &lPossui 1 habilidade: \\n\\n &6Estábulo&r: \\n Clique com o botão direito em um &9animal de montaria&r domesticado para colocá-lo dentro da &6Flauta do Cavaleiro&r, e clique com o botão direito novamente para &cliberá-lo&r ou &6chamá-lo&r. Armazene até &c2&r montarias e alterne entre elas enquanto estiver &cagachado&r. Para liberar totalmente uma montaria, se &cagache&r e clique com o botão direito. \\n\\n- Uma &6relíquia&r para aqueles que guiam suas &6montarias&r com uma &6canção&r… e nunca deixam um amigo para trás."]
	quest.21BEE9867796933A.quest_subtitle: "Chame suas montarias, armazene-as com segurança e domine a cavalgada"
	quest.21BEE9867796933A.title: "&cFlauta do Cavaleiro&r"
	quest.21BFDE6AD1C0F62A.quest_desc: ["Obviamente, na vida real, há muito mais do que apenas &6Abelhas de Mel&r ou &6Mamangavas&r, então a &6&lBumblezone&r adiciona mais &8A&6b&8e&6l&8h&6a&8s&r e &8A&6b&8e&6l&8h&6a&8s&r únicas! \\n\\nDe &4&lRabo Vermelho&r &8A&6b&8e&6l&8h&6a&8s&r, a &9Azuis&r &8A&6b&8e&6l&8h&6a&8s&r, a &8A&6b&8e&6l&8h&6a&8s&r Neopolitanas!"]
	quest.21BFDE6AD1C0F62A.title: "Variantes de &8A&6b&8e&6l&8h&6a&8s&r"
	quest.21C2458FED19363C.quest_desc: ["Ele usa &aEssência&r junto com uma criatura em uma Ferramenta de Prisão de Mob para gerar uma cópia dessa criatura."]
	quest.21C2458FED19363C.quest_subtitle: "Gerador do Industrial Foregoing"
	quest.21D1EA9F80823BF2.quest_desc: ["Vou assumir que você tem fabricado coisas, certo? Afinal, é &2&lMineCRAFT&r.\\n\\nClaro, você poderia fabricar em seu Inventário usando a Grade de Fabricação 2x2, mas isso não o levará longe. Precisamos melhorar fazendo uma &6Bancada de Trabalho&r!"]
	quest.21D1EA9F80823BF2.title: "Colocando a Fabricação no &2&lMinecraft"
	quest.21D8B88155648EA6.quest_desc: [
		"Vamos lá, todos nós sabemos para que você está aqui... &5&lMÁQUINAS&r! \\n\\nAs &5Máquinas&r são nossas pequenas fábricas, cada uma fará algo único para nos dar mais &eItens&r. Siga as Missões individuais para descobrir o que cada uma faz. \\n\\nAqui falarei mais sobre as configurações e &8Melhorias&r! "
		"{@pagebreak}"
		"Todas as &5Máquinas&r são diferentes, mas as cores dos slots e barras dirão para que servem! &aVerde Claro&f: &aEnergia&r. &4Vermelho&f: &4Item/Fluido/Químico Inicial&f. &9Azul&f: &9Produto&f. &3Ciano&f: &3Segundo Produto&f. &eAmarelo&f: &eTipos de Infusão&r. \\n\\nCada &5Máquina&r tem lados de configuração padrão. É aqui que os &eItens&r serão inseridos e ejetados. Você pode alterá-los na INTERFACE da &5Máquina&r em Configurações de Lados. \\n\\nIsso mudará para &eItens&f, &bFluidos&f, &cQuímicos&f e &aEnergia&r, mas cada um tem lados semelhantes que podem ser alterados. &4Vermelho&f: &5Entrada&f. &6Laranja&f: &6Segunda Entrada&f. &9Azul&f: &9Saída&f. &3Ciano&f: &3Segunda Saída&f. &5Roxo&f: &5Entrada e Saída&f. &aVerde Claro&f: &aEnergia&f. &eAmarelo&f: &eExtra&r como &cTipos de Infusão&r. \\nVocê precisará definir a INTERFACE para Ejeção Automática se quiser que os &eItens&r sejam inseridos e ejetados! "
		"{@pagebreak}"
		"Algumas &5Máquinas&r também podem usar &8Melhorias&r! Elas estão no canto superior direito da GUI. \\n\\nAqui você pode ver quais &8Melhorias&r a &5Máquina&r pode usar. Quando você as coloca, ela lhe dirá quantas pode conter. &eMelhorias de Velocidade&8 podem conter mais, enquanto as de Abafamento não precisam de mais!"
	]
	quest.21D8B88155648EA6.title: "&l&5Máquinas"
	quest.21EA29A8C7F950CE.quest_desc: ["&bDiamantes&r, o pilar do &2Minecraft&r, e aparentemente das fornalhas aprimoradas...\\n \\nEstas funcionam ainda mais rápido, levando apenas 80 tiques ou 4 segundos para fundir itens. Isso é mais rápido que um Alto-forno! \\n \\nElas são criadas apenas por &eFornalhas de Ouro&r e podem ser transformadas em &3Fornalhas de Cristal&r ou &aFornalhas de Esmeralda&r."]
	quest.21EA29A8C7F950CE.title: "&bFornalha de Diamante"
	quest.21EE03301BEFB449.quest_desc: ["Ela aumentará seu Limite de Nível para 22. \\n\\nSeu Item de Assinatura é a &7Lente de Alcance&r."]
	quest.21EE03301BEFB449.title: "&7Comandante Jupiter"
	quest.21F3379C904BFD50.quest_desc: ["O &6Aquecedor Resistivo&r também gerará &6Calor&r, mas em vez de usaressas Barras ustível de Fornalha, ele usará &aEnergia&r! \\n\\nAo alimentá-lo com &aEnergia&r, podemos escolher quanto &6Calor&r ele produzirá. \\n\\nQuanto mais &6Calor&r ele produz, mais &aEnergia&r ele consome! \\n\\nO &6Calor&r máximo é 9.999.999 e alguma coisa."]
	quest.21F3379C904BFD50.title: "&6Aquecedor Resistivo"
	quest.21F4CFF171246537.quest_subtitle: "Tier: &b4"
	quest.21F654C968722841.quest_subtitle: "Tier: &b4"
	quest.21FDF07571B5DCA7.quest_subtitle: "Alimente uma Abelha de Ferro com Geleia Primogel"
	quest.21FDF07571B5DCA7.title: "&fAbelha de Ferricore"
	quest.22151D56616559CB.quest_desc: ["Estes podem ser encontrados em baús dentro de Shipwrecks."]
	quest.22151D56616559CB.quest_subtitle: "Baús de Shipwreck"
	quest.2215FB0777D7029D.quest_desc: ["Travas, chuteiras, grampos, seja lá o que forem! \\n\\nAs &7Botas Firmes&r mantêm você firme em seus pés. Você não será derrubado por ataques e não escorregará mais no gelo."]
	quest.2215FB0777D7029D.quest_subtitle: "Pés"
	quest.2215FB0777D7029D.title: "&7Botas Firmes&r"
	quest.22171982D22CE15F.quest_desc: ["Em vez de cada &a&lPeça do Meka-Traje&r ter sua própria Carga individual, agora elas compartilharão uma única Carga. \\n\\nIsso é importante para manter todas as &a&lPeças&r Carregadas. \\n\\nE isso é importante para manter você vivo!"]
	quest.22171982D22CE15F.quest_subtitle: "Peitoral"
	quest.22171982D22CE15F.title: "&aUnidades de Distribuição de Energia"
	quest.221C9EDA651144BA.quest_desc: ["Que &9Água&r? \\n\\nCom o &3Amuleto do Afundamento&r você se move através da &9Água&r como se fosse Ar! Mas ainda não consegue respirar debaixo d'água..."]
	quest.221C9EDA651144BA.quest_subtitle: "Colar"
	quest.221C9EDA651144BA.title: "&3Amuleto do Afundamento&r"
	quest.2224AA108FC006F3.quest_desc: ["O Carregador Rápido de Revólver não é, na verdade, uma Melhoria, mas sim um item separado que ajuda. \\n\\nEncha-o com Cartuchos como o &d&lRevólver&r, mas agora, sempre que precisar recarregar o &d&lRevólver&r, você pode simplesmente clicar com o botão direito com ele para recarregar instantaneamente!"]
	quest.2224AA108FC006F3.quest_subtitle: "Eu atirei 6 vezes? Ou apenas 5?"
	quest.2226555D9552236E.quest_subtitle: "Aparece na maioria dos Ninhos de Madeira"
	quest.2226555D9552236E.title: "&fAbelha Carpinteira Amarela"
	quest.222739E77C745519.quest_subtitle: "Tier: &b4"
	quest.222D08F43B995FED.quest_subtitle: "Tente amassar isso"
	quest.222E16E832A13624.quest_desc: [
		"Nas profundezas das Cavernas de Espeleotema, você pode encontrar uma espécie de Oásis! \\n\\nAqui, &7Cascalho Suspeito&r surgirá no chão dele."
		"{image:atm:textures/questpics/pokemon/find_dripstone.png width:200 height:100 align:center}"
	]
	quest.222E16E832A13624.title: "Oásis de Espeleotema Pré-histórico"
	quest.223A5BDB5056B781.quest_desc: ["Capturando é um Encantamento para Espadas para fazer com que Criaturas raramente soltem seus Ovos. É raro, então continue procurando por um e confira o &5&lApothic Enchanting&r para ajudar. Cada nível oferece 0,5% de chance de obter um Ovo a cada morte e o nível mais alto que você pode obter normalmente é VII (7)."]
	quest.224716A537F2FFA0.quest_desc: ["Os &8Tomos de Armadura&r são usados para obter &5Encantamentos&r que são usados apenas em Armaduras. Todos os &8Tomos&r podem obter &5Proteção&f, &5Proteção contra Explosões&f e &5Proteção contra Fogo&r. \\n\\nCada um também dá um reservado para uma certa parte da Armadura. Botas darão &5Passos Profundos&r e Elmos darão &5Afinidade Aquática&r. \\n\\nSe você quer a melhor chance de obter apenas &5Proteção&r, tente o &8Tomo de Peitoral&r!"]
	quest.224716A537F2FFA0.title: "&8Tomos de Armadura"
	quest.224C07AC71C5F40E.quest_desc: ["Aplica &lFarinha de Osso&r ou &#8B4513Fertilizante&r em plantas em sua área de trabalho. Isso continuará aplicando &#8B4513Fertilizante&r na mesma plantação até que essa plantação não possa mais aceitar &lFarinha de Osso&r antes de passar para a próxima planta. Isso significa que a máquina pode ficar presa em plantas que sempre aceitam &lFarinha de Osso&r, como &eGirassóis&r, ou plantas que nunca atingem seu estado final de crescimento.\\n\\nEsta máquina suporta Adicionais de Alcance."]
	quest.224CE21E56703F6E.quest_desc: ["A Varinha pode ser usada para ativar o Altar de Infusão, basta clicar com o botão direito no altar para ativar o processo de infusão."]
	quest.224CE21E56703F6E.quest_subtitle: "Você é um Mago (Insira seu nome)!"
	quest.224CE21E56703F6E.title: "&2Varinha"
	quest.22572456571C3F8D.quest_desc: ["O &3Módulo de Carregamento&r despressuriza qualquer coisa pressurizável em recipientes para os quais ele aponta."]
	quest.226187AA3F1B6DB1.quest_desc: ["Misturar &#D4C35DAreia&r, &8Pederneira&r, &#8DF0EENitrogênio&r e &#69C9C7Tolueno&r nos dará &#D66D40TNT Industrial&r."]
	quest.2262AB9F934165D0.quest_desc: ["Eu não me importo como você conseguiu, só preciso que você o consiga! \\n\\nO &8&lImmersive Engineering&r adiciona muitos outros usos para o &8Aço&r além de simples construções, quase tudo precisará de &8Aço&r para ser feito! \\n\\nFerramentas, Peças Mecânicas e Blocos de Construção principalmente. Muitos são feitos com &8Placas de Aço&r ou &8Andaimes&r. \\n\\nVocê precisará de muito, mas o &l&cAlto-forno Rústico&r e o &l&6Alloy Kin&r não podem ser automatizados, então talvez precisemos de um... "]
	quest.2262AB9F934165D0.title: "&8Lingote de Aço"
	quest.22647504C37E547C.quest_subtitle: "Alimente uma Abelha Radioativa com um Bloco de Cyanita"
	quest.22647504C37E547C.title: "&fAbelha de Cianite"
	quest.226B8B60AF864FEF.quest_desc: [
		"Para aprimorar &6Allthemodium&r para &3Vibranium&r, você precisará de outro Molde de Forja.\\nEste pode ser encontrado ao Escovar Areia das Almas Suspeita.\\n\\nEla é encontrada em Bastiões no &l&cNether&r.\\n"
		"{image:atm:textures/questpics/allthemodium/all_bastion.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/allthemodium/all_soul.png width:200 height:100 align:center}"
	]
	quest.226B8B60AF864FEF.title: "&3Molde de Ferraria de Vibranium&r"
	quest.22702838FC507A2E.quest_desc: ["O Canteiro Hidropônico usa Energia e &9Água&r para cultivar plantações e mudas plantadas nele. Ele suporta praticamente qualquer plantação que você possa imaginar. Você também pode fornecer &bGás de Éter&r para que a máquina colha automaticamente a plantação e coloque os resultados da plantação em seu armazenamento interno. Isso também pode coletar dados de plantação para um Processador de Simulação Hidropônica, para usar em um Canteiro Hidropônico Simulado.\\n\\nMudas exigirão espaço para crescer."]
	quest.22739522F0D33D7B.quest_desc: ["Gloomgourds aparecem e são cultivados como Abóboras. \\n\\nAssim como Abóboras, eles podem ser transformados em Torta ou até mesmo em Jack-O-Lanterns! \\n\\nDiferente das Abóboras, eles podem ser transformados em explosivos..."]
	quest.227BEFEF59977CC4.quest_subtitle: "Pau-rosa + Teca"
	quest.227DBA8836021B0B.quest_desc: ["Em Ars Nouveau, o sistema de energia para máquinas é chamado de &9Fonte&r. \\n\\nPara começar a coletar alguma Fonte, precisaremos de um Jarro de Fonte. \\n\\nA Fonte também pode ser movida com baldes, ou quebrando e pegando Jarros de Fonte."]
	quest.227DBA8836021B0B.quest_subtitle: "Armazenando Fonte"
	quest.227E9783382527CA.quest_desc: ["Os &cCorredores&r são diferentes das outras Armaduras — eles usam &aEnergia&r em vez de um &cCombustível Químico&r. \\n\\nQuando Carregados e presos aos seus Pés, você pode pressionar (B) para ativá-los, e pressionar novamente para alternar entre os modos. \\n\\n&2Normal&r: os &cCorredores&r te protegem de Dano de Queda e pulam automaticamente sobre Blocos para você. \\n\\n&6Seguro&r: previne Dano de Queda, mas não pula automaticamente. (O método preferido). \\n\\n&4Desativado&r: os Corredores não protegem nem pulam automaticamente — só ficam estilosos! \\n\\nVocê também pode Melhorar os &cCorredores&r para dar a eles Proteção com Armadura, assim como o &cJetpack&r."]
	quest.227E9783382527CA.title: "&cCorredores"
	quest.228CB313BAB6406E.quest_desc: ["Aparentemente, este não tinha uma receita por padrão! É como se o desenvolvedor do mod não quisesse que você usasse suas Locomotivas &5Criativas&r no modo Sobrevivência. \\n\\nEu não achei que elas eram tão OP, então aproveite seus &5Trens&r! \\n\\nEles funcionam como &3Locomotivas&r normais, só que sem precisar dessas Barras ustível ou Energia! Só precisam de &6Trilhos&r."]
	quest.228CB313BAB6406E.title: "&5&lLocomotiva &8Criativa"
	quest.2296CE4418AE62D4.quest_desc: ["&6Armadura de Allthemodium&r mas com bônus para os feitiços do &d&lArs Nouveau&r!"]
	quest.2296CE4418AE62D4.quest_subtitle: "24"
	quest.2296CE4418AE62D4.title: "&6Equipamento Arcanista de Allthemodium"
	quest.22A0A9C81A5C85A1.quest_subtitle: "Segurando tudo junto"
	quest.22AD9DF2BCC04575.quest_subtitle: "Gerando a energia"
	quest.22AD9DF2BCC04575.title: "&fGeração de Eletricidade"
	quest.22ADCF96AE3E609B.quest_desc: ["&dMudas Ancestrais&r são criadas usando o &aRitual da Floresta&r. Quando crescem, as árvores tentam manter níveis normais de aura (nem muito altos, nem muito baixos).\\n\\nSe a aura cair, as folhas começarão a decair e a reverter o processo."]
	quest.22ADCF96AE3E609B.quest_subtitle: "Não aquelas Mudas Ancestrais"
	quest.22ADCF96AE3E609B.title: "Árvores Ancestrais"
	quest.22B8D57337944D9C.quest_desc: ["As &#DF9DE0Barras Quentes de Titânio&r agora podem ser resfriados no &#5CD1CFFreezer a Vácuo&r para obter &#F069F0Barra de Titânio&r utilizáveis."]
	quest.22B8D57337944D9C.title: "&#F069F0Titanium Ingot"
	quest.22B99F88295EC967.quest_desc: ["&9Subir o Nível&r dos &cPokemon&r os tornará mais fortes em múltiplos atributos e será necessário para certos Golpes e Evoluções. \\n\\n&cPokemon&r ganham &9Experiência&r toda vez que Vencem uma Batalha, mais contra &4Treinadores&r. Também ao Capturar outros &cPokemons&r. \\n\\nVocê pode verificar quanta &9Experiência&r o &cPokemon&r tem ou precisa para Subir de Nível no Menu da Equipe!"]
	quest.22B99F88295EC967.title: "Subindo o nível do seu &cPokemon"
	quest.22BB55249EF2E819.quest_desc: ["A &l&6Bumblezone&r é um Mod de Exploração que adiciona uma dimensão totalmente nova dentro de nossas &eColmeias&r. \\n\\nJá se perguntou o que as &6A&8b&6e&8l&6h&8a&6s&r fazem em suas &eColmeias&r? Bem, você pode descobrir se aventurando nela!"]
	quest.22BB55249EF2E819.quest_subtitle: "Bem-vindo ao Bumble!"
	quest.22BB55249EF2E819.title: "&l&6A Bumblezone!"
	quest.22C4318523A43B49.quest_desc: ["Os &eTerminal&f fornecem acesso a qualquer conteúdo de uma Rede ME. O &eTerminal ME&f padrão simplesmente lista tudo na rede como uma grande grade para puxar e inserir, semelhante a um único inventário.\\n\\nO &eTerminal de Fabricação ME&f é uma extensão do ME Terminal que também fornece uma grade de criação embutida, permitindo a criação conveniente usando qualquer item contido na rede e visível através da tela do terminal."]
	quest.22C4318523A43B49.quest_subtitle: "[piada de usuário de Linux vai aqui]"
	quest.22C4318523A43B49.title: "Terminais"
	quest.22D0C3F454F5E8F1.quest_subtitle: "Tier: &b4"
	quest.22D2CFDDB06C720C.quest_desc: ["Ferramentas são muito importantes no &2&lMinecraft&r, mas o espaço no inventário também é. Então, por que não liberar espaço criando uma Paxel! \\nPaxels são uma combinação de &ePicaretas&r, &eMachados&r, e &ePás&r. \\n\\nElas podem descascar madeira, fazer caminhos e minerar quaisquer blocos que uma picareta/machado/pá do mesmo Tier consiga!"]
	quest.22D2CFDDB06C720C.title: "Paxel"
	quest.22D383BAEF8A2B39.quest_desc: ["Você conhece o lendário Paxel? Uma combinação de Picaretas, Machados e Pás? Isto é semelhante, sendo uma combinação de Espadas, Picaretas e Pás! Ele faz tudo o que as Ferramentas Dracônicas fazem!"]
	quest.22D383BAEF8A2B39.title: "Cajado Dracônico"
	quest.22E007025C19EC0A.quest_desc: ["O &l&7Railcraft&r, juntamente com os Trens, adiciona algumas Pedras para Decoração! \\n\\nPedra de Pedreira e Pedra Abissal podem ser criadas juntas para fazer versões Polidas, Cinzeladas ou de Tijolo! \\n\\nE não se esqueça de Escadas e Lajes! "]
	quest.22E007025C19EC0A.title: "&fPedras do &l&7Railcraft&r"
	quest.22F5F931D38E5187.quest_desc: ["Pedras Carmesins são encontradas dentro de Postos Avançados de Saqueadores, elas são um pouco raras, mas não ajuda que nos deem apenas 2 Baús! \\n\\nElas não são usadas para novas receitas, mas diminuirão o uso de Almas na &6&lForja&r."]
	quest.22F5F931D38E5187.title: "&cPedra Carmesim"
	quest.22F80D267321BFC5.quest_desc: ["O &3Gerenciador Auto-fabricador&r permite que você acesse todos os seus &3Auto-fabricadores&r a partir de um único bloco.\\n\\nEspero que você não tente organizar tudo, para o seu próprio bem."]
	quest.22F80D267321BFC5.title: "&3Gerenciando Auto-fabricadores"
	quest.22FCEAECFBC734DD.quest_desc: ["Árvores de &6Bolotas&r aparecem em toda parte! Apenas bem raras. \\n\\nElas são do mesmo tamanho que Carvalhos, com Folhas &eAmarelas &6Amarronzadas&r e Troncos &6Marrons&r. \\n\\nNas Folhas, &6Bolotas&r irão Brotar. Uma vez Maduros, você pode Clicar com o Botão Direito neles para Colher. \\n\\nExistem 7 &6Bolotas&r: &cVermelho&f, &eAmarelo&f, &aVerde&f, &bAzul&f, &dRosa&f, &0Preto&r, e Branco. A Cor importa para outras Receitas."]
	quest.22FCEAECFBC734DD.quest_subtitle: "Não Bolota, isso é diferente!"
	quest.22FCEAECFBC734DD.title: "&6Bolota"
	quest.230463E830D6FFEB.quest_desc: ["Agora que temos plástico, o próximo passo é obter alguns PCBs finalizados, primeiro faça alguns &3PCBs Vazios&r na Pressure Chamber."]
	quest.230463E830D6FFEB.quest_subtitle: "O caminho para os PCBs"
	quest.230582AAFC0A1632.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.230EEE4671B46D0C.quest_desc: ["A &9Pedra Sombria&r aparece nas profundezas subterrâneas perto de &cLagos de Lava&r, como no Nível Y -54. \\n\\nÉ o Bloco mais usado para o &6&lForbidden \\& Arcanus&r, todos os Multiblocos o usarão como base. \\nCertifique-se de pegar uma tonelada deles!"]
	quest.230EEE4671B46D0C.title: "&9Pedra Sombria"
	quest.231E0C0A9B0C0509.quest_desc: ["Este pode ser anexado à sua &c&lMochila Acumuladora&r. \\n\\nQuando a &c&lMochila&r é usada, &eItens&r próximos serão sugados para o seu Inventário!"]
	quest.23254CE8487D2E68.quest_desc: ["O &8Construtor de Wither&r é uma das melhores máquinas que você pode obter do &lIndustrial Foregoing&r, e por causa disso é caro. \\n\\nPrimeiro, você precisará das partes que compõem um &8Wither&r e um drop do &8Wither&r. \\n\\nEntão, você precisará de uma &6Estrutura de Máquina Suprema&r, que você precisa de &bGás de Éter&r para fazer. Adivinhe o que você precisa para o &bGás de Éter&r? Isso mesmo! Um &8Wither&r! Você precisará de uma Broca a Laser trabalhando em um &8Wither&r para obtê-lo. \\n\\nOs &8Withers&r gostam de fugir e matar coisas, então uma Câmara de Estase tornaria a extração deles mais fácil! "]
	quest.23254CE8487D2E68.title: "&8Construtor de Wither"
	quest.2329AA0AFBEF1E13.quest_desc: [
		"&e&lPipez&r é o Mod de &f&lLogística&r mais simples. É tão simples que o mod inteiro cabe nesta página de Missões, com espaço para mais Mods!"
		""
		"Anexe o Cano específico onde você quer mover itens e use a Chave de Cano para configurar qual lado Puxa, Empurra ou não conecta."
		""
		"Outras Chaves também funcionam com &e&lPipez&r!"
		""
		"(Pode causar lag quando usado em massa, mas ainda não tanto quanto os canos do &5&lMekanism&r)."
	]
	quest.2329AA0AFBEF1E13.title: "&l&ePipez"
	quest.232A06C9FF0EE7B2.quest_desc: ["Sementes de Menril podem ser usadas para automatizar Bagas de Menril, Troncos de Menril e Mudas de Menril."]
	quest.232A06C9FF0EE7B2.quest_subtitle: "Automatizando Menril"
	quest.2338E5269CA23C91.quest_desc: ["A &3Netherite Drill Bit&r é a melhor ponta de broca, é ainda melhor que a Ponta de Broca de Diamante."]
	quest.2338E5269CA23C91.quest_subtitle: "Esta é a Melhor Ponta"
	quest.233C7CAA573D6045.quest_desc: ["Os módulos determinam a ação que o Roteador executa.\\n\\nEles podem fazer com que seu Roteador puxe itens de Baús, ou coloque itens em baús, ou até mesmo ambos! E muito mais!\\n\\nOs módulos vão para o próprio Roteador e múltiplos podem ser instalados.\\n\\nFiltros e Melhorias vão para os próprios Módulos."]
	quest.233C7CAA573D6045.title: "&lMódulos"
	quest.234DC1702333EB18.quest_desc: [
		"O add-on &dAEInfinityBooster&r fornece dois boosters sem fio personalizados para o &9Applied Energistics 2&r."
		""
		"Com eles, você obtém &lalcance de conectividade infinito&r, com suporte opcional para &eacesso entre dimensões&r."
		""
		"Ideal para manter seus sistemas AE2 sempre conectados, esteja você onde estiver!"
	]
	quest.234DC1702333EB18.quest_subtitle: "Não vou escrever a frase do Toy Story!"
	quest.234DC1702333EB18.title: "Infinity Booster"
	quest.23503DF29786B519.quest_desc: [
		"Sem Aumento de Nível."
		""
		"O Item de Assinatura é Bola Ferro."
	]
	quest.23503DF29786B519.title: "&3Elite dos Quatro Moleman"
	quest.235273F7C9A9B0D0.quest_subtitle: "3/5"
	quest.235273F7C9A9B0D0.title: "Parte inferior direita da &6&lEstrela ATM&r"
	quest.2354BC5330350DF6.quest_desc: ["Se &aEsmeraldas&r não são a sua praia, a &3Crystal Furnace&r pode ser o que você quer! \\n \\nFunciona da mesma forma que uma &aEmerald Furnace&r em 40 tiques. \\n \\nFeita com uma &bFornalha de Diamante&r e pode ser transformada em uma &dObsidian Furnace&r. \\n \\n(Não, você não pode ver os itens derretendo dentro dela, é apenas transparente)"]
	quest.2354BC5330350DF6.title: "&3Crystal Furnace"
	quest.235E3C386E8D36A3.quest_desc: [
		"É aqui que a separação entre &4Estante de Livros Infernais&r e &bEstante de Livros da Maré&r termina! \\n\\nPrimeiro, precisaremos criar uma &9Estante de Livros Profunda Adormecida&r. Estas são apenas 6 &8Ladrilhos de Ardosiabissal Rachados&r e 3 &7Livros&r. \\n\\nEntão, precisaremos de &a60 Eterna&r, &c40% Quanta&r e &540% Arcana&r. Podemos obter isso com 12 &bEstantes Marinhas Cristalinas&r ou 12 &4Estantes Infernais Luminosos&r! \\n\\nFinalmente, podemos &d&lInfundir&r nossas &9Estante de Livros Profunda Adormecida&r em &9Estante de Livros Profunda&r regulares!"
		"{image:atm:textures/questpics/apothic/enchant_deepshelf.png width:100 height:100 align:center}"
	]
	quest.235E3C386E8D36A3.title: "&9Estante de Livros Profunda"
	quest.23631A4A743D4F0C.quest_desc: ["Nem reclame deste. \\n\\nExistem dezenas de maneiras de obter Ferro e é necessário até mesmo para a progressão normal. \\n\\nVocê obterá Ferro, o transformará em um Bloco e o deixará bonito!"]
	quest.23631A4A743D4F0C.title: "&fMetais &l&bChipped"
	quest.236C936FE3BA8396.title: "Módulo de Voo Caótico"
	quest.236EA8D18ECD5FE8.quest_desc: ["Este é bem único em seu aparecimento! Depois que você mata o &b&lIgnis&r, há uma chance de &bBerserkers Incendiados&r aparecerem em Fortalezas do Nether. \\n\\nEles são como &bRevenants&r, só que em vez de Escudos, eles têm Espadas! Suas Espadas não protegem contra danos como os Escudos, em vez disso, causam mais dano. \\n\\nEles têm muito menos vida, com 65 &4Corações&r e droparão Brasas Moribundas ao serem mortos. 4 Brasas Moribundas podem ser transformadas em 1 &bCinza Ardente&r."]
	quest.236EA8D18ECD5FE8.title: "&bBerserker Incendiado"
	quest.23708582B1064C9D.quest_desc: [
		"Um &#46DBBBCircuito&r exigirá alguns desses componentes básicos para funcionar. "
		""
		"Automatizar partes disso será útil no futuro."
	]
	quest.23708582B1064C9D.title: "Capacitância e Resistência"
	quest.23737103592776C2.quest_desc: ["A &3Lâmpada de Querosene&r é uma ótima fonte de luz que usa combustível (sendo o Querosene o melhor) para produzir luz."]
	quest.23737103592776C2.quest_subtitle: "Mega Tochas não são nada!"
	quest.237D11FF5B09BA88.quest_desc: [
		"Habilidade Intrínseca:"
		"- Sem Pisotear"
		"- Colheita Automática"
		"- Crescimento Acelerado de Culturas III"
		""
		"Upgrade Válido:"
		"- Teletransportador de Drops"
	]
	quest.23820B0DCEC022D1.quest_subtitle: "Resin + Lumber"
	quest.23820B0DCEC022D1.title: "&fAbelha de Plástico"
	quest.23A05E86B1DF7B1E.quest_desc: [
		"Aumento de nível para 80."
		""
		"Item de Assinatura é &0Guarda-Chuva Utilitário&r."
	]
	quest.23A05E86B1DF7B1E.title: "&7Ariana, Admin. da Equipe Rocket"
	quest.23A5F5C9BC7B5CC7.quest_subtitle: "Ameixa + Noz"
	quest.23AE395433AED3C0.quest_desc: ["A &6&lEstrela ATM&r precisa de alguns Blocos para manter os diferentes Itens juntos e formar sua forma de estrela! \\n\\nOs primeiros Blocos são &5Blocos&r de &5Liga&r de &5Unobtainium&r - &6Allthemodium&r. Você precisa usar um Aparato de Encantamento do &d&lArs Nouveau&r para fazê-los!"]
	quest.23AE395433AED3C0.title: "O Invólucro da &6&lEstrela"
	quest.23B68F19A04AF5D7.quest_desc: ["Muitas destas &7Unidades&r para as &a&lCalças do Meka-Traje&r funcionam como Encantamentos. \\n\\nEsta aqui é uma 2 em 1! Tanto Afinidade com o Ar quanto &bAfinidade Aquática&r. \\n\\nVocê não terá mais uma penalidade de Mineração ao Nadar, Voar ou Cair."]
	quest.23B68F19A04AF5D7.quest_subtitle: "Calças"
	quest.23B68F19A04AF5D7.title: "&7Unidade de Estabilização Giroscópica"
	quest.23C36E4B5DCEBFDD.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.23D1F785BACBD39B.quest_desc: ["Às vezes nós simplesmente não conseguimos encontrar aquele &cPokémon&r &dFêmea&r para &dCruzar&r. \\n\\nEntão por que não transformar magicamente um dos nossos &bMachos&r em uma &dFêmea&r! Ou vice-versa! \\nApenas Clique com o Botão Direito em um &cPokémon&r com o &dOrbe de &aTransmutação&r e eles trocarão de Gênero. \\n\\nEu me pergunto se você pode usá-lo em um Ditto para fazer uma Ditta?"]
	quest.23D1F785BACBD39B.title: "&dOrbe de &aTransmutação"
	quest.23DAF5129F244C2C.quest_desc: ["&nForte&r \\n\\n&cFogo&r \\n&6Terra&r \\n&6Pedra&r \\n\\n&nVulnerável&r \\n\\n&eElétrico&r \\n&2Grama&r"]
	quest.23DAF5129F244C2C.title: "&bÁgua"
	quest.23DB52ECA259F36D.quest_desc: [
		"Água Pesada em um &#45BF56Reator&r produz &#EB5266Trítio&r e &#C09EDEVapor de Água Pesada&r."
		""
		"O &#EB5266Trítio&r é usado para componentes avançados, enquanto o &#C09EDEVapor de Água Pesada&r pode ser reciclado em &#8C47C9Água Pesada&r em um &#DEAB47Trocador de Calor&r."
	]
	quest.23DBBEFCE729AEA3.quest_desc: ["\"Ao fazer um desejo a uma estrela\" \\n\\nVocê será capaz de &cDynamaxizar&r seu &cPokémon&r! \\n\\nO &cDynamax&r é usado em batalha para usar uma versão &cMax&r dos movimentos do seu &cPokémon&r. \\n\\nIsso fará com que eles cresçam muito em tamanho, ganhem mais vida e tornem seus movimentos ainda mais poderosos!"]
	quest.23DBBEFCE729AEA3.title: "Estrela do Desejo"
	quest.23DE60E57136C207.quest_desc: ["O armazenamento de Energia infinito mais fácil, precisando apenas de 4 &3Baterias de Energia&r (de &3&lID&r) e uma &6&lEstrela&r! \\n\\nVocê precisará energizar todas elas com... bem, tanta Energia quanto o &2&lMinecraft&r pode suportar... Literalmente o limite de inteiros!"]
	quest.23DE60E57136C207.title: "&5&lBateria de Energia &3Criativa"
	quest.23F5D39BCBCD7D42.quest_desc: ["Ela aumentará você do 59 para o 61. \\n\\nSeu Item de Assinatura é &5Areia Macia&r."]
	quest.23F5D39BCBCD7D42.title: "&3Elite dos Quatro Bertha"
	quest.23F691FC053F2319.quest_desc: ["A Interface de Disco permite que você pegue itens e fluidos de um disco e os coloque nos discos de outra Grade."]
	quest.23F691FC053F2319.quest_subtitle: "Chega de Manipulação!"
	quest.23FDFA44A162023A.quest_desc: ["A &6Bancada de Trabalho do Engenheiro&r é um Bloco necessário para muitas Criações e Melhorias. \\n\\nPodemos usá-la com &9Plantas&r para Criar Itens especiais que não podemos Criar em outro lugar. Coloque as &9Plantas&r no Slot Esquerdo, e nossos &eItens de Criação&r nos Slots Direitos.\\n\\nOu podemos jogar nossas Ferramentas nela, para adicionar Melhorias a elas, como o Revólver ou a Broca de Mineração! \\n\\nAlém disso, quando você adiciona &eItens&r e &9Plantas&r, pode vê-los no próprio &6Bloco&r, bem legal!"]
	quest.23FDFA44A162023A.title: "&6Bancada de Trabalho do Engenheiro"
	quest.24042326B4632DD4.quest_desc: ["Para começar com a Logística, crie um &3Núcleo de Logística&r, recomendo ler o Manual do PNC:R para um tutorial completo sobre como usar esses itens."]
	quest.24042326B4632DD4.quest_subtitle: "Transportando Itens/Fluidos"
	quest.24042326B4632DD4.title: "Logística"
	quest.2405663C033CBDF1.quest_desc: ["O MK3 não se preocupa com eixos XYZ, linha de visão ou Dimensão. \\n\\nContanto que o Inventário esteja no mesmo Mundo do Minecraft, ele pode mover itens para dentro dele. \\n\\nCaramba, nem tenho certeza se o Inventário precisa estar no jogo do Minecraft para enviar!"]
	quest.2409EAD96CE3BDF7.quest_desc: ["Os Moldes de Blazegold são usados para aprimorar armaduras e ferramentas de Ferricore para Blazegold, mantendo encantamentos e melhorias instaladas."]
	quest.24285F25F9563B02.quest_desc: ["O &#467FDB&nCircuito Analógico&r, ah! você finalmente o fez. Normalmente, outras pessoas levavam metade do tempo que você, mas não vou guardar rancor por isso..."]
	quest.24285F25F9563B02.quest_subtitle: "Noções Básicas de Eletrônica"
	quest.24285F25F9563B02.title: "&cCircuito Analógico"
	quest.242F74010488F261.quest_desc: ["O Galão dessas Barras ustível é um item que permite um uso mais eficiente do combustível. Ele pode armazenar 50.000 de combustível, cada item queimável tem um valor de combustível diferente dependendo da quantidade de itens fundidos. Um combustível é suficiente para fundir um item."]
	quest.243008D4DCD789D0.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_wild.png width:100 height:150 align:center}"]
	quest.243008D4DCD789D0.quest_subtitle: "Templos da Selva"
	quest.243008D4DCD789D0.title: "Ornamento de Armadura Wild"
	quest.24310BEACE75749D.quest_desc: [
		"Addons funcionam como melhorias e também como módulos para o &5Oritech&r. "
		""
		"Addons devem ser adicionados em slots que parecem plugues. O número de addons depende dos núcleos de máquina sendo usados."
		""
		""
		"{image:atm:textures/questpics/oritech/ori-addon-slot.png width:50 height:100 align:left}"
		""
		"Addons também adicionam funcionalidades extras às máquinas. Às vezes, você precisará adicionar addons específicos para permitir que receitas funcionem"
	]
	quest.24310BEACE75749D.quest_subtitle: "Fazendo valer a pena"
	quest.24391162F4FF0587.quest_desc: ["Com as 15 &bEstantes Marinhas&r ao redor da &5Mesa de Encantamento&r, podemos &d&lInfundir&r nossa última &bEstante Marinha&r! \\n\\n&bEstantes Marinhas Infundidas&r dão mais &aEterna&r, 5, com um máximo de &a60&r. Também mais &5Arcana&r, &55%&r. \\n\\nElas podem ser transformadas em diferentes &7Estantes de Livros&r, as que estamos procurando para o &6Encantamento Máximo&r são as &bEstantes Marinhas Cristalinas&r. \\n\\nPrecisaremos de 12 delas, então precisaremos de 12 &bEstantes Marinhas Infundidas&r. Crie 8 e eu te recompensarei com o resto!"]
	quest.24391162F4FF0587.title: "&bEstante Marinha Infundida"
	quest.2444614287B6398E.quest_desc: [
		"Raramente nas Planícies você pode encontrar alguns blocos diferentes saindo do chão. Pode ser um Monte Suspeito! \\n\\n&7Cascalho Suspeito&r surge sob a &2Grama&r e algumas &7Pedras&r."
		"{image:atm:textures/questpics/pokemon/find_sus_mound.png width:200 height:100 align:center}"
	]
	quest.2444614287B6398E.title: "Monte Suspeito Pré-histórico"
	quest.2447208F1DC74FFE.quest_desc: ["Roteadores podem ser barulhentos, e o barulho definitivamente se acumula quando você tem centenas deles.\\n\\nTalvez seja bom investir em Melhorias de Abafador então!"]
	quest.244ACD7024566001.quest_subtitle: "Alimente uma Abelha Suada com Gelo"
	quest.244ACD7024566001.title: "&fAbelha de Gelo"
	quest.245203DBA9D45934.quest_desc: [
		"Aumento de nível para 44."
		""
		"Pode ser encontrado aleatoriamente em &9Ginásios&r que geram em &a#minecraft:village&r"
	]
	quest.245203DBA9D45934.title: "&aLíder Lt. Surge"
	quest.24599D45F5D1606E.quest_desc: ["O &bTesouro de Aura&r é uma versão aprimorada do &9Cache de Aura&r."]
	quest.24599D45F5D1606E.quest_subtitle: "Um Tesouro!"
	quest.24599D45F5D1606E.title: "&bTesouro de Aura"
	quest.247DAE5B4E1AC7F1.quest_desc: ["Água entra. \\nÁgua sai. \\n\\nO Módulo de Fluido pegará Fontes de Líquido perto do Roteador e as colocará em um Tanque no Buffer ou pegará Líquido de um Tanque em seu Buffer e o colocará na sua frente. \\n\\nFunciona apenas para blocos adjacentes ao Roteador, se você quiser um alcance maior, precisará de..."]
	quest.24846776077B52C3.quest_subtitle: "Fabricação por Infusão"
	quest.24846776077B52C3.title: "&fAbelha de Supremium"
	quest.24888CAD50B32B04.quest_subtitle: "Gerado usando um Ninho de Pedra"
	quest.24888CAD50B32B04.title: "&fAbelha Construtora"
	quest.248AEF5537E48B1A.quest_subtitle: "Tier: &b4"
	quest.24934231538B6492.quest_desc: [
		"A Pirâmide Ancestral é uma das 3 estruturas em &b&lThe Other&r. \\n\\nClaramente é uma pirâmide e não, esta não tem um porão! \\n\\nEm vez disso, ela tem o &ePiglichu&r! \\n\\nVocê me ouviu bem, aqui não é mais o &ePiglich&r, eles foram transformados em um &cPokemon&r chamado &ePiglichu&r. \\n\\nVocê pode lutar e capturá-los como qualquer outro &cPokemon&r! \\n"
		"{image:atm:textures/questpics/allthemodium/all_pyramid.png width:200 height:100 align:center}"
	]
	quest.24934231538B6492.title: "Pirâmide Ancestral"
	quest.249E5C6893387E15.quest_desc: ["Estes &cTrilhos&r são feitos para parar as &5Locomotivas&r e &7Vagões&r. \\n\\nO &cKit de Travamento&r para &7Vagões&r e só os inicia quando recebe um pulso de redstone. \\nO &cKit Amortecedor&r é para o final dos seus &6trilhos&r, irá pará-los e não iniciará. \\nO &cKit com Portão&r apenas implanta um Portão de Cerca conectado com o &6trilho&r."]
	quest.249E5C6893387E15.title: "&cKits de Trilhos&r para parar &7Vagões&r"
	quest.24B147D251D0CFFF.quest_subtitle: "Alimente uma Abelha de Ouro com Gosma Blazebloom"
	quest.24B147D251D0CFFF.title: "&fAbelha de Blazegold"
	quest.24BA4B4EED0A9DBD.quest_desc: [
		"Melhorias Válidas:"
		"- Névoa Mental"
	]
	quest.24BA664B60E49461.quest_desc: ["Apenas uma das Ferramentas mais poderosas de todo o &2&lMinecraft&r Modificado! A &6Caixa de Papelão&r! \\n\\nElas são feitas com ingredientes muito simples, apenas 4 &6Serragens&r. A &6Serragem&r é feita colocando &7Gravetos&r em uma &e&lSerraria de Precisão&r. \\n\\nAgora que, com sorte, temos uma, basta Clicar com o Botão Direito em um Bloco com ela e o Bloco será colocado na &6Caixa de Papelão&r. Agora podemos quebrar a &6Caixa de Papelão&r e mover o Bloco, colocando-o novamente e Agachando + Clicando com o Botão Direito para remover a Caixa. \\n\\nAlguns Blocos &4não&r funcionarão, como &8Rocha Matriz&r ou &dPortais do End&r... mas há muitos outros que funcionarão! Como &5Obsidiana&f, &3Ardósia Profunda Reforçada&r e &bSpawners! "]
	quest.24BA664B60E49461.title: "&6Caixa de Papelão"
	quest.24C757B8AA6841F6.quest_desc: ["O &5&lApotheosis&r sabe como &3Tridentes&r podem ser irritantes de obter, então eles tornaram mais fácil... bem, um pouco mais fácil! \\n\\nAgora você pode fazer um &3Tridente Inerte&r e &d&lInfundi-lo&r para obter um &3Tridente&r normal. \\n\\nO &3Tridente&r requer entre &a40 Eterna&r, &c20%-50% Quanta&r e pelo menos &535% Arcana&r. \\n\\nVocê pode obter isso com 1 &7Estante&r, 4 &9Echoing Sculkshelves&r e 1 &2Estante de Melão&r."]
	quest.24C757B8AA6841F6.title: "Fazendo um &3Tridente&r de verdade"
	quest.24D11ED5F4EEDC48.quest_desc: ["Para aqueles que são novos no &6&lApotheosis&r, os &9Encaixes&r podem ser confusos e irritantes. \\n\\nResumindo, suas Armas e Armaduras precisam de &9Encaixes&r para usar &aGemas&r. \\n\\nMas e se não tiver um &9Encaixe&r? \\n\\nEntão você precisará de um &9Símbolo de Encaixe&r! \\n\\nCombine seu item e o &9Símbolo&r em uma &8&lMesa de Ferraria&r e pronto, você pode obter até 2 &9Encaixes&r."]
	quest.24D11ED5F4EEDC48.title: "&9Símbolo de Encaixe"
	quest.24D38DA8E86DD897.quest_desc: [
		"O menor e mais fraco dos &cMobs da Podridão&r. \\n\\nEles têm 5 corações. \\n\\nComo todos os &cMobs da Podridão&r, eles atacarão &2Stoneborns&r e &7Forgottens&r e droparão &cFragmentos Utéricos&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotling.png width:100 height:100 align:center}"
	]
	quest.24D38DA8E86DD897.title: "&cRotling&r"
	quest.24D3F605315ADB03.quest_desc: ["A &9Grade Universal Sem Fio&r permite que você acesse o armazenamento da sua rede, sua rede de armazenamento com uma interface de criação embutida e sua fila de criação, tudo sem fio."]
	quest.24D3F605315ADB03.title: "&dGrade Universal Sem Fio"
	quest.24DB1F587DB99074.quest_desc: [
		"A Multibloco de Ressurreição de Fóssil precisa de 3 blocos. O Analisador de Fósseis, Monitor de dados e Tanque de Restauração. Posicione-os neste design."
		"{image:atm:textures/questpics/pokemon/find_fossil.png width:100 height:100 align:center} "
		"Antes de começarmos a restaurar ou ressuscitar ou qualquer coisa! Precisamos de combustível... O combustível vem na forma de vários itens de &2Plantações &fe &2Plantas&r. \\n\\nItens de comida como Bolotas, Bife e Bolo. Líquidos como Mel ou Ensopado Suspeito. Até coisas que não podemos comer como Mudas, Flores e Folhas! \\n\\nAssim que o tanque estiver cheio, podemos colocar nosso &6Fóssil&r no Analisador de Fósseis. Se estivermos usando alguns dos &6Fósseis&r especiais, você precisará colocar 2 &6Pokémon fossilizados&r únicos nele. \\n\\nQuando começar a funcionar, ele ligará, a tela brilhará, o Analisador disparará lasers vermelhos e o tanque borbulhará. \\n\\nFinalmente, quando tudo estiver resolvido e pronto, o &6Fóssil&r será agora um &cPokémon&r totalmente restaurado no tanque. Use uma &cPokebola&r no tanque e ele capturará o &cPokémon&r automaticamente."
	]
	quest.24DB1F587DB99074.title: "Ressurreição de Fóssil"
	quest.24E658BA47367A44.quest_desc: ["A &aPolia de Corda&r moverá quaisquer Blocos que estejam presos à sua &aCorda&r na parte inferior. Isso também moverá quaisquer Blocos &aColados&r a esse Bloco! \\n\\nQuando movida no &e&osentido horário&r por &dPotência Rotacional&r, ela abaixará a &aCorda&r até atingir outro Bloco, ou até onde estiver configurada para ir. \\n\\nQuando receber &dPotência Rotacional&r no &9&osentido anti-horário&r, ela moverá a &aCorda&r em direção à &aPolia&r até atingir a &aPolia&r ou ir para onde estiver configurada para ir. \\n\\nPor que continuo dizendo \"configurada para ir\"? Porque existem configurações de destino com o Modo de Movimento! \\n\\nEstas decidirão onde os Blocos pararão!"]
	quest.24E658BA47367A44.title: "&aPolia de Corda"
	quest.24E800EEC2CAD626.quest_desc: ["A &2Unidade Geiger&r funcionará como a &aUnidade de Dosímetro&r, mas em vez de medir a &aRadiação&r em você, ela mede a &aRadiação&r ao seu redor! \\n\\nApenas para que você possa encontrar onde ela pode estar escondida. \\n\\nVocê também pode ativá-la e desativá-la!"]
	quest.24E800EEC2CAD626.quest_subtitle: "Peitoral"
	quest.24E800EEC2CAD626.title: "&2Unidade Geiger"
	quest.24FCFF18296ED907.quest_desc: ["Para aprimorar as &9Estante de Livros Profunda&r ainda mais, surpreendentemente não precisamos de &d&lInfusão&r! Em vez disso, precisamos de mais Criação! \\n\\nPrimeiro, são 5 &3Blocos de Sculk&r e um &3Catalisador de Sculk&r. Ambos podem ser encontrados dentro do &9Deep Dark&r e precisarão de &5Toque Suave&r para coletar. \\n\\nPor último, há o &9Tentáculo do Warden&r... este é um Drop do &9&lWarden&r... Sim, você precisará matar o &9&lWarden&r. \\n\\nQuando tiver tudo isso, poderá criar uma das melhores &7Estantes&r! Uma que dá &a10 de Eterna&r, &c15% de Quanta&r e &510% de Arcana&r. \\n\\nE o mais importante, nos dá um máximo de &aEterna&r de &a80&r! Quase 100!"]
	quest.24FCFF18296ED907.title: "&9Estante de Sculk Tocada pela Alma"
	quest.25080E3295B1DF01.quest_desc: ["A &5Unobtainium Furnace&r funde itens mais rápido do que qualquer outra fornalha no pacote!"]
	quest.25080E3295B1DF01.title: "&5Unobtainium Furnace"
	quest.251464B43353D4C6.quest_desc: ["Nossa querida Estufa de Jardim! É uma Fazenda automática, e com esta Missão é simples de usar! \\n\\nPara começar, ela precisará de &cEntrada de Energia &6pela Esquerda, Direita ou Topo! \\n\\nDepois, precisará de &9Água&r pela Porta Traseira (tente usar uma &9Pia&r). \\n\\nEm seguida, precisaremos Inserir nossas Sementes, Farmland e Fertilizante opcional pela &eEntrada de Itens &6na Parte Inferior! \\n\\nEla precisará da Farmland correta para as Sementes, você pode verificar tudo isso Clicando com o Botão Direito na Estufa para ver sua GUI, a propósito! \\n\\nQuando tiver tudo isso, ela crescerá e colherá rapidamente suas Colheitas e as &6Ejetará&r pela Frente da Cúpula. \\n\\nÚltimas notas: ela manterá a Semente e a Farmland originais e não as consumirá, a Terra será transformada em Farmland, e os Fertilizantes são Enxofre, Escória, Nitrato e Fertilizante Industrial."]
	quest.25213DBA6E6CEDD2.quest_desc: [
		"A Gosma de Pulso Sombrio é o quarto e último nível de gosma adicionado pelo JDT e requer materiais da Cidade Ancestral e do Warden para ser criada."
		""
		"Criações Desbloqueadas:"
		"- Liga Eclipse"
		"- Brasa Eclipse"
		"- Cristal do Tempo"
	]
	quest.252169A6EB4DD75B.quest_subtitle: "&f9 de &cDano de Ataque"
	quest.252A24CED69C1882.quest_desc: ["O Gerador Termoelétrico, que vou chamar apenas de Termo, é um Gerador único. \\n\\nSozinho, ele não fará nada. O que precisaremos fazer é colocar Blocos ou Fluidos de temperaturas diferentes em lados diferentes do Termo. \\n\\nQuanto maior a diferença de Temperatura, mais Energia ele cria!"]
	quest.252A24CED69C1882.title: "Energia a partir da Temperatura"
	quest.252AD9C886DE45C8.quest_desc: [
		"Os Twilight Gaze são peixes neutros localizados no Abismo. \\n\\nSe você acertar um, todos atacarão você, semelhante a Lobos ou Porcos-zumbis. Se você se afastar muito do Abismo, eles pararão de segui-lo e nadarão de volta para as profundezas. \\n\\nEles não dropam nada ao morrer, então talvez não os acerte..."
		"{image:atm:textures/questpics/eternal/starlight_gaze.png width:150 height:100 align:center}"
	]
	quest.252AD9C886DE45C8.title: "Twilight Gaze"
	quest.252E8C0AA0C61575.quest_desc: ["&cCharcadet&r tem 2 caminhos de &bEvolução&r diferentes que ele pode seguir. \\n\\nO primeiro é &cArma&drogue&r, que é feito dando a ele &eAuspicious Armor&r. \\n\\nVocê pode encontrar &eAuspicious Armor&r em Baús de Bastilhas em Ruínas! \\n\\nO segundo é &cCeru&5ledge&r, que usa &5Malicious Armor&r. \\n\\n&5Malicious Armor&r aparece em Baús de Fortalezas do Nether!"]
	quest.252E8C0AA0C61575.title: "Itens de &bEvolução&r do &cCharcadet"
	quest.253657BE5D9D9162.quest_desc: ["O External Storage é um tipo de interface de cabo que é um dos itens mais importantes que alguém pode fazer em sua jornada no &3Refined Storage&r.\\n\\nEste tipo de interface conecta um armazenamento externo à sua rede. Basicamente, ele permite que o RS olhe para dentro do contêiner de armazenamento para que você possa acessá-lo dentro da sua &3Grade&r!\\n\\nIsso funciona em muitas coisas, incluindo, mas não se limitando a: Baús, Barris, Gavetas, Controladores de Gavetas e mais!\\n\\nSe você não pode fazer drives e tem um monte de baús por toda parte, esta é sua melhor aposta para criar uma rede de armazenamento!"]
	quest.253822C64BBBB1EB.quest_desc: ["O &#6E6D6DMartelo de Forja&r permitirá que você esmague facilmente os &#9AD5EDBarras&r ou minérios de Estanho em seus respectivos pós."]
	quest.253822C64BBBB1EB.quest_subtitle: "Nem tão 'estranho' assim."
	quest.253822C64BBBB1EB.title: "&fPó de Estanho"
	quest.253957D992A88C88.quest_desc: [
		"Este Escudo, como parece ser o caso da maioria dos Itens aqui, pode ser: encontrado em estruturas, criado ou trocado com a &5Rainha Abelha&r. \\n\\nFunciona como um Escudo &2Vanilla&r, segure-o na sua mão secundária e bloqueie ataques. \\n\\nO que o torna diferente (e melhor) é que, depois de repará-lo com &5Cristais de Mel&r, ele ficará mais forte."
		"{image:atm:textures/questpics/bumblezone/bumble_shield.png width:100 height:150 align:center}"
	]
	quest.2542D8A6894816C6.quest_desc: ["O &eOlho do Deserto&r o levará para a &ePirâmide Amaldiçoada&r para lutar contra o &e&lRemanescente Ancestral&r."]
	quest.2542D8A6894816C6.title: "&eOlho do Deserto&r"
	quest.25498A20F05FB703.quest_desc: ["Se um Aldeão estiver desempregado (e não for um &2Tolo&r!), você pode colocar um bloco de profissão e ele irá até ele para se tornar empregado. \\n\\nO bloco específico determina a profissão, e precisamos de um Barril para um &bPescador&r. \\nContinue negociando com eles e eles ganharão experiência. Quando atingirem o nível máximo, todas as trocas serão desbloqueadas. Precisamos de um &bPescador Mestre&r para obter o... \\n\\n&bModelo de Aprimoramento de PokeVara&r."]
	quest.25498A20F05FB703.title: "&bModelo de Aprimoramento de PokeVara"
	quest.2559201BCF5D497C.quest_subtitle: "Faz vários Materiais do Mundo Superior"
	quest.256C3DBA392B4236.quest_desc: ["Eletrólise das Soluções Ácidas de Manganês e Cromo produzirá seus Pós, que podem ser usados em receitas futuras."]
	quest.256C3DBA392B4236.quest_subtitle: "9 Pós Pequenos viram 1 Pó"
	quest.257C80468B080B3C.quest_desc: ["O Eletroímã é a versão do &8&lIE&r para o Funil de Absorção. \\n\\nBem, mais ou menos! Ele não segurará os &eItens&r, em vez disso, eles serão movidos para mais perto da face superior do Eletroímã. \\n\\nIsso pode ser usado para colocá-los em &eEsteiras&r ou funis! \\n\\nEle exigirá &cEnergia&r para ser usado, no entanto."]
	quest.257D8912FC58DB59.quest_subtitle: "Brazilwood + Mahogany"
	quest.2580135392DEF522.quest_desc: ["Já sentiu que o Canteiro Hidropônico padrão causa muito lag? Não consegue encaixar Surtos de Alma suficientes? Permita-me apresentar o Canteiro Hidropônico Simulado. Este usará um Processador de Simulação Hidropônica e uma semente/muda para cultivar qualquer plantação de sua escolha... virtualmente. Você nem precisa de &9Água&r e &bGás de Éter&r para este. Além disso, os Processadores de Simulação Hidropônica melhoram com o tempo à medida que cultivam mais plantações, embora a taxa em que escala seja mais lenta em um Canteiro Hidropônico Simulado.\\n\\nNem se incomode em tentar maximizar o Processador. Levará um tempo inimaginavelmente longo. Muito mais tempo do que eu levaria para fazer as missões para o Ender IO, com certeza."]
	quest.2580135392DEF522.quest_subtitle: "HNN mas para plantações?"
	quest.2580135392DEF522.title: "Canteiro Hidropônico Simulado"
	quest.2581B7D8E6C6E510.quest_subtitle: "Tier: &63"
	quest.2587D8B0BE7FE584.quest_desc: ["A única razão pela qual eu digo \"simples\" é devido à forma como as Máquinas recebem &cEnergia&r e &eItens&r. \\n\\nTodos os &eItens&r e &cEnergia&r podem ser transportados por tubos normalmente. \\n\\n&6&lOritech&r, &5&lMekanism&r, e &lIndustrial Foregoing&r são todos Mods de Tecnologia únicos. \\n\\n&6&lOritech&r foca em projetar Multiblocos e processar &eItens&r através deles. \\n\\n&5&lMekanism&r foca em processar &eItens&r ao limite com múltiplas máquinas e combinações diferentes. \\n\\n&lIndustrial Foregoing&r nos dá Máquinas, cada uma com diferentes maneiras de interagir com o Mundo."]
	quest.2598273041353196.quest_desc: ["Ao construir o &aReprocessador&r, você precisará de pelo menos um &eColetor&r e um &9Injetor de Resíduos&r.\\n\\nO &eColetor do Reprocessador&r deve ser colocado no centro da face inferior da estrutura.\\n\\nO &9Injetor de Resíduos&r deve ir no centro da face superior, que é onde você vai canalizar ou inserir resíduos como &9Barras de Cianita&r."]
	quest.2598273041353196.title: "Importando Resíduos"
	quest.25A3E30F722B38B6.quest_desc: ["Por que você está surpreso que o &eOuro&r é realmente usado em mods? Você já viu na vida real que ele faz muita coisa! Também abre portas para Geradores mais únicos que não usam apenas essas Barras ustível de Fornalha!"]
	quest.25A3E30F722B38B6.title: "&eGold Generator"
	quest.25ACB08E4F12CE79.quest_desc: ["A &cMinimonstruosidade de Netherite&r é um Pet que nos é dado pelo &4&lCataclysm&r! \\n\\nPrimeiro, você precisará criar uma &cEfígie de Netherite&r. \\n\\nDepois, podemos matar a &c&lMonstruosidade de Netherite&r para obter as &cCélulas de Poder de Lava&r. \\n\\nFinalmente, coloque a &cEfígie&r e alimente-a com uma &cCélula de Poder&r para domá-lo! \\n\\nUma vez domado, ele pode ser clicado com Shift + botão direito para editar se ele está seguindo, parado ou vagando. \\n\\nVocê também pode clicar com o botão direito nele para abrir seu inventário, ou seja, abrir sua cabeça inteira como um Monstro de Pedra da Lego Power Miners. Ele tem um inventário de 15 slots. \\n\\nEle também tem 960 &4Corações&r e não consigo encontrar uma maneira de curá-lo..."]
	quest.25ACB08E4F12CE79.title: "&cMinimonstruosidade de Netherite"
	quest.25AFD10D008DF30B.quest_desc: ["Os Baús do End todos compartilham o mesmo inventário e esse inventário é diferente para cada jogador. Eles não podem ser combinados em 1."]
	quest.25CDC402800CA4D1.quest_desc: ["Ei, os &cPokemon&r têm que vir de algum lugar! \\n\\nSe 2 &cPokemon&r estiverem vagando em um &6Pasto&r, eles podem &dCruzar&r. Mas existem muitos requisitos antes que possam fazer isso. \\n\\nPrimeiro, precisaremos de um &bMacho &fe uma &dFêmea&r para &dCruzar&r. O bebê &cPokemon&r virá de um &cOvo Pokemon&r e será da mesma espécie que a &dMãe&r. \\n\\nAmbos os &cPokemons&r precisarão estar no mesmo \"Grupo de Ovos\". Use a Wiki, eu não vou listar cada &cPokemon&r um por um! \\n\\nPor último, existem alguns atributos e &cPokemon&r específicos que não podem &dCruzar&r... \\n\\nSe você cumprir todos os requisitos, a &cPokemon &dFêmea&r botará um &cOvo&r de vez em quando!"]
	quest.25CDC402800CA4D1.quest_subtitle: "Os Delibirds e os Beedrills"
	quest.25CDC402800CA4D1.title: "&dCruzamento&r de &cPokemon&r"
	quest.25D4406CB86C8CBB.quest_desc: ["Agora que estamos coletando alguns &9resíduos&r do nosso reator, parte da progressão exige que você \"fluidize\" alguma das Barras que você obtém. Sabe o que isso significa?\\n\\nPrecisamos fazer um &aFluidificador&r! O componente principal é o &aControlador do Fluidificador&r. Uma vez construído, você pode clicar com o botão direito sobre ele para abrir a interface. Aqui, você pode ligá-lo ou desligá-lo, ver o que está dentro e o nível de energia atual."]
	quest.25D4406CB86C8CBB.title: "O Fluidificador"
	quest.25D84D82DBADA0DB.quest_subtitle: "Tier: &b4"
	quest.25D8BE0280B6E7F1.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.25DBA00422301EDC.quest_desc: ["O segundo Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e4194304&f (4096k) bytes de armazenamento."]
	quest.25DBA00422301EDC.quest_subtitle: "x4"
	quest.25DBA00422301EDC.title: "&5Componente de Armazenamento de 4M"
	quest.25E782DB4309A1B8.quest_desc: ["Galhadas de Aurora Deer são dropadas por Aurora Deers ao morrer. \\n\\nPode ser usado como uma Espada ou uma Enxada."]
	quest.25E915AE1FC53254.quest_desc: ["Modelos de Celestigem são usados para aprimorar armaduras e ferramentas de Blazegold para Celestigem, mantendo encantamentos e melhorias instaladas."]
	quest.25EE7E0119010291.title: "&fA Barra de &7Aço"
	quest.25EFC21A3C48E0B6.title: "Tier: &2Spirited"
	quest.25F4D4A723B298A4.quest_subtitle: "Maçã Red Delicious + Bétula"
	quest.2607F3DC07049785.quest_desc: ["Por que perder tempo sentado e comendo uma boa refeição caseira quando você pode simplesmente Comer e Beber rapidamente! \\n\\nCom este &6Chapéu&r muito estiloso, Comer e Beber é muito mais rápido."]
	quest.2607F3DC07049785.quest_subtitle: "Cabeça"
	quest.2607F3DC07049785.title: "&6Chapéu de Beber de Plástico"
	quest.260F9C98DC2E485B.quest_subtitle: "Tier: &b4"
	quest.261E8EE0C7E7E2F0.quest_desc: ["&c&lDanrique&r! O único que veio com uma Skin que combina com o tema! \\n\\nProcure pelo Criador de Conteúdo que está no estilo de alguém que te derrotaria em uma Batalha &cPokémon&r... então derrote-o no lugar dele!"]
	quest.261E8EE0C7E7E2F0.title: "&c&lDanrique"
	quest.262036FE8E87F50A.quest_subtitle: "Mineração 3x3"
	quest.262B307753106817.title: "Afogando-se em Desespero"
	quest.263860CADB3D76C6.quest_desc: ["Gerador Energizado é o Gerador de Criaturas feito usando o EnderIO. Primeiro, você precisará de um Frasco de Alma cheio e um Gerador Quebrado. (Tecnicamente você só precisa do Frasco de Alma para alterar o Gerador, mas tanto faz). Assim que tiver um Broken Spawner que goste, fabrique o Gerador Energizado com ele! Então, coloque-o no chão, dê a ele um Capacitor e forneça energia. Boom! agora você está gerando criaturas com o EnderIO.\\n\\nVocê também pode fazer este Gerador encher Frasco de Almas diretamente, sem a necessidade de um Clicador."]
	quest.263860CADB3D76C6.quest_subtitle: "Gerador do EnderIO"
	quest.263C9A0FC04472AB.quest_desc: ["Este pode tanto consumir &cLava&r como nenhum outro, ou ser usado para a &6&lEstrela (Star)&r. \\n\\nEste é difícil, eu gosto de ver a &cLava&r desaparecer em vez das minhas coisas desaparecerem na &cLava&r."]
	quest.263C9A0FC04472AB.title: "&4Gerador Magmático 64x"
	quest.263FBD9ED2756190.quest_subtitle: "Nogueira + Cuco"
	quest.264BFB8C5F79616F.quest_desc: ["Colocar um Ninho de Neve em um bioma de neve atrairá uma Abelha Suor."]
	quest.264BFB8C5F79616F.quest_subtitle: "Atrai a Abelha Suor em Biomas Frios"
	quest.264BFB8C5F79616F.title: "&fNinho de Neve"
	quest.265D0DB0E8CED73B.title: "Módulo de Compensação de Gravidade de Projétil Dracônico"
	quest.266127E7947CB3D4.quest_desc: ["Todas as belas Construções que você vê nesta Página de Missões são de pessoas do Discord do ATM! \\n\\nNão se preocupe, todos deram consentimento para compartilhar suas Construções e foram creditados! \\n\\nSe você também deseja compartilhar suas Construções, confira o canal artwork-builds-showoff no Discord! \\n\\n(Não posso garantir que todas as Construções foram feitas no ATMons, apenas que foram feitas por outros jogadores de Minecraft. Da mesma forma que alguns podem usar Shaders, então se suas Construções não forem exatamente iguais, pode ser por isso!)"]
	quest.2664388EBA1E8F90.quest_subtitle: "&f8 &cDano de Ataque"
	quest.267A357B28228694.quest_desc: ["A &#4DB85EMemória de Acesso Aleatório&r é feita em um &#5EC7E6Reator Químico&r com &#A1A1A1Borracha de Estireno-Butadieno&r, &#D15EE6Argônio&r, &7Pó de Antimônio&r, &#5ED2E6Pó de Alumínio&r e &#5D76C2Lâminas de Silício&r."]
	quest.268768465119632A.quest_subtitle: "Aspen + Alder"
	quest.268DEC15019B7CF0.quest_desc: [
		"Perto do fundo do oceano, você pode ser arrastado para as Fontes Hidrotermais. \\n\\nO &7Cascalho Suspeito&r surge perto de todo o outro &7Cascalho&r no fundo do oceano!"
		"{image:atm:textures/questpics/pokemon/find_hydrothermal.png width:200 height:100 align:center}"
	]
	quest.268DEC15019B7CF0.title: "Fontes Hidrotermais Pré-históricas"
	quest.268EA2DEC8840D13.quest_desc: ["Ao trabalhar com &4Computadores&r, especialmente os Quânticos, os Martelos e Alicates na Bancada de Trabalho não conseguirão fabricar o que precisamos, precisaremos de um &bMontador de Cristal (Crystal Assembler)&r. \\n\\nPara este, precisaremos de um monte de &9Singularidades&r!"]
	quest.268EA2DEC8840D13.title: "&4Multi-Threader de Computador Quântico"
	quest.268F6E67AA79A7BD.quest_subtitle: "&f69 &cDano de Ataque"
	quest.26988330D3E5BF95.title: "Estandarte: Flechas"
	quest.26988E22BD019628.quest_desc: ["Funde itens automaticamente na Mochila."]
	quest.26988E22BD019628.quest_subtitle: "Automático"
	quest.26988E22BD019628.title: "&eMelhoria de Auto-Fundição"
	quest.269D24B28FA92DF8.quest_desc: ["&4Associados de Treinador&r são Aldeões. Eles Aparecerão ao seu redor se você Segurar um &4Cartão de Treinador&r em sua Mão e não tiver uma &4&oSérie&r. Eles também apenas Aparecem em Vilas, como Aldeões normais. \\n\\nVocê pode dar Itens a eles para receber um &4Cartão de Treinador&r ou dar a eles um &4Cartão de Treinador&r e eles lhe darão uma &4&oSérie&r! \\n\\nClique com o Botão Direito no &4Cartão de Treinador&r para ver suas Informações. Aqui você pode encontrar Informações de cada &4Treinador&r que você enfrentou, ou Informações sobre o &4Treinador&r em sua &4&oSérie&r. \\n\\nAo visualizar um &4Treinador&r, você pode ver seu Nome e Nível Máximo. Clique na Seta Direita para ver os Biomas em que eles Aparecem! \\n\\nCom &4Treinadores&r de &4&oSérie&r, seus Nomes começarão como &kaleatório&r até você visualizá-los. Então, mostrará o Nome e o Nível Máximo que eles têm. \\n\\nSe você vencer o &4Treinador&r com um Nível Máximo maior em uma &4&oSérie&r, seu Nível Máximo aumentará!"]
	quest.269D24B28FA92DF8.title: "&4&oSérie"
	quest.26A7746051A4A079.quest_subtitle: "Tier: &63"
	quest.26A9F402DAE15EA2.quest_desc: ["Adiciona uma INTERFACE de Defumador à Mochila."]
	quest.26B3AE1E77A84BCB.quest_desc: ["Se você jogar um &9Ovo de Gerador de Abelha de Ósmio&r, &bQuartzo Certus Carregado&r e &8Pedra do Céu&r na Lava, você criará um &eOvo de Gerador de Abelha de Ósmio do Céu"]
	quest.26B3AE1E77A84BCB.title: "&fAbelha de Ósmio do Céu"
	quest.26B462F2F41A77C7.quest_desc: ["Todos os presentes da Mãe Natureza... podem ser impiedosamente queimados em um Forno até virar nada além de &bSal&r! \\n\\nTroncos, Folhas e Colheitas podem ser Tostados e virar &bSais de Planta&r."]
	quest.26B462F2F41A77C7.title: "&bSal de Planta"
	quest.26B9909717528D5E.quest_subtitle: "Encontrado no Undergarden"
	quest.26B9909717528D5E.title: "&fAbelha Utérica"
	quest.26BEA64C80ECE1A6.quest_desc: ["Cada &3Estrutura Logística (Logistic Frame)&r pode ser usada para diferentes tipos de automação."]
	quest.26DF1427AC3966DE.quest_desc: ["Bem-vindo ao Draconic Evolution, um mod muito divertido e OP! Para começar, você precisará minerar Minério Dracônico para obter Pó Dracônico. Ele aparece em todas as Dimensões (Vanilla), mas a maior quantidade está no End!"]
	quest.26DF1427AC3966DE.title: "Draconic Evolution"
	quest.26F9DB31A835B69C.quest_desc: ["&nFundição&r: &aOk&r \\n&nMetal Líquido na Fundição&r: &aOk&r \\n\\nAgora, como tiramos isso de lá? \\n\\nLembra do nosso amigo de antes? O &cDreno&r da &b&lFundição&r? Precisaremos apresentá-lo ao nosso novo amigo, a &7Torneira&r da &c&lFundição&r. \\n\\nColoque a &7Torneira&r da &c&lFundição&r no &bDreno&r, agora podemos colocar Blocos abaixo dela para drenar o &7Metal Líquido&r para... \\n\\nBlocos como o &8Recipiente de Fundição&r, que transformará cerca de 900mB de &7Metal Líquido&r no &7Bloco de Metal&r completo. \\n\\nOu a &8Mesa de Fundição&r, que é o que precisaremos para fazer..."]
	quest.26F9DB31A835B69C.title: "Fundindo Itens"
	quest.26FADB78B04F592B.quest_desc: ["&l&aBuilding Gadgets 2&r é um Mod que adiciona alguns Itens muito úteis. \\n\\nTodos, claro, para construir! \\n\\nCada um requer &aEnergia&r para funcionar e tem um Menu que é aberto por padrão com &lG&r."]
	quest.26FADB78B04F592B.title: "&l&aBuilding Gadgets&r"
	quest.26FB7A789981BD3C.quest_subtitle: "Alimente uma Abelha de Carvão com um Bloco de Grafite"
	quest.26FB7A789981BD3C.title: "&fAbelha de Grafite"
	quest.270498437D938DD4.quest_desc: ["Ao criar uma Super Vela com Geleia Real e uma Poção, você fará uma Vela de Poção! \\n\\nQuando a Vela estiver acesa, ela dará o Efeito de Poção a todos que estiverem por perto."]
	quest.270498437D938DD4.title: "Vela de Poção"
	quest.270BEFADE842144B.quest_desc: ["Bem-vindo ao &l&cAll&7The&fMons&r! \\n\\nNão, isso não foi um erro de digitação! Este é um Modpack centrado em &c&lCobble&fmon&r feito por nós mesmos, a &6&lEquipe ATM&r. \\n\\nPara começar, você precisará de um &cPokemon&r Inicial. Para obtê-lo, o Padrão é (M) \\n\\nCada Região tem 3 Iniciais: &2Grama&f, &bÁgua&f, e &cFogo&r. Você pode Clicar nos Ícones ou mover as Setas para escolher. \\n\\nO &2tipo Grama&r tem um Fundo &2Verde&r com um &2Ícone de Folha&r. O &btipo Água&r tem um &bFundo Azul&r com um &bÍcone de Gota de Água&r. &cFogo&r tem o &cFundo Laranja&r com um &bÍcone de Chama&r. \\n\\nCada &cPokemon&r terá seu Nome e Descrição acima dele. Assim que encontrar um que goste, aperte o Botão \"Eu escolho você!\" \\n\\n(&bMudkip&r é o meu favorito!)"]
	quest.270BEFADE842144B.title: "&c&lAll&7The&fMons"
	quest.27195E9A3482C158.quest_desc: ["A &bUnidade de Purificação por Inalação&r na verdade faz algumas coisas. \\n\\n1. Ela usará &aEnergia&r para bloquear Dano Mágico. Como Poções de Dano Instantâneo! \\n\\n2. Ela pode ser Configurada para bloquear Efeitos de Poção com base em seu nível de ajuda ou dano: Benéficos, Neutros e Prejudiciais. \\n\\nBenéficos ajudarão o Jogador de alguma forma. Como Regeneração, Cura, Velocidade e Força. \\n\\nNeutros não fazem muita coisa, como Brilho. \\n\\nPrejudiciais tornarão o Jogo mais difícil para o Jogador. Como Wither, Fraqueza ou Cegueira."]
	quest.27195E9A3482C158.quest_subtitle: "Helmet"
	quest.27195E9A3482C158.title: "&bUnidade de Purificação por Inalação"
	quest.271A112ABDD923A6.quest_desc: ["Como o Manguezal normal, mas estes não são feios."]
	quest.273605A191309522.quest_desc: ["Depois do &a&lMinitho Player&r vem o &lPilpoh&r. \\n\\nEm vez de usar um &6Lingote de Allthemodium&r ele na verdade usa Concreto Branco para invocá-lo com um &4Gerador de Treinadores&r. \\n\\nConhecendo-o, ele fará uma série dele jogando &l&cAll&7The&fMons&r... isso significa que ele acabará lutando contra si mesmo? Isso parece... estranho."]
	quest.273605A191309522.title: "&lPilpoh"
	quest.2745297337E13E9E.quest_desc: ["O &3Advanced Air Compressor&r funciona da mesma forma que o Air Compressor, só que muito melhor!"]
	quest.2745297337E13E9E.quest_subtitle: "Não há mais necessidade dos velhos e chatos Compressores de Ar!"
	quest.2746575C929B6C50.quest_desc: ["As Gavetas (Gavetas) podem ser 1x1, 2x1 ou 2x2. As Gavetas podem conter uma tonelada de pilhas de 1/2/4 itens, dependendo do tipo de Linking Tool."]
	quest.2746575C929B6C50.quest_subtitle: "Pilhas sobre Pilhas"
	quest.2747AEE1F7F97848.quest_desc: ["Poções são legais, mas você não odeia que elas tenham limites de tempo? \\n\\nNão, cale a boca sobre o Infusion Pylon! \\n\\nCom esta &7Unidade&r você correrá mais rápido e pulará mais alto! (Mas você ainda não é bom no Basquete). \\n\\nQuanto mais você tiver, mais rápido e mais alto você irá!"]
	quest.2747AEE1F7F97848.quest_subtitle: "Calças"
	quest.2747AEE1F7F97848.title: "&eUnidade de Propulsão Locomotiva"
	quest.2748ACEAB96A5F60.quest_desc: ["As Fornalha de Ferros (Não se confunda com cada um dos títulos, com &lFornalha de Ferros&r sendo o nome do mod e um nome de Item) funcionam ainda mais rápido que as Fornalhas Normais e de Cobre. Elas levam 160 Ticks para funcionar, ou 8 segundos.\\n\\nElas podem ser criadas a partir de uma Fornalha normal ou de uma &6Fornalha de Cobre&r! E podem ser transformadas em uma &7Silver Furnace&r ou uma &eFornalha de Ouro&r."]
	quest.2748ACEAB96A5F60.title: "&fFornalha de Ferro"
	quest.27512B0434531195.quest_desc: ["A &c&lCâmara de Injeção Química&r é outra &5Máquina&r que funciona combinando &eItens &f e &cQuímicos&r, mas desta vez é apenas 1 &eItem&r mais 1 &cQuímico&r para fazer 1 novo &eItem&r! \\n\\nVocê pode obter &bVapor de Água&r colocando &9Água&r em um &c&lCondensentrador &bRotativo&r, e então injetar esse &bVapor de Água&r em Coral Morto para revivê-lo. \\n\\nVocê pode obter &bOxigênio&r de um &9&lSeparador Eletrolítico&r e injetar esse &bOxigênio&f em &6Cobre&r para Oxidá-lo. \\n\\nE o mais importante, usar &3Cloreto de Hidrogênio&r em Blocos de Minério para obter Fragmentos de Minério para Processamento!"]
	quest.27512B0434531195.title: "&c&lCâmara de Injeção Química"
	quest.275D97BF0CE9DCD4.quest_subtitle: "Tier: &b3"
	quest.2777FEB022346947.quest_subtitle: "Tier: &a2"
	quest.277D15B7FC23784D.quest_desc: ["&nForte&r \\n\\n&9Voador&r \\n&bÁgua&r \\n\\n&nVulnerável&r \\n\\n&6Terra&r"]
	quest.277D15B7FC23784D.title: "&eElétrico"
	quest.27826D74ADC73556.quest_desc: ["Cozinhar &#ED8C61Pó de Cobre&r com &#90F0E7Oxigênio&r em um &#E3CE54EBF de Kanthal&r lhe dará &#E87848Barra Quente de Cobre Recosido&r. Isso pode ser resfriado em um &#4CBBD9Freezer a Vácuo&r para obter &#E87848Barra de Cobre Recosido&r. Essas Barras podem ser macerados para obter &#E87848Pó de Cobre Recosido&r."]
	quest.2782EA80C1C74EBD.quest_desc: ["O Triturador de Mobs &ldeleta&r mobs em sua área de trabalho, coletando o saque desse mob, além de converter a &aExperiência&r que aquele mob obteria em &aEssência&r. Você também pode opcionalmente usar o que seria a Experiência para aplicar Saque ao Triturador de Mobs.\\n\\nChefes e outros mobs que não podem ir para geradores estão na \"lista negra\" do Triturador de Mobs. Em vez de serem &ldeletados&r, eles recebem 75 de dano por operação.\\n\\nEsta máquina suporta Adicionais de Alcance."]
	quest.2786D5AC19163524.quest_desc: ["Este bloco ativa receitas de fundição em sua cozinha multi-bloco!"]
	quest.2786D5AC19163524.quest_subtitle: "Não precisa de temporizador"
	quest.2786D5AC19163524.title: "Querida, tem uma Fornalha na Cozinha"
	quest.278D34BBC13356DF.quest_desc: [
		"Um pântano roxo! \\n\\nEstes têm Cogumelos de Tinta e Mistura Virulenta por toda parte!"
		"{image:atm:textures/questpics/undergarden/undergarden_ink.png width:200 height:100 align:center}"
	]
	quest.278D34BBC13356DF.title: "Ink Mushroom Bog"
	quest.2790EB2E347D28DE.quest_subtitle: "Derrote todos os chefes do Cataclysm"
	quest.27A0BCE75F198A82.quest_subtitle: "Nível: &e1"
	quest.27A4FA38992448A0.quest_desc: [
		"As Flux Networks também fornecem uma maneira de carregar seus itens sem fio, até mesmo entre dimensões!\\n\\nAssim que tiver um Plug conectado ao seu sistema de energia, você vai querer fazer o &9Flux Controller&r e colocá-lo no chão.\\n\\nClique com o botão direito nele para abrir a interface e vá para a aba \"Carregamento sem Fio\". A partir daí, você pode selecionar cada seção do seu inventário que gostaria de manter carregada. Para ativar, certifique-se de apertar o botão de alternância na parte inferior para habilitar o Carregamento Sem Fio e, em seguida, clique em aplicar!\\n"
		"{image:atm:textures/questpics/basic_power/wireless_ui.png width:125 height:150 align:center}"
	]
	quest.27A4FA38992448A0.title: "Carregamento sem Fio"
	quest.27ACBFA9D014D2A6.quest_desc: ["&aVolkner&r aumentará seu Limite de Nível até o 55. \\n\\nSeu Item de Assinatura é a &aPedra do Trovão&r."]
	quest.27ACBFA9D014D2A6.title: "&aLíder de Ginásio Volkner"
	quest.27B5D0329DD92126.quest_desc: ["Sopa... feita de Abelhas? Parece meio desumano... \\n\\nComer/Beber isso lhe dará o Efeito Energizado por um tempo e dá uma chance de dar Sorte! \\n\\nTambém há uma chance de Levitação, Queda Lenta, Veneno e Paralisia. \\n\\nE falando em Paralisia, você pode fazer Poções Paralisantes usando a Sopa."]
	quest.27E8ED4B5F8127F9.quest_subtitle: "Nível: &b4"
	quest.27E951F4F4F6F847.quest_desc: ["Semelhante ao &aThorn Pendant&r, só que um pouco mais quente. Não, espere, muito mais quente! \\n\\nO &cPingente de Chama (Flame Pendant)&r tem uma chance de atear fogo em seus atacantes! Quando eles estão em chamas, o &cPingente&r também lhe dará Resistência ao Fogo."]
	quest.27E951F4F4F6F847.quest_subtitle: "Colar"
	quest.27E951F4F4F6F847.title: "&cFlame Pendant&r"
	quest.27FA2DB7839172BB.quest_desc: ["A &c&lMochila&r por padrão só carregará &eItens&r em sua Mão e Armadura que você está vestindo. Mas e se quiséssemos carregar mais do que isso! \\n\\nEntão precisaremos do Carregador por Indução! Com isso acoplado, cada &eItem&r em seu Inventário que pode receber carga, será carregado."]
	quest.27FC0C092EE00532.quest_desc: ["O Enlatador ME pode encher ou esvaziar recipientes que podem conter fluidos, químicos, energia, como baldes, tanques químicos e mais. Ele ejeta automaticamente para provedores de padrão se um padrão for usado para enchê-los."]
	quest.27FC0C092EE00532.quest_subtitle: "não confundir com o me caner"
	quest.27FC0C092EE00532.title: "Enlatando este Líquido: O Enlatador ME"
	quest.27FD46A8C958D259.quest_desc: ["O Totem de Retorno da Morte é um item de uso único que permite a um jogador se teletransportar de volta ao local de sua morte."]
	quest.27FEF80A08AF43C2.quest_desc: [
		"O Santuário da cor de &6A&8b&6e&rlha&r! \\n\\nPercorra a estrutura, eu recomendo não tocar em nenhuma Alavanca, Botão, Gancho de Armadilha ou Placa de Pressão, ou pode ser mortal! \\n\\nQuando chegar à &eEssência Amarela&r, prepare-se para correr! \\n\\nVocê precisará correr e pular através de &eAnéis Elétricos&r. Quando fizer isso, mais aparecerão! Continue fazendo isso por um longo tempo e, com sorte, um dia você terminará."
		"{image:atm:textures/questpics/bumblezone/bumble_yellow1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_yellow2.png width:200 height:100 align:center}"
	]
	quest.27FEF80A08AF43C2.title: "&eSantuário Sempiterno Amarelo&r"
	quest.2801B7B6BF61E978.quest_desc: ["O &3Querosene&r pode ser usado para fazer Gasolina ou como combustível em uma Lâmpada de Querosene."]
	quest.2801B7B6BF61E978.quest_subtitle: "Você já viu Quero-sene?"
	quest.2801B7B6BF61E978.title: "Querosene"
	quest.282A23C3E7561796.quest_desc: [
		"A &#94C0E3Matriz de Processamento&r é uma estrutura multibloco grande que permite simular máquinas operando em paralelo. O máximo de operações paralelas é &#94E3A264&r."
		""
		"Para construir o multibloco, primeiro selecione a quantidade de máquinas paralelas que deseja simular na interface do bloco controlador."
		""
		"{image:atm:textures/questpics/modernindustrialization/proc_array_gui.png width:175 height:100 align:center}"
		""
		"{@pagebreak}"
		"To use the machine, you need to put the machine you want to simulate into the slot on the right side of GUI. You need the same amount of machines as you want operations."
		""
		"Além disso, a &#94C0E3Matriz de Processamento&r normalmente aceita todos as Melhorias também."
	]
	quest.283AB56F81EF03A5.quest_desc: ["Para alimentar seus &6Trilhos Elétricos&r e sua &eLocomotiva Elétrica&r, você precisará de &eEstruturas (Frames). As Estruturas&r precisam ser alimentadas e moverão a energia para cada &eEstrutura&r conectada."]
	quest.283AB56F81EF03A5.title: "&eEstruturas (Frames)"
	quest.283D7E65F2AD45F2.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		""
		"Uma versão aprimorada do Scanner de Mobs que aplica o efeito Brilhando (Glowing) aos mobs próximos quando ativado."
	]
	quest.28408BFAA54E4FC6.quest_desc: ["A &7Armadura de Couro&r é o pior conjunto de Armadura que você pode obter. \\n\\nIsso ocorre principalmente porque a &c&lMojang&r esperava que você a obtivesse antes de qualquer outra. \\n\\nEu quase nunca a obtenho, no entanto, porque luto para encontrar tantas &8V&fa&8c&fa&rs&r, desculpe &c&lMojang&r!"]
	quest.28408BFAA54E4FC6.quest_subtitle: "7"
	quest.28408BFAA54E4FC6.title: "&7Armadura de Couro"
	quest.285656AF1F870AF8.quest_desc: ["Uma das 2 infusões de Nível Básico, mas não subestime o Baú de Draconium. Ele tem mais espaço que um baú duplo, pode fundir e criar itens e, o melhor de tudo, pode mudar de cor! Facilmente meu Baú favorito em qualquer mod!"]
	quest.285656AF1F870AF8.title: "Baú de Draconium"
	quest.285B3FB38B12F8CA.quest_desc: [
		"Precisaremos desses dois Blocos para fazer &dSal Ammoniac (Sal Ammoniac)&r (senti vontade de chamar de Multi-bloco, mas não considero 2 Blocos um Multi-Bloco). Um Tanque de &dSal Ammoniac&r na parte inferior com um &dAcumulador de Sal Ammoniac&r em cima dele. \\n\\nO &dAcumulador de Sal Ammoniac&r é onde a &9Água&r e os &dCristais&r irão; ele pode conter 10.000mb de &9Água&r ou 10 Baldes, e uma pilha de &dCristais de Sal Ammoniac&r. O Tanque irá conter o &dSal Ammoniac&r criado e pode conter 2.000mb ou 2 Baldes."
		"{image:atm:textures/questpics/theurgy/theurgy_sal_front.png width:100 height:200 align:center}"
	]
	quest.285B3FB38B12F8CA.title: "Fazendo &dSal Ammoniac"
	quest.2869AB982799CF0C.quest_desc: ["O &cKit de Trilho de Mão Única&r é bem simples. Os &7Carrinhos&r só podem ir para onde a seta está apontando."]
	quest.2869AB982799CF0C.title: "&cKit de Trilho&r de Mão Única"
	quest.2875FACD3BFB0A8E.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		""
		"Fornece cura menor quando ativado, mas só pode ser ativado se o jogador sofreu dano recentemente ou está sofrendo dano."
	]
	quest.287B47E27EBC2C18.quest_desc: ["A Fábrica de Encantamentos é basicamente uma Mesa de Encantamentos automatizada. Quando fornecida com Equipamento/Livros e &aEssência&r, ela encantará aquele item com algo aleatório. Esta máquina pode usar fluidos de tanques diretamente acima dela, para permitir um potencial aumentado para encantar equipamentos e livros."]
	quest.288406DE6DA31BA6.quest_desc: ["Muitas coisas precisam de &cEnergia&r, especialmente no &8&lIE&r. Para começar, precisaremos de alguns &6Alicates de Corte de Engenheiro&r! \\n\\nVocê pode usá-los para cortar algumas Chapas em &cFios&r, que podem então ser colocados em &cBobinas&r, prontos para uso. \\n\\nEles também são usados para remover &cFios&r de &cConectores&r."]
	quest.288406DE6DA31BA6.title: "Energia do &8&lImmersive Engineering&r!"
	quest.28847A536C38EEA0.quest_desc: ["&cTransformadores&r são como passamos de Conexões &6LV&r para Conexões &eMV&r. O &cConector&r pequeno é &6LV&r e o maior é &eMV&r! \\n\\nSe você quiser ir de &eMV&r para &5HV&r, precisaremos de um &5Transformador HV&r. Estes funcionam da mesma forma que o outro &cTransformador&r, apenas o &cConector&r menor é &eMV&r e o maior é &5HV&r! \\n\\nNão, você não pode ir de &6LV&r para &5HV&r sem &eMV&r!"]
	quest.28847A536C38EEA0.quest_subtitle: "Dirigido por Michael Bay"
	quest.28847A536C38EEA0.title: "&cTransformadores"
	quest.288A4A32CDBB14D5.quest_desc: [
		"Outra estrutura feita principalmente de Cera Ancestral. \\n\\nEsta parece quase uma antena parabólica! Cheia de &ePólen&r, então cuidado aqueles com alergias. \\n\\nNo meio você pode encontrar um bloco de Esmeralda e bastante Ametista."
		"{image:atm:textures/questpics/bumblezone/bumble_dish.png width:200 height:100 align:center}"
	]
	quest.288A4A32CDBB14D5.title: "Santuário Ancestral"
	quest.2893F483C10293E6.quest_desc: [
		"&lBem-vindo ao &bApplied Energistics 2&f!\\n\\nApplied Energistics 2 (ou &oAE2&r para abreviar) é um mod de &barmazenamento digital&f incrivelmente versátil, permitindo um armazenamento extremamente eficiente e todos os tipos de capacidades de automação para aumentar muito sua experiência de Minecraft modificado desde o início que você quiser até o final do jogo.\\n\\nPara mais informações sobre o AE2 além deste capítulo, consulte a wiki em"
		"&o&bappliedenergistics.github.io&f&r."
	]
	quest.2893F483C10293E6.quest_subtitle: "Sistema de Armazenamento Virtual"
	quest.2893F483C10293E6.title: "Applied Energistics 2"
	quest.2897FA291E5A38D8.quest_desc: ["A &bÂncora Espcial&f é um dispositivo companheiro da linhagem &bEspacial E/S&r que funciona simplesmente como um carregador de chunks. Quando conectado a uma Rede ME, o Anchor forçará o carregamento de todos os chunks ocupados pela Rede ME em todos os cabos e dispositivos, excluindo sub-redes, contanto que a rede permaneça energizada."]
	quest.289B30DAC960BFF2.quest_desc: ["Estes podem ser encontrados em baús dentro das Cidades do End."]
	quest.289B30DAC960BFF2.quest_subtitle: "Baús da Cidade do End"
	quest.28AE1D7D659E55D4.quest_desc: ["Com nossa &6Picareta de Madeira&r, precisaremos minerar um pouco de &7Pedra&r! \\n\\nSim, vamos substituir imediatamente nossa &6Picareta de Madeira&r... \\n\\nEu recomendo coletar 18 &7Pedregulhos&r com ela antes de descartá-la. Isso é o suficiente para fazer uma &cFornalha&r, Espada, Machado, Picareta e Enxada!"]
	quest.28AE1D7D659E55D4.title: "&7Pedregulho"
	quest.28AE3B536D23E138.quest_subtitle: "Fabricação por Infusão"
	quest.28AE3B536D23E138.title: "&fAbelha de Inferium"
	quest.28AF8DD34412CBAA.title: "Módulo de Velocidade Dracônico"
	quest.28B3591BFC0FA08B.quest_desc: ["O Construtor de Wither, como seu nome indica, constrói Withers. É parte da Bússola do Wither para a Estrela ATM.\\n\\n&8Você pode querer revestir o Construtor de Wither em algum vidro à prova de wither, para evitar que os Withers o explodam."]
	quest.28C9EDBF6607E180.quest_desc: ["Este bloco faz parte de uma cozinha multi-bloco.\\n\\nIsso mostrará todas as receitas que estão disponíveis para você com a comida que você tem em seu inventário, ou armazenada no multi-bloco da cozinha.\\n\\nVocê pode finalmente criar uma cozinha bonita no Minecraft."]
	quest.28C9EDBF6607E180.quest_subtitle: "Betty White nasceu antes do Pão Fatiado"
	quest.28C9EDBF6607E180.title: "A MELHOR COISA DESDE O PÃO FATIADO"
	quest.28E60192912BEBAD.quest_desc: ["No &l&2Vanilla&r, os Aldeões podem ser muito frustrantes de lidar. Trocar as negociações não é nada fácil, e as profissões às vezes podem ser difíceis de lidar.\\n\\n&l&2Easy Villagers&r é um mod para tornar tudo isso muito mais fácil de lidar! Para começar, você pode pegar um aldeão agachando e clicando com o botão direito nele. Eles podem então ser facilmente colocados no mundo, ou em blocos específicos do mod &l&2Easy Villager&r!\\n\\nVocê pode pesquisar &d@EasyVillagers&r no JEI para ver os blocos que o mod oferece!"]
	quest.28E60192912BEBAD.quest_subtitle: "Aldeões, simplificados"
	quest.28E60192912BEBAD.title: "&l&2Easy Villagers"
	quest.28E99A6E17E86709.quest_desc: ["Mover &bFluidos&r é uma parte essencial do &8&lIE&r, basta pensar no Óleo de Creosoto e no Óleo Vegetal! \\n\\n&bCanos de Fluido&r são nossas maneiras básicas de mover &bFluidos&r, se você quiser mais rápido, confira as &bBombas de Fluido&r. \\n\\n&bCanos de Fluido&r, como os Conectores de Energia, são determinados para &9Entrada&r e &6Saída&r pelo que estão conectados. Algumas Máquinas precisam de &4Sinais de Redstone&r para &6Sair&r para os &bCanos de Fluido&r, como o &b&lTanque&r! \\n\\nPodemos usar um &6Martelo de Engenheiro&r para mudar a que os &bCanos&r se conectam, além de podermos usar &8Andaimes de Aço&r neles para cobri-los, ou Corante para tingi-los!"]
	quest.28E99A6E17E86709.title: "Movendo &bFluidos"
	quest.28F40B9DD4896B5E.quest_desc: ["&nForte&r \\n\\n&dFada&r \\n&bGelo&r \\n&6Pedra&r \\n\\n&nVulnerável&r \\n\\n&4Lutador&r \\n&cFogo&r \\n&6Terra&r"]
	quest.28F40B9DD4896B5E.title: "&7Aço"
	quest.28FB4B9DCC268404.quest_subtitle: "Ameixa + Cereja"
	quest.28FDB2D13D0DDE8E.quest_desc: ["&b&lChipped&r é semelhante aos Mods Chisels, pois muda os designs dos Blocos, mas o &b&lChipped&r tem sua própria maneira de fazer isso! \\n\\n&b&lChipped&r em vez disso usa Estações que você precisará ir para mudar os Blocos. \\n\\nHá 7 Estações diferentes, cada uma muda Blocos diferentes: a Mesa de Carpinteiro muda Madeira, o Soprador de Vidro muda Vidro. \\n\\nE 6 dessas Estações podem ser transformadas em um Item de mão para acesso mais fácil. \\n\\nHá até mesmo Melhorias de Mochila para elas!"]
	quest.28FDB2D13D0DDE8E.title: "&l&bChipped&r"
	quest.28FEB4C11AD1AE7C.quest_desc: ["&bDiamantes&r são geralmente caros... para o Vanilla, mas isso é modificado, você terá o suficiente para pelo menos 1 &bDiamond Generator&r. Ainda usa combustível de fornalha normal."]
	quest.28FEB4C11AD1AE7C.title: "&bDiamond Generator"
	quest.290C1416EA2B5DF2.quest_subtitle: "Parecem um pouco secos"
	quest.29131C3532610ADF.quest_desc: ["Esta é uma Tampa de Pilar de Nível 2 para o Carregador de Luz Estelar."]
	quest.29131C3532610ADF.title: "Tampa de Pilar de Nível 2 do Carregador de Luz Estelar"
	quest.291C76140DE97E3C.quest_desc: ["O &bIgnitium&r é como a Netherita, mas requer habilidade real para obtê-lo. \\n\\nO &b&lIgnis&r só dropará 1, então faça bom uso dele! \\n\\nVocê pode usá-lo para aprimorar sua Armadura de Netherita ou para fazer as Armas."]
	quest.291C76140DE97E3C.quest_subtitle: "Melhor que Netherita?"
	quest.291C76140DE97E3C.title: "&bIgnitium"
	quest.291EE514A1602C46.quest_subtitle: "Balsa + Azaleia Florida"
	quest.29283BF1B6ED3634.quest_desc: ["A Besta Mecânica é feita como uma Besta normal, só que com Aço de Golem. \\n\\nFunciona como uma Besta normal, só que muito mais forte! E pode ser encantada para fazer ainda mais!"]
	quest.29434DB0CC2E30E6.quest_desc: ["Combinando &cPó de Mundabitur&r, &bPó de Cristal Arcano &r, &8Carvão&r e um &eBarra de Ouro&r, obteremos nossa primeira Liga! O &6Barra de Deorum&r! \\n\\nEste é o Barra fundamental do &6&lForbidden \\& Arcanus&r, você precisará de dezenas dele! \\n\\nÉ especialmente usado para Blocos de Construção para nossas Máquinas Multibloco."]
	quest.29434DB0CC2E30E6.title: "&6Deorum"
	quest.29448D08C8777425.quest_desc: ["Esta noite ele estará dormindo com os Peixes. \\n\\nO &cChapéu de Pescador&r ajuda você a Atrair Peixes e aumenta suas chances de obter um Drop Raro!"]
	quest.29448D08C8777425.quest_subtitle: "Cabeça"
	quest.29448D08C8777425.title: "&cChapéu de Pescador"
	quest.295C77EEC89000FC.quest_subtitle: "Gera Fonte da Morte de Mobs e da Criação de Animais"
	quest.295EB6CFEC029AE2.quest_desc: ["Antes de chegar aqui, primeiro você precisa de um item que necessite de OP: Arco Wyvern, Capacitor Caótico, Cajado de Poder, o que for. Então você precisa de um Módulo de Energia no item, que determina o armazenamento de OP no item e é isso que o item usará para se energizar. Quando tiver isso, faça e coloque o Transfusor de Energia, coloque OP nele e, em seguida, coloque seu item dentro dele! Você saberá que está funcionando quando o OP nele acender e se mover."]
	quest.295EB6CFEC029AE2.title: "Adicionando OP aos itens"
	quest.2960FFE0C53DFEB1.quest_desc: [
		"&cConfinamento Permanente de Sevira&r é o terceiro nível de &6Rituais de Infusão&r. É usado principalmente para criar o próximo nível de giz de fundação, o Giz Preto."
		""
		"Também é usado para criar alguns itens que podem acelerar significativamente a criação e execução de rituais."
	]
	quest.2960FFE0C53DFEB1.quest_subtitle: "O Ritual \"Ainda Mais de Tudo\""
	quest.2960FFE0C53DFEB1.title: "&cConfinamento Permanente de Sevira"
	quest.2982D38BD5EE6349.quest_desc: ["Você pode encontrar essas abelhas circulando pelas Florestas Distorcidas. O seu ninho também pode ser obtido ao cultivar Fungos Distorcidos, com uma chance de 2%."]
	quest.2982D38BD5EE6349.quest_subtitle: "Alimente uma Abelha Cogumelo com Fungo Distorcido"
	quest.2982D38BD5EE6349.title: "&fAbelha de Cogumelo Distorcido"
	quest.298437197EA5680D.quest_subtitle: "Cereja Preta + Cacau"
	quest.298963543B99734E.quest_desc: ["Os Mares Estrelados geram suas próprias versões de Corais! \\n\\nSó não seja como eu e esqueça o Toque Suave para pegá-los..."]
	quest.298A7BED5C2C7582.quest_desc: ["As &aCélulas de Indução&r são colocadas dentro da &a&lMatriz de Indução&r e aumentarão a quantidade de armazenamento que ela possui. \\n\\nE sim, seus totais se somarão! \\n\\n&aCélula de Indução Básica&r: armazena 3.2GFE cada. \\n\\n&cCélulas de Indução Avançadas&r: armazenam 25.6GFE cada. \\n\\n&bCélula de Indução de Elite&r: armazena 204.8GFE cada. \\n\\n&5Célula de Indução Suprema&r: armazena 1.6TFE cada."]
	quest.298A7BED5C2C7582.quest_subtitle: "Armazenamento"
	quest.298A7BED5C2C7582.title: "&aCélulas de Indução"
	quest.29917E6196649F5D.quest_desc: ["Velocidade é a distância sobre o tempo, ou seja, quanto tempo leva para ir do ponto A ao ponto B... bem... estamos trabalhando com &dRevoluções&r, é mais quanto tempo leva para ir do ponto A ao ponto A neste grande Círculo. \\n\\nDe qualquer forma, é a rapidez com que nossas &6Máquinas&r se movem, incluindo &dEngrenagens&r e &8Eixos&r! \\n\\nIsso é importante porque a Velocidade afetará como outras &6Máquinas&r funcionam. Algumas precisarão de uma certa Velocidade e outras funcionarão de forma mais eficiente em Velocidades mais altas. \\n\\nPodemos colocar um Velocímetro (sim, como em um carro) em nosso Sistema Cinético para ver a rapidez com que tudo está se movendo."]
	quest.29917E6196649F5D.title: "Velocidade"
	quest.2993EAB4850B7172.quest_subtitle: "Salgueiro Branco + Cereja"
	quest.299F56B753286D0C.quest_subtitle: "Nível: &e5"
	quest.29A05589E96C0569.quest_subtitle: "Nível: &54"
	quest.29A1E1FF02BD9219.quest_desc: [
		"Uma Floresta tão azul quanto o Oceano. \\n\\nA Starlight Forest é de longe o bioma mais comum na Luz Estelar. \\n\\nEla tem dezenas de Árvores Lunares cobrindo-a inteiramente com muitos Mobs, passivos e hostis, abaixo dela."
		"{image:atm:textures/questpics/eternal/starlight_forest.png width:200 height:100 align:center}"
	]
	quest.29A1E1FF02BD9219.title: "Starlight Forest"
	quest.29A71E780923874E.quest_subtitle: "Nômade + Cana"
	quest.29A71E780923874E.title: "&fAbelha de Silício"
	quest.29AE69722AB4C75C.quest_subtitle: "Nível: &a2"
	quest.29C78845B488EDF8.quest_desc: [
		"As muitas, muitas &5Flores Roxas&r and &5Cera Ancestral Luminescente Roxa&r nos mostram que esta é a &5Estrutura Roxa&r. \\n\\nAtravesse os &5túneis de vento roxos&r, afunde pelos &5esgotos roxos&r, caminhe pelas &5salas roxas&r cheias de &5Flores Roxas&r, ametista e cortinas de barbante, para chegar à &5Essência Roxa&r. \\nUma vez lá dentro, você terá que sobreviver até o tempo limite para vencer. Espinhos Roxos sairão do chão para te matar, evite-os!|"
		"{image:atm:textures/questpics/bumblezone/bumble_purple1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_purple2.png width:200 height:100 align:center}"
	]
	quest.29C78845B488EDF8.title: "&5Santuário Sempiterno Roxo"
	quest.29C83B00AC4AFC23.quest_desc: [
		"Agora que você chegou até aqui, pode estar se perguntando: o que vem a seguir? Bem, há muito mais coisas para explorar no Occultism! "
		""
		"Você pode ver uma lista abrangente de cada ritual e item em seu &6Dicionário dos Espíritos&r, você pode tentar examinar todos os resultados dos rituais para ver se encontra algo que desperte seu interesse!"
		""
		"Se ainda não o fez, você pode projetar e decorar quatro áreas rituais separadas: uma para Invocações, uma para Possessões, uma para Infusões e uma para Rituais diversos (Rituais Selvagens e Eldritch principalmente)."
		""
		"Sempre há novas maneiras de usar cada recurso aparentemente mundano para maximizar sua experiência com o modpack. Boa criação de rituais!"
	]
	quest.29C83B00AC4AFC23.title: "O que vem a seguir?"
	quest.29C9F8719DA63D8D.quest_desc: ["A &2&lSerra Circular&r funciona de forma semelhante à &4&lBroca de Mineração&r, só que para &2Árvores&r! \\n\\nRequer &2Bio-Diesel&r como Combustível, que não vou explicar como obter aqui também! \\n\\nE algum tipo de &8Lâmina de Serra&r. Que você pode anexar através do Slot Superior na &6Bancada de Trabalho do Engenheiro&r. \\n\\nSimplesmente quebre Troncos em uma &2Árvore&r e todos os Troncos, Folhas e Ninhos de Pássaros cairão com ela! Você pode segurar Shift para não quebrar tudo que está anexado. \\n\\nA &2&lSerra Circular&r também causa 10 de Dano! Caramba, por que usar uma Espada? Ah sim, as &8Serras&r têm Durabilidade e precisam de &2Bio-Diesel&r. \\n\\nA &2&lSerra Circular&r pode conter 1 &8Lâmina&r ou &8Disco&r e 2 Melhorias."]
	quest.29C9F8719DA63D8D.title: "&2&lSerra Circular"
	quest.29D28983E0200A3C.quest_desc: ["&l&dArs Nouveau&r é tudo sobre usar Glifos em Livros de Feitiços para poder lançá-los como Feitiços!"]
	quest.29D28983E0200A3C.title: "&d&lArs Nouveau"
	quest.29D309F9740FAEEA.quest_subtitle: "Nível: &c5"
	quest.29DF2E7D0402284F.title: "Radiância"
	quest.29E2033EA65E706E.quest_desc: [
		"Aqui você pode encontrar a casa de um Criador de Slimes apenas ganhando a vida... espere, o quê? Como um Aldeão chegou aqui?\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_ranch.png width:200 height:100 align:center}"
	]
	quest.29E2033EA65E706E.quest_subtitle: "Um \"Criador de Slimes\""
	quest.29E2033EA65E706E.title: "Rancho de &6Slime de Mel&r"
	quest.29E9E361DDC8041B.title: "Estandarte: Sol"
	quest.29EA8E178F8F8FDB.quest_desc: ["A &9&lMesa de Reforja Simples&r é usada como uma &5&lMesa de Encantamentos&r, mas com &eAfixos&r! \\n\\nPara adicionar um &eAfixo&r a qualquer &eItem&r, coloque o &eItem&r no espaço central. Em seguida, adicione seu Material de Raridade no espaço à esquerda. \\n\\nO Material de Raridade determinará qual &eAfixo&r de Raridade você obterá em seu &eItem&r. Isso pode ser usado para aprimorar alguns Itens, como de &8Comum&r para &aIncomum&r. \\n\\nVocê terá 3 escolhas de &eAfixos&r que pode selecionar, e semelhante a uma &5&lMesa de Encantamentos&r, o segundo e o terceiro ficam mais caros. \\n\\nCom a &9&lMesa de Reforja Simples&r, só podemos obter &eAfixos&r até o nível &9Raro&r."]
	quest.29EA8E178F8F8FDB.title: "&9&lMesa de Reforja Simples"
	quest.29EC143D7E0347DE.quest_desc: ["A Adaga da Fome é feita com os Dentes da Fome. Não, não estou dizendo Dentes. \\n\\nA Adaga tem um Valor de Fome. Quando você atinge Mobs, ele sobe, quando está inativo, ele diminui. Quando chega a 100%, você recebe bônus. E se chegar a 0%, começará a te matar. \\n\\nQuando você atinge Mobs (ou Jogadores), também dará o efeito de Fome. \\n\\nEu não a culpo, eu também fico com raiva quando estou com fome."]
	quest.29EE878BC8D3A742.quest_desc: [
		"Para começar nossa própria fazenda de abelhas, teremos que encontrar algumas abelhas... e capturá-las."
		""
		"Clicar com o botão direito em uma abelha com isso irá capturá-la!"
		""
		"Aventurar-se também pode render algumas &6Gaiolas de Abelha Resistentes&r, então fique de olho!"
	]
	quest.29EE878BC8D3A742.title: "&fCapturando &6Abelhas&f!"
	quest.29FA0E9664935566.quest_subtitle: "Balsa + Cacau"
	quest.2A01CE9206DD4F8A.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Minera blocos de minério adjacentes de uma só vez, mas leva um pouco mais de tempo para minerar."
	]
	quest.2A032EC573B5316C.quest_desc: ["Para obter o &lNível de Mundo: &2Fronteira&r, você obviamente precisará ter o &9&lRefúgio&r concluído, mas também precisará de alguns &eItens com Afixos&r! \\n\\nQuantos? Você precisa de um conjunto completo de &eArmadura com Afixos&r mais uma &eFerramenta &fou &eArma com Afixos&r. \\n\\nAgora, &4Invasores &f&aIncomuns&r e &aGemas&r são mais abundantes, com o resto seguindo em ordem: &8Comum&r, &9Raro&r e também &5Épico&r. \\n\\nO Jogador com o &lNível de Mundo: &2Fronteira&r receberá um Bônus de 35% de Experiência e 20% de Sorte! \\n\\nEi, mas nem tudo será fácil, agora os &4Monstros&r ganharão 4 Pontos de Armadura extras."]
	quest.2A032EC573B5316C.title: "&lNível de Mundo: &2Fronteira"
	quest.2A049419C78E96F4.quest_subtitle: "Nível: &a2"
	quest.2A196974431FCC42.quest_desc: ["A &cForja Infernal&r é um drop da &c&lMonstruosidade de Netherita&r e tecnicamente não é uma arma, é uma picareta! \\nEla pode ser usada para minerar até o nível de Netherita, então pode minerar Minério de Allthemodium. \\n\\nQuando clicada com o botão direito, ela ataca em um modo de área de efeito. Socando o chão e atingindo tudo que estiver por perto. \\n\\n(Pode ser encantada com encantamentos de Espada e Picareta!)"]
	quest.2A196974431FCC42.title: "&cForja Infernal"
	quest.2A1BFB2E0F1F3312.quest_desc: ["A &dVareta do End&r causa 10 de Dano e também atinge Endermen. \\nAs &5Pérolas do Ender&r não atingirão Mobs, em vez disso, elas o teleportarão para muito mais longe quando disparadas. \\nO &3Tridente&r age como um arremesso de &3Tridente&r normal, causando 8 de Dano. \\nAs &cVaras de Blaze&r causam 10 de Dano e incendeiam os Mobs!"]
	quest.2A1BFB2E0F1F3312.title: "Munição da &5&lRailgun&r do &2&lMinecraft"
	quest.2A20000FAEC2E16A.quest_desc: ["Para extrair energia ou itens do seu reator, ou mesmo inserir combustível, você precisará desses blocos &cobrigatórios&r.\\n\\nA &cTomada de Energia (Power Tap)&r fornece uma maneira de você \"acessar\" a energia que um reator &9passivo&r produz. Você pode conectar canos e cabos para extrair a energia dele.\\n\\nAs &aPortas de Acesso (Access Ports)&r são necessárias para todo reator e permitem que você insira combustível no reator ou extraia resíduos. Geralmente é uma boa ideia ter 2 por reator, um para cada tarefa."]
	quest.2A20000FAEC2E16A.title: "Interagindo com o Reator"
	quest.2A2CC461B9620BDC.quest_subtitle: "Nível: &a2"
	quest.2A30595DC6DDBFF7.quest_desc: [
		"Os &6Trilhos Elétricos&r são usados para as &eLocomotivas Elétricas&r. Eles precisarão ser alimentados por &eEstruturas (Frames)&r e sim, vai te machucar se você tocar."
		"{image:atm:textures/questpics/railcraft/rail_electric_rail.png width:150 height:100 align:center}"
	]
	quest.2A30595DC6DDBFF7.title: "&6Trilhos Elétricos"
	quest.2A3683BF7E50EF83.quest_desc: [
		"A maioria dos itens que precisamos do &3Outro Mundo&r até agora só precisavam de um pouco de Fogo Espiritual (Spiritfire). No entanto, precisaremos da ajuda do &3Terceiro Olho (Third Eye)&r para encontrar o Minério do &3Outro Mundo&r."
		""
		"Também precisaremos de uma picareta especial para poder minerá-lo. Para isso, precisaremos Infundir um Demônio em uma &dCabeça de Picareta Sintonizada com o Espírito (Spirit Attuned Pickaxe Head)&r para criar uma picareta que possa quebrar esse novo tipo de minério."
	]
	quest.2A3683BF7E50EF83.title: "Ferramentas do Ofício: Picareta Infundida"
	quest.2A444F4CCC72545D.quest_desc: ["O Item mais fácil que precisaremos para a &6&lEstrela ATM&r do &4&lCataclysm&r é o &5Sacrifício Abissal (Abyssal Sacrifice)&r. \\n\\nOs Itens mais básicos necessários são os Blocos de Barras e Ametista, que são apenas Itens &2&lVanilla&r. \\n\\nEntão, você precisará de uma Concha de Náutilo e um Coração do Mar. Estes são Itens &2&lVanilla&r que são raros de obter... a menos que você mate &5Deeplings&r que podem dropá-los! \\n\\nVocê também precisará de um Athame, que é uma arma usada por &5Feiticeiros Deepling &f e &5Sacerdotes&r e dropada por eles na morte. \\nA última parte nos dá uma escolha, ou Coral Cristalizado ou Pedaço de Coral. Ambos são drops do &5Golem de Coral&r e do &5Coralssus&r."]
	quest.2A444F4CCC72545D.title: "&5Sacrifício Abissal (Abyssal Sacrifice)"
	quest.2A4FE9644F3B9DC1.quest_desc: ["Versão aprimorada do &2Prudentium&r."]
	quest.2A4FE9644F3B9DC1.quest_subtitle: "26"
	quest.2A4FE9644F3B9DC1.title: "&cArmadura de Tertium"
	quest.2A5004EB99AE4F96.quest_desc: [
		"Há mais itens do Outro Mundo que você precisará coletar, e comer &cFruta do Sonho do Demônio&r toda vez que precisar do efeito do &7Terceiro Olho&r se torna irritante."
		""
		"É para isso que servem os &dÓculos do Outro Mundo&r! Quando equipados (mesmo no seu slot de Curios), eles dão o efeito do Terceiro Olho!"
	]
	quest.2A5004EB99AE4F96.quest_subtitle: "Pare de comer essa fruta!"
	quest.2A5004EB99AE4F96.title: "Ferramentas do Ofício: Óculos Espectrais"
	quest.2A50A687C40DB864.quest_desc: [
		"As &6&lParedes da Colmeia&r são a fundação da &l&6Bumblezone&r. \\n\\nSão paredes massivas de &6Favos de Mel&r e &eCera&r que vão do chão ao teto. \\n\\nElas também contêm Favos de &lProductive Bees&r e buracos nas &6&lParedes&r onde Blocos de Cria (Brood Blocks) irão aparecer."
		"{image:atm:textures/questpics/bumblezone/bumble_hivewall.png width:200 height:100 align:center}"
	]
	quest.2A50A687C40DB864.title: "&6&lParede da Colmeia"
	quest.2A559D527BC88DEC.quest_desc: ["Jogue um &9Ovo de Gerador de Abelha Espacial&r e um &8Bloco de Aço do Céu&r na &6lava&r, espere alguns ticks e voilà, você terá um Ovo de Gerador de Abelha de Aço do Céu."]
	quest.2A559D527BC88DEC.title: "&fAbelha de Aço do Céu"
	quest.2A5C5B44E9643A5D.title: "Módulo de Velocidade Caótico"
	quest.2A6900E87DE8BAE0.quest_desc: ["O Filtro de Mod é outro Filtro bem básico. Neste você coloca Itens e ele fará o mesmo com Lista Branca ou Lista Negra. Mas em vez de ser apenas aquele Item, será qualquer Item daquele Mod. \\n\\nUma Gema do Apotheosis só permitirá Itens do Apotheosis. Uma Liga do Mekanism só permitirá Itens do Mekanism. E assim por diante."]
	quest.2A69272FD3C57924.quest_subtitle: "Um pouco melhor"
	quest.2A6FC21142E75DD5.quest_desc: [
		"Os Lagos, Oceanos, Lagoas e Rios da &l&6Bumblezone&r. \\n\\nProvavelmente era originalmente apenas &bÁgua&r, mas todo o tempo que passou dentro da &eColmeia&r a tornou &bÁgua com Açúcar&r. \\n\\nEstes são muito úteis para sair da &l&6Bumblezone&r, pois há muito menos Blocos neste Bioma. \\n\\nTambém, &6Slimes de Mel&r aparecem às vezes aqui."
		"{image:atm:textures/questpics/bumblezone/bumble_sugar.png width:200 height:100 align:center}"
	]
	quest.2A6FC21142E75DD5.title: "Lagos de Açúcar! (&bÁgua&r)"
	quest.2A72B262AF4F11C9.quest_desc: ["Para obter a Muda de &6Dragoeiro de Socotra&r, você precisará Cruzar &7Wenge&r com &4Cocobolo&r. \\n\\nPara obter &7Wenge&r, você precisará Cruzar &4Cocobolo&r com &fBalsa&r. \\n\\nPara obter &4Cocobolo&r, você precisará Cruzar Balsa com &8Carvalho Escuro&r. \\n\\nPara obter &fBalsa&r, você precisará Cruzar &cAcácia&r com &eTeca&r. \\n\\nPara obter &fTeca&r, você pode Cruzar &2Jungle&r e &8Carvalho Escuro&r."]
	quest.2A72B262AF4F11C9.title: "Muda de &6Dragoeiro de Socotra&r"
	quest.2A793B35FE25003C.quest_desc: ["O &l&cCondensentrador &bRotativo&r pode fazer &cGás&f a partir de &bLíquidos&r, mas o &c&lOxidador &eQuímico&r pode transformar (alguns) Itens em Gás! \\n\\nIsso inclui &cTipos de Infusão&f como &0Carvão &fpara &0Carbono&r. \\n\\nIsso também será necessário para transformar Favos Desperdiçados e Favos de Lítio em seus &cQuímicos&r! \\n\\n&eItens&r irão para o &4Slot Vermelho&r e suas novas formas de &cGás&r aparecerão na &9Barra Azul&r."]
	quest.2A793B35FE25003C.title: "&c&lOxidador &eQuímico"
	quest.2A7E3F2CD335EAD0.quest_desc: ["Para começar sua jornada fazendo &aEquipamentos de Essência&r, você precisará fazer primeiro a Armadura de Inferium.\\n\\nEste equipamento pode ser aprimorado para níveis mais altos, assim como as Essências. Você também pode &9Melhorar&r com a &bMesa de Modificações&r!"]
	quest.2A7E3F2CD335EAD0.title: "&aArmadura de Inferium"
	quest.2A919F73CB09CF8B.quest_desc: [
		"Melhorias Válidas:"
		"- Run Speed"
		"- Walk Speed"
		"- Swim Speed"
		"- Decoy"
		"- Phase"
	]
	quest.2A95F4F998835B43.quest_subtitle: "9 Pepitas -> 1 Barra"
	quest.2A976D41F79C34B1.quest_desc: ["&e&lPipez&r tem sua própria maneira de Filtrar Itens, você precisa de pelo menos uma Melhoria Avançada para obtê-la. Quando uma Melhoria Avançada está instalada, você pode clicar no botão Adicionar para adicionar Filtros. \\nEntão você pode adicionar: Item, Tag ou NBT no Filtro. \\n\\nLá você também pode adicionar o filtro de Destino definido. Para configurá-lo, segure Shift e clique com o botão direito em um Inventário com ele. \\n\\nVocê também terá que configurá-lo para Lista Branca ou Lista Negra, para que apenas o Filtro ou tudo, exceto o Filtro, passe."]
	quest.2AA08313F927981E.title: "Módulo de Velocidade Wyvern"
	quest.2AA407EB0BF2922E.quest_subtitle: "Liquidâmbar + Pinheiro-loblolly"
	quest.2AAE61752728EA8D.quest_desc: ["Ao 'cair', sua Mineração é retardada. Isso inclui ao voar no criativo ou até mesmo quicando na água. Felizmente, você pode usar o Encantamento Afinidade Aquática para anular isso! Não é um encantamento vanilla, mas ainda é útil! Ah, espere, eu deveria falar sobre o Módulo... é a mesma coisa!"]
	quest.2AAE61752728EA8D.title: "Módulo Estabilizador de Mineração"
	quest.2AB0FA084739827A.quest_desc: ["Para realmente usar uma &9Perfuratriz de Túnel&r, você precisará de uma &9Cabeça de Perfuração de Túnel&r. \\n\\nElas vêm em 4 estilos diferentes e a mineração depende da &9Cabeça de Perfuração&r. \\n\\nPode ser encantada e tem durabilidade, então você vai querer encantá-la!"]
	quest.2AB0FA084739827A.title: "&9Cabeça de Perfuração de Túnel"
	quest.2ABAE97E992BB800.title: "Estandarte: Favo de Mel"
	quest.2ACFD25B43F0499C.quest_subtitle: "Ipê + Sorte"
	quest.2AD13B965611DC86.quest_desc: [
		"Facilmente o Bioma mais fascinante da &l&6Bumblezone&r, as &7&lConstruções Uivantes&r. \\n\\nNo chão há espigões de Pedra de Açúcar Infundida, &eCera Esculpível&r e &6Mel&r. \\n\\nA parte interessante é o que não está no chão. Existem &7estruturas flutuantes&r por todas as &l&7Construções Uivantes&r. \\n\\nElas são feitas de Cera Ancestral, sobre a qual você aprenderá mais eventualmente."
		"{image:atm:textures/questpics/bumblezone/bumble_constructs.png width:200 height:100 align:center}"
	]
	quest.2AD13B965611DC86.title: "&7&lConstruções Uivantes"
	quest.2AD68066C1948C90.quest_desc: [
		"Aquele primeiro &eFoliot Triturador&r foi legal, mas e se eu te dissesse que você poderia invocar um demônio que te dá 6 pós por minério bruto que ele tritura?"
		""
		"O &9Marid Triturador&r faz exatamente isso. Para invocar um, você precisará usar a &9Atração Incentivada de Fatma&r. "
	]
	quest.2AD68066C1948C90.quest_subtitle: "Invocação Máxima"
	quest.2AD68066C1948C90.title: "&9Atração Incentivada de Fatma"
	quest.2AD78E22988A92D3.quest_desc: ["Eu vejo você! \\n\\nAo usar &2Óculos de Visão Noturna&r, você ganha a habilidade de ver no escuro! Não há muito mais sobre eles..."]
	quest.2AD78E22988A92D3.quest_subtitle: "Cabeça"
	quest.2AD78E22988A92D3.title: "&2Óculos de Visão Noturna"
	quest.2ADA491A2485061C.quest_desc: [
		"&aExperiência&r é o 4º Slot e material necessário para a &6&lForja&r. \\n\\nPara adicionar &aExperiência&r, você precisará colocar 1 de 3 coisas no &aSlot de Experiência&r. \\n\\n1. &aOrbes Xpetrificados&r, estes dão a maior quantidade de &aEXP&r. \\n\\n2. &aFrasco de Encantamento&r, dá um pouco de &aEXP&r, mas é fácil de conseguir! \\n\\n3. &5Item Encantado&r, a &6&lForja&r irá remover os &5Encantamentos&r dele, mantendo-os como &aEXP&r!"
		"{image:atm:textures/questpics/forbidden/forbidden_experience.png width:135 height:100 align:center}"
	]
	quest.2ADA491A2485061C.title: "&aExperiência"
	quest.2AEA51044AD44BE8.quest_desc: ["&eDepósitos&r irão segurar &eItens&r. Eles podem segurá-los para processar os &eItens&r, ou depositar em uma &eCalha&r, ou mesmo apenas para decoração! \\n\\nVocê pode colocar uma &eCalha&r perto do final de uma &eCorreia&r para trazer &eItens&f da &eCorreia &rpara o &eDepósito&r. \\n\\nO &eDepósito&r também pode ser colocado abaixo de uma &6Máquina&r para processar &eItens&r dentro dele. "]
	quest.2AEA51044AD44BE8.title: "&eDepósito"
	quest.2AEC294578952BFD.quest_subtitle: "Lápis + Esquelético"
	quest.2AEC294578952BFD.title: "&fAbelha de Corante"
	quest.2AECDD9E2DEA708C.quest_subtitle: "Nível: &a2"
	quest.2AED15E3AC0346FE.quest_desc: [
		"Abaixo estão algumas &3Melhorias&r que você pode usar no início deste mod. Segure Shift enquanto passa o mouse sobre uma &3Melhoria&r para ver em que ela pode ser usada, ou segure Shift enquanto passa o mouse sobre algo para ver quais melhorias ela pode usar."
		""
		"Nota: O subtítulo informará a quantidade máxima dessa &3Melhoria&r que pode ser colocada em algo."
	]
	quest.2AED15E3AC0346FE.quest_subtitle: "Coisas muito úteis"
	quest.2AED15E3AC0346FE.title: "Melhorias Simples"
	quest.2AEEDCC6826CF4AB.quest_subtitle: "Negócio Suspeito"
	quest.2AEEDCC6826CF4AB.title: "&fAbelha de Petróleo"
	quest.2AF31F1769085641.quest_desc: [
		"O &aReprocessador&r é uma estrutura multibloco de 3x3x7 que possui regras específicas para concluir a construção do multibloco."
		""
		"O coração deste multibloco é o &aControlador&r, e pode ser colocado em qualquer face vertical, desde que não esteja na estrutura."
	]
	quest.2AFBE48DA832FF02.quest_subtitle: "Nível: &c5"
	quest.2B0553F307A024F7.quest_subtitle: "Nível: &c5"
	quest.2B05A29C62676EB2.title: "&l&9Recompensa do Mundo Superior:&r&e Zumbis"
	quest.2B08B19B35EEBCBA.quest_desc: ["Estas &6relíquias&r podem ser encontradas em Portais em Ruínas, Fortalezas do Nether e Bastiões por todo &cO Nether&r!"]
	quest.2B08B19B35EEBCBA.quest_subtitle: "Espero que tenha trazido resistência ao fogo... não trouxe? Boa sorte."
	quest.2B08B19B35EEBCBA.title: "&cO Nether"
	quest.2B115519A21F9CB7.quest_desc: [
		"O &d&lGuardião do Ender&r é uma besta colossal de Endstone, &dPurpur&r e &5Obsidiana&r que aguarda dentro do &dAltar do Vazio&r. \\nEle tem 6,660 &4Corações&r e cuidado para não chegar muito perto ou você pode ser puxado para mais perto dele! \\n\\nEle tem uma tonelada de ataques e habilidades, um sendo um soco muito simples para aqueles que estão muito perto de seu espaço pessoal, ou uma pancada que o jogará para trás. \\n\\nSe você estiver mais longe dele, ele pode fechar a distância avançando e colidindo com você. Ou ele pode pisar e produzir &dRunas do Vazio&r para atingi-lo! Ele também pode enviar &dBolas de Shulker&r em uma fileira. \\n\\nE lembra quando eu disse que ele pode te puxar para mais perto dele? Sim, ele faz isso com uma coisa chamada &dTufão do Vazio&r, que ele também pode invocar aos seus Pés para te prender. Depois que você fica lá por muito tempo, ele explode, muito provavelmente te danificando no processo. \\n\\nQuando você o leva à metade da &4Vida&r, sua Máscara se quebra revelando sua verdadeira Cabeça! Com raiva, ele destruirá o chão da arena, levando vocês dois para o nível inferior. \\n\\nAgora ele vai te sugar mais, enviar mais &dRunas do Vazio&r atrás de você e atacar mais rápido e mais forte!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_guardiuan.png width:100 height:100 align:center}"
	]
	quest.2B115519A21F9CB7.title: "&d&lGuardião do Ender&r"
	quest.2B1BAEC5DAAF9DAC.quest_desc: [
		"Melhorias Válidas:"
		"- Tree Feller"
		"- Leaf Breaker"
		"- Auto Smelter"
		"- Drops Teleporter"
	]
	quest.2B27E4E04A628C60.quest_desc: ["A &eMelhoria de Velocidade&r faz exatamente o que diz. Ela aumenta a velocidade na qual a interface/bloco funciona. Precisa que um importador puxe mais rápido? Quer que seus crafters funcionem mais rápido? Esta é a melhoria!\\n\\nA &eMelhoria de Pilha&r aumenta a velocidade de transferência para uma pilha de itens, em vez de apenas um. Combine com Melhorias de Velocidade para redes mais eficientes!"]
	quest.2B27E4E04A628C60.title: "&eAcelerando Tudo!"
	quest.2B29E9AB9447E1C6.quest_desc: [
		"Agora, isso sim é uma Máquina Multibloco! \\n\\nPara recuperar Itens do &eAlchemical Sulfur&r, precisaremos Incubá-los. Isso requer o Incubador com todos os 3 Recipientes adjacentes a ele. A ordem não importa, desde que estejam tocando a metade inferior. \\n\\nQuando tiver todos os Itens nos Recipientes e Calor, ele começará a Incubar seus Itens! Você saberá que está funcionando quando partículas de Fumaça saírem dele."
		"{image:atm:textures/questpics/theurgy/theurgy_incubator.png width:200 height:200 align:center}"
	]
	quest.2B31E6C1707D8195.quest_desc: ["O próximo passo para permitir o acesso à rede sem fio é o &bPonto de Acesso Sem Fio&f. O Ponto de Acesso é usado para abrir a rede para acesso sem fio através de um &eterminal sem fio&f, e tem um alcance definido (finito) dependendo de quantos &bAmplificador de Alcance Sem Fio&f são inseridos no Ponto de Acesso."]
	quest.2B422B7E0CE3590D.quest_desc: ["O Linking Tool de Compactação pode converter itens colocados dentro em suas formas de pepita ou bloco.\\n\\nPor exemplo: uma Barra de Ferro colocado aqui permitirá que você retire 9 pepitas, ou se mais Ferro for colocado, o converterá em Blocos de Ferro."]
	quest.2B422B7E0CE3590D.quest_subtitle: "Compacta/Descompacta Automaticamente"
	quest.2B4286EFCE51CC21.quest_desc: [
		"Aumento de Nível para 21."
		""
		"O Item de Assinatura é Defesa Especializada."
	]
	quest.2B4286EFCE51CC21.title: "&6Rival Wayne"
	quest.2B4801CD3E90BD40.quest_desc: ["&l&3Handcrafted&r é para tudo relacionado à Decoração. \\n\\nHá Camas (que parecem boas o suficiente para dormir, e eu sou um dorminhoco exigente!) e Mesas de Cabeceira para os Quartos. \\n\\nHá Cadeiras e Mesas para a Sala de Estar. \\n\\nHá um Forno, Pratos e Tigelas para a Cozinha. \\n\\nCaramba, há até Estátuas apenas para se exibir!"]
	quest.2B4801CD3E90BD40.title: "&l&3Handcrafted&r"
	quest.2B4D4E741D855B5A.quest_desc: ["Combinar 2 &bBarra dos Céus&r, 2 &6Barra de Ouro Corrompido&r e 1 &5Fragmento de Netherita&r juntos em uma grade de fabricação fará &dBarra das Profundezas&r."]
	quest.2B4D4E741D855B5A.title: "&dBarra das Profundezas"
	quest.2B57C8D2F98A9279.quest_desc: ["&l&7Pocket Storage&r é um mod que adiciona um armazenamento de mão simples. \\n\\nClique com o botão direito para abri-lo e você pode colocar Itens. Eles terão uma contagem máxima que podem conter, e quaisquer Itens colocados além disso serão anulados. Ele também aspirará Itens no chão que são os mesmos que estão nele. \\n\\nHá também maneiras de despejá-lo em Baús ou retirá-lo de Baús rapidamente. \\n\\nNos diferentes Níveis, quanto mais altos os Slots e Itens Máximos serão."]
	quest.2B57C8D2F98A9279.title: "&l&7Pocket Storage"
	quest.2B60D123123A5E8E.quest_desc: ["Por que definir um local para onde a Energia pode ir? Por que não deixá-la ir livre! \\n\\nComo libertar um monte de Abelhas, a Energia irá para todos os lugares quase instantaneamente (com menos zumbido). Quaisquer blocos que precisem de Energia por perto serão carregados sem fio."]
	quest.2B6D71DAF72EAFA4.quest_desc: ["Os Capacitores atuam como as Baterias do Draconic Evolution. Eles precisam de Módulos de Energia para realmente armazenar Energia e lembre-se, 'quanto mais, melhor!'."]
	quest.2B6D71DAF72EAFA4.title: "Capacitor Wyvern"
	quest.2B857941D7BBA0B8.quest_desc: ["Pode ser encontrada em estruturas na &6&lBumblezone&r ou trocada com a &5Rainha Abelha&r! \\n\\nJá odiou ficar preso em &6Blocos de Mel&r? Ou mesmo quando o &ePólen&r te desacelera? Bem, não há necessidade de temer, pois as Perneiras de Abelha de Mel estão aqui! Elas o ajudarão a se mover melhor através desses Blocos. Quanto mais Armadura de Abelha você usar, mais fácil será a viagem! \\n\\nVocê também pode se agachar através do &ePólen&r para coletá-lo! "]
	quest.2B864D741F7C7549.quest_desc: ["&lProductive Trees&r é tudo sobre Árvores e Cruzamento de Árvores para fazer mais Árvores. \\n\\nEntão você pode adivinhar com segurança que ele traz mais tipos de Madeira para o &2&lMinecraft&r! \\n\\nCaramba, até mesmo algumas Madeiras especiais!"]
	quest.2B864D741F7C7549.title: "&lProductive Trees"
	quest.2B9AF0D6ED8BA628.quest_subtitle: "&f6 &cDano de Ataque"
	quest.2BA0E5D48E234FE9.quest_desc: ["O reino mágico de &d&lArs Nouveau&r nos traz as Magelights! Fontes de luz de pura magia! \\n\\nElas podem ser colocadas normalmente usando Feitiços ou você pode criar uma Lanterna Magelight e colocá-la em vez disso."]
	quest.2BA0E5D48E234FE9.title: "Luzes do &d&lArs Nouveau&r"
	quest.2BB3DB19D5EFC7E2.quest_desc: ["A &dEmbreagem (Clutch)&r pode ser conectada aos nossos Sistemas Cinéticos, onde atuará como um Portão de Cerca. \\n\\nAo receber um &4Sinal de Redstone&r, ela interromperá o fluxo de &dForça Rotacional&r através dela. \\n\\nAssim, toda &dRotação&r parará na &dEmbreagem&r se ela estiver energizada com &4Redstone&r. Aqueles que estão &dGirando&r para dentro dela continuarão &dGirando&r normalmente!"]
	quest.2BB3DB19D5EFC7E2.title: "&dEmbreagem (Clutch)"
	quest.2BB5769119BA2472.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.2BC325DEBDD2F5CA.quest_desc: ["Sementes de Vibranium requerem Solo Mágico colocado abaixo para poderem crescer."]
	quest.2BC325DEBDD2F5CA.quest_subtitle: "Nível: &bMágico"
	quest.2BCB788924BBD849.quest_desc: ["Meu favorito pessoal e um dos mais poderosos. \\n\\nO &bIncinerador&r pode ser usado como uma Espada normal e Encantado como uma! \\nMas ao segurar o botão direito, ele faz algo que nenhuma Espada normal faz. Quando você segura e solta o botão direito por alguns segundos, chamas maciças surgem do chão na direção que você está olhando, e então elas explodem. \\n\\nEle também é enorme, o que não só parece legal, mas também dá um Alcance melhor!"]
	quest.2BCB788924BBD849.title: "&bO Incinerador"
	quest.2BD077EFE77B8EBB.quest_desc: ["Zumbis têm diferentes variantes que aparecem em outros Biomas. \\n\\n&eMúmia&r - aparecem em Desertos. \\n&9Afogados&r - aparecem debaixo d'água. \\n&bGelido&r - aparecem em Biomas Frios. \\n&2Verdejantes&r - aparecem em Selvas."]
	quest.2BD077EFE77B8EBB.title: "&aVariantes de Zumbi"
	quest.2BE538246C672689.quest_desc: ["Usando uma fundição, despeje &#9332D9Unobtainium Derretido&r sobre um &#F2EB2EOvo de Gerador de Abelha de Vibranium&r."]
	quest.2BE538246C672689.quest_subtitle: "Fundindo ovos de montão!"
	quest.2BE538246C672689.title: "&fAbelha de &dUnobtainium"
	quest.2BF119DD5D977409.title: "Catalisador de Nível 2 do Carregador de Luz Estelar"
	quest.2C04B3BA507D5673.quest_desc: ["&bPadrões&f são o que contém uma receita codificada para ser realizada por um Provedor de Padrões. Para codificar uma receita em um Padrão, o &bTerminal de Codificação de Padrões ME&f deve ser usado.\\n\\nPadrões podem ser configurados para conter uma receita de &efabricação&f regular, que exigirá o uso de um &eMontador Molecular&f na face de seu Fornecedor, ou uma receita de '&eprocessamento&f' mais geral, onde quaisquer itens de entrada podem ser enviados pelo fornecedor para algum outro bloco de máquina ou planta de processamento especializada."]
	quest.2C04B3BA507D5673.title: "&ePadrões"
	quest.2C0984E03F308959.quest_subtitle: "Ipê Rosa + Sorte"
	quest.2C272D1D6DE6C0F1.quest_desc: ["Enquanto estiver usando um &5Orbe Tera&r, você pode usar 50 do mesmo &5Fragmento Tera&r em seu &cPokémon&r para dar a ele esse tipo. \\n\\nObviamente, o tipo está relacionado ao tipo de &5Fragmentos&r que você usa. \\n\\nIsso entrará em vigor quando o &cPokémon&r estiver em batalha."]
	quest.2C272D1D6DE6C0F1.title: "&5Terastalizando"
	quest.2C2958E38293717E.quest_desc: ["Para começar com os novos &eItens&r do &6&lCreate&r, precisaremos de &ePapelão&r! \\n\\nQue é feito de &6Prensagem&r de Polpa. \\n\\nPolpa é feita de &6Mistura&r de 4 Mudas e &9Água&f em um &6Misturador Mecânico&r e &8Bacia&r. \\n\\nVocê pode combinar &ePapelões&r para fazer &eBlocos de Papelão&r que podem fazer os novos &eItens&r no &6&lCreate&r... ou &eArmadura de Papelão&r!"]
	quest.2C2958E38293717E.title: "&6&lCreate&r 1.21"
	quest.2C29683DA28A8D47.quest_subtitle: "Feito no Reprocessador"
	quest.2C29683DA28A8D47.title: "&fAbelha de Insanite"
	quest.2C2EF4EBB3C9EAE3.quest_subtitle: "Nível: &a2"
	quest.2C387BFA6EE6FDB7.quest_desc: ["&cCristais de Utherium&r dropam de &cRotbeasts&r no &2&lUndergarden&r!"]
	quest.2C387BFA6EE6FDB7.quest_subtitle: "20"
	quest.2C387BFA6EE6FDB7.title: "&cArmadura de Utherium"
	quest.2C4299D33D419AA0.quest_desc: ["Coloque o Bloco de Teleporte no &2&lMundo Superior&r para ir para a &7&lDimensão de Mineração&r."]
	quest.2C4299D33D419AA0.title: "&2&lMundo Superior"
	quest.2C5A7E4CD8B57E08.quest_desc: ["Árvores de Grongle são árvores altas como as da Selva que só aparecem em Biomas Gronglegrowth! \\n\\nEssas árvores também são onde os &eGronglets&r aparecem."]
	quest.2C5D78630C7AD57F.quest_desc: ["Aumenta o alcance, faz coisas diferentes quando usado em coisas diferentes."]
	quest.2C5D78630C7AD57F.quest_subtitle: "Chegue Mais Perto!"
	quest.2C73E3C5113BF2AC.quest_desc: ["Bééé bééé eu sou uma Ovelha"]
	quest.2C73E3C5113BF2AC.quest_subtitle: "Nível: &a2"
	quest.2C9C9CB71941DC01.quest_desc: ["Esta é a Essência de Nível 3, feita combinando 4 Prudentium com um Cristal de Infusão."]
	quest.2C9C9CB71941DC01.quest_subtitle: "Nível: &63"
	quest.2C9C9CB71941DC01.title: "&cTertium"
	quest.2CA2B3A1783B4040.quest_subtitle: "Álamo + Amieiro"
	quest.2CA3707BEE2E3C0D.quest_desc: ["Alimente uma &bAbelha de Diamante&r com um &8Bloco de Netherita&r"]
	quest.2CA3707BEE2E3C0D.quest_subtitle: "Ancestral mas com uma grande utilidade!"
	quest.2CA3707BEE2E3C0D.title: "&fAbelha &8Ancestral"
	quest.2CA4D7253DA1825F.quest_subtitle: "Gerado usando um Ninho de Madeira"
	quest.2CA4D7253DA1825F.title: "&fAbelha de Faixa Azul"
	quest.2CA9394459C24012.quest_desc: ["Rotbeasts são Minichefes que aparecem por todo o Undergarden."]
	quest.2CA9394459C24012.title: "&fMate um &cRotbeast"
	quest.2CB4138503F71E7A.quest_desc: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não tem permissão para ser usada em quaisquer pacotes públicos não lançados pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, está no modo de edição."]
	quest.2CC56A4F06E53307.quest_desc: [
		"Coloque seus PCBs Vazios em uma &3Caixa de Luz UV&r para carregá-los. Precisa de pressão e acesso à luz solar."
		"{image:atm:textures/questpics/pneumaticcraft/uv_charging.png width:300 height:150 align:center}"
	]
	quest.2CC56A4F06E53307.quest_subtitle: "Espero que você tenha óculos de sol!"
	quest.2CC56A4F06E53307.title: "Carregando com UVs"
	quest.2CCFEE98FE3B2E97.quest_desc: ["Estas máquinas são usadas para automatizar a colocação/quebra de blocos. Isso é especialmente útil ao automatizar o Látex."]
	quest.2CCFEE98FE3B2E97.title: "Blocos"
	quest.2CD58FC229BC0C28.quest_desc: ["A &dManopla do Guarda&r é o drop do &d&lGuardião do Ender&r. \\n\\nQuando você a segura em qualquer Mão, pode Segurar o Botão Direito para trazer todos os Mobs perto de você, ainda mais perto! \\n\\nVocê também pode bater em Mobs com ela em sua Mão Principal para causar Dano. \\n\\nTente usar a mecânica de puxar com o voo para derrubar Mobs!"]
	quest.2CD58FC229BC0C28.title: "&dManopla do Guarda"
	quest.2CE9AB9D08F1BF37.quest_desc: ["&7Bases de Bola&r! É, eu deveria ter te dito que o &7Zinco&r fará a &7Base de Bola de Ferro&r, peço desculpas. \\n\\nPrecisaremos de 2 &7Bases de Bola&r para cada &7Mecanismo&r. \\n\\nAlém de mais itens com os &6Implantadores&r para criar os &7Mecanismos&r."]
	quest.2CE9AB9D08F1BF37.title: "&7Bases de Bola"
	quest.2CECCA9D05D3EF12.quest_desc: ["A &2Stella Eterna&r é bem cara. Você precisará de uma Forja de Nível 3 primeiro! \\n\\nEntão, você precisará de &7Pedaços de Stellarite&r que você pode minerar. E você tem que conseguir 3 &aOrbes Xpetrificados&r que você não pode mais minerar. Em vez disso, você terá que alimentar um Buraco Negro com &aEXP&r para obtê-lo! \\n\\nFinalmente, você precisará de um &6Barra de AllTheModium&r para obter a &2Stella Eterna&r. Faz sentido o porquê de ser tão cara, já que pode ser combinada com qualquer Ferramenta para torná-la Invencível!"]
	quest.2CECCA9D05D3EF12.title: "&2Stella Eterna"
	quest.2CF6EA138B53CE1B.quest_desc: ["&3Vibranium&r combinado com &5Unobtainium&r!"]
	quest.2CF6EA138B53CE1B.title: "Barra de Liga de &5Unobtainium&r - &3Vibranium&r"
	quest.2CF96A264EB5522C.quest_desc: [
		"A &9Torre Invertida de Uphyxes&r é o nível máximo de &6Rituais de Infusão&r. Não tem tantos usos quanto os outros três níveis, mas ainda é necessária para o \"endgame\" do Occultism. "
		""
		"Principalmente, é usada para criar Pó de Dragonyst, que é o ingrediente principal do Giz Magenta."
	]
	quest.2CF96A264EB5522C.quest_subtitle: "Infusão Máxima"
	quest.2CF96A264EB5522C.title: "&9Torre Invertida de Uphyxes"
	quest.2CFEE04BA574921E.quest_desc: ["O &bConstrutor&r é uma interface que colocará um bloco designado na direção em que está apontado.\\n\\nVocê pode designar o bloco dentro da GUI. Isso pode ser útil para automação!"]
	quest.2CFEE04BA574921E.quest_subtitle: "Colocando Blocos!"
	quest.2D00F85379A4D591.quest_desc: ["O Carregador de Itens é o dispensador mais básico do RailCraft. Ele precisa estar acima do &6Trilho&r e pode ser configurado para o que você quer que seja carregado em seus &7Carrinhos&r abaixo."]
	quest.2D00F85379A4D591.title: "Carregador de Itens"
	quest.2D0BA4183DCA2751.quest_subtitle: "Nível: &a2"
	quest.2D0CF18C8B2ABB7D.quest_desc: ["Colocar isso perto de plantas ou mudas em crescimento fornecerá Fonte. As árvores Archwood fornecem mais Fonte! \\n\\nNota: Farinha de Osso não produz Fonte."]
	quest.2D0CF18C8B2ABB7D.quest_subtitle: "Cria Fonte usando o crescimento de Plantas"
	quest.2D1CBCEC82F1B37D.quest_desc: ["O &6Aquecedor a Lenha&r gerará &6Calor&r usando Combustíveis de Fornalha. \\n\\nTroncos, &0Carvões&f, &0Carvões Vegetais&r, até mesmo Espadas de Madeira! \\n\\nNão posso te dizer o quão &6Quente&r pode ficar, mas você saberá que está &6Aquecido&r pela Cor do &6Aquecedor&r mudando!"]
	quest.2D1CBCEC82F1B37D.title: "&6Aquecedor a Lenha"
	quest.2D3C8905B783A212.quest_desc: ["Por alguns Drops de Mob mais &bPó de Cristal Arcano &r você pode fazer &cPó de Mundabitur&r! \\n\\nEsta é uma parte muito importante na fabricação e construção de Multiblocos! \\n\\nE você pode encontrá-lo nas &dCidades do End&r, que a maioria acaba fazendo..."]
	quest.2D3C8905B783A212.title: "&cPó de Mundabitur"
	quest.2D41B04C75FA02BC.quest_desc: ["A &6Prensa Mecânica&r é muito útil para fazer ainda mais &6Máquinas&r! \\n\\nQuando alimentada com &dForça Rotacional&r (e muitas Unidades de Estresse) ela enviará a &6Prensa de Metal&r para baixo, nos Blocos abaixo dela. Como uma Prensa Hidráulica! \\n\\nQuaisquer Itens abaixo dela: seja em uma &eCorreia&r, &eDepósito&r, ou mesmo apenas dropados, serão &6Prensados&r. \\n\\nIsso é principalmente para transformar &7Barra &f em &7Placas&r sem custo de energia. Você também pode usá-la para obter Papel de Cana-de-Açúcar e Caminhos de Terra! \\n\\nSe você colocar uma &8Bacia&r abaixo dela, poderá usar a &6Prensa&r para combinar &bLíquidos&r, &eItens&r e Blocos para criar novos &eItens&r. \\n\\nOutra opção com a &8Bacia&r abaixo da nossa Prensa é a Fabricação por Compactação. Esta é a fabricação automatizada para Receitas que contêm apenas um tipo de &eItem&r, como 9 &7Iron Ingots&f em um &7Bloco de Ferro&r."]
	quest.2D41B04C75FA02BC.title: "&6Prensa Mecânica"
	quest.2D457E53BB6D63C7.quest_desc: [
		"Os pontos mais altos da Luz Estelar são as Florestas de Permafrost que se encontram sobre as Montanhas. \\n\\nEstar tão alto as torna muito mais frias, cobrindo-as de Neve e Gelo! \\n\\nPelo menos os Mobs amigáveis parecem gostar do Frio!"
		"{image:atm:textures/questpics/eternal/starlight_permafrost.png width:200 height:100 align:center}"
	]
	quest.2D457E53BB6D63C7.title: "Floresta de Permafrost"
	quest.2D474F8075E9DBD0.quest_desc: ["Primeiro você precisa colocar o Altar de Fundição e as Pedras Verticais no padrão especificado no JEI. \\n\\nEntão, você precisará colocar um Bloco de Diamante, uma Vara e Pó de Blaze no Altar. \\n\\nDepois disso, coloque 4 Braseiros de Incenso ao redor do Altar, coloque o Bloco de Carvão em um, Casca de Acácia em outro, Casca Verdejante no terceiro e Casca de Bétula no último. E acenda todos eles com um Isqueiro! \\n\\nEntão segure Shift e clique com o botão direito no Altar para iniciar o Ritual! Se não funcionou, verifique o padrão em que as Pedras Verticais estão."]
	quest.2D592669F4D41793.quest_desc: ["Assim como o Reator, a estrutura deve ser construída com &dInvólucros&r, mas as paredes podem ser de &9Vidro de Turbina&r em vez disso!"]
	quest.2D592669F4D41793.title: "Construção da Turbina"
	quest.2D64EF8D803AF9DA.quest_desc: ["O Portal mais caro que podemos fazer. Primeiro, para os &dOvos de Dragão&r, você não precisa continuar ordenhando o &dDragão&r, você pode usar &l&bHNN&r ou &l&2MA&r para obtê-los ou um Extrator para fazer mais! \\n\\nEntão, você precisará do &dInfused Dragon's Breath&r do Encantamento. \\n\\nLá você precisará de &9Soul-Touched Sculkshelves&r para Encantá-lo e para fazer o Portal. \\n\\nSe você está se perguntando por que o Portal não funciona, é porque você já está no &2&lMundo Superior&r! Brincadeira, você não pode usá-lo!"]
	quest.2D6FDCC948DB927D.quest_subtitle: "Mahogany + Teak"
	quest.2D8026E10FBA7A72.quest_desc: ["Uma picareta muito rápida."]
	quest.2D8026E10FBA7A72.title: "&6Picareta de &5Liga de &3Allthemodium"
	quest.2D86D4403E0F4EB9.quest_desc: [
		"Blazegold é um novo material adicionado pelo JDT. O Blazegold é adquirido realizando a Disseminação de Gosma em Blocos de Ouro usando gosma de nível dois ou superior. O Minério de Blazegold é afetado por fortuna."
		""
		"O Blazegold concede a habilidade intrínseca de Reparo com Lava a ferramentas e armaduras. O Reparo com Lava repara a ferramenta/armadura quando caída em um bloco de fonte de lava, convertendo o bloco de fonte em obsidiana em troca da reparação da ferramenta/armadura."
	]
	quest.2D86D4403E0F4EB9.title: "Blazegold"
	quest.2D8A7065F8CDDDDD.quest_desc: ["Cotonetes são minha maneira favorita de obter Ovos Geradores, você precisará usar o Mob Grinding Utils para isso. Basta clicar com o botão direito em uma criatura com o Swab e depois fabricar Chicken Feed com ele, sementes e um balde de qualquer tipo de &aXP Fluid&r. Eu não me importo com qual tipo de &aXP Fluid&r você usa para isso. Assim que tiver isso, alimente uma Galinha. Infelizmente a Galinha não sobreviverá ao procedimento, mas ei, Ovos Geradores!\\n\\nNem todas as criaturas podem ser coletadas, no entanto."]
	quest.2D93888313B03029.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_blue.png width:100 height:150 align:center}"]
	quest.2D93888313B03029.title: "&9Cristal de Luz Estelar Azul&r"
	quest.2D96965317D3CFEC.quest_desc: ["Yay, assuntos complicados! Desta vez são &5Condutores&r e &5Horários de Trem&r. \\n\\nPrimeiro é obter nosso &5Condutor&r, estes são quaisquer Mobs que podem ser guiados por Laço ou &cQueimadores de Blaze&r. Se tivermos um Assento ao lado dos Controles do Trem, podemos guiar um Mob para o Assento, onde ele esperará para se tornar um &5Condutor&r. \\n\\n&cQueimadores de Blaze&r funcionam de forma semelhante, só que sem a necessidade de um assento, eles trazem o seu próprio. \\n\\nEntão, podemos entregar ao nosso Mob ou &cQueimador de Blaze&r, um &5Horário&r preenchido para dar a eles essa tarefa, mais um &5Chapéu de Condutor&r. \\n\\n&5Horários&r são Itens que podem ser \"Codificados\" para ordenar que nossos &5Condutores&r realizem certas tarefas. As tarefas são: ir para a &5Estação&r, pegar ou deixar Pacotes, mudar de título ou mudar a velocidade máxima. \\n\\nUma vez que adicionamos uma tarefa, podemos editar suas configurações para mudar quando ela iniciará a próxima tarefa! Estas podem ser um certo Tempo esperado, Hora do Dia, quantidade de coisas no &5Trem&r, ou até mesmo &4Redstone&r!"]
	quest.2D96965317D3CFEC.title: "&5Condutores"
	quest.2D9AF97C03C5AEC7.quest_desc: ["Para os Níveis 5-8, você precisará de Estabilizadores Avançados. O que é um Estabilizador Avançado? São 9 Estabilizadores em uma área de 3x1x3. Quando feito corretamente, ele se transformará em um círculo! Apenas faça da mesma forma que faria com 1 Estabilizador."]
	quest.2D9AF97C03C5AEC7.title: "Estabilizadores Avançados"
	quest.2DA8CE213AC3869B.quest_desc: ["Cristais de Luz Estelar podem ser encontrados por todo e até mesmo sob os Desertos Cristalizados. \\n\\nEles funcionam de forma semelhante à Ametista e até soam como ela!"]
	quest.2DB2A4A1182FE0BB.quest_desc: [
		"O Nível 6 precisa de 150 Blocos de Barra de Draconium e 178 Blocos de Redstone (Não se esqueça dos 36 Estabilizadores)."
		"{image:atm:textures/questpics/draconic/draconic_core_6off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_6on.png width:100 height:100 align:1}"
	]
	quest.2DB2A4A1182FE0BB.quest_subtitle: "Armazena: 356.000.000.000 RF"
	quest.2DB2A4A1182FE0BB.title: "Nível 6"
	quest.2DB53A77C3CD90F1.quest_desc: ["A Picareta do Botânico transforma blocos com os quais interage em suas variantes musgosas, supondo que eles tenham uma."]
	quest.2DB53A77C3CD90F1.quest_subtitle: "Nível: &b3"
	quest.2DC012EF21FB359E.quest_desc: ["O Extrator de Encantamentos pode remover automaticamente encantamentos de equipamentos. Você pode fazer com que vá para um Livro ou que o encantamento seja convertido em &aEssência&r."]
	quest.2DC4446A644A4079.quest_desc: ["O &6Traje de Anti-Radiação&r é a única forma de impedir que a &aRadiação&r mate você. \\n\\nVocê precisa usar o conjunto completo para prevenir o &aEnvenenamento por Radiação&r! \\n\\nA &aRadiação&r matará outros Mobs e Jogadores próximos a ela, os Jogadores podem ser salvos com &6Trajes Hazmat&r... mas os Mobs não têm a mesma sorte!"]
	quest.2DC4446A644A4079.title: "&6Traje de Anti-Radiação"
	quest.2DC639C39AE90272.quest_subtitle: "Meranti Amarelo + Eucalipto Rosa"
	quest.2DD5F0693780B10A.quest_desc: ["Usado com a Extrusora MK2, os blocos extrudados imitarão os blocos reais. Blocos de Redstone emitirão Redstone, Pedra Luminosa emitirá luz, Grama agirá como transparente. Mas apenas com este Aprimoramento! \\nNão funciona com Entidades de Bloco como Fornalhas ou Câmaras de Enriquecimento."]
	quest.2DDA04088C8220D2.quest_desc: ["Prosperity Shards são um ingrediente central de fabricação no mod. Para encontrar algum Minério de Prosperidade, vá minerar."]
	quest.2DDA04088C8220D2.quest_subtitle: "Podemos finalmente ter Prosperidade?"
	quest.2DDA04088C8220D2.title: "&bProsperity Shards"
	quest.2DE2E5A1275E4B20.quest_desc: ["Pode ser encontrado em estruturas na &6&lBumblezone&r ou trocado com a &5Rainha Abelha&r! \\n\\nAs &6A&8b&6e&8lhas&r têm uma maneira bastante interessante de se encontrar e se comunicar. Eu não sei como elas fazem isso, então vou apenas supor que suas Antenas emitem e recebem sinais de rádio. \\n\\nAo usar o Capacete de Abelha Sem Ferrão, você pode se agachar para destacar todas as &6A&8b&6e&8lhas&r ao seu redor. \\n\\nAlém disso, ao usá-lo, o veneno e a náusea desaparecerão mais rapidamente."]
	quest.2DE7CC686B56881F.quest_desc: ["Protege você da radiação do Mekanism."]
	quest.2DE7CC686B56881F.quest_subtitle: "Máx: 1"
	quest.2DFFEB29B6CBFD99.quest_subtitle: "Ferro + Faixa Azul"
	quest.2DFFEB29B6CBFD99.title: "&fAbelha de Chumbo"
	quest.2E0275C21D3F0DA3.quest_desc: ["Não deve ser confundida com uma Abelha Dracônica."]
	quest.2E0275C21D3F0DA3.quest_subtitle: "Wyvern Fusão de Criação"
	quest.2E0275C21D3F0DA3.title: "Abelha Dracônio"
	quest.2E0F82F7E1B74033.quest_desc: ["&d&lArmadura da Terra&r do &d&lArs Elemental&r!"]
	quest.2E0F82F7E1B74033.quest_subtitle: "15"
	quest.2E0F82F7E1B74033.title: "&2Traje de Geomancer"
	quest.2E2811D1A0F2A492.quest_desc: ["Para aumentar o alcance da conexão sem fio ao seu sistema, você pode criar &bMelhorias de Alcance&r.\\n\\nO Transmissor Sem Fio só pode conter um total de 4."]
	quest.2E2811D1A0F2A492.quest_subtitle: "Sinal Melhor"
	quest.2E2811D1A0F2A492.title: "&bAumentando o Alcance do Wi-Fi"
	quest.2E29DC243E8AD61E.quest_desc: [
		"As Lacraias Cintilantes não fazem ou dropam nada, elas apenas adicionam atmosfera. \\n\\nElas também se assemelham ao único inseto que eu tolero!"
		"{image:atm:textures/questpics/eternal/starlight_shimmer.png width:150 height:100 align:center}"
	]
	quest.2E29DC243E8AD61E.title: "Shimmer Lacewing"
	quest.2E37997A065A29F1.quest_subtitle: "Nível: &c5"
	quest.2E4A0D8AEA1AE6B6.quest_desc: [
		"Outra estrutura de Terras Ruins! Os Restos Chamuscados pelo Sol. Não sei o que aconteceu, mas aparentemente alguém irritou um &cPokémon de Fogo&r. \\n\\n&7Cascalho Suspeito&r surge abaixo da Areia Vermelha."
		"{image:atm:textures/questpics/pokemon/find_sunscorched_remains.png width:200 height:100 align:center}"
	]
	quest.2E4A0D8AEA1AE6B6.title: "Restos Chamuscados pelo Sol Pré-históricos"
	quest.2E51F09F6D9E5EF8.quest_desc: ["Esta é a Abelha Criadora."]
	quest.2E51F09F6D9E5EF8.quest_subtitle: " Fazendeiro + Pecuarista"
	quest.2E51F09F6D9E5EF8.title: "&fAbelha Cupido"
	quest.2E596B5A4EA2ABF4.quest_desc: [
		"Aquela Smogvent está se movendo? Não, espere, é apenas um &3S'Mog&r! O primo próximo do &2Mog&r! \\n\\nEles agem exatamente como os &2Mogs&r, só que estes podem dropar Musgo-Mog Azul."
		"{image:atm:textures/questpics/undergarden/undergarden_smog.png width:100 height:100 align:center}"
	]
	quest.2E596B5A4EA2ABF4.title: "&3S'Mog&r"
	quest.2E5E129F25707C5D.quest_desc: ["O &6Símbolo da Supremacia&r!\\n\\nOutro símbolo que não pode ser criado, similarmente à &cMalícia&r. Como a &cMalícia&r, ele pode tornar os afixos mais fortes. Diferente da &cMalícia&r, ele faz isso com TODOS os afixos no equipamento, e não sacrificará nenhum no processo.\\n\\nVocê pode obtê-lo ao vencer 100 ondas do &zPortal Infinito&r de Invasores Apótico."]
	quest.2E5E129F25707C5D.quest_subtitle: "Estou dando uma ajudinha para as tentativas sem o Sieveless"
	quest.2E61219FC0BAB675.quest_subtitle: "Até +5 de Alcance"
	quest.2E6646301ACD332E.quest_desc: ["O &eObservatório&r é uma estrutura alta com um telescópio gigante saindo dela. \\n\\nO primeiro nível tem toneladas de Vasos, um PC e alguns monitores de dados. \\n\\nO segundo nível tem Estações de Cura e vidros pelos quais eu continuo tentando atravessar, assim como os pássaros tentam. \\n\\nO terceiro nível tem baús, barris e um..."]
	quest.2E6646301ACD332E.title: "&eObservatório"
	quest.2E68E1D96B25336D.quest_desc: ["Depois de lutar contra alguns Porcos Zumbificados Possuídos por Demônios, invocados pela &6Convocação Aberta de Odus&r, você pode usar a Carne Demoníaca dropada por eles para fabricar um pouco de Giz Rosa."]
	quest.2E68E1D96B25336D.title: "&dGiz Rosa"
	quest.2E6D11A5F5626A6C.quest_subtitle: "Nível: &f2"
	quest.2E6F761585C1FB4D.quest_subtitle: "Cinza + Lima Prateada"
	quest.2E74B5149D4BD0A0.quest_desc: ["O Cristal Básico (Relé de Energia) é o começo para mover Energia com o Draconic Evolution!"]
	quest.2E74B5149D4BD0A0.title: "Cristal de Relé de Energia Básico"
	quest.2E85D6E2CFCC356E.quest_desc: ["A &3Vibranium Furnace&r é ainda melhor que a &6Allthemodium Furnace&r!"]
	quest.2E85D6E2CFCC356E.title: "&3Vibranium Furnace"
	quest.2E88CCBC7B97A1F0.quest_desc: ["Se ao menos aquele portal gigante na Cidade Ancestral fizesse algo! Ah, espere, com &9&lDeeper and Darker&r ele pode! \\n\\nVocê só precisa de um..."]
	quest.2E88CCBC7B97A1F0.title: "&9&lDeeper and Darker"
	quest.2E89A03BA809634E.quest_desc: ["Estes só podem ser trocados com Armeiros. \\n\\nProjéteis Especializados são aqueles que fazem coisas únicas! \\n\\nHoming, Explosivos e Sinalizadores precisam ser fabricados com estes &9Blueprints&r."]
	quest.2E89A03BA809634E.title: "&9Specialized Projectiles Blueprints "
	quest.2E89ABF1A6145184.quest_subtitle: "Brazilwood + Kapok"
	quest.2E8E292ED596A104.quest_desc: ["A Lente Laser pode fazer com que os Lasers de Minério foquem mais em uma certa cor de minério. Verifique no JEI para ver qual lente funciona melhor para um certo tipo de minério. Ela também determina qual tipo de fluido pode ser produzido por Lasers de Fluido."]
	quest.2E8F851A4E98F741.quest_desc: [
		"A &3Armadura Pneumática&r por si só já é ótima, no entanto, se você quiser tornar essa armadura incrível, precisará instalar melhorias. Pressione 'U' por padrão para abrir a INTERFACE de Melhorias, algumas melhorias usam pressão, outras não."
		""
		"Assim como para aprimorar outras ferramentas em PneumaticCraft, para aprimorar a &3Armadura Pneumática&r, você precisará de uma Estação de Carregamento com pressão."
		""
		"Nota: O subtítulo informará a quantidade máxima dessa melhoria que pode ser colocada em algo."
	]
	quest.2E8F851A4E98F741.quest_subtitle: "Ferro Comprimido Man"
	quest.2E8F851A4E98F741.title: "Armadura Pneumática"
	quest.2E9C035EEE7E5C34.quest_desc: ["O clássico Laço. Use isso para levar animais para sua área de fazenda.\\n\\nIsso não é a mesma coisa que o minério (lead)."]
	quest.2E9C035EEE7E5C34.quest_subtitle: "Vamos lá, cachorrinho"
	quest.2E9C035EEE7E5C34.title: "Vamos fazer isso à moda antiga"
	quest.2E9D1131DC21CC5B.quest_desc: ["&lIndustrial Foregoing&r tem seu design futurista e elegante, &5&lMekanism&r tem seu design moderno e sem brilho, e &8&lImmersive Engineering&r o leva muito mais retrô! \\n\\nTudo é &6Marrom&r, &7Cinza&r e &8Cinza Escuro&r! \\n\\nO Mod todo começa com o &6Martelo de Engenheiro&r. Eles podem ser usados para fazer Chapas, Pó, ou apenas construir nossos Multiblocos! \\n\\nA propósito, eu te disse que faremos muitos deles neste Mod? Espero que goste!"]
	quest.2E9D1131DC21CC5B.title: "&8&lImmersive Engineering"
	quest.2EA0C74AE7366656.quest_desc: ["O &aTeletransportador Portátil&r permitirá que você se teletransporte para qualquer &a&lTeletransportador&r (energizado). \\n\\nClaro que ele também precisa de &aEnergia&r, então você precisará carregá-lo. E clicar com o botão direito nele para configurá-lo para você por razões de segurança. \\n\\nDepois de carregado e seu, você pode clicar com o botão direito para abrir sua &eGUI&r. Aqui você pode clicar em qualquer Rede e apertar o botão de Teletransporte para se teletransportar para aquele &a&lTeletransportador&r. \\n\\nNão, você não pode se teletransportar para o &aTeletransportador Portátil&r, é um Item..."]
	quest.2EA0C74AE7366656.quest_subtitle: "Aperte e desapareça!"
	quest.2EA0C74AE7366656.title: "&aTeletransportador Portátil"
	quest.2EA725733AC5B290.quest_desc: ["O &dValor de Amizade&r é necessário para Evoluir e Lutar. \\n\\nIsto não é Palworld, você não pode simplesmente abusar dos seus &cPokemons&r e ainda fazê-los trabalhar para você. \\n\\nEntão como aumentamos nossa &dAmizade&r? \\n&dAmizade&r aumentará quando você deixar seu &cPokemon&r fora de sua &cPoke&rbola para Vagar com você. Certos Itens Seguráveis e Consumíveis também ajudam a aumentar a &dAmizade&r! \\n\\nCuidado para não diminuir sua &dAmizade&r também... alguns Itens podem tirar &dAmizade&r em troca de outra ajuda. \\n\\nSe o &cPokemon&r tiver &dAmizade&r muito baixa, ele se recusará a Batalhar contra &4Treinadores&r, então corrija isso ou guarde-os!"]
	quest.2EA725733AC5B290.title: "&dAmizade"
	quest.2EA9DBB7F8F4EF40.quest_desc: ["Alguns &cPokemon&r não Aparecem como a maioria, alguns gostam de viver nas Profundezas do &9Oceano&r! \\n\\nPara chegar até eles, precisaremos de uma &cPoke&rvara! Espere, uma &cPoke&rvara? \\n\\nSim, uma Vara de Pescar para Iscar esses &cPokemon&r. Para Criar uma, precisaremos de um Molde de Vara de Pescar. \\n\\nVocê pode Trocar com um Aldeão Pescador Mestre para conseguir um!"]
	quest.2EA9DBB7F8F4EF40.title: "Pescando &cPokemon"
	quest.2EAA6BE598C83F24.quest_desc: ["&d&lArmadura da Água&r do &d&lArs Elemental&r!"]
	quest.2EAA6BE598C83F24.quest_subtitle: "15"
	quest.2EAA6BE598C83F24.title: "&3Traje de Aquamante"
	quest.2EB7784D5296F410.quest_desc: [
		"Clicar com o botão direito em um bloco funcional da Flux Network lhe dará esta interface.\\n\\nCada Plug ou Point pode ser nomeado, ter um nível de prioridade personalizado e um limite de transferência de energia personalizado. Isso permite controle total sobre todas as partes do seu sistema.\\n\\n&aIgnorar Limite&r ignora o limite definido.\\n\\nHá várias outras abas para conferir, principalmente para estatísticas da sua rede!\\n"
		"{image:atm:textures/questpics/basic_power/flux_ui.png width:125 height:150 align:center}"
	]
	quest.2EB96FF06627FD9A.quest_desc: ["O Recuperador permite que você desmonte equipamentos nos itens que os compõem.\\n\\nPor exemplo: Se você colocar umas Botas de Diamante, receberá 4 Diamantes de volta."]
	quest.2EB96FF06627FD9A.quest_subtitle: "Desmontando (alguns) itens!"
	quest.2EB96FF06627FD9A.title: "Recuperador"
	quest.2EC2FA680076C07D.quest_desc: ["Para aprimorar as &9Estantes Profundas&r ainda mais, surpreendentemente não precisamos de &d&lInfusão&r! Em vez disso, precisamos de mais Fabricação! \\n\\nPrimeiro, são 5 &3Blocos de Sculk&r e um &3Catalisador de Sculk&r. Ambos podem ser encontrados nas &9Profundezas Escuras&r e precisarão de &5Toque Suave&r para coletar. \\n\\nPor último, há o &9Tentáculo do Warden&r... este é um Drop do &9&lWarden&r... Sim, você precisará matar o &9&lWarden&r. \\n\\nQuando tiver tudo isso, poderá fabricar uma das melhores &7Estantes de Livros&r! Uma que dá &a10 Eterna&r, &c10% Quanta&r e &515% Arcana&r. \\n\\nE o mais importante, nos dá um máximo de &aEterna&r de &a80&r! Quase em 100!"]
	quest.2EC2FA680076C07D.title: "&9Estante de Sculk Ecoante"
	quest.2EC9EC0184C2024D.quest_desc: [
		"Outra estrutura dentro das Cavernas Exuberantes, a Lagoa Musgosa. \\n\\nO &7Cascalho Suspeito&r surge sob a &9Água&r."
		"{image:atm:textures/questpics/pokemon/find_mossy.png width:200 height:100 align:center}"
	]
	quest.2EC9EC0184C2024D.title: "Lagoa Musgosa Pré-histórica"
	quest.2EDE91023F7924FB.quest_desc: ["Coloque o Bloco de Teleporte no &d&lThe End&r para ir para o &5&lAlém&r."]
	quest.2EDE91023F7924FB.title: "&d&lThe End"
	quest.2EE4E88FC814AFA4.quest_subtitle: "Nível: &91"
	quest.2EE8FCB63A338BC4.quest_desc: [
		"A &zFornalha de Arco-Íris&r precisa, literalmente, de todas as outras Fornalhas para ser fabricada. 8 &zChapas de Arco-Íris&r e 1 &zNúcleo de Arco-Íris&r nos dão a melhor Fornalha que poderíamos imaginar!"
		""
		"Sim, leva 20 Ticks para fundir ou 1 Segundo para fundir, mas não funde 1 item. Quantos itens você pergunta? Quantos há em uma pilha de itens?"
	]
	quest.2EE8FCB63A338BC4.title: "&zFornalha de Arco-Íris"
	quest.2EEA11E6CE65C317.quest_desc: [
		"Pequeno Aumento de Nível para 38. "
		""
		"O Item de Assinatura é a Gema Normal."
	]
	quest.2EEA11E6CE65C317.title: "&aLíder Mel"
	quest.2EF0C033C540A7B1.title: "&fProcessamento de &5Rubi"
	quest.2F0D6267569F740B.quest_desc: ["Materiais Comuns são um degrau acima e mais raros que os Abundantes. Estes são principalmente Barras e Drops de Mobs mais raros como Pérolas do Ender ou Pele de Coelho. \\n\\nNovamente, você pode ver a lista completa em Tags."]
	quest.2F16B6A173525277.quest_desc: [
		"A última peça do quebra-cabeça para qualquer grande Rede ME é o &bControlador ME&f. "
		""
		"Um controlador fornece a uma Rede ME um número muito maior de canais do que os 8 canais padrão para redes ad-hoc, fornecendo &b32 canais&r de cada face do bloco para um total de &b216 canais&r. "
		""
		"Isso é apenas para um controlador de um único bloco, no entanto, já que o Controlador ME é, na verdade, uma estrutura multi-bloco. O controlador pode ter até &e7x7x7 blocos&r de tamanho e pode vir em qualquer arranjo de forma livre dentro desse tamanho máximo. Cada bloco individual pode então fornecer seu próprio conjunto separado de canais, desde que nenhum bloco de controlador único esteja cercado por 4 outros blocos no mesmo plano. "
		""
		"Uma Rede ME pode conter apenas um controlador multi-bloco a qualquer momento. Tentar conectar mais de um controlador em partes separadas da rede causará um conflito, desligando toda a rede."
	]
	quest.2F16B6A173525277.quest_subtitle: "O chefão da Rede ME!"
	quest.2F19529214CA9559.quest_desc: ["É como Espinhos, mas não causa Dano, apenas desorienta os Atacantes. \\n\\nEle apenas irá parar os Mobs por um tempo, é muito mais eficaz (e irritante) contra Jogadores!"]
	quest.2F19529214CA9559.quest_subtitle: "Blitz?"
	quest.2F2597122C6202EF.quest_subtitle: "Feito na Forja Atômica"
	quest.2F2597122C6202EF.title: "&fAbelha de Prometheum"
	quest.2F37E284BB83BFF6.quest_desc: ["A Chave Inglesa é usada para girar ou destruir certos blocos, segure shift e clique com o botão direito no ar para mudar os modos."]
	quest.2F3E7233129F2B89.quest_desc: [
		"Age exatamente como um Luminofish, só que estes têm um chifre na cabeça!"
		"{image:atm:textures/questpics/eternal/starlight_fish2.png width:100 height:100 align:center}"
	]
	quest.2F3E7233129F2B89.title: "Luminaris"
	quest.2F4458E9921DEB86.quest_desc: [
		"Estes &e&lPipez&r são principalmente devido ao &5&lMekanism&r. O &5&lMekanism&r adiciona o último estado da matéria na forma de &aGás&r. O &aGás&r não pode ser movido com nenhum dos outros &e&lPipez&r, então se você precisar mover Hidrogênio ou Lítio, você precisará de &aGas Pipez&r. \\n\\n(Eu sempre tive problemas para saber se o item do &5&lMekanism&r é &aGás&r, &bFluido&r ou até mesmo Tipo de Infusão. Quando está em uma Máquina, pode dizer &aGás&r ou &bFluido&r, o que pode ajudar a ensinar. Se não disser, você pode verificar no JEI por outras receitas que possam envolvê-lo!)"
		"{image:atm:textures/questpics/logistics/pipez_gas.png width:200 height:50 align:center}"
	]
	quest.2F4458E9921DEB86.title: "&aGas Pipez&r"
	quest.2F5263A4166BFCD6.quest_desc: ["Este Pilão evita que você destrua acidentalmente certos Blocos/Criaturas no raio da Chunk selecionada.\\n\\nVocê pode usar um Filtro de Criaturas para evitar a morte de uma certa Criatura com o Pilão, ou um Filtro de Bloco para evitar a destruição de um certo bloco.\\n\\nVocê pode acumular várias Criaturas e Filtro de Blocos para evitar que múltiplas Criaturas/Blocos diferentes sejam destruídos."]
	quest.2F5263A4166BFCD6.quest_subtitle: "Chega de destruição acidental!"
	quest.2F556E7919582D2D.quest_desc: ["A &bBancada de Células&f permite que as células sejam 'particionadas' para conter itens específicos, ou seja, receber um filtro de lista branca. Também permite que a célula seja atualizada com certos cartões de atualização, como o Cartão Inversor, que define a lista branca mencionada para ser uma lista negra.\\n\\nAs células também podem receber uma 'prioridade' maior ou menor através da bancada de trabalho, ou seja, permitir que a célula seja a primeira a receber certos itens até ficar cheia, ou ser feita para esperar que outras células de maior prioridade se encham primeiro."]
	quest.2F62C290A5CE50F8.quest_desc: ["Espere, você está me dizendo que por apenas alguns &eMetais Ancestrais&r podemos obter uma Arma que causa mais Dano que uma Espada de Netherita, tem um Alcance insano e lança &eTempestades de Areia&r!? \\n\\nSim, é isso que você obtém da &eLança Ancestral&r!"]
	quest.2F62C290A5CE50F8.title: "&eLança Ancestral"
	quest.2F69010E1FA2787D.quest_desc: ["Esta Missão foi criada pela &6Equipe do AllTheMods&r, ou um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.2F71A83DC5E91615.quest_desc: [
		"Existem muitas estruturas estranhas abaixo das profundezas do oceano. O Impacto Submerso é definitivamente uma das mais estranhas. \\n\\nDentro da quase caverna, há &7Cascalho Suspeito&r."
		"{image:atm:textures/questpics/pokemon/find_submerged_impact.png width:200 height:100 align:center}"
	]
	quest.2F71A83DC5E91615.title: "Impacto Submerso Pré-histórico"
	quest.2F76D074AEA84A4D.quest_desc: ["Clicando com o botão direito em um &dDragão do Ender&r com um &bModelo de Dados&r vazio, você pode fazer o &bModelo de Dados do &dDragão do Ender&r. \\n\\nA Missão precisa de qualquer versão dele, mas a &d&lAlma do Dragão&r precisa que o &bModelo de Dados&r seja &6Autoconsciente&r. \\n\\nPara torná-lo &6Autoconsciente&r, você precisa continuar matando o &dDragão&r ou fazer uma tonelada de Previsões!"]
	quest.2F76D074AEA84A4D.title: "&bModelo de Dados do &dDragão do Ender"
	quest.2F86FB9E4D49E4B0.quest_desc: [
		"Melhorias Válidas:"
		"- Mob Scanner"
	]
	quest.2F8D117F802FEAF0.quest_desc: ["Comandos são as tropas leves. \\n\\nEles têm 12 Corações e nenhuma Armadura. \\n\\nSua arma é um &d&lRevólver&r e um Escudo que eles seguram na Mão Secundária. \\n\\nNa morte, eles droparão peças de Revólver com estatísticas diferentes, semelhantes às estatísticas do Apotheosis!"]
	quest.2F8D117F802FEAF0.title: "Comando"
	quest.2F9B0C642A6BE30C.title: "&fMochila de Ferro"
	quest.2FA0F5B348322095.quest_desc: ["&7Cloggrum&r é o Minério de Ferro do &2&lUndergarden&r. Ele aparece em todos os lugares."]
	quest.2FA0F5B348322095.quest_subtitle: "14"
	quest.2FA0F5B348322095.title: "&7Armadura de Cloggrum"
	quest.2FA6B8A1C8713DE0.quest_desc: ["Para cultivar Sementes de Nível 6 ou Mágicas, você precisa ter um Crux específico colocado diretamente abaixo da Farmland em que elas estão crescendo."]
	quest.2FA6B8A1C8713DE0.title: "&5Farmland de Insanium"
	quest.2FB231069D2E4E77.quest_desc: ["Cada célula individual tem uma certa capacidade ditada pelo &ecomponente&f com o qual a célula foi fabricada.\\n\\nO primeiro dos componentes é o &bComponente de Armazenamento de 1k&f, fornecendo &e1024&f 'bytes' de armazenamento para uma determinada célula. Mais sobre isso depois."]
	quest.2FB231069D2E4E77.quest_subtitle: "O primeiro kilobyte."
	quest.2FB231069D2E4E77.title: "&eCriando sua primeira Célula de Armazenamento"
	quest.2FC15D3916DBF4E4.quest_subtitle: "Mais Opções de Filtragem"
	quest.2FC15D3916DBF4E4.title: "&eMelhoria de Anulação Avançada"
	quest.2FD22502E6481269.quest_desc: ["Usando o &dContato de Ronaza&r, você pode aprimorar sua Gema da Alma para criar uma Gema da Trindade. É basicamente uma versão turbinada da Gema da Alma que pode capturar inimigos maiores, embora ainda não possa conter a maioria dos chefes."]
	quest.2FD22502E6481269.title: "Gema da Trindade"
	quest.2FE088899C1AF39B.quest_subtitle: "Feito na Fundição de Ligas"
	quest.2FE088899C1AF39B.title: "&fAbelha de Aço Escuro"
	quest.2FE4B7B70D90A455.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.3003598CE8B1FAAA.quest_subtitle: "Melhor Tecnologia"
	quest.3003598CE8B1FAAA.title: "Componentes Mais Avançados"
	quest.3025081DA6D2B398.quest_desc: ["Normalmente o Roteador comanda os Módulos, mas com este Augmento o Módulo se rebela! Foge! Anarquia pura! \\n\\nEle obedecerá à sua própria ativação por Redstone em vez da dos Roteadores."]
	quest.3027584AA6138E6D.title: "Inserção e Extração de Esteira"
	quest.3029E1E133B91ED8.quest_desc: ["A &6Furadeira Mecânica&r pode ser usada dentro de uma &aContraption&r ou sem. A versão sem precisará de &dRotational Power&r, mas ainda realiza a mesma tarefa. \\n\\nA &6Furadeira Mecânica&r minerará qualquer Bloco à sua frente (que ela conseguir). \\n\\nEla minerará tão rápido quanto a &dRotational Power&r permitir. E se houver um Inventário conectado à &aContraption&r, o Bloco Minerado será colocado nele, em vez de no chão. \\n\\nSim, a &6Drill&r tem um limite, ela tem apenas o Tier Diamante para Mineração. Portanto, nada de minerar &6AllTheModium&r!"]
	quest.3029E1E133B91ED8.title: "&6Furadeira Mecânica"
	quest.302E9BC711779A4A.quest_desc: ["Vamos dar uma pausa no &eEnxofre&r e nos Ácidos e focar na parte &2Radioativa&r do &2Combustível Fóssil&r! \\n\\nAgora vejamos... o que é &2Radioativo&r, abundante e usado no &6&lATO&r para que qualquer versão funcione? \\n\\nAh, sim, &aUrânio&r! \\n\\nMinere &aMinério de Urânio&r e use as &aBarras de Urânio&r em uma &d&lCâmara de Enriquecimento&r para fazer &eBolo Amarelo de Urânio&r. \\n\\nNão, não coma. Não é esse tipo de Torta! \\n\\nAsse a &eBolo Amarelo de Urânio&r em um &c&lOxidador &eQuímico&r para criar &aÓxido de Urânio&r."]
	quest.302E9BC711779A4A.quest_subtitle: "Estática?"
	quest.302E9BC711779A4A.title: "Preparando &aUrânio"
	quest.3054D016D2EF25FF.quest_subtitle: "Despeje Electro Derretido sobre um Ovo de Gerador de Abelha de Ouro/Prata"
	quest.3054D016D2EF25FF.title: "&fAbelha de Electro"
	quest.30582B5FBED35FD1.quest_desc: ["&cUtherium&r pode ser Minerado ou dropado de &cMobs Rot&r."]
	quest.30582B5FBED35FD1.title: "&cUtheric&r"
	quest.3065EA195D0A36BA.quest_desc: ["Tags são uma parte muito importante para agrupar Itens no Minecraft. Então, é claro que podemos tirar vantagem disso para Filtros! \\n\\nVocê pode colocar um Item e selecionar uma Tag ou, se souber, digitá-la você mesmo. \\n\\nRealmente útil para tarefas como remover Equipamentos de um sistema usando a Tag de Ferramentas. \\n\\n(Você também pode encontrar Tags usando /kubejs hand para descobrir quais são as Tags do Item em sua mão.)"]
	quest.30700E99091B712A.quest_desc: ["A &cMelhoria Reguladora&r permite que você mantenha uma certa quantidade de itens dentro de um bloco ou máquina. Um ótimo exemplo disso é dizer à sua rede que você quer manter 64 Carvões dentro de uma Fornalha. Você colocaria a melhoria em um Exportador conectado a uma Fornalha e o configuraria para 64. Seu sistema então tentará manter a Fornalha cheia de combustível!\\n\\nMas e se você precisar de um item que é criado? A &6Melhoria de Criação&r faz exatamente isso. Se você tiver a receita dentro de um Auto-fabricador, adicionar esta melhoria a uma interface permitirá que ela saiba que deve criá-lo se você ficar sem.\\n\\nUsando nosso exemplo anterior, digamos que temos uma fazenda de &aMystical Agriculture&r funcionando e temos Essência de Carvão. Podemos então colocar a receita de Carvão em um Auto-fabricador conectado ao nosso sistema e, em seguida, colocar esta melhoria no mesmo Exportador que está mantendo a Fornalha abastecida. Se você ficar sem Carvão em seu sistema, a &6Melhoria de Criação&r permitirá que seu sistema crie mais alguns!"]
	quest.30700E99091B712A.title: "&cMelhoria Reguladora"
	quest.308935C85364B04D.quest_desc: ["Com cada Cartão contendo seus próprios dados, pode ser bem chato ficar mudando as configurações de cada Cartão constantemente. Então, vamos apenas cloná-los! \\n\\nClique com o botão esquerdo em um Cartão com o Clonador para copiar seus Dados, depois clique com o botão direito em um Cartão para dar a ele esses Dados!"]
	quest.309059DEDEE7AECD.quest_desc: ["Coleta itens no chão e os traz de volta para seu ninho."]
	quest.309059DEDEE7AECD.quest_subtitle: "Alimente uma Abelha Coletora com um Casco de Shulker"
	quest.309059DEDEE7AECD.title: "&fAbelha Acumuladora"
	quest.309B0B2898893B4E.quest_desc: ["&b&lSteve's Carts&r é totalmente sobre melhorar... bem, seus Carrinhos! \\n\\nQue tipo de melhorias? Praticamente tudo, menos a pia da cozinha! \\n\\nDe Brocas a armas, a máquinas de fliperama! O que mais você poderia querer com seus Carrinhos?"]
	quest.309B0B2898893B4E.title: "&l&bSteve's Carts"
	quest.309B6B8368E535A0.quest_desc: ["Um Roteador executa sua ação toda vez que tem um de seus ticks. \\n\\nO padrão é 20 Ticks ou 1 Segundo. \\n\\nIsso pode ser reduzido para menos Ticks com a Melhoria de Velocidade!"]
	quest.30A238E87F013CBB.quest_desc: ["As abelhas possuem diferentes características que podem afetar como elas trabalham, quando trabalham, sua agressividade e a probabilidade de perderem seu ferrão ao atacar você. Nessas missões, vou explicar como obter as melhores características possíveis, assim como usá-las.\\n\\nPara obter essas Amostras de Gene, confira a missão da Engarrafador, que é uma dependência desta. Para realmente aplicar essas Amostras de Gene nas suas abelhas, você precisará combiná-las com Guloseimas de Mel em uma bancada de trabalho. Todas as características, exceto o Tipo, podem ser aplicadas às suas abelhas alimentando-as com a Guloseima de Mel. O Tipo funciona de forma diferente, e deve ser usado com o Incubador para criar um Ovo de Gerador da abelha respectiva."]
	quest.30A238E87F013CBB.quest_subtitle: "Para criar a abelha definitiva"
	quest.30A238E87F013CBB.title: "Amostras de Gene"
	quest.30AC43222FF9B18A.quest_desc: ["&5Sinais de Trem&r são usados com &5Condutores&r que não são Jogadores. \\n\\nEles são colocados como &5Train Stations&f e &5Observadores&r, mas a maneira como são colocados determina a posição da Seta. \\n\\nAs Setas restringirão por onde os &5Condutores&r podem passar com seus &5Trens&r; se a Seta estiver virada para o lado oposto, o &5Trem&r não passará. \\n\\nVocê pode adicionar dois Sinais virados para direções opostas para deixar os &5Condutores&r passarem onde quiser. \\n\\nCom um monte de &5Sinais&r podemos fazer semáforos para cruzamentos de &7Trilhos&r. Coloque os &5Sinais&r de forma que haja Setas em ambos os lados do cruzamento. \\n\\nIsso fará com que os &5Trens&r parem se outro &5Trem&r estiver no cruzamento. Isso evita colisões que descarrilam os &5Trens&r. &5Trens&r descarrilados precisarão de uma Chave Inglesa para colocá-los de volta nos &7Trilhos&r!"]
	quest.30AC43222FF9B18A.title: "&5Sinais de Trem"
	quest.30AD7B15682E4D0E.quest_desc: ["Uma Placa inteligente que pode armazenar e exibir quantidades arbitrárias de texto, dimensionado para que o texto sempre caiba.\\n\\nClique com o botão direito com qualquer Corante para recolorir a placa, você pode colorir a borda e o fundo independentemente."]
	quest.30AD7B15682E4D0E.quest_subtitle: "Chapas? Nunca ouvi falar!"
	quest.30B0240543253EFB.quest_desc: ["Pylons é um mod maravilhoso feito pelo nosso próprio &aMutant Gumdrop&r!\\n\\nNão deixe o tamanho do mod te subestimar! Ele fornece muitos Pylons que podem ser usados para muitas coisas para ajudar a tornar o jogo de Minecraft mais fácil.\\n\\nPara começar, você precisará de um pouco de Blackstone Polido para fazê-los."]
	quest.30B0240543253EFB.title: "&lPylons"
	quest.30C12E249F7E2D52.quest_desc: [
		"Uma das maiores estruturas no &6&lBumblezone&r, o que obviamente significa mais saques!\\n\\nHá uma tonelada de salas diferentes conectadas em algum tipo de design de quebra-cabeça.\\n\\nSe você ainda não usou a Essência das Abelhas ou tem o Efeito de Proteção da Colmeia, você receberá a Ira da Colmeia enquanto estiver no Labirinto de Células. Então alimente algumas Abelhas!\\n\\nAlém disso, a &5Bússola do Pilar do Trono&r sempre aparecerá nesta estrutura.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_cell.png width:200 height:100 align:center}"
	]
	quest.30C12E249F7E2D52.title: "Labirinto de Células"
	quest.30C5B597610F4AFB.quest_desc: ["O primeiro e mais importante item a ser feito usando a Compulsão Espectral de Eziveus é o Pó de Fragmento de Pesquisa. Isso é usado em combinação com algumas Esmeraldas trituradas para criar Giz de Lima!"]
	quest.30C5B597610F4AFB.title: "&aGiz de Lima"
	quest.30C5D432C810F904.quest_desc: ["O &9Olho da Tempestade&r vai te levar até a &9Acropolis&r para lutar contra &9&lScylla&r."]
	quest.30C5D432C810F904.title: "&9Olho da Tempestade"
	quest.30CC20E33EFA2EDA.quest_desc: ["O &cQueimador de Blaze&r é na verdade provavelmente um dos Ingredientes &6&lEstrela&r mais fáceis! \\n\\nPrimeiro, precisaremos de um &cQueimador de Blaze Vazio&r. São apenas 4 &7Chapa de Ferro&r e uma única &cNetherrack&r. \\n\\nEntão, pegue seu &cQueimador de Blaze Vazio&r e encontre um &cBlaze&r. Você deve saber onde eles aparecem, mas caso não saiba: &cBlazes&r aparecem em Estruturas no &c&lNether&r. Apenas clique com o botão direito no &cBlaze&r com o &cQueimador de Blaze Vazio&r para capturá-lo! \\n\\nUma vez capturado, ele pode ser usado para fazer o &c&lCombustível do Filósofo&r."]
	quest.30CC20E33EFA2EDA.title: "&cQueimador de Blaze"
	quest.30DE4F5BC3EDB555.quest_desc: [
		"Transportadores Lógicos são o que o &5&lMeka&r usa para mover Itens e Blocos à distância. \\n\\nEles precisarão ser configurados para Puxar ou Empurrar para Inventários como Baús ou Gavetas."
		"{image:atm:textures/questpics/logistics/meka_transporter.png width:200 height:50 align:center}"
	]
	quest.30DE4F5BC3EDB555.quest_subtitle: "Blocos+Itens"
	quest.30DF8297FEEC9F22.quest_subtitle: "Tier: &63"
	quest.30E853CE699E669B.quest_desc: ["Antes de poder realizar um trabalho de auto-criação, você precisa de um dispositivo para armazenar a solicitação em si, juntamente com quaisquer itens intermediários para criações de múltiplos passos. Este dispositivo é conhecido como uma &eCPU de criação&f.\\n\\nUma CPU de criação é uma estrutura multibloco que requer pelo menos um bloco de &bArmazenamento de Criação&f, opcionalmente junto com qualquer outra Unidade de Criação. O multibloco pode ser feito em qualquer tamanho, mas deve ser um cubo sólido para se formar e funcionar adequadamente."]
	quest.30E853CE699E669B.quest_subtitle: "Baixe mais RAM"
	quest.30E853CE699E669B.title: "&eArmazenamento de &bC&9r&1i&3a&cç&eã&5o"
	quest.30E9255DEC69C061.title: "&4Ferramentas de Supremium"
	quest.30EA16BB8C169F86.quest_desc: ["Este é uma combinação de &6Cobre&r e &7Estanho&r! \\n\\nÉ muito usado em &7&lModern Industrialization&r! Mas em &8&lIE&r... nem tanto..."]
	quest.30EA16BB8C169F86.title: "&6Lingote de Bronze"
	quest.30EB438C66324213.quest_desc: [
		"Uma &9Estrela do Nether&r fará o que os &2Fragmentos de Prismarinho&r fazem, mas muito melhor.\\n "
		"Os jogadores não precisam mais estar perto do spawner.\\n"
		"Contanto que seu chunk esteja carregado, ele irá spawnar."
	]
	quest.30EB438C66324213.quest_subtitle: "Uma estrela Antissocial!"
	quest.30EB438C66324213.title: "&fIgnorar Jogadores"
	quest.30F97EB743B0A07F.quest_desc: ["Confira os Módulos para aprender mais sobre como usar e aprimorar os itens do DE! O Machado Wyvern é semelhante aos Machados do Minecraft após as Atualizações de Combate. Eles podem ser projetados como uma arma para matar inimigos, ou uma ferramenta para derrubar árvores."]
	quest.30F97EB743B0A07F.title: "Machado Wyvern"
	quest.31094CC16E710040.quest_desc: ["O &4Pé de Cabra&r é a principal ferramenta do RailCraft. \\n\\nQuando usado em uma &5Locomotiva&r, ele mudará a direção que ela está virada. \\n\\nQuando clicado com shift, você pode conectar &5Locomotivas&r e &7Carrinhos&r. \\n\\nQuando apenas usado em &7Carrinhos&r, ele lhes dá um leve empurrão. \\n\\nE quando usado em trilhos especiais, ele muda seu modo. \\n\\nOs diferentes &4Pés de Cabra&r apenas dão aparências e danos diferentes."]
	quest.31094CC16E710040.quest_subtitle: "\"O quê, vai me roubar?\""
	quest.310969B8FE0A94DE.quest_desc: [
		"Outra mudança que o &9Apotheosis&r traz para o jogo é nos &9Geradores&r.\\n"
		"Lembra de poder minerar &9Geradores&r com &6Toque Suave&r?\\n"
		"- Pois é, isso voltou graças ao &9Apotheosis&r!\\n"
		"Além disso, há muitas novas Modificações que você pode adicionar aos &9Geradores&r clicando com o botão direito em qualquer um desses itens."
	]
	quest.310969B8FE0A94DE.title: "&9Geradores Apóticos"
	quest.310FA9380CB3E0BB.quest_subtitle: "Permite a adição de fluidos à centrífuga"
	quest.311E949E3299C95C.quest_desc: ["A &bPedra do Gelo&r irá &bEvoluir&r &6Sandshrew&r para &6Sandslash&r e &cVulpix&r para &cNinetails&r."]
	quest.311E949E3299C95C.title: "&bPedra do Gelo"
	quest.311F43D48B9C26FF.quest_desc: ["O &dGerador de Obsidiana&r é mais lento que os &aGeradores de Esmeralda&r e &5Netherita&r, mas tem mais melhorias que todos eles combinados!"]
	quest.311F43D48B9C26FF.title: "&dGerador de Obsidiana"
	quest.312331F6DB0CE5F4.quest_desc: ["Vai mais rápido que o Tier I."]
	quest.312331F6DB0CE5F4.quest_subtitle: "Máx: 1"
	quest.31324A6F96CAC112.quest_desc: ["&bBombas de Fluido&r não são usadas apenas para Engarrafadores, elas também podem ser usadas para mover &bFluidos&r... mais rápido! \\n\\nUsando um &6Martelo de Engenheiro&r podemos definir os Lados da &bBomba de Fluido&r para &9Entradas&r e &6Saídas&r. \\n\\nEntão, podemos alimentá-la com &4Redstone&r ou &cEnergia&r, com &cEnergia&r movendo &bFluidos&r muito mais rápido que &4Redstone&r."]
	quest.31324A6F96CAC112.title: "&bBomba de Fluido"
	quest.3138B83ABC2930F9.quest_desc: [
		"Habilidade Intrínseca:"
		"- Não Pisotear"
		"- Colheita Automática"
		"- Crescimento Acelerado de Culturas IV"
		""
		"Melhoria Válida:"
		"- Teletransportador de Drops"
	]
	quest.313F5AFF459201EB.quest_desc: ["&l&5Eternal Starlight&r é uma dimensão totalmente nova para explorar! \\n\\nE para aqueles que procuram estritamente por Construção no &2&lMinecraft&r, vocês podem encontrar um monte de novas Pedras nela! \\n\\nPara chegar à Dimensão, você precisará encontrar o seu Portal!"]
	quest.313F5AFF459201EB.title: "Pedras de &l&5Eternal Starlight&r"
	quest.3142A40E1EAEBAA3.quest_desc: ["A &6Varinha de Prospecção&r lhe dá Descoberta Mágica e Vidência quando usada. \\n\\nIsso permite que você veja criaturas mágicas próximas, bem como o ajuda a encontrar ametista!"]
	quest.3142A40E1EAEBAA3.quest_subtitle: "Localizador Mágico"
	quest.3145B847A15F97F2.quest_desc: ["Você pode combinar as Essências de &2&lMystical Agriculture&r para fazer... &8Carvão&r. \\n\\nObviamente, funciona como uma fonte de Combustível incrível, mas &5Carvão de Insanium&r parece um pouco insano demais para mim. "]
	quest.3145B847A15F97F2.title: "&5Bloco de Carvão de Insanium"
	quest.3150CD77C1E90229.quest_desc: [
		"Aumento de nível para 56."
		""
		"Item de Assinatura é &8Lodo Negro&r."
	]
	quest.3150CD77C1E90229.title: "&7Archer e Ariana, Admin. da Equipe Rocket"
	quest.3155E4212045BC8E.quest_desc: [
		"O &5Ninho de Obsidiana&r atrairá &8Abelhas Dracônicas&r quando colocado no &eEnd&r."
		""
		"Elas não aceitam &6Guloseimas de Mel&r, mas usam &dSopro do Dragão&r."
	]
	quest.3155E4212045BC8E.quest_subtitle: "Atrai uma Abelha Dracônica no End"
	quest.3155E4212045BC8E.title: "&fNinho de &5Obsidiana"
	quest.3157BD833FCE8CD3.quest_subtitle: "Alimente uma Abelha de Lava com um Balde de Fogo de Sheol"
	quest.3157BD833FCE8CD3.title: "&fAbelha de Fogo do Sheol"
	quest.315FEAAAFDC05139.quest_desc: [
		"10 &5Obsidianas&r neste padrão (2 no topo e na base, 3 para os lados). "
		"{image:atm:textures/questpics/gettingstarted/example_netherportal.png width:150 height:200 align:center}"
		"Então, acenda-o com &cFogo&r e iluminaremos &cO Portal do Nether&r. Atravessá-lo nos teletransportará para &c&lO Nether&r. \\n\\nUma Dimensão cheia de &cLava&f, &cFogo&r e Criaturas hostis. "
	]
	quest.315FEAAAFDC05139.title: "&c&lO Nether"
	quest.316B513FE568EF57.quest_desc: [
		"Calor é outro fator no &5&lMekanism&r e alimenta muitas Máquinas e Multiblocos. Plantas de Evaporação Térmica e Reatores de Fusão ambos usam Calor para funcionar. E Condutores é como você moverá o Calor!"
		"{image:atm:textures/questpics/logistics/meka_conductor.png width:200 height:50 align:center}"
	]
	quest.316B513FE568EF57.quest_subtitle: "Calor"
	quest.31749B21AD674C5F.quest_desc: ["O próximo é &6&lVirtuositas&r! \\n\\nEle é conhecido por usar o mod &6&lCreate&r e &c&lCobble&fmon&r! Temos ambos no &c&lAll&7The&fMons&r, mas limite-se a derrotá-lo com &c&lCobble&fmon&r. \\n\\nAcho que você perderia em uma batalha de &6&lCreate&r... seja lá o que isso signifique."]
	quest.31749B21AD674C5F.title: "&6&lVirtuositas"
	quest.3182E8AF755104E4.quest_desc: ["Ao bloquear dano, o &9Escudo do Encantador&r dará ao usuário Regeneração de Mana e Dano de Feitiço por um curto período de tempo. \\n\\nAdicionalmente, o escudo se reparará ao longo do tempo usando a mana do usuário."]
	quest.318A2CC03D1D0B04.quest_desc: ["Sente falta das &lVarinhas de Construção&r? \\n\\nBem, eu sentia, e o &9Mrbysco&r também! Então ele fez as &l&6Varas de Construção&r! \\n\\nHá alguns Tiers diferentes de &6Vara de Construção&r. Quanto mais caras elas são, mais Durabilidade elas têm e mais Blocos elas podem colocar. \\n\\nElas começarão apenas colocando Blocos para preencher um espaço, mas suas opções podem ser alteradas abrindo sua GUI. Você precisará definir uma Tecla de Atalho para fazer isso. \\n\\nUma vez que você a abra, você pode mudar tudo sobre elas. Onde elas colocam Blocos, em que padrão e até mesmo quais Blocos colocar! \\n\\nElas também têm suas próprias Melhorias que você pode Criar. Para usá-las, combine a Melhoria com sua &6Vara de Construção&r em uma Mesa de Ferraria. "]
	quest.318A2CC03D1D0B04.title: "&l&6Varas de Construção"
	quest.3195A7AA874163CD.quest_desc: ["O &bCartão de Distribuição Igualitária&f é uma melhoria para células de armazenamento que pré-aloca uma certa quantidade de itens que pode ser ocupada por qualquer tipo individual.\\n\\nEste comportamento é comparável a algo como uma &6Functional Storage Gaveta&r, onde cada compartimento contém um número definido de pilhas, em oposição a permitir que itens de um compartimento vazem para os outros e expulsem outros tipos de itens."]
	quest.3195A7AA874163CD.quest_subtitle: "Organização nível TOC desbloqueada!"
	quest.31A370550BD592B6.quest_desc: ["Sementes de Cristal Nitro requerem um Crux de Cristal Nitro colocado abaixo para que possam crescer."]
	quest.31A370550BD592B6.quest_subtitle: "Tier: &56"
	quest.31AD9826FB036C98.quest_desc: ["&7Runas&r podem aparecer desde a Bedrock até a Camada Y 2. Isso inclui perto de &9Pedra Sombria&r! \\n\\nElas são mais úteis que &2Stellarite&r, mas menos úteis que &bCristais Arcanos&r."]
	quest.31AD9826FB036C98.quest_subtitle: "Estas runas costumavam ser &5Roxas&r!"
	quest.31AD9826FB036C98.title: "&eRunas"
	quest.31B0267C47DB9D98.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.31B73D16C0199785.quest_desc: ["Jogue o &5Pó de Obsidiana Refinada&r em um &7&lCompressor de Ósmio&r e &7Comprima &falgo de &7Ósmio&r nele! \\n\\nAcho que é assim que o &7&lCompressor de Ósmio&r funciona... \\n\\nAgora teremos &5Barras de Obsidiana Refinada&r, estes podem ser transformados em outras &5Máquinas&r ou até mesmo Ferramentas e Armaduras!"]
	quest.31B73D16C0199785.title: "&5Obsidiana Refinada"
	quest.31BAC57972148E1F.quest_subtitle: "Tier: &a2"
	quest.31BCE63F5E016323.quest_desc: ["O &3Compressor Solar&r gera Pressão usando a luz solar, quanto mais quente fica, mais Pressão ele produzirá.\\n\\nNo entanto, tenha cuidado, se ficar muito quente ele irá falhar e você precisará repará-lo."]
	quest.31BCE63F5E016323.quest_subtitle: "Na palma da minha mão..."
	quest.31BCE63F5E016323.title: "Pressão do Sol"
	quest.31CB278B4BA7B25E.quest_desc: ["Centrifugar &#B5E7F7Ar Líquido&r fornecerá 3 produtos: &#A5CAD9Oxigênio&r, &#78ADC2Nitrogênio&r e &#DD91EDArgônio&r. Usaremos esse &#DD91EDArgônio&r em breve."]
	quest.31CB278B4BA7B25E.quest_subtitle: "Faz sentido"
	quest.31CB278B4BA7B25E.title: "&fCentrifugando Ar"
	quest.31E7F7464D79F881.quest_desc: ["Não são apenas &7Estantes&r que podem ser &d&lInfusionadas!&r"]
	quest.31E7F7464D79F881.title: "Outros Itens de &d&lInfusão&r"
	quest.31EC6244E4A3CBD6.quest_subtitle: "Tier: &b4"
	quest.31ED0C236C41A837.quest_subtitle: "Alimente uma Abelha Magmática com um Balde de Lava"
	quest.31ED0C236C41A837.title: "&fAbelha de Lava"
	quest.320EE52EB022FAD3.quest_desc: ["Agora este é divertido! \\n\\n&bSaídas de Fluido&r podem ser configuradas para &9Entrada de &bFluidos&r, e então podemos fazer com que elas coloquem esses &bFluidos&r como Blocos Fonte ao lado dos Lados de &6Saída&r! \\n\\nIsso significa que podemos automatizar a colocação de &9Água&r, &cLava&r, ou praticamente quaisquer &bFluidos&r! "]
	quest.320EE52EB022FAD3.title: "&bSaída de Fluido"
	quest.321F16645640C462.quest_desc: ["Pérolas do End são uma forma divertida de viajar! (Útil para a Bumblezone, será que teremos um capítulo de Missão para esse Mod?) Mas você não odeia que a Pérola do End seja consumida ao usar e cause 2 Corações de dano a cada uso? \\n\\nCom o &9Warp Drive&r, tudo isso desaparece, tornando claramente as Pérolas do End o melhor meio de transporte! A Fome é consumida em vez da Pérola do End e você não sofre mais dano ao usar uma Pérola do End. Quando todas as Barras de Fome se esgotarem, ela voltará a consumir Pérolas do End."]
	quest.321F16645640C462.quest_subtitle: "Cinto"
	quest.321F16645640C462.title: "&9Warp Drive&r"
	quest.321FA7348E532F4E.quest_desc: ["O Látex é um fluido usado para fazer Borracha Seca, mas também pode ser usado para algumas coisas na Câmara de Dissolução."]
	quest.321FA7348E532F4E.title: "Látex"
	quest.3235FBD9CE21D5EE.quest_desc: ["Confira os Módulos para aprender mais sobre como usar e aprimorar os itens do DE! Eu sei com o que vocês, colegas Jogadores, realmente se importam sobre a Pá Wyvern. Vocês não precisam mais passar noites em claro, porque agora vocês sabem, as Pás do DE podem fazer caminhos."]
	quest.3235FBD9CE21D5EE.title: "Pá Wyvern"
	quest.32384DE59539557D.quest_desc: [
		"O &4&lTriturador&r é uma Máquina muito perigosa e barulhenta. \\n\\nVocê pode &9Inserir &eItens&r (ou Mobs) nas Grelhas Superiores, e ele os &4&lTriturará&r em seus Drops! \\n\\nIsso pode ser muito útil, especialmente para transformar Minérios Brutos em Pó. Se usarmos Blocos de Minério Bruto, obteremos mais Pó do que o &6Martelo&r nos daria, e alguns têm a chance de dar um tipo de Pó totalmente novo! \\n\\nTodos os Drops sairão pelo Bloco Frontal Inferior, sendo &6ejetados&r automaticamente. Ele também precisará de &cEntrada de Energia&r pelo Lado Superior Direito."
		"{@pagebreak}"
		"O &4&lTriturador&r é bem grande, precisaremos colocar este layout de &8Andaimes de Aço&r e &eBlocos de Engenharia Leve&r. A direção que os &eBlocos de Engenharia Leve&r estão virados é o lado Frontal!"
		"{image:atm:textures/questpics/immersive/immersive_crusher1.png width:100 height:150 align:center}"
		"Em cima dos nossos 3 &eBlocos de Engenharia Leve&r, colocaremos mais 3. Também colocaremos um &4Bloco de Engenharia de Redstone&r e um &eBloco de Engenharia Leve&r no Lado Esquerdo. Então, coloque outro &eBloco Leve&r no meio e cerque-o com &8Cercas de Aço&r."
		"{image:atm:textures/questpics/immersive/immersive_crusher2.png width:100 height:100 align:center}"
		"Finalmente, apenas jogamos 9 Funis em cima das &8Cercas de Aço&r e no meio!"
		"{image:atm:textures/questpics/immersive/immersive_crusher3.png width:100 height:100 align:center}"
		"Você precisará bater na &8Cerca&r do meio para formar o Multibloco."
		"{image:atm:textures/questpics/immersive/immersive_crusher.png width:100 height:100 align:center}"
	]
	quest.32384DE59539557D.title: "&l&4Triturador"
	quest.325483DEB0C602F8.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.3260EDAD3A619479.quest_desc: ["&5Minério de Aethersent&r é encontrado durante Chuvas de Meteoritos em &5&lEternal Starlight&r. Os pequenos quebram com o impacto, você precisará esperar por Meteoros grandes! \\n\\nOu são Meteoritos? Qual é a diferença?"]
	quest.3260EDAD3A619479.quest_subtitle: "14"
	quest.3260EDAD3A619479.title: "&5Armadura de Aethersent"
	quest.326C63F7DC713E71.quest_desc: ["O Distribuidor é o meio-irmão dos Sender Modules. (O MK3 para ser exato, do lado do MK2). \\n\\nEm vez de enviar para 1 Inventário, ele enviará para múltiplos que são selecionados. \\n\\nEle pode enviar em múltiplos modos: Round Robin, Aleatório, Mais Próximo Primeiro ou Mais Distante Primeiro. Round Robin distribui uma quantidade igual para cada um em uma fileira, como um dealer no Pôquer. Aleatório escolherá aleatoriamente um inventário para alimentar. Os outros são determinados pela distância do Roteador."]
	quest.3270D40010F5C78A.quest_desc: [
		"Aumento de Nível para 41."
		""
		"O Item de Assinatura é uma Bolota Preta."
	]
	quest.3270D40010F5C78A.title: "&7Admin Shadow Ivory e Recruta"
	quest.327587EEEF6849BE.quest_subtitle: "Abeto Prateado + Lariço Europeu"
	quest.32826A0DCA65AB2B.quest_desc: ["Seja você um jogador experiente em mods ou um completo novato no &2&lMC&r, todos têm que fazer uma &6Picareta de Madeira&r.\\n\\nPicaretas permitem que você quebre a maioria dos blocos de &7Pedra &fe &7Metal&r. Esta de &6Madeira&r não durará muito, então certifique-se de coletar um pouco de &7Pedregulho&r com ela!"]
	quest.32826A0DCA65AB2B.title: "Nossa Primeira Picareta"
	quest.32ABE5D734703B9C.quest_desc: ["&7Élitro&r ou &a&lPeitoral do Meka-Traje&r... \\n\\n&7Élitro&r ou &a&lPeitoral do Meka-Traje&r... \\n\\nPor que não ambos?"]
	quest.32ABE5D734703B9C.quest_subtitle: "Peitoral"
	quest.32ABE5D734703B9C.title: "&7Unidade de Élitros"
	quest.32B01BD789F0B037.quest_desc: ["Supremium Despertado e outras essências de tier podem ser farmadas usando o mod &6Productive Bees&r."]
	quest.32B01BD789F0B037.title: "Automatizando Supremium Despertado"
	quest.32C3E14578D48E6C.quest_desc: ["Assim como os &3Tubos de Pressão&r normais, só que estes podem suportar 10 bars de pressão."]
	quest.32C3E14578D48E6C.quest_subtitle: "Upgraded Pressure Tubes"
	quest.32C7D8AE859BF89E.quest_desc: [
		"Pode ser de &dObsidiana&r, mas não se preocupe, você não precisa de uma &bPicareta de Diamante&r para pegá-la, apenas para criá-la."
		""
		"Funciona a cada 20 Ticks ou a cada Segundo. Sim, não Segundos, apenas Segundo."
		""
		"Pode ser criada com uma &3Crystal Furnace&r ou &aEmerald Furnace&r, e pode ser transformada em uma &5Fornalha de Netherita&r!"
	]
	quest.32C7D8AE859BF89E.title: "&dObsidian Furnace"
	quest.32D585D9F73CD9FD.quest_desc: ["O &#EDDF55Alto-forno Elétrico&r permitirá que você processe diversos recursos. As receitas exigem uma &#B8ED55bobina específica&r para ser usada na estrutura."]
	quest.32D585D9F73CD9FD.title: "&eAlto-forno Elétrico"
	quest.32E52AD6EF194A60.quest_desc: ["O Pylon de Expulsão funciona como uma forma de manter as pessoas fora do seu gramado. \\n\\nQuando colocado, ele manterá qualquer Jogador que não esteja na lista branca fora de uma quantidade definida de Chunks ao redor dele. \\n\\nOs Chunks são definidos em sua INTERFACE no canto superior esquerdo de 1x1, 3x3 ou 5x5 Chunks. \\n\\nE não, ele não pode ser colocado muito perto do Spawn. Nós sabemos o que vocês, trolls, querem e não vamos dar! \\n\\nPara colocar jogadores na lista branca, confira a Missão do Filtro de Jogador!"]
	quest.32E52AD6EF194A60.quest_subtitle: "Saia do meu gramado!"
	quest.32EBB3D53AA91E09.quest_desc: ["A menos que você seja um trapaceiro que usa Pacotes de Textura de Visão Noturna, você pode achar o escuro um pouco preocupante. Felizmente, o Módulo de Visão Noturna em um Peitoral do DE ajuda a superar o medo de não conseguir ver no escuro. Mas não o medo do que está no escuro..."]
	quest.32EBB3D53AA91E09.title: "Módulo de Visão Noturna"
	quest.32ECD93A8F2FAB8F.quest_desc: ["&6Jetpacks&r são uma forma adorada de se locomover. \\n\\nPara começar a fazê-los, você precisará começar com um &6Jetpack de Madeira&r! Este pode ser atualizado até um &5Jetpack Criativo&r. \\n\\nEmbora tenha muitas versões, todas funcionam da mesma forma. Todas podem ser colocadas no seu Slot de Peitoral, ou Curio de Costas, ou Curio de Curio. \\n\\nTodas elas também precisam de FE para funcionar, você pode usar qualquer Carregador de Itens para carregá-las! Elas usarão FE para voar e sim, você cairá se ficar sem Energia. \\nPara voar, você precisará ligar seu Motor (V), então, quando você segurar Espaço, você voará para cima e cairá quando soltar. \\n\\nPara aqueles que não gostam de cair, você pode ligar o Hover (Não atribuído), quando ativado, você voará na mesma altitude; podendo subir com (Espaço) e descer com (Shift). \\n\\nPara ajustar a velocidade do seu voo, mude sua Aceleração. Diminuir é (,) por padrão e aumentar é (.) por padrão!"]
	quest.32ECD93A8F2FAB8F.title: "&l&6Iron Jetpacks"
	quest.32FDC5FFA000DAF8.quest_desc: ["Orgulhoso das Abelhas que você tem?\\n\\nQuer colocá-las em um pote para exibi-las?\\n\\nColoque um &6Jarro de Abelha&r no chão e use um Cano ou Funil para inserir a abelha enjaulada no Jarro."]
	quest.32FDC5FFA000DAF8.quest_subtitle: "Exibindo Abelhas"
	quest.32FDC5FFA000DAF8.title: "&fJarro de &6Abelha"
	quest.3308D7EDFBF51190.quest_desc: [
		"Desertos têm montes e montes. Alguns até Tocas Arenosas! \\n\\n&eAreia Suspeita&r surge na toca."
		"{image:atm:textures/questpics/pokemon/find_sandy.png width:200 height:100 align:center}"
	]
	quest.3308D7EDFBF51190.title: "Toca Arenosa Pré-histórica"
	quest.33105698C75093C2.quest_desc: ["O &4Destruidor Mega&r tem 54 espaços para filtros, funciona 8x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.33105698C75093C2.title: "&4Destruidor Mega"
	quest.33106E24A3B5DDD8.quest_desc: [
		"O próximo passo em sua jornada será encontrar &eMinério de Iesnium&r no Nether."
		""
		"Sem os efeitos do &3Terceiro Olho&r, isso parecerá apenas Netherrack. Certifique-se de ter seus &dÓculos do Outro Mundo&r equipados!"
		""
		"Para localizar o minério, tente usar uma &aVara de Adivinhação&r. Você precisará sintonizá-la com Netherrack primeiro, depois segure o botão direito do mouse para usá-la. Após alguns segundos, você verá uma partícula disparar na direção do Minério de Iesnium mais próximo. Você só pode minerar o minério usando a &dPicareta Infundida&r!"
		""
		"Como você não pode transformar este minério em o dobro de pós usando os métodos padrão, tente usar seu Foliot Triturador para dobrar suas Barras por minério bruto!"
		""
		"Nota: Se você não vir a partícula, certifique-se de que suas configurações de partículas estão ativadas!"
		""
		"{image:atm:textures/questpics/occultism/iesniumexample.png width:200 height:175 align:1}"
	]
	quest.33106E24A3B5DDD8.title: "&cIesnium: Minério do Outro Mundo"
	quest.3314FBC4FEAE1D08.quest_desc: ["O &6Deployer&r é uma &6Máquina&r muito divertida para cutucar! \\n\\nPor cutucar, eu quero dizer principalmente &eInterações de Itens&r que podemos realizar. Coloque um &eItem&r na &6Mão do Deployer&r, e então dê a ele &dPoder Rotacional&r. Ele então colocará o &eItem&r no Bloco em um &eDepot&f ou &eCorreia&r abaixo. \\n\\nIsso imitará muitas ações que podemos fazer, como adicionar &6Cera&r ao &cCobre&r. \\n\\nVocê provavelmente o usará para &8Carcaças de Andesito&r/&cCobre&r/&eLatão&r e &4Quartzo Rosa Polido&r."]
	quest.3314FBC4FEAE1D08.quest_subtitle: "Cutucar"
	quest.3314FBC4FEAE1D08.title: "&6Deployer"
	quest.3331EBE1BB4BF64D.quest_desc: ["Reatores Nucleares podem ser bem assustadores para alguns, especialmente com os efeitos perigosos deles! \\n\\nFelizmente, a única coisa assustadora sobre &a&lExtreme Reactors&r é o quão confuso pode ser seguir as receitas! \\n\\nNão a parte da explosão, eles não fazem isso."]
	quest.3331EBE1BB4BF64D.title: "&a&lExtreme Reactors"
	quest.3334D15766A47A46.quest_desc: ["Usando um Programa de Montagem a Laser, você pode acelerar a produção de &3PCBs Não Montadas&r. Basta colocar um PCB Vazio no baú de entrada, bombear um pouco de pressão e esperar."]
	quest.3334D15766A47A46.title: "Automatizando PCBs"
	quest.333682022948E2F3.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_thioquartz.png width:100 height:150 align:center}"]
	quest.333682022948E2F3.title: "&2Thioquartz&r"
	quest.3339445194568D77.title: "&2Ferramentas de Prudentium"
	quest.33415CB421F7620A.quest_desc: ["A &b&lCâmara de Purificação&r é tecnicamente uma Melhoria para a &d&lCâmara de Enriquecimento&r. Bem... ela perde muitas funções, mas melhora o &lProcessamento de Minério&r! \\n\\nIsso é praticamente tudo o que ela faz, combina &7Minérios&r com &bOxigênio&r para obter mais Barras deles! \\n\\nBem... ela não faz &7Barras&r, ela faz &7Aglomerados&r... seja como for, apenas leia a Missão de &lProcessamento de Minério&r para saber mais sobre isso!"]
	quest.33415CB421F7620A.title: "&b&lCâmara de Purificação"
	quest.33422FBDAE11AE82.quest_subtitle: "Alimente uma Abelha Espacial com uma Pérola de Fluix"
	quest.33422FBDAE11AE82.title: "&fAbelha de Fluix"
	quest.33433A443B65D252.quest_desc: [
		"&bÁgua&r=&bAzul&r &bÁgua&r=&bFluido&r portanto &bAzul&r=&bFluido&r\\n\\nMuitos Mods têm seus próprios &bFluidos&r, com até mesmo o Minecraft tendo os seus, com &bÁgua&r e &cLava&r. Você provavelmente precisará mover esses &bFluidos&r e uma boa maneira de fazer isso é com &bCanos de Fluido&r. \\n\\nIsso pode ser conectado a Pias para mover &bÁgua&r Infinita!"
		"{image:atm:textures/questpics/logistics/pipez_fluid.png width:200 height:50 align:center}"
	]
	quest.33433A443B65D252.title: "&bPipez de Fluido"
	quest.33436ED0D9F128BD.quest_desc: ["&4Aumento&r: Defumação transforma sua Fornalha de Ferro em um Defumador de Ferro. Agora ele só irá defumar itens de Comida, mas duas vezes mais rápido! Como o &4Aumento&r: Detonação, este também se acumula com outras Aumentos!"]
	quest.33436ED0D9F128BD.title: "&4Aumento&r: Defumação"
	quest.3347CB6478F486C6.quest_subtitle: "Bancada de Células Onde Quer Que Você Vá"
	quest.334AB2ED426108C7.quest_desc: ["É um &#E3495Emoedor&r, tudo o que ele faz é triturar coisas."]
	quest.334AB2ED426108C7.quest_subtitle: "Chame como quiser, isso mói"
	quest.33532408B21A5378.quest_desc: ["O Gerador Lamentável gera uma pequena quantidade de FE usando combustíveis queimáveis como Carvão."]
	quest.3365017C9B24C0A9.quest_desc: ["Use Arcos ou Bestas para atirar 32 Ferrões. \\n\\nSim, você pode fazer isso!"]
	quest.33682F4B44950123.quest_desc: ["Para obter mais conhecimento sobre feitiços, precisaremos de um tipo específico de madeira mágica! \\n\\nÁrvores de Archwood podem ser encontradas no Mundo Superior."]
	quest.3371F9248D403664.title: "&l&cRecompensa do Nether:&r&e Esqueletos Wither"
	quest.33732EE8110A0911.quest_desc: ["O Dev do &8&lIE&r esqueceu que a &4&lBroca de Mineração&r também pode ser usada para Mineração, então no último minuto ele colocou Fortuna III. \\n\\nSendo este o Ácido Amolecedor de Rochas."]
	quest.33816AF0E699F19F.quest_desc: ["Este bloco drenará FE de qualquer item carregado."]
	quest.3384308C78D86059.quest_subtitle: "Tier: &a2"
	quest.33882172DA8021F6.quest_desc: ["Mantém o inventário do jogador abastecido com itens de dentro da Mochila."]
	quest.338BD467EBE6EE1F.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_sentry.png width:100 height:150 align:center}"]
	quest.338BD467EBE6EE1F.quest_subtitle: "Posto Avançado de Pillager"
	quest.338BD467EBE6EE1F.title: "Ornamento de Armadura de Sentinela"
	quest.339384ADC9CDB944.title: "Conhecimento"
	quest.33977CEF056F0A13.quest_subtitle: "Alder + Rowan"
	quest.339DF320DDCAD98B.quest_desc: ["Os Transportadores podem ser usados para transportar Itens e/ou Fluidos entre inventários que estão a 1 bloco de distância. Você precisa de um Transportador no lado da extração e outro no lado da inserção. Para mudar esses modos, clique com o botão direito na área do meio.\\n\\nVocê pode ter múltiplos tipos de transportadores no mesmo bloco. Você pode melhorá-los com Adicionais. Velocidade para aumentar a velocidade de transferência, Eficiência para aumentar a quantidade de transferência."]
	quest.339DF320DDCAD98B.title: "Transporte de Item e Fluido"
	quest.33A0E06FE5CFD8F3.quest_desc: ["A &9Centrífuga&r é usada para processar Favos de Abelhas em itens úteis e mel! Embora você possa definitivamente usar uma &9Centrífuga&r regular no início, obter uma &6Centrífuga Elétrica&r logo depois é uma obrigação. Esta é uma Centrífuga mais rápida que funciona com energia!\\n\\nSe você está procurando a melhor maneira de processar seus Favos, a &cCentrífuga Aquecida&r é ainda mais rápida e processa &aBlocos de Favo&r em vez de Favos!\\n\\nTodas elas podem ser aceleradas usando Melhorias de Velocidade."]
	quest.33A0E06FE5CFD8F3.quest_subtitle: "Processando Favos de Mel"
	quest.33AADC1B97E9F7A9.quest_desc: ["Carrinhos de Mina com Baús são Carrinhos de Mina com Baús dentro deles. Você não pode andar neles, mas eles podem ser úteis para transportar itens através de sistemas de Trilhos."]
	quest.33ADE41526C39AFD.quest_desc: ["Este comportamento é comparável a algo como um Functional Storage Gaveta, onde cada compartimento contém um número definido de pilhas, em oposição a permitir que itens de um compartimento vazem para os outros e expulsem outros tipos de itens."]
	quest.33ADE41526C39AFD.quest_subtitle: "Não quero mais!"
	quest.33B1D3FD4C0B5514.quest_desc: [
		"O &e&lRemanescente Ancestral&r é mestre de seu domínio, da &eAreia&r. \\n\\nEle tem 2.700 &4Corações&r e é auxiliado por um &eWadjet&r e um &eKobolediator&r. \\n\\nEle tem alguns movimentos e ataques! Ele pode balançar sua cauda ossuda em você, morder você, ou ele pode pisar no chão, produzindo Ondas de Choque. \\n\\nEle também pode invocar &eTempestades de Areia&r com um poderoso RUGIDO e até mesmo soltar &eArmadilhas de Areia&r na sua cabeça. \\n\\nOutro ataque que ele pode usar para se aproximar de você é sua investida. Sua investida irá machucar você e seu FPS, pois destrói todos os Blocos em seu caminho. \\n\\nEle tem uma fraqueza, a mesma coisa que o ressuscitou! Se você acertar seu &eColar&r, ele será derrubado por um tempo, dando a você a chance perfeita para derrubá-lo e devolvê-lo ao túmulo!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_remnant.png width:100 height:100 align:center}"
	]
	quest.33B1D3FD4C0B5514.title: "&e&lRemanescente Ancestral&r"
	quest.33B301DB0637B6FC.quest_desc: ["Nas profundezas da terra, você pode encontrar um &bMegaroide&r! \\n\\nNão, não tem nada a ver com melhorias físicas... bem, exceto para &cPokémon&r. \\n\\nÉ chamado de 'roide' por causa de asteroides, não esteroides, é isso que estou tentando dizer! \\n\\nNo centro do &bMega-asteroide&r, fica o Minério de Pedra-chave."]
	quest.33B301DB0637B6FC.title: "&bMegaroide"
	quest.33C69B5934BE4D64.quest_desc: ["&bCanos Mecânicos&r moverão &bFluidos&r. Isso mesmo! Não apenas &9Água&r! \\n\\n&bCanos Mecânicos&r são feitos com 2 &8Barras de Aço&r e 1 &7Balde Vazio&r. Eles também são melhorados da mesma forma que os &eTransportadores Logísticos&r. \\n\\n&a&lBásico&r: comportará 2 Baldes de Fluidos e moverá 250mB de Fluido a cada Tick. \\n\\n&c&lAvançado&r: comportará 8 Baldes de Fluidos e moverá um Balde de Fluido a cada Tick. \\n\\n&b&lElite&r: comportará 32 Baldes de Fluido e moverá 8 Baldes a cada Tick. \\n\\n&d&lUltimate&r: comportará 128 Baldes e moverá 32 Baldes a cada Tick."]
	quest.33C69B5934BE4D64.quest_subtitle: "Fluidos"
	quest.33C69B5934BE4D64.title: "&bCanos Mecânicos"
	quest.33D23C65E7274A8F.quest_desc: ["Para despertar sua Essência de Supremium, você precisará criar um novo Altar e 4 novos Pedestais, bem como 4 &cVasos de Essência&r.\\n\\nOs Vasos de Essência exigirão as Essências Elementares iniciais para serem preenchidos: Fogo, Água, Terra e Ar."]
	quest.33D23C65E7274A8F.title: "&dO Despertar&r"
	quest.33D2901594655A77.title: "Módulo de Área de Efeito Caótico"
	quest.33F4A7613764A016.quest_desc: ["Funciona como os Importadores, só que eles exportam."]
	quest.33F4A7613764A016.quest_subtitle: "Exportando"
	quest.340F93695FFF8D76.quest_desc: ["Com isso, o &b&lLançador Químico&r será mais um Atirador Químico. \\n\\nO alcance será aumentado, mas a largura do spray será diminuída. Então é mais preciso!"]
	quest.341486C9F277FEB7.title: "Reator (Vibrante)"
	quest.3416DB9F58D8AA2C.quest_desc: ["&3Neptunium&r é uma recompensa da Recompensa de Netuno, que é obtida através da Pesca! \\nTambém concede bônus por estar debaixo d'água."]
	quest.3416DB9F58D8AA2C.quest_subtitle: "28"
	quest.3416DB9F58D8AA2C.title: "&3Armadura de Neptunium"
	quest.341BB1353A1E45EA.quest_desc: ["Torretas de Arma agirão como um &d&lRevólver&r com um cérebro de Computador! \\n\\nElas precisarão de &cEnergia&r por baixo dela, e um &4Sinal de Redstone&r para ligar. Ou use uma &6Chave de Fenda de Engenheiro&r nela para deixá-la sempre ligada. \\n\\nEla usa a mesma Munição que um &d&lRevólver&r, isso inclui Projéteis Especiais! Você pode &9Inserir&r Balas nela e &6Ejetar&r os Cartuchos, ou apenas deixá-los cair com o Botão de Ejetar Cartucho. \\n\\nAntes de começar a atirar, precisaremos definir seu alvo. Primeiro, ela não atacará a pessoa que a colocou. Também temos uma Barra de Tipo que podemos adicionar qualquer nome de Jogador ou Mob para Adicionar. Isso fará com que ela os poupe! \\n\\nEla é automaticamente definida como Lista Negra, se estiver na Lista Negra, significa que atirará no que está listado. Temos também Animais, que significa Mobs Passivos. Jogadores significa apenas Jogadores. Neutro representa quaisquer Mobs Neutros e Aldeões. Não se preocupe, ela sempre mirará em Mobs Hostis!"]
	quest.341DF467E3936E78.quest_desc: ["Mate o &dDragão do Ender&r enquanto usa um conjunto completo de Armadura de &8A&6b&8e&rlha! \\n\\nSeu nome será lembrado por séculos!"]
	quest.342D1FA0BCBB847A.quest_subtitle: "Tier: &b4"
	quest.342EEB042DEC2B8C.quest_desc: ["Magma e Gêiseres ambos aparecem no fundo do Abismo. \\n\\nMagma ajudará você a descer e a manter sua respiração. \\n\\nGêiseres apenas parecem legais!"]
	quest.3446803FB59D8875.quest_desc: ["Dá a você Espinhos. Não na sua Armadura, em você! Como um Baiacu!"]
	quest.3446803FB59D8875.quest_subtitle: "Colar"
	quest.3446803FB59D8875.title: "&aPingente de Espinhos&r"
	quest.3458F19FB41C7F0E.quest_subtitle: "Red Crepe Myrtle + Luck"
	quest.3459CAEB59CBD60E.quest_desc: ["Parece que alguém ligou o interruptor desta vez! \\n\\n&4The Prowler&r é um miniboss que guarda a &4Fábrica Ancestral&r. Ele tem 640 &4Corações&r. \\n\\nEle tem 3 ataques. A Serra para Inimigos próximos. E para Inimigos mais distantes, ele tem Mísseis de Ombro, semelhantes ao WASW, e um Laser de seu olho. \\n\\nNa morte, ele dropará Redstone e Ferro. \\n(Dica: ele também é fraco a ataques EMP)"]
	quest.3459CAEB59CBD60E.title: "&4The Prowler&r"
	quest.3466C70EB256026B.quest_subtitle: "Fabricado com Aparelho de Encantamento"
	quest.3466C70EB256026B.title: "&fAbelha de Essência do Fogo"
	quest.346860B8EBC4C28C.quest_desc: ["A criação de &cEnergia&r começa com algo muito simples. \\n\\nGeralmente um Gerador que usa &0Carvão&r ou &cLava&r para gerar FE. \\n\\nTodos estes Geradores fazem exatamente isso!"]
	quest.346B9339E3D66478.quest_desc: ["Energia é algo usado por praticamente tudo, então você precisa enviá-la para quase todos os lugares. Felizmente, o Módulo de Energia ajudará com isso! \\n\\nO Módulo de Energia moverá qualquer energia inserida nele para outro lugar! Para onde quer que você o configure!"]
	quest.3497C2E05DF5A87C.quest_desc: ["&cRedstone&r, &9Lápis-lazúli&r, Quartzo, &5Ametista&r, &aEsmeralda&r e &bDiamantes&r são todas Gemas preciosas. \\n\\nEntão, é claro que estamos transformando-as em Blocos, Blocos preciosos muito bonitos, para ser exato!"]
	quest.3497C2E05DF5A87C.title: "&fBlocos de Gemas &l&bChipped&r"
	quest.349D19F2FCC34B84.quest_desc: ["Colocar o Ninho de Tijolo do Nether no &cNether&r atrairá uma &cAbelha Magmática&r quando receber &cCreme de Magma&r."]
	quest.349D19F2FCC34B84.quest_subtitle: "Atrai uma Abelha Magmática quando colocado no Nether"
	quest.349D19F2FCC34B84.title: "&fNinho de Tijolos do &cNether"
	quest.349E8C0C3F9CC99B.quest_desc: ["Damas primeiro, eu suponho! \\n\\nA primeira streamer que você precisará derrotar é a &d&lPrincessStellar&r! \\n\\nEla ajuda muito no &6&lATM&r, incluindo nas Missões! Se você está lendo isso em Português Brasileiro, agradeça a ela por isso! "]
	quest.349E8C0C3F9CC99B.title: "&l&dPrincessStellar"
	quest.34AA079FFAFC64BD.quest_desc: ["O passo final da linha de processamento de minério do &bIndustrial Foregoing&r, a Máquina de Peneiramento de Fluido. Isso usará areia para filtrar a parte útil da Carne de Minério Fermentada, nos dando um pouco de pó. Faça o que quiser com esse pó. Funda-o, misture-o em uma liga."]
	quest.34AA079FFAFC64BD.quest_subtitle: "Processamento de Minério: Passo 3"
	quest.34ABEF75AE1E5A0F.quest_desc: ["O Cajado do Conhecimento Ancestral usa Aura para destacar &5Ancient Debris&r próximos."]
	quest.34ABEF75AE1E5A0F.quest_subtitle: "Localizador de Netherite"
	quest.34B53B764112A1BF.quest_desc: [
		"Aumento de nível para 63."
		""
		"Pode ser encontrado aleatoriamente em &9Ginásios&r que geram em &a#minecraft:village&r"
	]
	quest.34B53B764112A1BF.title: "&aLíder Sabrina"
	quest.34CD54347E9821B5.quest_desc: ["Depois de criar seu primeiro Modelo de Dados, você precisará subir o nível dele para que seja útil.\\n\\nOs Modelos de Dados começam no primeiro tier: &7Defeituoso&r. Você precisará, no mínimo, nivelá-lo para &aBásico&r se quiser executar algumas simulações nele!\\n\\nUma vez colocado dentro do Deep Learner, o HUD informará quantas mortes são necessárias para subir de nível. Você também pode ver essa informação na dica de ferramenta do próprio Modelo."]
	quest.34CD54347E9821B5.title: "Subindo o Nível dos Modelos de Dados"
	quest.34CFE1439262AA72.quest_desc: [
		"&5&lMekanism&r é um Mod de Tecnologia enorme e popular, então é claro que tem &lLogística&r com ele."
		""
		"As diferentes Máquinas são exigentes com as Configurações e precisarão ser alteradas em sua INTERFACE para mover itens corretamente. Então você pode usar os &5&lCanos Meka&r para mover o que precisar!"
		""
		"Mas espere, não é só para o &5&lMekanism&r que eles funcionam! Eles funcionam para muitas outras máquinas também! Só precisam ser configurados com uma Chave Inglesa para Empurrar e Puxar."
		""
		"(Eles podem causar um pouco de lag quando usados em massa, então tome cuidado com eles)."
	]
	quest.34CFE1439262AA72.title: "&5&lMekanism"
	quest.34D09336FA3E272A.quest_desc: ["A Torreta Lança-chamas Química tem exatamente a mesma mira que a Torreta de Arma, então confira lá para mais informações! \\n\\nAssim como a Torreta de Arma, a Torreta Lança-chamas Química precisa de &cEnergia&r de suas portas. Mas também precisará de &bFluidos&r canalizados para dentro para armazenar e atirar. &9Insira &bFluidos&r com Canos, pois você não pode usar &bBaldes&r para enchê-la, apenas &bCanos&r. \\n\\nA Torreta Lança-chamas Química tem um armazenamento de 4.000mB ou 4 &bBaldes&r. Você também pode pressionar um Botão para Incendiar os &bFluidos&r que são lançados. Isso incendiará &bFluidos&r inflamáveis!"]
	quest.34D14B807A2DAC0F.quest_desc: ["Você acha que o &5&lMekanism&r e o &l&7Modern Industrialization&r podem ter toda a diversão? \\n\\nEsta &5Armadura Quântica&r tem status padrão semelhantes à &cArmadura de Netherita&r, mas, como o &aMeka-Traje&r, pode usar Energia como um escudo. \\nTambém possui melhorias que podem ser instaladas para torná-lo ainda mais poderoso! Como Voo, Visão Noturna e até a capacidade de recarregar. \\n\\nMas a melhor parte é que ela pode ser vinculada ao seu Sistema de Armazenamento! Então, você pode retirar energia automaticamente dele e retirar qualquer Item dele, não importa onde você esteja. "]
	quest.34D14B807A2DAC0F.quest_subtitle: "Tanta Energia quanto você puder fornecer"
	quest.34D14B807A2DAC0F.title: "&5Armadura Quântica&r (&l&bAE2&r)"
	quest.34D3F6D54F5B26C2.quest_desc: ["Uma enxada aprimorada, seria então uma dama fina e simpática?"]
	quest.34D3F6D54F5B26C2.title: "Enxada Dracônica"
	quest.34F7325C2AFA6DA7.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2colaborador da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodososDireitosReservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, está no modo de edição."]
	quest.34FBD04361657724.quest_desc: [
		"Ao longo do ExtendedAE, você usará frequentemente &aCristais Entro &rcomo um recurso."
		""
		"Para obter o &aCristal Entro&r, você precisará de um Bloco de Fluix e uma Semente Entro. Clique com o botão direito do mouse no Bloco de Fluix que contém a Semente Entro."
		""
		"Isso criará o &aFluix Entroizado em Drusa&r, que, semelhante ao Quartzo de Certus em Drusa, fará crescer Cristais Entro ao seu redor. Diferente do Certus, sua decomposição é inevitável."
		""
		"O &aFluix Entroizado em Drusa&r sempre dropará &um &r&aPó Entro&r ao ser quebrado, independentemente do estado em que se encontra. Cristais Entro droparão Fragmentos Entro quando não estiverem totalmente crescidos."
	]
	quest.34FBD04361657724.quest_subtitle: "não confundir com cristais do tempo"
	quest.34FBD04361657724.title: "Os Cristais do Espaço e do Tempo: Cristais Entro"
	quest.351159C55159C316.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_spire.png width:100 height:150 align:center}"]
	quest.351159C55159C316.quest_subtitle: "Cidade do End e Navios do End"
	quest.351159C55159C316.title: "Ornamento de Armadura de Agulha"
	quest.3512A883CD4E007C.quest_subtitle: "Pinho Touro + Pinho"
	quest.3512F47DADC07EAE.quest_desc: ["&5Armadura de Unobtainium&r mas com bônus para Feitiços de &d&lArs Nouveau&r!"]
	quest.3512F47DADC07EAE.quest_subtitle: "40"
	quest.3512F47DADC07EAE.title: "&5Equipamento Arcanista de Unobtainium"
	quest.3514E9C1A8C7400C.quest_subtitle: "Nível: &b2"
	quest.3514E9C1A8C7400C.title: "&bChassi de Máquina Simples"
	quest.351769579833FA9E.title: "Relaxando com os parças abelhas"
	quest.351CFE6AD802F065.quest_desc: ["&nForte&r \\n\\n&4Lutador&r \\n&5Veneno&r \\n\\n&nVulnerável&r \\n\\n&aInseto&r \\n&8Sombrio&r \\n&5Fantasma&r"]
	quest.351CFE6AD802F065.title: "&dPsíquico"
	quest.3525D5DCC3A534D9.quest_desc: ["Estas são uma das minhas favoritas! \\n\\nAs &9Garras de Escavação&r irão 1. Aumentar sua Velocidade de Mineração, então basicamente um nível de Eficiência em todas as Picaretas, e 2. Fazer seus Punhos agirem como uma Picareta de Pedra! \\n\\nSuper útil para construir e apenas jogar em geral!"]
	quest.3525D5DCC3A534D9.quest_subtitle: "Mãos"
	quest.3525D5DCC3A534D9.title: "&9Garras de Escavação&r"
	quest.3526D444F81AD6D9.quest_desc: ["A &dMeka-Tool&r já causa mais Dano que uma &6Espada de AllTheModium&r, mas por que não um pouco mais! \\n\\nNão sei dizer quanto mais cada &7Unidade&r concede, mas o dano definitivamente aumenta quanto mais você adiciona. \\n\\nAssim como Afiação!"]
	quest.3526D444F81AD6D9.quest_subtitle: "Você é forte!?"
	quest.3526D444F81AD6D9.title: "&4Unidade de Amplificação de Ataque"
	quest.352A226915809E1B.quest_desc: ["O &#A57DE3Empacotador&r agora permitirá combinar &#7DD2E3Aço Inoxidável&r, &#B37DE3Tungstênio&r e &#E37DDBBarra de Titânio&r em uma nova &#3946E3Barra Mista à Prova de Explosão&r. "]
	quest.353AEEC116A5DEEF.quest_desc: [
		"Mares Ancestrais são Mares abertos no &2&lUndergarden&r. \\n\\nDe alguma forma, mesmo com a quantidade de poluentes, a Água é segura para beber. \\n\\nA Água também abriga &bGwibs&r e &bGwiblings&r. E não podemos esquecer do Glitterkelp!"
		"{image:atm:textures/questpics/undergarden/undergarden_ancient.png width:200 height:100 align:center}"
	]
	quest.353AEEC116A5DEEF.title: "Mar Ancestral"
	quest.354086C858E10154.quest_desc: [
		"Agora que temos um pouco de Cianita do nosso reator bebê, vamos querer uma maneira de reprocessar esse resíduo em algo útil."
		""
		"Para fazer isso, precisaremos construir outro multibloco: o &aReprocessador&r."
		""
		"Isso leva muita Cianita, então comece a estocar! Você também pode querer atualizar para um reator maior. "
	]
	quest.354086C858E10154.title: "Reprocessando nosso Resíduo"
	quest.3543563DF036D461.quest_desc: ["Para criar o Pó de Dragonyst, você precisará realizar a &9Torre Invertida de Uphyxes&r. No entanto, para criar o Giz Magenta, você também precisará de alguns materiais que só pode obter através do &9Marid Triturador&r."]
	quest.3543563DF036D461.title: "&#AD00C8Giz Magenta"
	quest.356102D5B5F3CA1E.quest_desc: ["Uma Liga adicionada por &6&lForbidden \\& Arcanus&r é a &5Obsidiansteel&r. \\n\\nEla é criada no &l&bClibano&r, combinando Ferro Bruto e &5Obsidiana&r. \\n\\nVocê precisará de uma Relíquia de Artesão para realmente fazer a Liga! \\n\\nAlém disso, você obterá &6Cobre&r como resíduo, o que provavelmente não deveria acontecer..."]
	quest.356102D5B5F3CA1E.title: "&5Obsidiansteel&r"
	quest.3561A33758A1E8C3.quest_desc: [
		"Primeiro, nós construímos. Segundo, nós iniciamos. Terceiro, nós usamos. \\n\\nTodos os lados do &c&lReator de Fusão&r usam um formato de diamante de 5 Blocos de comprimento. A estrutura será feita de &cCarcaça do Reator de Fusão&r e o interior pode ser feito de Vidro do Reator&r. \\n\\nAs &cPortas do Reator de Fusão&r podem substituir qualquer Bloco de Vidro do Reator na Estrutura (exceto onde outros Blocos são necessários) \\n\\nA &cMatriz Focal do Laser&r também será colocada onde fica o Vidro do Reator. Esperançosamente, não muito perto de outros Blocos! \\n\\nO &cControlador do Reator de Fusão&r, o Bloco mais importante, será colocado no centro do quadrado da camada superior. \\n\\nNão se preocupe, o interior será oco... Não recomendo verificar se está quando estiver ligado, isso vai te matar. "
		"{@pagebreak}"
		"BOOM! Está construído! Agora, como fazemos esta máquina funcionar? \\n\\nPrimeiro, pegue seu &eHohlraum&r, que deve estar preenchido! E coloque-o dentro da INTERFACE do &c&lReator de Fusão&r. \\n\\nPodemos abrir sua INTERFACE Clicando com o Botão Direito no &cControlador&r de um reator totalmente construído. \\n\\nAgora, junto com o &eHohlraum&r preenchido, precisaremos colocar um pouco de Combustível! \\n\\nEntão, podemos disparar o &4Amplificador Laser&r com pelo menos 1 GFE na &cMatriz Focal do Laser&r. \\n\\nAgora está pronto para uso! "
		"{@pagebreak}"
		"A maior parte do uso é através do &cControlador&r. Primeiro, temos o menu principal. Isto é apenas para o slot do &eHohlraum&r e para dizer se ele está construído corretamente! \\n\\nEm seguida, o menu de Calor. Isto é para quão quente está a &6Temperatura&r do &c&lReator de Fusão&r. Isso determina a quantidade de &aEnergia&r ou Vapor que é criada! E é determinado pelo &4Amplificador Laser&r que dispara nele, e se ele é resfriado. \\n\\nPodemos mudar as Unidades de &6Temperatura&r ou mesmo de &aEnergia&r com os Botões inferiores! \\n\\nO próximo menu é para o Combustível! Ele mostrará quanto &cDeutério&r, &aTrítio&r e &5Combustível D-T&r está dentro do &c&lReator de Fusão&r. Também podemos alterar a Taxa de Injeção, quanto Combustível é usado a cada Tick. \\n\\nO menu de Estatísticas nos mostra um monte de números chiques! Eles são importantes apenas para nerds, então não vamos focar neles!"
		"{@pagebreak}"
		"(texto de espaço reservado para nova página)"
		"{image:atm:textures/questpics/mek/mek_fusion1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_fusion2.png width:110 height:90 align:center}"
		"{image:atm:textures/questpics/mek/mek_fusion3.png width:110 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_fusion4.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_fusion5.png width:100 height:100 align:center}"
	]
	quest.3561A33758A1E8C3.quest_subtitle: "Combinando 2 Elementos em 1"
	quest.3561A33758A1E8C3.title: "&c&lReator de Fusão"
	quest.35629CB10DBDE340.quest_desc: [
		"O &6Templo Ancestral&r é a Estrutura importante e necessária encontrada dentro das &9Terras Profundas&r. \\n\\nEle parece uma Pirâmide Maia feita de &8Ardosiabissal &fe &3Sculk&r. Há toneladas de &3Sensores de Sculk &fe &3Emissores&r, bem como Baús e Vasos Ancestrais. \\n\\nNos andares mais altos, você encontrará principalmente Baús e Vasos Ancestrais, mas dentro da &6Pirâmide&r encontraremos até &eBlocos de Ouro&r e outros Materiais."
		"{image:atm:textures/questpics/deepndark/dnd_temple.png width:200 height:100 align:center}"
	]
	quest.35629CB10DBDE340.quest_subtitle: "A única estrutura"
	quest.35629CB10DBDE340.title: "&6Templos Ancestrais"
	quest.3567306F2B66BD20.quest_subtitle: "Fabricação por Infusão"
	quest.3567306F2B66BD20.title: "&fAbelha de Imperium"
	quest.35767977FB9E0B1B.quest_desc: [
		"O Nível 2 precisa de 6 Blocos de Barra de Draconium, 1 de cada lado do Núcleo. Então, obviamente, os 4 Estabilizadores para ser feito."
		"{image:atm:textures/questpics/draconic/draconic_core_2off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_2on.png width:100 height:100 align:1}"
	]
	quest.35767977FB9E0B1B.quest_subtitle: "Armazena: 273.000.000 RF"
	quest.35767977FB9E0B1B.title: "Nível 2"
	quest.357C9381A8155C08.quest_desc: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, você está no modo de edição."]
	quest.357DDE894EB512F7.quest_desc: ["A &#65C2A6Cortador de Fios&r é capaz de aplicar exatamente a quantidade certa de força para fazer &#53E67BFios&r para nós. Eletrizante!! Eu sei..."]
	quest.357DDE894EB512F7.title: "&fO &7Cortador de Fios"
	quest.35815F62705D1D53.quest_desc: ["&nVulnerável&r \\n\\n&4Lutador"]
	quest.35815F62705D1D53.title: "Normal"
	quest.358D4F507521075F.quest_desc: [
		"&eColmeia&r dentro de uma &eColmeia&r, &eColmeia&r-cepção.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_shrine.png width:200 height:100 align:center}"
	]
	quest.358D4F507521075F.title: "Templo da &eColmeia&r"
	quest.35A674E2C6F66673.title: "Módulo de Precisão de Projétil Caótico"
	quest.35A78E04092767AD.quest_desc: [
		"Melhorias Válidas:"
		"- Flecha de Poção"
		"- Explosão"
		"- Duradouro"
		"- Flecha Guiada"
	]
	quest.35ABB0DEE70DF7FD.quest_desc: ["Acredite ou não, o mod &aPowah&r tem ótimas opções para conseguir... energia.\\n\\nNão deixe de conferir o capítulo de missões do &cPowah&r para saber mais!"]
	quest.35ABB0DEE70DF7FD.title: "Mais &aPowah&r!"
	quest.35BC118040E7428F.quest_desc: [
		"Lasers Endéricos têm múltiplos usos:"
		""
		"1. Eles podem transferir energia de uma maneira muito estilosa."
		"2. Eles são usados para transformar materiais."
		"3. Eles podem quebrar blocos."
		"4. Eles aceleram o crescimento de ametista."
	]
	quest.35BC118040E7428F.quest_subtitle: "Não use perto de gatos"
	quest.35C46E6E27C9CB1A.quest_desc: ["Os 10 Troncos &2Vanilla&r são maravilhosas, mas eles só têm alguns designs! \\n\\nEntão, é claro, o &l&bChipped&r contribuiu adicionando dezenas de novos designs para essas Troncos!"]
	quest.35C46E6E27C9CB1A.title: "&fTroncos &l&bChipped&r"
	quest.35CC898E0E49FE58.quest_desc: ["&9Flux Networks&r é um mod que visa ser a solução para todas as suas necessidades de energia sem fio.\\n\\nO mod em si não tem uma maneira de gerar energia, mas pode armazenar e transmitir energia sem fio, até mesmo entre dimensões. Ele pode até carregar seus itens em seu inventário.\\n\\nVocê pode até carregar seus Jetpacks enquanto voa com este mod.\\n\\nPara começar com o mod, você precisará de um pouco de Pó de Fluxo. Vá para a Bedrock, jogue um pouco de Redstone em cima de alguma Bedrock. Coloque um pouco de Obsidiana logo acima da Redstone flutuante e clique com o botão esquerdo na Obsidiana."]
	quest.35CC898E0E49FE58.quest_subtitle: "A Solução Definitiva de Energia Sem Fio"
	quest.35CC898E0E49FE58.title: "&8Flux Networks"
	quest.35D9CD19EAADED6C.quest_desc: ["Você sabe que essa coisa de &aRadiação&r pode ser bem mortal! E todo mundo comete erros. \\n\\nMas a questão permanece, você preferiria usar o &6Traje Hazmat&r, estiloso, mas muito fraco, ou... o todo-poderoso &a&lMeka-Traje&r com a &aUnidade de Proteção Radioativa&r! \\n\\nSe todas as &a&lPeças do Meka-Traje&r tiverem a &aUnidade de Proteção Radioativa&r instalada, você poderá andar em segurança na &aRadiação&r!"]
	quest.35D9CD19EAADED6C.quest_subtitle: "Toda a Armadura"
	quest.35D9CD19EAADED6C.title: "&aUnidade de Proteção &7Radioativa"
	quest.35E399D88D2EDCB6.quest_desc: ["Com esta Melhoria, todos que te atacarem serão 1. Atordoados, o que os parará por um segundo 2. feridos e 3. destruirão quaisquer Projéteis. \\n\\nAcho que vale a pena a Melhoria!"]
	quest.35E399D88D2EDCB6.quest_subtitle: "Confronto?"
	quest.35E42F7925CA097A.quest_desc: ["&dNúcleos do Vazio&r são drops do &dGolem do Ender&r! \\n\\nEles são armas, quando você clica com o botão direito com eles, &dRunas do Vazio&r surgirão do chão. \\n\\n&dRunas do Vazio&r agem como Presas de Evocador, elas vão em linha por cerca de 10 Blocos na direção que você está usando. \\n\\nElas causam cerca de 3 corações e meio de dano cada vez que atingem um Mob. Elas também empurram Mobs, o que as Presas de Evocador não fazem. \\n\\nIsso pode ser usado em Criações para ainda mais Armas de &4&lCataclysm&r!"]
	quest.35E42F7925CA097A.title: "&dNúcleo do Vazio"
	quest.35E8F1CC0080E45E.quest_subtitle: "Alimente uma Abelha de Diamante com um Rubi"
	quest.35E8F1CC0080E45E.title: "&fAbelha de Rubi"
	quest.35EAB77C195E594E.quest_subtitle: "Alimente uma Abelha de Diamante com Ametista"
	quest.35EAB77C195E594E.title: "&fAbelha de Ametista"
	quest.35FDC436DE07635F.quest_desc: ["O &#DB62DECompressor de Implosão&r usa o poder de explosivos para combinar recursos. Ele pode ser usado para obter Barras mais eficientes de &#8762DELiga Mista à Prova de Explosão&r, além de muitos outros recursos úteis."]
	quest.35FE9C3395491433.quest_subtitle: "Pressurize o Ovo de Gerador de Abelha de Ferro"
	quest.35FE9C3395491433.title: "Abelha de Ferro Comprimido"
	quest.3601DD545E1D11B4.quest_desc: [
		"o &#DD91EDArgônio&r reagindo com &#83729EPó de Silício&r e &#AAA0BAPó Pequeno de Irídio&r nos dará &#919191Silício Monocristalino&r."
		""
		"&#AAA0BAIrídio&r é encontrado como minério no Mundo Superior."
	]
	quest.3602CA4E5D3687DF.quest_desc: ["&aPedras Brilhantes&r aparecem em Biomas de Flores e alguns Biomas de Pico."]
	quest.3602CA4E5D3687DF.title: "Encontrando &aPedras Brilhantes"
	quest.360B150190A5C894.quest_desc: [
		"Uma coisa que incomoda muitos jogadores de mods é que o &5Encantamento&r não pode ser completamente automatizado! E você não pode escolher quais &5Encantamentos&r você quer, você tem que ter Sorte! \\n\\nBem, não se preocupe, ambos os desejos foram realizados! Com o &5&lEncantador Rúnico&r. \\n\\nPara usá-lo, você não precisará tocar na &5Mesa de Encantamento&r, apenas enviar os Itens, &dFonte&r e &aFluido de XP&r corretos. \\n\\n&aFluido de XP&r precisará ser obtido engarrafando alguma forma de &aXP Líquida&r com a Máquina de Engarrafamento do &8&lImmersive Engineering&r, depois processando-o através da Máquina de Enlatamento do &7&lExtended Industrialization&r. \\n\\nVocê precisará fazer &dHálito de Dragão Infundido&r e &5Livros de Reparo&r para refazer a &6&lEstrela ATM&r!"
		"{@pagebreak}"
		"(&bCarpete Azul Claro&r é &bPrateleira Profunda Toca-Almas&r"
		"&5Carpete Roxo&r é &5Prateleira de Sculk Ecoante&r"
		"&9Carpete Azul&r é &9Prateleira de Sculk Toca-Almas&r)"
		"{image:atm:textures/questpics/chap3/creative_enchanter1.png width:125 height:100 align:center}"
		"A base do &5&lEncantador Rúnico&r está cheia de praticamente tudo! Tem &9Pedra Escura&r à vontade, Estantes, &7Blocos de Runas&r e &bBlocos de Cristal Arcano&r!"
		"{image:atm:textures/questpics/chap3/creative_enchanter2.png width:125 height:100 align:center}"
		"Continuaremos de forma semelhante, apenas substituiremos nossos &7Blocos de Runas&r e &bBlocos de Cristal Arcano&r por &6Gilded Chiseled Polished Darkstone&r e &6Pilares de Pedra Escura&r. Sim, esses quadrados engraçados e novos são os topos dos &6Pilares de Pedra Escura&r!"
		"{image:atm:textures/questpics/chap3/creative_enchanter3.png width:125 height:100 align:center}"
		"Não se preocupe, está ficando mais fácil! Mantenha mais algumas Estantes, além de adicionar &6Pedestais de Pedra Escura&r e uma &5Mesa de Encantamento&r."
		"{image:atm:textures/questpics/chap3/creative_enchanter4.png width:125 height:100 align:center}"
		"Droga, esta é ainda mais fácil! Apenas 4 &bLanternas da Alma&r em cima das últimas Estantes."
		"{image:atm:textures/questpics/chap3/creative_enchanter5.png width:125 height:100 align:center}"
		"Ok, esta é fácil demais! Apenas coloque um &7Injetor Quântico&r um Bloco acima da &5Mesa de Encantamento&r."
		"{image:atm:textures/questpics/chap3/creative_enchanter6.png width:150 height:150 align:center}"
		"{image:atm:textures/questpics/chap3/creative_enchanter7.png width:150 height:150 align:center}"
		"Provavelmente deveria ter te dito antes, mas os Alçapões ficam na parte inferior do &5&lEncantador Rúnico&r... desculpe!"
	]
	quest.360B150190A5C894.title: "&5&lEncantador Rúnico"
	quest.36149E69A8C264E4.quest_desc: ["Os &bLírios de Gelo&r são Plantas que crescem nos &9Lagos de Água&r dentro das &bCavernas Floridas&r (eu disse que tem muitas Plantas). \\n\\nHá 2 partes na Planta, o &bLírio&r e a &bFlor de Gelo&r. A &bVitória-régia&r é o que flutua na &9Água&r e permite que você ande sobre ela. A &bFlor de Gelo&r fica em cima da &bVitória-régia&r e é bonita!\\n\\nVocê precisará de Tesouras para pegá-los."]
	quest.36149E69A8C264E4.title: "&bLírios de Gelo"
	quest.361C9D90617E6D38.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_keeper.png width:100 height:150 align:center}"]
	quest.361C9D90617E6D38.quest_subtitle: "Trocado com o Gatekeeper"
	quest.361C9D90617E6D38.title: "Ornamento de Armadura de Guardião"
	quest.361CCBD353D6FF34.quest_desc: [
		"Com o &bComponente de Armazenamento de 1k&r, agora você pode criar uma &bCélulas de Armazenamento de Itens ME&r para iniciar seu sistema de armazenamento digital de itens. Você provavelmente vai querer que a maior parte do seu armazenamento seja para itens, então provavelmente vai querer fazer algumas &bCélulas de Armazenamento de Itens ME&f. "
		""
		"As &bCélulas de Armazenamento de Itens ME&r podem conter até 63 tipos diferentes de itens. Cada novo tipo de item adicionado a uma célula ocupará uma certa fração da capacidade total da célula de armazenamento em bytes. Para cada tipo já presente, 1 'byte' conta para 8 itens do mesmo tipo. "
		""
		"Como exemplo, uma &bCélulas de Armazenamento de Itens 1k&r contendo apenas pedregulho pode armazenar até 8128 pedregulhos (8*1024b - 8b/tipo * 1 tipo). "
		""
		"Se uma célula estiver vazia, ela pode ser reaproveitada desmontando-a em seu respectivo componente e invólucro. Isso é feito agachando e clicando com o botão direito no ar com a célula na mão."
	]
	quest.361CCBD353D6FF34.title: "Armazenamento de Itens"
	quest.361DFDB1E1352D6B.quest_desc: ["Encontre um pouco de Cana-de-Açúcar perto de um pouco de água."]
	quest.361DFDB1E1352D6B.title: "Açúcar, Açúcar"
	quest.3621155A4138EBCA.quest_desc: [
		"A Célula do Vazio precisa ser particionada (filtrada) em uma Bancada de Células antes do uso. Ela excluirá qualquer coisa que entre no sistema ME que corresponda ao filtro (assumindo que a célula do vazio seja priorizada), ou os condensará em Bolas de Matéria ou Singularidades, de forma semelhante ao Condensador de Matéria."
		""
		"Clique com o botão direito para abrir a GUI de configuração."
	]
	quest.3621155A4138EBCA.title: "Condensador de Matéria em uma Célula: A Célula do Vazio"
	quest.362F4CFD1B8B12B1.quest_desc: ["Todos os seres vivos morrerão em Éter como se fosse Lava. Engraçado que você pode colocá-lo em um Balde, no entanto! \\n\\nA única maneira de obtê-lo é encontrando-o no Rio de Éter. \\n\\nQuando a Água toca o Éter, formará Blocos de Thioquartz!"]
	quest.36389696767EFB4E.quest_desc: [
		"O Abismo Árido é, como o nome sugere, árido... Ele não contém nada além de Mobs Hostis e Seixos. \\n\\nPessoalmente, eu preferiria encontrar Seixos em qualquer outro lugar..."
		"{image:atm:textures/questpics/undergarden/undergarden_barren.png width:200 height:100 align:center}"
	]
	quest.36389696767EFB4E.title: "Abismo Árido"
	quest.3642AF6FE63B1C90.quest_desc: ["Vamos revisar nossa lista. \\n\\n&nPokémon segurando sua Mega Pedra&r? &aCheck&r! \\n\\n&nVocê está usando um Bracelete Mega&r? &aCheck&r! \\n\\nSe ambos estiverem marcados, em batalha, abaixo de seus movimentos, você verá um botão que diz &bMegaevoluir&r. Clique nele para ativá-lo. \\n\\nDepois, selecione um movimento e seu &cPokémon&r irá se transformar. \\n\\nCertifique-se de não estar usando um &eMovimento Z&r junto com &bMegaevoluções&r, você só pode usar 1 por vez."]
	quest.3642AF6FE63B1C90.title: "&bMegaevolução"
	quest.36541A2179A7E76B.quest_subtitle: "Alimente a Abelha de Blaze com Minério de Benitoíta"
	quest.36541A2179A7E76B.title: "&fAbelha de Benitoíte"
	quest.365D4B1DC953D406.quest_desc: ["O Dispensador de &7Carrinhos&r fará o que o nome sugere. Ele pode dispensar quaisquer &7Carrinhos&r nos &6Trilhos&r à sua frente. Precisa de um sinal de Redstone para dispensar."]
	quest.365D4B1DC953D406.title: "Dispensador de &7Carrinhos&r"
	quest.366431661CC43A6E.quest_desc: [
		"Esta Missão foi criada pela &6Equipe AllTheMods&r, ou um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods."
		"Como todos os packs &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pack público não lançado pela &6Equipe AllTheMods&r, sem permissão explícita."
		""
		""
		""
		"Esta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."
	]
	quest.366A1733E63AB3AD.quest_desc: ["Batalhando com &cPokemon&r! Ah sim, é para isso que estamos todos aqui! Finalmente... \\n\\nO Padrão para Lutar contra &4Treinadores&r ou &cPokemon&r Selvagens é (R). Então temos algumas escolhas do que fazer. \\n\\nCada Luta ocorre em Turnos, com você indo primeiro e depois eles. A cada vez, você pode escolher o que fazer. \\n\\nLutar abrirá nossos Golpes, que é o que usamos com nosso &cPokemon&r para Atacar o outro &cPokemon&r. Você pode ver o nome do Golpe, Tipo e Pontos de Ataque. Quando os Pontos de Ataque chegam a 0, você não pode usá-los. \\n\\nTrocar nos permitirá substituir nosso &cPokemon&r por um diferente da sua Equipe. Isso levará um Turno, no entanto. \\n\\nCapturar só funciona para &cPokemon&r Selvagens, confira a Missão da &cPoke&rbola para saber mais. \\n\\nCorrer e Desistir funcionam da mesma forma. Você pode sair da Batalha. Desistir fará você perder contra o &4Treinador&r assim que aceito. Correr, você precisará sair de uma certa área do &cPokemon&r para sair da Batalha. \\n\\nDentro da Batalha, você pode Pressionar o mesmo Botão que usou para entrar nela, para vagar livremente. Aqui você pode Alimentar o &cPokemon&r com Itens."]
	quest.366A1733E63AB3AD.title: "Batalhas &cPokemon&r"
	quest.367E891A50991436.quest_desc: ["Usando o &cConfinamento Permanente de Sevira&r, podemos combinar vários materiais diferentes de Wither e um pouco de Netherite para criar três Pós de Witherita. Com estes, podemos criar para nós mesmos a forma mais elevada de Giz de Fundação, o Giz Preto."]
	quest.367E891A50991436.title: "Giz Preto"
	quest.36836AD948F96B9F.quest_desc: [
		"O mais simples dos simples dos &e&lCanos&r, o &eCano de Item&r. \\n\\nEle moverá Itens de um Inventário para outro. Pode ser de um Baú para outro, de uma Fazenda para um Sistema, ou até de uma Pedreira para uma Fundição. \\n\\nMuito simples, basta conectar os &eCanos&r ao que você quer mover, e usar sua Chave Inglesa para configurar de qual lado ele Puxa. "
		"{image:atm:textures/questpics/logistics/pipez_item.png width:200 height:50 align:center}"
	]
	quest.36836AD948F96B9F.title: "&ePipez de Item"
	quest.3685B52446DEC809.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_gold.png width:100 height:150 align:center}"]
	quest.3685B52446DEC809.title: "&eOuro&r"
	quest.36926B5EBFF6E55A.quest_desc: [
		"&cMercúrio&r é um dos materiais mais importantes para a &l&6Teurgia&r! \\n\\nPara obtê-lo, precisaremos destilar um pouco no Destilador de &cMercúrio&r. Coloque Itens no Destilador e dê um pouco de Calor! \\n\\nAlguns Itens dão mais &cMercúrio&r, como Diamantes, que darão 10 &cMercúrio&r por 1 Diamante, em comparação com Pedra, que precisa de 10 Pedras para 1 &cMercúrio&r."
		"{image:atm:textures/questpics/theurgy/theurgy_distiller.png width:100 height:150 align:center}"
	]
	quest.36926B5EBFF6E55A.title: "Fazendo &cMercúrio"
	quest.3697AAF8F281B247.quest_desc: ["Este é complicado! Então ouça com atenção! \\n1º é construir o &bMotor a Vapor&r real. Os &bTanques de Fluido&r julgarão quanta &9Água&r pode ser contida nele e decidirão o Nível em que o &bMotor a Vapor&r estará. \\n\\nEntão, simplesmente anexe o &bMotor a Vapor&r ao lado dos &bTanques de Fluido&r e ele se tornará uma &bCaldeira a Vapor&r. Depois, coloque um &8Eixo&r no &bMotor a Vapor&r para obter nosso braço mecânico que nos dará &dPoder Rotacional&r dele. \\n\\n2º é uma &cFonte de Calor&r. Precisaremos de uma &cFonte de Calor&r abaixo dos &bTanques de Fluido&r para aquecer a &9Água&r. Existem algumas &cFontes de Calor&r: Fogo, Fogueira, Lava, Blocos de Magma, mas os &cBlaze Burners&r são os melhores! \\n\\nA melhor a &cFonte de Calor&r, mais Unidades de Estresse! Então alimente esses &cBlaze Burners&r com alguns &cBolos de Blaze&r e você estará arrasando! \\n\\n3º é &9Água&r. Este é o combustível do nosso &bMotor a Vapor&r, não haveria Vapor sem &9Água&r. \\n\\nComo você &bCanaliza&r a &9Água&r é sua escolha, mas para o &6&lATMons&r eu recomendo uma Pia e &9&lID&r!"]
	quest.3697AAF8F281B247.title: "&bMotor a Vapor"
	quest.369913246ECA136C.quest_desc: [
		"Dependendo se suas Chapas estão Carimbadas ou não, isso determina qual Máquina você pode usar. \\n\\nSe estiver Carimbadas, você pode usar a &6Prensa Mecânica&r para fazer as &7Bases de Bola&r. \\n\\nSe não, tente estas!"
		"{@pagebreak}"
		"A &8Linha de Montagem&r conecta diferentes Máquinas de Montagem para trabalharem juntas no processamento de Itens. \\n\\nColoque o Assembly Controller, Broca de Montagem, e as Unidades de Importação e Exportação para criar nossa Linha de Montagem. \\n\\nVocê também precisará de Baús ao lado das Unidades de Importação e Exportação para os Itens. \\n\\nQuando estiver pronto, forneça Pressão ao Controlador de Montagem e ele começará a funcionar imediatamente. "
		"{@pagebreak}"
		"A &5Forja Atômica&r é uma Máquina do &6&lOritech&r muito sofisticada. \\n\\nColoque a &5Forja&r e cerque-a com Revestimento de Máquinas. Então, Clique com o Botão Direito na &5Forja&r para montá-lo. \\n\\nA &5Forja Atômica&r não recebe &cEnergia&r de forma normal, por que? por que seria fácil? Em vez disso, você precisará de &2Lasers Endéricos&r! \\n\\nConstrua um &2Lasers Endéricos&r, energize-o e use um Designador de Alvo com Shift + Clique Direito tanto na &5Forja&r quanto no &2Laser&r para configurá-lo."
	]
	quest.369913246ECA136C.title: "Prensagem"
	quest.369D3AF332181DA8.quest_desc: ["O Ninho de Pedra pode ser colocado em qualquer bioma do Mundo Superior para atrair uma Abelha Pedreira ou uma Abelha Escavadora."]
	quest.369D3AF332181DA8.quest_subtitle: "Atrai Abelhas em qualquer Bioma do Mundo Superior"
	quest.369D3AF332181DA8.title: "&fNinho de &7Pedra"
	quest.369DADE3B3D8416F.quest_desc: ["O &aTrítio&r, infelizmente, não é tão fácil de obter quanto o &cDeutério&r... \\n\\nNós precisaremos de uma &6&lPlanta de Evaporação Térmica&r. Bem... na verdade, de 2 delas. 1 para transformar &9Água&r em &eSalmoura&r, e a outra para transformar a &eSalmoura&r em &6Lítio&r. \\n\\nBem... na verdade, &6Lítio Líquido&r, nós precisamos de &6Lítio&r no estado &cQuímico&r (gasoso). Use o &c&lCondensentrator &bRotativo&r para transformá-lo de &bLíquido&r para &cQuímico&r! \\n\\nEntão, podemos usar o &e&lAtivador de Nêutrons Solar&r para transformar o &6Lítio&r em &aTrítio&r.\\n\\nMais difícil que o &cDeutério&r, mas mais fácil que o &2Combustível Fóssil&r."]
	quest.369DADE3B3D8416F.quest_subtitle: "T"
	quest.369DADE3B3D8416F.title: "&aTrítio"
	quest.36A3ECD4F6CA2732.quest_subtitle: "&f8 &cde Dano de Ataque"
	quest.36ABE142039E712B.quest_desc: ["Este funciona como um armazenamento de energia infinito normal, só que este pode se conectar ao seu sistema! Nunca mais se preocupe se o seu Sistema tem Energia suficiente! E isso inclui a &5Armadura Quântica&r. \\n\\nVocê precisará de 4 &dCélulas Superdensas&r e uma &6&lEstrela ATM&r. Cada &dCélula Superdensa&r precisa de 8 &dCélulas Densas&r, cada &dCélula Densa&r precisa de 8 &dCélulas de Energia&r. \\n\\n256 &dCélulas de Energia&r... mais muita energia!"]
	quest.36ABE142039E712B.title: "&5&lCélula de Energia &dCriativa"
	quest.36B8B3C61E0CFAD1.quest_desc: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, você está no modo de edição."]
	quest.36B9D5A99E1AA85C.quest_subtitle: "&f8 &cde Dano de Ataque"
	quest.36BCCF7395658A5C.quest_desc: ["Os Chefes no Starlight vivem em suas estruturas. Elas não são comuns (felizmente), então você pode precisar de ajuda, também conhecida como os Olhos Rastreadores. \\n\\nOs Olhos Rastreadores funcionam como os Olhos do End, Clique com o Botão Direito com eles para lançá-los e siga-os para chegar às estruturas. \\n\\nPara definir a estrutura, você precisará de um certo Item em sua mão secundária, itens como..."]
	quest.36BCCF7395658A5C.title: "Encontrando os Chefes"
	quest.36BCE35215B2B6E9.quest_desc: ["Auto-funde itens na Mochila."]
	quest.36BCE35215B2B6E9.quest_subtitle: "Automático"
	quest.36BCE35215B2B6E9.title: "&eMelhoria de Auto-Defumação"
	quest.36CDA39C23D3AA2B.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.36CF8D1DD1EF6307.quest_subtitle: "2 Blocos Verde Claro Molhados"
	quest.36D35C35BBC0A555.quest_subtitle: "O mais eficiente"
	quest.36D72D759C4E8823.quest_desc: ["Talvez um pouco rápido demais, até."]
	quest.36D72D759C4E8823.quest_subtitle: "Máx: 1"
	quest.36DAFC3FECC67406.quest_desc: ["A melhor Bateria de Energia que o DE fornecerá."]
	quest.36DAFC3FECC67406.title: "Capacitor Caótico"
	quest.36DEA17CBB696CC7.quest_desc: ["Se você clicar com o botão direito no Plug, verá a interface da Rede Flux. No canto superior direito, clique no botão + para criar sua primeira rede. Você precisará definir uma senha para criar a rede, mas também pode definir uma cor!\\n\\nA partir daqui, você pode ir para a guia Seleção de Rede para ativar sua rede no Plug. Se o Plug estiver conectado a uma fonte de energia, agora você pode aproveitar essa energia em qualquer lugar do seu sistema usando um Ponto Flux!\\n\\nDica Profissional: Você pode criar várias redes se quiser ter diferentes fontes de energia alimentando diferentes partes de seus sistemas!"]
	quest.36DEA17CBB696CC7.quest_subtitle: "Tornando-se um Admin de Rede!"
	quest.36DED7099E80ED51.quest_desc: ["Este faz o que o nome sugere, ele coloca Blocos. \\n\\nDefina a Direção que você quer que o Bloco seja colocado, preferencialmente defina o Filtro, então jogue o Módulo e os Blocos no Roteador! Assim que a Redstone for ativada, os Blocos serão colocados!"]
	quest.36DF0D83EBC2B6A9.quest_desc: [""]
	quest.36DF0D83EBC2B6A9.quest_subtitle: "&oA falta de sabedoria é coisa do passado com isto."
	quest.36DF0D83EBC2B6A9.title: "&3&lDispositivo de Probabilidade Improvável"
	quest.36EB83BB41A9E621.quest_desc: [
		"O &b&lTanque&r é como o &l&eSilo&r, mas para &bFluidos&r! \\n\\nEle pode conter apenas 1 tipo de &bFluido&r, mas pode conter 512 Baldes desse &bFluido&r. \\n\\nVocê pode &9Inserir &bFluido&r pelo Lado Superior ou Inferior, mas só pode &6Ejetar&r pelo Lado Inferior."
		"{@pagebreak}"
		"O &b&lTanque&r é construído de forma semelhante ao &e&lSilo&r, comece com nossas Cercas Tratadas e uma única &7Chapa de Ferro&r."
		"{image:atm:textures/questpics/immersive/immersive_tank1.png width:125 height:100 align:center}"
		"Agora construímos nossos quadrados ocos de &7Chapas de Ferro&r acima de nossas Cercas, desta vez com 3 Blocos de altura."
		"{image:atm:textures/questpics/immersive/immersive_tank2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_tank3.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_tank4.png width:100 height:100 align:center}"
		"Então, cubra com um quadrado preenchido de &7Chapa de Ferro&r!"
		"{image:atm:textures/questpics/immersive/immersive_tank5.png width:100 height:100 align:center}"
		"Clique com o Botão Direito no mesmo Bloco do &e&lSilo&r para criar nosso &b&lTanque&r."
		"{image:atm:textures/questpics/immersive/immersive_tank.png width:100 height:120 align:center}"
	]
	quest.36EB83BB41A9E621.title: "&b&lTanque"
	quest.36F123B2A6B52A01.quest_desc: ["Estes podem mover mais Energia e ter mais links. O nível mais alto que os Cristais de Energia alcançam."]
	quest.36F123B2A6B52A01.title: "Cristal de Relé de Energia Dracônico"
	quest.36FB694262102CFD.quest_desc: [
		"O ExtendedAE oferece um novo tipo de célula, a Célula do Infinito."
		""
		"Essas células fornecem um suprimento ilimitado de um certo tipo de recurso, como Água, Pedregulho, Lava, etc."
	]
	quest.36FB694262102CFD.quest_subtitle: "A Pia, mas em forma de célula"
	quest.36FB694262102CFD.title: "Mais Recursos do que você jamais precisará: Células do Infinito"
	quest.37045B986619A03D.quest_subtitle: "Abelha Carpinteira Amarela + Verde"
	quest.37045B986619A03D.title: "&fAbelha Lenhadora"
	quest.3705D303CF423804.quest_desc: ["O outro lado das &aGarras Ferais&r, estas aumentam o Dano que você causa enquanto as usa."]
	quest.3705D303CF423804.quest_subtitle: "Mãos"
	quest.3705D303CF423804.title: "&eLuva de Poder&r"
	quest.3707C3EDA1C5A0B2.quest_subtitle: "Bombinha + Sol Cintilante"
	quest.3708A4780ACEB34E.quest_desc: ["Neste modpack, as missões são opcionais. Os mods não estão bloqueados atrás da conclusão de nenhuma missão!\\n\\nMuitas das linhas de missões individuais fora da linha de missão Principal servem como guias para os mods. Se você quiser seguir a progressão, certifique-se de conferir a Linha de Missões Principal!"]
	quest.371A34B297C8A8EF.quest_desc: ["PneumaticCraft é tudo sobre Pressão! Estas missões não abordarão tudo o que o mod tem, mas ainda abordarão muito! Por favor, lembre-se de verificar o JEI, ler as dicas de ferramentas e ler o PCB:R, todos eles são muito úteis.\\n\\nPara começar, você precisará criar alguns &3Barras de Ferro Comprimido&r! A maneira mais fácil de fazer isso é fazer um buraco no chão, jogar algumas Barras de Ferro (ou blocos) e depois explodi-lo com um pouco de TNT!\\n\\nAlguns podem se perder na explosão, mas é um risco que teremos que correr!"]
	quest.371A34B297C8A8EF.quest_subtitle: "O Poder do Ar"
	quest.371A34B297C8A8EF.title: "PneumaticCraft: Repressurized"
	quest.371A382CF1DDF2B2.quest_desc: ["O &bCartão de Capacidade&f permite que uma bus atualizada com ele carregue um filtro maior. As Import e Export buses atualizadas com capacity cards passam de suportar apenas um item filtrado cada para o máximo de nove slots de filtro, enquanto as Storage buses passam de 18 slots para um máximo de 63."]
	quest.371E09ED2A3F6BDC.quest_desc: ["À noite!"]
	quest.371E09ED2A3F6BDC.quest_subtitle: "Aparece em Colmeias Avançadas vazias em Lugares Escuros"
	quest.371E09ED2A3F6BDC.title: "&fAbelha Zumbi"
	quest.3722B43822F80470.quest_desc: ["Mais dano que uma Espada, mas mais lenta."]
	quest.3722B43822F80470.quest_subtitle: "Liberte Seu Samurai Interior"
	quest.372B5BF416CA83A4.quest_desc: ["&5&lMekanism&r é um dos Mods de Máquinas e Tecnologia mais populares. Francamente, tenho dificuldade em resumi-lo, pois tem tanta coisa! \\n\\nTem tanto que até tivemos que fazer 2 Páginas de Missões para ele! \\n\\nAs coisas que precisamos para a &6&lEstrela ATM&r estão na página de Reatores, mas você precisará passar pela página do Mekanism para chegar lá."]
	quest.372B5BF416CA83A4.title: "&5&lMekanism"
	quest.37355F60E45777FE.quest_desc: ["O Orbe da Profecia pode ser criado ou obtido ao vencer o Gatekeeper! \\n\\nSeu uso principal é ativar o Portal, mas haverá mais usos para ele!"]
	quest.373668AE257A7A94.quest_desc: ["Cartuchos de Alto Explosivo atirarão explosivos em seus Inimigos, explodindo tudo por perto como a TNT faria! \\n\\nProjéteis de Sopro de Dragão funcionam como chumbo grosso, mas agora os Projéteis estão em Chamas!!!!! \\n\\nCartuchos de Frasco dão Efeitos de Poção baseados na Poção usada em sua criação. \\n\\nProjéteis de Sinalizador funcionam como Fogos de Artifício em uma Besta. \\n\\nCartuchos Teleguiados mirarão no Mob mais próximo de você... esperemos que seja um Mob perigoso. \\n\\nProjéteis de Matilha são como Projéteis de chumbo grosso, mas agora os Projéteis são Cartuchos Teleguiados!"]
	quest.373668AE257A7A94.title: "Projéteis Especializados"
	quest.37367101B3DAA70F.quest_desc: ["A Abelha Mineradora Cinzenta é gerada a partir de um Ninho de Terra, Cascalho ou Areia."]
	quest.37367101B3DAA70F.quest_subtitle: "Gerada a partir de um Ninho de Terra"
	quest.37367101B3DAA70F.title: "&fAbelha Mineradora Cinzenta"
	quest.374C06B3999BB0D3.quest_desc: ["Misturar &#C2C78BFerro&r, &#EDB2EACromo&r, &#BEC9A3Níquel&r e &7Manganês&r resultará em &#ADF0EEPó de Aço Inoxidável&r."]
	quest.3751015CD5C84134.title: "&bParte de Armazenamento de Fluido de 4096B"
	quest.375F0A098589CF29.quest_desc: [
		"Usando seus Olhos Buscadores, você pode ficar confuso por que eles de repente foram para o subsolo. Isso provavelmente ocorre porque a Forja do Golem está nas profundezas do subsolo, como nos níveis Y negativos. \\n\\nHá muitas salas sinuosas, cada uma cheia de Saques, Lava e Congelamentos! A sala que estamos procurando abriga o Golem da Luz Estrelar!"
		"{image:atm:textures/questpics/eternal/starlight_golemforge.png width:200 height:100 align:center}"
	]
	quest.375F0A098589CF29.title: "Forja do Golem"
	quest.376532CD98D39781.quest_desc: ["O &a&lInfusor Químico&r pegará 2 &cQuímicos&r diferentes e... os combinará. \\n\\nIsso não é útil no início do jogo, mas mais tarde será muito importante! \\n\\nO primeiro &cQuímico&r vai na &4Barra Vermelha&r à Esquerda e o segundo &cQuímico&r vai na &6Barra Laranja&r à Direita. \\n\\nSim, o padrão em que eles estão importa. Isso eu aprendi da maneira mais difícil no &6&l9TTS&r!"]
	quest.376532CD98D39781.title: "&a&lInfusor Químico"
	quest.3765485408041FC6.quest_desc: ["Confira os Módulos para aprender mais sobre como usar e aprimorar os itens do DE! As Picaretas funcionam como uma Picareta normal de Nível 6. Elas podem minerar todos os níveis de bloco, de Pedra a Unobtainium. Os itens minerados irão automaticamente para o seu Inventário."]
	quest.3765485408041FC6.title: "Picareta Wyvern"
	quest.376D154F27A00BCD.quest_desc: ["Qual é o problema da Física e do DE em traí-los? A gravidade puxa a Flecha para baixo ao longo do tempo em que é disparada. A Compensação de Gravidade nos faz nos preocupar menos com isso."]
	quest.376D154F27A00BCD.title: "Módulo de Compensação de Gravidade de Projétil Wyvern"
	quest.377A41499D8218C9.quest_desc: [
		"O 1º &lNível de Mundo&r é o &l&9Refúgio&r! Sendo o primeiro, é o mais fácil de explorar e de obter. \\n\\nPara obtê-lo, você só precisa segurar um &eItem com Afixo&r na mão! Ele será definido automaticamente quando desbloqueado. \\n\\nO &lNível de Mundo: &9Refúgio&r tem as maiores chances para &aEquipamentos&r e &aGemas&r &8Comuns&r. Ele também pode ter itens &aIncomuns&r e, muito raramente, &9Raros&r."
		""
		"Este também é o único &lNível de Mundo&r onde &4Invasores&r não podem aparecer naturalmente."
	]
	quest.377A41499D8218C9.title: "&lNível de Mundo: &9Refúgio"
	quest.377D6CF86BC1C64F.quest_desc: ["O &8Tomos de Desmontagem&r removerá apenas metade das &5Encantamentos&r, enquanto o &8Tomos de Desmontagem Superior&r removerá todos os &5Encantamentos&r do Item! \\n\\nAmbos os &8Tomos&r quebrarão o Item em uso, no entanto. \\n\\nPara &d&lInfundir&r nosso &8Tomo de Desmontagem&r em um &8Tomo de Desmontagem Superior&r, podemos usar 3 &9Estantes de Livro de Sculk Ecoantes&r e 15 Estantes de Livros, ou 4 Blocos de Draconium."]
	quest.377D6CF86BC1C64F.quest_subtitle: "Todos os Encantamentos, quebra o Item"
	quest.377D6CF86BC1C64F.title: "&8Tomo da Desmontagem Superior"
	quest.379B33D0BCBC47AA.quest_subtitle: "Feito no Reprocessador"
	quest.379B33D0BCBC47AA.title: "&fAbelha de Magentite"
	quest.37AD651E91FE3E20.quest_subtitle: "Pomelo + Lima Chave"
	quest.37B297640F537383.quest_desc: ["O Augmento Não Sintonizado é usado em um Altar de Infusão para criar vários augmentos. Obtenha &ePressa&r, &1Visão Noturna&r, &bResistência a Dano de Queda&r, &6Resistência ao Fogo&r e muito mais com esses incríveis augmentos!"]
	quest.37B297640F537383.title: "&fAugmento Não Sintonizado"
	quest.37B805E875D82A8B.quest_subtitle: "Balsa + Teca"
	quest.37B903620493A354.quest_desc: [
		"Melhorias Válidas:"
		"- Auto Smoker"
		"- Cauterize Wounds"
		"- Drops Teleporter"
		"- Mob X-Ray"
	]
	quest.37CA6F9F0226F10E.quest_desc: ["Este bloco armazena itens para cozinhar.\\n\\nVocê também pode colocar outros itens de multibloco de cozinha nele, como torradeiras e uma Vaca em um Pote."]
	quest.37CA6F9F0226F10E.quest_subtitle: "Precisamos de mais espaço para cozinhar"
	quest.37CA6F9F0226F10E.title: "Precisa de mais espaço para cozinhar?"
	quest.37CC51B689CB8A40.quest_desc: ["Os Peitorais funcionam de forma semelhante ao Meka-Suit. Qualquer dano que seria infligido a você é anulado e, em vez disso, retirado do seu Escudo. A capacidade do Escudo é quanto Escudo você pode ter, a taxa de recarga é a rapidez com que ele enche, e o OP será usado ao recarregar."]
	quest.37CC51B689CB8A40.title: "Módulo de Capacidade de Escudo Wyvern"
	quest.37CD9BF281903F56.quest_subtitle: "Alimente uma Abelha de Cogumelo com um Cogumelo Vermelho"
	quest.37CD9BF281903F56.title: "&fAbelha de Cogumelo Vermelho"
	quest.37D4E5ACB35D8BF1.quest_desc: ["O &cJetpack&r do &5&lMekanism&r funciona de forma semelhante aos &l&7Jetpacks de Ferro&r, só que com Modos diferentes e usando Hidrogênio como Combustível em vez de &aEnergia&r! \\n\\nBasta colocar um pouco de Hidrogênio no &cJetpack&r colocando-o em uma &5Máquina&r que contenha Hidrogênio. Engraçado que o &9&lSeparador Eletrolítico&r também tem Hidrogênio quando tem &bOxigênio&r! \\n\\nDepois de colocá-lo nas Costas, você pode pressionar (G) para alternar entre os Modos. \\n\\n&aNormal&r: segure Pular para subir, você se moverá em qualquer direção com WASD, e se não pressionar nenhuma direção, subirá em linha reta. Ao soltar o botão de Pular, você Cairá. \\n\\n&bFlutuar&r: mesmos controles do Modo Normal, mas com movimento mais lento e você não Cairá ao soltar o botão de Pular. Você pode descer pressionando (Shift). \\n\\n&6Vetorial&r: não responde ao WASD e, em vez disso, move o jogador para onde estiver olhando enquanto segura Pular para subir. \\n\\n&4Desativado&r: não funciona! \\n\\nAh, e você pode melhorar o &cJetpack&r com alguns Blocos e Itens para que ele ofereça Proteção com Armadura!"]
	quest.37D4E5ACB35D8BF1.quest_subtitle: "Requer Hidrogênio para Funcionar!"
	quest.37D4E5ACB35D8BF1.title: "&cJetpack"
	quest.37E3E12CFC8DCA4F.quest_desc: ["A &2Pedra da Folha&r irá &bEvoluir&r &2Glo&5om&r para &2Vile&5plum&r, &2Weepin&5bell&r para &2Victree&5bell&r, &2Exegg&dcute&r para &2Exegg&dutor&r, e &2Nuz&9leaf&r para &2Shif&9try&r."]
	quest.37E3E12CFC8DCA4F.title: "&2Pedra da Folha"
	quest.37E4DECFB6526969.quest_desc: ["O &3Soul Render&r é criado a partir de &3Cursium&r e Black Steel. \\n\\nSendo uma arma massiva (como a maioria em &4&lCataclysm&r), tem grande Alcance e muito Dano... mas seus efeitos especiais são ainda melhores! \\n\\nVocê pode usar o Botão Direito do Mouse para ser lançado para frente com o &3Soul Render&r. Quando o fizer, &3Alabardas Fantasmas&r cairão do céu por onde você passou! Você também pode usar Shift + Botão Direito do Mouse para invocar &3Alabardas Fantasmas&r ao seu redor."]
	quest.37E4DECFB6526969.title: "&3Soul Render"
	quest.37EBB8E0D6E5F821.quest_desc: [
		"&6Hostile Neural Networks&r (HNN para abreviar) é um mod baseado em simular mortes de mobs para obter saques!\\n\\nPara fazer isso, você coletará \"dados\" sobre mobs e, em seguida, executará simulações a partir dos dados para criar seus drops!\\n"
		"{image:atm:textures/questpics/hnn.png width:150 height:150 align:center}"
	]
	quest.37EBB8E0D6E5F821.title: "&fBem-vindo ao &9Hostile Neural Networks&f!"
	quest.37F2BE3C2BAF7C2D.quest_desc: ["Tags são uma parte essencial do Minecraft. \\n\\nPara todos que não sabem, elas funcionam como uma ferramenta de organização para ajudar a escolher itens semelhantes para a mesma tarefa. Como a Mesa de Criação sendo feita com qualquer Tábua ou Árvores sendo Derrubadas mais rápido com qualquer Machado. \\n\\nPara filtrar por Tag, coloque um item e selecione a tag dos grupos. Como Minério de Ferro para Minérios."]
	quest.37F71E88EDF6BA2D.quest_desc: ["&6Metades de Bolotas&r! Que não fazem muito além de criar &bTampas&r... \\n\\nDesculpe se você estava esperando muito delas."]
	quest.37F71E88EDF6BA2D.title: "&6Metades de Bolotas"
	quest.380C4222BDD65415.quest_desc: ["Para &cDynamaxizar&r, precisamos de uma pulseira. \\n\\nUma &cPulseira Dynamax&r. \\n\\nUse-a para que possamos &cDynamaxizar&f nossos &cPokémon&r."]
	quest.380C4222BDD65415.title: "&cPulseira Dynamax"
	quest.380D3212D1CBA593.quest_desc: [
		"O &cMob Rot&r de tamanho médio, o &cRotwalker&r. \\n\\nEles têm 20 Corações. \\n\\nComo todos os &cMobs Rot&r, eles atacarão &2Stoneborns&r e &7Forgottens&r e droparão &cFragmentos Utéricos&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotwalker.png width:100 height:200 align:center}"
	]
	quest.380D3212D1CBA593.title: "&cRotwalker&r"
	quest.3813F5C1760C3A79.quest_desc: ["A presença de Piglin Bárbaro aqui pode causar controvérsia, mas eu os considero Minibosses. \\n\\nEles aparecem em Bastiões com Piglins normais, mas estes são Hostis, não Neutros. Pessoalmente, eu odeio isso, especialmente porque se você os atacar, todos os Piglins se tornarão Hostis a você. \\n\\nEles têm 50 Corações e um Machado de Ouro para te atingir. Normalmente, Machados de Ouro mal causam dano, mas quando eles o usam, é divino de alguma forma! \\n\\nEles não dropam nada e agem mais como um obstáculo para os Bastiões!"]
	quest.3813F5C1760C3A79.title: "&fMatar um &cPiglin Bárbaro"
	quest.38451B61E3FC075B.quest_desc: [
		"Espere, temos Aço novamente, isso também significa que temos nosso Coque (de Carvão) de volta? Sim! \\nPara obter Coque (de Carvão), você precisará de um Forno de Coque. Para fazer um, você precisará de 26 Tijolos de Forno de Coque e colocá-los em 3x3x3 com 1 bloco oco no centro. Você saberá que está pronto quando puder acessar a INTERFACE e for tudo uma única textura. \\n\\nColoque Carvão ou Blocos de Carvão para obter Coque (de Carvão) e Creosoto Líquido! Você sempre pode colocar qualquer tronco para obter Carvão Vegetal e Creosoto."
		"{image:atm:textures/questpics/railcraft/rail_coke.png width:100 height:100 align:center}"
	]
	quest.38451B61E3FC075B.title: "Forno de Coque"
	quest.38622692756F1F27.quest_subtitle: "Cristalina + Ender"
	quest.38622692756F1F27.title: "&fAbelha Espacial"
	quest.386ABEB4249D157D.quest_desc: ["Uma única &#919191Silício Monocristalino&r pode ser cortada em 32 &#8FA4B5Lâminas de Silício&r."]
	quest.3891F8D4201E6BFD.quest_desc: [
		"A &#EBA844Barra de Kanthal&r pode ser processado em Fio Fino, que pode ser moldado em Cabo para finalmente fabricar as &#EBA844Bobinas de Kanthal&r. "
		""
		"As &#EBA844Bobinas de Kanthal&r permitem que nosso &#816DF7Alto-forno Elétrico&r funcione a uma &#F76D6Dtemperatura&r muito mais alta, permitindo que mais receitas funcionem."
		""
		"Você deve trocar as bobinas na interface gráfica do &#816DF7Alto-forno Elétrico&r."
		""
		"{image:atm:textures/questpics/modernindustrialization/switch_to_kanthal.png width:150 height:75 align:center}"
	]
	quest.38954551309F42A7.quest_desc: ["O Sender Module MK2 funciona de forma similar ao MK1, mas com menos restrições. \\n\\nO MK2 não precisa de linha de visão direta ou de estar no mesmo eixo XYZ. \\n\\nNo entanto, ele precisará estar na mesma Dimensão, a menos que você tenha..."]
	quest.38956DC28E317DEF.quest_desc: ["O &dSímbolo do Renascimento&r é o combustível para todas as &l&9Mesas de Reforja&r. \\n\\nElas ainda precisam do outro Material e, obviamente, do Item que será alterado para funcionar... \\n\\nPelo menos eles são relativamente mais fáceis de Criar!"]
	quest.38956DC28E317DEF.title: "&dSímbolo do Renascimento"
	quest.389655CD41C7A691.quest_desc: [
		"O Nível 1 só precisa do Núcleo e de 4 Estabilizadores para ser feito."
		"{image:atm:textures/questpics/draconic/draconic_core_1off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_1on.png width:100 height:100 align:1}"
	]
	quest.389655CD41C7A691.quest_subtitle: "Armazena: 45.500.000 RF"
	quest.389655CD41C7A691.title: "Nível 1"
	quest.38A1295878B68F83.quest_desc: [
		"Não, não desse tipo."
		""
		"&cAfrit Demons&r são Demônios do &cFogo&r. Eles são Demônios mais avançados, alguns são amigos e outros... não. Tudo depende da força com que o ritual pode controlar o &cAfrit&r. "
		""
		"Como ainda não temos acesso a Red Chalk, tudo o que podemos invocar é um &9Demônio&r &9Liberto&r, o que significa que ele não pode ser controlado e será violento."
	]
	quest.38A1295878B68F83.quest_subtitle: "Demônios Quentes!"
	quest.38A1295878B68F83.title: "&6Conjuração Aberta de Kandar"
	quest.38A77DBAD24C4B53.quest_subtitle: "Tier: &63"
	quest.38AD547C36BDF4C4.title: "Módulo de Precisão de Projétil Dracônico"
	quest.38BFF6F845EA479E.quest_subtitle: "4/5"
	quest.38BFF6F845EA479E.title: "Parte inferior esquerda da &6&lEstrela ATM&r"
	quest.38C236042AB5DDB9.quest_subtitle: "Bull Pine + Silver Fir"
	quest.38C98FCB6A2D4226.quest_desc: ["A Miniatura Bobina Tesla agirá como o encantamento Espinhos. \\n\\nQualquer um que atingir você, enquanto estiver usando a &c&lMochila&r, será Eletrocutado. Causando Dano e aplicando um Efeito!"]
	quest.38CB5044AB3F859B.quest_desc: ["A &aSuper cola&r é usada para unir Blocos! Para poder movê-los com &aEngenhocas&r. \\n\\nPara &aColar&r os Blocos, Clique com o Botão Direito em dois Blocos diferentes e todos entre eles serão &aColados&r. Se você quiser &aDescolá-los&r, apenas Clique com o Botão Esquerdo neles com a &aSuper cola&r. \\n\\nExistem alguns requisitos, no entanto: cada Bloco deve estar conectado aos outros, e não na diagonal. \\n\\nVocê também pode combinar outros Blocos &aColados&r com diferentes Blocos &aColados&r. Todo mundo fica &aColado&r! \\n\\nAlém disso, isso afetará outros Blocos próximos ao que foi originalmente &aColado&r. Blocos adjacentes a Blocos &aColados&r serão movidos com eles. O mesmo acontece com Blocos que estão anexados a Blocos &aColados&r, como Tochas ou Chapas."]
	quest.38CB5044AB3F859B.title: "&aSuper cola"
	quest.38D0BBD5F699EF41.quest_desc: ["Permite que a peça da Armadura Quântica carregue a partir da energia do seu sistema ME se vinculada a um Ponto de Acesso Sem Fio. Se colocada em um Peitoral Quântico, também recarrega itens em seu inventário. Isso tem uma interação especial com o AppliedFlux, onde, se você tiver Células FE na rede, ela irá extrair energia dessas."]
	quest.38F01BAEC74D5D68.quest_desc: ["É o mesmo que o outro Preheater, eu só queria que fosse simétrico :D."]
	quest.38F4448F9603FE68.quest_subtitle: "Mais 2 passos para a grandeza"
	quest.38F9E9A830D3EA0C.quest_desc: ["Se você achou que este mod era apenas para armazenar itens, você estaria errado, também existem Fluid Gavetas!\\n\\nElas funcionam da mesma forma que as Gavetas normais, mas em vez disso armazenam fluidos."]
	quest.38FE871A5867D6F3.quest_desc: [
		"Sem Aumento de Nível."
		""
		"O Item de Assinatura é Garra Rápida."
	]
	quest.38FE871A5867D6F3.title: "&3Elite dos Quatro Penny"
	quest.39100B3867E9C01E.quest_desc: ["Os &cGêiseres Sombrios&r são Blocos que você pode encontrar dentro das &cColunas Nubladas&r. \\n\\nQuando você Anda sobre eles, eles te lançarão para o alto! Tenha cuidado, porém, você ainda sofrerá Dano de Queda. \\n\\nVocê pode pegá-los com Toque Suave."]
	quest.39100B3867E9C01E.title: "&cGêiser Sombrio"
	quest.3916B48D7F294932.quest_desc: ["O Hub Sem Fio ME é uma melhoria para o Conector Sem Fio ME. Ele agora pode se conectar a 8 Conectores ou Hubs Sem Fio diferentes. Note que o Hub só pode transferir 32 canais no total."]
	quest.3916B48D7F294932.title: "Ramos de Conexões: O Hub Sem Fio"
	quest.3917DECAEF56A06A.quest_desc: ["&fTier 2&r é o nível da picareta de pedra. É quase exclusivamente para minerar itens de Ferro."]
	quest.3917DECAEF56A06A.title: "&fNível de Coleta 2"
	quest.3924975B48F5A482.quest_desc: ["Se você prefere não levar &#27AEB9Tubos de Alma&r por aí, você pode usar o AE2. \\n\\nVocê pode colocar uma Ponto de Armazenamento ME no topo da &#27AEB9Base de Laser de Alma&r para permitir que sua rede ME acesse as &#27AEB9Almas&r dentro. Elas podem ser solicitadas para serem mantidas em Interfaces ME."]
	quest.3924975B48F5A482.title: "Energística de Alma"
	quest.392EAE8BE71510C1.quest_desc: ["A Terra Desolada do &5End&r agora tem mais 1 residente. \\n\\nO outro sendo o &dDragão do Ender&r, claro!"]
	quest.392EAE8BE71510C1.title: "&5End&r: Terra de 1 chefe solitário"
	quest.392F34FD4FCC794A.quest_desc: ["Embora possam ser caros, eles também são muito estilosos!"]
	quest.392F34FD4FCC794A.title: "Blocos de &2&lMystical Agriculture&r"
	quest.3930404D5C8B44EB.quest_desc: ["Isso é usado para criar ligas personalizadas.\\n\\nÉ também a única maneira de obter Aço Tírio!"]
	quest.3930404D5C8B44EB.quest_subtitle: "Combina Materiais"
	quest.3932FF3765BFACD3.quest_desc: [
		"O &9PC&r é uma Máquina para Armazenar &cPokemon&r. \\n\\nEle tem 30 Caixas, cada uma podendo conter 30 &cPokemon&r. Você pode Arrastar &cPokemon&r da sua Equipe para o &9PC&r ou vice-versa. \\n\\nAo passar o mouse sobre qualquer &cPokemon&r no Menu, você pode ver seu Nome, Espécie, Tipo, Natureza, Habilidade, Itens Seguráveis e Golpes. \\n\\nSe você mover um &cPokemon&r em direção à sua Equipe, haverá um Botão de Soltar. Pressione-o com um &cPokemon&r e esse &cPokemon&r será solto na Natureza! \\n\\nEntão ele não estará mais na sua &cPoke&rbola ou sendo seu &cPokemon&r."
		"{image:atm:textures/questpics/pokemon/poke_pc.png width:100 height:175 align:center}"
	]
	quest.3932FF3765BFACD3.title: "&9PC"
	quest.393DA9C9D808A851.quest_desc: ["A Chave Inglesa da &l&6Teurgia&r é a Varinha &cMercurial&r. Você pode usar Shift e Scroll para mudar seus Modos. \\n\\nVocê pode Habilitar/Desabilitar para basicamente impedir a transferência por Fios. \\n\\nVocê pode mudar o lado de onde os Itens serão Extraídos ou Inseridos. \\n\\nE você pode mudar o Canal de Frequência!"]
	quest.393DA9C9D808A851.quest_subtitle: "Pensei que este era um mod de magia..."
	quest.393DA9C9D808A851.title: "Claro que tem uma Chave Inglesa"
	quest.3940A15B6CE854D0.quest_desc: ["&nForte&r \\n\\n&6Terra&r \\n&6Pedra&r \\n&bÁgua&r \\n\\n&nVulnerável&r \\n\\n&aInseto&r \\n&cFogo&r \\n&9Voador&r \\n&bGelo&r \\n&5Veneno&r"]
	quest.3940A15B6CE854D0.title: "&2Grama"
	quest.3942B5F5FD8ADF89.quest_subtitle: "Sycamore + Breadfruit"
	quest.395668FBCB6537AF.quest_desc: [" Nas profundezas das terras implacáveis do &cNether&r, uma &6relíquia&r transforma &cdor&r em &6poder&r... o &cColar Reflexivo&r. \\n\\n Forjado por um mestre dos cristais, este colar captura a &cforça&r de &cataques&r recebidos, armazenando-a até o momento &6perfeito&r para &ccontra-atacar&r. \\n\\n- &lPossui 1 habilidade:&r \\n\\n &6Condensação de Dano&r: \\n Quando você recebe &cdano&r, há uma chance de criar uma &6orbe&r que armazena parte desse &cdano&r. Ao &catacar&r, essas &6orbes&r são &6lançadas&r em direção ao seu &2alvo&r, causando o dano armazenado a qualquer coisa com que colidirem antes de &9desaparecerem&r. \\n\\n- Uma &6relíquia&r que transforma &cdor&r em &6poder&r... e faz de cada golpe um erro que seus inimigos irão se arrepender."]
	quest.395668FBCB6537AF.quest_subtitle: "Nem toda defesa foi feita para bloquear..."
	quest.395668FBCB6537AF.title: "&9Colar Reflexivo"
	quest.39605F1FEB1A5A1C.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.39605F1FEB1A5A1C.title: "TodosOsDireitosReservados"
	quest.39647A2473F6F7D7.quest_desc: [
		"Nosso próximo passo é uma incursão nos &6Rituais de Infusão&r. Esses rituais são usados para imbuir itens com a magia de demônios."
		""
		"O primeiro tier de &6Rituais de Infusão&r é a &eCompulsão Espectral de Eziveus&r. Estaremos usando este ritual para criar vários itens que você precisará ao longo deste mod."
		""
		"Recomenda-se criar este ritual em uma área separada do seu primeiro, porque os três principais tipos de rituais se baseiam nos tiers anteriores."
	]
	quest.39647A2473F6F7D7.quest_subtitle: "Coloque um pouco de Pó de Demônio™ nisso!"
	quest.39647A2473F6F7D7.title: "&eCompulsão Espectral de Eziveus"
	quest.396CEB9D05700927.quest_desc: ["Para entrar na &l&6Bumblezone&r, você primeiro precisará de uma &eColmeia&r. &eColmeias&r normais e &eColmeias Avançadas&r, não faz diferença! \\n\\nEntão você precisará jogar uma Pérola do End nela ou ter um Pistão te empurrando para dentro! \\n\\nE você entrará na &eColmeia&r e adentrar a &l&6Bumblezone&r!"]
	quest.396CEB9D05700927.quest_subtitle: "Incrivelabelha"
	quest.396CEB9D05700927.title: "Para a &eColmeia"
	quest.396E7A2078F2CBC5.quest_subtitle: "Freixo + Mostajeiro"
	quest.3971FF7D044D1FE5.quest_desc: ["As habilidades da armadura podem ser configuradas e ativadas/desativadas no menu de configuração. Use uma ferramenta ou varinha JDT para abrir o menu e clique em sua armadura para configurar as habilidades daquela peça de armadura."]
	quest.3972EE0ECB215843.quest_desc: ["Extended e Advanced AE são addons para o Applied Energistics 2. Ambos se concentram em melhorar sua experiência, adicionando versões aprimoradas de vários dispositivos, e mais."]
	quest.3972EE0ECB215843.title: "Extended e Advanced AE"
	quest.39796D8EE440F318.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_dune.png width:100 height:150 align:center}"]
	quest.39796D8EE440F318.quest_subtitle: "Pirâmides do Deserto"
	quest.39796D8EE440F318.title: "Ornamento de Armadura de Duna"
	quest.397E11CDCB8B4DC4.quest_desc: [
		"Congelado no tempo, e congelado dentro de qualquer bioma gélido, está a Lagoa Congelada. \\n\\nDentro do &bGelo&r você encontrará &7Cascalho Suspeito&r."
		"{image:atm:textures/questpics/pokemon/find_frozen_pond.png width:200 height:100 align:center}"
	]
	quest.397E11CDCB8B4DC4.title: "Lagoa Congelada Pré-histórica"
	quest.397E2D14BDE7DED0.quest_desc: ["Todas as Abelhas darão Blocos de Favo em vez de Favos, quadruplicando efetivamente a produção!"]
	quest.397E2D14BDE7DED0.quest_subtitle: "4x Favo"
	quest.397E2D14BDE7DED0.title: "&fMelhoria de &6Blocos"
	quest.39865681B03CABAA.quest_desc: ["A água é um pouco viscosa, ou pelo menos mais densa que o ar. Por causa disso, a Mineração Subaquática é mais lenta. Você pode usar o Encantamento de Afinidade Aquática, ou usar este Módulo. A escolha é sua!"]
	quest.39865681B03CABAA.title: "Módulo de Adaptação Aquática"
	quest.3991EEEFDD263A91.quest_desc: [
		"Aranhas do Crepúsculo, como Esqueletos da Estrela Solitária, são Hostis e aparecem em qualquer lugar. \\n\\nElas têm 5 Corações e atacam te atingindo. Depois de te atingir, elas lhe darão o efeito de Brilho por alguns segundos. \\n\\nNa morte, elas droparão Linha e seus olhos!"
		"{image:atm:textures/questpics/eternal/starlight_spider.png width:100 height:100 align:center}"
	]
	quest.3991EEEFDD263A91.title: "Aranhas do Crepúsculo"
	quest.399858D28294D633.quest_subtitle: "Mandarina + Cidra"
	quest.399882F3C51DD282.quest_desc: ["Alimente uma &fAbelha Esquelética&r com uma &8Rosa do Wither&r!"]
	quest.399882F3C51DD282.quest_subtitle: "Abelhas esqueléticas têm gostos peculiares!"
	quest.399882F3C51DD282.title: "&fAbelha &8Withered"
	quest.3999AE0921641E60.quest_desc: [
		"&8Matéria Negra&r é criada derretendo Edelwood. \\n\\n&5Pó Corrupto&r é feito com &5Obsidiansteel&r e alguns Drops de Mobs. \\n\\nJogue ambos no chão juntos e um &8Buraco Negro&r aparecerá! \\n\\nO &8Buraco Negro&r anulará qualquer Item ou Projétil que se aproximar, mas o que queremos alimentá-lo é &aExperiência&r! \\n\\nQuando você o alimenta com &aEXP&r suficiente, ele devolverá um &aOrbe Xpetrificado&r."
		"{image:atm:textures/questpics/forbidden/forbidden_blackhole.png width:150 height:100 align:center}"
	]
	quest.3999AE0921641E60.title: "&8Buraco Negro"
	quest.39A0BA6E2A72A681.quest_desc: ["Misturar &#99F0F0Aço Inoxidável&r, &#ADDBDBAlumínio&r e &#E9A8F7Pó de Cromo&r nos dará &#EBA844Pó de Kanthal&r."]
	quest.39A19138C501B16F.quest_desc: ["Você pode atrair essas abelhas usando um &2Ninho de Slime&r em um bioma de &2pântano&r."]
	quest.39A19138C501B16F.quest_subtitle: "Lar, slime lar!"
	quest.39A19138C501B16F.title: "&fAbelha de &aSlime"
	quest.39A7619B4C5592BE.quest_desc: ["&bDrenos de Item&r são o que podemos usar para extrair em massa &bFluido&r de &eItens&r! \\n\\nSe uma Garrafa ou Balde for jogado em cima do &bDreno&r: seja por Correias, Calhas ou Mãos, o &bFluido&r será esvaziado no &bDreno&r. \\n\\nO &eItem&r agora vazio será então empurrado para fora do &bDreno&r na direção oposta, e o &bFluido&r ficará no &bDreno&r esperando para ser &bCanalizado&r para fora."]
	quest.39A7619B4C5592BE.title: "&bDreno de Item"
	quest.39AF9B1A996DA949.quest_desc: ["É como a Espada de Netherita, mas muito melhor e muito mais legal!"]
	quest.39AF9B1A996DA949.title: "Espada Caótica"
	quest.39B4F361EF611927.quest_desc: [""]
	quest.39B4F361EF611927.quest_subtitle: "&oPoder sobre a própria Morte."
	quest.39B4F361EF611927.title: "&l&8Bússola do Wither"
	quest.39B85DB54B1037FE.quest_desc: ["Um pouco mais rápida que uma Espada, mas com dano menor."]
	quest.39B85DB54B1037FE.quest_subtitle: "Espada Grossa"
	quest.39BED5DD9D24F98E.quest_desc: ["A &3Bola de Lama de Sculk&r é a versão de Argila do &3&lDeeper and Darker&r! \\n\\nVocê pode encontrá-la em alguns Biomas e, ao minerá-la, obterá &3Bola de Lama de Sculk&r. \\n\\nEstas podem ser transformadas de volta em &3Bola de Lama de Sculk&r ou em &3Tijolos de Fuligem&r."]
	quest.39BED5DD9D24F98E.title: "&3Bola de Lama de Sculk"
	quest.39C8E1705EF1CD31.title: "&eParte de Armazenamento de Fluido de 256B"
	quest.39DAC0592300992A.quest_desc: ["&9Projetos de Moldes para Prensa de Metal&r podem ser Criados. \\n\\nO &7&lMultibloco de Prensa de Metal&r automatizará a criação de &7Chapas de Metal&r e &eItens&r. \\n\\nPara prensar os &7Metais&r, precisaremos de Moldes. \\n\\nPara fazer os Moldes, precisaremos desses &9Projetos&r!"]
	quest.39DAC0592300992A.title: "&9Projetos de Moldes para Prensa de Metal "
	quest.39E4FD684972B543.quest_desc: ["Há algumas coisas que você precisa completar para &bEvoluir&r um &cPokémon&r... então é bem difícil &bEvoluir&r um acidentalmente... \\n\\nMas eu acho que se você quiser &bRegredir&r seu &cPokémon&r, apenas dê a ele este Item! \\n\\nNão, não funciona em &cPokémon&r de primeira &bEvolução&r para encontrar &bEvoluções&r negativas."]
	quest.39E822440E7D2E04.quest_desc: ["O Mob Grinding Utils é focado em Fazendas de Criaturas, então é claro que ele tem um Gerador! O Entity Spawner! Ele precisará de 3 coisas para funcionar: um Ovo Gerador, Doces de Gelatina de XP e um sinal de Redstone. Doces de Gelatina de XP são feitos processando XP através de um XP Solidifier com o Molde de Doces de Gelatina de XP. Eles podem ser comidos ou usados como Combustível no segundo slot. Assim que tiver o Ovo Gerador no slot superior, Doces de Gelatina de XP no segundo e um sinal de Redstone, ele começará a gerar as criaturas!"]
	quest.39E822440E7D2E04.quest_subtitle: "Gerador do Mob Grinding Utils"
	quest.39F142224D5210A9.quest_desc: ["&3Biodiesel&r pode ser usado para fazer &3Lubrificante&r e &3Plástico Derretido&r."]
	quest.39F142224D5210A9.quest_subtitle: "Bio/Diesel"
	quest.39F142224D5210A9.title: "Biodiesel"
	quest.39F9C825B03DA317.quest_desc: ["A &8Aerial Interface&r funciona como um elo entre seu próprio armazenamento interno e seu Inventário. Basicamente, o que entra nela, vai para você. \\n\\nVocê precisará de uma linha de montagem inteira para criá-la, as Missões devem te ajudar!"]
	quest.39F9C825B03DA317.title: "&8Aerial Interface"
	quest.3A03852E282DAA4D.quest_desc: ["O &#ED8055Eletrolisador&r é capaz de fornecer pulsos de energia suficientes para que o material se quebre em recursos mais fundamentais."]
	quest.3A03852E282DAA4D.title: "&5Eletrolisador"
	quest.3A0C8BCE197A448B.quest_desc: ["O &#827AFFEstireno-Butadieno&r pode ser misturado com &#9683F7Pó Pequeno de Chumbo&r ou &#FEA8FFPó Pequeno de Cromo&r para obter &#A1A1A1Borracha de Estireno-Butadieno&r."]
	quest.3A12B03FE9C9D925.quest_desc: ["Finalmente você está cara a cara com a &5Campeã&f, &5Cynthia&r! \\n\\nSe você derrotá-la, seu Limite de Nível subirá para 69. \\n\\nSeu Item de Assinatura é uma &3Escama de Prisma&r."]
	quest.3A12B03FE9C9D925.title: "&5Campeã Cynthia"
	quest.3A1D07AED2A841E4.quest_desc: ["Derrete itens automaticamente na Mochila."]
	quest.3A1D07AED2A841E4.quest_subtitle: "Automático"
	quest.3A1D07AED2A841E4.title: "&eAprimoramento de Auto-Fusão"
	quest.3A2047CC0F59C6CC.quest_desc: ["Armadura de fim de jogo para o &a&lRoots Classic&r"]
	quest.3A2047CC0F59C6CC.quest_subtitle: "17"
	quest.3A2047CC0F59C6CC.title: "&aEquipamento de Wildwood"
	quest.3A2249D94C019F0E.quest_subtitle: "Tília Prateada + Cereja"
	quest.3A471716A29F5172.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Fornece ao jogador uma Élitros. Note que a Élitros fornecida por este aprimoramento é afetada pelos Melhorias de Velocidade de Caminhada e Corrida."
	]
	quest.3A4A8EAA3022C7BA.quest_desc: ["As Rodas d'Água são uma das Máquinas que podemos usar para o Kinetic Dynamo. \\n\\nElas são muito mais compactas, mas também mais caras, em comparação com o Moinho de Vento. \\n\\nPara usá-las, você precisará de &9Água&r fluindo sobre a Roda d'Água. Quanto mais &9Água&r ao redor, mais rápido ela irá. Apenas certifique-se de que a &9Água&r não esteja fluindo em 2 direções diferentes! \\n\\nSer mais compacta significa que podemos colocar 3 Rodas d'Água em 1 Kinetic Dynamo para obter ainda mais Energia."]
	quest.3A4C17878FC8315B.quest_desc: ["A &6Allthemodium Furnace&r é praticamente a mesma coisa que a Fornalha de Netherita. Você precisará dela para criar a &3Vibranium Furnace&r."]
	quest.3A4C17878FC8315B.title: "&6Allthemodium Furnace"
	quest.3A4C62865C7CC862.quest_desc: ["Os &bTanques de Fluido&r podem conter &bFluidos&r. Como Baús, mas para &9Água&r e coisas do tipo! \\n\\nVocê só pode inserir &bFluidos&r com Baldes, mas com &bCanos&r você pode inserir e extrair &bFluidos&r deles. \\n\\nCada &bTanque de Fluido&r pode conter 8 Baldes ou 8000mB de &bFluido&r. Mas esse número aumentará quando os combinarmos! \\n\\nSim, você ouviu direito! Podemos colocar vários &bTanques de Fluido&r um ao lado do outro para conectar seus inventários. Eles se empilharão quando colocados um sobre o outro até 32, ou em 2x2 ou 3x3."]
	quest.3A4C62865C7CC862.title: "&bTanques de Fluido"
	quest.3A7120AD61BC6D74.quest_desc: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, você está no modo de edição."]
	quest.3A79E24283523E58.quest_subtitle: "Pinheiro + Bétula"
	quest.3A9AC6AB4407DC32.quest_desc: ["Embora nem toda receita exija os mesmos componentes, você pode configurar suas &3Linhas de Montagem&r com tudo instalado. Uma configuração simples de &3Linha de Montagem&r que pode ser usada para tudo é mostrada na imagem abaixo. Leia as missões de cada componente para obter informações importantes sobre eles.\\n\\nOs Aprimoramentos de Velocidade tornam isso muito mais rápido!"]
	quest.3A9AC6AB4407DC32.quest_subtitle: "Requer Montagem"
	quest.3A9AC6AB4407DC32.title: "Usando as Linhas de Montagem"
	quest.3AA4D1B60E4E71A5.quest_desc: [
		"Todos os &cMultiblocos&r são definidos pelas &eEscotilhas&r instalados neles. "
		""
		"Atualizar essas &eEscotilhas&r nos &cMultiblocos&r atualizará a máquina como um todo."
	]
	quest.3AA4D1B60E4E71A5.title: "&fNíveis dos Multiblocos"
	quest.3AA836E8EDB52097.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_lapis.png width:100 height:150 align:center}"]
	quest.3AA836E8EDB52097.title: "&9Lápis-lazúli&r"
	quest.3AAB71E9BDFD4C1E.quest_desc: ["Sem pressão! Bem, na verdade, você precisará de muita Pressão ao usar o &4&lPneumaticCraft&r. \\n\\nÉ meio que sobre isso que ele se trata..."]
	quest.3AAB71E9BDFD4C1E.title: "&4&lPneumaticCraft"
	quest.3AB0822F02350DA3.quest_subtitle: "Dano Infinito"
	quest.3ABE7074E500494D.quest_desc: ["O &7Aço&r é usado na maioria das Máquinas do &5&lMekanism&r... além da Armadura, o que é bom!"]
	quest.3ABE7074E500494D.quest_subtitle: "20"
	quest.3ABE7074E500494D.title: "&7Armadura de Aço"
	quest.3AC03D1FA5C341A7.quest_desc: ["O Recristalizador permite que você combine diferentes cristais para criar novos cristais a serem usados na fabricação de armas, ferramentas e armaduras."]
	quest.3ACC27B786CDCF22.quest_desc: ["Um &#3ABEC7Compressor Elétrico&r permite transformar &#CE5ADBPó Pequeno de Tungstênio&r em &#AF22BFPepitas de Tungstênio&r."]
	quest.3ACC787A0ED75A11.quest_desc: ["A &aPedra Brilhante&r irá &bEvoluir&r &2Rose&5lia&r para &2Rose&5rade&r e &dFloette&r para &dFlorges&r."]
	quest.3ACC787A0ED75A11.title: "&aPedra Brilhante"
	quest.3AD4367855B3E595.quest_subtitle: "Tier: &b4"
	quest.3ADC0CBB059FF927.quest_desc: ["Para usar isto: 1. Tenha em sua mão secundária 2. Esteja de dia 3. Esteja exposto ao céu. \\n\\nEntão você receberá Regeneração, Saturação, Velocidade, Pressa e Resistência. Também reparará a durabilidade da sua Armadura. \\n\\nUma vez usado, terá um tempo de recarga de 10 minutos."]
	quest.3ADC0CBB059FF927.title: "&eEssência do Esplendor"
	quest.3AE0198177A8E91B.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_coast.png width:100 height:150 align:center}"]
	quest.3AE0198177A8E91B.quest_subtitle: "Shipwrecks e Tesouros Enterrados"
	quest.3AE0198177A8E91B.title: "Forro de Armadura Costa"
	quest.3AE1811C32B94A66.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Apaga o fogo do jogador se ele estiver em chamas, possui um tempo de recarga."
	]
	quest.3AF1DC02E9A0010C.quest_desc: ["Os &cTubos Pressurizados&r movem praticamente tudo que os outros Canos não conseguem mover! &cQuímicos&f, &cPigmentos&f, e &cTipos de Infusão&r são todos movidos com &cTubos Pressurizados&r. \\n\\nNo entanto, para mover &cQuímicos&r para as &5Máquinas&r, precisaremos alterar as Configurações dentro da &5Máquina&r. Elas estão no canto superior esquerdo da INTERFACE da Máquina, em Configurações de Lado. Precisam ser definidas como Ejetar Automaticamente para a Saída! \\n\\nVocê pode criá-los com 2 &8Barras de Aço&r e um pedaço de Vidro, qualquer Vidro! Depois, aprimorá-los com 8 &cTubos&r e um Circuito de Controle. \\n\\n&a&lBásico&r: comporta 4 Baldes de químicos e move 750mB de químicos por Tick. \\n&c&lAvançado&r: comporta 16 Baldes de químicos e move 2 Baldes de químicos por Tick. \\n\\n&b&lElite&r: comporta 256 Baldes de químicos e move 64 Baldes por Tick. \\n\\n&d&lUltimate&r: comporta 1.024 Baldes e move 256 Baldes por Tick."]
	quest.3AF1DC02E9A0010C.quest_subtitle: "Químicos, Pigmentos, Tipos de Infusão"
	quest.3AF1DC02E9A0010C.title: "&cTubos Pressurizados"
	quest.3AF2BC9A0E298882.quest_desc: ["Com nossas &8Ligas de Andesito&r, agora podemos fazer o &8Invólucro de Andesito&r. \\n\\nPegue um pouco de Madeira, descasque-a com um Machado e clique com o botão direito na Madeira Descascada com a &8Liga de Andesito&r. \\n\\nIsso nos dará nosso &8Invólucro de Andesito&r! \\n\\nO &8Invólucro de Andesito&r será necessário para muitas, muitas, muitas &6Máquinas&r! E fica bom para decoração."]
	quest.3AF2BC9A0E298882.title: "&6&lMáquinas"
	quest.3AF30E1EC163E2E3.quest_subtitle: "Alimente uma Abelha de Diamante com uma Safira"
	quest.3AF30E1EC163E2E3.title: "&fAbelha de Safira"
	quest.3AF7446592D19FA6.quest_desc: ["O &eRegalium&r é o equivalente da Esmeralda no &2&lUndergarden&r. \\n\\nNão pode ser transformado em Armadura ou Ferramentas, mas pode ser usado para trocar com os &2Stoneborns&r por outros Itens."]
	quest.3AF7446592D19FA6.title: "&eRegalium&r"
	quest.3AFDE3396861A944.quest_desc: ["O Aplicador de Encantamentos é uma Bigorna automatizada. Ele pode aplicar Livros Encantados ao equipamento automaticamente. Usa &aEssência&r no lugar de &aExperiência&r. Esta máquina pode usar fluidos de tanques diretamente acima dela, para permitir um potencial aumentado para encantar equipamentos."]
	quest.3B04DBF92FDF859F.quest_desc: ["Ótimo trabalho! Você levou seu &cPokémon&r (&bEvolução de Tier 1&r) ao Nível 15! \\n\\nPor que não podemos &bEvoluí-los&r ainda? \\n\\nGraças aos &4&lTreinadores Radicais&r, precisaremos Vencer um certo &4Treinador&r em Batalha para desbloquear nosso Nível Máximo. \\n\\nObtenha um &4Cartão de Treinador&r e encontre um &4Associado de Treinador&r (Eu os encontrei principalmente em Vilas!)"]
	quest.3B04DBF92FDF859F.title: "Níveis Máximos"
	quest.3B062B9EC2CEF592.quest_desc: ["O &4Exportador Mega&r tem 54 espaços para filtros, funciona 8x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.3B062B9EC2CEF592.title: "&4Exportador Mega"
	quest.3B1CDC2DD05CAE80.quest_desc: ["O &#F36EF5Policloreto de Vinila&r com &#6EBAF5Chapa de Platina&r, &#C4C362Bateria de Cádmio&r, &#F7BB57Cabo de Cobre Recozido&r e &#57BFF7Placa de Circuito Digital&r nos dará &#EBE56EPlaca de Unidade de Processamento&r."]
	quest.3B3B38B17CF5D81C.quest_desc: ["Os &ePackage Frogports&r são &6Máquinas&r adoráveis e úteis usadas para misturar &ePacotes&f e &8Correias de Corrente&r! \\n\\nPrimeiro, clique com o botão direito em uma parte da &8Corrente&f em uma &8Correia de Corrente&r com o &eFrogport&r na mão, isso definirá o destino do &eFrogport&r. \\n\\nDepois, quando colocado, podemos mexer em sua GUI. Aqui podemos mudar o nome do seu Endereço, determinar se ele pega e entrega &ePacotes&r ou apenas entrega &ePacotes&r. \\n\\nEles têm 18 Slots para armazenar &ePacotes&r para movimentação. \\n\\nSe o Endereço do &ePacote&r não corresponder ao Endereço que você deu ao &eFrogport&f, o &eFrogport&r enviará o &ePacote&r para a &8Correia de Corrente&r. \\n\\nSe corresponder ao Endereço, o &ePacote&r será levado para dentro do &eFrogport&r. Se não houver Endereço correspondente, o &ePacote&r ficará girando em círculos! \\n\\n&ePacotes&r também podem ser enviados e retirados automaticamente dos &eFrogports&r com &eFunis&f e &eEsteiras&r."]
	quest.3B3B38B17CF5D81C.title: "&ePackage Frogport"
	quest.3B3BD39BA02DCA13.quest_desc: ["Com o &6Pistão de Bolso&r, seus Ataques atingirão seus Inimigos muito mais longe! \\n\\nQual será que vence, &6Pistão de Bolso&r ou &7Botas Firmes&r?"]
	quest.3B3BD39BA02DCA13.quest_subtitle: "Mãos"
	quest.3B3BD39BA02DCA13.title: "&6Pistão de Bolso&r"
	quest.3B3E3D81843BB358.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Aumenta a velocidade de corrida."
	]
	quest.3B3F1DE1AF6EBC1E.quest_subtitle: "+10 de Força"
	quest.3B42CCC19D23EC6D.quest_desc: ["O segundo tier de Componente de Armazenamento, fornecendo &e4096&f bytes de armazenamento."]
	quest.3B42CCC19D23EC6D.quest_subtitle: "x4"
	quest.3B42CCC19D23EC6D.title: "&eComponente de Armazenamento de 4k"
	quest.3B4511E7DC788AB3.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_tenacious.png width:100 height:150 align:center}"]
	quest.3B4511E7DC788AB3.title: "&dPétala Tenaz&r"
	quest.3B4BF42C55C8BBBF.quest_desc: ["Você não odeia quando está quebrando algo e os Blocos caem fora do seu alcance! \\n\\nBem, não se preocupe mais, pois temos &4Ímãs&r! Simplesmente clique com o botão direito segurando o &4Ímã&r para ligá-lo. Então, todos os Itens e Blocos dropados em um raio de 5 Blocos virão até você. \\n\\nVocê também pode equipar o &4Ímã&r nos seus Curios para continuar usando-o! \\n\\nSe não desejar continuar usando o &4Ímã&r (acho que isso acontece perto de fazendas de Mobs), basta clicar com o botão direito novamente para desativá-lo. \\n\\nEle também pode ser aprimorado para aumentar o alcance!"]
	quest.3B4BF42C55C8BBBF.title: "&l&9Ímãs &4Simples"
	quest.3B4CEE8A8CE0D6CB.quest_desc: [
		"Quase lá! Nível 7. 210 Barras de Draconium e 328 Blocos de Redstone!"
		"{image:atm:textures/questpics/draconic/draconic_core_7off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_7on.png width:100 height:100 align:1}"
	]
	quest.3B4CEE8A8CE0D6CB.quest_subtitle: "Armazena: 2.140.000.000.000 RF"
	quest.3B4CEE8A8CE0D6CB.title: "Nível 7"
	quest.3B5095CEDD9FB323.quest_subtitle: "Feito com Energizador"
	quest.3B5095CEDD9FB323.title: "&fAbelha de Aço Energizado"
	quest.3B542DC05240242C.quest_subtitle: "&f6 &cde Dano de Ataque"
	quest.3B5578F000D6AD9E.quest_desc: ["Combine qualquer Vara de Pesca com o &bModelo de Aprimoramento de PokeVara&r e uma &cPoke&rbola para criar uma &cPoke&rRod! \\n\\nA &cPoke&rbola utilizada apenas mudará a aparência da &cPoke&rRod... não use as caras para isso. \\n\\nA minha favorita é a que usa a &dBola Cura&r!"]
	quest.3B5578F000D6AD9E.title: "Criando uma &cPoke&rRod"
	quest.3B560B2ECE331CAF.quest_desc: ["Esta é uma Tampa de Pilar de Tier 3 para o Starlight Charger."]
	quest.3B560B2ECE331CAF.title: "Tampa de Pilar do Starlight Charger Tier 3"
	quest.3B570B3DB5F6D2CB.quest_subtitle: "Aprimoramento de Armazenamento x16"
	quest.3B570B3DB5F6D2CB.title: "&eAprimoramento de Ouro&r"
	quest.3B577572FA7A413E.quest_desc: ["A &3Ira do &eDeserto&r é uma combinação do &3Arco Amaldiçoado&r e da &eTempestade de Areia na Garrafa&r. \\n\\nEste Arco não dispara Flechas como o normal, em vez disso, ele dispara &3Tempestades de Areia &eAmaldiçoadas&r! \\n\\nTrês delas, para ser exato! \\n\\nEle também não precisa de Flechas para atirar, o que também é bom."]
	quest.3B577572FA7A413E.title: "&3Ira do &eDeserto"
	quest.3B57EEC3E8E67D12.quest_desc: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, você está no modo de edição."]
	quest.3B6F723B03C4BF55.quest_desc: ["A Digestão (uma forma muito rudimentar de processamento) é como mudamos os &3Nitratos Alquímicos&r para diferentes formas. \\n\\nPrimeiro, precisaremos de Ouro Purificado, que pode ser feito colocando Ouro, &bSal Alquímico&r e &9Água&r no Tanque de Digestão e clicando com Shift + botão direito para fechá-lo como o Tanque de Fermentação. \\n\\nDepois, podemos combinar 4 de um &3Nitrato Alquímico&r com Ouro Purificado e &dSal Ammoniac&r para obter um Tier superior ou fazer o inverso para um Tier inferior."]
	quest.3B6F723B03C4BF55.title: "Tanque de Digestão"
	quest.3B750DFAF99B858A.quest_desc: ["Para desbloquear &4&oUnbound&r você precisará derrotar &4&oRadical Red&r ou &4&oBDSP&r. \\\\n\\\\nEstas são duas &4&oSéries&r que vêm antes de &4&oUnbound&r. O &4Associado de Treinador&r não oferecerá &4&oUnbound&r até que uma delas seja concluída. \\\\n\\\\nIsso mesmo, você não precisa terminar ambas, apenas uma!"]
	quest.3B750DFAF99B858A.title: "Derrote &4&oRadical Red"
	quest.3B7BB08D6AA2E7FE.quest_desc: [
		"Agora as &cSuper Velas Vermelhas&r finalmente parecem no lugar! Sabemos que é a &cVermelha&r pelas &cFlores Vermelhas&r e pela &cCera Anciã Luminescente Vermelha&r. \\n\\nAventure-se pelas &csalas vermelhas flamejantes&r para chegar à &cEssência Vermelha&r. \\n\\nDezenas de Mobs furiosos diferentes aparecerão: Lobos, Ursos Polares e Hoglins. Mate todos para vencer!"
		"{image:atm:textures/questpics/bumblezone/bumble_red1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_red2.png width:200 height:100 align:center}"
	]
	quest.3B7BB08D6AA2E7FE.title: "&cSantuário Sempiterno Vermelho&r"
	quest.3B84215240D9F2CB.quest_desc: ["O &3Gerenciador de Segurança&r permite que você conceda acesso e permissões a usuários dentro de sua rede.\\\\n\\\\nQuando colocado em seu sistema, você precisará de um &3Cartão de Segurança&r para cada jogador para o qual deseja configurar permissões. Quando não há cartões presentes, todos têm acesso a todas as permissões.\\\\n\\\\nPara restringir permissões e acesso a todos os jogadores não configurados, configure um cartão que não esteja vinculado a um jogador e coloque-o no gerenciador. A pessoa que colocou o &3Gerenciador de Segurança&r sempre terá acesso a ele."]
	quest.3B84215240D9F2CB.quest_subtitle: "Proteja sua Grade!"
	quest.3B84215240D9F2CB.title: "&3Gerenciador de Segurança"
	quest.3B884E05AE2EEBFC.quest_subtitle: "Tier: &c5"
	quest.3B88D58B11B5DC78.quest_subtitle: "Tier: &54"
	quest.3B936CA3F0F7B26B.quest_desc: ["A &l&7Mineradora Digital&r é um Bloco... 3x2x3? Uma &5Máquina&r? \\n\\nTodos nós conhecemos as Mineradoras de Vácuo, mas vamos lá, elas são estranhas! Esta aqui Minera Blocos de verdade! \\n\\nPodemos Clicar com o Botão Direito nela para abrir sua GUI, aqui podemos ver um monte de coisas! Botões, Telas e até Slots! \\n\\nOs Slots são para onde os &eItens Minerados&r irão. A Tela dirá se ela está pronta, se não tem &aEnergia&r suficiente ou quantos Blocos pode Minerar. Ela também tem Botões dentro da Tela para Ejeção Automática, para sugar os Blocos que Minera e até para usar Toque Suave! \\n\\nOs Botões farão todo o resto! Podemos usar as Visualizações para ver a área que será Minerada. Ou até adicionar Melhorias para aprimorá-la! \\n\\nIniciar: dirá à &l&7Mineradora Digital&r para começar a Minerar! Não funcionará se a &5Máquina&r não estiver pronta. Parar: dirá à &l&7Mineradora Digital&r para parar de Minerar. Config: define os Filtros, isso é importante. Resetar: está quebrado. \\n\\nO lado esquerdo das Configurações define a Área de Trabalho para a Mineração. Quão longe, alto e baixo! O lado direito é para o Filtro de &eItens&r. O Filtro é o mesmo dos &eImportadores &fe &eExportadores&r do &e&lOIQ&r, confira a Missão deles para aprender a configurá-los! \\n\\nVocê também pode usar o Modo Inverso para colocar os Filtros em uma lista negra. E também as Substituições, que preencherão os Blocos Minerados. "]
	quest.3B936CA3F0F7B26B.quest_subtitle: "Sim, ela minera. Não, não tem picareta."
	quest.3B936CA3F0F7B26B.title: "&l&7Mineradora Digital"
	quest.3B99290BE63F2968.quest_subtitle: "Compactando Pó de Carbono"
	quest.3B9D9CB589DB2003.quest_desc: [
		"As máquinas do &#71EBB4&nModern Industrialization&r funcionam de forma diferente dos outros mods. Todas as máquinas possuem um &#E5EB71multiplicador de eficiência&r, que aumenta enquanto a máquina estiver processando uma receita. A &#E5EB71eficiência&r aumenta a &#E5EB71velocidade&r da máquina. A &#E5EB71eficiência&r é zerada quando a receita é alterada."
		""
		"Recomenda-se usar 1 máquina para 1 receita que produza componentes passivamente. É assim que o mod foi pensado para ser jogado. Atualizações irão melhorar o sistema. Isso será abordado no futuro."
		""
		"{image:atm:textures/questpics/modernindustrialization/prod_line.png width:100 height:100 align:center}"
		""
		"{@pagebreak}"
		"Todas as máquinas deste mod aceitam FE como energia. &c16 FE&r convertem para &#E1EB591 EU&r de energia."
	]
	quest.3B9D9CB589DB2003.quest_subtitle: "Isso vai ajudar"
	quest.3B9D9CB589DB2003.title: "&cLeia isto com atenção"
	quest.3B9E6FBEDABA4F7E.quest_desc: [
		"No interior das &6&lParedes da Colmeia&r você pode encontrar uma Caverna de &6Mel&r! \\n\\nAqui você pode encontrar &6Fluido de Mel&r, &5Cristais de Mel&r, Blocos de Ninhada e até mesmo Beehemoths! \\n\\nTudo relacionado a &6Mel&r. "
		"{image:atm:textures/questpics/bumblezone/bumble_cave.png width:200 height:100 align:center}"
	]
	quest.3B9E6FBEDABA4F7E.title: "Sala da Caverna de &6Mel&r"
	quest.3BA4504DEFB87264.quest_desc: ["Funciona de forma semelhante às &lSimply Lights&r, a Invertida acenderá quando nenhuma Redstone for aplicada, enquanto a normal só funcionará com Redstone. \\n\\nNo entanto, estas precisam ser fixadas a uma Parede para serem colocadas."]
	quest.3BA4504DEFB87264.title: "&fLâmpadas de Parede"
	quest.3BAEF1A3FDB818A4.quest_subtitle: "Lariço Europeu + Bordo Vermelho"
	quest.3BB0926C4C00BE1D.quest_desc: ["Você não odeia quando acaba a Energia do seu Jetpack? Bem, você nunca mais precisará se preocupar com isso! \\n\\nVocê pode precisar fazer todos os Jetpacks antes dele, uma &6&lEstrela ATM&r, além de mais Itens caros, mas ei, vale a pena! \\n\\nBasta colocá-lo e usá-lo normalmente, só que com menos recarga."]
	quest.3BB0926C4C00BE1D.title: "&5&lJetpack Criativo"
	quest.3BB3AA6C29285837.quest_desc: ["Bônus:\\n\\n - Absorção II (3:00)\\n - Velocidade II (3:00)"]
	quest.3BB3AA6C29285837.title: "&2Maçã de Prudentium"
	quest.3BC0A50886A3222B.quest_desc: ["&dAll the Mons&r é um pack estilo kitchensink que inclui &3Cobblemon&r.\\n\\nO pack usa o All the Mods - 10 como base, mas altera algumas coisas para funcionar com o &3Cobblemon&r.\\n\\nSe você tiver alguma dúvida ou problema, sinta-se à vontade para se juntar ao Discord do ATM!"]
	quest.3BC0A50886A3222B.title: "&dBem-vindo ao All the Mons!"
	quest.3BC94B0B922C0708.quest_desc: ["Estes são ingredientes de criação para coisas que fazem importação, seja de itens, fluidos ou energia."]
	quest.3BD304D851F49EC0.quest_subtitle: "Baga de Sabugueiro + Abeto Prateado"
	quest.3BD73FEAE853D350.quest_desc: [" Lendas falam de caçadores que confiavam não apenas em suas &cpróprias mãos&r, mas nas &2presas de seus companheiros&r. Seus &ccintos de couro&r, adornados com &2amuletos de osso&r, carregam a memória de inúmeras batalhas travadas juntos. \\n\\n- &lPossui 1 habilidade: \\n\\n &5Matilha&r: \\n Aumenta o dano causado pelos &cpets&r do portador da relíquia. \\n\\n- Uma &6relíquia&r para caçadores que confiam em sua matilha… e fazem cada &cgolpe do companheiro contar&r."]
	quest.3BD73FEAE853D350.quest_subtitle: "Una-se aos seus pets e liberte uma matilha mortal!"
	quest.3BD73FEAE853D350.title: "&2Cinto de Caça&r"
	quest.3BDB94F17765EE77.quest_desc: ["Se você está procurando gerar uma tonelada de energia, pode começar ampliando algumas das opções da seção &9Energia de Meio de Jogo&r. Aumente seus &aReatores&r. Aprimore seus &9Geradores Térmicos&r para Nitro. Enlouqueça.\\n\\nNo entanto, você pode precisar de ainda mais energia."]
	quest.3BDB94F17765EE77.quest_subtitle: "Mais Energia do que Você Precisará"
	quest.3BDB94F17765EE77.title: "Opções de Energia de Fim de Jogo"
	quest.3BE3B54B4A681668.quest_desc: ["É aqui que tudo se resume: você gosta de machucar seus inimigos como um Caminhão, mas muito mais devagar? Ou prefere ser uma pessoa normal que usa uma Espada."]
	quest.3BE3B54B4A681668.title: "Machado Caótico"
	quest.3BE5CD0C7CC4BCC6.quest_desc: [
		"Lava da Alma faz parte de &6&lAllthemodium&r. Pode ser encontrada na Dimensão do &b&lO Outro&r muito raramente no subsolo, ou comumente em Vilarejos Piglich!\\n\\nPrecisaremos pegar um Balde de &9Lava da Alma&r e derramá-lo sobre um Ovo de Geração de Abelha Fantasmagórica para fazer um &9Ovo de Geração de Abelha de Lava da Alma&r.\\n\\nDepois, você precisará esmagá-las ou cutucá-las para obter seu DNA e criar um Ovo de Geração!\\n"
		"{image:atm:textures/questpics/soul_lava_process.png width:100 height:100 align:center}"
	]
	quest.3BE5CD0C7CC4BCC6.title: "Ovo de Spawn da &9Abelha de Lava da Alma&r"
	quest.3BF1900346772703.quest_subtitle: "Tier: &f2"
	quest.3BF32843DE3CF3C2.quest_desc: [
		"Aprimoramentos Válidas:"
		"- Velocidade de Corrida"
		"- Velocidade de Caminhada"
		"- Velocidade de Nado"
		"- Isca"
	]
	quest.3BF5B8DE7A1CC4D7.quest_desc: ["Se você quer bons equipamentos, vai precisar de &6&lEquipamentos do Apotheosis&r, e tudo começa com uma &aGema&r! \\n\\n&aGemas&r são Drops raros de qualquer Mob, e também são Drops garantidos de &4Invasores&r. \\n\\nVocê aprenderá mais sobre eles depois, por enquanto, Farme esses Mobs!"]
	quest.3BF5B8DE7A1CC4D7.title: "&6&lAventura Apotheosis"
	quest.3C0F8EB779E56F2A.quest_desc: ["Aqui está a sua Garra de Caranguejo da Votação dos Mobs! \\n\\nMas o Caranguejo que você precisa matar é muito maior... e mais feroz... \\n\\nA Garra de Quitina é um item solto pelo Clawdian. \\n\\nQuando usada, você terá aumento no Alcance de Bloqueio e no Alcance de Entidade. Assim, você pode colocar Blocos mais longe e golpear Mobs mais longe também!"]
	quest.3C0F8EB779E56F2A.title: "&9Garra de Quitina"
	quest.3C108354DB6D9562.quest_desc: [
		"Sem Aumento de Nível, estou vendo o padrão."
		""
		"O Item de Assinatura é Pedra de Tumulto Celeste."
	]
	quest.3C108354DB6D9562.title: "&7Líder das Ruínas Aklove"
	quest.3C2F5AB815A6C949.quest_desc: ["Para fazer um &2Barra de Ferro Infundido&r, coloque uma Barra de Ferro no &2Altar Natural&r.\\n\\nEste processo será mais rápido do que com &6Ouro Contaminado."]
	quest.3C3FE45CEF5E242B.quest_desc: ["Enquanto as outras &aPeças do Reprocessador&r têm um local obrigatório na construção, estas três peças podem ser colocadas em qualquer face vertical, desde que não estejam na estrutura!\\n\\nA &cPorta de Energia&r é usada para fornecer energia à máquina multibloco para processar resíduos.\\n\\nA &9Porta Injetora de Fluido&r é usada para injetar o líquido necessário, que dependerá do tipo de resíduo injetado. Para Cianeto, isso significa água!\\n\\nA &aPorta de Saída&r é usada para expelir o material reprocessado. Você pode clicar com o botão direito para pegar o material manualmente, ou usar canos para automatizar a extração."]
	quest.3C413D4A210A3BDE.title: "Abelha de Mel"
	quest.3C54C36CE97A48DC.quest_desc: ["Droppers dropam,\\nDispensers dispensam, \\nE Flingers arremessam! \\n\\nEm vez de colocar delicadamente os itens do Buffer, o Módulo Flinger irá jogá-los? Quão longe? Você determina isso!"]
	quest.3C5734448FEC128B.quest_desc: ["A Vareta de Adivinhação mais barata, a Vareta de Adivinhação de Vidro. \\n\\nEla pode encontrar todos os Minérios que uma Picareta de Pedra pode minerar. Ou seja, Cobre, Carvão e Ferro. Nada superior."]
	quest.3C74DAE7EC844A98.quest_desc: ["As Bagas Lunares são uma excelente fonte de comida, além de serem muito fáceis de obter! \\n\\nElas crescem para baixo das Folhas de Árvore Lunar, você pode colher as Bagas das Vinhas como as Bagas Luminosass. \\nSó que estas dão muito mais Pontos de Fome e Saturação!"]
	quest.3C7C9EE57AD00A76.quest_desc: ["Você pode fabricar isso?!?!?! Eu sempre saqueei para consegui-los. \\n\\nVocê pode alterar se eles miram nos alvos ou voam reto. Ao mirar, você pode alternar entre as configurações de &cVelocidade&r, &6Dano&r e &aVelocidade de Curva&r."]
	quest.3C7C9EE57AD00A76.title: "&cMicromísseis"
	quest.3C84F6C08BC4C74E.quest_desc: ["Estas são 3 categorias inteiras de Mods! Como eu coloquei todas elas em apenas algumas Missões? \\n\\nApenas arranhando a superfície do que todos eles têm a oferecer! \\n\\nVocê tem que descobrir o resto."]
	quest.3C84F6C08BC4C74E.title: "&lExploração, Combate e Magia"
	quest.3C8522C5E8CA5629.quest_desc: ["Às vezes precisamos de uma &bTampa de Bola&r especial para fazer uma certa &cPoke&rbola que queremos. \\n\\nPara obtê-las, precisaremos picar algumas &bTampas de Bola&r para obter &6Fragmentos de Bolota&r. \\n\\nEntão jogue essas &bTampas de Bola&r através da &6Serra&r ou no que você quiser usar!!"]
	quest.3C8522C5E8CA5629.title: "Serrando (novamente)"
	quest.3C892B33758B7BA6.quest_desc: ["As &dEngrenagens &fe &dEngrenagens Grandes&r podem interagir entre si para alterar a Velocidade e o Estresse! \\n\\nSe você conectar uma &dEngrenagem&r, na diagonal de uma &dEngrenagem Grande&r, a &dEngrenagem&r dobrará de Velocidade! Isso ocorre porque a &dEngrenagem Grande&r tem mais Dentes que a &dEngrenagem&r, demorando mais para completar uma &dRotação&r. \\n\\nIsso também funciona ao contrário, se você colocar uma &dEngrenagem Grande&r na diagonal de uma &dEngrenagem&r, a &dEngrenagem Grande&r girará na metade da Velocidade. \\n\\nIsso também alterará as Unidades de Estresse das &dEngrenagens&r. Mais Velocidade, mais Estresse. Menos Velocidade, menos Estresse."]
	quest.3C892B33758B7BA6.title: "Trabalho em Equipe das &dEngrenagens&r!"
	quest.3C8C80345D3F5FE8.quest_desc: ["O coletor de itens coleta itens e os deposita no inventário abaixo dele."]
	quest.3C8D9278B81BB37A.quest_desc: ["Não temos todo o tempo do Mundo, vamos &eAcelerar&r um pouco! \\n\\nOs &2&lReatores&r não vão esperar para sempre!"]
	quest.3C8D9278B81BB37A.title: "&eAprimoramento de &8Velocidade"
	quest.3C9539083BCC145C.quest_desc: ["As Abelhas de Menril podem ser usadas para automatizar Pedaços de Menril Cristalizado."]
	quest.3C9539083BCC145C.quest_subtitle: "Automatizando Menril"
	quest.3C99017FD32B6DE2.quest_desc: ["Os &eInvólucros de Latão&r são feitos da mesma forma que os &8de Andesito&r e os &cde Cobre&r. Basta aplicar o &eItem&r em Madeira Descascada. \\n\\nMas como os &eInvólucros de Latão&r nos dão algumas das &6Máquinas&r mais poderosas, não será tão fácil de obter quanto os &8de Andesito&r ou os &cde Cobre&r. \\n\\nFelizmente, este é o &6&lATMons&r, então você pode fazer &eLatão&r de várias maneiras diferentes! \\n\\nMas a maneira do &6&lCreate&r seria jogar um &cBarra de Cobre&r e um &7Barra de Zinco&r em uma &8Bacia&r abaixo de um &6Misturador Mecânico&r, enquanto a &8Bacia&r está aquecida."]
	quest.3C99017FD32B6DE2.title: "&eInvólucro de Latão"
	quest.3C9F5EB59D72AC90.quest_desc: ["Um Bloco de Barra de Supremium Despertado é necessário para criar a &6Estrela ATM&r."]
	quest.3CAD0701EC16C2D8.quest_desc: [
		"Pântanos Escuros cobrem o mundo do Starlight. \\n\\nAqui você pode encontrar muitas plantas, animais e, claro, Lama."
		"{image:atm:textures/questpics/eternal/starlight_swamp.png width:200 height:100 align:center}"
	]
	quest.3CAD0701EC16C2D8.title: "Pântano Escuro"
	quest.3CB05026BC4C5577.quest_desc: ["Atualmente, você pode produzir de forma muito ineficiente &#986FC7Chapas de Liga à Prova de Explosão&r em um &#6F93C7Compressor Elétrico&r usando o &#3946E3Barra Mista à Prova de Explosão&r."]
	quest.3CB6DC5B09C62CFE.quest_desc: ["Os &5Portões Ender&r são usados para transferir energia sem fio de e para um bloco adjacente na &7Rede Ender&r.\\n\\nPense neles como pontos de acesso sem fio para sua rede de energia sem fio.\\n\\nNota: Você só pode adicionar &acapacidade de armazenamento de energia&r usando uma Célula Ender."]
	quest.3CB7884B7B32CF00.quest_desc: ["Conseguir seu primeiro &bGás de Éter&r pode ser um pouco assustador.\\n\\n&bGás de Éter&r é feito perfurando um Wither, usando uma Broca de Fluido com uma &5Lente Roxa&r.\\n\\nMas não se preocupe com o Wither, o Industrial Foregoing tem uma máquina apenas para ajudar você com essa tarefa. A &4Câmara de Estase&r é uma máquina que congela no lugar qualquer coisa que esteja em cima dela em uma área de 3x3, incluindo o Wither.\\n\\n&cEspero que você não fique sem energia, porque se ficar... espero que esteja pronto para lutar contra o &0Wither&c. Por causa disso, recomendo usar algum tipo de Vidro À Prova de Wither, como Vidro Tingido do Mob Grinding Utils, ou Vidro de Crystalix com o Modo Reforçado ativado.&c"]
	quest.3CB7884B7B32CF00.quest_subtitle: "Gás de Éter? Hã?"
	quest.3CB7AB928D3E1CC6.quest_subtitle: "Feito com energizador"
	quest.3CB7AB928D3E1CC6.title: "&fAbelha de Cristal Flamejante"
	quest.3CB8F5F1D33C8F9F.quest_desc: ["O mesmo da missão anterior, só que mais, muito mais."]
	quest.3CB8F5F1D33C8F9F.title: "Módulo Grande de Capacidade de Escudo Wyvern"
	quest.3CBB78C9B8D3665E.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Reduz o alcance de detecção de mobs hostis."
	]
	quest.3CCBE9BBCA8ADA38.quest_desc: ["O &d&lAlterador de Fase Supercrítica&r precisará de muita &aEnergia&r. E quero dizer, muita mesmo! Centenas de Milhões de FE. \\n\\nMas como nós entregamos tanta &aEnergia&r? \\n\\nPrecisaremos de pelo menos 1 (recomendado 2) &dBobinas Supercarregadas&r! \\n\\nA &dBobina Supercarregada&r é colocada dentro do &d&lA.F.S.&r, em uma &dPorta do AFS&r. A &dPorta&r precisará alimentar a &dBobina Supercarregada&r com &aEnergia&r. \\n\\nCada &dBobina Supercarregada&r pode enviar 400 MFE por Tick. E precisaremos de um monte delas para a &dAntimatéria&r!"]
	quest.3CCBE9BBCA8ADA38.title: "&dBobinas Supercarregadas"
	quest.3CD6F0BBE9D7EB75.quest_desc: ["&nForte&r \\n\\n&5Fantasma&r \\n&dPsíquico&r \\n\\n&nVulnerável&r \\n\\n&aInseto&r \\n&dFada&r \\n&4Lutador&r"]
	quest.3CD6F0BBE9D7EB75.title: "&8Sombrio"
	quest.3CE3D9245F8EC005.quest_desc: ["O quarto Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e67108864&f (65536k) bytes de armazenamento."]
	quest.3CE3D9245F8EC005.quest_subtitle: "x4^3"
	quest.3CE3D9245F8EC005.title: "&5Componente de Armazenamento de 64M"
	quest.3CE72DAF431269CD.quest_desc: ["O &#D6AC2FPolarizador&r é capaz de magnetizar os materiais colocados nele."]
	quest.3CE72DAF431269CD.title: "&5Polarizador"
	quest.3CF2DFB7F0CE065B.quest_desc: [
		"As &cColunas Nubladas&r são muito mais Quentes e &6Laranjas&r do que qualquer outro Bioma aqui. \\n\\nAqui o &3Sculk&r é substituído por &3Sculk Sombrio&r e a &3Pedra de Sculk&r é substituída por &cArdósia Resinada&r. \\n\\nVocê também encontrará Areia/Terra de Almas, além de &cMagma &fcom &cLava&r abaixo deles. \\n\\nCom as temperaturas tão altas, Mobs normalmente não aparecerão aqui, mas há alguma vida vegetal! "
		"{image:atm:textures/questpics/deepndark/dnd_column.png width:200 height:100 align:center}"
	]
	quest.3CF2DFB7F0CE065B.title: "&cColunas Nubladas"
	quest.3CF32F2314839B1D.quest_desc: [
		"Cansado da decomposição do seu Quartzo de Certus em Drusa e do Fluix Entroizado? Nós podemos consertar isso! Com este Reparador de Cristal, você pode consertar Cristais de Certus em Drusa com Quartzo de Certus Carregado, e Fluix Entroizado com Pó de Ender."
		""
		"Ele ainda tem uma pequena chance de criar Quartzo de Certus em Drusa Impecável."
	]
	quest.3CF32F2314839B1D.title: "Conserte-Seus-Cristais: O Reparador de Cristal"
	quest.3CFD27F273B97FDD.quest_desc: ["Os mods &5&lApothic&r têm vários núcleos, cada um alterando diferentes partes do &2&lMinecraft&r.\\n\\nOs mods de Atributos e Encantamentos são os que você precisará seguir para obter a &6&lEstrela ATM&r!"]
	quest.3CFD27F273B97FDD.title: "Mods &5&lApothic&r"
	quest.3CFD798362605880.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Faz com que as Flechas de Poção disparadas pelo Arco tenham um efeito de Explosão, atingindo múltiplos alvos em uma área."
	]
	quest.3CFE522A4B7CC2EC.quest_desc: [
		"O &3Baú Reforçado&r é um Baú à prova de explosão com 36 espaços. Não pode ser transformado em Baú Duplo. Também funciona como uma Caixa de Shulker."
		"{image:atm:textures/questpics/pneumaticcraft/reinforced_chest_ui.png width:200 height:100 align:center}"
	]
	quest.3CFE522A4B7CC2EC.quest_subtitle: "Melhor que seu Baú Comum"
	quest.3D24607A51997B39.quest_desc: [
		"Sem aumento de nível."
		""
		"Encontrado no 3º andar da &cLiga Kanto&r."
	]
	quest.3D24607A51997B39.title: "&3Elite dos Quatro Agatha"
	quest.3D26E7BFE0AA964A.quest_desc: [
		"O Luminofish é um Peixe Luminoso que vive no Abismo.\\n\\nEles agem como Peixes normais. Você pode pescá-los, colocá-los em um Balde, e pode até cozinhá-los!"
		"{image:atm:textures/questpics/eternal/starlight_fish1.png width:100 height:100 align:center}"
	]
	quest.3D26E7BFE0AA964A.title: "Luminofish"
	quest.3D2A03EB2B91E9C1.quest_desc: ["Estes são literalmente Funis chiques. \\n\\nEles conectam dois Inventários, trazendo &eItens&r do de Cima para o de Baixo. \\n\\nAs &eCalhas&r podem se conectar umas às outras, até mesmo na diagonal. \\n\\nVocê também pode usá-las com &6Ventiladores&r para disparar &eItens&r para cima pelas &eCalhas&r!"]
	quest.3D2A03EB2B91E9C1.title: "&eCalha"
	quest.3D2B4D9FD2086B9B.quest_desc: ["O &2Adaptador Lógico do Reator de Fissão&r, que chamarei de &2FRLA&r, é usado para monitorar e configurar o &2&lReator de Fissão&r com &4Redstone&r. \\n\\nPrimeiro, coloque o &2FRLA&r em uma das paredes do &2&lReator de Fissão&r, como você faria com as &2Portas&r. \\n\\nEntão, podemos Clicar com o Botão Direito no &2FRLA&r para configurá-lo. \\n\\nDesativado: não interagirá com &4Redstone&r. \\n\\nAtivação: ligará o &2&lReator&r ao receber um &4Sinal de Redstone&r, e quando não houver mais um &4Sinal&r, ele desligará. \\n\\nTemperatura Alta: enviará um &4Sinal de Redstone&r quando as &6Temperaturas&r atingirem um Nível perigoso. \\n\\nNível Crítico de Rejeito: emitirá um &4Sinal&r quando houver muito &8Rejeito Nuclear&r. \\n\\nDano Crítico: assim como os outros, emitirá um &4Sinal&r quando o &2&lReator&r estiver prestes a explodir! \\n\\nCombustível Insuficiente: emitirá um &4Sinal&r quando estiver ficando sem &2Combustível Fóssil&r."]
	quest.3D2B4D9FD2086B9B.title: "&2Adaptador Lógico do Reator de Fissão"
	quest.3D2C6FF462B17205.quest_desc: ["Dano baixo, velocidade de ataque muito alta. Reduz o tempo de invencibilidade do alvo."]
	quest.3D2C6FF462B17205.quest_subtitle: "Esfaqueia Esfaqueia"
	quest.3D31B94CC42BCE43.quest_desc: ["O &8Tomo de Extração&r é o &8Tomo&r que estamos procurando! Ele removerá todos os &5Encantamentos&r e deixará o Item intacto! \\n\\nPara criá-lo, precisaremos &d&lInfundir&r nosso &8Tomo de Desmontagem Superior&r. \\n\\nPodemos usar a configuração anterior para isso."]
	quest.3D31B94CC42BCE43.quest_subtitle: "Todos os Encantamentos, não quebra"
	quest.3D4032E7119AF8B7.quest_desc: ["Bombas Sonares são feitas com Gel Trêmulo, que é dropado de Mariposas Cristalizadas. \\n\\nElas podem ser arremessadas para danificar qualquer Mob (e Jogador) em uma área enorme! Também irá sacudir a tela dos jogadores e tocar um efeito sonoro alto. \\n\\nÉ desorientador, então use apenas em seus amigos!"]
	quest.3D41D0092D94636B.quest_desc: [
		"E se eu te dissesse que a Fruta do Demônio é inflamável?"
		""
		"Jogar nossa &cFruta do Sonho do Demônio&r no chão e incendiá-la criará o &dFogo Espiritual&r. É assim que converteremos alguns itens do mundo normal em materiais do &9Outro Mundo&r."
		""
		"Também é bonito."
	]
	quest.3D41D0092D94636B.title: "As Chamas do &9Outro Mundo"
	quest.3D4D88B8BE881351.quest_desc: ["Se você quiser lançar feitiços melhores, precisará de uma &6Mesa de Escriba&r para desbloquear novos glifos para seu livro de feitiços. \\n\\nExistem 3 tiers de glifos para desbloquear, e cada um requer alguma experiência e itens. \\n\\nA Mesa de Escriba também é usada para anexar feitiços a Pergaminhos de Feitiço. Para fazer isso, coloque um Pergaminho de Feitiço na mesa, selecione o feitiço em seu Livro de Feitiços e, em seguida, agache e clique com o botão direito do mouse com o livro na mesa. \\n\\nPara criar um Glifo, clique com o botão direito na Mesa de Escriba com seu livro de feitiços. Procure o glifo que deseja fazer e clique em Selecionar na parte inferior. Clique com o botão direito na mesa com os itens necessários e o glifo será criado. Use o glifo para aprendê-lo. \\n\\nNota: A mesa pode puxar itens de inventários próximos."]
	quest.3D4D88B8BE881351.quest_subtitle: "Aprimorando Feitiços"
	quest.3D579A1F7EFEDD5C.quest_desc: [
		"O &9&lWarden&r. O chefe mais difícil do &2&lMinecraft&r, claro, estando dentro da Estrutura mais difícil. \\n\\nEle é gerado por um &3Emissor de Sculk&r sendo ativado 3 vezes, ou qualquer quantidade após o primeiro &9&lWarden&r. \\n\\nEle tem 500 &4Corações&r e causa muito Dano, seja te atingindo com os punhos ou com sua &bExplosão Sônica&r! \\n\\nEle tem uma fraqueza, no entanto, que é ser Cego. Ele só pode te encontrar pelo Som, ou pelo Cheiro se você estiver perto o suficiente! Mantenha distância, tipo 23 Blocos de altura."
		"{image:atm:textures/questpics/gettingstarted/warden_roar.png width:100 height:100 align:center}"
	]
	quest.3D579A1F7EFEDD5C.title: "Mate o &9&lWarden&r"
	quest.3D5852E6D0ADF651.title: "Armazenamento Dimensional"
	quest.3D5F87F8E6B89C1B.quest_desc: ["O &7Furnator&r queimará itens como carvão e madeira para produzir FE."]
	quest.3D6167F673BB5256.quest_desc: ["Ao minerar o &bMega Cristal&r com uma &bPicareta de Diamante&r (ou melhor), você obterá uma &bMega Pedra&r! \\n\\nEstas não fazem nada sozinhas; em vez disso, precisaremos usá-las para Fabrique uma certa &bMega Pedra&r para um &cPokémon&r específico. \\n\\nNem todos os &cPokémon&r podem se tornar &bMega&r, apenas alguns selecionados. Cada um precisará de sua &bMega Pedra&r específica, o que significa que se você quiser vários &bMega Pokémon&r, precisará de vários &bLocais Mega&r."]
	quest.3D6167F673BB5256.title: "&bMega Pedra"
	quest.3D63868AC4393EBC.quest_desc: ["Uma abelha que dá Fluido de XP do &2Just Dire Things&r."]
	quest.3D63868AC4393EBC.quest_subtitle: "Lápis + Esmeralda"
	quest.3D63868AC4393EBC.title: "&fAbelha de Experiência"
	quest.3D63B8A64B561A71.quest_desc: ["Ele aumentará seu Limite de Nível para 36. \\n\\nSeu Item de Assinatura desta vez é o &dEviolite&r. \\n\\nVocê precisará lutar com ele 3 vezes. Não apenas lutar, mas também vencer!"]
	quest.3D63B8A64B561A71.title: "&6Treinador Pokemon Cedric"
	quest.3D7480E4F9063E93.quest_subtitle: "Madeira + Suor"
	quest.3D7480E4F9063E93.title: "&fAbelha Fazendeira"
	quest.3D755073C56274BE.quest_desc: ["Jogue um Item de Lente na frente do Reconstructor Atômico e quando ele ativar, se transformará em uma Lente de &cC&eo&al&bo&3r&r. \\n\\nJogue uma Lente de &cC&eo&al&bo&3r&r na frente dele, e quando ele ativar, fará uma Lente de &cDetonação&r. \\n\\nContinue fazendo isso até obter a Lente da &3Morte Certa&r."]
	quest.3D755073C56274BE.title: "Lente da &3Morte Certa"
	quest.3D78D9F4E8A60EDB.quest_desc: ["Atualmente uma receita bem simples, precisando apenas de 4 &dJarras de Fonte&r, 4 &dBlocos de Gema da Fonte&r, e uma &6&lEstrela&r. Não se preocupe, isso será alterado para ser ainda mais difícil! \\n\\nEsta jarra está sempre cheia de &dFonte&r e pode ser vinculada a qualquer coisa que precise de &dFonte&r. Incluindo os multiblocos da &6&lEstrela ATM&r."]
	quest.3D78D9F4E8A60EDB.quest_subtitle: "Pegue isto primeiro!"
	quest.3D78D9F4E8A60EDB.title: "&5&lJarra de &dFonte &fCriativa"
	quest.3D819550074CA376.quest_desc: ["O item precisará ser colocado aqui antes de ser pego novamente."]
	quest.3D819550074CA376.quest_subtitle: "Sempre Necessário"
	quest.3D82C6639A6371CB.quest_desc: ["4 &7Núcleos Quânticos&r e uma &cPoeira de Mundabitur&r e você pode obter o &7Injetor Quântico&r. \\n\\nOs &7Injetores Quânticos&r não são muito usados nesta fase, mas serão necessários mais tarde!"]
	quest.3D82C6639A6371CB.title: "&7Injetor Quântico&r"
	quest.3D862A3D3F83CA26.quest_desc: [
		"O &9Aparelho de Encantamento&r é usado para criar vários itens dentro do mod. Ele requer Fonte para funcionar.\\n\\nÉ também uma estrutura multibloco que utiliza Pedestais Arcanos para a criação.\\n\\nComece colocando um Núcleo Arcano no chão, depois coloque o Aparelho de Encantamento em cima dele. Cerque o Aparelho com Pedestais Arcanos.\\n"
		"{image:atm:textures/questpics/ars/enchanting_app.png width:200 height:175 align:1}"
	]
	quest.3D862A3D3F83CA26.title: "Aparelho de Encantamento"
	quest.3D9964CB0440DD5A.quest_desc: ["Jogar Brasa de Blaze em Polymorphic Fluid criará Combustível de Brasa de Blaze Não Refinado. Realizar a Dispersão de Gosma com gosma de Tier Dois ou superior converterá o Combustível de Brasa de Blaze Não Refinado em Combustível de Brasa de Blaze."]
	quest.3DA07EE81C9E13BF.quest_desc: ["O &eSincronizador&r de Bolas pode ser usado para trocar a &cBola&r em que um &cPokémon&r está. \\n\\nDeixe um &cPokémon&r Segurar a &cBola&r desejada, então use o &eSincronizador&r de Bolas nele para trocá-la. A &cBola&r em que ele estava será Anulada... \\n\\nEu não vejo isso ajudando muito a não ser que você use &cBolas&r que dão benefícios após Capturar um &cPokémon&r!"]
	quest.3DA07EE81C9E13BF.title: "&eSincronizador&r de Bolas"
	quest.3DA5F622E3266AE5.quest_subtitle: "Feito no Reprocessador"
	quest.3DA5F622E3266AE5.title: "&fAbelha de Ridiculite"
	quest.3DD27DED791C6A0B.quest_desc: ["Para processar minérios usando &5Oritech&r, você precisa usar uma &aCentrífuga&r com um &6Addon de Fluido&r e um &aPulverizador&r ou &6Forja de Fragmentos&r."]
	quest.3DD27DED791C6A0B.quest_subtitle: "Saída máxima"
	quest.3DD27DED791C6A0B.title: "Processamento de Minério"
	quest.3DD71B6C4B80FB44.quest_desc: ["O &3Eye of Curse&r o levará à &3Frosted Prison&r para lutar contra o &3&lMaledictus&r."]
	quest.3DD71B6C4B80FB44.title: "&3Eye of Curse"
	quest.3DDB0DDA7571B2C1.quest_desc: ["O &bEmissor de Nível ME&f, quando configurado com um item específico e uma quantidade dele para responder, emitirá um sinal de redstone dependendo se o item armazenado na rede cair abaixo, ultrapassar ou igualar a quantidade dada.\\n\\nIsso pode ser usado, por exemplo, para ligar automaticamente certas máquinas com redstone para fabricar automaticamente um recurso quando ele cai abaixo de uma quantidade mínima definida."]
	quest.3DDB0DDA7571B2C1.title: "&cEmissor de Nível ME"
	quest.3DDB7C8E61BA048F.quest_subtitle: "Tier: &a2"
	quest.3DDF87A1E5F5D009.quest_desc: [
		"No início, você pode se virar criando as máquinas de tier &7Iniciante&r e &bBásico&r usando Ferro, mas eventualmente precisará criar materiais energizados usando o &9Orbe Energizante&r.\\n\\nO &9Orbe Energizante&r energizará itens usando &aVaretas Energizantes&r próximas em uma área de 9x9 ao redor dele, criando materiais melhores para você usar para progredir através dos &eTiers&r no Powah.\\n\\nPara alimentar o orbe, você precisará conectar Varetas Energizantes a Cabos de Energia que estão sendo supridos com energia. Se você quiser que o Orbe energize mais rápido, faça mais varetas, atualize para varetas de tier superior, ou ambos! Para ver se as Varetas estão conectadas, defina sua &aChave Inglesa&r para o modo de vinculação e você poderá vincular qualquer Vareta ao Orbe."
		""
		"{image:atm:textures/questpics/powah/powah_energizing.png width:200 height:200 align:1}"
	]
	quest.3DDF87A1E5F5D009.title: "O &9Orbe Energizante"
	quest.3DE14F16F3109229.quest_desc: ["Combinando 8 Tábuas de qualquer Madeira, com um &7Balde de Óleo de Creosoto&r, obteremos Madeira Tratada! \\n\\nA Madeira Tratada é usada em quase todos os Itens que o &8&lIE&r nos dá, além da maioria das Máquinas simples. \\n\\nO mais importante são as &6Bancadas de Engenheiro&r! Elas nos darão uma tonelada de novas Receitas."]
	quest.3DE14F16F3109229.title: "Madeira Tratada"
	quest.3DF794EBCAA7AE1A.title: "Lenhador de Árvores Dracônico"
	quest.3E0643EA9183CDAE.quest_desc: ["'Era o chapéu dele, Seu Siriguejo! Ele era o número 1!' \\n\\nFaz exatamente a mesma coisa que o &6Chapéu de Beber&r normal, só que parece muito mais legal!"]
	quest.3E0643EA9183CDAE.quest_subtitle: "Cabeça"
	quest.3E0643EA9183CDAE.title: "&9Chapéu de Beber Inusitado"
	quest.3E16CF590C911129.quest_desc: ["O &3Air Compressor&r é uma maneira fácil de criar pressão, basta colocar alguns itens combustíveis nele e ver a mágica acontecer! (Recomendo fazer pelo menos 3 deles para começar)."]
	quest.3E16CF590C911129.quest_subtitle: "Sentindo a Pressão"
	quest.3E16CF590C911129.title: "Gerando Pressão"
	quest.3E1A3BC8642390B3.quest_desc: ["'Eu sou a Mary Poppins, pessoal!' \\n\\n&4O Guarda-chuva&r é uma ferramenta muito útil adicionada pelo &l&3Artifacts&r! Ele pode ser segurado na sua frente para funcionar como um Escudo, segurando o botão direito. Ou pode ser usado para retardar sua queda, apenas segurando-o! "]
	quest.3E1A3BC8642390B3.quest_subtitle: "Único"
	quest.3E1A3BC8642390B3.title: "&4Guarda-chuva&r"
	quest.3E2A411FF5B4B0E7.quest_desc: [
		"O &3Alcance de Ativação&r é a distância que o Jogador (você) precisa estar do Gerador para que ele funcione.\\n"
		"O menor valor possível é 1 bloco de distância, e o maior é um raio de 48 blocos."
	]
	quest.3E2A411FF5B4B0E7.title: "&3Raio de Ativação"
	quest.3E301F3EEC8C763A.quest_desc: [
		"Isso pode ser usado para acelerar o ritmo de crescimento das abelhas bebês, ou para criar novos Ovos de Geração.\\n\\nColoque uma abelha bebê enjaulada com 20 Guloseimas de Mel para transformá-la em um adulto.\\n\\nPara criar Ovos de Geração, você precisará combinar o gene da abelha desejada com uma guloseima de mel, depois usar essa guloseima de mel nesta máquina com um ovo para criar o novo Ovo de Gerador.\\n\\nOs genes podem ser combinados para uma pureza máxima de 100%, o que lhe dará 100% de chance de converter um Ovo em um Ovo de Gerador de Abelha."
		"{@pagebreak}"
		"Você também pode aplicar genes em uma abelha sem retirá-la da sua gaiola com isso. Coloque uma Guloseima de Mel com as amostras de gene de sua escolha no incubador junto com uma gaiola de abelha contendo a abelha na qual você quer aplicar os genes."
	]
	quest.3E301F3EEC8C763A.quest_subtitle: "Creche para Abelhas Bebês"
	quest.3E301F3EEC8C763A.title: "&fIncubadora de &6Abelhas Bebê"
	quest.3E32450DBB7529AA.quest_desc: ["O &eAgrupador de Itens&r funciona meio como a fila de uma Montanha-Russa. \\n\\nA Montanha-Russa não sairá até que todos os assentos estejam preenchidos! Da mesma forma, o &eAgrupador&r não &6Enviará&r &eItens&r até que o Filtro e a Quantidade definidos tenham sido correspondidos. \\n\\nPerfeito para coisas como o Processamento de Minério do &5&lMekanism&r, que precisa de certas quantidades de &eItens&r &9Inseridos&r, ou então irá afunilar."]
	quest.3E32450DBB7529AA.title: "&eAgrupador de Itens"
	quest.3E33730DC2115D26.title: "&eBaú de Ouro"
	quest.3E3CBDCEAB0FF28F.quest_desc: ["O &9Deep Learner&r é um dos componentes principais do HNN.\\n\\nCom este item, você pode clicar com o botão direito para abrir um HUD e armazenar &6Modelos de Dados&r para coletar dados enquanto mata mobs.\\n\\nCada Learner pode conter 4 Modelos de Dados, e contanto que você tenha o Learner em qualquer lugar do seu inventário, ele coletará dados para os modelos colocados dentro!\\n\\nNota: Você pode ter vários Deep Learners em seu inventário, e ele contará as mortes para todos os Modelos de Dados dentro de todos os Learners."]
	quest.3E3CBDCEAB0FF28F.quest_subtitle: "O HUD de Aprendizagem"
	quest.3E3CBDCEAB0FF28F.title: "&aAprendendo Mobs"
	quest.3E3DF8E967D95DB0.quest_desc: ["Ao usar um Componente de Armazenamento de 64k ou superior, o Condensador de Matéria se torna capaz de condensar significativamente mais para produzir uma &bSingularidade&f. Uma única singularidade requer que 256.000 itens sejam anulados. Isso é exatamente &o4000 stacks&r!\\n\\nVeja o que acontece quando você joga essa singularidade no chão com um pedaço de &ePó de Ender&f. Você terá que causar algum dano aos arredores enquanto faz isso, mas felizmente o AE2 oferece sua própria &bTNT Minúscula&f para minimizar isso."]
	quest.3E3DF8E967D95DB0.quest_subtitle: "Isso não é automação, é sacrifício em massa."
	quest.3E3DF8E967D95DB0.title: "&5&lMatéria Hiper-Condensada"
	quest.3E4B27759C973006.quest_desc: ["&l&6Framed Blocks&r é o Mod de Construção mais importante de todos. Na verdade, se você me der um Modpack e &l&6Framed Blocks&r não estiver nele, eu não jogo. É tão importante assim! \\n\\n&l&6Framed Blocks&r nos dá Blocos de imitação que podem ser preenchidos com qualquer Bloco que não seja uma Entidade de Bloco (Entidades de Bloco são Blocos como Mesa de Trabalho, Fornalha ou Câmara de Enriquecimento). \\n\\nEssas Estruturas podem ter praticamente qualquer forma! Desde Lajes verticais, até rampas, e até mesmo quartos de bloco! \\n\\nVocê quer Escadas de &5Netherita&r? Então use Framed Blocks! Você quer uma Mesa de Trabalho de Fardo de Feno? Você pode ter! Você quer ângulos perfeitos em sua construção? Então comece a fazer &l&6Framed Blocks&r!"]
	quest.3E4B27759C973006.title: "&l&6Framed Blocks&r"
	quest.3E555B364FD88B43.quest_subtitle: "Alcance: &c45&r Blocos"
	quest.3E555B364FD88B43.title: "&4Growth Accelerators de Supremium"
	quest.3E5BE6D6422F682C.quest_desc: ["Nossa &9&lTurbina&r precisará de entrada de Vapor, saída de &9Água&r e saída de &aEnergia&r. \\n\\nMas como? \\n\\nPodemos usar as &9Portas da Turbina&r para trazer Vapor e extrair &aEnergia&r. Nós precisaremos usar os &9Dutos da Turbina&r para extrair a &9Água&r, no entanto! \\n\\nAmbos são colocados nas Paredes de nossas &9&lTurbinas&r."]
	quest.3E5BE6D6422F682C.title: "Entradas e Saídas da &9&lTurbina&r"
	quest.3E6706BC4C318A40.quest_desc: ["O Esgoto produz &#8B4513Resíduo&r de animais em sua área de trabalho, bem como absorve &aExperiência&r de jogadores para converter em &aEssência&r.\\n\\nO Compostador de Resíduo pode transformar &#8B4513Resíduo&r em &#8B4513Fertilizante&r.\\n\\nO Esgoto suporta Adicionais de Alcance."]
	quest.3E6706BC4C318A40.quest_subtitle: "Fresco do Campo de Esterco, sua assombração"
	quest.3E6706BC4C318A40.title: "Esgoto"
	quest.3E75AFE3482834C5.quest_desc: ["&lRailCraft&r é um mod inteiro baseado em &5Trens&r! \\n\\nDe &7Carrinhos de Mina&r a &eLocomotivas Elétricas&r e &9Perfuratrizes de Túnel&r! Ele tem tudo em termos de acessórios para &5Trens&r também! Semáforos, Caldeiras a Vapor para alimentar &5Trens&r e automação para tudo isso. \\n\\nO mod modelo para os amantes de modelos de &5Trens&r!"]
	quest.3E75AFE3482834C5.title: "&7&lRailCraft"
	quest.3E822975A8A66EBD.quest_desc: [
		"Poços de Lama surgem em Selvas, e eu só fico feliz que não sejam areia movediça! \\n\\n&7Cascalho Suspeito&r está localizado sob a &8Lama&r."
		"{image:atm:textures/questpics/pokemon/find_mud.png width:200 height:100 align:center}"
	]
	quest.3E822975A8A66EBD.title: "Poço de Lama Pré-histórico"
	quest.3E89034E0CB8D687.quest_desc: ["Caixotes de Madeira agem como Barris... mas os do &2&lMinecraft&r, então são Baús que podem ser abertos de qualquer lado! \\n\\nEles têm 27 Slots, mas podem ser clicados com Shift + botão direito com um &6Martelo de Engenheiro&r (várias vezes) para fechá-los! Isso significa que eles podem ser quebrados e preservar os &eItens&r dentro. \\n\\nVocê também pode editar o Texto do Caixote para mudar seu nome como se estivesse em uma Bigorna. \\n\\nO Caixote Reforçado funciona exatamente da mesma forma que o normal, só não pode ser explodido!"]
	quest.3E89034E0CB8D687.title: "Armazenando &eItens"
	quest.3E890BABC4C41370.quest_desc: ["Devido ao limite de Controladores, você provavelmente acabará querendo conectar sistemas diferentes ao seu hub principal sem um bilhão de cabos conectando-os.\\n\\nIsso é feito usando &3Network Transmitters&r e &3Network Receivers&r.\\n\\nOs &9Transmitters&r devem ser conectados ao seu sistema principal, onde quer que seu Controller esteja.\\n\\nO &9Receiver&r deve ir para onde você quer que sua rede externa esteja. Por exemplo, pode ser uma parte separada de sua base onde você tem Abelhas, uma farm de mobs, etc.\\n\\nPara conectar o Receiver à sua rede principal, você precisará usar um &3Network Card&r. Para vincular o Network Card, clique com o botão direito no Receiver e, em seguida, coloque o Network Card no Transmitter que está conectado ao seu sistema principal"]
	quest.3E890BABC4C41370.quest_subtitle: "Conectando Redes Sem Fio"
	quest.3E890BABC4C41370.title: "&3Redes de Grade"
	quest.3E8BA5E075ABD136.quest_desc: [" Outrora usado por &6cozinheiros&r lendários cujos banquetes atraíam &5reis&r e &9guerreiros&r, o &5Chapéu de Chefe&r carrega o cheiro de &6fumaça&r, &cespeciarias&r e &5caldeirões ferventes&r. Suas dobras guardam a memória de inúmeras &9refeições&r preparadas no caos da batalha. \\n\\n Esta &5relíquia&r recompensa o portador por suas vitórias: quando um inimigo cai, há uma chance de produzir &calmôndegas&r, uma comida simples mas farta, proporcionando &aforça&r e &6sustento&r no calor do combate. \\n\\n- &lPossui 1 habilidade: \\n\\n &6Colheita de Almôndegas&r: \\n O &6Chapéu de Chefe&r recompensa seu portador por cada vitória: quando um inimigo é derrotado, há uma chance de produzir uma &calmôndega&r, uma comida simples mas farta, idêntica à carne bovina crua, que pode ser comida diretamente ou cozida para maior &arestauração&r. Esta &6relíquia&r transforma os despojos de batalha em &9nutrição&r, mantendo o portador forte mesmo no calor do combate. \\n\\n- Uma &6relíquia&r para aqueles que transformam cada vitória em &anutrição&r… e nunca passam fome."]
	quest.3E8BA5E075ABD136.quest_subtitle: "Transforme o calor da batalha em nutrição"
	quest.3E8BA5E075ABD136.title: "&fChapéu de Chefe&r"
	quest.3E8C2E7769DFBF35.quest_desc: [
		"Ao contrário da &3Locomotiva a Vapor&r, você não precisará colocar nada na &eLocomotiva Elétrica&r. \\n\\nEla funciona com a energia dos &eFrames&r sob os &6Trilhos Elétricos&r. \\n\\nSim, ela só pode funcionar em &6Trilhos Elétricos&r."
		"{image:atm:textures/questpics/railcraft/rail_electric.png width:100 height:100 align:center}"
	]
	quest.3E8C2E7769DFBF35.title: "&eLocomotiva Elétrica"
	quest.3E8C7D92F99496BE.quest_desc: ["O &5Olho do Abismo&r o levará à &5Cidade Submersa&r para lutar contra o &5&lLeviatã&r."]
	quest.3E8C7D92F99496BE.title: "&5Olho do Abismo&r"
	quest.3E99F4CD379DE9D7.quest_desc: ["Esta missão foi escrita pela equipe &6AllTheMods&r, ou por um &2contribuidor da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta missão não tem permissão para ser usada em quaisquer pacotes públicos não lançados pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, está no modo de edição."]
	quest.3EA2578C3A56FAE8.quest_desc: ["O Extrator de Almas permite que você encha Jarras de Almas inserindo uma jarra e usando itens de mobs para enchê-las. Por exemplo, adicionar Carne Podre dará uma porção de uma Alma de Zumbi."]
	quest.3EA3A6414AB8A39C.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_flow.png width:100 height:150 align:center}"]
	quest.3EA3A6414AB8A39C.quest_subtitle: "Câmaras de Desafio"
	quest.3EA3A6414AB8A39C.title: "Forro de Armadura Fluxo"
	quest.3EA883C0BB7BD38F.quest_desc: ["Vamos coletar alguns pedaços de Lã!"]
	quest.3EA883C0BB7BD38F.quest_subtitle: "Cujo Velo era....Arco-íris?"
	quest.3EA883C0BB7BD38F.title: "Maria Tinha um Carneirinho"
	quest.3EB34CC8A3B0DB3C.quest_subtitle: "Não funciona como comida de hamster"
	quest.3EB63AF53E70C931.quest_desc: [
		"A Reforma precisa de Fluxo de Mercúrio para funcionar! Você precisará clicar com Shift + botão direito em todos os 3 Pedestais com o Emissor de Fluxo Sulfúrico para configurá-los. Em seguida, coloque o Emissor e forneça energia a ele.\\n\\nDepois disso, deve estar pronto para Reformar!"
		"{image:atm:textures/questpics/theurgy/theurgy_reform_setup.png width:200 height:50 align:center}"
	]
	quest.3EB63AF53E70C931.title: "Passo 4: Energizando"
	quest.3EC2877B9018FF02.quest_desc: [
		"A &6Serra Mecânica&r funciona como a maioria das máquinas do &6&lCreate&r. \\n\\nDê a ela &dEnergia Rotacional&r, e quaisquer itens que passarem serão fatiados ao meio."
		"{@pagebreak}"
		"A &eSerraria de Precisão&r é uma máquina de fábrica do &5&lMekanism&r. \\n\\nÉ muito fácil de usar! Jogue um pouco de &cEnergia&r nela, depois coloque a &6Bolota&r na máquina, e ela irá fatiar e picar em &6Metades de Bolotas&r!"
		"{@pagebreak}"
		"A &8Linha de Montagem&r precisará de algumas máquinas para funcionar: Controlador de Montagem, Laser, Unidade de Entrada, Unidade de Exportação e a Plataforma de Montagem. \\n\\nTodas as máquinas precisarão estar sentadas uma ao lado da outra conectadas para funcionar. \\n\\nO Controlador é o que recebe Pressão. A Unidade de Entrada precisará de um inventário perto dela para retirar, e a Unidade de Exportação precisará de um baú para colocar os itens. Se tudo estiver funcionando, dirá que está rodando. Se não, o Controlador declarará o problema!"
		"{@pagebreak}"
		"A &cForja de Fragmentos&r, como todas as fábricas gananciosas da &6&lOritech&r, precisará de Estruturas de Máquina para ser feita. \\n\\n3 para ser exato. Uma vez que você tenha as 3 Estruturas de Máquina e a &cForja de Fragmentos&r posicionada, clique com o botão direito na Forja para construí-la. \\n\\nEntão, fica muito mais fácil, apenas ligue-a e jogue suas &6Bolotas&r nela!"
		"{@pagebreak}"
		"Por último está o &dGlifo de Corte&r. \\n\\nPrimeiro, use qualquer Forma de Feitiço que desejar. Toque, Raio, Projétil, Míssil, o que for! \\n\\nEntão, selecione o &dGlifo de Corte&r e adicione Sensível a ele. Isso permitirá que o &dCorte&r funcione em itens dropados. \\n\\nEntão agora você pode jogar suas &6Bolotas&r no fluxo, atingi-las com o feitiço, e ele magicamente as cortará."
	]
	quest.3EC8A0B89788D079.quest_desc: ["Eu não tenho Mãos, eu tenho &9Nadadeiras&r. \\n\\nAs &9Nadadeiras&r agirão como um Depth Strider muito melhor. Você pode Nadar e Andar na &9Água&r muito mais rápido!"]
	quest.3EC8A0B89788D079.quest_subtitle: "Pés"
	quest.3EC8A0B89788D079.title: "&9Nadadeiras&r"
	quest.3EC90ADA4E322B14.quest_desc: ["Para fazer um &6Barra de Ouro Contaminado&r, coloque um &eBarra de Ouro&r no &2Altar Natural&r.\\n\\nEste processo levará mais tempo do que com o &2Ferro Infundido&r."]
	quest.3EC90ADA4E322B14.quest_subtitle: "Contamine esse Ouro!"
	quest.3EC90ADA4E322B14.title: "&6Ouro Contaminado"
	quest.3ED40CC40458087E.quest_desc: ["A &c&lMochila Acumuladora&r não faz muito por si só, precisaremos dar a ela um &cAcumulador&r para que ela funcione! Qualquer &cAcumulador&r, ela não é exigente! \\n\\nDepois de dar a ela um &cAcumulador&r em uma &6Bancada de Engenheiro&r, você pode carregá-la. Uma vez carregada, ela fornecerá &cEnergia&r para Itens em sua Mão e Armadura que você está vestindo. \\n\\nVocê pode usá-la no seu Slot de Costas nos Curios, no seu Slot de Peitoral, ou combiná-la com um Peitoral em uma Mesa de Trabalho. \\n\\nA Mochila pode conter 1 &cAcumulador&r e 3 Aprimoramentos."]
	quest.3ED40CC40458087E.title: "&c&lMochila Acumuladora"
	quest.3ED8365BAD406CC5.quest_desc: ["Estes são Mods que eu achei perfeitos para decorar sua casa ou base! \\n\\nSinta-se à vontade para conferir ainda mais do que é mostrado aqui!"]
	quest.3ED8365BAD406CC5.title: "Mods de Decoração!"
	quest.3EDDF96EA5056D28.quest_desc: ["&6Cobre&r e &7Níquel&r farão &6Constantan&r! \\nFinalmente, este é bastante usado no &8&lIE&r, especialmente em Máquinas ou Itens que usam Calor e Metal, como Geradores."]
	quest.3EDDF96EA5056D28.title: "&6Lingote de Constantan"
	quest.3EE95747CA6DFB1A.quest_desc: [
		"A &7&lPrensa de Metal&r é nossa Melhor Amiga para todas as Receitas de Criação com &7Metal&r! \\n\\nÉ muito simples, colocamos nossos Moldes na Prensa, conectamos um pouco de &cEnergia&r no topo e jogamos nossos &eItens&r nas &eEsteiras Transportadoras&r. \\n\\nNossos &eItens&r passarão, serão &7&lPrensados&r, e se tornarão um novo &eItem&r que continua se movendo na &eEsteira&r! \\n\\nIsso pode ser usado para fazer &cFios&r, &7Placas&r, &8Varas&r, e... &2Fatias de Melancia&r?"
		"{@pagebreak}"
		"A primeira camada é muito simples, apenas &8Andaime de Aço&r e ambos os lados de um &4Bloco de Engenharia de Redstone&r."
		"{image:atm:textures/questpics/immersive/immersive_press1.png width:150 height:75 align:center}"
		"Em seguida, colocamos um Pistão, virado para Baixo, acima do &4Bloco de Engenharia de Redstone&r e adicionamos duas Esteiras Transportadoras ao lado dele."
		"{image:atm:textures/questpics/immersive/immersive_press2.png width:125 height:100 align:center}"
		"Então, colocamos um único &7Bloco de Engenharia Pesada&r acima do nosso Pistão!"
		"{image:atm:textures/questpics/immersive/immersive_press3.png width:100 height:100 align:center}"
		"Por último, clicamos com o botão direito no Pistão com o Martelo do Engenheiro!"
	]
	quest.3EE95747CA6DFB1A.title: "&l&7Prensa de Metal"
	quest.3EEF17C57375CC39.quest_desc: ["O &lSimply Lights&r adiciona luzes muito simples de fazer e fáceis de usar.\\n\\nQuando invertidas, elas funcionarão sem Redstone e desligarão quando o sinal de Redstone for ativado.\\n\\nExistem muitas cores e formas diferentes!"]
	quest.3EEF17C57375CC39.title: "&lSimply Light&r"
	quest.3F02EF19112D23BE.quest_desc: ["Você precisará de &6Criadores Mecânicos&r para fazer as &6Rodas de Esmagamento&r, elas são grandes demais para uma Mesa de Trabalho 3x3. Você também precisará de uma tonelada de &8Ligas de Andesito&r. \\n\\nA propósito, você precisará de 2 para realmente usá-las. \\nDepois de ter 2, coloque-as uma ao lado da outra. Então, alimente ambas com &dPotência Rotacional&r e muitas Unidades de Estresse. \\n\\nCertifique-se de que as &6Rodas de Esmagamento&r estão girando em direções opostas, senão não irá &6Esmagar&r! A da esquerda deve girar no &e&osentido horário&r, e a da direita deve girar no &9&osentido anti-horário&r. \\n\\nUma vez que elas estejam girando (rápido e nas direções certas), você pode ter &eItens&r jogados entre elas e eles serão &6Esmagados&r. \\n\\nQuais &eItens&r? Minérios &6Esmagados&r de Minérios, &eItens&r de Pedras e Netherrack, Areia e Pederneira de Cascalho, e até Fungo do Nether de Blocos de Fungo do Nether!"]
	quest.3F02EF19112D23BE.title: "&6Rodas de Esmagamento"
	quest.3F0CD2C03CD7D730.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_forge.png width:100 height:150 align:center}"]
	quest.3F0CD2C03CD7D730.quest_subtitle: "Deixado pelo Golem Starlight"
	quest.3F0CD2C03CD7D730.title: "Ornamento de Armadura da Forja"
	quest.3F185554793CCE54.quest_desc: ["Para construir, você precisará de Ferramentas. E você vai querer Ferramentas. \\n\\nFerramentas que podem ajudá-lo a obter Blocos, Ferramentas para ajudá-lo a obter diferentes versões desses Blocos, e Ferramentas para ajudá-lo a colocar Blocos! \\n\\nVocê precisará começar com um Graveto!"]
	quest.3F185554793CCE54.title: "Ferramentas!"
	quest.3F2C1A81C17D2D67.quest_desc: ["Os &6Braços Mecânicos&r devem ser configurados antes de serem colocados, como o &eEjetor Ponderado&r. \\n\\nEle tem um Alcance de 4 Blocos e pode pegar de &eEsteiras&f e &eDepósitos&r. Ele também pode depositar em &eEsteiras&f, &eDepósitos&f e &eFunis&r. \\nEnquanto segura o &6Braço Mecânico&r, clique com o botão direito nos Blocos para definir como Entrada, depois clique novamente para mudar para Saída. Você pode clicar com o botão esquerdo para desmarcar os Blocos. Você pode selecionar quantos estiverem ao alcance! \\n\\nAssim que tiver &dPotência Rotacional&r, um &eItem&r em qualquer Bloco de Entrada e espaço em qualquer Bloco de Saída, ele começará a mover &eItens&r. Ele irá mais rápido quanto mais Velocidade for dada a ele. \\n\\nComo o &eTúnel de Latão&r, o &6Braço Mecânico&r tem Modos de Distribuição. Felizmente, muito menos! Round Robin: irá em ordem para Entradas e Saídas. Round Robin Forçado: esperará até que todas as Saídas tenham espaço ou todas as Entradas tenham &eItens&r disponíveis. Preferir Primeiro Alvo: irá para o Bloco mais próximo dele."]
	quest.3F2C1A81C17D2D67.quest_subtitle: "Por que fazer você mesmo quando um Robô pode fazer melhor?"
	quest.3F2C1A81C17D2D67.title: "&6Braço Mecânico"
	quest.3F33E55B8D9E09A4.quest_desc: ["&nForte&r \\n\\n&8Sombrio&r \\n&bGelo&r \\nNormal \\n&6Pedra&r \\n&7Aço&r \\n\\n&nVulnerável&r \\n\\n&dFada&r \\n&9Voador&r \\n&dPsíquico&r"]
	quest.3F33E55B8D9E09A4.title: "&4Lutador"
	quest.3F3559EF5D08B706.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Faz com que as Flechas busquem ativamente seus alvos."
	]
	quest.3F39BEB788175CEF.quest_subtitle: "Escavação 3x3!"
	quest.3F55F3CC8519D783.quest_desc: ["O Gerador Soulium é o Gerador presenteado a nós pelo Mystical Agriculture. Ele usa Essência de Criatura e Energia para gerar as criaturas. Essência de Criatura é obtida através da colheita de Mob Plants, feitas por Soul Jars. Então você terá que matar as criaturas primeiro, ou usar o Soul Extractor."]
	quest.3F55F3CC8519D783.quest_subtitle: "Gerador do Mystical Agriculture"
	quest.3F663416E824720C.quest_desc: ["Os &cInvólucros de Cobre&r serão necessários para a maioria das Máquinas envolvidas na &bLogística de Fluidos&r. \\n\\nVocê quer colocar &9Água&r? Você precisará de &cInvólucros de Cobre&r. Você quer pegar &9Água&r? Você precisará de &cInvólucros de Cobre&r. \\n\\nEles são feitos como os &8Invólucros de Andesito&r, aplique um &cBarra de Cobre&r em uma Tronco Descascado."]
	quest.3F663416E824720C.title: "&cInvólucros de Cobre"
	quest.3F67085593A2DF93.quest_desc: ["&9Pedras da Lua&r são encontradas em Taigas e Cavernas de Espeleotemas."]
	quest.3F67085593A2DF93.title: "Encontrando &9Pedras da Lua"
	quest.3F769D575AF8C3CC.quest_desc: ["&6Fragmentos de Bolota&r não fazem muito. Não pode comê-los nem dá-los a &cPokemon&r. \\n\\nVocê só pode usar &6Implantadores&r para misturar &6Fragmentos de Bolota&r e Corantes com &bTampas de Bola&r para fazer outras &bTampas&r. "]
	quest.3F769D575AF8C3CC.title: "&6Fragmentos de Bolota"
	quest.3F8A5CBEAE024748.quest_desc: ["O Olho do Saqueador, o Olho do Blaze e o Olho do Shulker são usados para localizar estruturas específicas."]
	quest.3F8A5CBEAE024748.quest_subtitle: "Estou de olho em você"
	quest.3F8A5CBEAE024748.title: "Localizadores de Estrutura"
	quest.3F8AEBB994716318.quest_desc: ["&8Wither&r é um Efeito na &l&2Vanilla&r, então é claro que precisamos da nossa própria maneira de usá-lo e abusar dele! \\n\\nVocê pode preparar uma Poção Estranha com uma &8Caveira de Esqueleto Wither&r para criá-lo. Então você pode criar Flechas com ele!"]
	quest.3F8D515D7B81B0E3.quest_desc: [
		"Outro Molde de Ferraria?!?!?!\\n\\nBem, pelo menos você não precisa de Arqueologia para isso!\\n\\nVocê terá que ganhá-los vencendo os Geradores de Desafio que são encontrados na estrutura da Masmorra no &b&lOutro Lugar&r. Mais especificamente nas Salas da Biblioteca!\\n"
		"{image:atm:textures/questpics/allthemodium/all_library.png width:200 height:100 align:center}"
	]
	quest.3F8D515D7B81B0E3.title: "&5Molde de Ferraria de Unobtainium"
	quest.3F8EEE1AD4420702.title: "&bParte de Armazenamento de 64k"
	quest.3F9CCCFEF4E84166.quest_desc: ["Para aumentar sua produção de calor, coloque um &3Dissipador de Calor&r no lado frio do seu Tubo de Vórtice."]
	quest.3F9CCCFEF4E84166.quest_subtitle: "Mais Calor"
	quest.3F9CCCFEF4E84166.title: "Melhor Produção de Calor"
	quest.3F9D553C9FA64F2A.quest_desc: ["Os reatores são estruturas multi-bloco, o que significa que você pode criar seu próprio tamanho personalizado!\\n\\nSe estiver usando &aPeças de Reator Básicas&r, o maior reator que você pode construir é de 5x5x5.\\n\\nO &lMaior&r Reator que você pode fazer usando &ePeças de Reator Reforçadas&r é de 32x32x48. Há muitas variáveis que contribuem para a produção geral de um reator, então certifique-se de experimentar!\\n\\nAlgumas dicas gerais:\\n\\nQuanto mais alto o reator, mais combustível ele pode conter e queimar, porque há mais barras de combustível, o que significa mais energia geral. Isso também significa uma &ctaxa de queima&r maior.\\n\\nQuanto mais largo o reator, mais eficiente ele é, desde que você não adicione mais barras de combustível ao design. Isso significa menos consumo geral."]
	quest.3F9D553C9FA64F2A.title: "Expandindo Nossos Reatores"
	quest.3FACB48732D14A79.quest_desc: ["Raramente, no subsolo, você pode encontrar um &bLocal Mega&r. \\n\\nParece um pouco com um &bMegaroide&r se a atmosfera fosse muito mais agressiva com ele. \\n\\nVocê encontrará minérios nele, assim como o &bMega Cristal&r."]
	quest.3FACB48732D14A79.title: "&bLocal Mega"
	quest.3FBCBBEBB78B83FC.quest_desc: ["Finalmente, faça um &5Trem&r! \\n\\nNós já devemos ter nossos &5Truques&r da Missão da &5Estação de Trem&r, o design do &5Truque&r não importa. \\n\\nEntão, podemos colocar Blocos no &5Truque&r com &aSupercola&r. Não importa quais Blocos, praticamente qualquer Bloco que possa ser movido pode ser &aColado&r! \\n\\nÉ aqui que você tenta deixá-lo bonito! Dê uma olhada na Exibição de Construções Artísticas no Discord para ver alguns deles. \\n\\nO Bloco mais importante para o nosso &5Trem&r são os &5Controles do Trem&r. Você precisará de um para realmente mover o &5Trem&r. \\n\\nVocê também pode adicionar um &5Assento&r para os &5Condutores&r (mais sobre isso depois) ou até mesmo para você! \\n\\nQuando estiver tudo pronto, basta clicar em \"Montar Trem\" e ou seu &5Trem&r será feito, ou ele dirá o que você fez de errado!"]
	quest.3FBCBBEBB78B83FC.title: "Construindo &5Trens"
	quest.3FC34BEE629F4037.quest_desc: [
		"Lá nos biomas nevados, vem o perigo da Neve Fofa. Ela pode levar a uma derrota gelada, uma grande queda ou até mesmo fósseis! \\n\\nO &7Cascalho Suspeito&r está sob a neve fofa."
		"{image:atm:textures/questpics/pokemon/find_powder.png width:200 height:100 align:center}"
	]
	quest.3FC34BEE629F4037.title: "Depósito de Neve Fofa Pré-histórico"
	quest.3FCEF8FF45E51608.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_quartz.png width:100 height:150 align:center}"]
	quest.3FD19A001899D8C6.quest_desc: ["Ok, agora este dá tanto o Planar quanto o Voo real, Voo Criativo para ser mais exato."]
	quest.3FD19A001899D8C6.title: "Módulo de Voo Dracônico"
	quest.3FD702B5AB006402.quest_desc: ["Você já quis apenas pairar por onde quer que vá? \\n\\nEste cinto permite que você levite. Para ativar, basta agachar enquanto estiver no ar, seja caindo ou pulando."]
	quest.3FD801D7DE9176FB.title: "&eParte de Armazenamento de 4k"
	quest.3FD9DC6B7844A79C.quest_desc: ["Eu sempre odiei como o Concreto é sem graça, especialmente na vida real. \\n\\nBem, pelo menos no &2&lMinecraft&r com o Mod &l&bChipped&r podemos obter diferentes designs com ele!"]
	quest.3FD9DC6B7844A79C.title: "&fConcreto &l&bChipped&r"
	quest.3FE2A649F07DF28D.quest_subtitle: "Você pode triturar Blutônio dos Reactores Extremos para obter Pó de Plutônio"
	quest.3FE489E6B1FAC24B.quest_subtitle: "Reciclando as Varas Esgotadas"
	quest.3FE489E6B1FAC24B.title: "Obtendo Plutônio"
	quest.3FE739EA7E297DF3.quest_desc: [
		"Dispositivos Estendidos são variantes de dispositivos do AE2 que ou têm uma capacidade maior, são mais rápidos, e talvez até ambos."
		""
		"Por exemplo: O Provedor de Padrão Estendido tem 36 slots de padrão, 4 vezes mais que um Provedor de Padrão comum."
		""
		"Ou as Pontas de Exportação/Importação Estendidas, elas funcionam cerca de 8x mais rápido que uma normal e suportam mais melhorias."
		""
		"Como a maioria destes são apenas versões aprimoradas da versão base, não farei missões separadas para cada um individualmente."
	]
	quest.3FE739EA7E297DF3.title: "Mais Rápido e Maior: Dispositivos Estendidos"
	quest.3FEFD0340A60DD5F.quest_subtitle: "Complete todos os truques!"
	quest.3FF61A4D7A250AE1.quest_desc: ["Para esta &5Célula de Energia &cCriativa&r, não confundir com a outra &5Célula de Energia &dCriativa&r, você precisará de 4 &cCélulas Nitro&r. \\n\\nCada &cCélula Nitro&r precisa de 2 &aCélulas Espirituais&r, e cada &aCélula Espiritual&r precisa de 2 &bCélulas Nióticas&r. Isso continua por um tempo... \\n\\nEu não vou fazer essa conta, pegue uma Árvore de Receitas, tenho coisas mais importantes para fazer!"]
	quest.3FF61A4D7A250AE1.quest_subtitle: "Powah Ilimitado!"
	quest.3FF61A4D7A250AE1.title: "&l&cCélula de Energia &5(Criativa)"
	quest.4007DFA7CC3A5FF2.quest_desc: ["Para evitar que esta &oseção de missões inteira&r seja coberta de aprimoramentos, dê uma olhada nos aprimoramentos da Sophisticated Backpack.\\n\\nVocê precisará fazer o equivalente do Sophisticated Storage, mas eles funcionam da mesma forma."]
	quest.4007DFA7CC3A5FF2.quest_subtitle: "A Base para Aprimoramentos"
	quest.40096ED0B04C3EC5.quest_desc: [
		"O item indispensável para todos os &2Geradores&r. Quando diz que ignora todas as condições, significa a maioria.\\n"
		"Ignora Níveis de Luz, Blocos necessários para a Geração e Biomas.\\n"
		"Condições de espaço ainda são necessárias, como &aSlimes&r precisando de uma área de &a3x3&r para Gerar, e o mesmo vale para jogadores precisando estar por perto."
	]
	quest.40096ED0B04C3EC5.title: "&fIgnorar Todas as Condições"
	quest.401A3FD6A3511870.quest_subtitle: "Abre-te Sésamo"
	quest.401A3FD6A3511870.title: "&fPortões"
	quest.401B559649C54C5C.quest_desc: ["Misturar &#92CCF0Hidrogênio&r e &#519BC9Cloro&r resultará em &#4FB373Ácido Clorídrico&r. Isso será usado para processar &#F2A0E1Pó de Cromo&r."]
	quest.402F1F09F5AB59FD.quest_desc: ["&dAlcreamie&r é um &cPokémon&r baseado em sorvete! \\n\\nEntão, quando você &bEvolui&r &dMilcrey&r para &dAlcreamie&r com esses Doces, eles os usarão como cobertura! Muito fofo."]
	quest.402F1F09F5AB59FD.title: "Item de &bEvolução&r de &dMilcrey"
	quest.403F76908A8A5661.quest_desc: ["O Pilão de Expulsão empurra os jogadores para fora da área, mas e se você quiser &lalguns&r jogadores por perto! Então você precisará de um Filtro de Jogador. \\n\\nClique com o botão direito em um Jogador com ele para defini-lo, e depois coloque-o no Pilão para colocá-lo na lista branca! \\n\\nAssim, quando todos os outros forem empurrados, seu amigo não será! \\n\\nAlém disso, por padrão, o Dono do Pilão não será expulso."]
	quest.4040BFCD4BE56621.quest_desc: [
		"O Hotel de &6Mel&r (Honitel) é uma estrutura grande e relativamente segura, exceto por danos de queda. \\n\\nEle tem dezenas de quartos para &6A&8b&6e&8l&6h&8a&6s&r ficarem. Também nos quartos há muito saque para você pegar. \\n\\nEu só espero que você se sinta culpado por roubar dessas &6A&8b&6e&8l&6h&8a&6s&r inocentes.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_honitel.png width:200 height:100 align:center}"
	]
	quest.4040BFCD4BE56621.quest_subtitle: "Sem Vagas"
	quest.4040BFCD4BE56621.title: "Honitel"
	quest.404AA0F5557D7E35.quest_desc: ["Sementes de Unobtainium requerem Solo Mágico colocado abaixo para poderem crescer."]
	quest.404AA0F5557D7E35.quest_subtitle: "Tier: &bMágico"
	quest.404DE5C374A17479.quest_desc: ["Tostar uma Erva de Reviver nos dará &aPó de Cura&r. \\n\\nEste Pó removerá todos os Efeitos do seu &cPokemon&r. Como Paralisia! Mas isso removerá &dAmizade&r... \\n\\nOu podemos Criá-lo para fazer um &aReviver&r. Este é um Item que Reviverá um &cPokemon&r Desmaiado e lhes dará metade de sua Vida de volta. \\n\\nVocê pode fazer um &aReviver&r mais poderoso com 3 deles ou fazer algumas Máquinas!"]
	quest.404DE5C374A17479.title: "&aReviver"
	quest.405D2571E61694FD.quest_desc: ["Clicando com o botão direito em uma &dAbelha &aPatrick&r com um &6&lBloco da Estrela ATM&r, você obterá uma &6Abelha Estrelada&r! \\n\\nVocê precisará de outro &6&lBloco da Estrela ATM&r para elas polinizarem... Eu provavelmente deveria ter te dito isso antes... \\n\\nA &6Abelha Estrelada&r fará &6Favos Estrelados&r que podem ser usados em uma Centrífuga para raramente obter &6Fragmentos de Estrela&r!"]
	quest.405D2571E61694FD.title: "&6Abelha Estrelada&r!"
	quest.405DCD3E36232EEA.quest_desc: ["Menos dano que uma Espada, mas alcance maior."]
	quest.405DCD3E36232EEA.quest_subtitle: "Liberte seu Espartano Interior"
	quest.40708C304424C3FE.quest_desc: ["&4Treinadores&r indesejados demais? Livre-se deles com a &4Vara de Repelir Treinadores&r! \\n\\nNão tenho certeza da área de Gerações que ela desabilita... ela não me diz. \\n\\nPelo menos ela não impede &4Geradores de Treinadores&r de funcionarem."]
	quest.40708C304424C3FE.title: "&4Vara de Repelir Treinadores"
	quest.4071BBBE12CACD2D.quest_desc: ["O Dispensador de &5Trem&r é uma versão melhor do Dispensador de &7Carrinho&r. Ele pode dispensar a &5Locomotiva&r inteira e mais! Defina um padrão para o que você quer que seja implantado e então dê um sinal de redstone."]
	quest.4071BBBE12CACD2D.title: "Dispensador de Trem"
	quest.40786B63E2901D11.quest_desc: [
		"Deixe-me ver como descrevo o Jardim Amaldiçoado... é um labirinto gigante! \\n\\nHá entradas de cada lado e você deve encontrar o caminho para o meio, onde está a Monstruosidade Lunar! \\n\\nPor todo o labirinto você pode encontrar baús cheios de Saque e Emaranhados!"
		"{image:atm:textures/questpics/eternal/starlight_maze.png width:150 height:150 align:center}"
	]
	quest.40786B63E2901D11.title: "Jardim Amaldiçoado"
	quest.40788326E791845D.quest_desc: ["Extrusão é uma palavra tão formal. \\n\\nO Extrusor colocará os blocos no Buffer do Roteador em uma linha na frente do Roteador quando receber um Sinal de Redstone. Quando o Sinal for desativado, ele quebrará todos esses blocos. \\n\\nÚtil para Portas!"]
	quest.407C2D00F22BD89D.quest_desc: ["Este Aprimoramento dá espaço para mais 6 Balas! Totalizando 14."]
	quest.408203C29BAABA44.quest_desc: ["Usado apenas para uma coisa."]
	quest.408D8B1CFBA22BAF.quest_desc: ["Blocos à Prova de Wither, Tijolos à Prova de Wither e Vidro à Prova de Wither têm uma resistência a explosões muito alta e não podem ser destruídos pelo Wither ou pelo Dragão do End."]
	quest.408D8B1CFBA22BAF.title: "&0Blocos à Prova de Wither"
	quest.408EBED932656006.quest_desc: ["Dopar o &7Silício&r vai garantir um rendimento muito melhor do que usar o &7Silício&r comum."]
	quest.408EBED932656006.title: "&fSilicone Dopado"
	quest.40924F0D64253A38.quest_desc: ["Faz com que as coisas possam dispensar itens."]
	quest.40924F0D64253A38.quest_subtitle: "Sumiu!"
	quest.4092E914B24C52A7.quest_subtitle: "Produz vários Materiais Starlight"
	quest.409A92D40F539485.quest_subtitle: "Tier: &e1"
	quest.40AB457E37919ABE.quest_desc: [
		" Escondido dentro das &cprofundezas ardentes&r do &cNether&r, o &5Anel dos Sete Pecados Capitais&r aguarda por aqueles ousados o suficiente para usá-lo. Cada cristal ligado ao anel responde a um &5pecado&r diferente, transformando &2fraqueza&r em &cforça&r... mas nunca sem um preço. \\n\\n- &lPossui 7 habilidades:&r \\n\\n1. &dOrgulho&r: \\n Cause &cdano&r aumentado enquanto estiver acima do seu &6alvo&r, mas sofra mais &cdano&r ao &clutar&r por baixo. \\n\\n2. &aInveja&r: \\n Quanto mais &cvida&r seu &cinimigo&r tiver em comparação a &2você&r, mais &cdano&r você &ccausa&r. Mas contra inimigos &2mais fracos&r, você se torna muito mais &2vulnerável&r. \\n\\n3. &4Ira&r: \\n Cada &cgolpe&r abre uma curta janela de &cpoder&r oscilante. No início, seus ataques &cbatem mais forte&r, mas espere &otempo demais&r e essa mesma &cfúria&r se transforma em uma pesada &cpenalidade&r. \\n\\n4. &8Preguiça&r: \\n Permaneça &2parado por tempo&r suficiente, e o anel concede &9imortalidade&r. Mas ao se mover, cada bit de velocidade faz você &creceber&r ainda mais &cdano&r. \\n\\n &lPróxima Página ->&r"
		"{@pagebreak}"
		"5. &6Ganância&r: \\n O anel aumenta sua &2sorte&r e a quantidade de &6saque&r que você ganha, mas &6às vezes&r ele &cdestrói&r as próprias &zrecompensas&r que ajudou você a obter. \\n\\n 6. &2Gula&r: \\n Quando sua &6fome&r está &calta&r, todos os seus atributos são &cfortalecidos&r. Mas se sua &6fome&r cair &odemais&r, esse mesmo &cpoder&r se torna uma &o&2fraqueza&r. \\n\\n 7. &5Luxúria&r: \\n Reproduzir &2animais&r pode gerar &2filhotes&r extras, mas esses &2recém-nascidos&r estão ligados a um destino cruel, a menos que o ciclo continue. \\n\\n- Uma &6relíquia&r de &4tentação&r e &6poder&r... onde cada &cpecado&r concede uma bênção, e cada bênção exige um custo."
	]
	quest.40AB457E37919ABE.quest_subtitle: "Algumas relíquias concedem poder. Esta testa sua alma!"
	quest.40AB457E37919ABE.title: "&cAnel dos Sete Pecados Capitais"
	quest.40B13424FA523E11.quest_subtitle: "Tier: &a2"
	quest.40B24676E11D9410.quest_desc: ["Precisamos de muitos Minérios para o &5&lMekanism&r, então por que não aprimorar nossa &dMeka-Tool&r para obter mais! \\n\\nO &dRefinamento de Minério&r agirá como Fortuna. Quando Minérios são Minerados, há uma chance de obter mais Drops deles. \\n\\nNão podemos usar a &bUnidade de Toque Suave&r com esta, no entanto. Ou Blocos de Minério ou Drops de Minério, escolha 1!"]
	quest.40B24676E11D9410.quest_subtitle: "Da melhor qualidade!"
	quest.40B24676E11D9410.title: "&dUnidade de Refinamento de Minério"
	quest.40B757772D0FBAC9.quest_desc: [
		"O &4Sangue&r é o 3º Slot que precisa ser preenchido na &6&lForja&r. \\n\\nVocê pode matar Mobs sobre/perto da &6&lForja&r para adicionar &4Sangue&r. \\n\\nOu pode depositar Tubos de Ensaio cheios para colocar esse &4Sangue&r na &6&lForja&r. \\n\\nPara encher um Tubo de Ensaio, tenha-o na sua mão secundária ao matar Mobs."
		"{image:atm:textures/questpics/forbidden/forbidden_blood.png width:135 height:100 align:center}"
	]
	quest.40B757772D0FBAC9.title: "&4Sangue"
	quest.40BC67BDEE15D1DE.quest_desc: ["Para criar Gemas da Fonte, precisaremos colocar Fragmentos de Lápis-lazúli ou Ametista na Imbuement Chamber. Com o tempo, eles se converterão em Gemas da Fonte!"]
	quest.40BC67BDEE15D1DE.title: "&5Gemas da Fonte"
	quest.40C068B2B8AC0F33.quest_desc: ["Terraformar é uma parte importante até mesmo das Construções mais simples. Mas nós, Jogadores de &2&lMinecraft&r, simplesmente não temos tempo ou esforço para isso. \\n\\nEntão, por que não deixar as Máquinas fazerem isso por nós? \\n\\nPedreiras são maneiras muito fáceis de fazer isso, mas todas começam com Quebradores de Blocos. O Quebrador de Blocos Simples só quebrará o que está à sua frente, não é o mais útil... \\n\\nMas o Quebrador de Blocos Avançado Minará uma Área definida! Muito melhor para Terraplanar!"]
	quest.40C068B2B8AC0F33.title: "&fPedreiras e Minas"
	quest.40C5C355B6DA1893.quest_desc: ["O Gerador de Bolso é um gerador portátil que usa itens combustíveis para carregar itens e ferramentas no inventário do jogador, o Gerador de Bolso é compatível com o Recipiente de Combustível."]
	quest.40C776497D68367F.quest_desc: ["Vinha, Tapetes de Musgo de Cristal Vermelho e Azul, Bagas Lunares, Musgo de Caverna e Raízes de Cristal Vermelho e Azul. \\n\\nEles podem ser usados na sua mão secundária com o Olho Perseguidor para encontrar o Jardim Amaldiçoado."]
	quest.40C776497D68367F.title: "Itens da Monstruosidade"
	quest.40DB6E3DE87F16EF.quest_desc: [
		"O &bSopro do Dragão&r é um item poderoso, (fedorento) e misterioso. Poderoso significa que podemos gerar Energia a partir dele, e muita! O &5Gerador de Halitose&r gera Energia a partir do &bSopro do Dragão&r!"
		""
		"(A propósito, você pode farmar &bSopro do Dragão&r com um Extrator do XyCraft com uma Cabeça de Dragão)."
	]
	quest.40DB6E3DE87F16EF.title: "&5Gerador de Halitose"
	quest.40E4F1172A164DD1.quest_subtitle: "Chance de surgir ao quebrar Vagens de Cacau em uma Selva"
	quest.40E4F1172A164DD1.title: "&fAbelha de Açucar"
	quest.40E8940C92668D4F.quest_desc: ["O &cDeutério&r é na verdade relativamente simples de obter! \\n\\nPrimeiro, precisamos de &9Água Pesada&r. A &9Água Pesada&r é como a boa e velha H2O, só que o H é um pouco diferente! \\n\\nPodemos usar a &9Melhoria de Filtro&r em uma &9&lBomba Elétrica&r (obviamente sobre a &9Água&r) para extrair &9Água Pesada&r em vez de &9Água&r comum. \\n\\nProcessar a &9Água Pesada&r em um &9&lSeparador Eletrolítico&r nos dará &bOxigênio&r e &cDeutério&r em vez de &7Hidrogênio&r. \\n\\nEu disse que era simples!"]
	quest.40E8940C92668D4F.quest_subtitle: "D"
	quest.40E8940C92668D4F.title: "&cDeutério"
	quest.40E89CCC6DFDA49A.quest_desc: ["&nForte&r \\n\\n&aInseto&r \\n&2Grama&r \\n&4Lutador&r \\n\\n&nVulnerável&r \\n\\n&eElétrico&r \\n&bGelo&r \\n&6Pedra&r"]
	quest.40E89CCC6DFDA49A.title: "&9Voador"
	quest.40F2EDB9384CE782.quest_desc: ["Destilar &#DBE37FVapor Craqueado de Combustível Leve&r lhe dará &#9C6C35Acetileno&r como produto."]
	quest.40F34EBE09DA7752.quest_desc: ["A Autoalimentação irá alimentá-lo automaticamente com qualquer comida em seu Inventário quando estiver com fome. No entanto, ele tem um armazenamento máximo de Pontos de Fome, cada barra cheia são 2 Pontos de Fome. Então, o Básico só pode armazenar o equivalente a 8 Bifes."]
	quest.40F34EBE09DA7752.title: "Módulo de Autoalimentação Básico"
	quest.40F634AC38F42B88.quest_desc: ["Para mover pressão, você precisará obter &3Tubos de Pressão&r. Que pressão, você pode estar se perguntando? Continue a linha de missões para ver para que são usados."]
	quest.40F634AC38F42B88.quest_subtitle: "Que Pressão?"
	quest.40F634AC38F42B88.title: "Movendo Pressão"
	quest.40F8A44DF4D8DBD6.quest_subtitle: "Magmatic + Nomad"
	quest.40F8A44DF4D8DBD6.title: "&fAbelha de Blaze"
	quest.4101F8275B41C79B.title: "&6Parte de Armazenamento de 1k"
	quest.410492282A446A06.quest_desc: ["O &aPokeNav&r é uma ferramenta para ajudar a entender quais &cPokémon&r irão (ou podem) surgir perto de você. \\n\\nEle é ajustado para qualquer bioma em que você esteja. \\n\\nAbrindo o &aPokeNav&r, você terá uma longa lista de &cPokémon&r! \\n\\nOs botões no topo mudarão a raridade de surgimento de cada &cPokémon&r, se a lista é por ordem de mais comum para menos comum ou vice-versa, e o último atualiza a lista! \\n\\nPassar o mouse sobre um &cPokémon&r na lista mostrará informações. A espécie, chance de surgimento, se você já os encontrou, quantos capturou ou nocauteou, e quaisquer requisitos específicos de surgimento. \\n\\nRequisitos como luz solar, clima ou até hora do dia!"]
	quest.410492282A446A06.title: "&aPokeNav"
	quest.4104C5D003D4705A.quest_desc: [
		"Outro Multibloco que usa &eEsteiras&r, estou vendo um padrão. Primeiro, precisamos definir um &9Projeto&r. Clique com o botão direito na &6&lBancada de Trabalho Automatizada&r para abrir sua INTERFACE e coloque um &9Projeto&r no slot mais à direita. \\n\\nEntão, podemos fazer com que nossos &eItens&r passem pelas &eEsteiras&r para serem usados em Receitas, se possível. \\n\\nDepois disso, o &eItem&r Criado (e &eItens&r que foram acidentalmente colocados nas &eEsteiras&r) sairão pelas &eEsteiras&r. \\n\\nIsso é útil para automatizar Balas, &0Grafite HOP&r e &7Componentes Mecânicos&r."
		"{@pagebreak}"
		"Começamos muitos desses com formas usando &8Andaime de Aço&r, desta vez é uma linha diagonal. No canto menor, colocaremos um &7Bloco de Engenharia Pesada&r. No canto maior, colocaremos 2 &eBlocos de Engenharia Leve&r e um &4Bloco de Engenharia de Redstone&r."
		"{image:atm:textures/questpics/immersive/immersive_automated1.png width:100 height:100 align:center}"
		"Em seguida, colocaremos mais &eBlocos de Engenharia Leve&r e &7Blocos de Engenharia Pesada&r em cima de seus antigos. Acima do &4Bloco de Engenharia de Redstone&r e do &8Andaime de Aço&r à sua esquerda, colocaremos Lajes de Madeira Tratada. No resto do espaço, colocaremos &eEsteiras Transportadoras&r na ordem mostrada."
		"{image:atm:textures/questpics/immersive/immersive_automated2.png width:100 height:100 align:center}"
		"Para obter nossa &6&lBancada de Trabalho Automatizada&r, bata na Laje de Madeira Tratada da esquerda com o &6Martelo de Engenheiro&r!"
		"{image:atm:textures/questpics/immersive/immersive_automated.png width:100 height:100 align:center}"
	]
	quest.4104C5D003D4705A.title: "&l&6Bancada de Trabalho Automatizada"
	quest.411A463E98C3B102.quest_desc: [
		"Alguns ingredientes que você precisará para fazer o Computador, o Criador e a Armadura Quânticos."
		""
		"A Singularidade Estilhaçada é feita com uma Singularidade, 2 Pós de Ender, 2 Pós de Sky Stone e 100 mB de Lava em uma Câmara de Reação."
		""
		"1 balde de Infusão Quântica é feito com 4 baldes de Água e um Pó com Infusão Quântica, que é obtido triturando a Singularidade Estilhaçada em um Inscriber ou Triturador do Mekanism."
		""
		"A Liga com Infusão Quântica é feita com 1 balde de Infusão Quântica, 4 Barras de Cobre, 4 Singularidades Estilhaçadas e 4 Singularidades normais."
	]
	quest.411A463E98C3B102.title: "Ingredientes Quânticos"
	quest.411EA1CAD3BF6D3C.quest_desc: ["Depois de gastar nosso &6Fragmento&r, Tampa Vazia e o equivalente a blocos de Lingote, podemos Fabricar nossas Tampas de Bola. \\n\\nEu acho que a de &6Allthemodium&r parece a mais legal!"]
	quest.411EA1CAD3BF6D3C.title: "Tampas de Metal &6&lAllthemodium&r"
	quest.413F338DB07BA88C.quest_subtitle: "Igual ao do vapor"
	quest.413F338DB07BA88C.title: "&5Desempacotador Elétrico"
	quest.4141EF8B8C316118.quest_desc: ["O &7Cloggrum&r é o Ferro do &2&lUndergarden&r. \\n\\nEle é encontrado em todos os lugares e é usado em uma dúzia de receitas diferentes. \\n\\nAté alguns Mobs o dropam!"]
	quest.4141EF8B8C316118.title: "&7Cloggrum&r"
	quest.4147D247E4D754D0.quest_desc: [
		"Gleeches são pequenos mobs que surgem no Deserto Cristalizado. \\n\\nEles querem seu sangue implacavelmente e isso significa até mesmo através de meios violentos. Felizmente, eles só têm 4 Corações! \\n\\nAo morrer, eles podem dropar seus Ovos, que podem ser arremessados como um projétil."
		"{image:atm:textures/questpics/eternal/starlight_gleech.png width:100 height:100 align:center}"
	]
	quest.4147D247E4D754D0.title: "Gleech"
	quest.414A35A72AFB5FF5.quest_desc: ["Este é provavelmente um dos mais irritantes de criar, precisa de &bPrismarinho&r, &2Escama de Tartaruga&r, &9Lápis-lazúli&r e um &3Coração do Mar&r. \\n\\nEspero que você goste de &2&lMA&r! \\n\\nEle combina com Elmos... muito provavelmente para dar Respiração ou Afinidade Aquática, mas não consigo fazer funcionar..."]
	quest.414A35A72AFB5FF5.title: "&9Prisma do Mar"
	quest.4160EC0860E9CA4C.quest_desc: ["&4&oUnbound&r foi criado em resposta aos jogos da Geração II terem o mesmo enredo da Geração I. \\\\n\\\\nMesma mecânica de FireRed, apenas novos &cPokemon&r e o mais importante, uma nova história! \\\\n\\\\nComo sempre, entregue seu &4Cartão de Treinador&r a um &4Associado de Treinador&r e você o receberá de volta configurado para &4&oUnbound&r."]
	quest.4160EC0860E9CA4C.title: "&4&oUnbound"
	quest.417B88FEB1B8F44E.quest_desc: ["Caramba, esses Suck! Literalmente! \\n\\nO Módulo de Vácuo sugará quaisquer itens na área definida e os moverá para o Buffer do Roteador. Semelhante ao Funil de Absorção. \\n\\nTambém pode ser usado com o Aumento de Experiência!"]
	quest.41877F44CD3D1EDB.quest_desc: ["A &#E3BC19Fornalha de Bronze&r funciona como uma comum, só que a grande diferença é que ela usa vapor e é duas vezes mais rápida."]
	quest.41877F44CD3D1EDB.title: "&fA &#ED9553Fornalha de Bronze"
	quest.418E0A23EC74F320.quest_desc: ["Uma máquina importante para seus futuros empreendimentos."]
	quest.418E0A23EC74F320.quest_subtitle: "Você gira minha cabeça..."
	quest.418E57E34FFC19E1.quest_desc: ["A Base de Laser de Minério é o Minerador de Vazio do &bIndustrial Foregoing&r, sendo capaz de conjurar minérios do nada. Lentes permitem que você favoreça uma cor específica de minério, como Azul para Lápis.\\n\\nA Base de Laser de Fluido produz Fluidos do nada ou de mobs específicos. Eles exigem que você use Lentes específicas. Mobs que são usados para produzir Fluidos sofrerão dano, então usar uma Câmara de Estase para isso é recomendado.\\n\\nBrocas a Laser fornecem progresso para a Base de Laser em sua área de trabalho."]
	quest.418E57E34FFC19E1.quest_subtitle: "Minerador de Vazio"
	quest.418E57E34FFC19E1.title: "Broca a Laser"
	quest.4194397DFD0199C2.quest_desc: ["Os &6Criadores Mecânicos&r podem ser usados para &6Criação Automática&r e Receitas maiores que a Grade de Criação 3x3, como a &6Roda de Esmagamento&r. \\n\\nColoque os &6Criadores Mecânicos&r na ordem necessária, então você precisará definir para qual direção os &eItens&r na receita vão. \\n\\nA direção é conhecida pelas setas na borda dos &6Criadores&r. Elas podem ser alteradas clicando com o botão direito nelas com uma &6Chave Inglesa&r! \\n\\nEntão, basta colocar &eItens&r nos &6Criadores Mecânicos&r com as Mãos ou automatizado com &eFunis&r. \\n\\nDepois disso, você pode fornecer &dPotência Rotacional&r a qualquer um dos &6Criadores Mecânicos&r (eles compartilham &dEngrenagens&r) para iniciar as Receitas. \\n\\nSe não estiver funcionando, verifique se todos os &eItens&r estão dentro, todas as setas estão na direção certa e se há &dPotência Rotacional&r suficiente."]
	quest.4194397DFD0199C2.title: "&6Criador Mecânico"
	quest.4195800B4D7631E2.quest_desc: ["Através do ritual da &6Compulsão Espectral de Eziveus&r, podemos combinar uma &7Estrutura de Buraco de Minhoca&r, 2 Quartzos e uma &3Enderpearl&r para obter nosso Buraco de Minhoca!"]
	quest.4195800B4D7631E2.title: "&6Buraco de Minhoca Estável"
	quest.419C808FE10DB496.quest_subtitle: "Balsa + Wenge"
	quest.419DD6FE84B91749.quest_desc: ["Ao coletar genes, você obterá uma porcentagem de uma característica. Você pode combiná-los em uma mesa de trabalho para somá-los, ou colocá-los em um Indexador de Genes para auto-combinar."]
	quest.419DD6FE84B91749.quest_subtitle: "O Combinador e Baú de Genes"
	quest.41A0BE357C8A74E1.quest_desc: ["O &9Vínculo de Fonte Alquímico&r produz Fonte a partir de frascos de poção adjacentes. \\n\\nA quantidade de fonte varia por poção e complexidade."]
	quest.41A0BE357C8A74E1.quest_subtitle: "Poder através de Poções"
	quest.41ABC09C798CA8BE.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.41B99DBD03EB74FF.quest_desc: [
		"Confie em mim, o Multibloco não está mentindo quando diz que foi aprimorado! \\n\\nEste pode ser automatizado para receber &9Entradas&r pelo Topo, e &6Saídas&r pelos Slots da Frente e de Trás. \\n\\nAlém disso, podemos adicionar Pré-aquecedores à sua Esquerda e Direita! \\n\\nTudo isso o torna muito mais rápido e, claro, mais eficiente!"
		"{@pagebreak}"
		"Finalmente um diferente! Você começará com uma base de 3x3x3 de &4Tijolos de Alto-forno Reforçados&r."
		"{image:atm:textures/questpics/immersive/immersive_blast1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_blast2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_blast3.png width:100 height:100 align:center}"
		"Então, coloque um Funil no Topo do Bloco do Meio."
		"{image:atm:textures/questpics/immersive/immersive_blast4.png width:100 height:125 align:center}"
		"Agora, clique com o botão direito no Bloco do Meio da 2ª camada com o &6Martelo de Engenheiro&r."
		"{image:atm:textures/questpics/immersive/immersive_blast.png width:100 height:150 align:center}"
	]
	quest.41B99DBD03EB74FF.title: "&l&4Alto-forno Aprimorado"
	quest.41BD497108CA109F.quest_desc: ["O Draconium Despertado vem da Criação por Fusão dos blocos. Os blocos podem ser desmontados em 9 Barras. Estas são as segundas Barras mais importantes no Draconic Evolution e muito necessárias para os Níveis Wyvern e Dracônico."]
	quest.41BD497108CA109F.title: "Draconium Despertado"
	quest.41C0948CD9D50322.quest_desc: ["Aqui você encontrará todas as recompensas que pode obter ao derrotar inimigos."]
	quest.41C0948CD9D50322.quest_subtitle: "Matando Todas as Coisas"
	quest.41C0948CD9D50322.title: "&eQuadro de Recompensas"
	quest.41C661E8630D0146.quest_subtitle: "&f5 &cde Dano de Ataque"
	quest.41C70F0873E14307.quest_desc: ["Há Árvores no Deserto! \\n\\nNão, espere, havia Árvores..."]
	quest.41CF7CAEE4F60CCD.quest_desc: ["Quando colocado no &cNether&r e recebendo &ePedra Luminosa&r, o Ninho de &ePedra Luminosa&r atrairá uma &eAbelha Luminosa&r."]
	quest.41CF7CAEE4F60CCD.quest_subtitle: "Atrai uma Abelha Luminosa no Nether"
	quest.41CF7CAEE4F60CCD.title: "&fNinho de &ePedra Luminosa"
	quest.41CFA175B69E6639.quest_desc: ["&cBosque do Desejo&r, não Poço. Não há água aqui, apenas uma estrutura na floresta. \\n\\nNo centro da estrutura haverá uma estrela caída. \\n\\nFaça um desejo! Ou minere o cristal com uma &bPicareta de Diamante&r. "]
	quest.41CFA175B69E6639.title: "&cBosque do Desejo"
	quest.41D0CC616B762F4C.quest_desc: ["Você pode jogar um &9Ovo de Gerador de Abelha Fluix&r e &8Pó de Entro&r na água para criar um Ovo de Gerador de Abelha Entro."]
	quest.41D0CC616B762F4C.title: "&fAbelha de Entro"
	quest.41D246E896BD791F.quest_subtitle: "Tier: &63"
	quest.41D539DA3B3EC287.quest_desc: [
		"Golias está subestimando esta Fonte de &6Mel&r. Pense em algo mais massivo ou enorme! \\n\\nA Fonte de &6Mel&r Golias é uma estrutura gigantesca com um Oceano de &6Mel Líquido&r dentro dela. \\n\\nVocê pode até passear dentro dela para encontrar uma tonelada de &6Cristais de Mel&r e &5Ametista&r."
		"{image:atm:textures/questpics/bumblezone/bumble_goliath.png width:200 height:100 align:center}"
	]
	quest.41D539DA3B3EC287.title: "Fonte de &6Mel&r Golias"
	quest.41DBE44D7AA0B623.quest_desc: ["A Mesa de Ajustes é como você adiciona esses aumentos ao seu equipamento de essência!"]
	quest.41E8550FC36ABCA5.quest_desc: ["Ferramentas do Infinito, chamadas assim por causa de sua capacidade de serem carregadas quase infinitamente. Aumentar o nível da ferramenta pode dar a tal ferramenta vantagens especiais. Ter &5Biocombustível&r nelas as tornará mais eficientes, consumindo o combustível em vez de energia quando usadas.\\n\\nExistem 7 níveis:\\nPobre\\nComum\\nIncomum\\nRaro\\nÉpico\\nLendário\\nArtefato\\n\\nPara saber mais sobre cada Ferramenta do Infinito, confira o Manual do Industrial Foregoing (para que eu não tenha que cobrir tantas ferramentas do infinito em uma missão)!"]
	quest.41E8550FC36ABCA5.title: "Ferramentas do Infinito"
	quest.41E8C93A44559E48.quest_desc: ["A &7Máquina do Paradoxo&r pode, por um preço alto de Poder e &aFluido do Tempo&r, tirar uma Captura de Blocos e Entidades na área designada; depois, ela pode duplicá-los. \\n\\nMuitos Blocos e Entidades estão na lista negra por configurações, então nada de duplicar Abelhas!"]
	quest.41FD145B911BD625.quest_subtitle: "Ovo de Invocação de Abelha de Prata no Fogo Espiritual"
	quest.41FD145B911BD625.title: "&fAbelha de Iesnium"
	quest.420FE84DEE12CCE0.quest_desc: ["A &eFornalha de Ouro&r é melhor que as de Ferro, com um tempo de cozimento de 120 Ticks.\\n\\nEla pode ser criada com uma &7Silver&r ou Fornalha de Ferro e é transformada em uma de &bDiamand&r!"]
	quest.420FE84DEE12CCE0.title: "&eFornalha de Ouro"
	quest.4211F29561F21643.quest_desc: ["A forma como a &9&lTurbina&r funciona é recebendo Vapor através das &9Portas&r, e esse Vapor moverá as &9Pás&r nos &9Rotores&r. \\n\\nAh, espere, eu provavelmente deveria te dizer como criar as partes internas da &9&lTurbina&r! \\n\\nOs &9Rotores&r serão colocados a partir do chão, no centro exato de nossas &9&lTurbinas&r. Cada &9Rotor&r pode conter 2 &9Pás&r. \\n\\nQuanto mais &9Pás &fe &9Rotores&r, mais larga ela se tornará. Não poderemos usar uma Base 5x5 com partes internas maiores. \\n\\nNo topo do nosso &9Rotor&r mais alto, colocaremos o &9Complexo Rotacional&r. Confie em mim, é importante!"]
	quest.4211F29561F21643.title: "Partes móveis"
	quest.421851D4D39910DB.quest_desc: ["Afeta a probabilidade da abelha perder seu ferrão sempre que atacar algo. Essa característica é menos importante em comparação com as 3 primeiras que mencionei, mas vou falar sobre ela mesmo assim. Existem 4 níveis disso: &aFraca&r, &9Normal&r, &dMédia&r, &cForte&r. &cForte&r é o que vou focar. Certas Abelhas, como Dracônicas, Obsidianas e algumas outras abelhas que talvez eu não tenha mencionado, naturalmente possuem resistência forte, permitindo que mantenham seu ferrão."]
	quest.421851D4D39910DB.quest_subtitle: "Uma das menos importantes..."
	quest.421851D4D39910DB.title: "&b&lResistência"
	quest.421954D7D46FAAD6.quest_desc: ["Os Estabilizadores do Núcleo de Energia... estabilizam? O Núcleo. Para os primeiros 4 Níveis de Núcleos, você precisa de apenas 4 Estabilizadores ao redor dele. Você também pode acessar a GUI do Núcleo através dos Estabilizadores. Se eles forem colocados muito perto do Núcleo ou nos lugares errados, ele dirá que está incorreto."]
	quest.421954D7D46FAAD6.title: "Estabilizadores do Núcleo de Energia"
	quest.421C02BBAF6616FC.quest_desc: ["Parabéns por encontrar um &6Sítio de Fósseis&r!... e agora? \\n\\nPegue (ou fabrique) um Pincel. Então, olhe para a &eAreia Suspeita &fou &7Cascalho&r e segure o botão direito. \\n\\nIsso pincelará os blocos suspeitos e revelará itens. Os itens são definidos a partir de tabelas de saque aleatório, como baús de masmorras. \\n\\nNo entanto, locais diferentes dão &6Fósseis&r diferentes."]
	quest.421C02BBAF6616FC.title: "&6&lArqueologia"
	quest.4221D6CDDF90DACB.quest_subtitle: "Tier: &b4"
	quest.423B8DA485C1308C.quest_desc: ["A &3Gasolina&r pode ser usada para fazer GLP."]
	quest.423B8DA485C1308C.quest_subtitle: "Gás, gás, gás"
	quest.423B8DA485C1308C.title: "Gasolina"
	quest.424B3E3B299D3999.quest_desc: ["O &8Medidor Conta-Gotas&r é uma ferramenta útil para esvaziar &cInventários Químicos&r. \\n\\nNa INTERFACE de uma &5Máquina&r, segure o &8Medidor Conta-Gotas&r e arraste-o sobre os &cQuímicos&r na &5Máquina&r. Então, basta clicar com o botão direito e ele removerá os &cQuímicos&r, adicionando-os ao &8Medidor Conta-Gotas&r. \\nEu devia ter especificado: não podemos recuperar esses &cQuímicos&r do &8Medidor Conta-Gotas&r clicando em qualquer &5Armazenamento Químico&r como um tanque ou limpando o &8Conta-gotas&r clicando com shift no ar."]
	quest.424B3E3B299D3999.title: "Medidor de &8Conta-Gotas"
	quest.425E375A9EC127EB.quest_desc: [
		"Os &6Trilhos Reforçados&r são a versão aprimorada dos &6trilhos&r normais! Eles são um pouco mais rápidos e não explodem."
		"{@pagebreak}"
		"1"
		"{image:atm:textures/questpics/railcraft/rail_reinforced1.png width:150 height:100 align:center}"
		"{@pagebreak}"
		"2"
		"{image:atm:textures/questpics/railcraft/rail_reinforced2.png width:150 height:100 align:center}"
		"{@pagebreak}"
		"3"
		"{image:atm:textures/questpics/railcraft/rail_reinforced3.png width:150 height:100 align:center}"
		"{@pagebreak}"
		"4"
		"{image:atm:textures/questpics/railcraft/rail_reinforced4.png width:150 height:100 align:center}"
	]
	quest.425E375A9EC127EB.title: "&6Trilhos Reforçados"
	quest.427014BDE06DE631.quest_desc: ["Tudo que eu acerto, pega Fogo!!!!!"]
	quest.427014BDE06DE631.quest_subtitle: "Mãos"
	quest.427014BDE06DE631.title: "&cManopla de Fogo&r"
	quest.42746659C66CF17F.quest_desc: ["A &6&oBiblioteca de Alexandria&r é uma &5Biblioteca de Encantamentos&r melhor. \\n\\nEla pode conter Níveis mais altos de &5Livros Encantados&r, mas ainda precisará do Nível do &5Livro&r para ser retirado nesse Nível. \\n\\nEla também conterá mais Pontos. A &5Biblioteca de Encantamentos&r pode conter 32768, enquanto a &6&oBiblioteca de Alexandria&r pode conter 1.1 Bilhão de Pontos de cada &5Livro&r! \\n\\nPara obtê-la, precisaremos &d&lInfundir&r a &5Biblioteca de Encantamentos&r. \\n\\nUse 4 &9Prateleiras de Sculk Tocadas pela Alma&f, 4 &9Prateleiras de Sculk Ecoantes&f, 1 &dEstante de Livro do End Dracônica&f, 5 &6Estantes de Estabilidade Revestidas de Geodo&r e uma Caveira de Esqueleto."]
	quest.42746659C66CF17F.quest_subtitle: "Imagine se Roma nunca tivesse queimado..."
	quest.42746659C66CF17F.title: "&6&oBiblioteca de Alexandria"
	quest.4274E777FB60BA28.quest_desc: ["Os &a&lCarregadores&r carregarão quaisquer &eItens&r no Jogador quando o Jogador pisar na &a&lAlmofada&r! \\n\\nObviamente, ele precisará de &aEnergia&r para funcionar. Podemos adicioná-la na parte de Trás ou de Baixo do &a&lCarregador&r. \\n\\nAssim que tiver &aEnergia&r, ele carregará cada &eItem&r em seu Inventário que pode conter uma Carga! \\n\\nNão importa de qual Mod seja! \\nEle priorizará os primeiros &eItens&r em seu Inventário e, uma vez que esteja cheio, carregará o próximo. \\n\\nA rapidez com que preenche os &eItens&r parece ser a mesma para cada &eItem&r."]
	quest.4274E777FB60BA28.title: "&a&lCarregador"
	quest.427516AA3E8C9442.quest_subtitle: "Enxada Versátil"
	quest.427A28BB6FEAAC6C.quest_desc: ["Pedaços de tamanho divertido de &6Bolotas&r perfeitos para lanchar e Fabricar nossas Tampas de Metal &6&lAllTheModium&r!"]
	quest.427A28BB6FEAAC6C.title: "&6Fragmentos de Bolota&r de Metal &6&lAllthemodium&r"
	quest.427B9C6D95885DE2.quest_subtitle: "Maçã Red Delicious + Azaleia Florida"
	quest.427BBEB1F24E9DEE.quest_desc: ["A maior parte do &5Pó Corrupto&r é facilmente automatizada. \\n\\n&4Fungo do Nether&r pode ser feito com qualquer fazenda automática. &cBlaze Powder&r e &3Fragmentos de Enderpearl&r podem ser feitos com o &b&lHNN&r. E os &bCristais Arcanos&r são mostrados em outra Missão. \\n\\nApenas o &5Aço Obsidiano&r precisará ser automatizado a partir do &b&lCrucible Rúnico&r."]
	quest.427BBEB1F24E9DEE.title: "&5Pó Corrupto"
	quest.427C3AFC0FF131CD.title: "Fluidos"
	quest.4281BCDCE233F65B.quest_desc: ["Estes podem ser encontrados em baús dentro de Cidades Ancestrais."]
	quest.4281BCDCE233F65B.quest_subtitle: "Baús da Cidade Ancestral"
	quest.42822B1E8A53D051.title: "&l&9Recompensa do Mundo Superior:&r&e Esqueletos"
	quest.4285510271B5223D.quest_desc: ["A &dCaixa de Engrenagens&r é útil para enviar &dPotência Rotacional&r em um monte de direções diferentes! \\n\\nA &dCaixa de Engrenagens&r normal terá 4 &8Eixos&r internos, em cada uma das Direções Cardeais: Norte, Leste, Sul e Oeste. \\n\\nOs outros &8Eixos&r corresponderão às Unidades de Velocidade e Estresse, mas também girarão em direções diferentes do &8Eixo&r original."]
	quest.4285510271B5223D.title: "&dCaixa de Engrenagens"
	quest.42951D14ADCD9332.quest_desc: ["Poderia me ver isso com purê de ervilhas e feijão com torrada, por favor, Governador?"]
	quest.42951D14ADCD9332.quest_subtitle: "Quer um Fish & Chips?"
	quest.42951D14ADCD9332.title: "Fish & Chips!"
	quest.4295C863C9A81F28.quest_desc: ["A Bobina de Tesla é uma defesa doméstica muito divertida e faminta por &cEnergia&r! \\n\\nPrimeiro, alimente-a com &cEnergia&r de qualquer uma de suas Portas. Então, dê um &4Sinal de Redstone&r para ligá-la, ou use uma &6Chave de Fenda de Engenheiro&r para deixá-la sempre ligada! \\n\\nUma vez ligada, ela estará ativamente usando &cEnergia&r e quando um Mob se aproximar, ela os Atordoará e os machucará! Ferir Mobs faz com que ela consuma mais &cEnergia&r. \\n\\nVocê pode clicar com Shift + botão direito com uma &6Chave de Fenda de Engenheiro&r para colocá-la em modo de baixo consumo. Ela consumirá menos &cEnergia&r, mas também terá menos Alcance e causará menos Dano!"]
	quest.429785E8F64929CE.quest_desc: ["Para chegar à Dimensão Starlight, você precisará encontrar Ruínas do Portal no Mundo Superior. \\n\\nLá você encontrará um Guardião do Portal, clique com o botão direito para iniciar uma conversa e desafiá-lo para um duelo! Cuidado, eles são muito difíceis. \\n\\nAssim que vencer o duelo, você receberá alguns Itens, sendo o Orbe da Profecia um deles. Clique com o botão direito no Portal com o Orbe para ativá-lo! Então, entre para chegar ao..."]
	quest.429785E8F64929CE.title: "O Guardião e o Portal"
	quest.429B5A81DF6C43FE.quest_desc: [
		"A &6Convocação Aberta de Odus&r é usado para trazer um demônio &cAfrit&r para dentro de um Porco. Como este ritual é realizado sem o uso de Giz Vermelho, ele é poderoso o suficiente apenas para invocar um demônio &9não vinculado&r."
		""
		"Em particular, este ritual criará um Piglin Zumbificado possuído por um &cAfrit&r, que dropará um pouco de Carne Demoníaca, usada para criar Giz Rosa."
		""
		"&4AVISO: VOCÊ PODE TER QUE FAZER ESTE RITUAL VÁRIAS VEZES PARA OBTER CARNE DEMONÍACA SUFICIENTE."
	]
	quest.429B5A81DF6C43FE.quest_subtitle: "Quão... Carnudo..."
	quest.429B5A81DF6C43FE.title: "&6Convocação Aberta de Odus"
	quest.42AAEC41F2BC2474.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_glacite.png width:100 height:150 align:center}"]
	quest.42AAEC41F2BC2474.title: "&bGlacita&r"
	quest.42CB494F72FA1FD1.quest_desc: ["Crie 6 &eColmeias&r ou &eNinhos de Abelha&r. Isso inclui as &eColmeias&r do &l&6Productive Bee's&r também!"]
	quest.42D173B9FF8D16E4.quest_desc: ["Procurando por opções de energia no início do jogo? Estas são boas maneiras de começar a gerar energia.\\n\\nElas não produzem uma tonelada de energia, mas geralmente são fáceis ou baratas de obter no início do jogo!"]
	quest.42D173B9FF8D16E4.quest_subtitle: "Energia Inicial"
	quest.42D173B9FF8D16E4.title: "&8&lOpções de Energia de Início de Jogo"
	quest.42D7C8CD8E6F5CD7.quest_desc: [
		"Ao usar uma &5Fruta do Coro&r em um &2Gerador&r, você suga as almas dos mobs que seriam gerados, restando apenas uma casca vazia do que eles costumavam ser. \\n"
		""
		"Os mobs perderão toda a sua &5IA&r, então basicamente agirão como um suporte de armadura. "
		""
		"Eles não podem te atacar, não podem se teletransportar, não podem se mover sozinhos. Eles apenas ficam lá, prontos para serem mortos... \\n"
		""
		"              &6Que empolgante!&r"
	]
	quest.42D7C8CD8E6F5CD7.quest_subtitle: "Mais inofensivos que um aldeão com medo"
	quest.42D7C8CD8E6F5CD7.title: "&fSem IA"
	quest.42F50CE7FE715583.quest_desc: [
		"Para aumentar a quantidade de stacks que seu armazenamento mágico pode conter, você precisará fazer &dEstabilizadores de Armazenamento&r."
		""
		"Uma vez feitos, eles devem apontar diretamente para a parte da Matriz Dimensional do seu Atuador de Armazenamento, não para a base. Eles podem estar a até 5 blocos de distância, mas precisam ter uma linha de visão limpa para a Matrix."
		""
		"Sempre que você quiser atualizar para um Stabilizer de tier superior, quebrá-lo não destruirá os itens dentro. No entanto, você não poderá adicionar mais itens ao seu armazenamento até que ele seja substituído ou atualizado."
		""
		"Abaixo está um exemplo de uma configuração simples!"
		""
		"{image:atm:textures/questpics/occultism/storageupgradeexample.png width:200 height:150 align:1}"
	]
	quest.42F50CE7FE715583.title: "&aAprimorando Nosso Armazenamento Mágico"
	quest.43021923E220CF68.quest_desc: ["Para arar Terra e transformá-la em Farmland, você precisará de uma Hoe."]
	quest.43021923E220CF68.quest_subtitle: "Espere até ter Máquinas para isso..."
	quest.43021923E220CF68.title: "O Planter"
	quest.43167C59036E79A7.quest_desc: ["O &8Tomo de Mineradores&r ajudará você em toda a sua Mineração. Ele dará &5Eficiência&f, &5Fortuna&f e &5Toque Suave&r. \\n\\nIsso funciona para Picaretas, Machados, Pás e até Enxadas! \\n\\nO &8Tomo dos Pescadores&r dará apenas &5Encantamentos&r de Vara de Pesca, e sim, há muitos."]
	quest.43167C59036E79A7.title: "&8Tomes de Ferramentas"
	quest.431C62A6F8ECB4EC.quest_desc: ["&7Aluminum Rod&r - 10 \\n&7Iron Rod&r - 16 \\n&8Steel Rod&r - 24 \\n&8Sawblade&r - 12 \\n&0Graphite Electrode&r - 30"]
	quest.431C62A6F8ECB4EC.title: "Munição de &5&lRailgun&r do &8&lIE&r"
	quest.43265FEF45846357.quest_subtitle: "Pomelo + Citron"
	quest.433117EEA55B6A54.quest_desc: ["Apenas um simples colocador de fluidos."]
	quest.436E4E3515BCCDE9.quest_desc: ["Com a &bCloud in a Bottle&r equipada, você pode apertar a Barra de Espaço duas vezes para dar um pulo duplo! Muito útil para parkour! \\n\\nTambém aumenta a altura de queda que você pode suportar, como as &dBunny Hoppers&r!"]
	quest.436E4E3515BCCDE9.quest_subtitle: "Cinto"
	quest.436E4E3515BCCDE9.title: "&bCloud in a Bottle&r"
	quest.437DB2CE10D33A08.quest_desc: ["Você precisará pegar um &6Colmeia de Pedra Luminosa&r e ir para o &cNether&r para capturar esta abelha!"]
	quest.437DB2CE10D33A08.title: "&fAbelha &6Luminosa"
	quest.437F4945AFBE0825.quest_desc: ["Quando você clica com o botão direito em um Importer ou Exporter, um menu aparece. O menu é principalmente para filtragem, digamos que você tenha um Variable Card configurado para Cobblestone, seu Exporter enviará apenas Cobblestone.\\n\\nHá um pequeno \"+\" à esquerda das variáveis quando você as insere, clicar nele abre outra GUI. Aqui você pode alterar as taxas de transferência para poder enviar itens/fluidos/energia &dINFINITOS&r, além de poder fazer outras coisas.\\n\\nNo canto superior esquerdo temos as configurações, que são, na maior parte, a mesma coisa que as configurações da interface."]
	quest.438F734D16DA9638.quest_desc: ["Nós temos nosso &aPolônio&r e o resto é o que já devemos ter! \\n\\nUma &2&lP.R.C.&r, &9Água&r e &dPó de Fluorita&r! \\n\\nCombine 1.000mB de &9Água&r com 1.000mB de &aPolônio&r e 1 &dPó de Fluorita&r para fazer 1 &aPastilha de Polônio&r e 1.000mB de &8Rejeito Nuclear&r. \\n\\nO &dPó de Fluorita&r pode ser feito como qualquer Pó de Metal: no &4&lTriturador&r, na &d&lCâmara de Enriquecimento&r ou até mesmo com um Martelo de Minério!"]
	quest.438F734D16DA9638.title: "&aPastilhas de Polônio!"
	quest.43A1BC20BB054A14.quest_desc: ["Glitterkelp cresce em Mares Ancestrais e Gelados. \\n\\nEles não fazem muito além de Brilhar e podem ser transformados em Torta!"]
	quest.43A5B83862D9E94C.quest_desc: ["O &bEye of Flame&r o levará para a &bBurning Arena&r para lutar contra o &b&lIgnis&r."]
	quest.43A5B83862D9E94C.title: "&bEye of Flame&r"
	quest.43C2B07AB25C708E.quest_desc: ["Versão aprimorada do Arco Wyvern."]
	quest.43C2B07AB25C708E.title: "Arco Dracônico"
	quest.43CDC28DC56BB3E2.quest_subtitle: "128.000mb"
	quest.43D83CFA824B0A70.quest_desc: ["O &9Mekanism&r tem uma opção de energia de fim de jogo que é difícil de superar. O &dReator de Fusão&r pode produzir até 80MRF/t, e se você quiser aprender a construí-lo, não deixe de conferir o capítulo de missões &aMekanism: &dReactors&r!"]
	quest.43D83CFA824B0A70.quest_subtitle: "Fusão, Ativar!"
	quest.43D83CFA824B0A70.title: "&9Mekanism: &dReator de Fusão"
	quest.43DB0CFC5F5B0967.quest_desc: ["O &aDosímetro&r mostrará quantas Unidades de SV de &aRadiação&r estão atualmente em você. \\nSim, em você. \\n\\nLembre-se que você pode ativá-lo e desativá-lo para liberar espaço no seu HUD!"]
	quest.43DB0CFC5F5B0967.quest_subtitle: "Peitoral"
	quest.43DB0CFC5F5B0967.title: "&aUnidade de Dosímetro"
	quest.43E8912CB307E421.quest_desc: ["Ótimo! Podemos armazenar coisas virtualmente, mas como vemos o que está na rede?\\n\\nPara acessar o sistema, você precisará fabricar uma &3Grade&r. Esta é a forma mais básica de 'Exibição' para os itens em sua rede.\\n\\nA &3Grade&r pode armazenar Itens, Fluidos, Energia, Fonte, Almas e Químicos."]
	quest.43E8912CB307E421.quest_subtitle: "Não saia da Grade"
	quest.43E8912CB307E421.title: "&3A Grade"
	quest.43EF5513A1C52A37.quest_desc: ["A &3Thermopneumatic Processing Plant&r será usada para fazer Plástico Derretido, basta bombear um pouco de GLP, Carvão e um pouco de calor."]
	quest.43EF5513A1C52A37.quest_subtitle: "Quanto mais longo o nome, melhor"
	quest.43EF5513A1C52A37.title: "Processamento Termopneumático"
	quest.43FD4AEBB9548E57.quest_desc: [
		"A Smogstem Forest é um Bioma vizinho aos Indigo Mushroom Bogs. \\n\\nClaro que também é Azul e tem Cogumelos Indigo! Só que tem Árvores Smogstem maiores!"
		"{image:atm:textures/questpics/undergarden/undergarden_smogstem.png width:200 height:100 align:center}"
	]
	quest.43FD4AEBB9548E57.title: "Smogstem Forest"
	quest.440B1E1D4951F808.quest_desc: [
		"O &3Smart Chest&r é um Baú à prova de explosão com 72 slots, inclui um Hopper Omnidirecional embutido e totalmente configurável e possui slots de atualização. Não pode ser transformado em Baú Duplo. Também funciona como uma Shulker Box."
		"{image:atm:textures/questpics/pneumaticcraft/smart_chest_ui.png width:200 height:100 align:center}"
	]
	quest.440B1E1D4951F808.quest_subtitle: "O Nerd dos Baús"
	quest.440B61C517B8BD09.quest_desc: ["Com um pincel, podemos descobrir itens da Areia Suspeita em &eSítios Arqueológicos&r. \\n\\nDois itens raros que podemos obter são as Pedras Brilhantes de Luz e Escuridão. \\n\\nNão há diferença entre elas além dos &eAnéis&r que elas fabricam. Os &eAnéis&r apenas mudam a aparência, não o efeito ou habilidade."]
	quest.4415C9F8DA2D7E68.quest_desc: ["Com Cyanite, podemos criar o coração da Turbina, o &9Turbine Controller&r.\\n\\nTurbinas são estruturas multibloco, assim como os Reatores! Elas recebem vapores como &7Vapor&r feitos por Reatores &dResfriados Ativamente&r para criar TONELADAS de energia! Precisaremos de algumas outras peças para poder construir nossa primeira.\\n\\nNota: Peças de Turbina básicas só podem ser usadas para construir uma Turbina de tamanho máximo de 5x5x10. Para construir uma Turbina maior, você deve usar &aPeças de Turbina Reforçadas&r."]
	quest.4415C9F8DA2D7E68.title: "Fabricando Turbinas"
	quest.441C0659ED28D935.quest_desc: ["Glifos de Tier 1 requerem 3 níveis de experiência para serem feitos."]
	quest.441F37A95AB66E6B.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.442227B0C475A142.quest_desc: ["Como quer que você as consiga... você precisará de 2. \\n\\nDesculpe! Eu deveria ter avisado antes."]
	quest.442227B0C475A142.title: "&7Bases de Bola&r de Metal &6&lAllthemodium&r"
	quest.442B1A1900BADAFC.quest_desc: ["Algumas Máquinas no &8&lIE&r не são Multiblocos, mas sim de um único bloco! \\n\\nNão pense que, só porque são feitas com 1 Bloco, não são importantes!"]
	quest.442B1A1900BADAFC.title: "Máquinas Pequenas"
	quest.4447EEEB8D762721.quest_desc: ["As &4Unidades de Dissipação de Laser&7 irão aprimorar a &a&lMekaArmadura&r. Bem, cada peça dela. \\n\\nEm vez de te matar instantaneamente ao entrar em &4Lasers&r, eles não causarão Dano algum! \\n\\nUma pequena parte do &4Laser&r na verdade vai passar direto por você! Mas não toda."]
	quest.4447EEEB8D762721.quest_subtitle: "Toda a Armadura"
	quest.4447EEEB8D762721.title: "&4Unidade de Dissipação de Laser&7"
	quest.4458F8829800A950.quest_desc: ["Polymorphic Fluid é a base de todos os Fluidos / Combustíveis no JDT. O Polymorphic Fluid é criado jogando Polymorphic Catalyst na água."]
	quest.445C9117198936B6.quest_desc: ["A &4Wither Assault Shoulder Weapon (W.A.S.W.)&r é a última arma que você pode fazer com &4Witherite&r. \\n\\nEla tem 2 projéteis diferentes que pode disparar: &4Wither Missiles&r e &4Wither Howitzers&r. \\n\\nOs &4Wither Missiles&r são disparados apenas segurando o botão direito do mouse e danificarão qualquer coisa que for atingida por eles, com baixo tempo de recarga. \\n\\nOs &4Wither Howitzers&r são disparados quando você segura Shift e o botão direito do mouse, eles danificam uma área maior e deixam uma área de Efeito Wither, que danifica qualquer coisa que entre nela. Eles têm um tempo de recarga muito maior, no entanto."]
	quest.445C9117198936B6.title: "&4W.A.S.W. (Wither Assault Shoulder Weapon)"
	quest.445CC9AAA6F8AAB6.quest_desc: [
		"Para o próximo Tier de &lProcessamento de Minério&r, precisaremos de &l&bPurificadores&r e eles precisarão de &bOxigênio&r. Então, vamos produzir um pouco de &bOxigênio&r! \\n\\nUse uma &9&lBomba Elétrica&r ou qualquer &9Água&r Automatizada para alimentar &9Água&r em um &9&lSeparador Eletrolítico&r. \\n\\nUma vez alimentado com &aEnergia &fe &9Água&r, o &9&lSeparador Eletrolítico&r transformará essa H2O em H (Hidrogênio) e O (&bOxigênio&r)! \\n\\nPodemos despejar o &bHidrogênio&r e canalizar o Oxigênio para o &b&lPurificador&r. \\n\\nAgora que o &b&lPurificador&r tem &bOxigênio&r, podemos colocar nossos &7Minérios&r nele para obter 3 &7Aglomerados de Minério&f a partir de &7Blocos de Minério&f ou 2 &7Aglomerados de Minério &f a partir de &7Minério Bruto&r."
		"{image:atm:textures/questpics/mek/mek_tier2_1.png width:100 height:100 align:center}"
	]
	quest.445CC9AAA6F8AAB6.quest_subtitle: "Processamento de Minério Tier 2"
	quest.445CC9AAA6F8AAB6.title: "Fazendo &bOxigênio &fpara a &b&lPurificação"
	quest.44688FC2E34FF09F.quest_desc: ["O Minecraft já adiciona centenas de Blocos, e os Mods adicionam mais centenas! Mas às vezes ainda não é o suficiente. \\n\\nCom alguns Mods podemos mudar os Blocos que já temos em outros com diferentes formas, designs e até mesmo em Blocos totalmente novos!"]
	quest.44688FC2E34FF09F.title: "&fMudando Blocos"
	quest.446A37C7FCDACF84.quest_desc: ["Voidflame Coal é um novo material adicionado por JDT. Voidflame é adquirido realizando a Propagação de Gosma em Blocos de Brasa de Blaze usando gosma de nível três ou superior. O Minério de Voidflame Coal é afetado por fortuna."]
	quest.447CAC472A99835B.quest_subtitle: "Surge de um Ninho de Neve"
	quest.447CAC472A99835B.title: "&fAbelha de Suor"
	quest.447F3DCAB7F60641.quest_desc: ["O &6Bloco de Pastagem&r funciona lado a lado com o &9PC&r. Só que este permite que seus &cPokemon&r vagueiem por uma certa área! \\n\\nVocê pode mover até 16 &cPokemon&r para uma &6Pastagem&r. Eles então andarão pela área ao redor da &6Pastagem&r. \\n\\n&cPokemon&r vagando Atacarão Mobs Hostis ou Mobs que você Atingir. \\n\\nSe um &cPokemon&r Desmaiar, ele retornará ao &9PC&r."]
	quest.447F3DCAB7F60641.title: "&6Bloco de Pastagem"
	quest.4485C4ABD57874EB.quest_desc: ["&b&lApplied Energistics&r não é um Mod de Armazenamento, é &lO&r Mod de Armazenamento. \\n\\nEu pessoalmente não sei muito sobre o Mod, mas a página de Missões deve ajudá-lo a aprendê-lo!"]
	quest.4485C4ABD57874EB.title: "&b&lApplied Energistics"
	quest.44881E39AB1D62AA.quest_desc: ["O &3Auto-fabricador&r é como armazenamos Padrões para que nossa rede saiba como criar itens. Uma vez que uma receita é colocada na máquina, você poderá 'Solicitar' a criação de um item a partir da sua &3Grade&r. Você pode fazer isso pressionando Control + Shift enquanto clica no item para o qual você tem uma receita para abrir a interface de criação.\\n\\nEste bloco também pode ser colocado de frente para uma máquina para usar &6Padrões de Processamento&r. Por exemplo, se você apontar o &3Auto-fabricador&r para uma Fornalha, você pode colocar uma receita dentro para uma receita que precise de uma Fornalha, como fundir Processadores Brutos. Contanto que o &3Auto-fabricador&r esteja conectado ao seu sistema e a Fornalha tenha um Importador conectado a ela, o Crafter permitirá que você solicite a versão fundida do Processador!"]
	quest.44881E39AB1D62AA.quest_subtitle: "Criação automatizada!"
	quest.44881E39AB1D62AA.title: "&3Auto-fabricador"
	quest.44B22160850ACAB2.quest_desc: ["Sementes de Nether Star requerem um Nether Star Crux colocado abaixo para poderem crescer."]
	quest.44B22160850ACAB2.quest_subtitle: "Tier: &56"
	quest.44D5EDB8711EC7A0.quest_desc: ["O &2&lVanilla&r não poderia ter toda a diversão com Maças! Então é claro que existe uma melhoria de &6Allthemodium&r para elas! \\n\\nMelhore uma Maça com um &6Bloco de Allthemodium&r para obter a &6Maça de Allthemodium&r. \\n\\nEla causa mais dano base, mais dano de queda e tem os mesmos Encantamentos!"]
	quest.44D5EDB8711EC7A0.title: "&6Maça de Allthemodium"
	quest.44DA091B53473723.quest_desc: ["O Mechanical Squeezer usa energia para espremer."]
	quest.44F63C35341C3198.quest_desc: [
		"A &6Serra Mecânica&r funciona como a maioria das Máquinas do &6&lCreate&r. \\n\\nDê a ela &dEnergia Rotacional&r, e quaisquer Itens que passarem por ela serão fatiados ao meio."
		"{@pagebreak}"
		"A &eSerraria de Precisão&r é uma Máquina de fábrica do &5&lMekanism&r. \\n\\nEla é muito fácil de usar! Coloque um pouco de &cEnergia&r nela, depois coloque a &6Bolota&r na Máquina, e ela as fatiará e picará em &6Meias Bolotas&r!"
		"{@pagebreak}"
		"A &8Linha de Montagem&r precisará de várias Máquinas para funcionar: Controlador de Montagem, Laser, Unidade de Importação, Unidade de Exportação e Plataforma de Montagem. \\n\\nTodas as Máquinas precisarão estar uma ao lado da outra conectadas para funcionar. \\n\\nO Controlador é o que recebe Pressão. A Unidade de Importação precisará de um inventário próximo para retirar itens, e a Unidade de Exportação precisará de um Baú para colocar os Itens. Se tudo estiver funcionando, dirá que está rodando. Se não, o Controlador indicará o problema!"
		"{@pagebreak}"
		"A &cForja de Fragmentos&r, como todas as fábricas gananciosas da &6&lOritech&r, precisará de Revestimentos de Máquina para ser feita. \\n\\n3 para ser exato. Depois que você tiver os 3 Revestimentos de Máquina e a &cForja de Fragmentos&r colocados, Clique com o Botão Direito na Forja para montá-la. \\n\\nEntão, fica muito mais fácil, apenas energize-a e jogue suas &6Bolotas&r dentro!"
		"{@pagebreak}"
		"Por último está o &dCortar Glifo&r. \\n\\nPrimeiro, use qualquer Formula de Feitiço que desejar. Toque, Raio, Projétil, Míssil, o que for! \\n\\nDepois, selecione o &dCortar Glifo&r e adicione Sensitivo a ele. Isso permitirá que o &dCortar&r funcione em Itens dropados. \\n\\nEntão agora você pode jogar suas &6Bolotas&r no chão, acertá-las com o Feitiço, e ele magicamente as cortará."
	]
	quest.44F9B8F285546B2C.quest_desc: ["O &bMusgo Florido&r vem das... você adivinhou! Das &bCavernas Floridas&r! \\n\\nEle aparecerá no chão apenas esperando que você o colete. \\n\\nEles não se espalham como &2Musgo&r normal nem têm nenhuma Receita."]
	quest.44F9B8F285546B2C.title: "&bMusgo Florido"
	quest.44FEE957BD333241.quest_subtitle: "Lima Prateada + Cereja Azeda"
	quest.450EDE68EC992A5A.quest_desc: ["Interfaces &cleem&r o que quer que estejam olhando. Você pode pensar nisso como uma &bAE2&r Storage Bus.\\n\\nNão sabe o que é isso? Aqui vai um exemplo: Um baú com 100 Cobblestones tem uma interface conectada a ele, isso significa que sua rede ID tem 100 Cobblestones no sistema, bem simples, certo?"]
	quest.450EDE68EC992A5A.quest_subtitle: "Interfaces Têm GUIs!"
	quest.4510FD92BACF00FF.quest_subtitle: "Ameixa + Castanha-doce"
	quest.45135F112E05F9B5.quest_desc: ["A &4&oSérie&r ainda não acabou! Você precisará de uma revanche com a &3Elite dos Quatro&r e a &5Campeã Cynthia&r. \\n\\nVocê só pode encontrá-los em seus biomas, confira o &4Cartão de Treinador&r! \\n\\nDerrotar &3Aaron&r aumentará seu Nível para 71. \\n&3Bertha&r para 73. \\n\\n&3Flint&r para 75. \\n\\n&3Lucian&r para 78. \\n\\nE a &5Campeã Cynthia&r para 79."]
	quest.45135F112E05F9B5.title: "Revanche da &3Elite dos Quatro&r e &5Campeã&r"
	quest.45161821C221EF0B.quest_desc: ["Assim que tivermos essas 15 &4Estante de Livro Infernais&r ao redor da nossa &5Mesa de Encantamento&r, teremos &a45 Eterna&r e &c30% Quanta&r na nossa &5Mesa&r. \\n\\nEsta é a quantidade perfeita para &d&lInfundir&r nossas &4Estante de Livro Infernais&r! \\n\\nAs &4Estantes Infernais Infundidas&r dão &a5 Eterna&r com um máximo de &a60 Eterna&r, junto com &c5% Quanta&r. \\n\\nElas podem ser Fabricadas com outros Itens para fazer diferentes &7Estantes de Livros&r, para as que queremos, precisaremos de 12 &4Estantes Infernais Infundidas&r! \\n\\nClaro, como sou muuuito generoso, você só precisará coletar 8!"]
	quest.45161821C221EF0B.title: "&4Estantes Infernais Infundidas"
	quest.45268A619787288F.title: "&eMochila de Ouro"
	quest.4526E151BAE88310.quest_subtitle: "Tier: &e1"
	quest.452DC5EB02D592B8.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_amethyst.png width:100 height:150 align:center}"]
	quest.452DC5EB02D592B8.title: "&5Ametista&r"
	quest.452EF09F6CB4AD99.quest_desc: ["&cRelays&r não conectam &cFios&r a Máquinas, mas sim conectam &cFios&r a mais &cFios&r! \\n\\n&cRelays&r funcionam combinando um monte de &cFios&r em um só lugar, então ele pegará toda a &9Energia&r de &cEntrada&r e a enviará para &cConectores&r para todas as &6Saídas&r conectadas. \\n\\nIsso é útil para quando você tem um Gerador de Energia que deseja carregar várias Máquinas!"]
	quest.452EF09F6CB4AD99.title: "&cRelays"
	quest.4530C14828C3D153.quest_subtitle: "Tier: &b4"
	quest.454662617304E299.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Permite que o jogador passe através de blocos quando aplicado às calças. Existe uma tag de bloco para adicionar blocos à lista negra, impedindo que sejam atravessados."
		"Quando aplicado a um arco, permite que as flechas atravessem paredes."
	]
	quest.454AC491FDFC3FDB.quest_desc: [
		"Diferente da maioria dos Mobs cúbicos, os &6Slimes de Mel&r são amigáveis! \\n\\nEles podem ser reproduzidos com Açúcar e podem ser... ordenhados? Com garrafas para &6Garrafas de Mel&r. Eles ficarão agressivos se você os ordenhar, a menos que você tenha a Essência de Abelhas. \\n\\nAo morrer, eles dropam Açúcar. \\n\\nVocê pode encontrá-los em algumas estruturas, &bLagos de Açúcar&r, ou às vezes ao criar &6A&8b&6e&8l&rhas em Blocos de Cria."
		"{image:atm:textures/questpics/bumblezone/bumble_slime.png width:100 height:100 align:center}"
	]
	quest.454AC491FDFC3FDB.quest_subtitle: "Sem Slimes de Geleia Real?"
	quest.454AC491FDFC3FDB.title: "&6Slimes de Mel"
	quest.454CA1F8CC198D9D.quest_desc: [
		"Melhorias Válidas:"
		"- Step Assist"
		"- Jump Boost"
	]
	quest.45549E52B3CE2D23.quest_desc: ["Foices são ferramentas que podem cultivar grandes áreas de plantações de uma só vez. Elas também podem ser usadas como uma arma razoavelmente boa."]
	quest.45647395169978ED.quest_desc: ["Para obter &9Pó de Gema&r, você precisa de uma &aGema&r do &6&lApotheosis&r e uma &7&lBigorna&r. \\n\\nQualquer &aGema&r do &6&lApotheosis&r (Recomendado apenas &8Comuns &fe &aIncomuns&r)! \\n\\nAssim que obter suas &aGemas&r, esmague-as com uma &7&lBigorna&r em queda! \\n\\nEntão, você pode usar seu &9Pó de Gema&r para Criar uma &c&lMesa de Desmanche&r."]
	quest.45647395169978ED.title: "&9Pó de Gema"
	quest.4564B577CB4EC046.quest_desc: ["Ao abater centenas de Vacas, você pode encontrar um Bife Raro. Não um com a Doença da Vaca Louca, quero dizer o &cEverlasting Beef&r!\\n\\nO &cEverlasting Beef&r pode ser comido como um Bife Cru normal, mas não será deletado quando consumido! Em vez disso, terá um tempo de recarga antes que você possa comê-lo novamente.\\n\\n(Também funciona com mochilas de alimentação automática!)"]
	quest.4564B577CB4EC046.quest_subtitle: "Único"
	quest.4564B577CB4EC046.title: "&cEverlasting Beef&r"
	quest.45686EA3EC85C958.quest_desc: ["Para desbloquear &4&oUnbound&r você precisará derrotar &4&oRadical Red&r ou &4&oBDSP&r. \\\\n\\\\nEstas são duas &4&oSéries&r que vêm antes de &4&oUnbound&r. O &4Associado de Treinador&r não oferecerá &4&oUnbound&r até que uma delas seja concluída. \\\\n\\\\nIsso mesmo, você não precisa terminar ambas, apenas uma!"]
	quest.45686EA3EC85C958.title: "Derrote &4&oBDSP"
	quest.4568C2F465EDB960.quest_desc: ["Droopfruit pode aparecer em praticamente qualquer Bioma, é só olhar para cima! \\n\\nElas aparecem no teto da maioria dos Biomas e crescerão de forma semelhante às Glowberries."]
	quest.456B9DD108CF340F.quest_desc: ["Torna as coisas mais rápidas."]
	quest.456B9DD108CF340F.quest_subtitle: "Veloz!"
	quest.457CAE66B0FA4CCF.quest_desc: ["Todos os Minérios &2Vanilla&r podem ser encontrados com a Vareta de Adivinhação de Diamante. Sendo capaz de encontrar todos, mais Netherita!"]
	quest.457DE8C154641437.quest_desc: ["O &9Ritual Brazier&r é usado para lançar rituais. Também pode ser usado para decoração. Se você quiser acender o Braseiro, use um feitiço de Luz nele. \\n\\nPara realizar rituais, você também precisará de Pedestais Arcanos. Como há tantos rituais para lançar, certifique-se de verificar cada um deles usando o &6Caderno Gasto&r! \\n\\nIsso pode ser feito segurando Ctrl na Mesa Ritual com o livro em seu inventário."]
	quest.458265FCD6B3068E.quest_desc: ["Todo mundo amava as Estações de Criação do &lTinker's Construct&r e, aparentemente, os desenvolvedores do &8&lIE&r também! \\n\\nA &6Engineer's Crafting Table&r agirá como uma Bancada de Trabalho normal, com 18 Slots de Armazenamento adicionais, e ainda mantém seus &eItens&r na Grade quando você para de visualizá-la! \\n\\nO que mais você poderia querer!"]
	quest.458265FCD6B3068E.title: "&6Engineer's Crafting Table"
	quest.45899579D9B92D91.quest_desc: ["O &aControlador&r é o coração da &c&lFundição&r. \\n\\nCada &c&lFundição&r precisará de pelo menos 1 para ser feita. \\n\\nPodemos usar a &c&lFundição&r para visualizar a INTERFACE da &c&lFundição&r. Aqui podemos ver as quantidades de Líquidos dentro da &c&lFundição&r. \\n\\nTambém podemos usá-la para colocar e tirar Itens da &c&lFundição&r."]
	quest.45899579D9B92D91.title: "&aControlador&r da &c&lFundição"
	quest.458BFDB636F8B495.quest_desc: [
		"Combinar o &6Pó de Coque&r com &8Ferro&r resultará em &8Pó de Aço Cru&r. "
		""
		"Cozinhá-lo na &eFornalha a Vapor&r gerará &8Barras de Aço&r necessários para o progresso futuro."
	]
	quest.458BFDB636F8B495.title: "&fPó de Aço Cru"
	quest.4597D3B3BDC2BED5.quest_desc: ["O &bMontador Molecular&f é o equivalente do AE2 a uma mesa de trabalho automática, necessária para cumprir todos os trabalhos de padrões de &ecriação&f.\\n\\nMontadores Moleculares são capazes de transferir energia e canais para outros dispositivos ME conectados a ele, mas não ocuparão um canal. Até 6 &6MM's&r podem ser conectados a um único Provedor de Padrões (se empregado) para permitir que mais criações sejam feitas em paralelo.\\n\\n&6MMs&r também têm cada um seu próprio slot dedicado para um único padrão de criação, permitindo que funcionem de forma autônoma quando energizados. Quando operados desta forma, quaisquer itens correspondentes inseridos no MA serão automaticamente criados no resultado do padrão."]
	quest.4597D3B3BDC2BED5.title: "&fMontador Molecular"
	quest.45996B848792379E.quest_desc: ["Você pode Minerar &dCristais de Sal Ammoniac&r no &2Mundo Superior&r, mas não é tão fácil. Ainda precisaremos de &9Água&r e das Máquinas para fazer &dSal Ammoniac&r para fazer &eAlchemical Sulfur&r. \\n\\nOs &dCristais&r são opcionais, mas ajudam muito; com apenas Água, 1000mb serão transformados em 100mb de &dSal Ammoniac&r. Com 1000mb de &9Água&r e um &dCristal de Sal Ammoniac&r, obteremos 1000mb de &dSal Ammoniac&r. \\n\\n10 vezes a produção com apenas um Item a mais!"]
	quest.45996B848792379E.quest_subtitle: "Por que precisamos de Máquinas se podemos apenas Minerar?"
	quest.45996B848792379E.title: "Por que Máquinas?"
	quest.459AEC4C2A611824.quest_desc: ["Para todos os Jogadores que não trapaceiam usando Pacotes de Recursos de &aVisão Noturna&r, isto pode ser útil! \\n\\nEsta &7Unidade de Módulo&r lhe dará &aVisão Noturna&r quando você usar o &a&lCapacete do Meka-Traje&r. \\n\\nEmbora, sim, muitos &eItens&r tornem isso inútil, eu ainda vou falar sobre isso para você!"]
	quest.459AEC4C2A611824.quest_subtitle: "Capacete"
	quest.459AEC4C2A611824.title: "&aUnidade de Aprimoramento de Visão"
	quest.459BA85E48B343AE.quest_desc: ["O &aChassi Radial&r funciona de forma semelhante ao &aChassi Linear&r ao se conectar a outros &aChassis Radiais&r, mas todo o resto muda. \\n\\nVocê pode conectar outros &aChassis Radiais&r na parte superior ou inferior de outros e eles se conectarão automaticamente. \\n\\nEntão, &aCole&r os lados do &aChassi Radial&r para &aColar&r todos os Blocos dentro de um Raio definido do &aChassi&r. A propósito, Raio significa círculo! \\n\\nVocê pode alterar a distância do círculo com uma &6Chave Inglesa&r no &aChassi Radial&r."]
	quest.459BA85E48B343AE.title: "&aChassi Radial"
	quest.459BB5B4CDB21773.quest_desc: ["&9Prata do Pântano&r é encontrada na lama dos pântanos de &5&lEternal Starlight&r."]
	quest.459BB5B4CDB21773.quest_subtitle: "15"
	quest.459BB5B4CDB21773.title: "Armadura de &9Prata do Pântano"
	quest.45A25221F54A1DEC.quest_desc: ["A Ferricore Wrench permite ao jogador girar máquinas, mas também é usada para conectar trocadores."]
	quest.45C9D975E3731DFE.quest_desc: ["O &9Fragmento de Eco Reforçado&r é um Item fabricado que requer alguns Itens. \\n\\nPrimeiro, e mais fácil de obter, são as &7Membranas de Phantom&r! &7Phantoms&r surgirão depois que o Jogador não dormir por alguns dias. Quanto mais noites sem dormir, mais &7Phantoms&r! \\n\\nSegundo, é o &9Fragmento de Eco&r. Estes podem ser encontrados de várias maneiras, mas a mais fácil é saqueando nas &6Cidades Ancestrais&r. \\n\\nO último são as &9Carapaças do Warden&r. São drops do &9&lWarden&r ao morrer. Não se preocupe, ele geralmente dropa mais de uma!"]
	quest.45C9D975E3731DFE.title: "&9Fragmento de Eco Reforçado"
	quest.45D1FFB263CD722D.quest_subtitle: "Teca + Cravo-da-índia"
	quest.45D683D7F1A32B04.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Permite que a ferramenta minere blocos instantaneamente."
	]
	quest.45EC31812FB9934D.quest_desc: ["&aPistões Mecânicos&r agem como Pistões normais movendo Blocos, mas depois disso as semelhanças terminam! \\n\\nEles não funcionam com &4Redstone&r, em vez disso, usam &dPotência Rotacional&r. A &dPotência Rotacional&r determinará a velocidade e a direção em que o Pistão se move. \\n\\nEles também podem ter &aBolas de Slime&r adicionadas para &aGrudar&r em Blocos. E esses Blocos podem ser &aColados&r para que tudo se mova com o Pistão. \\n\\nA melhor parte é que podemos adicionar &aVaras de Extensão de Pistão&r na parte de trás do &aPistão&r para alterar a distância que o &aPistão&r pode se mover! \\n\\nCada nova &aVara&r adiciona um novo Bloco de distância. Não tenho certeza do máximo que você pode adicionar, talvez isso seja algo que você possa descobrir por si mesmo!"]
	quest.45EC31812FB9934D.title: "&aPistões Mecânicos"
	quest.45EE60207C466D6C.quest_desc: ["Para entrar no Draconic Evolution, você precisará de Fragmentos do Caos. Os Fragmentos do Caos estão nas Ilhas do Caos, guardados por Guardiões do Caos no End. Vá para o End em uma coordenada X/Z que seja um múltiplo de 10k. 10k, 10k / 10k, 20k / 20k, 20k etc."]
	quest.45EE60207C466D6C.quest_subtitle: "Encontrando a Ilha do Caos"
	quest.45EE60207C466D6C.title: "Onde ele está?"
	quest.45F83C2750F70F9B.quest_desc: ["Vá em frente, coloque um Livro em uma Fornalha e derreta-o."]
	quest.45F83C2750F70F9B.quest_subtitle: "Totalmente não vai pegar fogo..."
	quest.45F83C2750F70F9B.title: "Fazendo uma Cozinha, com um Livro"
	quest.45FBEABEBA7CC09E.quest_desc: [
		"Quem sabe o que aconteceu para trazer essa &5Cidade&r para debaixo da &9Água&r, mas claramente está lá! Você perceberá facilmente pelos Tijolos de Pedra saindo da &9Água&r. \\n\\nA primeira e maior sala é o Centro da Cidade, a enorme cúpula! É aqui que está o &5Altar do Abismo&r. \\n\\nA partir das salas você encontrará corredores que levam a outros prédios na &5Cidade&r. Prisões com &5Coralussus&r e até Salas de Tesouro com toneladas de Loot preciosos! \\n\\nPor toda a &5Cidade&r você encontrará seus habitantes, os &5Deeplings&r. "
		"{image:atm:textures/questpics/cataclysm/cataclysm_city.png width:200 height:100 align:center}"
	]
	quest.45FBEABEBA7CC09E.title: "&5Cidade Submersa&r: Lar do &5&lLeviatã&r"
	quest.45FF08E4DB6F7F0E.quest_desc: ["O Auto-fabricador Elite tem 18 espaços para Padrões e funciona 2x mais rápido."]
	quest.460A8F17F3ED6CAF.quest_desc: ["Chega um ponto em qualquer jogatina de um grande modpack em que mesmo o maior nível padrão de célula de armazenamento não é suficiente para a quantidade de itens e recursos que você pode estar acumulando.\\n\\nÉ aqui que o add-on &dMEGA Cells&f entra, estendendo os níveis de armazenamento disponíveis para o território dos megabytes. O primeiro desses novos níveis é dado pelo &b1M MEGA Storage Component&f, fornecendo 1024 &oquilo&rbytes, ou &e1048576&f bytes, de armazenamento."]
	quest.460A8F17F3ED6CAF.quest_subtitle: "O primeiro MEGAbyte."
	quest.460A8F17F3ED6CAF.title: "&5Componente de Armazenamento de 1M"
	quest.461C8F1E88AA58D9.quest_desc: [
		"Estes podem ser usados em receitas que utilizam a versão em balde dos líquidos do PneumaticCraft.\\n\\nQuando um &3Tanque de Fluido&r é colocado em cima de outro &3Tanque de Fluido&r e unidos com uma chave inglesa, eles se tornam um grande tanque.\\n"
		"{image:pneumaticcraft:textures/patchouli/small_tanks.png width:250 height:250 align:center fit:true}"
	]
	quest.461C8F1E88AA58D9.quest_subtitle: "32.000mb"
	quest.462C1F75A2FB9F02.quest_subtitle: "Cadê o Willy?"
	quest.462D173D576A8D91.quest_desc: ["&eMetal Ancestral&r é um Drop de praticamente tudo dentro da &ePirâmide Amaldiçoada&r! \\n\\nComo outras Barras, pode ser Criado a partir de Pepitas ou Blocos e vice-versa. \\n\\nVocê pode usá-lo para fazer &eArmadura de Réptil de Osso&r ou a &eLança Ancestral&r."]
	quest.462D173D576A8D91.title: "&eMetal Ancestral"
	quest.46342661700839E0.quest_desc: ["A &bPedra do Amanhecer &firà &bEvoluir&r &dKirlia &fpara &dGall&4ade&r e &bSnorunt&f para &bFros&5lass&r."]
	quest.46342661700839E0.title: "&bPedra do Amanhecer"
	quest.4638F21544D6D337.title: "Túnel de Energia Quântica Entrelaçada ao Caos"
	quest.4646DCF463FD913F.quest_desc: ["Mate o Wither com a Lança Ferrão. \\n\\nTente usar o Portal de Saída do End para facilitar isso."]
	quest.464DDEAF167BD0D5.quest_subtitle: "&f9 &cde Dano de Ataque"
	quest.46567ED894E9883C.quest_desc: [
		"É aqui que a diversão começa! \\n\\nUse 4 Barras de &6Deorum&r, 4 &bCristais Arcanos&r e uma &9Pedra Sombria Polida Cinzelada&r para atualizar do &3&lTier 2&r para o &e&lTier 3&r. \\n\\nAgora podemos guardar ainda mais Essências, ainda mais Relíquias e ainda mais Receitas!"
		"{image:atm:textures/questpics/forbidden/forbidden_tier2.png width:100 height:100 align:center}"
	]
	quest.46567ED894E9883C.title: "&e&lForja &6Tier 3"
	quest.46581A7015C7AD87.quest_desc: ["O &3Deep Dark&r é o Bioma mais perigoso do &2&lMinecraft&r. Ele é gerado profundamente sob a &8Ardosiabissal&r, geralmente abaixo de Montanhas e Colinas. \\n\\nO que torna um Bioma tão perigoso? &3Sculk&r. \\n\\n&3Sculk&r vem com &3Sensores de Sculk &fe &3Sensores de Vibração&r. &3Sensores&r captam qualquer som dentro de uma certa área. Minerar blocos, atirar flechas, comer comida, tudo faz som. \\n\\nSe um &3Sensor&r captar um som, ele alertará &3Sensores de Vibração&r próximos. Se os &3Sensores de Vibração&r dispararem 3 vezes seguidas, eles farão um Gerador de..."]
	quest.46581A7015C7AD87.title: "Bioma &3Deep Dark&r"
	quest.465B08461B460DAC.quest_desc: ["&dEndermaptera&r vivem ao redor da &dCidadela em Ruínas&r. \\n\\nElas têm 8 &4Corações&r e apenas um ataque básico de roer você. \\n\\nSe elas roerem você demais, podem quebrar suas mandíbulas, e então não as droparão mais na morte. \\n\\nEntão, certifique-se de matá-las rapidamente se quiser aquelas &dMandíbulas do Vazio&r!"]
	quest.465B08461B460DAC.quest_subtitle: "Baratas do End"
	quest.465B08461B460DAC.title: "&dEndermaptera"
	quest.4664AFCFB5618CEB.quest_desc: ["&bGlacite&r é encontrado nos biomas frios de &5&lEternal Starlight&r!"]
	quest.4664AFCFB5618CEB.quest_subtitle: "17"
	quest.4664AFCFB5618CEB.title: "Armadura de &bGlacite"
	quest.4676E9CD0F312C1A.quest_subtitle: "Tangerina + Kumquat"
	quest.46ABFEAF723C7057.quest_desc: ["O &6Ventilador Encapsulado&r é uma máquina divertida do &6&lCreate&r. \\n\\nQuando recebe &dEnergia Rotacional&r no sentido horário, ele soprará itens e criaturas para longe dele. Quando girado no sentido anti-horário, ele sugará os itens e criaturas para mais perto. \\n\\nNão se preocupe, só melhora! Podemos colocar &9Água&r na frente do &6Ventilador Encapsulado&r para Lavar itens dropados na frente do &6Ventilador&r. \\n\\nPodemos Lavar nossas &6Metades de Bolotas&r para fazer nossas &bTampas de Bola&r."]
	quest.46ABFEAF723C7057.title: "Lavagem em Lote"
	quest.46BE62C20C720D10.quest_desc: ["Faz com que os Endermen não fiquem bravos com você, como as Abóboras Entalhadas."]
	quest.46BE62C20C720D10.quest_subtitle: "Máx: 1"
	quest.46C816844C513D5D.quest_desc: ["Versão aprimorada da Pá Wyvern."]
	quest.46C816844C513D5D.title: "Pá Dracônica"
	quest.46CC8E7ED59F51D2.quest_desc: ["As &5Tidal Claws&r são um drop confirmado do &5&lLeviatã&r. \\n\\nEla tem dois modos, ataque e agarrar. Ataque é com o Clique Esquerdo, Agarrar é com o Clique Direito. \\n\\nQuando você usa o ataque, ela lança a garra e atravessa no máximo 5 mobs. Causando dano e dando a &5Maldição Abissal&r, que continuará a danificá-los. \\n\\nA garra, em vez disso, se prenderá a qualquer coisa que estiver ao alcance e o puxará em direção a ela. \\n\\nNão há durabilidade, então aproveite para sempre!"]
	quest.46CC8E7ED59F51D2.title: "&5Tidal Claws"
	quest.46D756F4DC6CC894.title: "&dMochila de Netherita"
	quest.46DCB235D3FEDA61.quest_desc: ["Semelhante às Ferramentas de Ferro, só que todas estas retardam quem for atingido por elas. \\n\\nBem, exceto a Enxada, mas você realmente se importa com uma simples enxada?"]
	quest.46DCB235D3FEDA61.title: "Ferramentas de &bAço Gelado&r"
	quest.46E6B1600AA8A61E.quest_desc: [
		"Melhorias Válidas:"
		"- Mob Scanner"
		"- Auto Smoker"
		"- Cauterize Wounds"
		""
		"Intrinsic Ability:"
		"- Lava Repair"
	]
	quest.46EE2F9818F8D1D9.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Limpa automaticamente quaisquer blocos afetados pela gravidade diretamente acima do bloco minerado."
	]
	quest.46EFCAE81C09368A.quest_desc: [
		"Núcleos de máquina formam a base do &9Oritech&r. Clique com o botão direito nas máquinas com núcleos de máquina para construí-las."
		""
		"Eles não afetam a velocidade ou eficiência das máquinas diretamente, apenas o número de modificadores."
	]
	quest.46EFCAE81C09368A.quest_subtitle: "Todas as máquinas usam núcleos de máquina"
	quest.46EFCAE81C09368A.title: "Núcleos de Máquina"
	quest.46FEF3DB6A5B52A0.quest_desc: [
		"Battle Cubes são uma dungeon no &6&lBumblezone&r! \\n\\nSemelhante às Câmaras de Teste, estes têm várias salas com spawners e, obviamente, Saque! \\n\\nNas salas há Teias de Aranha e Lã para representar Ovos de Aranha, dentro deles há Spawners de Aranha ou Aranha da Caverna e às vezes Saque valioso como Blocos de Diamante ou Esmeralda! \\n\\nHá também alguns Casulos de Mel na última sala que podem conter algum Saque valioso, como uma &5Bússola do Pilar do Trono&r!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_cube.png width:200 height:100 align:center}"
	]
	quest.46FEF3DB6A5B52A0.title: "Cubos de Batalha"
	quest.47043AF7D1FABC43.quest_desc: ["A &bMesa de Desencantamento&r é provavelmente a Dica mais útil aqui. \\n\\nSimplesmente coloque um Item Encantado no Slot Esquerdo e um Livro no Slot do Meio. Então, os Encantamentos irão para o Slot Direito em forma de Livro! \\n\\nVocê também pode usar Livros Encantados em vez do Item para dividir seus Encantamentos."]
	quest.47043AF7D1FABC43.title: "&l&bMesa de Desencantamento"
	quest.47045A0E8E3457C2.quest_subtitle: "Tier: &63"
	quest.4707FB01F15F6E1F.quest_desc: [
		"O &b&lClibano&r é um novo Multibloco que age como uma Fornalha Jumbo! Para fazê-lo, siga estes passos!"
		"{image:atm:textures/questpics/forbidden/forbidden_clibano1.png width:100 height:100 align:center}"
		"A primeira camada é uma área de 3x3, com os cantos feitos de &9Pedra Sombria Polida&r e o resto preenchido com &9Tijolos de Pedra Sombria Polidos&r."
		"{image:atm:textures/questpics/forbidden/forbidden_clibano2.png width:100 height:100 align:center}"
		"A segunda camada usa apenas &9Tijolos de Pedra Sombria Polidos&r e o &bNúcleo do Clibano&r. Lembre-se de manter o Bloco do meio vazio!"
		"{image:atm:textures/questpics/forbidden/forbidden_clibano3.png width:100 height:100 align:center}"
		"A camada final é como a primeira... só que acima das outras duas camadas!"
		"{image:atm:textures/questpics/forbidden/forbidden_clibano4.png width:100 height:100 align:center}"
		"Finalmente, clique com o botão direito no Multibloco com &cPó de Mundabitur&r para finalizá-lo!"
	]
	quest.4707FB01F15F6E1F.title: "&b&lNúcleo de Clibano"
	quest.4718C2728C0CA40F.quest_desc: ["Quando em sua Mão Secundária, você aprenderá tanto conhecimento! \\n\\nO canto inferior esquerdo lhe dirá a estrutura em que você está, se estiver em uma. \\n\\nTodas as entidades também serão destacadas quando estiver em uso. Isso inclui entidades de bloco como Baús ou Suportes de Armadura. \\n\\nDepois de todos os seus usos, terá um tempo de recarga de 15 minutos. Tem muitos usos, então você ficará bem!"]
	quest.4718C2728C0CA40F.title: "&5Essência do Conhecimento"
	quest.47358ADC1470C82A.quest_desc: [
		"A &cFruta do Sonho do Demônio&r é perfeitamente saudável para você. Pode haver alguns efeitos colaterais que você deve saber."
		""
		"Quando você consome uma, tem a chance de obter o efeito do &3Terceiro Olho&r, permitindo que você veja o &9Outro Mundo&r. Certos itens no mundo podem não ser o que parecem, e você precisará dessa \"visão\" para encontrar certos itens para progressão."
		""
		"Ou você pode incendiá-la e pular a busca pela maioria deles. Isso fica a seu critério."
	]
	quest.47358ADC1470C82A.quest_subtitle: "Prepare-se para uma Viagem"
	quest.47358ADC1470C82A.title: "&cFruta do Demônio"
	quest.4745152F6FF242B3.quest_desc: ["Quando o reator queima combustível, ele cria &9resíduos&r ou um &dReagente&r que você também vai querer extrair. É para isso que serve a outra Porta de Acesso a Sólidos! Certifique-se de configurá-la para saída e, em seguida, canalize-a para algum tipo de armazenamento."]
	quest.4745152F6FF242B3.quest_subtitle: "Quem não quer não tem ou algo assim...."
	quest.4745152F6FF242B3.title: "Lidando com Resíduos"
	quest.4745488579AAF603.quest_subtitle: "&f5.8 &cde Dano de Ataque"
	quest.475E1B94A61B9EB0.quest_desc: ["Como o MK1, este puxa! Só que não apenas de Inventários adjacentes, mas de qualquer Inventário próximo!"]
	quest.475E307844E3AF7F.quest_desc: [
		"As Caldeiras a Vapor são algumas das máquinas mais úteis do &l&7RailCraft&r. Elas precisam de uma Fornalha a Combustível e algum tipo de caldeira em cima. A Fornalha a Combustível pode ser 1x1, 2x2 ou 3x3. O tamanho da Fornalha muda o quão grande a Caldeira em cima pode ser. Para uma Fornalha 1x1, só pode ter uma Caldeira 1x1. Para uma Fornalha 2x2, pode ser uma Caldeira 2x2x3. Para uma Fornalha 3x3, pode ser 3x3x4. O Combustível Líquido usará Creosoto para aquecer. Para a Fornalha Sólida, usará qualquer coisa que uma fornalha possa usar."
		"{image:atm:textures/questpics/railcraft/rail_big_boiler.png width:100 height:100 align:center}"
	]
	quest.475E307844E3AF7F.title: "Caldeiras"
	quest.47656073894224AF.quest_desc: ["Sim, é como as dos navios de guerra gigantes! \\n\\nA &5&lRailgun&r é uma Arma especial. Primeiro, ela usa Munição especial, não Cartuchos como o Revólver usa. Segundo, ela usa &cEnergia&r e precisa carregar antes de atirar. \\n\\nA Munição que ela usa são &eItens&r do seu Inventário: &7Hastes de Alumínio&r, &7Ferro&r e &8Aço&r, &0Eletrodos de Grafite&r, Lâminas de Serra, Pérolas do Ender, Tridentes, Varas de Blaze e Varas do End. \\n\\nEla pegará o que estiver no seu Inventário, para mudar o que ela Atira, Segure Shift e Role o mouse. \\n\\nEm seguida, ela precisa de &cEnergia&r dentro dela para Atirar, para carregá-la podemos usar qualquer &cCarregador de Itens&r, incluindo o adicionado pelo &8&lImmersive Engineering&r! \\n\\nAssim que tivermos tudo isso, Segure o Botão Direito do Mouse até a Railgun chegar ao Nível 99, então solte! \\n\\nAs Melhorias da &5&lRailgun&r são: Mira de Precisão e Dissipadores de Calor. \\n\\nEla pode segurar 2 Melhorias, bem, faz sentido que não possa usar mais do que isso!"]
	quest.47656073894224AF.title: "&5&lRailgun"
	quest.476755275B948A5F.quest_desc: ["Reatores também podem ser usados para aquecer &brefrigerantes&r como água para criar &bvapor&r, como &bVapor&r.\\n\\nPara fazer isso, você precisará construir um reator reforçado. Isso é construído da mesma maneira que você construiu seu reator 3x3x3, mas todas as peças precisarão ser &aPeças de Reator Reforçadas&r em vez disso. Eu também sugeriria que ele seja maior que um 3x3x3.\\n\\nPara inserir um refrigerante, você precisará de uma &9Porta de Fluido da Forja&r. Isso irá portar quaisquer fluidos como Água para o reator. Isso também será usado para exportar o vapor criado no reator.\\n\\nSe quiser, você pode criar uma &aPorta de Fluido Mekanism&r para converter o fluido Vapor no gás Vapor do Mekanism."]
	quest.476755275B948A5F.quest_subtitle: "Para Fazer Vapor!!"
	quest.476755275B948A5F.title: "Construindo um Reator com Resfriamento Ativo"
	quest.476C7317510198D9.quest_desc: ["Essa é divertida! Você gosta de arremessar &eItens&r? Tipo, arremessá-los de verdade! \\n\\nEntão, o &eEjetor Ponderado&r é para você! \\n\\nPrimeiro, você precisa segurar Shift e clicar com o botão direito em um Bloco com o &eEjetor Ponderado&r para defini-lo como alvo. O alvo tem que estar alinhado com a mira do &eEjetor&r para acertá-lo. \\n\\nUma vez que tenha um alvo e esteja posicionado, ele pode ser alimentado com &dPotência Rotacional&r para carregá-lo! Então, quando um &eItem&r é colocado no &eEjetor Ponderado&r, ele o arremessará! \\nVocê pode segurar em alguns dos Lados para alterar o Tamanho da Pilha necessário para arremessar &eItens&r."]
	quest.476C7317510198D9.title: "&eEjetor Ponderado"
	quest.4773421DC70009AB.quest_desc: [
		"Habilidade Intrínseca:"
		"- Sem Pisotear"
		"- Crescimento Acelerado de Culturas I"
	]
	quest.47750F3CB020104C.quest_desc: ["&lGenerator's Galore&r e &lFornalha de Ferros&r são dois mods diferentes, mas também semelhantes. Ambos começam com a lendária Fornalha!"]
	quest.47750F3CB020104C.quest_subtitle: "Tudo começa aqui"
	quest.47750F3CB020104C.title: "A Fornalha"
	quest.47764EFC822E462A.quest_desc: ["Este bloco produz leite ao longo do tempo e habilita receitas de leite para a multiblock da cozinha.\\n\\nPara colocar uma vaca no frasco, coloque o frasco em um buraco. Atraia a vaca para cair no referido buraco acima do frasco, depois jogue uma bigorna nela.\\n\\nNão faço ideia do que este vidro é feito, mas é mais forte que meu relacionamento com a Galinha."]
	quest.47764EFC822E462A.quest_subtitle: "Poderes de ordenha fenomenais....espacinho de vida minúsculo"
	quest.47764EFC822E462A.title: "Uma Vaca em um Frasco"
	quest.47768B1FFD57D56E.quest_desc: ["Você não odeia ter que ligar &4Redstone&r em todo lugar? Se podemos ter FE Sem Fio, por que não &4Redstone&r Sem Fio? Finalmente podemos, graças ao &c&lLaserIO&r. Você pode Inserir um &4Sinal de Redstone&r com o &4Cartão&r e depois usar um &4Cartão de Saída&r para Emitir o &4Sinal&r em outro lugar!"]
	quest.47768B1FFD57D56E.title: "&4Cartão de Redstone"
	quest.477B411F84342EEA.quest_desc: ["Mekanism é um dos melhores mods para armazenamento de energia, especialmente no início do jogo.\\n\\nO Cubo de Energia Básico é fácil de configurar, fácil de criar e armazena muita energia. Ele também pode ser atualizado e pode carregar itens dentro da interface!\\n\\nPara saber mais sobre como atualizar o Cubo de Energia, bem como o mod, vá para o capítulo de missões do &aMekanism&r!"]
	quest.477B411F84342EEA.title: "&9Mekanism: &aCubo de Energia"
	quest.47897D827C50629D.quest_desc: ["Os &aPólos de Extensão de Pistão&r são como podemos criar e expandir &aPistões Mecânicos&r. \\n\\nNão são os Pistões normais, desculpe!"]
	quest.47897D827C50629D.quest_subtitle: "Por que mover só até aqui?"
	quest.47897D827C50629D.title: "&aExtensão de Pistão"
	quest.478C1AF86610A8B7.quest_desc: ["O &#EDD653&nCompressor&r é usado para fazer &#53EDAAChapas&r, &#53EDAACurvas&r e &#53EDAAAnéis&r."]
	quest.478C1AF86610A8B7.title: "&fO &#ED9553Compressor de Bronze"
	quest.47A2BEFB11F4D581.quest_desc: ["O Filtro Básico é bem... fácil de usar! Simplesmente coloque Itens nele e eles agora estão filtrados. \\n\\nVocê pode alterá-lo para que ele Coloque na Lista Branca/permita apenas esses Itens ou que ele Coloque na Lista Negra/negue apenas esses Itens. \\n\\nVocê também pode fazer com que ele corresponda aos dados NBT ou não. Corresponder aos Dados NBT significaria ter os mesmos Encantamentos, Durabilidade ou até mesmo Mobs dentro de qualquer Item. Se selecionado para não corresponder, ele fará qualquer um desse Item, independentemente do NBT."]
	quest.47A6769B6BF1A46D.quest_desc: ["&eFunis&r são como se um Funil e um Ejetor tivessem um bebê. \\n\\nQuando colocados em um Bloco com um Inventário, como Baús, eles automaticamente retiram &eItens&r um de cada vez. \\nSe você segurar Shift e clicar com o botão direito, eles automaticamente colocarão &eItens&r no Inventário. \\n\\nAmbos podem ser desligados com um &4Sinal de Redstone&r!"]
	quest.47A6769B6BF1A46D.title: "&eFunil de Andesito"
	quest.47AED7219704EB3E.quest_subtitle: "&f18 &cde Dano de Ataque"
	quest.47CB136D7764B86D.quest_desc: ["As Torreya Vines são encontradas penduradas nas Árvores de Torreya. \\n\\nElas estão penduradas porque não podem ser colocadas de outra forma... \\n\\nO bulbo na parte inferior delas emitirá Luz!"]
	quest.47CEFA06392C4211.quest_desc: ["Expansion boxes são colocadas em cima das suas Colmeias Avançadas para aumentar a quantidade de abelhas que podem estar na colmeia para um total de 5 slots. Elas também são necessárias para que suas Colmeias Avançadas suportem melhorias."]
	quest.47CEFA06392C4211.quest_subtitle: "Aumentando nosso armazenamento de abelhas"
	quest.47CEFA06392C4211.title: "&fCaixas de Expansão"
	quest.47E32A084CAA1512.quest_desc: ["Pode ser Trocado com um Armeiro ou Fabricado. \\n\\nArmas não são muito divertidas sem Balas, então vamos Fabricar algumas! Para Fabricá-las, no entanto, precisaremos deste &9Projeto&r."]
	quest.47E32A084CAA1512.title: "&9Projeto de Projéteis Comuns"
	quest.47E79DFD123BF617.quest_desc: ["A &eMáscara de Mergulho&r é tanto um Capacete quanto uma Peitoral que vai te dar &9Respiração Aquática&r quando estiver equipado! \\\\n\\\\nMas para obter &9Respiração&r, precisaremos encher nosso &eTanque de Mergulho&r com um pouco de &bOxigênio&r. Basta colocá-lo dentro de uma &5Máquina&r que possua Oxigênio, como um &9&lSeparador Eletrolítico&r, e ele será lentamente preenchido! \\\\n\\\\nDepois, equipe tanto a &eMáscara de Mergulho &fe o &eTanque de Mergulho&r e pressione (G) para ativá-los. Uma vez que o &eEquipamento de Mergulho&r estiver ligado, ele consumirá o &bOxigênio&r, permitindo que você &9Respire Debaixo d'Água&r!"]
	quest.47E79DFD123BF617.quest_subtitle: "Só um peixinho no oceano!"
	quest.47E79DFD123BF617.title: "&eConjunto de Mergulho"
	quest.47F38E606AD3FF53.quest_desc: ["Algumas Receitas exigirão &7Pós de Minério&r! \\n\\nGraças ao &6&lAllTheOres&r, podemos fazer &7Pós de Minério&r de um milhão de maneiras diferentes! \\n\\nAs maneiras do &5&lMekanism&r são com o &4&lTriturador&r e a &d&lCâmara de Enriquecimento&r. \\n\\nPodemos &4Triturar&r &7Barras&f em &7Pó&r. Ou &dEnriquecer&r &7Blocos de Minério&r para obter 2 &7Pós&r."]
	quest.47F38E606AD3FF53.title: "&4Triturado &faté Virar Pó!"
	quest.47F734CDD5793F26.title: "&5Besta de Unobtainium"
	quest.480FA9FE57743B66.quest_subtitle: "&f5 &cde Dano de Ataque"
	quest.481205F0C9B08200.quest_subtitle: "Teak + Clove"
	quest.4816190648A0F176.quest_desc: [
		"Sem Aumento de Nível."
		""
		"O Item de Assinatura é Pena de Fada."
	]
	quest.4816190648A0F176.title: "&3Elite dos Quatro Arabella"
	quest.481735FE3164C8D5.quest_desc: ["&bGelo Azul&r- 200 K \\n&bGelo Compactado&r- 240 K \\n&bGelo&r- 260 K \\nNeve- 273 K \\n&9Água&r- 300"]
	quest.481735FE3164C8D5.title: "&bItens Frios"
	quest.4818C8387C0DBBE7.quest_desc: [
		"ExtendedAE é um addon para o Applied Energistics 2, focado em adicionar versões melhoradas de vários dispositivos e trazer de volta alguns recursos de versões mais antigas do AE2."
		""
		"Para começar, pegue um Bloco de Fluix."
	]
	quest.4818C8387C0DBBE7.title: "ExtendedAE"
	quest.4821419D44F8083F.quest_desc: [
		"Os &9Growth Accelerators&r aumentam muito ligeiramente a velocidade de crescimento de uma semente quando colocados diretamente sob a Farmland. Cada nível tem um alcance de quantos blocos 'para cima' ele pode acelerar, com Inferium sendo o mais baixo, com 12."
		""
		"Nota: Growth Accelerators de todos os níveis fornecem a mesma taxa de ticks de crescimento. Níveis mais altos, no entanto, têm um alcance maior, então você pode empilhar mais deles sob uma única planta. Não importa qual nível você usa, desde que o Growth Accelerators seja colocado dentro de seu alcance máximo."
	]
	quest.4821419D44F8083F.quest_subtitle: "Alcance: &e9&r Blocos"
	quest.4821419D44F8083F.title: "&aGrowth Accelerators de Inferium"
	quest.482E558BCFEE6B7E.quest_desc: ["&3Tijolos de Construção&r são blocos de construção legais, tenha cuidado, eles machucam. Crie-os novamente para torná-los lisos."]
	quest.482E558BCFEE6B7E.quest_subtitle: "Não há dor pior do que pisar nisto"
	quest.48357A7486125C52.quest_desc: [
		"Cansado da velocidade lenta do Inscriber?"
		""
		"Apresentamos o Fatiador de Circuitos! Ele pode fatiar blocos como Blocos de Ouro em circuitos, fazendo até 9 circuitos por vez (ou 4 no caso de certus ou entro)."
		""
		"As faces de vidro do Fatiador de Circuitos que não têm uma porta não podem se conectar a uma Rede ME."
	]
	quest.48357A7486125C52.title: "De Blocos a Circuitos: O Fatiador de Circuitos"
	quest.483892F0A0F75B97.quest_desc: ["&bCanos de Fluido&r são o que usaremos para mover &bFluidos&r automaticamente de um Inventário para outro! \\n\\nVocê pode colocá-los e eles se conectarão automaticamente a Inventários e outros &bCanos&r. \\n\\nCom uma Chave Inglesa, você pode adicionar Janelas a um &bCano&r. Estes não se conectarão a &bCanos&r paralelos sem Janelas. \\n\\nOs &bCanos&r em si não moverão &bFluidos&r, precisaremos de uma &bBomba Mecânica&r para isso! \\n\\nQuando conseguirmos que os &bCanos&r comecem a fluir, poderemos usá-los para retirar &bFluidos&r de um Bloco Fonte ou o oposto, colocando Blocos Fonte. \\n\\nO &bCano&r precisará ter uma Extremidade Aberta para fazer isso, então não pode haver Blocos no caminho."]
	quest.483892F0A0F75B97.title: "&bCano de Fluido"
	quest.483E93500E645835.quest_desc: ["É pelo menos mais versátil que a barra."]
	quest.484ABFF266C8791E.quest_desc: ["Orbflora são plantas que crescem do fundo do mar. \\n\\nElas podem ser colhidas a qualquer momento, mas se você quiser as Luzes de Orbflora, precisará esperar! \\n\\nQuando crescem até o Nível do Mar, elas florescem. Após a floração, elas crescerão a Luz!"]
	quest.485AFAE5BBEF2FC7.quest_desc: ["O Rancheiro de Animais tosquia &zOvelhas&r e ordenha &8V&ra&8c&ra&8s&r.\\n\\nO Alimentador de Animais alimenta animais para que possam procriar.\\n\\nO Separador de Bebês Animais teletransporta bebês para trás dele.\\n\\nTodas essas máquinas suportam Adicionais de Alcance."]
	quest.485AFAE5BBEF2FC7.title: "Animais"
	quest.485D5664A17E16DF.quest_subtitle: "Melhoria de Armazenamento x8"
	quest.485D5664A17E16DF.title: "&6Melhoria de Cobre"
	quest.486060882E507CF1.quest_subtitle: "Surge de um Ninho de Terra"
	quest.486060882E507CF1.title: "&fAbelha Mineradora de Chocolate"
	quest.4869C413646CC4CC.quest_desc: ["Nem todo Mod é como o &5&lMekanism&r onde as máquinas apenas compartilham &cEnergia&r. Alguns precisarão que você a mova! \\n\\nPipez, Cabos, Condutos, não importa, todos podem mover &cEnergia&r de uma máquina para outra. \\n\\nCada Máquina e Tubo tem suas próprias configurações de para onde a &cEnergia&r entra e sai. Para mudá-la para tubos de &cEnergia&r, você precisará de algum tipo de chave inglesa em cada extremidade para alterar qual Empurra e qual Puxa."]
	quest.4869D9DBDD1A15CD.quest_desc: ["A &cM&6o&ed&au&bl&ca&6ç&eã&ao&r de &cC&6o&br &7Unidade&r permitirá que você mude a &cC&6o&br&r da &a&lParte da MekaArmadura&r em que ela está. \\n\\nBasta segurar o &eItem&r e pressionar (\\n\\) para acessar suas Configurações. \\n\\nQuantas &cC&6o&br&ae&es&r nós temos disponíveis? Eu não sei, quantas &cC&6o&br&ae&es&r temos com Códigos Hex! \\n\\nIsso afetará apenas aquela &a&lParte da MekaArmadura&r, então cada &a&lParte da MekaArmadura&r precisará de sua própria &7Unidade&r."]
	quest.4869D9DBDD1A15CD.quest_subtitle: "Toda a Armadura"
	quest.4869D9DBDD1A15CD.title: "Unidade de &cM&6o&ed&au&bl&ca&6ç&eã&ao &rde &cC&6o&br"
	quest.486B5A605D79EA10.quest_desc: [""]
	quest.486B5A605D79EA10.title: "&cMódulo Manhattan&r"
	quest.487C70679535DDDB.quest_desc: ["Você não odeia aquelas limitações estúpidas no seu Capturador Quântico? Não pode colocar Wardens na base dos seus amigos! \\n\\nBem, agora não há mais preocupações, pois podemos aprimorar nosso Capturador Quântico com 3 &2Fragmento de Stellarita&r e uma Estrela do Nether para fazer o Capturador de Chefes. \\n\\nAgora podemos transportar nossos Chefes para onde quisermos!"]
	quest.488DBE69595F38F8.quest_desc: ["Não, não, não, não, chega de usar &0Carvão&r para alimentar nossas Fornalhas, precisamos de &0Carvão &fpara o &8Aço&r! \\n\\nEm vez disso, use o &6&lForno Energizado&r! Ele usa &aEnergia&r para &6Fundir&e Itens&r! \\n\\nEle também pode ser Aprimorado para conter mais Slots para mais &6Fundição&r, tipo uma Fornalha Jumbo. \\n\\n&lTiers&r aprimorados também terão um botão de Auto-Organização. Isso permite que a &6&lMáquina&r distribua automaticamente os &eItens&r de forma uniforme entre os Slots para ser mais eficiente!"]
	quest.488DBE69595F38F8.quest_subtitle: "A Fornalha Energizada do Mekanism"
	quest.488DBE69595F38F8.title: "&6&lForno Energizado"
	quest.48971CE964CF037F.quest_desc: ["Embora proteger nossos Reatores Nucleares seja importante e visualizar seu conteúdo esteja relacionado à segurança dele. \\n\\nO Vidro também pode ser usado para deixar nossas bases mais bonitas! \\n\\nE, na verdade, o que é mais importante: segurança e proteção de nossos reatores nucleares? Ou deixar nossas bases mais bonitas!"]
	quest.48971CE964CF037F.title: "&fVidro dos &3Reatores"
	quest.4897C7BB3139C6C6.quest_subtitle: "Lenhador + Fazendeiro"
	quest.4897C7BB3139C6C6.title: "&fAbelha Fazendeira"
	quest.489A811AB1CFCBA3.quest_subtitle: "Kapok + Carvalho Escuro"
	quest.48B97E3C2A93BC46.quest_subtitle: "Álamo + Faia"
	quest.48BA8ACFADE3C8CE.quest_subtitle: "Cidra + Cereja Silvestre"
	quest.48BE7DAC5082044D.quest_desc: ["Estresse, como &dPotência Rotacional&r, é importante e confuso. \\n\\nUnidades de Estresse (Su) são cargas de energia para nossas &6Máquinas&r. Algumas &6Máquinas&r terão um Estresse mínimo, o que significa que você precisará dessa quantidade de Estresse em seu Sistema para operar a &6Máquina&r. \\n\\n&6Deployers&f, &6Serras Mecânicas&f e &6Ventiladores Embutidos&r são exemplos disso! \\n\\nAlgumas &6Máquinas&r também têm um máximo de Unidades de Estresse. Isso significa que se passar dessa quantidade, provavelmente parará de funcionar. Ou explodirá, um ou outro! \\n\\nAs Unidades de Estresse são desenvolvidas a partir de &dEngrenagens&r e de nossas &6Máquinas&r que produzem &dPotência Rotacional&r. &9Rodas d'Água&r dão pouco Estresse, enquanto &dMotores a Vapor&r podem dar uma tonelada!"]
	quest.48BE7DAC5082044D.title: "Estresse"
	quest.48BF71269DEA1AB1.title: "&4Farmland de Supremium"
	quest.48D358470A019E7A.title: "Catalisador de Carregador de Luz Estelar Tier 1"
	quest.48DC9E8E9D21A2FA.quest_desc: ["Mekanism oferece várias maneiras de gerar energia usando recursos renováveis.\\n\\nOs &9Geradores Solares&r aproveitam a energia do Sol para suprir necessidades básicas de energia. Não funciona durante a noite e deve ter acesso ao céu. Vidro é permitido.\\n\\nO &9Gerador Eólico&r fornece energia através do vento. A menos que você tenha descoberto uma maneira de seu personagem girá-lo manualmente, a velocidade com que ele gira é baseada no nível Y em que está colocado. Ele também precisa de acesso direto ao céu, sem nenhum bloco acima dele."]
	quest.48DC9E8E9D21A2FA.quest_subtitle: "O Poder do Sol..."
	quest.48DC9E8E9D21A2FA.title: "&9Mekanism: &aEnergia Renovável"
	quest.48E4D75FD3145AD6.quest_desc: ["O Fluido do Tempo é usado pela Máquina do Paradoxo e pela Varinha do Tempo. Ele é obtido ao jogar um Cristal do Tempo no Fluido Polimórfico.\\n\\nPara um cristal tão difícil de obter, fico feliz que tenham nos dado um fluido fácil dessa vez."]
	quest.48EE6C807C1668D4.quest_desc: ["Se você precisar que os Fios vão mais longe ou se conectem a mais lugares, talvez precise de um Nó Conector. \\n\\nSimples assim!"]
	quest.48EE6C807C1668D4.title: "Fios para cá, Fios para lá"
	quest.48F496BD0FFE5A34.quest_desc: ["A &4Unidade de Atração Magnética&r funciona como um Ímã Simples. Quando usada/vestida, ela atrairá &eItens&r em sua direção que estão fora do alcance. \\n\\nQuanto mais &4Unidades de Atração Magnética&r, de mais longe os &eItens&r podem ser puxados em sua direção."]
	quest.48F496BD0FFE5A34.quest_subtitle: "Vem cá rapidinho!"
	quest.48F496BD0FFE5A34.title: "&4Unidade de &9Atração &4Magnética"
	quest.48F77A0BE1F33B29.quest_desc: ["Usando a recém-fabricada &#65C2A6Cortadora de Fios&r, agora podemos fazer &#53E67BFios&r e &#53E67BFios Finos&r, o que nos levará ao mundo da eletricidade."]
	quest.48F77A0BE1F33B29.title: "&cFio Linear"
	quest.4903BDC389C73082.title: "Módulo de Dano de Projétil Dracônico"
	quest.490A35A715E8E20E.quest_desc: ["Com uma &cPulseira Dynamax&r em seu personagem, um &cPonto de Energia&r por perto e um &cPokémon&r pronto para lutar, podemos &cDynamaxizar&r! \\n\\nSeu &cPokémon&r não precisa ter um &cNível Dynamax&r alto para usá-lo; tudo o que isso fará é tornar o movimento dele ainda mais poderoso e dar a ele mais vida. \\n\\nEm batalha, você pode olhar abaixo dos movimentos para ver o botão &cDynamax&r. Clique nele para transformar nossos movimentos em &cMovimentos Max&r!"]
	quest.490A35A715E8E20E.title: "&cDynamaxizando"
	quest.49264B6A20E2657E.quest_desc: [
		"Sem aumento de nível aqui, este cara é um verdadeiro mão-de-vaca!"
		""
		"O Item de Assinatura é uma Faixa de Vinculação."
	]
	quest.49264B6A20E2657E.title: "&6Rival Wayne"
	quest.4926C95DD02F1410.quest_desc: ["Você já viu aqueles Tutoriais que usam Sinalizadores como um &4Portão de Segurança a Laser&r? E então, quando você tenta, fica decepcionado por não matar as pessoas? \\n\\nBem, os &4Lasers&r fazem exatamente isso! \\n\\nConfie em mim, eles se parecem com Sinalizadores e eles definitivamente matam! \\n\\nDiferente dos Sinalizadores, no entanto, você não pode mudar sua Cor com Vidro. Muito provavelmente porque eles quebram quase todos os Blocos que ficam em seu caminho e anulam os drops... \\n\\nEles também usam &aEnergia&r em vez de Materiais para serem energizados. \\n\\nEu não sei a quantidade exata de Dano que eles causam, mas é o suficiente para Fritar uma Galinha no instante em que ela toca o &4Laser&r!"]
	quest.4926C95DD02F1410.title: "&4Lasers"
	quest.4933CF4675E77D50.quest_desc: ["Depois que você levar um golpe de Dano de Fogo, o &5Crânio de Obsidiana&r será ativado, dando a você um período de Resistência ao Fogo. Esperançosamente, tempo suficiente para escapar das chamas!"]
	quest.4933CF4675E77D50.quest_subtitle: "Cinto"
	quest.4933CF4675E77D50.title: "&5Crânio de Obsidiana&r"
	quest.4935209D870E25F2.quest_desc: ["90% das &5&lMáquinas&r do &5&lMekanism&r precisarão de &aEnergia&r para funcionar. O &5&lMekanism&r usa FE para operar as &5Máquinas&r! \\n\\n1kFE é 1000 FE, e 1mFE é 1.000.000 FE! \\n\\nO &aTablete de Energia&r é a versão de Bateria do &5&lMekanism&r. Ele também será necessário para Criar a maioria dos &aGeradores&r. \\n\\nSim, o &5&lMekanism&r tem &aGeradores&r e sim, eles são incríveis!"]
	quest.4935209D870E25F2.title: "&a&lEnergia!"
	quest.493D04D954E4FBA0.quest_desc: [
		"&5&lMekanism&r é um Mod de Tecnologia... por que você está surpreso que ele precisa de Energia para suas Máquinas?"
		"{image:atm:textures/questpics/logistics/meka_cable.png width:200 height:50 align:center}"
	]
	quest.493D04D954E4FBA0.quest_subtitle: "Energia"
	quest.49598F74E0F165D1.quest_desc: [
		"Sem Aumento de Nível."
		""
		"O Item de Assinatura é uma Estrela do Nether."
	]
	quest.49598F74E0F165D1.title: "&7Líder das Ruínas Aklove"
	quest.495B0CC178B4CFA9.quest_desc: ["O &eFunil de Latão&r é colocado e usado de forma semelhante ao &eTúnel de Andesito&r. \\n\\nMas cada lado vem com novas configurações! \\n\\nO lado de Entrada agora virá com uma opção de Filtro. Basta colocar o &eItem&r, e ele só aceitará aquele &eItem&r. \\n\\nO lado de Saída agora virá com um limite. Você pode Rolar para definir um número de 1 a 64. Você também pode escolher se ele irá Sair exatamente essa quantidade, ou até essa quantidade. \\n\\nSe for exatamente essa quantidade, ele esperará até que essa quantidade esteja no Inventário para Saí-la. Se for até, ele continuará Saindo &eItens&r até que esse número seja alcançado."]
	quest.495B0CC178B4CFA9.title: "&eFunil de Latão"
	quest.495DCA49B4E80852.quest_desc: ["A &3Minigun&r é uma arma que precisa de pressão e munição para funcionar. Leia a dica de ferramenta para mais informações."]
	quest.495DCA49B4E80852.quest_subtitle: "Pew Pew!"
	quest.49636B3C6E6D0C2A.quest_desc: ["Não tem utilidade, mas é legal."]
	quest.4966162FBA933453.title: "&4Parte de Armazenamento de 262m"
	quest.4967CD7D2701C594.quest_desc: ["Há 6 versões de atualização atrás e as &6Abelhas&r ainda mal fazem nada! \\n\\nA menos que você use &6&lProductive Bees&r, então elas fazem tudo! \\n\\nDesde fazer &6Favos de Mel&r, até &6AllTheModium&r grátis, até duplicar &6Troncos &fe &7Pedra&r. Estas pequenas amiguinhas &6Abelhas&r fazem o que você precisar. \\n\\nTudo o que elas precisam é do Bloco de Flor e uma &6Colmeia&r. As Melhorias e Genes são opcionais."]
	quest.4967CD7D2701C594.title: "&6&lProductive Bees"
	quest.4975A8FD77155647.quest_desc: ["&nForte&r \\n\\n&aInseto&r \\n&cFogo&r \\n&9Voador&r \\n&bGelo&r \\n\\n&nVulnerável&r \\n\\n&4Lutador&r \\n&2Grama&r \\n&6Terra&r \\n&7Aço&r \\n&bÁgua&r"]
	quest.4975A8FD77155647.title: "&6Pedra"
	quest.4975ADE2D75353CA.quest_desc: ["Ele não aumentará seu Limite de Nível. \\n\\nSeu Item de Assinatura é o &7Revestimento de Metal&r."]
	quest.4975ADE2D75353CA.title: "&aLíder de Ginásio Byron"
	quest.49772923B8AF0F1F.title: "&bParte de Armazenamento de Fluido de 1048kB"
	quest.49776AC58E535E6A.quest_subtitle: "Feito no Reprocessador"
	quest.49776AC58E535E6A.title: "&fAbelha de Inanite"
	quest.497AE687B7E95DE8.quest_desc: [
		"O &aRitual da Floresta&r pode ser feito criando uma estrutura multibloco usando 8 Suportes de Madeira, 16 &ePó de Ouro&r e uma Muda de Carvalho ou de Selva, dependendo da receita.\\n\\nPara iniciar um ritual, coloque os itens necessários para a receita nos Suportes de Madeira e Faça Crescer a Muda necessária no meio. O &ePó de Ouro&r é consumido na receita, então você precisará de muito."
		"{image:atm:textures/questpics/natures_aura/forest_ritual.png width:295 height:150 align:center}"
	]
	quest.497AE687B7E95DE8.title: "&aRitual da Floresta"
	quest.497D222F74A52DF5.quest_desc: ["Agora sim, é disso que eu gosto! Ferro é muito comum e sua Armadura é incrível para o início do jogo. \\n\\nZumbis e Esqueletos quase não têm chance!"]
	quest.497D222F74A52DF5.quest_subtitle: "15"
	quest.497FA7CA04117995.title: "Vida"
	quest.498483750C18FCD6.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_regalium.png width:100 height:150 align:center}"]
	quest.498483750C18FCD6.title: "&eRegalium&r"
	quest.4987759CF379C1EB.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Previne os efeitos de lentidão e velocidade de serem aplicados enquanto você tiver Cristais do Tempo no seu inventário."
	]
	quest.499CF9F39CED8899.quest_desc: ["&bIntegrated Dynamics&r (ID) é um mod de logística que pode ser usado para armazenamento, transferência de itens/energia/fluidos e mais!\\n\\nÁrvores de Menril podem ser encontradas em biomas de Meneglin.\\n\\nEstas missões cobrirão alguns dos conceitos básicos do mod, leia o guia dado como recompensa por esta missão se quiser se aprofundar mais."]
	quest.499CF9F39CED8899.quest_subtitle: "Cultivando Menril"
	quest.499CF9F39CED8899.title: "&bIntegrated Dynamics"
	quest.49D03933633D6A45.quest_subtitle: "É IA"
	quest.49D0B6D3ED3DCCCD.quest_desc: ["&bPó de Cristal Arcano &r é bem simples, basta Fundir &bCristais Arcanos&r e pronto! \\n\\nVocê também pode usar o Multibloco &bClibano&r para recuperar alguns pedaços de &bCristais Arcanos&r!"]
	quest.49D0B6D3ED3DCCCD.title: "&bPó de Cristal Arcano"
	quest.49D1B01E07ABA471.quest_desc: [
		"Você pode transferir Itens usando &cMercúrio&r. \\nAnexe um Extrator de Itens onde você quer que os Itens sejam retirados. Em seguida, anexe o Inseridor de Itens onde você quer que os Itens vão. Conecte ambos com &cFios de Mercúrio&r e os Itens devem começar a se mover! \\n\\nIsso pode ser usado com Máquinas &l&6Theurgy&r para automação!"
		"{image:atm:textures/questpics/theurgy/theurgy_item.png width:200 height:75 align:center}"
	]
	quest.49D1B01E07ABA471.title: "Movimento de Itens"
	quest.49D1EA8E812A12F6.quest_desc: ["É apenas uma planta legal. \\n\\nVocê precisará de uma Foice de Prata do Pântano para coletá-la! \\n\\nNão sei por que nunca me importei com plantas, mas Juncos são legais para mim. Talvez seja por estarem perto da Água, ou por Taboas parecerem Corndogs. Não sei, mas eu gosto deles."]
	quest.49DC0BD7DC1B893C.quest_desc: ["O Abismo são fossas profundas dentro dos Mares Estrelados. Estas indo tão fundo quanto -50! \\n\\nEles têm várias camadas coloridas de Pedra que os revestem e abrigam muitos Blocos, Musgos e Peixes diferentes!"]
	quest.49DC0BD7DC1B893C.title: "O Abismo"
	quest.49EB9FB2133E3219.quest_desc: ["Armadura Ancestral é o que é usado pelos &7Esquecidos&r, e é de onde você pode obtê-la. \\n\\nNão há Botas Ancestrais, aparentemente os &7Esquecidos&r não têm pés."]
	quest.49EB9FB2133E3219.title: "Armadura Ancestral"
	quest.49EDAA2F57D3BF1D.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os packs &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não tem permissão para ser usada em nenhum pack público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta; se você estiver vendo isso, está no modo de edição."]
	quest.49EF8A4346AEF582.quest_desc: ["Jogar Brasa do Eclipse em Combustível de Voidflame criará Combustível de Brasa do Eclipse Não Refinado. Realizar a Dispersão de Gosma com gosma de nível quatro converterá o Combustível de Brasa do Eclipse Não Refinado em Combustível de Brasa do Eclipse."]
	quest.49F08DE190AAD0D8.quest_desc: ["&3Aumento&r: Fábrica torna sua Fornalha mais parecida com a Fábrica de Fundição do Mekanism. Em vez de usar Combustível, agora usará Energia! Conecte um pouco de Energia e ela começará a Fundir."]
	quest.49F08DE190AAD0D8.title: "&3Aumento&r: Fábrica"
	quest.49F4016F012BFA95.quest_desc: ["&4&oRadical Red&r é uma ROM Hack para Pokemon Red, segue a mesma história de Pokemon Red... apenas muito mais difícil. \\\\n\\\\nSim, isso não será fácil. \\\\n\\\\nVocê pode começar a &4&oSérie&r trocando com um &4Associado de Treinador&r para dar a ele seu &4Cartão de Trocas&r para que possa começar &4&oRadical Red&r."]
	quest.49F4016F012BFA95.title: "&4&oRadical Red"
	quest.4A01C5F5DCF32C19.quest_desc: ["A &3Élitros das Almas&r funciona como uma &8Élitra&r normal, só que agora com mais Durabilidade e Pontos de Armadura! \\n\\nElas não podem ser reparadas com &7Membranas de Phantom&r como as &8Élitras&r normais... mas os Encantamentos ainda podem repará-las! \\n\\nPara criar uma, você precisará de uma &8Élitra&r, 4 &3Ossos de Sculk&r que dropam dos &3Estilhaçado&r, 2 &3Pós de Alma&r que dropam dos &3Agarrador de Sculk &fou &3Sanguessugas de Sculk&r, e um &3Cristal de Alma&r que dropa do &3&lPerseguidor&r."]
	quest.4A01C5F5DCF32C19.title: "&3Élitros das Almas"
	quest.4A03A671757B2EBF.quest_desc: ["Durabilidade, Nível de Fluido, Nível de Energia, Nível de Encantamento e Valor Alimentar são todas categorias que podemos usar com o Filtro de Inspeção.\\n\\nEntão selecionamos se queremos Maior que, Menor que, Igual a, ou uma mistura desses com a Quantidade Numérica.\\n\\nEm seguida, damos uma Quantidade Numérica e apertamos o Botão Mais para adicioná-lo ao Filtro.\\n\\nIsso pode ser usado para manter apenas Ferramentas com alta Durabilidade ou Comida com alto Valor Alimentar."]
	quest.4A05C037C0EE40BD.quest_desc: ["Cabos Lógicos são diferentes de outros cabos. Outros Cabos agem como Funis, os itens se movem de 1 Inventário, para o cabo, e depois para o 2º inventário. Cabos Lógicos simplesmente pulam o intermediário, o que também pula muito lag.\\n\\nEles são apenas para conectar Importadores e Interfaces."]
	quest.4A05C037C0EE40BD.quest_subtitle: "Criando Redes"
	quest.4A05C037C0EE40BD.title: "Cabos Lógicos"
	quest.4A06CCE1FE0F333C.quest_desc: ["A &#74C3DBEntrada de Ar&r, quando colocado em um &#46CAF2Freezer a Vácuo&r, lhe dará &#B5E7F7Ar Líquido&r."]
	quest.4A076530297F4A97.quest_desc: [
		"Com estes 3 componentes, você pode criar &3Elevadores&r incríveis.\\n"
		"{image:pneumaticcraft:textures/patchouli/elevator.png width:1 height:1 align:left fit:true}"
	]
	quest.4A076530297F4A97.title: "Elevadores"
	quest.4A079D40C0AF6BC3.quest_desc: [
		"Não, não é encontrado em &5&lThe Beyond&r. \\n\\nVocê pode encontrar &5Minério de Unobtainium&r muito raramente nos biomas das Terras Altas do End. Geralmente é onde as Cidades do End também aparecem! \\n\\nVocê precisará de uma &3Picareta de Vibranium&r (ou de nível igual) para Minerar o Minério. \\n\\nPreciso ainda te dizer para processar o minério?"
		"{image:atm:textures/questpics/allthemodium/all_3.png width:100 height:100 align:center}"
	]
	quest.4A079D40C0AF6BC3.title: "&5Barra de Unobtainium&r"
	quest.4A198E875A6B0A64.quest_desc: ["O &bAuto-fabricador Ultra&r tem 36 espaços para Padrões, funciona 5x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.4A198E875A6B0A64.title: "&bAuto-fabricador Ultra"
	quest.4A1C8125896F7F1A.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.4A3A5684302C8627.title: "Módulo de Capacidade de Escudo Caótico"
	quest.4A44623D8A307473.quest_desc: [
		"Os &6Trilhos Elétricos de Alta Velocidade&r são como os &6Trilhos Elétricos&r, mas mais rápidos! Eles também exigem o que os &6High Speed Tracks&r normais exigem e o que os &6Trilhos Elétricos&r exigem. &cImpulsos de Velocidade&r e &eFrames&r para alimentá-los. Agora você tem que ter cuidado nas curvas e ao tocá-los!"
		"{image:atm:textures/questpics/railcraft/rail_electric_speed.png width:150 height:100 align:center}"
	]
	quest.4A44623D8A307473.title: "&6Trilhos Elétricos de Alta Velocidade"
	quest.4A4C14AF947D93EF.quest_subtitle: "Tier: &b4"
	quest.4A4CD38007804B1C.quest_desc: ["Para obter nossa &5Bola Mestra&r, vamos precisar das &cPoke&rbolas de Metal &6AllTheModium&r. \\n\\nPara obter as &cPoke&rbolas de Metal &6AllTheModium&r, vamos precisar de &6Bolotas&r de Metal &6AllTheModium&r. \\n\\nPara obter essas, precisaremos visitar &b&lOutro Mundo&r."]
	quest.4A4CD38007804B1C.quest_subtitle: "O Outro Mundo"
	quest.4A4CD38007804B1C.title: "As melhores &cPoke&rbolas começam em"
	quest.4A54288FD22C903D.quest_desc: ["Velvetumoss surge dentro do Abismo. \\n\\nVocê pode minerar os verdes para obter Bolas de Velvetumoss, que podem ser comidas ou transformadas em uma Bola de Slime! \\n\\nOs vermelhos gerarão plantas bonitas!"]
	quest.4A564E8FE587C7E4.quest_desc: ["A melhor maneira de obter Almas é através do Extrator de Almas! \\n\\nPor alguns Itens e Blocos do Nether e um Frasco de Utrem (que precisa de Edelwood para ser fabricado), você pode obter sua ferramenta para Encontrar Almas! \\n\\nSegure o botão direito com ela sobre a Areia das Almas e ela extrairá as Almas dela. \\n\\nDeixando-a como Areia... não, espere, é Areia Sem Alma... o que diabos é Areia Sem Alma?!?!?!"]
	quest.4A5937F6E5D06BE1.quest_desc: ["Um gerador de combustível líquido simples que funciona com os combustíveis líquidos adicionados pelo JDT."]
	quest.4A5A143A79809BB6.quest_desc: [
		"Ah, sim, você finalmente chegou. &6Bem-vindo&r à &9Era Elétrica&r, este é o verdadeiro começo da sua aventura."
		""
		"Antes de tudo, precisamos da &5Liga de Bateria&r... para fazer baterias. Surpreendente, eu sei."
	]
	quest.4A5A143A79809BB6.quest_subtitle: "Liga de Bateria"
	quest.4A5A143A79809BB6.title: "&9A Era Elétrica"
	quest.4A5EA948F5DCEB73.quest_desc: ["Prata do Pântano pode ser raramente encontrada na Lama do Crepúsculo. \\n\\nPode ser usada para criar Armaduras e Ferramentas!"]
	quest.4A5F84912C755688.quest_desc: [
		"\"The Vengabus is coming\\nAnd everybody's jumping\\nNew York to San Francisco\\nAn intercity disco\\nThe wheels of steel are turning\\nAnd traffic lights are burning\\nSo if you like to party\\nGet on and move your body\".\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_dance.png width:200 height:100 align:center}"
	]
	quest.4A5F84912C755688.title: "Pista de Dança"
	quest.4A618CA66AD6223D.quest_subtitle: "Entrada de energia ainda maior"
	quest.4A6B585C2394A89A.quest_desc: ["Os dois Itens que precisamos através do &5&lEncantador Rúnico&r são &dSopro de Dragão Infundido&r e &5Livros de Remendo&r. \\n\\n&dSopro de Dragão Infundido&r é bem simples, apenas &aXP Fluido&r, &dFonte&r e &dSopro de Dragão&r! \\n\\nO &dSopro de Dragão&r pode ser farmado facilmente com &b&lHNN&r ou ainda melhor, um Extrator do &l&9X&cy&aC&8r&aa&cf&9t&r. \\n\\nOs &5Livros de Remendo&r podem ser automatizados com &aXP Fluido&r, &dFonte&r, &9Lápis-lazúli&r, &4Base de Encantamento de Supremium&r e a parte mais difícil, a &aVara de Experiência&r. \\n\\nO &9Lápis&r pode vir de &2&lMA&r, &6&lAbelhas&r ou até mesmo de Pedreiras. \\n\\nA &aVara de Experiência&r precisará de duas ligas do &a&lEnderIO&r: Soularium e Liga Energética. Ambas podem ser feitas no Forno de Ligas. \\n\\nA &4Base de Encantamento de Supremium&r é um novo Item feito para o &5&lEncantador Rúnico&r, você precisará usar toneladas de &aEssência de EXP&r e Essências de Nível para ir de um Livro e Pena (que pode ser automatizado via &b&lHNN&r) para a &4Base de Encantamento de Supremium&r!"]
	quest.4A7AEBEB87CEC274.quest_desc: ["Não acredito que tenho permissão para usar uma marca específica de &cTênis de Corrida&r, então use sua imaginação para saber quais são. \\n\\n&cTênis de Corrida&r lhe darão um Impulso de Velocidade ao Correr, então você será ainda mais rápido ao Correr! Também lhe dá pulo automático ao Correr..."]
	quest.4A7AEBEB87CEC274.quest_subtitle: "Pés"
	quest.4A7AEBEB87CEC274.title: "&cTênis de Corrida&r"
	quest.4A82BC9DA2759C9E.quest_desc: [
		"Sem Aumento de Nível."
		""
		"O Item de Assinatura é Moeda Relíquia."
	]
	quest.4A82BC9DA2759C9E.title: "&7Admin das Ruínas Ivory"
	quest.4A854CD5EC70733E.quest_desc: ["Adiciona uma INTERFACE de Bancada de Trabalho à Mochila."]
	quest.4A8C60412E59E971.quest_desc: ["Esta máquina pode organizar itens encantados e itens não encantados. Os itens encantados acabam no inventário superior, enquanto os itens não encantados acabam no inventário inferior."]
	quest.4A99CAB529BB9F75.quest_desc: ["O &4Construtor Mega&r tem 54 espaços para filtros, funciona 8x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.4A99CAB529BB9F75.title: "&4Construtor Mega"
	quest.4A9CB8778D37049F.quest_desc: ["Você precisará usar um Ritual do Despertar para obter os Itens para fazer outro Ritual do Despertar na &4Armadura de Supremium&r. \\n\\nEu acho que vale a pena; é a melhor Armadura que você pode obter do &2&lMystical&r!"]
	quest.4A9CB8778D37049F.quest_subtitle: "36"
	quest.4A9CB8778D37049F.title: "&6Armadura de Supremium Desperta"
	quest.4AAADEC52D16461A.quest_desc: ["Basicamente, ele ativa o pulo automático. Pessoalmente, eu gosto, mas a decisão de usar é sua!"]
	quest.4AAADEC52D16461A.title: "Módulo de Passo em Colinas"
	quest.4AAB3899F530CC19.quest_desc: ["Calhas podem pegar &eItens&r (e algumas Entidades) e soltá-los sem a preocupação de desaparecerem! \\n\\nElas também soltam &eItens&r muito rapidamente. \\n\\nVocê pode usar o &6Martelo de Engenheiro&r para fazer uma Calha curvar para jogar os &eItens&r em uma &eCorreia&r!"]
	quest.4AAB3899F530CC19.quest_subtitle: "Sem Escadas?"
	quest.4AB0DD227471FDBF.quest_desc: ["Este capítulo é dedicado a tudo relacionado à energia!\\n\\nAqui você encontrará as maneiras básicas de gerar, armazenar e transferir energia."]
	quest.4AB0DD227471FDBF.quest_subtitle: "Toda a Energia!"
	quest.4AB0DD227471FDBF.title: "&cEnergia Básica"
	quest.4AB564420C48579B.quest_desc: ["O Draconic Evolution não vê a necessidade de cobrir o corpo inteiro com uma armadura patética quando você pode usar um único Peitoral com escudos embutidos. Espere, eles não são embutidos, você precisa de Módulos para eles... desculpe."]
	quest.4AB564420C48579B.title: "Peitoral Wyvern"
	quest.4ABACE222E647E2C.quest_desc: ["O Altar de Sacrifício é outra ferramenta que o Ars Ocultas oferece, desta vez, focando na automação de Sacrifícios.\\n\\nEste Altar vai sob sua tigela central e permitirá que Sacrifícios sejam substituídos por Fonte de uma Jarra de Fonte próxima, se uma Jarra de Contenção contendo o suposto sacrifício também estiver próxima."]
	quest.4ABACE222E647E2C.quest_subtitle: "Fonte Substitui Sacrifício"
	quest.4ABEF61DADBD0640.quest_desc: ["A maioria dos Arcos são Semiautomáticos. Você tem que puxar a corda, soltar, e colocar outra Flecha no arco, e repetir. Em vez disso, pule tudo isso e deixe o Arco disparar automaticamente toda vez que estiver totalmente puxado. Apenas segure o Botão Direito e veja-o funcionar!"]
	quest.4ABEF61DADBD0640.title: "Módulo de Disparo Automático"
	quest.4AC3EA41234BC5F0.quest_subtitle: "+20 de Vida Máxima"
	quest.4ACB72F3A23A5A19.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Aumenta a velocidade de natação."
	]
	quest.4AD4FDF70B9BFCC9.quest_desc: ["Usar seus Tokens na Mesa de Oferendas irá aprimorá-los. Esses Tokens aprimorados serão necessários para receitas de fabricação mais avançadas."]
	quest.4AD4FDF70B9BFCC9.title: "Tokens Aprimorados"
	quest.4AD8363D7359A072.quest_desc: [
		"Vamos construir o menor reator passivo possível, o &93x3x3&r. Os requisitos para a missão são as quantidades exatas do que você precisará para construir um.\\n\\nPara construir isso, você começa construindo uma estrutura 3x3x3 feita de Casings. No meio da face inferior, você pode usar outro Reator Casing. Você vai querer que cada parede externa tenha um &9componente do reator&r, como uma Torneira de Energia Ativa ou Porta de Acesso a Sólidos."
		"{@pagebreak}"
		"Todo reator que você construir exigirá exatamente 1 &6Controlador de Reator&r, que geralmente é colocado no meio da parede frontal. Em seguida, colocaremos 1 &aVareta de Combustível&r no centro do multibloco, e 1 &eVareta de Controle&r acima dela na face superior.\\n\\nVocê precisará de uma maneira de inserir e remover resíduos, o que é feito usando &9Portas de Acesso a Sólidos do Reator&r. Para esta construção, coloque uma no lado esquerdo e uma no lado direito.\\n\\nPara extrair energia, colocaremos a &cTorneira de Energia Ativa&r no meio da parede traseira. Uma vez colocada, o reator deve ser concluído! Agora você pode clicar com o botão direito no Controlador para abrir a interface e ligá-lo!\\n\\nNota: O maior reator que você pode fazer usando &aPeças de Reator Básicas&r é 5x5x5. Para construir um reator maior, você precisará de &ePeças de Reator Reforçadas&r."
		"{@pagebreak}"
		"Isto é como um reator 3x3x3 se parecerá:\\n"
		"{image:atm:textures/questpics/extremereactors/3x3sample.png width:150 height:150 align:1}"
	]
	quest.4AD8363D7359A072.quest_subtitle: "Aprendendo o Básico"
	quest.4AD8363D7359A072.title: "&dNosso Primeiro Reator"
	quest.4AEB4BF7624ABA0F.quest_subtitle: "Árvore-de-fogo + Árvore da Alma"
	quest.4AFA3CB55F6C10C2.quest_subtitle: "Pandanus + Coconut"
	quest.4B12425E74C5E511.quest_desc: ["O &cGerador Micelial Explosivo&r faz um trabalho incrível absorvendo Explosões. \\n\\nPodemos usar isso para um &d&lBuraco &8Negro &dPulsante&r!"]
	quest.4B12425E74C5E511.title: "&cGerador Micelial Explosivo"
	quest.4B1E4FC4599DB916.quest_desc: [
		"Melhorias Válidas:"
		"- Invulnerability"
		"- Extinguish"
		"- Élitros"
	]
	quest.4B2146C9527C54E7.quest_desc: ["Obviamente, agora que você está no Capítulo 2, você venceu o &2&lMinecraft Vanilla&r! \\n\\nAté agora você já deve ter &cNetherita&r e ter matado todos os chefes que o &2&lMinecraft&r tem. Então, o que vem a seguir? \\n\\n&6&lAllthemodium&r é o que vem a seguir! Para começar a obter &6Allthemodium&r, você precisará de &cNetherita&r. Vamos começar por aí!"]
	quest.4B2146C9527C54E7.title: "&6&lAllthemodium"
	quest.4B2835706B593E9A.quest_desc: ["O &d&lNucleossintetizador Antiprotônico&r é uma &5Máquina&r feita de &dPastilhas de Antimatéria&r. \\n\\nClaro que ele também usa &dAntimatéria&r como Combustível, porque não era caro o suficiente! \\n\\nEntão, o que ele faz? \\n\\nCom nossa &dAntimatéria&r, &aEnergia&r e um certo &eItem&r, ele cria um &eItem&r novinho em folha (e geralmente raro). Alguns nós nem conseguimos Criar! \\n\\nComo transformar &5Ametista&f em &9Fragmentos de Eco&f, &eMaçã Dourada&f em &eMaçã Dourada Encantada&r, e até Ovos no &dOvo do Dragão&r!"]
	quest.4B2835706B593E9A.title: "&d&lNucleossintetizador &5Antiprotônico"
	quest.4B35C01F5D0AAC58.quest_desc: ["Agora que temos nosso &9&lInfusor Metalúrgico&r e, com sorte, um pouco de &cEnergia&r, podemos começar a fazer &8Aço&r! \\n\\nPrecisaremos de &0Carbono&r em nossa &eBarra de Químico&r. Podemos usar &0Carvão&f, &0Carvão Vegetal&r ou qualquer variante deles no &eSlot de Químico&f para adicionar &0Carbono&r. \\n\\nEntão, se adicionarmos um &7Barra de Ferro&f/&7Pó&r no &4Slot de Item&r, ele o infundirá com 10mB de Carbono para criar Ferro Enriquecido. \\n\\nPrecisaremos repetir esse passo agora, adicionando 10mB de &0Carbono&r para transformar nosso &7Ferro Enriquecido&r em &8Pó de Aço&r! Funda o &8Pó&r para obter um &8Barra de Aço&r. \\n\\nO &8Aço&r é usado para praticamente tudo! Máquinas, Ferramentas, Melhorias, Reatores, Células de Energia! Você precisará de muito dele."]
	quest.4B35C01F5D0AAC58.title: "&8Aço "
	quest.4B3F20E5C7E3BCFB.quest_desc: ["Carvão Primitivo é um novo material adicionado por JDT. O Carvão Primitivo é adquirido realizando a Propagação de Gosma em Blocos de Carvão usando gosma de nível um ou superior. O Minério de Carvão Primitivo é afetado por fortuna."]
	quest.4B42D962FE910CB3.quest_desc: ["Com isto adicionado ao seu &d&lRevólver&r, suas Balas darão aos Mobs que você atingir o Efeito de Atordoamento."]
	quest.4B4F5341D6DBDD19.quest_desc: ["Mantenha sua respiração debaixo d'água, assim que suas bolhas descerem para 5, elas serão recarregadas! Também permite que você veja muito mais facilmente debaixo d'água!"]
	quest.4B4F5341D6DBDD19.quest_subtitle: "Máx: 1"
	quest.4B62AF0405F68041.quest_desc: ["Adiciona um filtro que permite que você diga à Mochila quais itens ela deve manter em estoque. Clicar com o botão direito do mouse em um inventário irá reabastecê-lo."]
	quest.4B62AF0405F68041.quest_subtitle: "Tudo abastecido"
	quest.4B76FE0348DB0E45.quest_desc: ["O Cartão de Quantum Bridge é um método alternativo para obter acesso interdimensional sem fio ao seu sistema Applied Energistics. Você precisará de uma Ponte Quântica conectada em sua base e um Cartão de Quantum Bridge em seu terminal. Esses túneis são então ligados com uma &5Singularidades Quanticamente Entrelaçadas&r para obter acesso onde quer que você vá."]
	quest.4B76FE0348DB0E45.title: "&eCartão de Ponte Quântica"
	quest.4B7840F1A8CF1378.quest_desc: ["A Criação por Fusão é como a maioria (pelo menos os itens divertidos) será feita. Para começar, você precisa de um Núcleo de Criação por Fusão, coloque-o cerca de um bloco acima do chão. O Núcleo é onde as receitas podem ser colocadas automaticamente a partir do JEI, onde o item do meio vai, и onde o item final será colocado. Ele precisará que os Injetores sejam colocados a alguns blocos de distância dele, olhando para o Núcleo em dois de seus lados. Confira a próxima Missão para saber mais sobre eles. Os Injetores também precisarão de Energia, o que será explicado mais na Missão de Vinculação de Cristais."]
	quest.4B7840F1A8CF1378.title: "Criação por Fusão"
	quest.4B7D387CEFF9667E.quest_desc: ["Finalmente! O &6&lCreate&r foi atualizado e definitivamente valeu a pena esperar! \\n\\nO &6&lCreate&r é todo sobre girar e usar a Energia Rotacional... bem, para praticamente tudo! Criação, trituração, mistura, fermentação, ETC. \\n\\nSe já faz tanto tempo que você не lembra como usar o &6&lCreate&r, você pode usar a &7&lIndustrialização Moderna&r para Criar a &6&lEstrela ATM&r."]
	quest.4B7D387CEFF9667E.title: "&6&lCreate"
	quest.4B81E84CAE814BA9.title: "&6Parte de Armazenamento de Fluido de 64B"
	quest.4B9C54DA5CB6D5C9.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_host.png width:100 height:150 align:center}"]
	quest.4B9C54DA5CB6D5C9.quest_subtitle: "Ruínas de Trilha"
	quest.4B9C54DA5CB6D5C9.title: "Ornamento de Armadura Host"
	quest.4B9E9497E44D0096.quest_desc: ["Para construir um reator, você precisará começar fazendo &6Invólucros de Reator&r.\\n\\nEles compõem a estrutura e as paredes do seu reator, embora as paredes possam ser substituídas por &9Vidro de Reator&r se você quiser ver o interior do seu reator.\\n\\nPara referência futura, quando uma peça diz \"Básica\", isso significa que ela só pode ser usada com outras peças básicas. As peças Básicas também só podem ser usadas para construir reatores menores, pois têm um certo limite de tamanho. Tenha isso em mente!"]
	quest.4B9E9497E44D0096.title: "Componentes de Construção do Reator"
	quest.4B9FF9E972B0E530.quest_desc: ["Quanto melhor o Link ou Túnel de Energia, obviamente mais OP ele pode transferir, mas você também pode ter notado algo faltando no Link de Energia. Ele não funciona entre Dimensões! Felizmente, os melhores podem, apenas certifique-se de que o outro lado esteja carregado (chunkloaded)."]
	quest.4B9FF9E972B0E530.title: "Túnel de Energia Quântica"
	quest.4BA2F4AC2A08C294.quest_desc: [
		"O que é isso? É apenas o Multibloco mais difícil e caro do &8&lImmersive Engineering&r. A &c&lEscavadeira&r! \\n\\nEste gigante mastodôntico coletará automaticamente Minérios e Blocos do Chão. \\n\\nOs Itens que ele coleta serão &6Saídos&r por uma Porta na parte de trás dele. Se não houver Inventário ao lado, ele dispensará os Itens. \\n\\nEsta também é uma Máquina super faminta por &cEnergia&r, você precisará usar as Portas de Energia no lado esquerdo dela para alimentá-la!"
		"{@pagebreak}"
		"Coloque um &8Bloco de Aço&r."
		"{image:atm:textures/questpics/immersive/immersive_excavator1.png width:100 height:100 align:center}"
		"Adicione 3 &8Andaime de Aço&r acima do &8Bloco de Aço&r e coloque 2 &8Blocos de Aço&r nas extremidades."
		"{image:atm:textures/questpics/immersive/immersive_excavator2.png width:175 height:100 align:center}"
		"Depois disso, coloque um 3x3 de &8Andaime de Aço&r acima do &8Andaime&r anterior, e um extra em cada um dos &8Blocos de Aço&r. Então, usando &8Chapa de Aço&r, faça um aro a partir do &8Andaime&r, incluindo um &eBloco de Engenharia Leve&r e um &8Bloco de Radiador&r."
		"{image:atm:textures/questpics/immersive/immersive_excavator3.png width:150 height:100 align:center}"
		"Acima do &8Andaime de Aço&r, adicione mais, com um &8Bloco de Aço&r no meio. Então, anexe mais &8Blocos de Aço&r nas extremidades daqueles. De um lado, serão 3 &eBlocos de Engenharia Leve&r e do outro serão 3 &7Blocos de Engenharia Pesada&r. Acima do &eBloco de Engenharia Leve&r na última camada, haverá outro. E acima do &8Bloco de Radiador&r haverá um &4Bloco de Engenharia de Redstone&r. Ao lado dele, haverá outro &7Bloco de Engenharia Pesada&r e o resto será &8Chapa de Aço&r."
		"{image:atm:textures/questpics/immersive/immersive_excavator4.png width:150 height:100 align:center}"
		"Agora, para a parte do meio, vamos repetir o que fizemos abaixo da metade, então agora é apenas &8Andaime de Aço&r. Do lado dele com &eBlocos de Engenharia Leve&r, haverá mais 3, o mesmo com o &eBloco de Engenharia Leve&r aleatório do outro lado. Ao lado dos 3 &eBlocos de Engenharia Leve&r, haverá 2 &8Blocos de Radiador&r, e todo o resto é &8Chapa Metálica&r."
		"{image:atm:textures/questpics/immersive/immersive_excavator5.png width:150 height:100 align:center}"
		"Acima do &8Andaime de Aço&r haverá 1 &8Bloco de Aço&r seguido por 3 &8Andaime&r e outro &8Bloco&r."
		"{image:atm:textures/questpics/immersive/immersive_excavator6.png width:150 height:100 align:center}"
		"A cereja final no topo, &8Bloco de Aço&r!"
		"{image:atm:textures/questpics/immersive/immersive_excavator7.png width:150 height:100 align:center}"
		"Então, nós apenas Clicamos com o Botão Direito no &7Bloco de Engenharia Pesada&r na parte de trás com nosso &6Martelo&r e ele se tornará a poderosa &c&lEscavadeira&r!"
		"{image:atm:textures/questpics/immersive/immersive_excavator.png width:125 height:100 align:center}"
	]
	quest.4BA2F4AC2A08C294.title: "&l&cEscavadeira"
	quest.4BADD8A0FD85DB33.quest_desc: ["Entre os &cdangerosos&r &6piglins&r do &cNether&r, um minúsculo &eDente de Ouro&r brilha, segurando a &bpromessa&r de riqueza… e influência. \\n\\n Aqueles que coletam esses &6dentes&r aprendem rapidamente que uma única peça pode &eabrir portas&r que outros jamais ousariam abordar. \\n\\n- Pode ser usado para &2trocas&r com &6piglins&r ou derretido em &eouro&r."]
	quest.4BADD8A0FD85DB33.quest_subtitle: "Mesmo os menores tesouros podem mudar o destino!"
	quest.4BADD8A0FD85DB33.title: "&eDente de Ouro"
	quest.4BAF44FCA0894DE8.quest_desc: ["Assim como a &5&lCentrífuga Isotópica&r, o &e&lAtivador de Nêutrons Solar&r é usado apenas para 2 Receitas, e 1 delas é com &8Rejeito Nuclear&r! \\n\\nEsta &5Máquina&r captará os Raios do &eSol&r através das &eCélulas Solares&r no topo. Ela então focará esses Raios em um único Feixe e o usará no &8Rejeito Nuclear&r. \\n\\nIsso também faz com que ela não funcione &9à noite&r... \\n\\nCada 5mB de &8Rejeito Nuclear&r se tornarão 1mB de &aPolônio&r. \\n\\nEntão, você precisará de 5.000mB de &2Combustível Fóssil&r para fazer 5.000mB de &8Rejeito Nuclear&r."]
	quest.4BAF44FCA0894DE8.title: "Usando o &eSol&r para fazer &aPolônio"
	quest.4BBF987FEF639801.quest_desc: [
		"Ligas são combinações de 2 Metais diferentes. \\n\\nMetais geralmente não são líquidos à temperatura ambiente, então precisaremos derretê-los um pouco (obrigado, Mercúrio)! \\n\\nAdicione os 2 Metais nos slots superiores e um Combustível de Fornalha como &0Carvão Vegetal&r no slot inferior. \\n\\nEspere... &8Aço&r é uma Liga!"
		"{@pagebreak}"
		"O &6&lFundição de Ligas&r é um 2x2x2 de &6Tijolos de Forno&r."
		"{image:atm:textures/questpics/immersive/immersive_alloy1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_alloy2.png width:100 height:100 align:center}"
		"Então Clique com o Botão Direito no Bloco Superior Direito com um &6Martelo de Engenheiro&r para fazê-lo!"
		"{image:atm:textures/questpics/immersive/immersive_alloy.png width:100 height:100 align:center}"
	]
	quest.4BBF987FEF639801.title: "&l&6Fundição de Ligas"
	quest.4BC2D7FCDD792DBA.quest_desc: [
		"Porque os Itens, Blocos e Fluidos normais do &2&lMinecraft&r não eram suficientes. E o Calor e Energia adicionados também não. \\n\\nO resto do &5&lMekanism&r é movido com Tubos Pressurizados. Gases são os principais, pois se você está usando o &5&lMekanism&r, você usará Gases como Hidrogênio e Oxigênio. \\nTipos de Infusão são semelhantes, como Infusão de Carvão e Infusão de Redstone. Pastas são usadas com o Processamento de Minério. \\nE Pigmentos de Corante são a essência da Cor, qualquer item que seja Tingido pode ser alterado com essa parte do &5&lMekanism&r."
		"{image:atm:textures/questpics/logistics/meka_tube.png width:200 height:50 align:center}"
	]
	quest.4BC2D7FCDD792DBA.quest_subtitle: "Gás+Mais"
	quest.4BD203AD481DDE8F.quest_desc: ["O &4Meat Shredder&r é feito de &4Witherite&r, que é um Drop do &4&lArauto&r. \\n\\nVocê precisará encontrar a &4Fábrica Ancestral&r que fica no subsolo profundo do &2&lMundo Superior&r. \\n\\nEntão você encontrará o &4&lArauto&r desligado, para ligá-lo, precisaremos alimentá-lo com uma Estrela do Nether! \\n\\nEntão, após uma luta de chefe muito difícil e longa, você pode Criar o &4Meat Shredder&r!"]
	quest.4BD203AD481DDE8F.title: "&4Meat Shredder"
	quest.4BE209D5DAF1F321.quest_desc: [
		"&bAureal&r é o primeiro e mais importante Slot na &6&lForja&r. \\n\\nVocê pode automatizá-lo com &bCristal Arcano Obelisks&r ou depositar &bGarrafas de Aureal&f/&bPoções&r! \\n\\nVocê pode encontrar &bGarrafas de Aureal&r em Baús na maioria das Estruturas, ou pode criá-las com &bPó de Cristal Arcano &r e uma Poção de Regeneração II."
		"{image:atm:textures/questpics/forbidden/forbidden_aureal.png width:135 height:100 align:center}"
	]
	quest.4BE209D5DAF1F321.title: "&bAureal"
	quest.4BF0BB763BFFACF0.quest_desc: [
		"Indiscutivelmente, o recurso mais importante que você precisará a seguir é o &5Fluix&f, usado na grande maioria dos dispositivos &bAE2&r e servindo como base para a criação de toda a fiação dentro de uma Rede ME."
		""
		"Você normalmente vai querer produzir isso em massa, e a maneira de fazer isso é fazer um &dCristal de Fluix&f jogando &eQuartzo do Nether&f, &bQuartzo de Certus &oCarregado&r e &cRedstone&f juntos em uma poça de água. Isso lhe dará um &5Cristal de Fluix&r que você pode transformar em pó em um &eInscritor&r."
	]
	quest.4BF0BB763BFFACF0.title: "&5Fluix"
	quest.4BF5EB050EC14C80.quest_desc: ["&4Os Vigias&r... bem, eles vigiam a &4Fábrica Ancestral&r. Eles atacarão qualquer coisa que virem (em termos de Jogador) com seus 'raios laser do caramba!' e Lâminas se estiverem perto o suficiente. \\n\\nEles têm 12 e meio &4Corações&r, podem voar e também são fracos a ataques PEM. \\n\\nComo &4O Predador&r, eles dropam redstone e ferro na morte."]
	quest.4BF5EB050EC14C80.title: "&4Os Vigias&r"
	quest.4C0302FF4F63B52E.quest_desc: [
		"Se você quer as abelhas ATM, é preciso muitas &6capturas&r, &6criações&r e &6alimentações&r."
		""
		"A parte seguinte da linha de missões descreve quais abelhas você precisará para avançar."
		""
		"Certifique-se de verificar o JEI e o &9Grande Livro das Abelhas&r para mais informações!"
	]
	quest.4C0302FF4F63B52E.title: "&fProgressão &eAllthemodium"
	quest.4C0BDD483CCB40C4.title: "&bBaú de Diamante"
	quest.4C0D00B5305117A1.quest_desc: [
		"A &3Torreta Sentinela&r pode ser colocada em algum lugar e configurada para atacar mobs ou jogadores quando eles estiverem ao alcance. Ela só precisa de um pouco de Munição de Minigun."
		""
		"{image:pneumaticcraft:textures/patchouli/sentry_turret.png width:100 height:100 align:left fit:true}"
	]
	quest.4C0D00B5305117A1.quest_subtitle: "Pew Pew (Sem você)"
	quest.4C0EAB9F795686D0.quest_subtitle: "Mais Opções de Filtragem"
	quest.4C0EAB9F795686D0.title: "&eMelhoria de Depósito Avançada"
	quest.4C1F13F5A0E273EF.title: "&6Parte de Armazenamento de 256k"
	quest.4C23D7E3DC8327C2.quest_desc: ["Para matar a Monstruosidade Lunar, você precisará incendiá-la! \\n\\nVocê pode usar Pederneira e Isqueiro ou uma Caixa de Fósforos de Salitre. \\n\\nPessoalmente, acho que a Caixa de Fósforos é mais adequada!"]
	quest.4C23D7E3DC8327C2.title: "Queime-o!"
	quest.4C2A60FC1F1E0328.quest_desc: ["Adiciona uma bateria à Mochila."]
	quest.4C31649D721F76B5.quest_desc: ["A &6Colheitadeira Mecânica&r irá automaticamente Colher Culturas Maduras e Replantá-las. \\n\\nObviamente, ela precisa ser movida por uma &aEngenhoca&r para funcionar. \\n\\nEla também colocará automaticamente as Culturas coletadas em Inventários conectados à &aEngenhoca&r. Se não, ela dropará as Culturas no chão."]
	quest.4C31649D721F76B5.title: "&6Colheitadeira Mecânica"
	quest.4C366515E3CCB0B2.quest_desc: ["Carne através de um tubo, delícia."]
	quest.4C3B7BAEA653587B.quest_desc: ["Estes podem ser encontrados em baús dentro de Pirâmides do Deserto."]
	quest.4C3B7BAEA653587B.quest_subtitle: "Baús de Pirâmides do Deserto"
	quest.4C41FD926F31180B.quest_desc: ["Para mover &2Itens&r com &c&lLaserIO&r, você precisará de alguns &2Cartões de Item&r. \\n\\nDefina um para Extrair e coloque-o no lado do &cNó Laser&r de onde você deseja Importar. Em seguida, defina o outro para Inserir e coloque-o no lado para onde você deseja que os Itens sejam Exportados. \\n\\nExistem várias configurações que você pode alterar com a Extração, na ordem de para onde você deseja que os Itens vão, se houver vários lugares para Extrair. Round Robin fará com que ele Extraia itens em uma ordem, em vez de primeiro o Inventário mais próximo."]
	quest.4C41FD926F31180B.title: "&2Cartão de Item"
	quest.4C47EB9D2CE26BC6.quest_subtitle: "Surge de um Ninho de Quartzo no Nether"
	quest.4C47EB9D2CE26BC6.title: "&fAbelha Cristalina"
	quest.4C4C9ADAC6107F89.quest_desc: ["O &eConjunto Leve de Engenharia&r é uma receita bem fácil. \\n\\nVocê precisará de 1 &6Lingote de Cobre&r, que eu não deveria ter que explicar, é literalmente um recurso &2&lVanilla&r. \\n\\n4 &7Chapas de Ferro&r, que são apenas 4 &7Chapa de Ferro&r combinadas! \\n\\nVocê também precisará de 4 &7Componentes Mecânicos de Ferro&r, que são ou 4 &7Chapa de Ferro&r e um &6Lingote de Cobre&r em uma Bancada de Trabalho, ou 2 &7Chapa de Ferro&r e um &6Lingote de Cobre&r na &6Bancada de Trabalho do Engenheiro&r."]
	quest.4C4C9ADAC6107F89.title: "&eBloco de Engenharia Leve"
	quest.4C54BD57CAB8A54B.quest_desc: [
		"Blazebloom Goo é o segundo nível de gosma adicionado por JDT e requer materiais do Nether para ser fabricado."
		""
		"Fabricações Desbloqueadas:"
		"- Blazegold"
		"- Blaze Ember"
	]
	quest.4C5CFA45D9B4F6D3.quest_desc: ["Cogumelos Índigo são aparentemente melhores amigos do Smogstem e aparecerão principalmente com eles!"]
	quest.4C77ABCD41383F32.quest_desc: ["&cBlaze Cakes&r podem ser usados para &bSuperaquecer&r os &cBlaze Burners&r! Um calor nunca antes visto! \\n\\nMas como os assamos? \\n\\nPrimeiro, precisaremos fazer a &4Base de Blaze Cake&r. Para obtê-la, processe um Ovo, Açúcar e &4Farinha de Cinzas&r em uma Prensa Mecânica e Bacia. \\n\\nA &4Farinha de Cinzas&r é criada esmagando &4Netherrack&r em duas Rodas de Esmagamento. \\n\\nEntão, quando tivermos nossa &4Base de Blaze Cake&r, podemos preenchê-la com &cLava&r de um &bBico&r para fazer nosso &cBlaze Cake&r!"]
	quest.4C77ABCD41383F32.title: "&cBlaze Cakes"
	quest.4C7E006502E30C20.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.4C873491F6F0FFAF.quest_desc: [
		"Usando &dFogo Espiritual&r, podemos converter vários materiais do Mundo Superior em suas variantes do Outro Mundo. Você também pode encontrar vários materiais do Outro Mundo sob os efeitos do &bTerceiro Olho&r e se aventurando pelo mundo. Você pode se surpreender com o que encontrará. Para facilitar, existem receitas de fabricação para os materiais básicos, jogando-os no &dFogo Espiritual&r."
		""
		"&bAndesito&r se converte em &3Pedra do Outro&r, que pode ser usada para acender um &dFogo Espiritual&r permanente."
		""
		"Mudas de &aCarvalho&r se convertem em &9Mudas de Carvalho&r, mas não são as mesmas. Quando crescidas, elas se parecerão exatamente com uma árvore de Carvalho normal. No entanto, sob os efeitos do &bTerceiro Olho&r, você poderá colher a variante do Outro Mundo."
		""
		"Se você tiver problemas para coletar os troncos (se eles se transformarem em troncos de Carvalho normais mesmo com o &bTerceiro Olho&r), tente coletá-los pelo topo."
		""
		"&eDiamantes&r se transformarão em &dGemas Sintonizadas com Espírito&r, que são usadas em várias receitas que precisaremos mais tarde."
	]
	quest.4C873491F6F0FFAF.title: "Conversões do &dFogo Espiritual&r"
	quest.4C8C56F960D92E9D.quest_subtitle: "&f51 de &cDano de Ataque"
	quest.4CA17B0A80020B2F.quest_desc: ["O &3Manômetro&r é usado para mostrar informações extras sobre uma máquina."]
	quest.4CA17B0A80020B2F.quest_subtitle: "Preciso de mais Informações!"
	quest.4CB488E5CF10F3A4.quest_desc: ["Apenas o Gerador mais poderoso e caro de &c&lGenerator Galore&r. \\n\\nVocê precisará de um &9Fragmento de Eco&r, um &bConduto&r e uma tonelada de Geradores de Netherstar!"]
	quest.4CC963F5AECF285A.quest_desc: ["Normalmente, o Roteador move 1 item a cada um de seus Ticks. Isso pode ser duplicado e acumulado! com a Melhoria de Pilha. \\n\\n1 Melhoria de Pilha são 2 Itens, 2 Pilhas 4 Itens, e 6 Pilhas são 64 Itens por segundo."]
	quest.4CCEC13CC5A5772D.quest_desc: ["Existem 3 Pets de &4&lCataclysm&r: o &eRemanescente Moderno&r, o &5Bebê Leviatã&r e a &4Ministrosidade de Netherite&r! \\n\\nTanto o &eRemanescente Moderno&r quanto a &4Ministrosidade de Netherite&r podem ser colocados em Baldes. \\n\\nO &5Bebê Leviatã&r precisará de um Balde de Água."]
	quest.4CCEC13CC5A5772D.title: "Aqui, segure isso!"
	quest.4CD2ADD3601B8191.quest_desc: ["Quer que seu Escudo volte e não apenas quando você está quase morrendo? Então, você precisará de Módulos de Recuperação. Quanto mais Módulos, mais rápido ele se recupera."]
	quest.4CD2ADD3601B8191.title: "Módulo de Recuperação de Escudo Wyvern"
	quest.4CD83943865018EA.quest_desc: ["O &9Exportador&r é usado para empurrar itens do seu sistema para um bloco a partir do armazenamento da sua rede.\\n\\nIsso pode ser usado para encher Fornalhas com minérios ou combustível, empurrar materiais para baús designados, etc.\\n\\nVocê também pode filtrar quais itens são empurrados."]
	quest.4CD83943865018EA.quest_subtitle: "Exportando Itens!"
	quest.4CE571F942461909.quest_desc: [
		"A Bolsa Ritual é legal, mas leva muito tempo para colocar todos os blocos. Agora que você pode realizar o ritual &cConfinamento Permanente de Sevira&r, você pode criar a Bolsa Ritual Artesanal!"
		""
		"A Bolsa Ritual Artesanal funciona de forma quase idêntica à Bolsa Ritual comum, exceto que ela coloca instantaneamente todos os itens necessários para o ritual e tem a capacidade adicional de clicar com o botão direito em uma Tigela Dourada para apagar todas as Runas de Giz e coletar todos os outros itens (Crânios, Velas e Cristais) e devolvê-los à Bolsa."
		""
		"Não, ela não restaura a durabilidade do Giz."
	]
	quest.4CE571F942461909.title: "Ferramentas do Ofício: Bolsa Ritual Artesanal"
	quest.4CE6EB54B12EF6C5.quest_subtitle: "&f10 de &cDano de Ataque"
	quest.4CFA7EE8174E3FD8.quest_subtitle: "Aumenta a taxa de entrada de energia"
	quest.4CFE097D0A8683C8.quest_desc: ["A &5Crânio de Obsidiana&r é um Elmo que, quando usado, pode protegê-lo de dano de Fogo/Lava! \\n\\nCom o tempo, ele se desgastará, e você precisará repará-lo com &5Obsidiansteel&r. \\n\\nÉ também assim que você o fabrica, um Crânio de Esqueleto com 8 &5Obsidiansteel&r."]
	quest.4CFE097D0A8683C8.title: "&5Crânio de Obsidiana"
	quest.4D07B0A4A2E77CDA.quest_desc: [
		"&9Entidades máximas&r é a quantidade de mobs que podem ser gerados por um &9Spawner&r e &9Mantidos&r.\\n"
		"Se for apenas 6 entidades máximas quando 6 mobs já estão gerados, nenhum outro será gerado até que eles morram ou sejam movidos.\\n"
		"Cada Lágrima de Ghast aumenta ou diminui em 2 Entidades.\\n"
		"Máximo de 16 Entidades e Mínimo de 1."
	]
	quest.4D07B0A4A2E77CDA.title: "&fEntidades Máximas"
	quest.4D0B50731FED3CEE.quest_desc: ["Para obter a Lança Crescente, você precisará fabricá-la a partir de Itens derrubados pela Monstruosidade Lunar e pelo Ódio Emaranhado, ou tê-la derrubada pela Monstruosidade Lunar. (Você terá que matá-lo de qualquer maneira, basicamente). \\n\\nVocê pode usar a Lança como um Tridente e apenas bater nos Mobs ou pode segurar o Clique Direito para ser lançado para a frente com ela. Se você atingir algum Mob com o segundo ataque, qualquer Mob próximo também sofrerá dano."]
	quest.4D193D60A3CAF435.quest_desc: [
		"Este é o Gerador que você provavelmente mais usará, o &2&lGerador a Diesel&r! \\n\\nVocê irá &9Inserir&r Combustível nos cantos inferior esquerdo e direito do &2&lGerador a Diesel&r. O Combustível pode ser: Óleo de Creosoto, Biodiesel e Biodiesel de Alto Cetano. Eles estão em ordem do pior para o melhor! \\n\\nO &2&lGerador a Diesel&r queimará o Combustível e produzirá &cEnergia&r que pode ser &6Saída&r pelos 3 conectores na frente."
		"{@pagebreak}"
		"Na parte de trás do &2&lGerador a Diesel&r precisaremos de 3 &8Blocos de Radiador&r. O meio será de &bTubos de Fluido&r cercados por &8Andaimes de Aço&r. Com a frente tendo um &6Bloco Gerador&r e 2 &bTubos de Fluido&r ao lado."
		"{image:atm:textures/questpics/immersive/immersive_diesel1.png width:100 height:150 align:center}"
		"Acima dos 3 &8Blocos de Radiador&r haverá mais 3 &8Blocos de Radiador&r! E o &6Bloco Gerador&r e os &bTubos de Fluido&r ao lado terão 3 &6Blocos Geradores&r acima deles. O resto será preenchido com &7Blocos de Engenharia Pesada&r e um único &4Bloco de Engenharia de Redstone&r."
		"{image:atm:textures/questpics/immersive/immersive_diesel2.png width:100 height:100 align:center}"
		"Para terminar, precisaremos de mais 3 &8Blocos de Radiador&r acima dos outros, e ao lado faremos uma cruz de &7Blocos de Engenharia Pesada&r."
		"{image:atm:textures/questpics/immersive/immersive_diesel3.png width:100 height:100 align:center}"
		"O último passo é clicar com o botão direito no &6Bloco Gerador&r do meio e de cima com nosso &6Martelo de Engenheiro&r!"
		"{image:atm:textures/questpics/immersive/immersive_diesel.png width:100 height:100 align:center}"
	]
	quest.4D193D60A3CAF435.title: "&2&lGerador a Diesel"
	quest.4D3379D38237F830.quest_desc: ["Enquanto estiver usando &bestas&r nos seus Pés, você pode realizar um milagre! Andar sobre a &9Água&r! \\n\\nBem, na verdade, correr sobre a &9Água&r, você tem que estar Correndo para conseguir correr sobre a &9Água&r. Quando você parar de Correr, começará a Afundar."]
	quest.4D3379D38237F830.quest_subtitle: "Pés"
	quest.4D3379D38237F830.title: "&bAqua-Dashers&r"
	quest.4D4152032F0410D2.quest_desc: ["O Programador Lógico permite que você defina o valor de variáveis. Isso pode ser definido para itens e fluidos para filtragem, ou até mesmo valores. \\n\\nDeixe-me dar um exemplo simples: Selecione &bItem&r do lado esquerdo, coloque um item de sua escolha no slot central da INTERFACE que aparece e coloque um &bCartão de Variável&r no slot inferior direito. Se você então colocar esse cartão de variável em um importador/exportador, ele só importará/exportará aquele bloco!"]
	quest.4D4152032F0410D2.quest_subtitle: "Ficando Avançado"
	quest.4D4DE266A2A325B0.quest_desc: ["Redstone, Aço de Golem e Aço de Golem Oxidado são Itens usados para encontrar a Forja de Golem. \\n\\nSegure um desses (mais provavelmente Redstone que aparece no subterrâneo de Starlight) em sua mão secundária e use o Olho Inquieto para encontrar a Forja de Golem que, a propósito, é subterrânea!"]
	quest.4D4DE266A2A325B0.title: "Itens de Golem"
	quest.4D53D9BBD8279282.quest_desc: ["As Árvores Lunares podem variar de árvores imponentes e gigantescas a pequeninas. Elas se adaptam para ocupar o máximo de espaço possível! (Isso explicaria as Florestas Densas). \\n\\nElas são plantadas como mudas normais e podem ter Bagas Lunares surgindo de suas folhas!"]
	quest.4D562F5D72038083.quest_subtitle: "Amieiro + Lariço Europeu"
	quest.4D57A07592AED307.quest_desc: [
		"O &3&lPerseguidor&r é um Chefe que pode ser invocado quebrando Vasos Ancestrais. \\n\\nEle tem 200 &4Corações&r e uma Barra de Chefe para acompanhar. Precisaremos matá-lo para obter &3Cristais de Alma&r. \\n\\nEle é muito rápido e causa muito Dano se te acertar. Felizmente, ele é Cego, como o &9&lWarden&r. Mas ele também tem um incrível senso de audição que lhe permite ouvir tudo por perto. \\n\\nEle tem alguns ataques, normalmente ele apenas te Baterá. Às vezes, ele pode causar um ataque em área e pode invocar &3Sanguessugas de Sculk&r para te atacar! \\n\\nEle também atacará todos os Mobs que não sejam de &3Sculk&r."
		"{image:atm:textures/questpics/deepndark/dnd_stalker.png width:100 height:200 align:center}"
	]
	quest.4D57A07592AED307.title: "&3&lPerseguidor"
	quest.4D62C62B523C69EC.quest_desc: ["O Gerador gera FE usando combustíveis queimáveis como Carvão."]
	quest.4D62C62B523C69EC.quest_subtitle: "Fornecendo Energia!"
	quest.4D644A9829C240CB.quest_desc: ["Você gosta do escudo do &b&lIgnis'&r? Bem, você pode fazer um para si mesmo com &bIgnitium&r. \\n\\nO &bBaluarte da Chama&r pode ser usado como um Escudo normal, mas também tem um efeito especial. \\n\\nAo Segurar o Clique Direito e Shift, soltar permitirá que você avance contra o que estiver à sua frente, como as cabras fazem. \\n\\nO que for atingido sofrerá Dano e, se for pressionado contra uma parede, também ficará atordoado. \\n\\nDefinitivamente bom ter por perto!"]
	quest.4D644A9829C240CB.title: "&bBaluarte da Chama"
	quest.4D7D4C718837BCA5.quest_desc: ["A parte principal da receita para o Portal do Nether em Miniatura é a &3Estante Infernal da Visão Magistral&r. Geralmente, ela é usada para ver quais Encantamentos você obterá, mas estamos aqui pela &6&lEstrela ATM&r, não por Encantamentos. \\n\\nVocê só precisará encantar até uma &4Estante Infernal Infundida&r, que pode ser obtida com apenas algumas Estantes. Então você precisa fabricar com ela para aprimorá-la ainda mais! \\n\\nDepois disso, você pode fabricar o Portal do Nether em Miniatura, pelo qual não, você não pode passar, você é grande demais!"]
	quest.4D8190E94851C546.quest_desc: ["&cFios&r energizados (&cFios&r transportando &cEnergia&r são &cFios&r energizados) irão machucá-lo ao usar um &6&lGancho Aéreo&r neles. \\n\\nA menos que você isole seu Punho!"]
	quest.4D822D92492E1F53.quest_desc: ["O &3Aptrgangr&r é o mini chefe dentro da &3Prisão Gelada&r. \\n\\nEles têm 480 &4Corações&r e irão atacá-lo com seu machado gigante. \\n\\nEles podem balançar seu Machado normalmente, ou podem esmagá-lo no chão perto de você. Quando fazem isso, lasers aparecerão, danificando tudo em seu caminho. Eles também têm um ataque de carga semelhante ao do &eKobolediator&r! \\n\\nNa morte, eles derrubarão Barras e Pepitas de Aço Negro, e Carne Podre e Ossos."]
	quest.4D822D92492E1F53.title: "&3Aptrgangr"
	quest.4D836B9D9E3B898F.quest_desc: [
		"&2Stoneborns&r são a mistura perfeita de Aldeões e Golems de Ferro. \\n\\nVocê pode negociar com eles clicando com o botão direito. \\n\\nE eles lutarão contra Mobs Hostis (ou Jogadores que os atingirem)."
		"{image:atm:textures/questpics/undergarden/undergarden_stoneborn.png width:100 height:150 align:center}"
	]
	quest.4D836B9D9E3B898F.title: "&2Stoneborn&r"
	quest.4D8B82FBA0FFD49E.quest_subtitle: "Nível: &63"
	quest.4D8C9960BB675221.quest_desc: ["Tem um nome engraçado!"]
	quest.4D98D2123BD5BFB3.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Minera troncos adjacentes de uma só vez, note que aumentará o tempo necessário para quebrar ao minerar múltiplos troncos."
	]
	quest.4DB5DD6E20619B4D.quest_desc: ["Usado para tornar as máquinas melhores. Existem 4 níveis de adicionais, e mais 8 especificamente para Alcance."]
	quest.4DBC3B4D38CC6152.quest_desc: [
		"Mariposas Cristalizadas aparecem nas profundezas dos Desertos Cristalizados. \\n\\nElas são neutras e eu recomendo não atacá-las porque elas causam muito dano! \\n\\nElas também têm 10 Corações e podem derrubar Cristais de Starlight ou Gel Trêmulo na morte."
		"{image:atm:textures/questpics/eternal/starlight_moth.png width:125 height:100 align:center}"
	]
	quest.4DBC3B4D38CC6152.title: "Mariposa Cristalizada"
	quest.4DC435B42889FE12.quest_desc: ["Qualquer Bioma com Gelo ou Neve é onde você encontrará estas!"]
	quest.4DC435B42889FE12.title: "Encontrando &bPedras do Gelo"
	quest.4DC4FFD69B1688BF.quest_subtitle: "Balsa + Eucalipto Rosa"
	quest.4DCEC4B97E24B6F1.quest_subtitle: "&f17 de &cDano de Ataque"
	quest.4DDF647FE6494DE1.quest_subtitle: "Aumenta a Produtividade das Abelhas em 260% entre outras coisas."
	quest.4DDF647FE6494DE1.title: "&fMelhoria de &6Produtividade Omega"
	quest.4DF0D7B85065ADC9.quest_subtitle: "Picar e fatiar!"
	quest.4DF0D7B85065ADC9.title: "Ferramentas do Ofício: Faca de Açougueiro"
	quest.4DF23FC932F5EB7D.quest_subtitle: "Nível: &b4"
	quest.4DF683461225690F.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_iron.png width:100 height:150 align:center}"]
	quest.4DF683461225690F.title: "&7Ferro&r"
	quest.4E03AE15BEF86178.quest_desc: [
		"Melhorias Válidas:"
		"- Mob Scanner"
		"- Auto Smoker"
		"- Cauterize Wounds"
		"- Drops Teleporter"
	]
	quest.4E09BBC0BAED3440.quest_subtitle: "Nível: &c5"
	quest.4E18E28BDF6B7983.quest_desc: ["As &cPortas do Reator de Fusão&r substituirão o Vidro do Reator dentro do &c&lReator de Fusão&r para poderem ser usadas. \\n\\nPrecisaremos de algumas &cPortas&r. 2 (ou 1) para &cDeutério&r e &aTrítio&r (ou apenas &5Combustível D-T&r) para o Combustível. Também precisaremos de 1 para a Saída de &aEnergia&r. \\n\\nSe você quiser usar &9Água&r para resfriar o &c&lReator de Fusão&r, precisará de mais 2 &cPortas&r. 1 para a Entrada de &9Água&r e 1 para a Saída de Vapor. \\n\\nComo outras Portas, podemos usar o &3Configurador&r para definir se a &cPorta&r funcionará como Entrada ou Saída!"]
	quest.4E18E28BDF6B7983.title: "&cPortas do Reator de Fusão"
	quest.4E1E31EDD544EE10.quest_subtitle: "64.000mb"
	quest.4E27182763DA83DC.quest_desc: ["Versão aprimorada do Peitoral Wyvern."]
	quest.4E27182763DA83DC.title: "Peitoral Dracônico"
	quest.4E28B67554CBDAB7.quest_desc: ["Segunda em dano de todas as Espadas. A primeira em dano causa Infinito, e não há como competir com o Infinito."]
	quest.4E28B67554CBDAB7.title: "Espada de &5Liga&r de &6Allthemodium&r &3"
	quest.4E297778DCEEC963.quest_desc: ["Dissipadores de Calor Avançados são nossas únicas Melhorias exclusivas para a &5&lRailgun&r. \\n\\nIsso fará com que a &5&lRailgun&r carregue muito mais rápido!"]
	quest.4E2C589C7638390F.quest_desc: ["O &3Arco Amaldiçoado&r funciona de maneira semelhante a um Arco com o Encantamento de Tiro Múltiplo! \\n\\nCom Flechas normais, ele disparará 3 de cada vez! Com Flechas especiais, ele disparará apenas 2. \\n\\nEu me pergunto se você também pode Encantá-lo com Tiro Múltiplo?"]
	quest.4E2C589C7638390F.title: "&3Arco Amaldiçoado"
	quest.4E3D548E5D8D7D26.quest_desc: [
		"Campos Esquecidos são as Planícies do &2&lUndergarden&r. \\n\\nEles não têm Árvores, mas têm muitas Rochas, Flores e Mobs! \\n\\nNo entanto, eles não geram &7Esquecidos&r, sim, desculpe estragar seu entusiasmo."
		"{image:atm:textures/questpics/undergarden/undergarden_field.png width:200 height:100 align:center}"
	]
	quest.4E3D548E5D8D7D26.title: "Campos Esquecidos"
	quest.4E4C8BCD45766F03.quest_desc: ["Esta Gaveta converterá automaticamente o item colocado dentro dela para sua forma compactada."]
	quest.4E4C8BCD45766F03.quest_subtitle: "Compacta/Descompacta Automaticamente"
	quest.4E69C6ABFE467C25.quest_desc: ["O &#65C2A6Fundidor de Ligas&r vem do &#3187C4Extended Industrialization&r. Ele combina as funções do &#4C4BDEMisturador&r e da &#954BDEFornalha&r em um só, tornando o trabalho menos cansativo."]
	quest.4E69C6ABFE467C25.title: "&fO &7Forno de Ligas"
	quest.4E737C490DCC5D6C.quest_desc: [
		"A &5Armadura de Unobtainium&r é o melhor que podemos obter do &6&lAllTheModium&r! Precisaremos dela para as verdadeiras melhores Armaduras! \\n\\nA &5Armadura de Unobtainium&r dá 40 Pontos de Armadura, 60 de Resistência de Armadura, mais 100% de Resistência a Repulsão. Você não vai a lugar nenhum! \\n\\nAgora, junto com os outros efeitos dados pelas Armaduras anteriores, teremos 90% de &dResistência a Dano Mágico&r."
		"{image:atm:textures/questpics/allthemodium/all_armor_uno.png width:100 height:175 align:center}"
	]
	quest.4E737C490DCC5D6C.title: "Armadura de &5Unobtainium"
	quest.4E7823C2FCEBE4DC.quest_desc: ["Apenas um Arco normal que consome &aEnergia&r em vez de Durabilidade."]
	quest.4E7823C2FCEBE4DC.title: "&3Arco Elétrico"
	quest.4E7990AEBCCC3C95.quest_subtitle: "Nível: &b4"
	quest.4E7B1B16C7CDA84C.quest_subtitle: "Igual ao do vapor"
	quest.4E7B1B16C7CDA84C.title: "&5Compressor Elétrico"
	quest.4E802144C6E40D43.quest_subtitle: "Ébano do Ceilão + Cereja"
	quest.4E802144C6E40D43.title: "Muda de Lagerstroemia Roxa"
	quest.4E82E843737045D9.quest_desc: [""]
	quest.4E82E843737045D9.quest_subtitle: "&oEssência dos seres mais poderosos."
	quest.4E82E843737045D9.title: "&d&lAlma de Dragão"
	quest.4E895C54651A3CB3.quest_desc: ["&8Tomos&r são &7Livros&r... apenas &7Livros&r mais úteis! \\n\\nCada &8Tomo&r é Fabricado com &7Livros&r, Varetas, &cVaras de Blaze &fe &cPó de Blaze&r. \\n\\n&8Tomos&r podem ser &5Encantados&r, como Itens, para obter certos &5Encantamentos&r. \\n\\nHá também os &8Tomos da Desmontagem&r que podem ser usados em Bigornas para tirar &5Encantamentos&r de Itens."]
	quest.4E895C54651A3CB3.title: "&8&lTomos"
	quest.4E8A05C3BFA80540.quest_desc: ["Indiscutivelmente o aspecto mais importante do Applied Energistics 2 é seu sistema de armazenamento, fazendo uso de &eCélulas de Armazenamento&f digitais. Essas células são acessíveis através de um &eBaú ME&r para células únicas, ou um &eGabinete ME&r para múltiplas células.\\n\\nO &bBaú ME&f comporta uma única Célula por vez, que pode então ser lida e escrita de qualquer outro terminal na mesma rede. O próprio Baú ME também fornece sua própria tela de terminal no topo com acesso específico apenas à célula que contém.\\n\\nO &bGabinete ME&f pode comportar até 10 Células de Armazenamento variadas no espaço de um único bloco e um único canal ME. No entanto, ele não fornece sua própria tela de terminal, exigindo algum terminal externo em outro lugar da rede para acesso ao armazenamento."]
	quest.4E8A05C3BFA80540.quest_subtitle: "Itens como um sistema de arquivos"
	quest.4E8A05C3BFA80540.title: "O Armazenamento"
	quest.4E8C32CD6057A1AB.quest_desc: ["Para fazer o &c&lCombustível do Filósofo&r, você precisa fabricar o &cQueimador de Blaze&r. \\n\\nEste &ccomponente&r é essencial para a fabricação desse combustível poderoso (&n&lou quase&r&r), então não tem como pular essa etapa! \\n\\nCertifique-se de reunir tudo o que você precisa para fabricar o seu &cQueimador de Blaze&r antes de avançar."]
	quest.4E8C32CD6057A1AB.quest_subtitle: "Combustível que nunca se apaga… ou será? 🔥"
	quest.4E8C32CD6057A1AB.title: "&cQueimadores de Blaze&f"
	quest.4E8ECD407C8EA2DC.quest_subtitle: "Tangerina + Pomelo"
	quest.4E921DD32E1C4ABA.quest_desc: ["O próximo na lista é o &7&lJoeychin01&r! \\n\\n&7&lJoey&r não tem um Canal, mas ele ajuda muito com nossos Modpacks! \\n\\nDigo, ei, isso ainda é Conteúdo e ele o está produzindo. Então eu o considero um Criador de Conteúdo."]
	quest.4E921DD32E1C4ABA.title: "&l&7Joeychin01"
	quest.4E943465A0F727A9.quest_desc: ["Assim que você escolher um Inicial, você receberá a &2Pokepedia&r! \\n\\nEste livro é o seu guia completo para tudo em &c&lCobble&fmon&r. \\n\\nVocê até pode seguir apenas o livro em vez das Missões... Mas... \\n\\nPreferimos que você siga ambos!"]
	quest.4E943465A0F727A9.title: "&2Pokepedia"
	quest.4E9B35DCA018FD42.title: "Melhorias de Ferramentas"
	quest.4E9DDDBD8263D0E3.quest_desc: ["O &7Símbolo da Desnomeação&r faz o que o nome sugere: quando você tem um &eItem com Afixo&r com um nome estranhamente longo, pode combiná-lo com o &7Símbolo&r em uma &8&lMesa de Ferraria&r para se livrar da maior parte do nome. \\n\\n(Apenas o Material e o Tipo do Item, assim como a cor da Raridade, permanecerão)."]
	quest.4E9DDDBD8263D0E3.title: "&7Símbolo da Desnomeação"
	quest.4EAD06B0B3AD7D6E.quest_subtitle: "Fragmenta minérios brutos"
	quest.4EAD06B0B3AD7D6E.title: "Grumos"
	quest.4EAFE7B240AF0A4D.quest_desc: ["Simplesmente não consegue alcançar o que precisa? Tente Aumentar o Alcance! \\n\\nCom isso, tudo fará suas ações, mas mais longe. O Vácuo tem um alcance maior para pegar itens. A Energia vai mais longe. O Arremessador arremessa com mais força!"]
	quest.4EB7245727EE1EF9.quest_subtitle: "Nível: &63"
	quest.4ED01E04D55999D9.quest_subtitle: "Despeje Uru Derretido sobre um Ovo de Gerador de BeeBee"
	quest.4ED01E04D55999D9.title: "&fAbelha de Uru Metal"
	quest.4ED29ACF4A699E1B.quest_subtitle: "É 'mais melhor'"
	quest.4ED36AA3766E842B.quest_desc: ["Em vez de construir a menor Turbina neste ponto, é melhor construir uma Turbina baseada no design do seu &9Reator&r.\\n\\nPara começar, você quer construir uma Turbina que possa lidar com a &9Taxa de Produção de Vapor&r do seu reator. Para obter o máximo de energia dela, ela precisará manter 900RPM ou 1800RPM também. Isso exige muita experimentação com diferentes bobinas, número de pás e tamanho geral da Turbina!\\n\\nNota: Para completar esta missão, você precisará criar uma &dTela de Tarefas&r de qualquer tamanho. Uma vez colocada, você pode clicar com o botão direito na tela e selecionar esta missão como o requisito, então fornecer energia ao bloco da tela de tarefas para preenchê-la e completar a missão."]
	quest.4ED36AA3766E842B.title: "&dA Turbina"
	quest.4EDD96EB60EF5814.quest_desc: ["Se você está se perguntando se vale a pena fazer esta atualização, a resposta é sim.\\n\\nOs &e&l&oGerador a Energia Solar Avançado&r ocuparão mais Espaço e são caros de Fabricar, mas gerarão muito mais &aEnergia&r. \\n\\nEles funcionam da mesma forma que os &e&lGerador a Energia Solar&r normais, durante o &eDia&f e precisam de Exposição ao &bCéu&r. \\n\\nEles podem conter 100kFE! \\n\\nVocê também pode adicioná-los no topo do &6&lPlanta de Evaporação Térmica&r para produzir mais &6Calor&r."]
	quest.4EDD96EB60EF5814.quest_subtitle: "Gera cerca de 480FE/t"
	quest.4EDD96EB60EF5814.title: "&l&e&oGerador Solar Avançado"
	quest.4EE10B8E194F5CA9.quest_desc: ["O &6&lCreate&r 1.21 agora também vem com Trens incluídos no Mod base. \\n\\nPrimeiro, você precisará de &5Metal Resistente&r! \\n\\nEsmague &5Obsidiana&r para obter &5Pó de Obsidiana&r. Em seguida, use um &bBico&r para colocar &cLava&r no &5Pó de Obsidiana&r. \\n\\nDepois disso, Pressione-o duas vezes com &6Prensas Mecânicas&r e você obterá &5Metal Resistente&r. \\n\\nO &5Metal Resistente&r pode então ser aplicado a uma &eCarcaça de Latão&r para fazer &5Carcaças de Trem&r."]
	quest.4EE10B8E194F5CA9.title: "&5&lTrens"
	quest.4EE482B9D61B5933.quest_desc: ["Claro que o &2Vanilla&r não é nosso máximo, há muito mais e muito mais raro no Modificado!"]
	quest.4EEAB467C722ECE7.quest_desc: ["Estes são canos simples que podem ser melhorados com Melhorias de Cano.\\n\\nPara 'extrair' energia de um bloco, coloque o cano ao lado do bloco e, no lado que está conectado, shift+clique com o botão direito com a chave de cano para definir o cano para extrair.\\n\\nO mod &e&lPipez&r também oferece maneiras de transportar itens, gases e líquidos! Ou você pode fazer um Cano Tudo-em-Um chamado &aCano Universal&r.\\n\\nOutras Chaves Inglesas funcionam com &e&lPipez&r também!"]
	quest.4EEAB467C722ECE7.title: "&9Pipez: &aCanos de Energia"
	quest.4EF5DE3FBA2A7AE3.quest_desc: ["Começando com a Essência de Inferium, você pode criar Barras para fazer tanto &9Ferramentas&r quanto &9Armaduras&r de Essência.\\n\\nAs ferramentas de Essência podem ser atualizadas para níveis mais altos e, assim como a Armadura, podem ser &5Aumentadas&r na &3Mesa de Bricolagem&r."]
	quest.4EF5DE3FBA2A7AE3.title: "Ferramentas de &aInferium"
	quest.4EFFE300EC781C3E.quest_desc: ["Módulos são muito importantes para nossos itens do DE. Tão importantes que eles não funcionam sem eles! A maioria dos Módulos é feita de um Núcleo de Módulo ou de um Módulo anterior. Segure um item e pressione Shift e C para abrir o Menu de Módulos. Lá você verá alguns slots e botões! Os Slots são onde os Módulos realmente vão e a Grade é o que determina quantos Módulos podem ir. Quando um Módulo diz 1x1, ele ocupará apenas 1 Slot, enquanto um que diz 2x2 ocupará 4 slots. O botão mais baixo à direita mostrará quais Módulos podem ser aplicados ao Item que você está segurando. O resto apenas muda a aparência da GUI."]
	quest.4EFFE300EC781C3E.title: "Módulos!"
	quest.4F03B152479C4AC0.quest_desc: ["O &bCajado das Riquezas&r usa aura para destacar todos os contêineres de armazenamento em um raio de 64 blocos por cerca de 1 minuto.\\n\\nIsso pode ser muito útil se você estiver procurando por baús de tesouro ou se colocou um baú em uma mina em algum lugar."]
	quest.4F03B152479C4AC0.title: "&bCajado das Riquezas"
	quest.4F0DD86CF6E5F1B5.quest_subtitle: "Nível: &b4"
	quest.4F137DB561F45306.title: "Armadura de &2Prudentium&r"
	quest.4F144E5F70932C7D.quest_desc: [
		"Outra estrutura flutuante! (Acho que estou notando um padrão aqui). \\n\\nAqui você encontrará toneladas de Tesouros em Casulos e sob Cristais de Mel Luminoso. \\n\\nVocê também encontrará toneladas de Phantoms aqui, daí o nome! Talvez queira algo para prevenir dano de queda..."
		"{image:atm:textures/questpics/bumblezone/bumble_phantasm.png width:200 height:100 align:center}"
	]
	quest.4F144E5F70932C7D.title: "Aviário Fantasma"
	quest.4F1FFC02F4EAA2E6.title: "Nível: &4Nitro"
	quest.4F35D04721DFC9FF.quest_desc: [
		"O primeiro tipo de ritual que faremos é o &9Ritual de Invocação&r. Esses rituais são usados para invocar diferentes tipos de Demônios úteis para ajudá-lo a triturar, fundir e muito mais, à medida que você alcança níveis mais altos de rituais."
		""
		"Para nosso primeiro ritual, queremos invocar um Demônio &aTriturador Foliot&r. Este Demônio irá triturar itens para nós, algo que precisaremos para fazer alguns dos Gizes de nível superior!"
		""
		"Para começar, combine seu Livro Desvinculado com seu &aDicionário de Espíritos&r em uma grade de fabricação. Isso vinculará um Demônio ao Livro, que é o que precisaremos para o ritual."
		""
		"Falando em seu Dicionário de Espíritos, é hora de abri-lo! À esquerda, clique na aba &dPentáculos&r e clique em &bCírculo de Aviar&r. Você pode ter que avançar lendo um pouco. Há também uma maneira de clicar em \\\"Marcar Tudo Como Lido\\\" para desbloquear tudo no Livro."
		""
		"É isso que vamos usar para invocar nosso novo amigo. No lado direito, você pode clicar no olho no canto inferior esquerdo da imagem para construir um esboço do ritual para você no mundo. Isso é super útil!"
		""
		"Depois de completar o ritual multibloco, coloque 4 (ou mais para rituais futuros) Tigelas de Sacrifício em qualquer lugar dentro de um raio horizontal de 8 blocos da Tigela de Sacrifício central e use os itens necessários nelas. Assim que você colocar seu Livro Vinculado na Tigela de Sacrifício Dourada, o ritual começará!"
		""
		"É assim que o ritual se parecerá."
		""
		"{image:atm:textures/questpics/occultism/aviarcirclenew.png width:200 height:200 align:1}"
	]
	quest.4F35D04721DFC9FF.quest_subtitle: "Círculo de Aviar"
	quest.4F35D04721DFC9FF.title: "&bNosso Primeiro &dRitual"
	quest.4F3B4990BE6C2A4A.quest_desc: [
		"&7Scintlings&r são pequenas lesmas inocentes encontradas em toda parte no &2&lUndergarden&r. \\n\\nEles agem como Golems de Neve, deixando um rastro por onde andam. Só que este é mais Gosmento... \\n\\nNa morte, eles derrubam Gosma de Scintling, mas você pode simplesmente cultivá-la de seus rastros, então por que matá-los!"
		"{image:atm:textures/questpics/undergarden/undergarden_scintling.png width:150 height:100 align:center}"
	]
	quest.4F3B4990BE6C2A4A.title: "&7Scintling&r"
	quest.4F3EF1574F31A7E2.quest_desc: ["A Câmara de Estase pode manter mobs no lugar em sua área de trabalho. Os mobs mantidos sob estase também são curados pela Câmara. Precisa de mais cura? Obtenha alguns adicionais!"]
	quest.4F460A7A6F0C704B.quest_desc: ["&2Pedras da Folha&r aparecem em Florestas, Selvas e Cavernas Exuberantes. \\n\\nEntão, basicamente em qualquer lugar!"]
	quest.4F460A7A6F0C704B.title: "Encontrando &2Pedras da Folha"
	quest.4F4C1A349F953013.quest_subtitle: "Encontrado no Undergarden"
	quest.4F4C1A349F953013.title: "&fAbelha Esquecida"
	quest.4F5348D0C83C3B0D.quest_desc: ["&3Células Solares&r são usadas para fazer Compressores Solares."]
	quest.4F5348D0C83C3B0D.quest_subtitle: "As Células do Sol"
	quest.4F5348D0C83C3B0D.title: "Células Solares"
	quest.4F56BFE6E4716F6D.quest_desc: [
		"O &8&lForno a Arco&r é uma Máquina massiva e útil. Ele torna a maioria das outras Máquinas inúteis! \\n\\nPara começar, você precisará de Entrada de &cEnergia&r pelas saídas na Parte Traseira do &8&lForno a Arco&r. Ele então precisará de Combustível, que são &0Eletrodos de Grafite&r. Estes só podem ser colocados em sua GUI, não podem ser automatizados. \\n\\nVocê então precisará &6Inserir&r os &eItens&r nos Portas Superiores, perto de onde os &0Eletrodos de Grafite&r estão. Quando abastecido e ligado, ele derreterá praticamente qualquer coisa. De &7Varas de Ferro&r a &7Iron Ingots&r, de &bElmos de Aço Gelado&r a &bAço Gelado&r, de &ePicaretas de Ouro&r a &eOuro&r! \\n\\nOs &eItens&r derretidos serão &6Saída&r na Parte Traseira, abaixo das Saídas de Energia. \\n\\nEle também pode fazer Ligas de Metais!"
		"{@pagebreak}"
		"A 1ª camada começa com um U feito de &8Chapa de Aço&r com o centro sendo um &7Bloco de Engenharia Pesada&r e as pontas sendo &8Blocos de Aço&r. O resto será de &8Lajes de Chapa de Aço&r com um &8Andaime de Aço&r e um Caldeirão perdidos."
		"{image:atm:textures/questpics/immersive/immersive_arc1.png width:100 height:100 align:center}"
		"A 2ª camada começa com, acima do &7Bloco de Engenharia Pesada&r e dos 2 Blocos ao lado, &eBlocos de Engenharia Leve&r. Então, os lados do U serão &7Blocos de Engenharia Pesada&r. Com mais &8Blocos de Aço&r acima dos anteriores. Também precisaremos de um 2x3 de &4Tijolos de Alto-forno Reforçados&r acima das &8Lajes&r. Não se esqueça do &4Bloco de Engenharia de Redstone&r acima do &8Andaime&r!"
		"{image:atm:textures/questpics/immersive/immersive_arc2.png width:100 height:100 align:center}"
		"A 3ª camada tem mais &8Blocos de Aço&r, mais &eBlocos de Engenharia Leve&r e uma extensão de nossos &4Tijolos de Alto-forno Reforçados&r. Também precisaremos de 1 &8Chapa de Aço&r de cada lado."
		"{image:atm:textures/questpics/immersive/immersive_arc3.png width:100 height:100 align:center}"
		"A 4ª precisa de um &eBloco de Engenharia Leve&r colocado no meio, acima dos outros. Ao lado, haverá 2 &8Andaimes de Aço&r. E precisaremos adicionar mais &4Tijolos de Alto-forno Reforçados&r, mas desta vez um Bloco de comprimento a menos!"
		"{image:atm:textures/questpics/immersive/immersive_arc4.png width:100 height:100 align:center}"
		"A 5ª e última camada são apenas mais 2 &8Andaimes de Aço&r em cima dos outros. Então, &eBlocos de Engenharia Leve&r acima do anterior e em uma linha à sua frente."
		"{image:atm:textures/questpics/immersive/immersive_arc5.png width:100 height:100 align:center}"
		"Finalmente, Clique com o Botão Direito no Caldeirão com o &6Martelo&r para finalizá-lo!"
		"{image:atm:textures/questpics/immersive/immersive_arc.png width:100 height:100 align:center}"
	]
	quest.4F56BFE6E4716F6D.title: "&8&lForno a Arco"
	quest.4F5A2E2A5C7F4837.quest_desc: ["Barras &aEsquecidas&r precisam ser obtidos através das Catacumbas; seja saqueando os Baús ou matando o &aGuardião Esquecido&r. \\n\\nVocê também precisará de um Modelo de Ferraria que é encontrado em Baús de Catacumbas."]
	quest.4F5A2E2A5C7F4837.title: "&aEsquecido&r"
	quest.4F6A9F1AEFD535F5.title: "Módulo Grande de Capacidade de Escudo Dracônico"
	quest.4F780343E3FFA43E.quest_subtitle: "Este é o Fim"
	quest.4F7F0A5162D70082.quest_desc: ["Não se confunda, existe um &5Cubo de Energia &aCriativo&r cheio e vazio. \\n\\nOs &aCubos Vazios&r funcionam como uma Lixeira de Energia, anulando qualquer Energia que entre neles. \\n\\nOs &aCubos Cheios&r funcionam como um armazenamento infinito de energia. Você precisará de &aCubos de Energia vazios&r para fazê-lo, no entanto... e eles são caros! \\n\\nEnergizando 4 &aCubos de Energia vazios&r com uma &6&lEstrela ATM&r, você pode obter o cheio."]
	quest.4F7F0A5162D70082.title: "&5&lCubo de Energia &aCriativo"
	quest.4F7F8F4ED1CA0550.quest_desc: ["Uma &cFogueira&r usada no gerador fará com que os mobs apareçam pegando fogo. Perfeito para um bom &cBife&r."]
	quest.4F7F8F4ED1CA0550.title: "&cQueimando"
	quest.4F870252E9FB1A41.quest_desc: ["O reator pode ser abastecido com Varas de Combustível, que são as mais básicas que você pode fabricar."]
	quest.4F89C04CEBF812F9.quest_subtitle: "Funda gemas em barras"
	quest.4F89C04CEBF812F9.title: "Barras"
	quest.4F9932477EDDCB8E.quest_desc: ["A Pistola de Portal Avançada é a versão atualizada da Pistola de Portal que requer tanto energia quanto fluido de portal para operar. Ao contrário da Pistola de Portal, a Pistola de Portal Avançada permite ao jogador teletransportar-se entre locais que foram codificados. Usando \"V\" (atalho de teclado padrão), o menu usado para codificar e selecionar destinos para teletransporte."]
	quest.4F9C8D90ACF563F5.quest_desc: ["Obrigado &2&lMinecraft&r pelo Update Aquatic, mas Nadar ainda pode ser muito lento. \\n\\nEntão por que não acelerar isso! Assim como o encantamento Passos Profundos! \\n\\nCom a &9Unidade de Repulsor Hidrostático&r você pode Andar e Nadar mais rápido na &9Água&r."]
	quest.4F9C8D90ACF563F5.quest_subtitle: "Calças"
	quest.4F9C8D90ACF563F5.title: "&9Unidade de Repulsor Hidrostático"
	quest.4F9D6109EEA5D26A.quest_desc: ["Quebrar &eFolhas Douradas&r tem uma alta chance de dropar uma &eFolha Dourada&r, que é necessária para o &ePó de Ouro&r."]
	quest.4F9D6109EEA5D26A.quest_subtitle: "Aura com Vagalumes"
	quest.4F9D6109EEA5D26A.title: "&eFolhas Douradas"
	quest.4FA156C383C9C438.quest_desc: ["&eKoboletons&r são mini Esqueletos de Dinossauros que servem ao &e&lRemanescente Ancestral&r. \\n\\nEles têm apenas 12 e meio &4Corações&r e te atacam com seu Khopesh. \\n\\nEles podem dropar sua arma, junto com seus Ossos e Pepitas de Metal Ancestral."]
	quest.4FA156C383C9C438.quest_subtitle: "Mini Dinos!"
	quest.4FA156C383C9C438.title: "&eKoboletons"
	quest.4FA5192164E4A427.quest_desc: ["Fluidos não se empilham como Itens, então sua atualização é um pouco diferente. Ainda move mais, só que a uma taxa diferente."]
	quest.4FA6BEA4E646B742.quest_desc: ["Antes de podermos começar a construir nosso reator, precisaremos fundir um pouco de Carvão ou Carvão Vegetal para criar &9Barras de Grafite&r.\\n\\nGrafite, juntamente com Ferro, é um dos principais materiais ao fazer um Reator."]
	quest.4FA6BEA4E646B742.quest_subtitle: "Carbono Endurecido"
	quest.4FA6BEA4E646B742.title: "Grafite para Carcaças"
	quest.4FA7774D89171BB3.quest_desc: ["Quer outro pet de &4&lCataclysm&r? Então o Crânio Remanescente é o que você precisa! \\n\\nÉ um drop confirmado do &eRemanescente Ancestral&r e quando usado irá gerar um Revenant Moderno. \\n\\nEste é muito menor e mais legal que o &eAncestral&r. Você pode domesticá-lo alimentando-o com um Ovo de Sniffer e então ele agirá como um cachorro. \\n\\nAtacando o que te ataca ou o que você ataca. Ele também tem 3 modos: seguir, vagar e ficar. Seguir, ele vai... bem, te seguir. Vagar fará com que ele ande por uma determinada área. E ficar fará com que ele se deite em um lugar. \\n\\nEles têm 1,500 &4Corações&r e eu aprendi que você pode alimentá-los com &eOssos de Koboleton&r para curá-los! \\n\\nAproveite seu novo dino!"]
	quest.4FA7774D89171BB3.title: "O que não deve ser nomeado por minhas razões de travamento"
	quest.4FBAB3A0FBF8CE2F.quest_desc: [
		"Por que se preocupar com o que está sendo movido quando você pode simplesmente mover tudo! Os &5Pipez Universais&r são ainda menos discriminatórios que os &cPipez de Energia&r. Eles podem mover &eItens&r, &bFluidos&r ou &cEnergia&r."
		"{image:atm:textures/questpics/logistics/pipez_universal.png width:200 height:50 align:center}"
	]
	quest.4FBAB3A0FBF8CE2F.title: "&5Pipez Universais"
	quest.4FCC20D9F8F87B2F.quest_desc: ["A &3Chave Pneumática&r é usada para mover ou quebrar suas máquinas e tubos."]
	quest.4FCC20D9F8F87B2F.quest_subtitle: "Torque-ando sobre Ferramentas!"
	quest.4FD9219B6005D90E.quest_desc: ["Assim que você derrotar o &4&oRadical Red&r você poderá encontrar o &6Trainer Red&r, o personagem principal dos primeiros jogos e mídias! \\n\\nEle é um lutador opcional. Isso significa que ele não possui um Item de Assinatura, em vez disso você precisará encontrá-lo vagando por um certo Bioma. Sendo este qualquer um que possa ter Cidades do End. \\n\\nTodos os anos lutando contra Treinadores em vários jogos e mídias fizeram dele um lutador muito bom, então traga o seu melhor! \\n\\nSe você conseguir derrotá-lo, você se tornará a Lenda de Kanto!"]
	quest.4FD9219B6005D90E.title: "&6Treinador Red"
	quest.4FE7F45C72EF5DC1.quest_subtitle: "Ferro + Suor"
	quest.4FE7F45C72EF5DC1.title: "&fAbelha de Níquel"
	quest.50013DD7370F8EDB.title: "Módulo de Salto Caótico"
	quest.500BEAD94C97DF96.quest_desc: ["Pode ser colocado em uma colmeia ou centrífuga.\\n\\nQuando em uma colmeia, diminui a quantidade de tempo que as abelhas passam na colmeia em 20%.\\n\\nQuando colocado em uma Centrífuga, aumenta a velocidade de processamento.\\n\\nEstes se acumulam."]
	quest.500BEAD94C97DF96.quest_subtitle: "Abelhas Sônicas"
	quest.500BEAD94C97DF96.title: "&fMelhoria de &6Velocidade"
	quest.50150380043F97F9.title: "O Voo do Besouro"
	quest.501A0AEEC73C0790.quest_desc: ["&6Piglich&r é um Chefe adicionado por &6&lAllthemodium&r que vive na Pirâmide Ancestral em &l&bO Outro&r. \\n\\nNa morte, ele dropará 1 de seus Corações! Você precisará matar 9 deles para fazer um Bloco... \\n\\nFelizmente, existem maneiras de farmá-los!"]
	quest.501A0AEEC73C0790.title: "Bloco de Coração de &6Piglich"
	quest.501C6B7580453410.quest_desc: ["O &aFluidificador&r é um multibloco personalizável que tem um tamanho mínimo de 3x3x3. Assim como os outros multiblocos, a estrutura precisará ser feita de Carcaças, enquanto as faces podem ser feitas de Vidro."]
	quest.501C6B7580453410.title: "Construção do Fluidificador"
	quest.5021D159A5EC2315.title: "Módulo de Energia Dracônico"
	quest.50243E5CF1B156ED.quest_desc: ["Para obter &5Pó de Plutônio&r, você deve fragmentar &aUrânio Bruto&r na Forja de Fragmentos para adquirir &5Pó de Plutônio Pequeno&r ou disparar um &5Laser Endérico&r em um &aCristal de Uranita&r."]
	quest.50243E5CF1B156ED.quest_subtitle: "De Uranita a Plutônio"
	quest.5030F1D96457202E.quest_subtitle: "Lariço Europeu + Abeto"
	quest.50326B1D6EE8FA0B.quest_desc: ["&cAcumuladores&r são a versão de baterias do &8&lIE&r. \\n\\nEles armazenam &cEnergia&r, com o &6LV&r segurando 100kFE, o &eMV&r segurando 1MFE, e o &5HV&r segurando 4MFE! \\n\\nPor padrão, eles têm um slot superior que só permite &9Entrada&r, mas qualquer lado pode ser alterado com o &6Martelo de Engenheiro&r para &9Entrada&r, &6Saída&r, ou Nenhum."]
	quest.50326B1D6EE8FA0B.title: "&cAcumuladores"
	quest.5034A9137E0F3D3D.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.503B409765D30E60.quest_desc: ["&nForte&r \\n\\n&9Dragão&r \\n\\n&nVulnerável&r \\n\\n&9Dragão&r \\n&dFada&r \\n&bGelo&r"]
	quest.503B409765D30E60.title: "&9Dragão"
	quest.5040B3D29F238BC0.quest_desc: ["Coelhinho, pula. Coelhinho, pula. Coelhinho, pula.\\n\\nCom &dSaltadores de Coelho&r nos pés, você pode pular o dobro da altura e sofrer metade do dano de queda usual! Não te torna invencível a Dano de Queda, você ainda pode morrer, só é mais difícil."]
	quest.5040B3D29F238BC0.quest_subtitle: "Pés"
	quest.5040B3D29F238BC0.title: "&dSaltadores de Coelho&r"
	quest.50429F57480F44DA.quest_desc: ["A &cPedra de Fonte Termal&r aparece em lagoas quentes encontradas raramente em &5&lEternal Starlight&r!"]
	quest.50429F57480F44DA.quest_subtitle: "16"
	quest.50429F57480F44DA.title: "Armadura de &cPedra de Fonte Termal"
	quest.504752A1C9EFED76.quest_subtitle: "Cidra + Cereja Silvestre"
	quest.5054977BD5354561.quest_desc: [
		"Melhorias Válidas:"
		"- Tree Feller"
		"- Leaf Breaker"
	]
	quest.505799C894C771B2.quest_desc: [
		"Algumas &5Máquinas&r do &5&lMekanism&r podem ser Aprimoradas, como o &9&lInfusor Metalúrgico&r e a &d&lCâmara de Enriquecimento&r. Algumas não podem, no entanto; estas só aceitam Cartões de &8Melhoria&r. \\nOs &6&lDesenvolvedores do ATM&r viram isso e quiseram que os jogadores, em vez de fazer 50 &9&lSeparadores Eletrolíticos&r, pudessem fazer 1 Multibloco! \\n\\nPara criar esses Multiblocos, no entanto, precisaremos de um Multibloco anterior. A &c&lForja Automática de Hefesto&r. \\n\\nEla tem sua própria Missão no &aCapítulo 4&r: &dCriativo&r. Dê uma olhada lá! \\n\\nTodos os Multiblocos usam a mesma Estrutura, apenas com Controladores diferentes. Confira a Próxima Página para ver as Instruções de como construí-lo!"
		"{@pagebreak}"
		"A primeira camada é a mais complicada, pois abriga todos os &cCarcaças de Máquina&r. As vários &cCarcaças de Máquina&r ficarão no meio, enquanto as &9Escadas de Pedra Sombria&r, os &9Blocos&r e a &6Pedra Sombria Polida Talhada Dourada&r os cercam."
		"{image:atm:textures/questpics/mek/mek_multi_runic1.png width:150 height:100 align:center}"
		"A segunda camada completa a primeira com mais &9Tijolos de Pedra Sombria&r e &9Escadas&r. Agora também inclui &9Lajes de Pedra Sombria&r e &7Blocos de Runa&r!"
		"{image:atm:textures/questpics/mek/mek_multi_runic2.png width:150 height:100 align:center}"
		"Não tem como ser mais simples que isso! Basta colocar &9Pilares de Pedra Sombria&r acima dos 4 &7Blocos de Runa&r externos e é só isso!"
		"{image:atm:textures/questpics/mek/mek_multi_runic3.png width:150 height:100 align:center}"
		"Eu estava certo, não fica mais simples. Continua exatamente o mesmo nível de simplicidade! Repita o passo anterior."
		"{image:atm:textures/questpics/mek/mek_multi_runic4.png width:150 height:100 align:center}"
		"Para finalizar, coloque &bBlocos de Cristal Arcano&r acima dos &9Pilares de Pedra Sombria&r e um &8Injetor Quântico&r acima do &7Bloco de Runa&r descoberto."
		"{image:atm:textures/questpics/mek/mek_multi_runic5.png width:150 height:100 align:center}"
		"Nossas &5&lMáquinas Multibloco&r precisarão de Escotilhas para funcionar! Para adicioná-las, substitua os &9Tijolos de Pedra Sombria&r da primeira camada pelas Escotilhas."
	]
	quest.505799C894C771B2.quest_subtitle: "É quase uma evolução!"
	quest.505799C894C771B2.title: "&5Máquinas&r Aprimoradas, porém Não-Aprimoráveis"
	quest.5064D5F99E2C69C8.quest_desc: ["Versão melhorada do &9Imperium&r."]
	quest.5064D5F99E2C69C8.quest_subtitle: "29"
	quest.5064D5F99E2C69C8.title: "Armadura de &4Supremium"
	quest.50674FE3C6BE9990.quest_desc: [
		"Assim como a Floresta Starlight normal, só que com muito menos espaçamento entre as Árvores!"
		"{image:atm:textures/questpics/eternal/starlight_dense.png width:200 height:100 align:center}"
	]
	quest.50674FE3C6BE9990.title: "Floresta Starlight Densa"
	quest.506F20AF8E857559.quest_desc: ["O Dínamo Cinético é um Gerador que usa momento para criar Energia! \\n\\nPara começar a criar Energia, você precisará de uma Roda d'Água ou Moinho de Vento acoplado ao lado com o buraco gigante! \\n\\nO Dínamo Cinético não tem um armazenamento interno de Energia, mas fornece Energia para Blocos conectados como Conectores ou Acumuladores."]
	quest.506F20AF8E857559.title: "Energia de coisas em movimento!"
	quest.507635FE52E22D7D.quest_desc: ["Passando de uma Skin com tema &cPokémon&r para alguém usando a Skin do Steve, é o &3&lDirewolf20&r! \\n\\nConhecido por criar e jogar Mods por anos. Agora ele será conhecido por perder para você também! \\n\\n&3&lJust Dire Things&r não vai te ajudar aqui, &3&lDirewolf&r!"]
	quest.507635FE52E22D7D.title: "&3&lDirewolf20"
	quest.508A8366219175FE.quest_desc: ["A Ferramenta de Configuração é usada para travar Gavetas para que elas se lembrem do item que têm dentro.\\n\\nIsso pode ser útil sempre que você configurar um sistema para empurrar e puxar de Gavetas. A Gaveta travada não substituirá o item que foi travado nela!"]
	quest.508CCA2DDD8602AA.quest_desc: ["Ele aumentará seu Limite de Nível para 16. \\n\\nSeu Item de Assinatura é a &eRocha Lisa&r."]
	quest.508CCA2DDD8602AA.title: "&aLíder de Ginásio Roark"
	quest.50A286C268F38E09.quest_desc: ["Nesta página de Missão, dediquei muito tempo colorindo os textos para tentar ajudar você, o Jogador, a entender a que estou me referindo. Só para perceber que pode ser ainda mais confuso, então aqui está uma Legenda! \\n\\n&5Roxo&r é qualquer Trem ou Locomotiva, tanto Locomotivas Elétricas quanto a Vapor e Vagões acoplados. \\n&6Dourado&r é qualquer Trilho e Ferrovia, inclui Trilhos especiais, mas não Kits de Trilhos. \\n&cVermelho Claro&r representa qualquer Kit de Trilhos. \\n&4Vermelho Escuro&r é para Pés de Cabra. \\n&3Ciano&r é apenas para a Locomotiva a Vapor. \\n&eAmarelo&r é apenas para a Locomotiva Elétrica. \\n&9Azul&r é para a Perfuratriz de Túnel. \\n&7Cinza&r é para Carrinhos de Mina e Vagões especiais."]
	quest.50A286C268F38E09.title: "Legenda de Cores"
	quest.50A32AC6EDBC5854.quest_desc: ["Comida por si só pode ser bem chata, mas fica muito melhor quando você tem um acompanhamento com seu prato! Mais especificamente, um (a) &6Anel de Cebola&r!\\n\\nAo usar o &6Anel de Cebola&r, tudo que você comer lhe dará um leve efeito de Pressa."]
	quest.50A32AC6EDBC5854.quest_subtitle: "Mãos"
	quest.50A32AC6EDBC5854.title: "&6Anel de Cebola&r"
	quest.50B127137AA9E660.quest_desc: ["Finalmente o &6Cobre&r tem um uso de verdade!"]
	quest.50B127137AA9E660.quest_subtitle: "13"
	quest.50B127137AA9E660.title: "Armadura de &6Cobre"
	quest.50C9CB8FB16E453D.quest_desc: [
		"A &bArena Ardente&r é uma arena gigante, estilo Coliseu, dentro do &4Nether&r. \\nVocê chegará ao primeiro andar, pacífico, mas quente. No segundo andar, encontrará &bRevenants Incendiados&r, que você precisará matar para obter &bCinzas Ardentes&r. \\n\\nQue podem ser usadas no terceiro andar, no Altar para invocar o &b&lIgnis&r! \\n\\nAh, e se estiver procurando por Tesouros, olhe acima do terceiro andar!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_arena.png width:200 height:100 align:center}"
	]
	quest.50C9CB8FB16E453D.title: "&bArena Ardente&r: Lar do &b&lIgnis&r"
	quest.50DBB87E53017E60.quest_desc: ["&bVálvulas de Fluido&r podem ser usadas para impedir que &bCanos&r movam &bFluidos&r. \\n\\nDê a eles uma Rotação, muito provavelmente de uma &cManivela de Válvula&r, para parar de mover &bFluidos&r. \\n\\nBasta Girar novamente para fazer os &bFluidos&r voltarem!"]
	quest.50DBB87E53017E60.title: "&bVálvula de Fluido"
	quest.50ED69AEEE808B24.quest_subtitle: "Alimente uma Abelha de Água com um Balde de Lítio Líquido"
	quest.50ED69AEEE808B24.title: "&fAbelha de Lithium"
	quest.50F1C4521D282C60.quest_desc: ["Os Baluartes são as unidades pesadas destes militantes. \\n\\nEles têm 12 Corações com 18 Pontos de Armadura! \\n\\nSua arma é o &b&lLança-Químicos&r com um &8&lEscudo Pesado Banhado&r na Mão Secundária. \\n\\nSe você conseguir matar um, receberá &aEsmeraldas&r e Sacos de Tonalizante Obra-Prima!"]
	quest.50F1C4521D282C60.title: "Baluarte"
	quest.50F23B2688D7E699.quest_desc: ["Com 1.000mB de &dAntimatéria&r processada em um &5&lCristalizador Químico&r, podemos fazer 1 &dPastilha de Antimatéria&r. \\n\\nIsso significa que são necessários 1.000.000mB de &aPolônio&r ou 1MmB de &aPolônio&r. \\n\\nPara todo esse &aPolônio&r, você precisará de 5.000.000mB de &8Rejeito Nuclear&r, e de &2Combustível Fóssil&r para fazer o &8Rejeito Nuclear&r. Apenas 5MmB de &2Combustível Fóssil&r... apenas! \\n\\nMas finalmente, nós o temos! O &eItem&r mais valioso de todo o &5&lMekanism&r! A &dPastilha de Antimatéria&r. \\n\\nAgora podemos fazer nosso Meka-Traje, mais armazenamento para o &e&lOIQ&r e até mesmo a &6&lEstrela do ATM&r!"]
	quest.50F97171D25CD2EE.quest_desc: ["&#6EDDFFMelhoria Turbo&r adicionam &#FFEB6E512EU/t&r de capacidade por melhoria."]
	quest.5103C817381181DE.quest_desc: ["Permite que você use uma Élitros enquanto ainda tem seu Peitoral Pneumático equipado."]
	quest.5103C817381181DE.quest_subtitle: "Máx: 1"
	quest.511144EF336BFAF5.quest_desc: [
		"As Torres de Poluição são... sim, você adivinhou! De onde toda a Poluição vem! Bem, não toda, não podemos desacreditar os &2Mogs&r e &3S'mogs&r. \\n\\nAqui você encontrará Blisterberries, Deepsoil Grosseiro e Fendas de Poluição. Eu não recomendaria chegar perto delas..."
		"{image:atm:textures/questpics/undergarden/undergarden_smogspires.png width:200 height:100 align:center}"
	]
	quest.511144EF336BFAF5.title: "Torres de Poluição"
	quest.511562EA5811306B.title: "Vara de Pesca de Diamante"
	quest.51162B9185A45BB1.quest_desc: ["Este arco pode ser inscrito com um feitiço usando uma Mesa de Escriba. \\n\\nAo custo de mana, as flechas se tornarão Flechas de Feitiço e aplicarão o feitiço em seu alvo. \\n\\nSe você não tiver flechas, uma flecha de feitiço que causa 0 de dano será lançada. Se não houver mana suficiente, flechas normais serão disparadas. \\n\\nO &9Arco do Encantador&r também pode usar Flechas de Aumento especiais que fortalecem o feitiço inscrito."]
	quest.51236544BFEF487B.quest_desc: ["É hora de encontrar &eMeteoritos&f que contêm &bPedra do Céu&f. Eles podem estar na superfície ou no subsolo e contêm um &bCubo Misterioso&f em seu centro.\\n\\nEste cubo contém todas as diferentes &ePrensas&f usadas no Inscritor para fazer os componentes de fabricação especiais do AE2.\\n\\nA maneira mais fácil de localizar um meteorito é fabricando uma &eBússola de Meteorito&r, colocando uma bússola dentro de um Carregador."]
	quest.51236544BFEF487B.quest_subtitle: "'GIBI #42: procurando por bobby [Fischer]'"
	quest.51236544BFEF487B.title: "&8&lCaça a Meteoritos"
	quest.512396B331108BAF.quest_subtitle: "Nível: &e5"
	quest.5128B119DFFF0C4C.quest_desc: [
		"A &3Locomotiva a Vapor&r é a &5Locomotiva&r mais básica. Ela pode ser alimentada com água, combustível de fornalha e esperando. Precisará de água constante para continuar funcionando. \\n\\nNão se preocupe, isso significa apenas que a fumaça que sai do topo dela é Vapor de Água, que é seguro para o Meio Ambiente. Bem, a parte do Carvão não é a melhor para o Meio Ambiente... eh, é o &2Minecraft&r, o que nos importa!"
		"{image:atm:textures/questpics/railcraft/rail_steam_locomotive.png width:100 height:100 align:center}"
	]
	quest.5128B119DFFF0C4C.title: "&3Locomotiva a Vapor"
	quest.513060836057E5B7.quest_desc: [
		"&e&lCampos Polinizados&r são... ATCHIM... como o Bioma de Planícies, mas cheios de &ePólen&r! ATCHIM... O &ePólen&r se acumula como Neve em camadas, ele... ATCHIM... se empilha sobre outro &ePólen&r e cai com a Gravidade... ATCHIM. Ele vai te desacelerar ao caminhar por ele, semelhante a... ATCHIM... Neve em Pó.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_pollenfields.png width:200 height:100 align:center}"
	]
	quest.513060836057E5B7.title: "&e&lCampos Polinizados"
	quest.5134C81D96C55375.quest_desc: ["&5Observadores de Trem&r funcionam como um Trilho de Detecção sofisticado. \\n\\nQuando um &5Trem&r passa sobre o &7Trilho&r para o qual está definido (que é escolhido como a &5Estação de Trem&r), ele emitirá um &4Sinal de Redstone&r. \\n\\nVocê também pode colocar Filtros no &5Observador&r para obter &4Sinais de Redstone&r apenas quando o &5Trem&r tiver aquele &eItem &ou &bFluido&r dentro."]
	quest.5134C81D96C55375.title: "&5Observador de Trem"
	quest.514A8996A1C18BAF.quest_desc: [
		"Aumento de nível para 29."
		""
		"Pode ser encontrado aleatoriamente em &9Ginásios&r que geram em &a#minecraft:village&r"
	]
	quest.514A8996A1C18BAF.title: "&aLíder Misty"
	quest.5151CDD8FCDE7A07.quest_desc: ["Bem-vindo às Ferramentas Básicas!\\n\\nJá pegou uma ferramenta que nunca viu ou ouviu falar e quis saber onde ela se encaixa entre outras ferramentas? Então essas missões são perfeitas para você!\\n\\n(As espadas são classificadas por dano base, espadas que podem ser melhoradas ou usadas para obter mais dano não estão incluídas).\\n\\nA missão para todas as picaretas e espadas é OPCIONAL!"]
	quest.5151CDD8FCDE7A07.quest_subtitle: "Todas as Ferramentas"
	quest.5151CDD8FCDE7A07.title: "Ferramentas Básicas!"
	quest.51592B271E56C6B2.quest_subtitle: "Nível: &a2"
	quest.515A60B89ED5440D.quest_desc: ["O &7Gerador de Pedra&r é apenas para o &7&lMinerador Digital&r. \\n\\nQuando usado nele, eles criarão &7Pedra&r automaticamente, em vez de precisarem de esmolas. \\n\\nEle usará essas &7Pedras&r para substituir os Minérios que coleta!"]
	quest.515A60B89ED5440D.title: "Melhoria do &7Gerador de Pedra &8"
	quest.515C0527226BA50C.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Concede ao jogador voo criativo."
	]
	quest.5160D62F07A642A7.quest_subtitle: "Rowan + Beech"
	quest.516289A040EE9FDC.quest_subtitle: "Cristalino + Neon Cuckoo"
	quest.516289A040EE9FDC.title: "&fAbelha de Menril"
	quest.5169625567DC3B75.quest_desc: ["Ele aumentará seu Limite de Nível para 30. \\n\\nSeu Item de Assinatura é a &bPedra da Eternidade&r."]
	quest.5169625567DC3B75.title: "&6Treinador Pokemon Cedric"
	quest.516AC1F0E0BCAE55.quest_desc: ["Tubos Congelados são dropados por Freezes na Forja de Golem. \\n\\nEles podem ser arremessados como Poções para ferir quem for atingido."]
	quest.516E66BE01EE5B31.quest_desc: ["&8Tomos de Armamento&r darão &5Encantamentos&r para Espadas e Machados. \\n\\nPrincipalmente aqueles que ajudam a Matar coisas! Como &5Afiação &fe &5Aspecto Flamejante&r. \\n&8Tomos de Arquearia&r darão &5Encantamentos&r para Armas de longo alcance, o Arco e a Besta. \\n\\n&5Perfuração&f, &5Força&f, e &5Repulsão&r!"]
	quest.516E66BE01EE5B31.title: "&8Tomos de Armas"
	quest.516ECA0396621C32.quest_desc: [
		"Como sabemos que é o &aVerde&r? A Grama é &aVerde&r, mas também está em todos os outros Santuários. Os &aArbustos de Azaleia&r e a &aCera Ancestral Luminescente Verde&r mostram que este é o &aVerde&r. \\n\\nSiga o Ar Ventoso e os esgotos úmidos até a sala principal para encontrar a &aEssência Verde&r. \\n\\nEntre nela e uma luta contra um Chefe chamado Rootmin começará. Vá para a outra plataforma e rebata as Pelotas de Terra de volta nele para reduzir a Barra do Chefe no topo."
		"{image:atm:textures/questpics/bumblezone/bumble_green1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_green2.png width:200 height:100 align:center}"
	]
	quest.516ECA0396621C32.title: "&aSantuário Sempiterno Verde"
	quest.517F0135926B15EE.quest_desc: ["Todas as máquinas simples vêm com controle de redstone, e algumas vêm com filtragem."]
	quest.5180CDD196518F64.quest_desc: [
		"Os &6Trilhos de Ferro em Tira&r, como os &6Trilhos Abandonados&r, são perfeitos para os pão-duros. Eles são muito mais lentos que os outros &6trilhos&r, mas sem risco de descarrilamento!"
		"{image:atm:textures/questpics/railcraft/rail_strap.png width:150 height:100 align:center}"
	]
	quest.5180CDD196518F64.title: "&6Trilhos de Ferro em Tira"
	quest.5184669F1F038E9A.quest_desc: [
		"Aumento de nível para 27."
		""
		"Item de Assinatura é &ePepita de Ouro&r."
	]
	quest.5184669F1F038E9A.title: "&6Rival Terry"
	quest.5189D72ED3808DC6.quest_desc: [
		"&aShift + botão direito&r com seu designador de alvo no agregado de ametista e então &aShift + botão direito&r no laser para definir o alvo."
		""
		"Esses pequenos cristais fazem mais do que apenas parecer bonitos. Eles podem armazenar energia e são usados para fazer máquinas mais complexas."
	]
	quest.5189D72ED3808DC6.quest_subtitle: "Carregue a ametista com o laser"
	quest.5194A067BEA98E79.quest_desc: ["Ei, eu me lembro de você! \\n\\nAcontece que a &5&lCentrífuga Isotópica&r é usada para 2 Receitas. &2Combustível Fóssil&r e &3Plutônio&r! \\n\\nPara cada 5mB de &8Rejeito Nuclear&r, podemos criar 1mB de &3Plutônio&r. \\n\\nSe cada &3Pastilha de Plutônio&r equivale a 1.000mB de &3Plutônio&r, então precisaremos de 5.000mB de &8Rejeito Nuclear&r e o mesmo para o &2Combustível Fóssil&r."]
	quest.5194A067BEA98E79.title: "Girando por &3Plutônio"
	quest.51A57E142C686C8F.quest_desc: ["O quinto e último Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e268435456&f (262144k) bytes de armazenamento."]
	quest.51A57E142C686C8F.quest_subtitle: "x4^4"
	quest.51A57E142C686C8F.title: "&5Componente de Armazenamento de 256M"
	quest.51C59FDF0BD11FDF.quest_desc: ["Tenho quase certeza de que a única definição do que é uma Árvore de Wigglewood é que ela tem Troncos e Folhas de Wigglewood. Elas parecem crescer em qualquer direção, tamanho e forma. \\n\\nVocê pode encontrá-las em Florestas de Wigglewood e Florestas Densas. \\n\\nElas têm folhas rosa bonitas e troncos marrons semelhantes ao Abeto!"]
	quest.51C8B7AAA05EA266.quest_desc: [
		"Alguns &alíderes &r&lAPENAS&r geram nos &9Ginásios&r que geram em vilas, então anote quais &aLíderes de Ginásio&r você encontrou!"
		"&6Você precisará deles mais tarde!!!&r"
	]
	quest.51C8B7AAA05EA266.quest_subtitle: "&e&lAVISO&r"
	quest.51C8B7AAA05EA266.title: "&9Ginásios&r de Kanto"
	quest.51CE19706BB6B2A1.quest_desc: ["&bDiamantes&r, o coração e a alma do &2&lMinecraft&r. \\n\\nEncontrados abaixo do Nível Y 16, mais comuns logo acima da Rocha Matriz! \\n\\nVocê precisará de uma Picareta de Ferro (preferencialmente com Fortuna) para minerá-los. Então, você poderá fazer Ferramentas e Armaduras ainda melhores! \\n\\nEstes costumavam ser os melhores no &2&lVanilla&r, agora é a &cNetherita&r. E agora que existem Mods, há coisas ainda melhores que &cNetherita&r."]
	quest.51CE19706BB6B2A1.title: "A melhor amiga de um jogador"
	quest.51CF09EC333DB1A3.quest_desc: ["Para subir de Nível na Criação por Fusão do Draconic Evolution, os Injetores necessários para uma receita devem ser pelo menos do Nível ou superior. Por exemplo, se você quiser fazer o Machado Wyvern, você precisa de pelo menos 6 Injetores Wyvern, com 3 de cada lado. Não se preocupe, o Núcleo de Criação permanece o mesmo!"]
	quest.51CF09EC333DB1A3.title: "Nível Wyvern"
	quest.51DBE688ED630DB1.quest_subtitle: "Nível: &54"
	quest.51DE3157DE3E57B8.quest_desc: [
		"Armazenamento é bom e tudo mais, mas de que adianta um sistema de armazenamento se ele está entupido de matérias-primas que precisam ser fabricadas e processadas em algo e você ainda está preso tendo que fazer isso manualmente?"
		""
		"O sistema de &efabricação automática&f do AE2 começa com o &bProvedor de Padrões ME&f. O Provedor de Padrões contém certos itens chamados &bPadrões&f (abordados na próxima missão) que são programados para conter alguma receita que transforma itens de entrada em uma certa saída. Até 9 padrões podem caber em um fornecedor."
		""
		"Você frequentemente usará múltiplos fornecedores de padrões espalhados por toda a sua base, e é por isso que é útil ter um &bTerminal de Acesso a Padrões&f para acessar remotamente o conteúdo de qualquer e todos os fornecedores em sua Rede ME mais ampla."
	]
	quest.51DE3157DE3E57B8.quest_subtitle: "Pedido feito"
	quest.51DE3157DE3E57B8.title: "&5Fabricação Automática"
	quest.51E2728C5E35A152.quest_desc: ["Aço Gelado aparece nos Biomas Congelados: Campos de Gelo, Florestas de Smogstem Geladas e provavelmente Mares Gelados. \\n\\nEle aparece em Shiverstone, que substitui a Depthrock nesses Biomas. A Shiverstone agirá de forma semelhante ao Gelo, sendo escorregadia e te desacelerando um pouco. \\n\\nVocê também pode encontrar algumas Pepitas nas barrigas dos Munchers!"]
	quest.51E2728C5E35A152.title: "&bAço Gelado&r"
	quest.51E554305FFEBA1D.quest_desc: ["&4Estantes Infernais Flamejantes&r dão um pouco de &cQuanta&r e &aEterna&r, mas não são a opção barata que estamos procurando para nossas &d&lInfusões&r!"]
	quest.51E554305FFEBA1D.title: "&4Estante Infernal Flamejante"
	quest.51E77B9CD3FB6DEA.quest_desc: ["Isso não é necessário, mas eu acho muito útil. \\n\\nAs Garras de Escavação aumentam o Nível da sua Picareta, para suas Mãos. Assim, você pode Minerar até Minério de Ferro apenas com seus Punhos! \\n\\nIsso também inclui minerar coisas como Pedra, Terracota e Concreto. E você pode até minerar isso com os Blocos em suas Mãos. \\n\\nHonestamente, é basicamente necessário."]
	quest.51EA6B1452883AB2.quest_desc: ["Chassis Lineares funcionam como massa de modelar na vida real, conectando-se apenas uns aos outros. \\n\\nChassis Lineares, que estão virados para a mesma direção, se conectarão automaticamente como se estivessem Colados. Outros Chassis Lineares ou aqueles virados para direções diferentes, não ficarão juntos. \\n\\nVocê pode então usar Cola no Topo e na Base do Chassi Linear para conectar uma linha de Blocos a partir dele. Assim, todos os Blocos em cima deles serão Colados ao Chassi Linear. Muito útil para economizar Cola! \\n\\nCom a Chave Inglesa, você pode definir quantos Blocos são Colados no Topo ou na Base do Chassi Linear."]
	quest.51EA6B1452883AB2.title: "&aChassi Linear"
	quest.520904C106D7D93D.quest_desc: ["Isso faz o &6&lGancho Aéreo&r agir de forma semelhante a uma Maça, você causará Dano extra ferindo Mobs se estiver caindo enquanto os atinge. \\n\\nEm Bioshock Infinite, isso é chamado de Skystrike!"]
	quest.520904C106D7D93D.quest_subtitle: "Pressione LMB para Skystrike"
	quest.520EFA7F446AFBF2.quest_desc: ["O &3Lubrificante&r pode ser usado para fazer Brocas."]
	quest.520EFA7F446AFBF2.quest_subtitle: "Produzindo Lubrificante!"
	quest.520EFA7F446AFBF2.title: "Lubrificante"
	quest.5210DC0095996B62.quest_subtitle: "Nível: &b4"
	quest.521656D425E2FDBA.quest_desc: ["Vai ainda mais rápido que o Nível II."]
	quest.521656D425E2FDBA.quest_subtitle: "Máx: 1"
	quest.5218DAE147AC9F44.quest_desc: ["A Aljava de Lâminas permite que você segure mais &8Lâminas&r ou &8Itens semelhantes a Lâminas&r na &2&lSerra Circular&r. \\n\\nPara alternar entre as &8Lâminas&r (ou &8Itens semelhantes a Lâminas&r), segure Shift e Role o mouse. \\n\\nIsso é útil para substituir &8Lâminas&r quebradas ou até mesmo para trocar por &8Discos de Moagem&r!"]
	quest.5219D2F2B13F57F3.quest_desc: [
		"Um dos, se não o, item mais importante em &6&lBumblezone&r! A Maleta Zumbidora é o item perfeito para o cuidado de &6A&8b&6e&rlhas. \\n\\nVocê pode clicar com o botão direito em uma &6A&8b&6e&rlha com a Maleta para capturá-la. Então, você pode clicar com Shift e o botão direito com a Maleta para ver as &6A&8b&6e&rl&8has&r dentro. \\n\\nEla pode conter 14 &6A&8b&6e&rl&8has&r, e qualquer &6A&8b&6e&rl&8ha&r, incluindo as &lProductive Bees&r. \\n\\nAqui você pode ver a Vida delas, Nome, tipo de &6A&8b&6e&rlha, se tem um Ferrão, se tem &ePólen&r, e mais! \\n\\nVocê também pode usá-la para soltar as &6A&8b&6e&rl&8has&r dela."
		"{image:atm:textures/questpics/bumblezone/bumble_briefcase.png width:200 height:150 align:center}"
	]
	quest.521C9B00B1D87DEB.quest_subtitle: "Nível: &b4"
	quest.5233A447BAA4593C.quest_desc: ["O &bCabo ME Inteligente&f e o &bCabo ME Denso Inteligente&f funcionam de forma idêntica aos cabos cobertos em termos de distribuição de canais, mas também exibirão visivelmente a quantidade de canais que estão usando como linhas coloridas ao longo deles."]
	quest.5233A447BAA4593C.quest_subtitle: "Mais canais que TV a cabo!"
	quest.5233A447BAA4593C.title: "Cabeamento Avançado"
	quest.523853C1C4E688BA.quest_desc: ["O quarto nível do Componente de Armazenamento, fornecendo &e65536&f bytes de armazenamento."]
	quest.523853C1C4E688BA.quest_subtitle: "x4^3"
	quest.523853C1C4E688BA.title: "&eComponente de Armazenamento de 64k"
	quest.523DC411241B470A.quest_desc: [
		"Todos os &5Encantamentos&r da &5Mesa de Encantamentos&r são determinados pelos Níveis de &aEterna&r, &cQuanta&r e &5Arcana&r. \n\nPodemos ver o conjunto de &5Encantamentos&r disponíveis clicando no ? no Canto Superior Direito da GUI da &5Mesa de Encantamentos&r quando um Item está sendo &5Encantado&r. \n\nQuanto maior o &cQuanta&r, maior a chance de aparecer um &5Encantamento&r mais fraco. \n\nCom a &6Estante de Livros Envolta em Geodo de Estabilidade&r, as chances aumentadas de Encantamentos piores serão eliminadas."
		"{@pagebreak}"
		"Para criá-lo, precisaremos de um &7Estante de Livros&r, 7 Calcite e 1 &5Drusa de Ametista Brotante&r. \\n\\nA &5Drusa de Ametista Brotante&r não pode ser coletado pela Mineração, mesmo com &5Silk Touch&r. Você precisará de um Ritual ou de uma Infusão para obter um, então!"
	]
	quest.523DC411241B470A.title: "Remoção de &6Encantamentos Negativos"
	quest.5244B2D6B5FA0487.quest_desc: [
		"O Deserto Cristalizado parece um Deserto normal, mas com tons de Roxo. \\n\\nTambém com cristais gigantes adicionados, eu não acho que Desertos normais tenham isso..."
		"{image:atm:textures/questpics/eternal/starlight_desert.png width:200 height:100 align:center}"
	]
	quest.5244B2D6B5FA0487.title: "Deserto Cristalizado"
	quest.524606135B91B536.quest_desc: [
		"Aumento de Nível para 76."
		""
		"O Item de Assinatura é Gema de Inseto."
	]
	quest.524606135B91B536.title: "&aLíder Benjamin"
	quest.52472667678E10D1.quest_desc: ["&2Stellarite&r aparece entre os níveis Y 42 e -44. \\n\\nVocê pensaria que, com um raio tão grande, seria fácil de encontrar! Não é, é muito raro! \\n\\nTenha cuidado ao minerá-la, pois quando quebrada, ela EXPLODIRÁ!"]
	quest.52472667678E10D1.title: "&2Pedaços de Stellarite"
	quest.525F25F4ADE45B50.quest_desc: [
		"O &bPlano de Formação ME&f age de forma semelhante ao Ponto de Armazenamento, mas trata o próprio mundo como seu meio de armazenamento. Em outras palavras, ele colocará qualquer bloco em seu filtro diretamente à sua frente."
		""
		"Isso pode ser útil para situações em que um bloco pode ser processado simplesmente colocando-o e quebrando-o com uma determinada ferramenta."
	]
	quest.525F25F4ADE45B50.quest_subtitle: "SAIA"
	quest.52672B7FFFD51D16.quest_desc: ["Adiciona uma INTERFACE de Cortador de Pedra à Mochila."]
	quest.526A9655A62C93F4.quest_subtitle: "Lariço Europeu + Pinheiro Ponderosa"
	quest.526CED9509FAA79B.quest_subtitle: "Blue Yonder + Firecracker"
	quest.529123A789D790E3.title: "Módulo de Salto Wyvern"
	quest.52ACADDFCB0E22AB.title: "&aParte de Armazenamento de 4096k"
	quest.52AFABA08674B6A8.quest_desc: ["&3Armadura de Vibranium&r mas com bônus para os Feitiços de &d&lArs Nouveau&r!"]
	quest.52AFABA08674B6A8.quest_subtitle: "32"
	quest.52AFABA08674B6A8.title: "Equipamento Arcanista de &3Vibranium"
	quest.52B1A935EBCFA6D0.quest_desc: ["Para fazer nossa &bGrande Bola de Fogo&r, podemos usar nossa &7Câmara de Pressão&r de antes, &6Implantadores&r ou um &cMontador&r. \\n\\nVocê já conhece a &7Câmara de Pressão&r e os &6Implantadores&r. \\n\\nO &cMontador&r precisará de 3 Estruturas de Máquina com ele em um formato 1x2x2 para ligá-lo. Apenas ligue-o e jogue os itens."]
	quest.52B1A935EBCFA6D0.title: "Fabricando nossa &cBola Fogo"
	quest.52B22C07818981D0.quest_subtitle: "Despeje Constantan Derretido sobre um Ovo de Gerador de Abelha de Cobre/Níquel"
	quest.52B22C07818981D0.title: "&fAbelha de Constantan"
	quest.52B2ADE472707372.quest_subtitle: "Golden Declious Apple + Granny Smith Apple"
	quest.52B3955A80DB0B4A.quest_desc: ["A &6Detonação&r não se parece com os Encantamentos &2&lVanilla&r, mas sim com os de Modpacks! \\n\\nUma vez Instalada, podemos mexer em suas Configurações para mudar o quão grande é o quadrado de Blocos que podemos Minerar. \\n\\nO Padrão é 1x1, ou seja, 1 Bloco. Podemos mudar para 3x3, 5x5, 7x7 e 9x9. \\n\\nSim, Minerar um quadrado de 9x9 consumirá mais &aEnergia&r do que Minerar um único Bloco."]
	quest.52B3955A80DB0B4A.quest_subtitle: "K-BOM!"
	quest.52B3955A80DB0B4A.title: "&6Unidade de Explosão"
	quest.52B61FB01D7C12A4.quest_desc: ["Versão melhorada do &aInferium&r."]
	quest.52B61FB01D7C12A4.quest_subtitle: "23"
	quest.52B61FB01D7C12A4.title: "Armadura de &2Prudentium"
	quest.52BB58D470560219.quest_subtitle: "Alcance: &c54&r Blocos"
	quest.52BB58D470560219.title: "Growth Accelerators de Supremium Despertado"
	quest.52C301DF1776E0D8.title: "Módulo de Dano de Projétil Caótico"
	quest.52C3F61D678B00F5.quest_desc: ["Uma Enxada Caótica, eu namorei uma dessas há um tempo."]
	quest.52C3F61D678B00F5.title: "Enxada Caótica"
	quest.52C7FAA044E07628.quest_desc: ["Pense no Totem da Imortalidade, agora pense em como ele pode ser super poderoso. Essa é a &fEssência da Continuidade&r. \\n\\nQuando você está prestes a receber um golpe fatal, você será teletransportado para o seu Ponto de Renascimento com Vida e Fome cheias, e os efeitos ruins removidos. Salvando sua vida, obviamente. \\n\\nEle também lhe dará um diário descrevendo como e onde você teria morrido. \\n\\nDepois de salvar sua vida, ele terá um tempo de recarga de 40 minutos e dará tempos de recarga a todas as outras Essências que você possa ter."]
	quest.52C7FAA044E07628.title: "&fEssência da Continuidade"
	quest.52CD31F48715B17C.quest_desc: [
		"O Conector Sem Fio ME pode ser usado para conectar dois pontos de uma Rede ME sem fio, similarmente à Ponte Quântica. Diferente da Ponte Quântica, ele só pode se conectar a Conectores Sem Fio a até cerca de 1000 blocos de distância, e não pode se conectar entre dimensões."
		""
		"&lPara configurar uma conexão, use um Kit de Configuração Sem Fio nos dois Conectores Sem Fio que você deseja vincular.&r"
		""
		"Você também pode mudar a cor de um Conector Sem Fio com o Aplicador de Cor. Isso fará com que ele não se conecte a cabos ou Conectores Sem Fio de uma cor diferente."
	]
	quest.52CD31F48715B17C.title: "Conexões a longas distâncias: O Conector Sem Fio"
	quest.52CDB46F6CBF007B.quest_subtitle: "Você está cavando isso?"
	quest.52D3697F1F5625C7.quest_desc: ["O &3Ácido de Corrosão&r é feito na Pressure Chamber com Plástico Derretido... e algumas outras coisas. Usado no Tanque de Corrosão."]
	quest.52D3697F1F5625C7.quest_subtitle: "Não Pergunte..."
	quest.52D4FCE72B15BC46.quest_desc: ["Sempre quis um \"Balde melhor\"? Bem, você pode com o Balde de Edelwood! \\n\\nPor apenas algumas Tábuas de Edelwood, você pode obter um Balde melhor, que pode conter 4 Baldes de Água ou Leite. \\n\\nVocê também pode segurar 3 Baldes de Lava! Pesa mais, então você só pode segurar 3 em vez de 4."]
	quest.52E59FCB39D66BCF.quest_desc: ["Uma das melhores opções para \"Energia Passiva\", o &9Gerador Térmico&r produzirá FE quando colocado sobre uma &cFonte de Calor&r e receber um suprimento constante de água.\\n\\nAtualmente, existem 3 blocos sobre os quais você pode colocar isso: um bloco de Magma que produz o mínimo, um bloco de fonte de lava que é um pouco melhor, ou um &cBloco de Cristal Ardente&r, que fornece o maior calor."]
	quest.52EA9793A7100E75.title: "Módulo Imortal Caótico"
	quest.52EC86E03EB50525.quest_desc: [
		"Habilidade Intrínseca:"
		"- Reparo por Lava"
		"- Sem Pisotear"
		"- Colheita Automática"
		"- Crescimento Acelerado de Culturas II"
	]
	quest.52F85CED20C8B1E9.quest_desc: ["A &eEnergia&r tem que circular de alguma forma, de preferência para onde queremos que ela vá. Mova-a da mesma forma que com &2Itens&r, &9Fluidos&r e &5Químicos&r!"]
	quest.52F85CED20C8B1E9.title: "Cartão de &eEnergia"
	quest.52FAF122466FDDC9.quest_desc: ["Gerador Estabilizado é a versão do Gerador do Draconic Evolution. Quando você usa um dos Núcleos em um Gerador, ele se tornará um Gerador Estabilizado. Você pode trocar os Núcleos, mas não poderá alterar as estatísticas, pois agora elas são definidas pelos Núcleos. Quanto melhor o Núcleo, mais criaturas surgem e em um ritmo mais rápido."]
	quest.52FAF122466FDDC9.quest_subtitle: "Gerador do Draconic Evolution"
	quest.5303509A1C2B1CCD.quest_desc: ["A &3Marreta Pneumática&r usa pressão para minerar, pode ser aprimorada para ser incrível!"]
	quest.5303509A1C2B1CCD.quest_subtitle: "Desculpe, Jack!"
	quest.5311404799117060.quest_subtitle: "Nível: &b4"
	quest.53154550397E9704.quest_desc: [
		"A &c&lMonstruosidade de Netherite&r faz jus ao seu nome, é uma fera de &cNetherite &fe &cLava&r. \\n\\nEle pode ter até 9.600 &4Corações&r, mas quando o encontrei pela primeira vez, ele estava com apenas cerca de 1.100 &4Corações&r. Ele regenerará &4Corações&r quando nenhum Jogador estiver por perto.\\n\\nEle tem alguns ataques corpo a corpo, como bater em você com seus braços enormes e pisotear você. Ele também pode jogar blocos no Ar, causando uma Onda de Choque. \\n\\nSe você se afastar dele, ele pode avançar em você ou pular em você. Honestamente, ele parece pesar 100 Toneladas, eu não gostaria que ele fizesse nenhuma das duas coisas comigo! \\n\\nO pior de seus ataques são definitivamente os de Longo Alcance... ele pode atirar &cBolas de Magma&r em você e, onde elas caem, &cLava&r aparecerá. Ele também pode atirar &cBolas de Fogo&r de suas mãos, estas causarão &bJatos de Fogo&r saindo do chão."
		"{image:atm:textures/questpics/cataclysm/cataclysm_monstrosity.png width:100 height:100 align:center}"
	]
	quest.53154550397E9704.title: "&c&lMonstruosidade de Netherite&r"
	quest.5316DF321B45D2CA.quest_desc: ["Bem-vindo ao &dOccultism&r!\\n\\nEste mod visa ajudar o jogador de várias maneiras, recrutando a ajuda de &c&mDemônios&r &bEspíritos&r! Não se preocupe, a maioria deles é amigável. &oA maioria&r.\\n\\nPara começar, você precisará obter algumas &aSementes de Fruta do Demônio&r."]
	quest.5316DF321B45D2CA.title: "Sonhando com &cDemônios"
	quest.532229D285CA4858.quest_desc: ["O &9Importador&r é uma interface que pode ser usada para puxar itens de um bloco conectado.\\n\\nPor exemplo, você pode usá-los em Fornalhas para puxar o produto final para o seu sistema.\\n\\nVocê também pode filtrar quais itens são puxados."]
	quest.532229D285CA4858.quest_subtitle: "Importando Itens!"
	quest.53292D808E8F5218.quest_subtitle: "Pilriteiro + Sorte"
	quest.532BCAB3FBF91B1D.quest_desc: [
		"&#44DB9CAs Melhorias&r adicionam a capacidade das máquinas entrarem no estado &#4467DBoverclocked&r, aumentando ainda mais a velocidade máxima da máquina."
		""
		"Uma máquina pode suportar até uma pilha de qualquer nível de atualização. A &#CEDB44Melhoria Básica&r adiciona &#F7F448+2 EU/t&r à capacidade por melhoria."
	]
	quest.532BCAB3FBF91B1D.title: "&5Melhoria Básica"
	quest.532F3E6868A29037.quest_desc: ["Pense na Melhoria anterior: Velocidade, agora pense nela tornando as coisas ainda mais rápidas! \\n\\nEstas Melhorias podem ser usadas nas Máquinas para fazê-las funcionar 40% mais rápido! \\nSim, seus efeitos se acumulam. \\n\\nNão, elas não podem ser usadas em Colmeias, para isso serve a Produtividade!"]
	quest.532F3E6868A29037.quest_subtitle: "Sônico em tudo, menos nas Abelhas"
	quest.532F3E6868A29037.title: "&fMelhoria de &6Aceleração"
	quest.534D827A628907F4.quest_desc: [
		"O Terminal de Acesso a Padrões Estendido funciona da mesma forma que o Terminal de Acesso a Padrões normal, mas com 3 recursos adicionais."
		""
		"&l&nPesquisa de Padrão Aprimorada&r"
		""
		"Você pode procurar por um padrão pelo nome dos ingredientes de entrada/saída."
		""
		"&l&nDestaque de Padrão&r"
		""
		"Às vezes, devido à forma como os padrões são exibidos em um grupo, ainda é difícil encontrar o padrão que você está procurando. Com este terminal, o padrão que você está procurando será destacado na GUI."
		""
		"&l&nDestaque no Mundo do Provedor de Padrão&r"
		""
		"Pode ser irritante descobrir qual dos seus Provedores de Padrão está travado ao fazer grandes trabalhos de crafting. O Terminal de Acesso a Padrões Estendido pode destacar os Provedores de Padrão no mundo, facilitando sua localização."
	]
	quest.534D827A628907F4.title: "Melhor Acesso a Padrões: O Terminal de Acesso a Padrões Estendido"
	quest.53518D4ED99A242F.quest_desc: ["O &3Aplicador de Camuflagem&r pode ser usado para esconder maquinário do PneumaticCraft dentro de outros blocos."]
	quest.53518D4ED99A242F.quest_subtitle: "Quer deixar sua montagem legal?"
	quest.535525EA4DF4AB59.quest_desc: ["O &cTransmissor de Jogador&r fornecerá energia a qualquer pessoa com o Cartão Vinculado. Isso inclui energia para todas as armaduras, ferramentas e itens em seu inventário. \\n\\nO &cNível Nitro&r é necessário para a &6&lEstrela&r, que é, claro, o último e mais difícil de obter."]
	quest.535525EA4DF4AB59.title: "&cTransmissor de Jogador Nitro"
	quest.53594EBA9F7BA840.quest_desc: ["O Descarregador de Itens Avançado é igual à parte normal, mas pode ser usado de qualquer direção. Nada de diferente além da direção."]
	quest.53594EBA9F7BA840.title: "Descarregador de Itens Avançado"
	quest.5372264ED2D55143.quest_subtitle: "Esprema industrialmente alguns Ovos de Geração de Abelha de Carvão"
	quest.5372264ED2D55143.title: "&fAbelha de Grafite HOP"
	quest.538186D01429F05F.quest_desc: [
		"Nesta missão, focaremos em usar o AE2 para automatizar o &cDestilador de Poções&r. Primeiro, construa uma configuração como esta:"
		"{image:atm:textures/questpics/industrialforegoing/potionbrewerdemonstration.png width:175 height:200 align:center}"
		"(A Célula de Energia Criativa serve como um substituto para sua rede principal)"
		"{@pagebreak}"
		"Precisaremos de um &9Ponto de Exportação&r ou uma &9Interface&r para encher o &cDestilador de Poções&r com &1Água&r e &6Pó de Blaze&r. O &6Pó de Blaze&r será usado como combustível. Não forneça garrafas ainda, pois elas encherão sua rede com Garrafas de Água."
		"{@pagebreak}"
		"O próximo passo será obter um"
		"&5Provedor de Padrão Avançado&r. Verifique o capítulo Extended \\& Advanced AE para saber mais sobre como usá-lo. A seguir, precisaremos codificar um padrão. Um exemplo será destilar uma &4Poção de Cura&r, focada em Guloseimas Reais para Abelhas Modulares. Codifique o padrão assim: 3 Garrafas de Vidro, 1 Fungo do Nether, 1 Fatia de Melancia Reluzente, para produzir 3 &4Poções de Cura&r. Usaremos ambas as habilidades especiais do &5Provedor Avançado&r aqui. A primeira é sua habilidade de enviar itens para um lado específico. Usaremos isso para enviar Garrafas de Vidro para o lado SUPERIOR da máquina. Use o &5Codificador de Padrão Avançado&r para codificar o padrão, assim:"
		"{image:atm:textures/questpics/industrialforegoing/advanced_pattern.png width:200 height:100 align:center}"
		"{@pagebreak}"
		"A seguir, precisamos habilitar a Importação Filtrada no &5Provedor Avançado&r. Isso fará com que o &5Provedor Avançado&r aceite apenas itens que correspondam aos trabalhos de criação ativos no momento. Isso significa que ele não aceitará poções prematuramente. Você também pode adicionar Adicionais de Processamento para ajudar com isso, especialmente com trabalhos de criação grandes o suficiente que podem usar esse mesmo provedor.\\n\\nPor último, você terá que configurar os lados do Destilador de Poções assim:"
		"{image:atm:textures/questpics/industrialforegoing/blaze_input.png width:125 height:100 align:center}"
		"{image:atm:textures/questpics/industrialforegoing/bottle_input.png width:125 height:100 align:center}"
		"{image:atm:textures/questpics/industrialforegoing/brewing_input.png width:125 height:100 align:center}"
		"{image:atm:textures/questpics/industrialforegoing/output.png width:125 height:100 align:center}"
		"Se você estiver usando o método da &9Interface&r, configure os lados assim:"
		"{image:atm:textures/questpics/industrialforegoing/blaze_input_for_interface.png width:125 height:100 align:center}"
		"{image:atm:textures/questpics/industrialforegoing/water_for_interface.png width:125 height:100 align:center}"
		"{@pagebreak}"
		"Opcionalmente, você pode colocar um Rótulo de Transferência entre o &5Provedor Avançado&r e o &cDestilador&r.\\n\\nSe você ainda está confuso com esta configuração, ou prefere assistir a um vídeo, confira o vídeo que linkei aqui, do ChosenArchitect:"
		"{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://youtu.be/DOW4xkxqp6g?si=paZ2xFKyycPumqaS&t=427\"},\"color\":\"blue\",\"text\":\"LINK DO VÍDEO AQUI\",\"underlined\":true} "
	]
	quest.538186D01429F05F.quest_subtitle: "Usando AE2"
	quest.538186D01429F05F.title: "Automatizando o Destilador de Poções"
	quest.5387480428BC6E0A.quest_desc: ["A &9Pedra da Água&r irá &bEvoluir&r &9Poliwhirl&r para &9Poli&4wrath&r, &9Shellder&r para &9Cloy&bster&r, &9Staryu&r para &9Star&dmie&r, &9Lom&2bre&r para &9Ludi&2colo&r, e finalmente Eevee para &9Vaporeon&r!"]
	quest.5387480428BC6E0A.title: "&9Pedra da Água"
	quest.53880926982968FD.quest_subtitle: "Diga meu nome"
	quest.538821E23E39BE97.quest_desc: ["&2Aumento&r: Eficiência de Combustível é para todos vocês, Amantes da Terra, Abraçadores de Árvores, Adeptos do Capitão Planeta, Hippies. A Fornalha consome metade da quantidade de Combustível ao custo de metade do tempo. O Carvão não Fundirá 8 itens, mas sim 16!"]
	quest.538821E23E39BE97.title: "&2Aumento&r: Eficiência de Combustível"
	quest.539266A1C03C2EBA.quest_desc: [
		"Almas é o 2º Slot necessário para a &6&lForja&r, também o menor: precisando de apenas 10 para preenchê-lo! \\n\\nCada Alma e Alma Corrompida contará como 1 Alma. Enquanto Almas Encantadas contam como 10 inteiras!"
		"{image:atm:textures/questpics/forbidden/forbidden_souls.png width:135 height:100 align:center}"
	]
	quest.539266A1C03C2EBA.title: "Almas"
	quest.53A556F14187F399.quest_desc: ["O Movimento Z em Branco! \\n\\nSim, ele está em branco! \\n\\nSe quisermos fazer um &eMovimento Z&r específico, precisaremos de Fabrique com alguns itens para criar esse &eMovimento Z&r."]
	quest.53A5F5E49EA8D5AF.quest_desc: [
		"Aqui está um bom exemplo de uso de Roteadores Modulares para criar uma Fazenda de Mobs super fácil e organizada. (Não inclui a maneira de matar os mobs). \\n\\nPara isso, usarei uma Fazenda de Esqueletos Wither como exemplo. \\n\\nPrimeiro, você quer colocar os Itens no Buffer com um Módulo de Vácuo. Em seguida, livre-se das Espadas de Pedra com um Módulo de Anulação. Para garantir que ele não apague tudo, use um Filtro de Lista Branca com a Espada de Pedra nele e sem corresponder ao Dano. Depois disso, você precisará de um lugar para colocar o Loot, eu recomendo um Sistema de Gavetas. Então, use um Módulo Emissor para enviar o Loot para o Sistema de Armazenamento. \\n\\nÉ tudo que você precisa!"
		"{image:atm:textures/questpics/router/router_mob.png width:200 height:65 align:center}"
	]
	quest.53A5F5E49EA8D5AF.title: "Roteadores para Fazendas de Mobs"
	quest.53B00024E5493C96.quest_desc: ["Assim que tivermos o &3Lingote&r e o &3Molde&r, use uma &8Bancada de Metalurgia&r para combinar o &cLingote &fe o &cMolde&r com uma peça de Equipamento de &bDiamante&r para aprimorá-la para &cNetherita&r. \\n\\n&cNetherita&r tem o maior Dano, Durabilidade e Proteção de todos os equipamentos do &2&lMinecraft&r! Também é inteiramente &cà prova de fogo&r (não o tornará resistente ao fogo, apenas os Itens não queimarão na &cLava&r). \\n\\nPrecisaremos da força que a &cNetherita&r oferece para ter uma chance no..."]
	quest.53B00024E5493C96.title: "Ferramentas e Equipamentos de &cNetherita&r"
	quest.53B3B9A401360586.quest_desc: ["A &aPedra do Trovão&r irá &bEvoluir&r &ePikachu&r para &eRaichu&r e Eevee para &eJolteon&r."]
	quest.53B3B9A401360586.title: "&aPedra do Trovão"
	quest.53B58FC3958750E7.quest_desc: ["Você brincou demais com o Colocador e precisa Quebrar esses Blocos? \\n\\nSeu Nível e Encantamentos são determinados pela Picareta com a qual é Fabricado. \\n\\nAgora defina a área e, com sorte, coloque um Filtro e deixe-o funcionar! \\n\\nPode ser usado com um Colocador para fazer coisas como transformar Minérios em Itens."]
	quest.53BA0C64804ADD24.quest_subtitle: "Pomelo + Cereja Silvestre"
	quest.53BDD0459F7B1D60.quest_subtitle: "Coffea + Teca"
	quest.53C0C8BCCB804368.quest_desc: ["Agora temos nossos diferentes &eMovimentos Z&r. \\n\\nAlguns apenas tornarão um movimento ainda mais forte, esses geralmente são nomeados de acordo com os tipos, como Normalium Z. \\n\\nAlguns mudarão o movimento de um &cPokémon&r para um diferente, como o &ePikanium Z&r. \\n\\nE alguns são apenas estranhos, como o &6Ultranecrozium Z&r."]
	quest.53C0C8BCCB804368.title: "&eMovimentos Z"
	quest.53C167AF34694F8F.quest_desc: ["Misturar &#40B36AYtrium&r, &#DBA146Cobre Recosido&r, &#33CC3ANeodímio&r e Pó de &#D6D290Irídio&r produzirá &#5EDEE0Pó de Supercondutor&r. Isso pode ser cozido em um &#E3CE54EBF de Kanthal&r para ser resfriado no &#4CBBD9Freezer a Vácuo&r."]
	quest.53C167AF34694F8F.quest_subtitle: "Conduzindo superlativamente"
	quest.53CA0D6B4D5A17D5.title: "&6Parte de Armazenamento de Fluido de 16384B"
	quest.53D5A6F210DF199C.quest_subtitle: "Transfira suavemente 10k rf/t"
	quest.53D5A6F210DF199C.title: "Transferindo Energia"
	quest.53DEA3DFEDC4809E.quest_desc: [
		"Não se preocupe, este é o último da série de rituais de Abras. Ele é usado para invocar um demônio &9Marid&r, mas mesmo que use Giz Vermelho, não é poderoso o suficiente para &9vincular&r o Demônio. Isso significa que, infelizmente, você terá que lutar contra ele."
		""
		"Este ritual usa um Tridente como sacrifício, o que é confuso porque a maioria dos sacrifícios são criaturas vivas. Então, em vez de matar um mob em cima do círculo ritual completo, você simplesmente joga o Tridente na tigela central para iniciar o ritual."
	]
	quest.53DEA3DFEDC4809E.quest_subtitle: "É um Pássaro? É um Avião? Não, é um &9Marid&r desvinculado!"
	quest.53DEA3DFEDC4809E.title: "&4Atração de Tibira"
	quest.53E2BEA626B35BFC.quest_desc: ["Receita bem cara, mas com certeza vale a pena! \\n\\nUsar o &6Olho &4Espectral&r lhe dará o &4Efeito de Visão Espectral&r. Este Efeito dá &eBrilho&r a todos os Mobs em um raio de 100 Blocos em todas as direções! \\n\\nPerfeito para encontrar estruturas subterrâneas, ou Bastiões no &c&lNether&r, ou até mesmo para encontrar a fazenda de Axolotes escondida de seus amigos!"]
	quest.53E2BEA626B35BFC.quest_subtitle: "Muito popular no ATM6!"
	quest.53E2BEA626B35BFC.title: "Amuleto do &6Olho &4Espectral &7"
	quest.53E5A8F2B05C2989.quest_subtitle: "Nível: &63"
	quest.53E70A8232A8F06E.quest_desc: ["Vendedores Errantes e &4Treinadores&r?!?!?! Quantos visitantes nós precisamos! \\n\\nBem, podemos nos livrar dos &4Treinadores&r com uma &4Vara Repelente de Treinador&r. \\n\\nApenas coloque-a no chão e eles não Aparecerão perto dela!"]
	quest.53E929BF89209CFC.quest_desc: ["&eImportadores &fe &eExportadores do OIQ&r podem ser usados para Importar e Exportar do &eItens&r de e para o &e&lSistema OIQ&r automaticamente. \\n\\n&eImportadores &fe &eExportadores&r são ambos Colocados em Blocos com Inventários para pegar ou dar &eItens&r. Eles também precisarão ser configurados para a mesma Rede da &e&lMatriz de Drives OIQ&r. \\n\\nSe forem configurados para Importar ou Exportar sem Filtros, eles automaticamente pegarão (ou enviarão) todos os &eItens&r nos respectivos Inventários ou Sistema. \\n\\nSe você quiser Filtrar, você usa Pilha de Itens, Tag e Mod. Cada um é configurado colocando um &eItem&r no Slot. Pilha de Itens usará apenas aquele &eItem&r exato. Tag precisará da Tag do Item digitada na Caixa de Texto. Mod usará o Mod de onde um &eItem&r vem. Como &2&lMinecraft&r para todos os Blocos &2&lVanilla&r."]
	quest.53E929BF89209CFC.quest_subtitle: "Melhor que uma via de mão dupla!"
	quest.53E929BF89209CFC.title: "Importar e Exportar"
	quest.53EC96FA0E7C4ED4.quest_desc: [
		"Todo Mod de Tecnologia precisa de &cEnergia&r, seja FE, RF ou outra coisa! Os &cPipez de Energia&r não discriminam, eles apenas movem! \\n\\nAlgumas Máquinas têm portas de E/S estritas para &cEnergia&r, então certifique-se de verificar isso!"
		"{image:atm:textures/questpics/logistics/pipez_energy.png width:200 height:50 align:center}"
	]
	quest.53EC96FA0E7C4ED4.title: "&cPipez de Energia"
	quest.53F54C6A1EAB9574.quest_desc: ["Odeia ocupar 4 espaços para usar &eMovimentos Z&f, &cDynamax&f, &bMegaevoluções&f e &5Terastalização&r? \\n\\nEntão, por que não dar uma chance ao Anel &bO&5m&en&ci&r! \\n\\nBasta usar este garotão em qualquer um desses 4 espaços e você terá a função do &eAnel Z&f, &cPulseira Dynamax&f, &bBracelete Mega&f e &5Orbe Tera&r em um pequeno pacote."]
	quest.53F54C6A1EAB9574.title: "Anel &bO&5m&en&ci&r"
	quest.53F861876B991C36.quest_desc: ["Adiciona uma INTERFACE deToca-discoà Mochila."]
	quest.53F861876B991C36.quest_subtitle: "Agora estamos na vibe"
	quest.53F9E5CE7EE6F852.quest_desc: ["O Capturador de Criaturas permite o transporte de mobs. Mobs podem ser colocados na lista negra através de uma tag de entidade."]
	quest.53FDC6C536E50A1A.quest_desc: ["&bGwiblings&r são peixes amigáveis nos Mares. \\n\\nEles são menores que os &bGwibs&r e agem como Peixes Vanilla!"]
	quest.53FDC6C536E50A1A.title: "&bGwibling&r"
	quest.5405C436B4489E0C.quest_desc: ["&3Infusão Medicinal&r! \\n\\nElas podem ser Criadas ou Fervidas em Consumíveis. \\n\\nAlguns que Aumentam Atributos, alguns que removem Efeitos, até mesmo alguns que dão Efeitos! \\n\\nVocê consegue Ferver todos eles?"]
	quest.5405C436B4489E0C.title: "&3Infusão Medicinal"
	quest.540895E6C9E724AD.quest_desc: [
		"&6&lPilares&r são como &6&lParedes de Colmeia&r, só que menores. Simplesmente isso."
		"{image:atm:textures/questpics/bumblezone/bumble_hivepillar.png width:200 height:100 align:center}"
	]
	quest.540895E6C9E724AD.title: "&6&lPilar de Colmeia"
	quest.540B857F043C24D5.quest_desc: ["O Biorreator produz &5Biocombustível&r com &9Água&r e um monte de materiais diferentes (verifique o JEI para todas as Entradas do Biorreator válidas). Quanto mais tipos de materiais você fornecer, mais eficiente o Biorreator é na produção de &5Biocombustível&r.\\n\\nO Gerador de Biocombustível usa &5Biocombustível&r feito do &5Biorreator&r para gerar FE."]
	quest.540B857F043C24D5.title: "Bio Energia"
	quest.54169B69725C49DF.quest_desc: ["Coloque seu Plástico Líquido no chão ou armazene um pouco em um Baú com uma Estrutura de Calor acoplada e aí está sua &3Folha de Plástico&r!"]
	quest.54169B69725C49DF.quest_subtitle: "Finalmente!"
	quest.54169B69725C49DF.title: "&fPlástico"
	quest.541D270451DA4320.quest_desc: ["O Trilho de Mudança será necessário para mudar de faixa entre os diferentes &6Trilhos&r Especiais. As setas nele mostram qual vai para onde."]
	quest.5424A0E1292B13EE.quest_desc: ["Perto da Starlight você pode encontrar Lagoas Quentes. \\n\\n(Estes não são um bioma ou estrutura, então você precisará apenas procurar para encontrá-los!) \\n\\nDentro delas você pode encontrar Pedra de Fonte Termal."]
	quest.542AD6FD1927C3E6.title: "Módulo Imortal Dracônico"
	quest.542C6D76B579886C.quest_desc: ["Usando nossa estrutura de Aparato de Encantamento, vamos querer criar nossa primeira semente, a &5Semente de Magebloom&r. \\n\\nIsso será usado para criar algumas roupas mágicas para nós!"]
	quest.5436157FDFC9633E.quest_desc: ["Com a &dEstrela&r &ado &aPatrick&r Infundida, 5 &6Fragmentos de Estrela&r, &5Pó Corrupto&r, &cPó de Mundabitur&r e a Lente do &4Assassino&r, podemos reconstruir &6&lEstrelas ATM&r, 100% automatizadas! \\n\\nAgora, esses Itens &5Criativos&r serão muito fáceis de fabricar!"]
	quest.5436157FDFC9633E.title: "Estrela &6&lATM&r Totalmente Automatizada"
	quest.54378277B8D28B1D.quest_desc: [
		"Uma \"melhoria\" para o &zGiz Arco-Íris&r, para aqueles que não gostam das runas de cores que mudam rapidamente arruinando sua estética meticulosamente criada."
		""
		"Tem a mesma função que o Giz de Arco-íris, exceto que todas as runas aparecerão em branco. Além disso, também funciona para o giz de fundação."
	]
	quest.543F00603790AD3E.quest_desc: ["O Descascador (de Troncos) descasca Troncos automaticamente usando Machados colocados na máquina."]
	quest.543F00603790AD3E.quest_subtitle: "Por favor, não"
	quest.543F00603790AD3E.title: "Descascando"
	quest.5443AA65C0D0C599.quest_desc: ["Você pode roubá-lo da &5Abelha Rainha&r ou trabalhar para consegui-lo, ajudando-a. Recomendo ser respeitoso com a &5Rainha&r, afinal, ela é da realeza! \\n\\nAo beber, você receberá vários Efeitos incríveis, além de remover alguns terríveis. \\n\\nTambém pode ser usado em &6B&8e&6e&8s&r e Beehemoths para dar-lhes Efeitos!"]
	quest.5443E15E226DFC86.quest_desc: ["Pilares são como você insere e remove OP do Núcleo de Energia. Coloque-os pelo menos perto do Núcleo, 2 deles, 1 para entrada e 1 para saída (você pode usar mais). Em seguida, coloque Vidro sobre eles e eles serão montados automaticamente, mirando no Núcleo de Energia mais próximo. Clique com o botão direito nas esferas recém-formadas no topo dos Pilares para alterar se eles são de Entrada ou Saída (você saberá pelas setas e pelo design deles). Então, você pode conectar Cristais a eles para mover OP para dentro e para fora!"]
	quest.5443E15E226DFC86.title: "A energia entra e sai por aqui"
	quest.544791880F315D5A.quest_desc: ["Barcos com Baús são Barcos com Baús neles. Você pode abrir o baú enquanto está no Barco ou pode clicar com o botão direito nele. Apenas uma pessoa pode andar no Barco de cada vez."]
	quest.544893F746387EC8.quest_desc: ["Agora com &cRedstone&r ganhamos acesso à &cEnergia&r! \\n\\nQuase todas as Máquinas no &c&lMinecraft com Mods&r precisam de &cEnergia&r. A maioria está na forma de FE (Forge Energy). \\n\\nAlgumas estão em formas semelhantes como AE, estas podem funcionar com FE ou serem traduzidas para AE. Outros Mods usam sua própria forma de Energia que é exclusiva deles."]
	quest.544893F746387EC8.title: "&cEnergia"
	quest.5466CB622A637DCD.quest_desc: ["A Fruta Abissal tecnicamente pode aparecer em qualquer corpo d'água, mas é a única que vive nos Rios Cintilantes. \\n\\nEla cresce como Kelp do chão para cima, mas também funciona como Glowberries, pois a Fruta cresce e pode ser coletada dela."]
	quest.54729932639621E3.quest_desc: ["Ela não aumentará seu Limite de Nível. \\n\\nSeu Item de Assinatura é o &0Cinto Preto&r, ela deve ser boa no Karatê!"]
	quest.54729932639621E3.title: "&aLíder de Ginásio Maylene"
	quest.54735C5FCD2077B3.quest_desc: ["&aMystical Agriculture&r é um mod de geração de recursos que permite cultivar uma grande variedade de recursos vanilla e de mods usando &aSementes&r."]
	quest.54735C5FCD2077B3.title: "&aMystical Agriculture!"
	quest.5480C9F72052ECAD.quest_desc: ["Combate é uma parte importante de todo &2&lMinecraft&r de Sobrevivência. \\n\\nSe você quer dificuldades ou não, tudo importa para o seu Combate. \\n\\n&5Encantamento&r é inteiramente diferente (e melhor) com Mods como &5&lApotheosis&r mudando a forma como fazemos isso. Além de outros Mods adicionando ainda mais &5Encantamentos&r. \\n\\nAlguns Mods dão pequenas &6&lRelíquias&r ou &3&lArtefatos&r que você pode Vestir e Segurar para obter Efeitos! "]
	quest.5480C9F72052ECAD.title: "Combate"
	quest.54822638CC243004.quest_desc: [" Nas profundezas das terras ardentes do &cNether&r, uma &6relíquia&r pulsa com uma vida estranha... a &cEsfera do Autossacrifício&r. \\n\\n Ela não te &8protege&r da &cmorte&r… ela te ensina a &enegociar&r com ela. Aqueles que a empunham aprendem que a sobrevivência pode vir com um custo... um pago com seu próprio &csangue&r. \\n\\n- &lPossui 1 habilidade:&r \\n\\n &4Sacrifício&r: \\n Ao usar, você consome uma porção da sua própria &cvida máxima&r, convertendo-a em uma &2poderosa regeneração&r ao longo do tempo. Este efeito pode &2acumular&r, mas usá-lo novamente irá &6redefinir todas&r as &6durações&r de cura ativas. \\n\\n- Uma &6relíquia&r de dor e resiliência... onde cada segundo de &cvida&r é conquistado."]
	quest.54822638CC243004.quest_subtitle: "O poder nem sempre é tomado... às vezes, é entregue."
	quest.54822638CC243004.title: "&cEsfera do Autossacrifício&r"
	quest.548274CC00E67EC4.quest_desc: ["Transferir eletricidade é simples, basta conectar um cabo entre seus &#F5B027Geradores&r e &#3CC1FAMáquinas&r. Cabos &eLV&r podem transferir no máximo &#EEFA3C256 EU/t&r."]
	quest.548274CC00E67EC4.quest_subtitle: "Limites dos Cabos"
	quest.548274CC00E67EC4.title: "&5Cabos &eLV"
	quest.54B1A876E9F6707A.quest_desc: [""]
	quest.54B1A876E9F6707A.quest_subtitle: "&oPoder e destruição como nenhum outro!"
	quest.54B1A876E9F6707A.title: "&5&lFragmento do Oblívio"
	quest.54B5E76DD69EA4CD.quest_desc: [
		"Aumento de nível para 68."
		""
		"Item de Assinatura é &5Cinto de Especialista&r."
	]
	quest.54B5E76DD69EA4CD.title: "&6Treinador Brendan"
	quest.54C852CA6E056589.quest_subtitle: "Baterias Nucleares"
	quest.54CBCD9D2F1AD907.quest_subtitle: "Alimente uma Abelha Diamante com um Bloco de Cristal Arcano"
	quest.54CBCD9D2F1AD907.title: "&fAbelha Arcana"
	quest.54CE9493B63620C4.quest_desc: ["O &#AC59EBGerador a Diesel&r converte uma variedade de combustíveis líquidos em eletricidade. Os mais acessíveis para você no início serão &7Óleo de Creosoto&r e &8Óleo Sintético&r."]
	quest.54CE9493B63620C4.quest_subtitle: "Combustíveis Líquidos -> Eletricidade"
	quest.54CE9493B63620C4.title: "&5Gerador a Diesel"
	quest.54D3D6806C1F33F3.quest_subtitle: "&f5 &cde Dano de Ataque"
	quest.54D72C234EA76054.quest_subtitle: "Nível: &e1"
	quest.54D80939887B3F7D.quest_desc: ["Faça trocas com a &5Abelha Rainha&r 128 vezes! \\n\\nBoa sorte!"]
	quest.54DE8AAAE2181F18.quest_desc: ["A Moonring Greatsword precisa ser criada a partir de drops de ambos os Chefes! Obviamente, tornando-a a mais difícil de obter e a mais poderosa! \\n\\nEla funciona como uma Espada normal, pouco antes da 1.9. Ela pode bloquear ataques como um escudo, mas não pode ser usada repetidamente para dano total."]
	quest.54E0B946BAC13654.quest_desc: [
		"Tecnicamente, a menor &a&lMatriz de Indução&r (funcional) que podemos fazer tem apenas 1 &aCélula de Indução &fe 1 &aProvedor de Indução&r, mas todas são feitas da mesma maneira. \\n\\nPrecisaremos fazer uma estrutura de &aCarcaças de Indução&r de pelo menos 3x4x3 até 18x18x18. \\n\\nAs Paredes, o Teto e o Chão podem ser preenchidos com &aCarcaça de Indução&r, Vidro Estrutural/de Reator ou &aPortas de Indução&r. \\n\\nO interior da &a&lMatriz de Indução&r será feito de nossas &aCélulas de Indução &fe &aProvedores&r. \\n\\nSe usarmos o tamanho 18x18x18, teremos 4.096 de Espaço para colocar &aCélulas &fe &aProvedores&r. Então, se dividirmos ao meio entre os dois, podemos obter... um Armazenamento de 3.28 QFE e uma Entrada/Saída de 107 GFE por Tick."
		"{@pagebreak}"
		"Este Multibloco pode ser feito em qualquer tamanho disponível, não apenas no que é mostrado nas Imagens. As Imagens meramente mostram o menor tamanho que podemos fazer."
		"{image:atm:textures/questpics/mek/mek_matrix1.png width:100 height:75 align:center}"
		"{image:atm:textures/questpics/mek/mek_matrix2.png width:100 height:90 align:center}"
		"{image:atm:textures/questpics/mek/mek_matrix3.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_matrix4.png width:100 height:110 align:center}"
	]
	quest.54E0B946BAC13654.title: "&a&lMatriz de Indução"
	quest.54E4F00AD20D7096.quest_subtitle: "Nível: &b4"
	quest.54E7967B45B20F36.quest_subtitle: "Azevinho + Murta-de-crepe Roxa"
	quest.54EC1C7FC1DA9107.quest_desc: ["Os &dDrives de Corrente Ajustáveis&r funcionam como os &dDrives de Corrente Encapsulados&r, mas com mais configurações. \\n\\nSe enviarmos um &4Sinal de Redstone&r para o &dDrive de Corrente Ajustável&r ao qual o &8Eixo&r original está conectado, a Velocidade dos outros &8Eixos&r do &dDrive de Corrente&r dobrará! \\n\\nSe enviarmos um para um &dDrive de Corrente&r diferente, a Velocidade daquele &dDrive de Corrente&r será cortada pela metade!"]
	quest.54EC1C7FC1DA9107.title: "&dDrive de Corrente Ajustável"
	quest.54F0C5C48CFC94D0.quest_desc: ["Com Logística, precisamos de Filtragem. Existem dois Filtros diferentes: de Lista e de Atributo. \\nNo Filtro de Lista, você adiciona Itens a ele e altera se é lista branca ou lista negra, e se respeita ou não os Dados NBT. \\n\\nO Filtro de Atributo pega um Item de referência e então Filtra com base em um Atributo selecionado. Isso inclui tags e outras coisas, como se pode ser usado como Combustível de Fornalha ou se pode ser roteado!"]
	quest.54F2CB52D3A7BA87.quest_desc: ["O Descarregador de Itens é o oposto do Carregador de Itens. Ele pegará itens dos &7Carrinhos&r. Este também deve estar acima do &6Trilho&r."]
	quest.54F2CB52D3A7BA87.title: "Descarregador de Itens"
	quest.54F78C9A945CF0E7.title: "Módulo de Energia Caótico"
	quest.54F7AD64A403C9BF.quest_desc: ["Esses Catalisadores podem ser adicionados como topos de pilar ao seu &2Altar Natural&r. Eles permitem que você transforme mais itens em outros itens ou os decomponha.\\n\\nO Catalisador de Desmoronamento permite que você transforme cada Folha de Ouro em 4 Pós de Ouro em vez de 2!"]
	quest.54F7AD64A403C9BF.title: "Catalisadores"
	quest.550464B5F7F4F699.quest_desc: ["A &6Pokebola de Allthemodium&r tem uma chance de 4x de capturar qualquer &cPokemon&r. Sem pegadinhas! 4x é o máximo que a maioria das &cPoke&rbolas chega, além da &aQuick&f, &dLove&f e &9Bola Criatura&r. \\n\\nA &3Pokebola de Vibranium&r tem uma chance de 6x com 50x de chance de capturar Lendários. Lendários são o melhor dos melhores &cPokemon&r, também os mais raros, claro. \\n\\nA &5Pokebola de Unobtainium&r tem uma chance de 10x com 100x de chance para Lendários. As únicas &cPokebolas&r que são melhores são a &4Bola Origem&r e..."]
	quest.550464B5F7F4F699.title: "Bolas de &6Allthemodium &3Vibranium &fe &5Unobtainium&r"
	quest.55186B8602689B66.quest_desc: [
		"O &bCartão de Memória&f é uma ferramenta com duas funções diferentes. A mais simples das duas é salvar as configurações de vários dispositivos (como filtros de lista branca) para serem copiadas para outro dispositivo do mesmo tipo."
		""
		"A segunda função de um cartão de memória é conectar &etúneis P2P&f. Ao fazer isso, o túnel P2P que está sendo conectado receberá uma ID exclusiva, que é armazenada no cartão de memória para futuras conexões."
	]
	quest.552335ED867D6EFA.quest_desc: [
		"Ótimo para fundir uma tonelada de itens!"
		""
		"Um Bloco de Carvão de Insanium é necessário para criar a &6Estrela ATM&r."
	]
	quest.55278DDC31951DA5.quest_desc: ["Eu acho que os &3Draugrs&r realmente queriam manter a &3Pedra Tumulada&r segura, por isso a trancaram! \\n\\nA &3Porta do Selo&r, sim, um nome bem criativo, nos impede de chegar até ela. Precisaremos de uma &3Chave Estranha&r para abri-la. \\n\\nNovamente, eles realmente querem que esteja trancada porque deram a &3Chave Estranha&r para o &3Aptrgangr&r. Apenas os caras mais durões da &3Prisão Congelada&r que ainda estão vivos!"]
	quest.55278DDC31951DA5.quest_subtitle: "Desbloqueando o acesso ao Maledictus"
	quest.55278DDC31951DA5.title: "&3Chave Estranha"
	quest.552BA5E6FA987256.quest_desc: ["O &cSímbolo da Malícia&r é um símbolo misterioso. Ninguém sabe como criá-lo. Circulam rumores de que ele é dropado por &4Invasores&r.\\n\\nO que ele faz é outro mistério, embora alguns jogadores tenham descoberto que perderam um afixo do equipamento em que o usaram, tornando um afixo diferente mais forte. Os afixos escolhidos para isso são, assim como o próprio símbolo, mais um mistério."]
	quest.552CA2ABE659A507.quest_desc: ["&cLava&r entra. Energia sai."]
	quest.552CA2ABE659A507.title: "&cGerador Magmático"
	quest.552F0B9B00F4F914.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.553220A2CD7CAFE4.quest_desc: ["No Natal todos os Baús parecem Presentes... mas as Fornalhas se destacam! Agora isso pode ser mudado com o Papel de Embrulho! Você pode Clicar com o Botão Direito em qualquer &lFornalha de Ferro&r e ela estará pronta para a temporada de festas! E depois que a temporada acabar, você pode Clicar com Shift e Botão Direito para desembrulhá-la!"]
	quest.553220A2CD7CAFE4.quest_subtitle: "Tudo Embrulhado"
	quest.553ADA7040B652CD.quest_desc: ["A &4&lBroca de Mineração&r, &2&lSerra Elétrica&r e o &b&lLançador Químico&r normalmente armazenam 1.000mB ou o equivalente a 1 Balde de &bFluido&r. \\n\\nNormalmente não significa sempre! Com o Tanque Grande, eles agora podem armazenar 2.000mB ou o equivalente a 2 Baldes. \\n\\nNão parece muito, mas confie em mim, é."]
	quest.553C44F85E508DE3.quest_desc: ["Este é único, pois não é usado para apenas 1 Roteador, mas para múltiplos. \\n\\nSe você quer que múltiplos Roteadores funcionem ao mesmo tempo, então cada um precisa de uma Melhoria de Sincronização. \\n\\nPrecisará ser ajustado em sua própria GUI."]
	quest.554F47A0AF7506EC.quest_subtitle: "59.049 Pedras do End"
	quest.554FADF336FF2D04.quest_desc: [
		"Sem Aumento de Nível de novo e de novo e de novo."
		""
		"O Item de Assinatura é Óculos Pretos."
	]
	quest.554FADF336FF2D04.title: "&7Luz da Ruína Vega"
	quest.55519316D85D116B.quest_desc: ["Ele também não aumentará seu Limite de Nível. Por que estamos lutando com esses caras! \\n\\nAh sim, nós temos que lutar. \\n\\nSeu Item de Assinatura é uma Carga de Vento."]
	quest.55519316D85D116B.title: "&7Revanche do Comandante Saturn"
	quest.5560F303C452E110.quest_desc: ["O Extrusor empurra blocos e entidades, mas por que não empurrar um pouco mais! \\n\\nAs entidades, não os blocos."]
	quest.5563BD4934297522.quest_desc: ["Quando você possuir uma &bAbelha de Diamante&r, cruze-a com a &2Abelha de Slime&r para criar uma &aAbelha de Esmeralda!"]
	quest.5563BD4934297522.quest_subtitle: "Abelha de Diamante + Abelha de Slime"
	quest.5563BD4934297522.title: "&fAbelha de &aEsmeralda"
	quest.55702BE0151D33FE.quest_desc: ["As &aPortas de Indução&r são como colocaremos nossa &aEnergia&r para dentro e para fora de nossa &a&lMatriz de Indução&r. \\n\\nComo no que parece ser todo Multibloco, você precisará colocar as &aPortas&r nas Paredes da &a&lMatriz de Indução&r. \\n\\nEu não acredito que as &aPortas&r tenham outros limites além dos que a própria &a&lMatriz de Indução&r possui, então você não precisará de mais de 2, a menos que esteja pegando energia de fontes diferentes!"]
	quest.55702BE0151D33FE.title: "&aPortas de Indução"
	quest.5577F49A93ADB19C.quest_desc: ["&lProductive Trees&r é um Mod irmão de &lProductive Bees&r.\\n\\nPara obter as diferentes Árvores, você precisará de Folhas Polinizadas. Para obter Folhas Polinizadas, você precisa de Pólen. Para Pólen, você precisa de Abelhas.\\n\\nAbelhas florindo perto das Árvores polinizarão automaticamente as Folhas, ou você pode usar uma Melhoria de Peneira de Pólen na Colmeia para obter e usar o Pólen você mesmo! Pegue uma por conta da casa!"]
	quest.5577F49A93ADB19C.title: "Productive Trees"
	quest.55820773BDD5319D.quest_desc: ["&bIndustrial Foregoing&r (IF para abreviar) é um mod de tecnologia que adiciona muitas máquinas com vários usos diferentes.\\n\\nPara começar, crie um &aChassi de Máquina Lamentável&r."]
	quest.55820773BDD5319D.quest_subtitle: "Nível: &a1"
	quest.55820773BDD5319D.title: "Industrial Foregoing"
	quest.5585130028BB8298.quest_desc: ["A Arma mais básica que podemos encontrar em &6&lATMons&r, o &d&lRevólver&r! \\n\\nSegure Shift e Clique com o Botão Direito para abrir o &d&lRevólver&r, depois mova alguma Munição para os Slots. Depois disso, apenas Clique com o Botão Direito para atirar! \\n\\nVocê pode aplicar 2 Melhorias a ele. As Melhorias sendo: Baioneta, Carregador Rápido, Carregador Estendido, Tubos de Elétrons Amplificadores e Mira de Precisão. \\n\\nO &d&lRevólver&r só pode conter 2 Melhorias, mas o Carregador Rápido é tecnicamente diferente."]
	quest.5585130028BB8298.quest_subtitle: "Você se sente com sorte, marginal?"
	quest.5585130028BB8298.title: "&d&lRevólver"
	quest.55882C10292B6A3D.quest_subtitle: "Alimente uma Abelha Cristalina com um Bloco da Prosperidade"
	quest.55882C10292B6A3D.title: "&fAbelha da Prosperidade"
	quest.5596F9B74231AB62.quest_desc: ["Esse cara de novo? O que ele tem, uma queda por você? \\n\\nEle aumentará seu Limite de Nível para 57. \\n\\nSeu Item de Assinatura agora é uma Pedra Brilhante."]
	quest.5596F9B74231AB62.title: "&6Treinador Pokemon Cedric"
	quest.55A9EB63F4964FCF.quest_subtitle: "&f7 &cde Dano de Ataque"
	quest.55B9B9C3AA01D323.quest_desc: [
		"Entre os enormes &5Cristais Brilhantes&r no &5&lDesfiladeiro de Cristal&r, há um &5Cristal&r na forma de uma &dFlor&r. \\n\\nÉ lindo, quase hipnotizante. Me dá vontade de cultivar um Jardim de &dFlores&r lindas, mas sei que nenhuma dessas &dFlores&r chegará perto de quão deslumbrante a &dFlor&r de &5Cristal&r é... \\n\\nDe qualquer forma, você encontrará muitos &5Cristais de Mel&r, &6Mel&r e, o mais importante, &5Flores Cristalinas&r!"
		"{image:atm:textures/questpics/bumblezone/bumble_overgrown.png width:200 height:100 align:center}"
	]
	quest.55B9B9C3AA01D323.title: "&5Flor Coberta de Vegetação"
	quest.55BB4005BB4CA316.title: "&fProcessamento de Monazita"
	quest.55BF1E9BB9F0768D.quest_desc: [
		"Acho que você já conhece o padrão, onde quer que haja Abeto, estas estão! \\n\\nSiga os troncos para baixo para encontrar &7Cascalho Suspeito&r."
		"{image:atm:textures/questpics/pokemon/find_spruce.png width:200 height:100 align:center}"
	]
	quest.55BF1E9BB9F0768D.title: "Abeto Pré-histórico"
	quest.55BF254B1831359B.quest_desc: ["As &5Brocas Galadorianas&r são as melhores Brocas que podemos anexar aos nossos Carrinhos. \\n\\nPor causa de sua grandeza, isso também significa que criá-las será mais difícil... \\nDigamos apenas que você precisará de muito &3Metal Estabilizado&r! Siga as receitas!"]
	quest.55BF254B1831359B.title: "&5Brocas Galadorianas"
	quest.55C4824DAD905512.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.55C6BBC996B51838.quest_desc: [
		"A &#ED9553Caldeira de Bronze&r converte &9água&r em vapor. O vapor atuará como combustível para suas máquinas funcionarem na &7&nEra do Vapor&r."
		""
		"Para usar a máquina, basta fornecer &9água&r e qualquer &#ED5353combustível de fornalha&r. "
		""
		"Isso aumentará a temperatura da máquina; na temperatura máxima, ela poderá operar 4 máquinas simultaneamente."
	]
	quest.55C6BBC996B51838.quest_subtitle: "Fervendo água"
	quest.55C6BBC996B51838.title: "&fA &#ED9553Caldeira de Bronze&r"
	quest.55D7CD0FA8F1AE48.quest_desc: ["A razão pela qual estamos todos aqui, &5Trens&r. O mod se chama &l&7RailCraft&r, não finja surpresa. \\n\\nExistem 2 &5Trens&r principais diferentes e 1 &5Trem&r de mineração especial. \\n\\nEsses &5Trens&r, por si só, podem ficar um pouco chatos, então por que não anexar &7Carrinhos&r a eles! Conectar &7Carrinhos&r com &7Carrinhos&r e com &5Trens&r é chamado de Acoplamento, e desconectá-los é Desacoplar. Para Acoplar &5Trens&r e &7Carrinhos&r, use uma &4Pé-de-cabra&r ou um &6Trilho&r com o &cKit de Trilho&r de Acoplamento."]
	quest.55D7CD0FA8F1AE48.title: "&7&lCarrinhos&r e &5&lTrens&r!"
	quest.55DCA040C84DCEF3.quest_desc: ["Se você quiser obter o produto que o &aFluidificador&r faz, precisará de uma &aPorta de Saída&r em uma das faces.\\n\\nO &aFluidificador&r precisará de energia para operar, então uma &cPorta de Energia&r é necessária para completar a estrutura."]
	quest.55DCA040C84DCEF3.title: "Portas Necessárias"
	quest.55DCCC4035B8BB2A.quest_subtitle: "Misture netherita e platina"
	quest.55DFC96B4CDBFA7D.quest_desc: ["O Núcleo de Computador Quântico é o coração do Computador Quântico. Ele possui 256M de armazenamento de crafting e 8 threads de coprocessamento por si só. É também o único bloco capaz de formar um Computador Quântico sozinho, quando alimentado pelos lados de Cima ou de Baixo, onde estão os conectores. No entanto, se usado para criar um multibloco, um computador muito mais poderoso pode ser criado."]
	quest.55DFC96B4CDBFA7D.title: "Coração dos Crafts: Núcleo de Computador Quântico"
	quest.55E321EFBE8956DE.quest_desc: ["Se você quer economizar com Receitas de Fermentação, o Fermentation Starter é perfeito para você. \\n\\nSubstituto muito barato para outros Itens na Fermentação."]
	quest.55E321EFBE8956DE.title: "Fermentação Facilitada"
	quest.5600FEC956AA3752.quest_desc: ["Não se preocupe, a &9Lava da Alma&r não mudou em nenhuma atualização recente! \\n\\nVerifique nas profundezas do subsolo em &b&lOutro Mundo&r ou em Vilas Piglin em &b&lOutro Mundo&r."]
	quest.5600FEC956AA3752.title: "&9Lava da Alma"
	quest.5608C74936CA9E81.quest_desc: ["O &6Braço Mecânico&r é uma Máquina muito confusa, mas também muito útil do &6&lCreate&r. Graças a Deus, não preciso explicar como usá-los, apenas como Criá-los! \\n\\nPrimeiro, e mais simples, é a &8Liga de Andesito&r. São apenas 2 &8Blocos de Andesito&r e 2 &7Pepitas de Zinco/Ferro&r. \\n\\nEm seguida, temos as &eChapas de Latão&r e &eInvólucro&r. Ambos obviamente requerem &eLatão&r, que é uma Liga feita de &6Cobre&r e &7Zinco&r! \\n\\nPor último, é definitivamente o mais difícil deles, o &eMecanismo de Precisão&r. Você precisará de toda uma configuração de &6Posicionadores&r e &eCorreias&r para continuar movendo nossa &eChapa de Ouro&r para adicionar mais Itens a ela. \\n\\n1º passo: é usar o &6Posicionador&r para adicionar uma &dRoda Dentada&r à nossa &eChapa de Ouro&r. 2º: é usar algo semelhante para adicionar uma &dRoda Dentada Grande&r a ela. 3º passo: temos que adicionar uma &7Pepita de Ferro&r com o &6Posicionador&r. \\n\\nPrecisaremos repetir isso 5 vezes para, com sorte, obter nosso &eMecanismo de Precisão&r! Sim, há uma chance de 20% de você não conseguir o Item no final! \\n\\nEi, se você não gosta de todo esse trabalho, sempre pode Criar o &6Grande Motor Avançado&r."]
	quest.5608C74936CA9E81.title: "&6Braço Mecânico"
	quest.561B5FB009744D2B.quest_desc: ["Para obter &aBlocos de Insanite&r, você precisará de 8 &aBarras de Insanite&r e 1 &cBloco de Inanite&r. Sim, eu sei que é confuso com apenas uma letra de diferença. \\n\\nPara obter &aBarras de Insanite&r, você precisará reprocessar &bBenitoite&r com &4Rossinite&r em um Reprocessador. \\n\\n&bBenitoite&r precisa ser Minerado no &c&lNether&r. \\n\\n&cBlocos de Inanite&r são feitos combinando 8 &cBarras de Inanite&r com um &cBloco de Netherita&r! &cInanite&r, não &aInsanite&r. \\n\\nPara obter Barras de Inanite, você precisará reprocessar &dRidiculite&r com &4Rossinite&r em um Reprocessador. \\n\\n&dRidiculite&r é outra cadeia de receitas que, francamente, estou cansado de olhar!"]
	quest.561B5FB009744D2B.title: "&aBlocos de Insanite"
	quest.562BD37539EE318E.title: "Nível: &cFlamejante"
	quest.565376084F05ED6E.quest_desc: ["A Dimensão conhecida por abrigar os piglins, blazes e esqueletos wither, agora abriga mais 2 chefes para lutar!"]
	quest.565376084F05ED6E.title: "&4Nether&r: Terra de 2 chefes"
	quest.56550CD12C681B0F.quest_desc: ["&2Sementes de Linho&r podem ser encontradas crescendo em campos de grama. Linho é ótimo se você precisar de muita Linha no início do jogo."]
	quest.56550CD12C681B0F.quest_subtitle: "Põe Linho, tira Linho"
	quest.565EBD340595EAC4.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.5660E81BBEED6DC3.quest_desc: ["O &dCristal de Vínculo de Alma&r é o mais difícil de criar. \\n&3Fragmentos de Pérola do End&r podem ser criados a partir de &3Pérolas do End&r, que podem ser farmadas de &5Endermen&r. Você pode usar um Extrator para obter &5Ametista&r infinita. Quartzo pode ser farmado com &2&lMA&r. \\n\\nAgora precisamos focar nas Almas. Para começar, precisamos de Almas normais! Que geralmente usamos um Extrator de Almas na Areia das Almas para tirar a Alma dela. \\n\\nMas isso é usando um Item, e muda a Areia das Almas... Primeiro, podemos nos substituir usando um Clicker do &3&lJust Dire Things&r! \\n\\nAgora só precisamos substituir a Areia sem Alma por Areia das Almas, o que pode ser feito com Quebradores e Colocadores de Blocos, também do &3&lJust Dire Things&r. \\n\\nAgora podemos combinar Almas com &5Pó Corrupto&r e Almas Aprisionadas (itens farmados do &5Guardião Lunar&r) para obter Almas Corrompidas. \\n\\nFinalmente, combine Almas com Liquid Aureal e a Granada de Mão Sagrada para fazer Almas Encantadas. A Granada de Mão Sagrada vem de uma linha de receitas do &c&lReliquary&r."]
	quest.5660E81BBEED6DC3.title: "&dCristal de Vínculo de Alma"
	quest.566C1DBA9829E328.quest_desc: ["O &e&lCombinador&r pode automatizar Receitas simples de 2 &eItens&r! \\n\\nComo 2 Corantes diferentes, ou Lama e Trigo para obter Lama Compactada. \\n\\nEle pode até fazer algumas Receitas novas e únicas como &7Pedregulho&f e &0Sílex&r para fazer &7Cascalho&r, ou 4 &5Pós de Obsidiana &f e &8Ardósia Profunda&f para fazer &5Obsidiana&r!"]
	quest.566C1DBA9829E328.title: "&e&lCombinador"
	quest.567005978482235F.quest_desc: [
		"Melhorias Válidas:"
		"- Flecha de Poção"
		"- Explosão"
		""
		"Habilidade Intrínseca:"
		"- Reparação de Lava"
	]
	quest.56970D44D4C9015A.quest_subtitle: "&f7 &cde Dano de Ataque"
	quest.56A4F5D301BC1E93.quest_desc: ["A &#6EDDFFMelhoria de Turbo&r adicionam &#FFEB6E64EU/t&r de capacidade por melhoria."]
	quest.56B58CAFCB707565.quest_subtitle: "Nível: &63"
	quest.56B6ABF3D6EA0D84.quest_desc: ["Com nosso Plugue configurado, agora podemos acessar a energia da nossa rede. O &9Ponto de Fluxo&r faz exatamente isso. Ele direciona a energia da sua rede para qualquer bloco ao qual esteja conectado, incluindo Canos ou Cabos, ou diretamente em máquinas!\\n\\nDepois de colocar seu Ponto na máquina ou bloco que deseja energizar, clique com o botão direito nele e selecione sua rede na aba \"Seleção de Rede\". Assim como o Plugue, você pode ajustar quanta energia o Ponto consome, nível de prioridade, etc."]
	quest.56B6ABF3D6EA0D84.title: "Acessando a Energia da Rede"
	quest.56B80A7EBFE21428.quest_subtitle: "Mais Opções de Filtragem"
	quest.56B80A7EBFE21428.title: "&eMelhoria de Bomba Avançada"
	quest.56BF647EA84FFF7E.quest_desc: ["Mostra quais receitas de criação estão acontecendo a qualquer momento."]
	quest.56BF647EA84FFF7E.quest_subtitle: "Mostra Receitas"
	quest.56CE6CF9C99FB522.quest_desc: ["Para os &8Radiadores&r, precisaremos da habitual &8Chapa de Aço&r, um &9Balde de Água&r que é uma novidade! E &6Chapas de Constantan&r. \\n\\n&6Constantan&r é uma Liga feita combinando &6Cobre&r e &7Níquel&r em uma &l&6Fundição de Ligas&r."]
	quest.56CE6CF9C99FB522.title: "&8Bloco de Radiador"
	quest.56D41A4605C42EB5.quest_desc: ["O &6Âmbar Cristalizado&r aparece nas &cColunas Nubladas&r. \\n\\nVocê precisará de Toque Suave para pegá-los. \\n\\nEles não fazem muito, mas são bonitos!"]
	quest.56D41A4605C42EB5.title: "&6Âmbar Cristalizado"
	quest.56DA46DC82F6665D.quest_desc: ["A Wilden Chimera é um Chefe adicionado pelo Ars Nouveau e é necessária para progredir no mod. \\n\\nEle precisa ser invocado através de um ritual e depois combatido!"]
	quest.56DA46DC82F6665D.title: "&fMate a &dWilden Chimera"
	quest.56DB53F255100136.quest_desc: ["Você precisa de Calças ainda mais chiques? Que tal aprimorarmos nossas &5perneiras de Unobtainium&r para as &a&lCalças do Meka-Traje&r! \\n\\nIsso também custará uma &dPastilha de Antimatéria&r, uma &dCélula de Indução Suprema&r e algumas &aPastilhas de Polônio&r. \\n\\nO aprimoramento vale a pena? Elas têm os mesmos atributos de Armadura que as &cPerneiras de Netherita&r?!? E estas deveriam ser 4 aprimoramentos depois da &cNetherita&r! \\n\\nSim... vale... a pena! Nós podemos Carregar as &a&lCalças do Meka-Traje&r e, em vez de você receber Dano, as &a&lCalças do Meka-Traje&r consumirão &aEnergia&r! Bem, todo Dano, exceto Dano Mágico... \\n\\nEntão, use-a em uma &7&lEstação de Modificação&r para adicionar &7Unidades de Módulo&r que, em sua maioria, aprimoram seu Movimento. É, isso pode ser muito importante mesmo!"]
	quest.56DB53F255100136.title: "&a&lCalças do Meka-Traje"
	quest.56DE217FEAE3F036.quest_desc: [
		"O Provedor de Padrão Avançado ME é um novo tipo de Provedor de Padrão ME que aprimora um Provedor de Padrão padrão ou Estendido com a habilidade de configurar a face para a qual cada item individual em um padrão é enviado. Isso permite a automação de máquinas que requerem lados específicos para entradas específicas ser feita com um único bloco e sem tubos ou uma sub-rede, como com o Infusor Metalúrgico do Mekanism."
		""
		"Para fazer uso deste recurso, você precisa de um Codificador de Padrão Avançado, para decidir para qual lado da máquina enviar cada ingrediente."
	]
	quest.56DE217FEAE3F036.quest_subtitle: "Olhando para você, Mekanism"
	quest.56DE217FEAE3F036.title: "Padrões com Lados Específicos: O Provedor de Padrão Avançado"
	quest.56E30438AE512475.quest_desc: ["Vamos fazer essas chamas arderem! \\n\\nO Pré-aquecedor é uma adição muito simples à &l&4Alto-forno Melhorado&r. \\n\\nSimplesmente coloque-os à Esquerda e à Direita do &l&4Alto-forno Melhorado&r. Então, conecte a energia ao topo dele e ele começará a acelerar o &l&4Alto-forno Melhorado&r."]
	quest.56EC79AF11B0869E.quest_desc: ["&9Xeovrenth Invocada&r é o nível máximo de &5Rituais de Possessão&r. Ele tem apenas dois usos: criar Essência da Crueldade, o principal ingrediente do Giz Marrom, e criar um Golem de Iesnium, que é basicamente um Golem de Ferro imortal e que causa mais dano."]
	quest.56EC79AF11B0869E.quest_subtitle: "Possessão Máxima"
	quest.56EC79AF11B0869E.title: "&9Xeovrenth Invocada"
	quest.56F6B205855AF7F2.quest_desc: ["O &cPokémon&r não é grande o suficiente? Por que não usar o &cGigamax&r! \\n\\nApenas alguns &cPokémon&r podem usá-lo (há uma lista online, mas Charizard e Eevee estão nela). \\n\\nAlimente-os com uma &cSopa Max&r (ou se for um Urshifu, uma &cSopa Max Doce&r) e eles poderão usar &cMovimentos G-Max&r."]
	quest.56F6B205855AF7F2.title: "&cGigamax"
	quest.570223A03231DF8C.quest_desc: ["&5Overhauled Enderman&r é um Mod semelhante ao &aCreeper Overhaul&r! Só que com Enderman, claro! \\n\\nVocê encontrará todos esses Endermen em biomas diferentes e cada um é único à sua maneira! Alguns têm ataques diferentes, alguns dropam Pérolas diferentes, e todos eles parecem diferentes!"]
	quest.570223A03231DF8C.title: "&5Enderman Reformulados"
	quest.5703EDAFCF9E7719.quest_subtitle: "Nível: &63"
	quest.57167FE67CFAC255.quest_subtitle: "Usado para adicionar Abelhas a um Filtro"
	quest.57167FE67CFAC255.title: "&fMelhoria de &6Filtro"
	quest.5716E84828EC0C23.quest_desc: ["Tijolos de Construção de Plástico são Blocos feitos através do &l&7PneumaticCraft: Repressurized&r. \\n\\nAssim como suas contrapartes da vida real, eles machucam ao pisar! \\n\\nEntão, ou use Sapatos ou alise os Tijolos."]
	quest.5716E84828EC0C23.title: "Tijolos de Construção de Plástico"
	quest.571CC5558B87377D.quest_desc: [
		"O Canhão de Cristal é uma Arma muito divertida e perigosa adicionada pelo &6&lBumblezone&r! \\n\\nMas como todos os Canhões, é melhor praticar. O Campo de Tiro de Canhão foi feito para isso! \\n\\nLá você encontrará muitos Canhões, &5Cristais&r e Alvos para acertar! Então você pode pegar as recompensas por acertar os Blocos Alvo."
		"{image:atm:textures/questpics/bumblezone/bumble_range.png width:200 height:100 align:center}"
	]
	quest.571CC5558B87377D.title: "Campo de Tiro de Canhão"
	quest.57282D7E31EE61EE.quest_desc: [
		"Depois de coletar alguns &aMinérios Brutos de Iesnium&r, você provavelmente vai querer usar os primeiras Barras para fazer uma &dPicareta de Iesnium&r. Ela não só minera Iesnium como a Picareta Infundida, mas também dura muito mais."
		""
		"Faça um favor a si mesmo e faça uma dessas!"
	]
	quest.57282D7E31EE61EE.title: "&aA Picareta do Outro Mundo&r"
	quest.5728D87E3240AF0D.quest_desc: [
		"Estrutura muito simples, os &eCórregos Polinizados&r. São Aquedutos de &bÁgua com Açúcar&r!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_streams.png width:200 height:100 align:center}"
	]
	quest.5728D87E3240AF0D.title: "&eCórregos Polinizados"
	quest.573885D6EF32B7BC.quest_subtitle: "Nível: &a2"
	quest.573C2242EAB85B49.quest_desc: [
		"O &0&lForno de Coque&r é como fazemos nosso &0Carvão de Coque&r, adivinhe do que é feito! \\n\\nPodemos usar o &0&lForno&r para fundir Troncos em &0Carvão Vegetal&r, ou fundir &0Carvão&r e &0Blocos de Carvão&r em &0Coque&r! \\n\\nQualquer um desses produzirá Óleo de Creosoto, além da receita normal."
		"{@pagebreak}"
		"O &0&lForno de Coque&r é um Multibloco muito simples, 3x3x3 de &0Tijolos de Coque&r."
		"{image:atm:textures/questpics/immersive/immersive_coke1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_coke2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_coke3.png width:100 height:100 align:center}"
		"Simplesmente Clique com o Botão Direito no Bloco do Meio da Face Frontal com um &6Martelo de Engenheiro&r para criá-lo."
		"{image:atm:textures/questpics/immersive/immersive_coke.png width:100 height:100 align:center}"
	]
	quest.573C2242EAB85B49.title: "&l&8Forno de Coque"
	quest.573DD5834B321D0A.quest_desc: [
		"A &9Acropolis&r é uma gigantesca cidade nas Nuvens acima dos vastos &9Oceano&r. (Ainda assim, não a vi da primeira vez). \\n\\nEla é feita de &9Seastone Azul&r, &3Prismarina&r e &9Água&r! Sim, muita, muita e muita &9Água&r! \\n\\nEla é baseada na Arquitetura Grega, com muitos andares diferentes, jardins e até arenas. \\n\\nPor toda ela, irão aparecer &9Octohosts&r, &9Urchinkin&r, &9Cindaria&r, &9Hippotamus&r e &9Clawdian&r! Assim como alguns Mobs do &9Oceano&r muito infelizes. \\n\\nEscondido pela Arquitetura você encontrará Baús e Blocos raros como Blocos de Diamante e Espongas!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_acropolis.png width:200 height:100 align:center}"
	]
	quest.573DD5834B321D0A.title: "&9Acropolis&f: Lar de &9&lScylla"
	quest.574E5806D1A98FE5.quest_desc: ["Os Módulos de Energia são os Módulos mais importantes e são necessários para usar os itens do DE. A quantidade neles determina quanto OP um item pode armazenar e receber, confira o Infusor de Energia para saber mais sobre o carregamento. Quanto mais avançado o Nível do Módulo de Energia, mais OP os itens podem armazenar e usar. Isso é importante, pois quando os itens são aprimorados, eles usam mais OP por uso."]
	quest.574E5806D1A98FE5.title: "Módulo de Energia Básico"
	quest.5753E0138A072A3F.quest_subtitle: "Cherry + Oak/Dark Oak"
	quest.5766C8B9E850C186.quest_desc: [
		"Para criar um dos principais itens de criação em Ars, a &9Source Gem&r, precisaremos fazer uma &6Imbuement Chamber&r. \\n\\nA Imbuement Chamber requer Fonte para imbuir itens. Ela produz uma pequena quantidade de Source por si só, mas também pode usar Source Jars como fonte de energia. \\n\\nVárias receitas também exigem que Pedestais Arcanos sejam colocados ao redor dela.\\n"
		"{image:atm:textures/questpics/ars/imbuement.png width:200 height:150 align:1}"
	]
	quest.5766C8B9E850C186.quest_subtitle: "Criando Gemas de Fonte"
	quest.576ABF43FCF886B7.title: "&2Farmland de Prudentium"
	quest.577A5FC500E14C05.quest_subtitle: "Lawson Cypress + Oak"
	quest.5791F3000D18E2C9.quest_desc: ["O &8Wither&r tem a tendência de quebrar e explodir Blocos. \\n\\nA maioria dos jogadores não gosta disso, então os &8Tijolos à Prova de Wither&r são exatamente o que você está procurando! \\n\\nEles são como os &8Blocos à Prova de Wither&r, mas com um design melhor!"]
	quest.5791F3000D18E2C9.title: "&8Tijolos à Prova de Wither"
	quest.579DA82672BF632C.quest_subtitle: "&f6 &cde Dano de Ataque"
	quest.57A18F2E51952EB8.quest_desc: ["As &5Caixas de Correio&r usarão Endereços e &5Trens&r para entregar &ePacotes&r! \\n\\nPrimeiro, os &ePacotes&r podem ser transportados nos &5Trens&r com &eDepósitos&r! Obviamente, o &eDepósito&r precisa estar conectado ao &5Trem &fvia &aCola&r. \\n\\nEm seguida, podemos atribuir a &5Caixa de Correio&r a uma &5Estação de Trem&r clicando com o botão direito na &5Estação de Trem&r com a &5Caixa de Correio&r na mão. \\n\\nPodemos então colocar a &5Caixa de Correio&r nas proximidades e quando um &5Trem &rchegar à &5Estação&r, eles interagirão com a &5Caixa de Correio&r. \\n\\nNa INTERFACE da &5Caixa de Correio&r, podemos alterar seu Endereço, o que afetará se os &ePacotes&r serão entregues ou enviados a partir dela. Se o Endereço do &ePacote&r corresponder ao Endereço da &5Caixa de Correio&r, ele será enviado para a &5Caixa de Correio&r. Se não corresponder, ele irá da &5Caixa de Correio&r para o seu &5Trem&r!"]
	quest.57A18F2E51952EB8.title: "&5Caixas de Correio"
	quest.57A7A5C79389A96A.quest_desc: ["A maioria dos jogadores já conhece o &6&lCreate&r, especialmente seus bilhões de Addons! Não são muitos os Mods que têm modpacks inteiros baseados neles! \\n\\nSe você não está acostumado com o &6&lCreate&r, estas Missões devem ajudá-lo a aprender o Mod. E com muitos &eItens &f e &6Máquinas&r, há uma Opção de Ponderar! Segure W enquanto visualiza o &eItem&r para assistir a um esquema que o ensinará a entender o &eItem &f ou a &6Máquina&r. \\n\\nE confie em mim, você vai querer aprender &6&lCreate&r, é super útil! \\n\\nPara começar, você precisará de &8Andesito&r e muito dele."]
	quest.57A7A5C79389A96A.title: "&6&lCreate&r"
	quest.57ACD83205988834.quest_subtitle: "Ouro + Ender"
	quest.57ACD83205988834.title: "&fAbelha de Platina"
	quest.57B314DBCE27B06E.quest_desc: ["Ela aumentará seu Limite de Nível para 37. \\n\\nHer Signature Item is an &aOlho de Ender&r."]
	quest.57B314DBCE27B06E.title: "&aLíder de Ginásio Fantina"
	quest.57BB2CC6D9D2AE87.quest_desc: ["Isto é o que você realmente precisa para ter &eAfixos&r perfeitos. \\n\\nPrimeiro você precisa da &6&lMesa&r, uma Ferramenta e &6Símbolos do Aprimoramento&r. \\n\\nAssim que tiver tudo isso, o mundo é todo seu! Você pode rerrolar &eAfixos&r, escolher um &eAfixo&r específico ou melhorar &eAfixos&r já existentes!"]
	quest.57BB2CC6D9D2AE87.title: "&6&lMesa de Aprimoramento"
	quest.57C4A0BAE739E903.quest_desc: ["A Câmara de Dissolução é usada para criar máquinas mais avançadas.\\n\\nVocê precisará colocar um certo fluido nela junto com os itens necessários para o que está criando. Verifique o JEI."]
	quest.57C4A0BAE739E903.quest_subtitle: "A Bancada de Trabalho?"
	quest.57CE837EC3FD5BA1.quest_desc: ["Com ambas as ferramentas, nenhum &cPokémon&r poderá se esconder de nós! \\n\\nClicar em um &cPokémon&r no &aPokeNav&r abrirá a página dele. Se houver um por perto, mostrará todos os seus status! E o mais importante, nos permitirá rastreá-lo. \\n\\nAo rastrear um &cPokémon&r, uma &cPok&rebola na sua tela apontará na direção do &cPokémon&r e contará a quantos blocos de distância ele está. \\n\\nE se você tiver dificuldade em digitar nomes de &cPokémon&r (como 99% de nós), você pode usar o botão à esquerda do botão de rastreio ao visualizar um &cPokémon&r para adicioná-lo ao seu &3PokeLocalizadores&r!"]
	quest.57CE837EC3FD5BA1.title: "Encontre todos!"
	quest.57CF8C6C867B9BDA.quest_subtitle: "Mais Opções de Filtragem"
	quest.57CF8C6C867B9BDA.title: "&eMelhoria de Filtro Avançada"
	quest.57F107892FFA1F52.quest_desc: ["Para cultivar Sementes de Estrela do Nether, você precisará de um Crux abaixo da Farmland. Sim, o cultivo de Estrelas do Nether precisava ser mais caro! \\n\\nPara fazer o Crux da Estrela do Nether, você precisará de &7Almas Languinhentas&r, que têm 1/3 de chance de drop de &8Withers&r."]
	quest.57F47BA495B27F83.quest_desc: ["O Nível de Coleta &9Nível 1&r é o nível mais baixo de picareta, necessitando de uma picareta. Qualquer picareta pode minerar estes. Itens que são de Nível 1 seriam como Pedra, Fornalha e Minério de Carvão."]
	quest.57F47BA495B27F83.title: "&9Nível de Coleta 1"
	quest.580148D1141446A6.quest_desc: [
		"&c&lO Nether&r é assustador demais para você? Então, você pode procurar Almas no &2&lMundo Superior&r!\\n\\nDentro do seu mundo (eu te fiz ir para Florestas Escuras porque o antigo &l&6Forbidden \\& Arcanus&r costumava ter blocos lá) você pode encontrar algumas Almas Perdidas vagando por aí.\\n\\nVocê pode matá-las pelas Almas que elas dropam! Mas é bem menos eficiente...\\n"
		"Se estiver tendo dificuldades para encontrar Almas, talvez queira considerar o encantamento Saque de Alma para sua espada. Matar mobs com esse encantamento ocasionalmente fará aparecer Almas."
	]
	quest.580148D1141446A6.title: "Almas Perdidas"
	quest.5820EDEF71340A1A.quest_desc: [
		"&6Trilhos Abandonados&r são bons para os mão-de-vaca e para a estética. Eles podem ser usados para fazer pontes sobre alguns blocos sem suporte. Eles só podem estar a 2 blocos de distância de blocos indo na mesma direção, ou a um bloco da direção oposta. Eles vêm com o risco de descarrilamento, basicamente seu &7Carrinho&r será jogado para fora dos &6trilhos&r."
		"{image:atm:textures/questpics/railcraft/rail_abandoned.png width:150 height:100 align:center}"
	]
	quest.5820EDEF71340A1A.title: "&6Trilhos Abandonados"
	quest.5831B3192C0E8C56.quest_desc: [
		"Quer acessar seu armazenamento remotamente? Isso pode ser feito com o &eBuraco de Minhoca Estável&r ou o &aAcessor de Armazenamento&r."
		""
		"Para usar o &eBuraco de Minhoca Estável&r, clique com Shift em um &dAtuador de Armazenamento&r para vinculá-lo. Você pode então colocar o Buraco de Minhoca para atuar como outro local de armazenamento."
		""
		"O &aAcessor de Armazenamento&r é vinculado da mesma forma, mas atua como um controle remoto sem fio que pode funcionar até mesmo entre dimensões!"
	]
	quest.5831B3192C0E8C56.title: "&aAcesso Remoto"
	quest.5844DD2BEE5EC3DC.quest_desc: ["Não coma! \\n\\n&cMercúrio&r pode ser usado para 3 coisas diferentes: Incubação, Criação de Energia e Logística!"]
	quest.5844DD2BEE5EC3DC.quest_subtitle: "Vênus... não, &cMercúrio&r!"
	quest.5844DD2BEE5EC3DC.title: "Mercúrio"
	quest.58495CFBF4F20CE9.quest_desc: ["Isto funciona como a bancada da cozinha, exceto que no ar.\\n\\nE você não pode colocar coisas em cima."]
	quest.58495CFBF4F20CE9.quest_subtitle: "Tanto espaço para atividades!"
	quest.58495CFBF4F20CE9.title: "Ainda Mais Armazenamento"
	quest.58514FDE153FD971.quest_subtitle: "Baús de Ferro?"
	quest.58514FDE153FD971.title: "&fBaú de Ferro"
	quest.5865951E4F81C91F.quest_desc: ["&7Ósmio&r + &6Pedra Luminosa&r = &ePedra Luminosa Refinada&r!"]
	quest.5865951E4F81C91F.quest_subtitle: "20"
	quest.5865951E4F81C91F.title: "&eArmadura de Pedra Luminosa Refinada"
	quest.5866438E5D19AB69.quest_desc: [
		"As &3Sanguessugas de Sculk&r às vezes podem surgir de Vasos Ancestrais quebrados. \\n\\nFunciona como uma pequena surpresa para você quando 2 aparecem! \\n\\nElas têm apenas 2 &4Corações&r e irão te atacar apesar disso. \\n\\nAo morrer, elas droparão &3Pó de Alma&r."
		"{image:atm:textures/questpics/deepndark/dnd_leech.png width:100 height:100 align:center}"
	]
	quest.5866438E5D19AB69.title: "&3Sanguessuga de Sculk"
	quest.5867713D016143A6.quest_subtitle: "Fabricado com Aparelho de Encantamento"
	quest.5867713D016143A6.title: "&fAbelha Arcana"
	quest.5869E198DA416346.quest_desc: ["O Fim de Jogo do &5&lMekanism&r é simplesmente insano. Para 1 &5Pellet de Antimatéria&r, você precisa cristalizar 1.000mb de &5Antimatéria&r. \\n\\nPara 1mb de &5Antimatéria&r, você precisa energizar 1.000mb de &3Polônio&r através do AFS. \\n\\nPara obter 1mb de &3Polônio&r, você precisará ativar os Nêutrons de 5mb de &2Lixo Nuclear&r. \\n\\nE &2Lixo Nuclear&r você obtém processando &9Combustível Fóssil&r através de um Reator de Fissão!"]
	quest.5869E198DA416346.title: "2 &5Pastilhas de Antimatéria"
	quest.586D5DE28EEC8014.quest_desc: ["&cQuanta&r ajuda a diversificar o Conjunto de &5Encantamentos&r, facilitando a obtenção de uma grande variedade de &5Encantamentos&r. \\n\\n&cQuanta&r pode acabar trabalhando contra você, quanto mais você tiver, mais comuns serão os &5Encantamentos&r fracos. \\n\\nAntes usávamos &eRetificação&r, agora usamos &6Estantes de Livros Envoltas em Geodo de Estabilidade&r! \\n\\nO &cQuanta&r padrão é &c15%&r e seu máximo é &c100%&r."]
	quest.586D5DE28EEC8014.title: "&cQuanta"
	quest.586F6FD38CF85DCA.quest_desc: ["A &4&lBroca de Mineração&r faz o que o nome sugere, ela Minera! \\n\\nFunciona como uma Picareta, precisando apenas de &8Cabeças de Broca&r e &2Bio-Diesel&r. As &8Cabeças de Broca&r determinam seu Nível de Mineração e têm Durabilidade, o que significa que precisarão ser substituídas. Você pode anexar &8Cabeças de Broca&r na &6Bancada do Engenheiro&r, no Slot Superior. \\n\\n&2Bio-Diesel&r é um &bCombustível Líquido&r que tem uma receita muito difícil de fazer... isso é para outra Missão, estamos apenas vendo como abastecê-la! Você pode usar a &4&lBroca&r em qualquer &bTanque&r ou Máquina contendo &2Bio-Diesel&r para enchê-la. \\n\\nA &4&lBroca de Mineração&r minerará em uma área de 3x3 ou 2x2, a menos que você esteja Agachado enquanto quebra! \\n\\nVocê também pode Acertar Mobs com ela para causar a mesma quantidade de Dano que uma Espada de Netherita, isso consome Combustível e Durabilidade. \\n\\nA &4&lBroca de Mineração&r pode conter 1 Cabeça de Broca e 3 Melhorias."]
	quest.586F6FD38CF85DCA.quest_subtitle: "Poderia, por favor?"
	quest.586F6FD38CF85DCA.title: "&4&lBroca de Mineração"
	quest.58819CE09A648A43.quest_desc: ["Estes são alguns dos &#3FE0AEcomponentes básicos&r necessários para fabricar a maioria dos itens em &#F5D842Oritech&r. Recomenda-se produzi-los usando o &#E0F772Montador&r para economizar recursos."]
	quest.58819CE09A648A43.quest_subtitle: "Estes serão usados para fazer a maioria das máquinas"
	quest.58819CE09A648A43.title: "Componentes Básicos de Construção"
	quest.588D4017A5FEB45B.quest_desc: ["O &5&lDraconic Evolution&r e o &3&lJust Dire Things&r são sequer Mods de Tecnologia? \\n\\nO &5&lDraconic Evolution&r usa Máquinas e... Magia? Para fundir e aprimorar diferentes Blocos. É tudo baseado no &d&lO End&r. \\n\\nO &3&lJust Dire Things&r gira em torno do uso de Goo, para converter e criar novos Blocos e &eItens&r. Para fazer novas Máquinas e até Ferramentas!"]
	quest.5894A9DB9C379E91.quest_subtitle: "Fabricação por Infusão"
	quest.5894A9DB9C379E91.title: "&fAbelha de Prudentium"
	quest.5895B7FA5497BD68.quest_desc: ["Versão aprimorada do Machado Wyvern."]
	quest.5895B7FA5497BD68.title: "Machado Dracônico"
	quest.589DFDB8FB7211AA.quest_desc: [
		"A produção de &7Borracha&r para sua transição para a &#C1DB46&nEra Elétrica&r é simples. "
		""
		"Automatizá-la o quanto antes vai te levar mais longe do que imagina."
	]
	quest.589DFDB8FB7211AA.title: "&fA &7Borracha&f e &cPlaca de Circuito"
	quest.589EB4602E3F9EEE.quest_desc: ["Abelhas de Estanho são feitas cruzando uma Abelha Cristalina com uma Abelha Mineradora Cinzenta."]
	quest.589EB4602E3F9EEE.quest_subtitle: "Mineira Cinzenta + Cristalina"
	quest.589EB4602E3F9EEE.title: "&fAbelha de Estanho"
	quest.589F1D502F680075.quest_desc: ["Perfeito para Festas na Piscina! \\n\\nAlém de parecer fofo e engraçado, o &dFlamingo de Hélio&r permite que você nade no Ar. Sim, você me ouviu! Nadar... no... Ar... \\n\\nQuando no Ar, como ao pular, você pode pressionar CTRL para começar a Nadar no Ar. Você pode se mover como na Água: Nadar para cima, Nadar para baixo, Nadar por toda parte!"]
	quest.589F1D502F680075.quest_subtitle: "Cinto"
	quest.589F1D502F680075.title: "&dFlamingo de Hélio&r"
	quest.58ACADCBA57BC1DB.quest_subtitle: "Aumenta a Produtividade das Abelhas em 200% entre outras coisas."
	quest.58ACADCBA57BC1DB.title: "&fMelhoria de &6Produtividade Gamma"
	quest.58B125BD4876054C.quest_desc: ["O &5&lMekanism&r é um mod de tecnologia que mudará a forma como você joga &2&lMinecraft&r. \\n\\nO mod foca em decompor materiais até sua composição química e tirar o melhor proveito de cada material que você encontrar.\\n\\nEste mod apresenta &cJetpacks&r movidos a Hidrogênio, um amigo mini-robô, &2&lReatores&r, uma &7&lMineradora Digital&r para automatizar a mineração e muito, muito mais. \\n\\nConfie em mim, você verá por que ele é usado em quase todo &6&lModpack ATM&r!"]
	quest.58B125BD4876054C.quest_subtitle: "O Início da Sua Própria Fábrica"
	quest.58B125BD4876054C.title: "&5&lMekanism&r"
	quest.58B5EF8EB72934C2.quest_desc: ["A &cUnidade de Jetpack&r agirá como se você estivesse usando o &cJetpack&r do &5&lMekanism&r e seu &a&lPeitoral do Meka-Traje&r. \\n\\nO &cJetpack&r usa os mesmos Controles e precisará de &7Hidrogênio&r como combustível. \\n\\nVocê pode abastecê-lo com &7Hidrogênio&r de 2 maneiras. Você pode colocá-lo em uma &5Máquina&r que tenha &7Hidrogênio&r. Ou ficar debaixo d'&9água&r enquanto seu &a&lCapacete do Meka-Traje&r tem a unidade de &9&lRespiração Eletrolítica&r. \\n\\nVocê não poderá usar esta &7Unidade&r enquanto tiver a &dUnidade de Modulação Gravitacional&r equipada."]
	quest.58B5EF8EB72934C2.quest_subtitle: "Peitoral"
	quest.58B5EF8EB72934C2.title: "&cUnidade de Jetpack"
	quest.58C2ABED43B2EA61.quest_desc: ["As &9Estruturas de Modelo&r são o ponto de partida para a criação de Modelos de Dados.\\n\\nPara começar a coletar dados sobre um mob específico, você vai querer fazer uma dessas e &9clicar com o botão direito&r no mob sobre o qual deseja coletar dados. Quando feito corretamente, a Estrutura de Modelo se transformará no Modelo de Dados do mob em que você clicou.\\n\\nPara coletar dados para esse mob, coloque o Modelo de Dados recém-criado dentro de um &aDeep Learner&r e comece a matar esse mob específico com o Deep Learner em seu inventário."]
	quest.58C2ABED43B2EA61.quest_subtitle: "\"Coletando Dados\""
	quest.58C2ABED43B2EA61.title: "&9Modelando Mobs"
	quest.58CC2E563F92B4C5.quest_desc: ["A &cEssência da Fúria&r, quando na sua Mão Secundária, agirá como um sistema de recompensas. \\n\\nEla destacará 4 Mobs e, quando eles forem mortos, você ganhará Força, e quanto mais você matar, mais alto ela vai! \\n\\nAté um máximo de 16. \\n\\nUma vez usada, ela terá um tempo de recarga de 30 minutos."]
	quest.58CC2E563F92B4C5.title: "&cEssência da Fúria"
	quest.58D3CBB518020833.quest_desc: ["Eu não vou listar todas essas &cPoke&rBolas. \\n\\nTodas essas &cPoke&rBolas terão uma chance melhor de Capturar um &cPokémon&r sob certas circunstâncias. \\n\\nDesde os Atributos do &cPokémon&r Selvagem, ao tempo em Batalha, ao lugar no Mundo, ou até a hora do dia. Todas essas &cPoke&rBolas são únicas à sua própria maneira! \\n\\nA maioria se não estiver sob essas circunstâncias, terá apenas uma Chance de 1x... A NÃO SER QUE seja dito o contrário."]
	quest.58D3CBB518020833.title: "&cBolas&r com maior taxa de Captura"
	quest.58D5BD3106BFD94A.quest_desc: ["Crie a próxima versão do livro. Eu prometo, vale a pena.\\n\\nEu até te devolvo um Diamante."]
	quest.58D5BD3106BFD94A.quest_subtitle: "Isso vale totalmente a pena"
	quest.58D5BD3106BFD94A.title: "Cozinhando com o poder dos Diamantes"
	quest.58DDD32F849940A0.quest_subtitle: "Nível: &d6"
	quest.58EC47584C773B82.quest_desc: ["Usando nossa estrutura do Aparato de Encantamento, vamos querer criar nossa primeira semente, a &5Semente de Magebloom&r. \\n\\nIsso será usado para criar algumas roupas mágicas para nós!"]
	quest.58EC47584C773B82.quest_subtitle: "Cultivando Magia"
	quest.58EC47584C773B82.title: "Semente de Magebloom"
	quest.58F7C11C241DD7A4.quest_desc: [
		"A &#6AADD9Torre de Destilação&r é a forma aprimorada da &#A3D2F0Destilaria&r. Seu principal benefício é que ela fornece múltiplas saídas para a mesma entrada."
		""
		"Para construir a estrutura, você deve abrir a interface da &#6AADD9Torre de Destilação&r e escolher a altura. A altura depende de quantas saídas você precisa. Para processar &#76759OPetróleo Bruto&r, é necessário uma altura de 3 blocos."
	]
	quest.58F7C11C241DD7A4.quest_subtitle: "Eficiência é importante"
	quest.59135B04FC7C3E61.quest_subtitle: "Alimente uma Abelha Ferro com um Bloco de Cloggrum"
	quest.59135B04FC7C3E61.title: "&fAbelha de Cloggrum"
	quest.5914D015D8543875.quest_desc: ["O &aFluidificador&r pode operar em um dos 3 modos: Sólido para Fluido, Combinando 2 Sólidos em um Fluido, ou combinando 2 Fluidos em um novo Fluido. Tudo isso depende do tipo de &aInjetores&r que você usa para o multiblock.\\n\\nPor exemplo, se você quiser converter &dBlutonium&r em um fluido, você pode usar 1 &aInjetor de Sólidos&r.\\n\\nSe você quiser combinar dois sólidos para criar algo novo, você construirá o multiblock com 2 &aInjetores de Sólidos&r.\\n\\nSe você quiser combinar dois fluidos, usará 2 &9Injetores de Fluidos&r.\\n\\nIsso pode parecer confuso, mas é importante para a progressão. Por exemplo, você vai querer converter Magnetita em um fluido no Fluidificador primeiro, e depois enviá-lo para um &aReprocessador&r com Ludicrita para criar Ridiculita."]
	quest.5914D015D8543875.title: "Modos Operacionais"
	quest.591E6964ABCC638C.quest_desc: ["&eCorreias Transportadoras&r são como podemos mover &eItens&r (e algumas Entidades). \\n\\nQuando &eItens&r são dropados nas &eCorreias&r, elas os seguram e os movem. Eles podem então ser movidos para diferentes Inventários, se quisermos extrair de Inventários, precisaremos de um tipo especial de &eCorreia&r! \\n\\nA maneira como você coloca sua &eCorreia&r determinará para onde ela se move, isso também pode ser alterado com o &6Martelo de Engenheiro&r! \\nElas precisam ser colocadas sobre Blocos, mas, curiosamente, não precisam de Blocos abaixo para continuar de pé e funcionando!"]
	quest.591E6964ABCC638C.quest_subtitle: "e algumas Entidades!"
	quest.591E6964ABCC638C.title: "Movendo &eItens&r"
	quest.5932B5AD48F6AB74.quest_desc: ["Use energia com um &5Reforço de Tubo&r para impulsionar a velocidade de extração dos tubos &2Oritech&r."]
	quest.5932B5AD48F6AB74.quest_subtitle: "Torna-os mais rápidos"
	quest.593A32072E7FD91D.quest_subtitle: "Nível: &c5"
	quest.593CB120B657126C.quest_desc: ["Agora podemos finalmente nos preocupar com a &aRadioatividade&r! \\n\\nO &8Rejeito Nuclear&r (e seus produtos) são &aRadioativos&r. Isso significa que eles devem ser contidos em &eBarris de Rejeito Radioativo&r. \\n\\nO &8Rejeito Nuclear&r (e seus produtos) deve ser transportado por tubos para dentro e para fora dos &eBarris de Rejeito Radioativo&r. \\n\\nVocê não pode quebrar o &eBarril&r ou os &cTubos&r que contêm materiais &aRadioativos&r, senão a &aRadiação&r se espalhará pelo Mundo. \\n\\nA &aRadioatividade&r também pode vir de &2&lReatores&r vazando ou derretendo. \\n\\nComo lidamos com a &aRadioatividade&r? Com o &6Traje Hazmat&r e tempo. Confira a Missão dele para aprender mais sobre eles!"]
	quest.593CB120B657126C.title: "&aRadioatividade"
	quest.594BBD31461F212D.title: "Módulo de Recuperação de Escudo Dracônico"
	quest.594F6ED00D1619EE.quest_subtitle: "Nível: &a2"
	quest.5961C1ED32522BEF.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r "
		""
		"Invoca um falso do jogador que atrai a atenção para si, afastando o aggro do jogador, com tempo de recarga."
	]
	quest.5962DC39E5874FB9.quest_subtitle: "Lápis + Esquelético"
	quest.5962DC39E5874FB9.title: "&fAbelha Corante"
	quest.5979DE0E2BA3DAE5.quest_desc: ["&7Trilhos de Trem&r são... bem, o que você usará para mover &5Trens&r! \\n\\nVocê precisará &6Posicionar&r 2 &7Pepitas de Ferro&r em uma &8Laje de Pedra&r, depois &6Prensá-la&r com uma &6Prensa de Metal&r para obter 1. \\n\\nEste será o primeiro Bloco que você colocará para obter &5Trens&r, pois será necessário para colocar &5Train Stations&r. \\n\\nEles têm algumas limitações, no entanto, não podem fazer curvas ou elevações em ângulos acentuados. Você precisará de 4 Blocos de espaço para subir um Bloco com &7Trilhos de Trem&r. Para virar, é ainda pior! Digamos apenas que, se você quiser um círculo perfeito com &7Trilhos de Trem&r, ele precisará de um diâmetro de 18 Blocos."]
	quest.5979DE0E2BA3DAE5.title: "&7Trilhos de Trem"
	quest.598DE7CEDA864B50.quest_desc: ["Por que ter apenas 1 Tanque, quando podemos usar 3! \\n\\nAgora você pode carregar 3 &bFluidos&r diferentes em seu &b&lLançador Químico&r. Segure Shift e role o mouse para alternar entre eles. \\n\\nIsso não pode ser usado com o Tanque Grande, no entanto..."]
	quest.59AF80E8EE17C769.quest_desc: [
		"A &5Floresta Ecoante&r é um pouco simples, mas também abriga as &5Árvores Ecoantes&r! \\n\\nAs &5Árvores Ecoantes&r agem como Árvores normais, você pode Minerar suas &aToras&r para Criação e suas &5Folhas&r droparão Mudas. Você também pode encontrar Brilho de Sculk dentro das Folhas. \\n\\nA seu redor, você encontrará &5Solo Ecoante&r por toda a superfície. Infelizmente, eles não podem ser transformados em Terra Arada ou Terra, são apenas Blocos."
		"{image:atm:textures/questpics/deepndark/dnd_forest.png width:200 height:100 align:center}"
	]
	quest.59AF80E8EE17C769.title: "&5Floresta Ecoante"
	quest.59B6C6BF0550D13D.quest_desc: ["Novos tipos de Vidro que podem ser usados com seus Trens! Ou bases, \\n\\nNão posso obrigá-lo a usá-lo para algo específico."]
	quest.59B6C6BF0550D13D.title: "&fVidro do &7&lRailcraft&r"
	quest.59EC02C1FBCF14EA.quest_desc: ["Você pode atualizar seu &5Gerador de Obsidiana&r para um &3Gerador do End&r. \\n\\nEntão, ele pode usar &3Pérolas do End&r ou &3Olhos do End&r para gerar Energia! \\n\\nOu fazer a &6&lEstrela&r, sua escolha."]
	quest.59EC02C1FBCF14EA.title: "&3Gerador do End"
	quest.59F5ED931FD70C55.quest_desc: ["Os &9Padrões&r são a base da autocriação. Eles armazenam receitas para que sua rede RS saiba como criar itens."]
	quest.59F5ED931FD70C55.quest_subtitle: "Siga o Padrão"
	quest.59F5ED931FD70C55.title: "Autocriação"
	quest.5A011CE8EEA3F9D8.quest_desc: ["A Aura pode ser engarrafada clicando com o botão direito no ar com uma Garrafa e Rolha. A Aura assume diferentes formas dependendo de onde é coletada.\\n\\nNo Mundo Superior, ela é engarrafada como &aLuz do Sol&r, no Nether são &4Fantasmas&r e no End é &0Escuridão&r.\\n\\nSe a área onde você usou a Garrafa e Rolha tiver uma grande falta de aura, você obterá &0Vácuo Engarrafado&r."]
	quest.5A011CE8EEA3F9D8.quest_subtitle: "Engarrafando Aura"
	quest.5A011CE8EEA3F9D8.title: "Garrafas de Aura"
	quest.5A0860631323B5E3.quest_desc: ["Feito com &3Farinha de Trigo&r. Pode ser usado para fazer Tempura de Salmão e Pão de Fermentação Natural."]
	quest.5A0860631323B5E3.quest_subtitle: "Você precisa disso"
	quest.5A088F8402230BA5.quest_desc: ["As &2Portas do Reator de Fissão&r são muito importantes mesmo. O &2&lReator de Fissão&r precisará de Portas para &2Combustível&f, &bFluido de Arrefecimento&f e &8Rejeito&r... então ele não funcionará sem as &2Portas&r. \\n\\nAs &2Portas&r podem ser colocadas em qualquer parte das Paredes do &2&lReator de Fissão&r, mas não na borda. \\n\\nPrecisaremos ter 4 delas e usar o &3Configurador&r nas &2Portas&r para Configurá-las. \\n\\nElas começarão como &aApenas Entrada&r, mas ao Clicar com Shift + Botão Direito nas &2Portas&r com o &3Configurador&r, elas mudarão para &eSaída de Rejeito&r e depois para &bSaída de Refrigerante&r. \\n\\nO modo &aApenas Entrada&r aceitará tanto &2Combustível Fóssil&r quanto &bFluido de Arrefecimento&r, seja &9Água&r ou Sódio. \\n\\nO modo &eSaída de Rejeito&r enviará o &8Rejeito Nuclear&r para fora do &2&lReator de Fissão&r. \\n\\nO modo &bSaída de Refrigerante&r extrairá Vapor se &9Água&r foi usada como &bFluido de Arrefecimento&r, ou se Sódio for usado, extrairá &6Sódio Superaquecido&r."]
	quest.5A088F8402230BA5.quest_subtitle: "Toc, Toc!"
	quest.5A088F8402230BA5.title: "&2Porta do Reator de Fissão"
	quest.5A0EB2ADEBC7EE2B.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.5A15FBB64AB9369B.quest_desc: [
		"Aumento de Nível para 47."
		""
		"O Item de Assinatura é Fruta Colbur."
	]
	quest.5A15FBB64AB9369B.title: "&7Admin Shadow Marlon"
	quest.5A17C762CDB680B5.quest_subtitle: "Nível: &63"
	quest.5A1AB1AD7DEFDD9A.quest_desc: [
		"Melhorias Válidas:"
		"- Invulnerability"
		"- Extinguish"
		"- Élitros"
		"- Death Protection"
		"- Flight"
		"- Lava Immunity"
		"- Proteção do Tempo"
	]
	quest.5A1DCD6C7F712A78.title: "Vara de Pesca de Neptunium"
	quest.5A23107C363A209E.quest_subtitle: "Faz vários Materiais do End"
	quest.5A2908437EC43AC6.quest_subtitle: "Nível: &54"
	quest.5A2A718C569F3C19.quest_desc: ["Ao Fundir &0Carvão&r em um &lForno de Coque&r, podemos obter &0Coque de Carvão&r! Ou como vou chamá-lo, apenas &0Coque&r! \\n\\nÉ praticamente apenas &0Carvão&r, mas tem mais usos no &8&lIE&r. \\n\\nVocê pode combiná-lo com Ferro para obter &7Aço&r, Triturá-lo para obter &0Pó de Coque&r, que será necessário para o &0Grafite&r, ou usá-lo como Combustível para um Alto-forno."]
	quest.5A2A718C569F3C19.title: "&8Coque&r"
	quest.5A38E9F68570F7F3.quest_desc: [
		"Melhorias Válidas:"
		"- Run Speed"
		"- Walk Speed"
		"- Swim Speed"
		""
		"Intrinsic Ability:"
		"- Lava Ability"
	]
	quest.5A4406F89DB802F0.quest_desc: ["A reação entre &#BB95CFEstireno&r e &#D46C85Butadieno&r resulta em &#827AFFEstireno-Butadieno&r."]
	quest.5A4C9F7F81D6B9DB.quest_desc: ["A &5Unidade Adicional de Modulação Gravitacional&r, como você pode ver pelo nome, é um aprimoramento para a &dUnidade de Modulação Gravitacional&r. \\n\\nAmbas precisarão ser Instaladas para usá-las! \\n\\nEntão, quais são esses Aprimoramentos? Bem, você irá parar instantaneamente ao soltar suas Teclas de Movimento durante o Voo. Você pode subir mais rápido! E até mesmo Voar sempre!"]
	quest.5A4C9F7F81D6B9DB.quest_subtitle: "Peitoral"
	quest.5A4C9F7F81D6B9DB.title: "&5Unidade Adicional de Modulação Gravitacional"
	quest.5A615BB74A5CD332.quest_desc: ["Usando o &aReprocessador&r, podemos combinar tudo o que fizemos até agora para fazer algumas Barras novas.\\n\\nNota: Você pode precisar de um &9Fluidificador&r para completar esta etapa!"]
	quest.5A615BB74A5CD332.title: "Ludicrita e Ridiculita"
	quest.5A62260FB3850092.quest_desc: ["Misturar &eEnxofre&r, &#6ACDE6Oxigênio&r e &9Água&r resultará em &#D3D955Ácido Sulfúrico&r. Isso será usado para processar &7Pó de Manganês&r."]
	quest.5A6670364ADE0858.quest_subtitle: "&f29 &cde Dano de Ataque"
	quest.5A6FF0D4BA894306.quest_desc: ["A garota-propaganda do &6&lForbidden \\& Arcanus&r, a &aStella Eterna&r. \\n\\nPor 1 Barra de &6Allthemodium&r, 3 &aOrbes Xpetrificados&r e uma &2Peça de Stellarite&r, podemos fazer um dos Itens mais superpoderosos deste Modpack! \\n\\nVocê pode usar a &aStella Eterna&r com um Item e um Modificador de Aplicação de Item para fazer os Itens perderem sua Durabilidade. Não, espere, quero dizer, perderem sua necessidade de Durabilidade! Basicamente, Itens Indestrutíveis. \\n\\nIsso pode ser usado em quase todos os Itens com Durabilidade, desde &bMachados de Diamante&r, até Varas de Pesca, e até mesmo &eArmadura de Pedra Luminosa Refinada&r! \\n\\nExistem algumas limitações, só funciona com Itens com Durabilidade, não com usos: como Cristais de Infusão ou Energia: como a Meka-Tool!"]
	quest.5A6FF0D4BA894306.title: "&aStella Eterna"
	quest.5A84A64CB3D3E6F5.quest_subtitle: "Salgueiro Branco + Carvalho/Bétula/Tília-prateada"
	quest.5A9436B100FC1E67.quest_desc: [
		"Melhorias Válidas:"
		"- Flecha de Poção"
	]
	quest.5A94A2664BFDD7B9.quest_desc: ["Bem-vindo ao Capítulo de Armazenamento Básico!\\n\\nVocê encontrará todas as formas básicas de armazenar itens sem precisar de energia, bem como itens úteis para suas necessidades de armazenamento!"]
	quest.5A94A2664BFDD7B9.title: "Armazenamento Básico"
	quest.5A955C0F53AED3ED.quest_desc: ["A &bCorrente de Almas&r funciona de forma semelhante a um Gancho de Arpão. \\n\\nVocê pode Clicar com o Botão Direito para que ela envie uma &bCorrente&r que o arrastará em direção ao Bloco em que você atirou. Você pode Clicar com o Botão Direito novamente para soltá-la. Além disso, tem um Alcance de 90 Blocos, mais ou menos alguns. \\n\\nPara fazê-la, você precisará de uma &bAlma Aprisionada&r, 2 &5Cipós Tenazes&r e uma &9Pétala Tenaz&r. \\n\\nOs dois primeiros você pode obter como drops de um &5Ódio Emaranhado&r, enquanto o último você precisará matar uma &9Monstruosidade Lunar&r."]
	quest.5A955C0F53AED3ED.title: "&bCorrente de Almas"
	quest.5A9B2246E33065A5.quest_desc: ["Afeta a quantidade de favos que você recebe sempre que uma abelha produz favos de mel. Existem 4 níveis disso: &aNormal&r, &9Médio&r, &dAlto&r, &cMuito Alto&r. &cMuito Alto&r é o que estamos procurando.\\n\\nEle é encontrado na Abelha Kamikaz e na BeeBee. A BeeBee está atualmente de férias lá embaixo, no entanto, então a Abelha Kamikaz é nossa única opção.\\n\\nPara obter uma Abelha Kamikaz, você precisa de um Capacete Ninho de Abelha. Seja atacado por criaturas (ou atire em si mesmo com uma flecha) enquanto usa o capacete para ter 30% de chance de uma Abelha Kamikaz emergir. Ela é bem rápida e vai picar o agressor (a menos que seja você), então é melhor pegá-la rapidamente ou usar o Apanhador."]
	quest.5A9B2246E33065A5.quest_subtitle: "A grande!"
	quest.5A9B2246E33065A5.title: "&a&lProdutividade"
	quest.5A9C646718EE92C2.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_vibranium.png width:100 height:150 align:center}"]
	quest.5A9C646718EE92C2.title: "&3Vibranium&r"
	quest.5A9D6672385D3D82.quest_desc: ["Use apenas 1 Lápis para uma Melhoria em vez de 4."]
	quest.5A9D6672385D3D82.quest_subtitle: "Economizando Lápis"
	quest.5AA3E5DFECB4AC4D.quest_desc: ["Naturalmente, o AE2 fornece sua própria maneira de acelerar drasticamente o crescimento de cristais.\\n\\nColoque-os ao redor de seus Cristais em Brotação, dê-lhes um pouco de energia e observe seus cristais crescerem!"]
	quest.5AA8D2A1F3618615.quest_subtitle: "Movendo eletricidade"
	quest.5AA8D2A1F3618615.title: "&fTransferência de Eletricidade"
	quest.5AAF6CA41209B365.title: "&3Ferramentas de Vibranium"
	quest.5AC1BE754210429E.quest_desc: ["Se você quiser criar uma equipe para você e seus amigos, use o comando &a/ftbteams party create (nome da equipe)&r para criar a equipe!"]
	quest.5AC497F76A086A5C.title: "&l&9Recompensa do Mundo Superior:&r&e Bruxas"
	quest.5AC68C8A4024F4C9.quest_desc: ["As &aUnidades de Energia&r podem ser usadas em todas as &a&lPeças do Meka-Traje&r e até na &dMeka-Tool&r. \\n\\nPodemos adicionar 8 delas a cada &eItem&r. Cada uma adiciona mais &aArmazenamento de Energia&r ao &eItem&r. \\n\\nNão, ela não aumenta a &aEnergia&r que já está nele. Não existe tal coisa como &aEnergia&r Grátis!"]
	quest.5AC68C8A4024F4C9.quest_subtitle: "Tudo"
	quest.5AC68C8A4024F4C9.title: "&aUnidade de Energia"
	quest.5ACE97EE75813006.quest_desc: [
		"Esta é a principal fonte de informação sobre &dRituais&r. Aqui está o básico:"
		""
		"&lNíveis de Rituais&r:"
		""
		"Os Rituais têm (basicamente) quatro níveis baseados no quão poderoso é o Demônio que você está invocando. O primeiro nível é &eFoliot&r, depois &aDijini&r, &cAfrit&r e &9Marid&r. Alguns rituais se enquadram em níveis intermediários, como o nível &6Afrit Desencadeado&r."
		""
		"T&lipos de Rituais&r:"
		""
		"Existem cinco tipos principais de rituais, mas só precisaremos de quatro para a progressão. Os três principais são &9Rituais de Evocação&r, &5Rituais de Possessão&r e &6Rituais de Infusão&r. Cada um será explicado na primeira vez que aparecer nestas missões. O quarto tipo de ritual é uma espécie de &dRitual&r &dsem Demônio&r, o que significa que ele usa partes dos três tipos para realizar uma ação especial sem o uso direto de um Demônio."
		""
		"O quinto tipo, &eRituais de Familiar&r, não é necessário para a progressão. Mas eles ainda podem invocar alguns amigos úteis para te ajudar!"
		""
		"&lGizes&r:"
		""
		"Existem dois tipos de Gizes: Gizes de Fundação e Gizes Coloridos."
		""
		"Gizes de fundação são usados em todos os rituais, e cada nível superior ganha um tom mais escuro, começando com o Giz Branco e terminando com o Giz Preto. "
		""
		"Os Gizes Coloridos são os mais comumente usados, mas a cor do Giz não se correlaciona diretamente com seu poder da mesma forma que os Gizes de Fundação."
	]
	quest.5ACE97EE75813006.title: "Os Fundamentos dos Rituais"
	quest.5AD09CCEEDC0B50F.quest_desc: ["Agora, estes são super úteis, você definitivamente deveria dar uma olhada! \\n\\nA verdadeira Fonte de Luz é a Lanterna Feral Flare. Ela colocará Fontes de Luz invisíveis em torno de 20 Blocos ou mais ao seu redor. \\n\\nA Mega Tocha é diferente: ela não emite Luz, mas Bloqueia todos os spawns de Mobs Hostis a 64 Blocos dela! Útil para quem usa Visão Noturna. \\n\\nA Lâmpada do Medo faz o oposto, ela bloqueia os spawns de Mobs Passivos na mesma área."]
	quest.5AD09CCEEDC0B50F.title: "&l&eTorchmaster&r"
	quest.5AD80D3242DD3F60.quest_desc: ["Um dos materiais mais difíceis de obter no mod!\\n\\nIsso também é usado para criar a &6Estrela ATM&r!"]
	quest.5AD80D3242DD3F60.title: "&dBloco de Insanite"
	quest.5ADFC45B03BAB852.quest_desc: ["É para isso que servem os Núcleos Dracônicos."]
	quest.5ADFC45B03BAB852.title: "Nível Dracônico"
	quest.5AE80FF518B1BBA6.quest_desc: [
		"Cansado de carregar Gizes, Candles, Skulls, and Crystals? Apenas faça uma Ritual Satchel!"
		""
		"Ao agachar + clicar com o botão direito com a Ritual Satchel em sua mão, você pode preenchê-la com todos os materiais que precisa para desenhar um círculo ritualístico."
		""
		"Depois de carregar a Bolsa, simplesmente clique com o botão direito em qualquer bloco de pré-visualização para começar a posicionar (lentamente) de forma automática todas as runas para o ritual selecionado. "
		""
		"Se um giz dentro da bolsa ficar com menos de 40% de durabilidade, o brilho de encantamento neste item irá desaparecer para sinalizar que pode ser hora de reparar ou substituir alguns dos seus Gizes."
	]
	quest.5AE80FF518B1BBA6.quest_subtitle: "Ritual de Bolso!"
	quest.5AE80FF518B1BBA6.title: "Ferramentas do Ofício: Bolsa Ritual"
	quest.5AE851B8074BC7E6.quest_subtitle: "Luminoso + Mineradora de Chocolate"
	quest.5AE851B8074BC7E6.title: "&fAbelha de Cristal de Redstone"
	quest.5AEA705D6A64A982.quest_desc: ["Se você tem um &2&lReator de Fissão&r pequeno, usado principalmente para &aPolônio&r, então devemos usar isso como um mecanismo de segurança simples! \\n\\nO &aPolônio&r é feito com o &e&lAtivador de Nêutrons Solar&r. Você provavelmente pode imaginar que ele precisa de &eLuz do Dia&r para funcionar! \\n\\nEntão, para evitar gargalos (o que pode ser mortal quando falamos de &2&lReatores&r), podemos desligar nosso &2&lReator&r quando for Noite! \\n\\nPrimeiro, configure seu &2FRLA&r para Ativação. Isso ligará o &2&lReator&r quando ele receber um &4Sinal de Redstone&r e o desligará quando não receber. \\n\\nAgora podemos colocar nosso &eSensor de Luz Solar&r e conectá-lo ao &2FRLA&r com &4Redstone&r. \\n\\nEntão, boom, está pronto!"]
	quest.5AEA705D6A64A982.title: "Interruptor de Relógio"
	quest.5AEE86EB39FD4087.quest_desc: ["O &3Tubo de Vórtice&r separa o ar pressurizado em ar quente e frio. O ar frio vai para o lado azul e o ar quente para o lado vermelho."]
	quest.5AEE86EB39FD4087.quest_subtitle: "Ainda não é RF..."
	quest.5AEE86EB39FD4087.title: "Produção de Calor"
	quest.5AF01BC5631ED1BD.quest_desc: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, você está no modo de edição."]
	quest.5B02719C13B1FFE2.quest_desc: [
		"Habilidades:"
		"- Explosão Aérea: Distância de lançamento ainda mais aprimorada."
		"- Deslocamento do Vazio: Distância de teletransporte aprimorada."
		"- Portão do Eclipse: Cria um buraco portátil em uma área de 3x3, a direção depende da face do bloco alvo. A distância do buraco criado é configurável. Nota: o Portão do Eclipse não funciona em entidades de tile."
	]
	quest.5B0FF8E0B58A4150.quest_subtitle: "Walnut + Wild Cherry"
	quest.5B114CE7192A0549.quest_subtitle: "Beech + Birch"
	quest.5B18676A77CD6069.quest_desc: ["Abram alas, &b&lAE2&r e &3&lRefined Storage&r! Nós temos &5&lMekanism&r! \\n\\nA &e&lOrquestração Quântica de Itens&r (&e&lOIQ&r) é um sistema de armazenamento Virtual de &eItens&r. Precisaremos de alguns &eItens&r para abrir e armazenar &eItens&r nele antes que possamos usá-lo! \\n\\nPrimeiro, temos o coração do sistema, a &e&lMatriz de Disco do OIQ&r. É a &5Máquina&r pela qual tudo passará e se conectará. \\n\\nEla não requer &aEnergia&r, mas como os &a&lTeletransportadores&r e os &5&lEntrelaçadores Quânticos&r, precisará ser configurada em uma Rede! Os outros &eItens&r que se conectam à &e&lMatriz de Disco do OIQ&r também precisarão ser configurados para essa mesma Rede. \\n\\nQuanto aos &eDisco do OIQ&r, nós só precisamos colocá-los dentro da &e&lMatriz de Disco do OIQ&r! "]
	quest.5B18676A77CD6069.quest_subtitle: "(OIQ)"
	quest.5B18676A77CD6069.title: "&e&lOrquestração Quântica de Itens"
	quest.5B1E0E3E876339E7.title: "&4Armadura de Supremium"
	quest.5B2FD54E425D5C9D.quest_desc: ["Agora este é difícil de conseguir... precisaremos matar 2 Chefes e um Minichefe para obter tudo para a &dForja do &cVazio&r. \\n\\nPrimeiro, precisaremos de uma &4Bigorna de Fusão Mecânica&r. Para obtê-la, visite a &4Fábrica Ancestral&r que fica sob o &2&lMundo Superior&r. \\n\\nEntão, alimente &4&lO Mensageiro&r com uma Estrela do Nether para fortalecê-lo e matá-lo! &4&lO Mensageiro&r dropará &4Witherite&r, que pode ser usada para Criar a &4Bigorna de Fusão Mecânica&r. \\n\\nEm seguida, precisaremos da &cForja Infernal&r. Isso é um Drop da &c&lMonstruosidade de Netherita&r. \\n\\nVá para o &c&lNether&r para encontrar a estrutura do &cFerreiro de Almas&r. Então, lute e mate a &c&lMonstruosidade de Netherita&r para obter sua &cForja Infernal&r! \\n\\nPor último e provavelmente o mais fácil é o &dNúcleo do Vazio&r. Felizmente, não é dropado por um Chefe, mas sim por um Minichefe! \\n\\nVisite o &5&lEnd&r para encontrar uma &dCidadela em Ruínas&r, dentro dela você encontrará o &dGolem do End&r. Este nos dropará nosso &dNúcleo do Vazio&r. \\n\\nQuando tiver tudo, use a &4Bigorna de Fusão Mecânica&r para combinar a &cForja Infernal&r e o &dNúcleo do Vazio&r para criar a &dForja do &cVazio&r."]
	quest.5B2FD54E425D5C9D.title: "&dForja do &cVazio"
	quest.5B36DE3826F26963.quest_desc: ["A &dEnergia Rotacional&r é a parte mais importante e confusa do &6&lCreate&r. \\n\\nTodas as Máquinas precisarão de algum tipo de &dEnergia Rotacional&r para funcionar, mas o que é e como a usamos? \\n\\n&dEnergia Rotacional&r é simplesmente o movimento de nossas Máquinas. Blocos como Eixos e Engrenagens moverão essa &dEnergia Rotacional&r para nossas Máquinas. \\n\\nFalando em Eixos, esse é o nosso começo para a &dEnergia Rotacional&r. Eles podem ser colocados em linha reta, um ao lado do outro. \\n\\nQuando um &8Eixo&r é movido, todos os &8Eixos&r conectados a ele (no mesmo eixo) se moverão com ele. \\n\\nCrie 2 &8Ligas de Andesito&r para criar 8 &8Eixos&r."]
	quest.5B36DE3826F26963.title: "&d&lEnergia Rotacional"
	quest.5B4397D4EC23E702.quest_desc: [
		"O lugar perfeito para todos os guerreiros &6A&8b&6e&8l&6h&8a&r! \\n\\nAqui você pode pegar uma Lança de Ferrão e encantamentos para ela!"
		"{image:atm:textures/questpics/bumblezone/bumble_stingy.png width:200 height:100 align:center}"
	]
	quest.5B4397D4EC23E702.title: "Santuário da Lança de Ferrão"
	quest.5B45AB96953FA61C.title: "&fA Era Digital"
	quest.5B46B5BF4ADB2BE9.quest_desc: ["Sim, pode fazer caminhos, não se preocupe!"]
	quest.5B46B5BF4ADB2BE9.title: "&6Pá de &5Liga de &3Allthemodium"
	quest.5B4B5C148D63ACA1.quest_desc: [
		"Os &aServos Esquecidos&r não são gerados como Mobs normais, eles precisam ser criados. Eles são criados colocando uma Gloomgourd Esculpida sobre um &aBloco de Barras Esquecidas&r. \\n\\nEles agem de forma semelhante aos Golems de Neve, eles nunca o atacarão e, em vez disso, atiram em Mobs Hostis. \\n\\nEles têm 10 Corações e não dropam nada na morte... mas por que você os mataria?"
		"{image:atm:textures/questpics/undergarden/undergarden_minion.png width:125 height:100 align:center}"
	]
	quest.5B4B5C148D63ACA1.title: "&aServos Esquecidos&r"
	quest.5B50AC47957F0CD7.quest_desc: ["A &7Plataforma de Perfuração de Petróleo&r vai extrair para você &#7A7A7APetróleo de Folhelho&r e &#918686Petróleo Bruto&r."]
	quest.5B50AC47957F0CD7.quest_subtitle: "Ruídos de Águia"
	quest.5B52389583A70E66.quest_subtitle: "Nível: &c5"
	quest.5B556192F060F3F1.quest_desc: ["A &5Obsidiana Refinada&r será importante para muitos &eItens &f e &5Máquinas&r dentro do &5&lMekanism&r, especialmente no &d&lTier Ultimate&r. \\nPrimeiro, precisaremos &3Triturar &5Obsidiana&f para obter &5Pó de Obsidiana&r. Obviamente, você precisa usar um &4&lTriturador&r para isso. \\n\\nEntão, podemos usar o &9&lInfusor Metalúrgico&r para &9Infundir&f o &5Pó de Obsidiana&r com &bDiamante Químico&r. Eu recomendaria usar &bDiamantes Enriquecidos&r para obter o máximo de aproveitamento! \\n\\nAgora temos algumas opções do que fazer com ele, ou &dEnriquecê-lo&r para obter mais &5Obsidiana Refinada Química&r ou..."]
	quest.5B556192F060F3F1.title: "&5Pó de Obsidiana Refinada"
	quest.5B5FC539BD1F4A73.quest_desc: ["Este Pilão é focado em bloquear a Geração de Criaturas. \\n\\nVocê pode usar Filtro de Criaturas para bloquear a geração de apenas certas Criaturas ou usar o Filtro Sem Vida para bloquear a geração de todas as Criaturas! \\n\\nVocê pode acumular vários Filtro de Criaturas para bloquear mais gerações. Além disso, você pode alterar a Área de Atuação para definir a distância do bloqueio da geração dessas Criaturas. \\n\\nSe você usar o Filtro Sem Vida, ele ignorará todas essas configurações."]
	quest.5B8A381EFA3D836B.quest_desc: [
		"Acima dos biomas gélidos, alguns espigões podem ser como o Espigão Submerso. \\n\\nEstes vêm com &eAreia Suspeita&r! "
		"{image:atm:textures/questpics/pokemon/find_submerged_spike.png width:200 height:100 align:center}"
	]
	quest.5B8A381EFA3D836B.title: "Espigão Submerso Pré-histórico"
	quest.5B910F1389C0B915.quest_desc: [
		"Habilidades:"
		"- Explosão Aérea: Distância de lançamento aprimorada e consome FE."
		"- Deslocamento do Vazio: Teletransporta o jogador na direção que ele está olhando, consumindo FE no processo."
	]
	quest.5B947A01CB2FA378.quest_desc: [
		"Como literalmente todos os outros passos, há várias maneiras de formar nossos &7Mecanismos&r. \\n\\nVocê pode usar &6Implantadores&r para bater em uma &7Base de Bola&r primeiro com uma Pepita, depois um &8Eixo&r, depois a outra &7Base de Bola&r para criar um &7Mecanismo&r completo. "
		"{@pagebreak}"
		"Também temos a &7Câmara de Pressão&r do &8&lPneumaticCraft&r. \\n\\nVocê precisará de uma Interface de Câmara de Pressão, 2 Válvulas e Paredes ou Vidro de Câmara de Pressão. \\n\\nA Interface é como você coloca pressão na Câmara de Pressão, sim, precisará de Pressão para fabricá-la. \\n\\nAs Válvulas são como os itens entram (pelo lado azul) e saem (pelo lado laranja). \\n\\nAs Paredes ou Vidro preencherão o resto da estrutura, exceto o centro. Esse precisa ser oco."
		"{@pagebreak}"
		"O &cMontador&r (diferente da &8Linha de Montagem&r) é perfeito para nossas receitas detalhadas de fabricação 2x2. \\n\\nPrimeiro, precisaremos fazer nossa máquina. Coloque o &cMontador&r com 3 Estruturas de Máquina em um design 1x2x2. Então, clique com o botão direito no &cMontador&r para montá-lo. \\n\\nAgora podemos dar a ele um pouco de &cEnergia&r e ele nos fará nossos &7Mecanismos&r!"
	]
	quest.5B9F3F32AB28A83A.quest_desc: ["O interior, e a parte importante, da &6&lCaldeira Termoelétrica&r é feito de Blocos chiques! \\n\\n&6Elementos de Superaquecimento&r, que trabalham transferindo &6Calor&r para a &9Água&r, e &9Dispersores de Pressão&r, que ajudarão a criar o Vapor! \\n\\nSe usarmos Construções maiores, podemos deixar espaço entre os diferentes Blocos dentro da &6&lCaldeira&r para dar mais armazenamento para Vapor e &9Água&r. \\n\\nAr entre o Topo e os &9Dispersores de Pressão&r aumentará o Armazenamento de Vapor. Ar entre os &9Dispersores de Pressão&r e os &6Elementos de Superaquecimento&r dará mais espaço para a &9Água&r."]
	quest.5B9F3F32AB28A83A.title: "A parte Termo da &6&lCaldeira Termoelétrica"
	quest.5B9F933ECD6B24FD.quest_desc: ["Permite que você pule mais alto do que com o Nível II."]
	quest.5B9F933ECD6B24FD.quest_subtitle: "Máx: 1"
	quest.5BA5B2670890EAFE.quest_desc: ["Pessoalmente, odeio ter que correr até um bloco apenas para fabricar. É aí que entra a &2Bancada de Trabalho num Graveto&r!\\n\\nEste item funciona como uma &6Bancada de Trabalho&r Portátil!\\n\\nDica: Você também pode colocar isso no seu slot de &aCurios&r e definir uma &bTecla de Atalho&r para abri-la!"]
	quest.5BA5B2670890EAFE.title: "Fabricando, mas num Graveto"
	quest.5BA986D7928BF09F.quest_desc: ["Você pode querer capturá-los, pois essa é a maneira de obter &eCorações de Piglich&r no &l&cAll&7The&fMons&r! \\n\\nBasta deixar seu &ePiglichu&r vagar livremente com um Pasto e eles começarão a soltar &eCorações de Piglich&r. \\n\\nEles simplesmente os soltam aleatoriamente no chão, a menos que você tenha um Baú por perto, então eles colocarão os &eCorações&r lá."]
	quest.5BA986D7928BF09F.title: "Corações de Piglichu?"
	quest.5BB7648DC10E1E08.quest_desc: ["O &bExportador Ultra&r tem 36 espaços para filtros, funciona 5x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.5BB7648DC10E1E08.title: "&bExportador Ultra"
	quest.5BB887411B8B38FA.quest_desc: ["Quanto a expandir a Rede ME sem fio, o primeiro passo é, admitidamente, um tanto heterodoxo.\\n\\nO &bCondensador de Matéria&f é a versão do AE2 de uma lixeira, descartando quaisquer itens inseridos nele. Quando equipado com um &eComponente de Armazenamento&f, no entanto, o condensador pode aproveitar um pouco da energia restante do item sendo descartado e armazená-la para fazer dois itens de criação especiais a partir de energia concentrada suficiente.\\n\\nO primeiro desses dois itens é a &bMatter Ball&f, exigindo pelo menos um Componente de Armazenamento de 1k e o valor de 256 itens de material descartado."]
	quest.5BB887411B8B38FA.title: "Condensador de Matéria"
	quest.5BBE8B30ED7518B8.quest_desc: [
		"Melhorias Válidas:"
		"- Ore Miner"
		"- Ore Scanner &4&lDISABLED&r&f"
	]
	quest.5BC4250E4C9F803C.title: "&9Imperium Farmland"
	quest.5BC6CC3C09F512A7.quest_desc: [
		"O Núcleo do Reator é a parte mais importante do Reator, ou seja, o Núcleo! Coloque-o a 5 blocos ou mais do Injetor e dos Estabilizadores, e você pode clicar com o botão direito nele para ver sua GUI. Aqui você encontrará algumas barras, uma esfera, botões e slots. As Barras vão da esquerda para a direita: Calor, Campo de Contenção, Saturação de Energia e Conversão de Combustível. Você já aprendeu sobre o Campo e a Energia e aprenderá sobre o Combustível em uma próxima missão. O Calor é muito importante, pois ao aquecer ele subirá para 2000C antes de estar pronto para ativar. Certifique-se de que não suba muito ou então... colapso! A Esfera é a imagem do seu Núcleo, no momento tenho um bug onde o Núcleo não tem textura, então não posso explicar muito. Os Botões mudam a aparência da GUI, para ativar ou desligar o Reator, e carregá-lo."
		"{image:atm:textures/questpics/draconic/draconic_reactor_off_down.png width:200 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_reactor_off_up.png width:150 height:150 align:1}"
	]
	quest.5BC6CC3C09F512A7.quest_subtitle: "PODER ILIMITADO"
	quest.5BC6CC3C09F512A7.title: "Construindo o Reator"
	quest.5BCA3F716348ECCD.quest_desc: ["O &9Funil de Energia&r carregará qualquer item carregável dentro do inventário do bloco para o qual ele está apontado, como um baú."]
	quest.5BD22081ED81BCC6.quest_desc: ["&9Urchinkin&r são pragas pequenas que, por algum motivo, vivem em &9Acropolis&r. \\n\\nEles têm 6 &4Corações&r sem Armadura. Felizmente, são bem fracos. \\n\\nEles têm alguns Ataques, se estiverem perto de você, vão te bater. Se houver distância, eles irão rolar em sua direção. Quando rolarem, toneladas de seus &9Espinhos&r serão disparados, causando dano a qualquer um que atingirem! \\n\\nAo morrer, eles não soltarão nada de único. Além de mais &9Espinhos&r para te ferir, é só isso."]
	quest.5BD22081ED81BCC6.title: "&9Urchinkin"
	quest.5BD5737703F3F077.quest_desc: ["Ferricore é um novo material adicionado pelo JDT. O Ferricore é adquirido realizando a Propagação de Gosma em Blocos de Ferro usando gosma de nível um ou superior. O Minério de Ferricore é afetado por fortuna."]
	quest.5BD5737703F3F077.title: "Ferricore"
	quest.5C040191740A53C8.quest_desc: [
		"Vossa &5Alteza&r, a &5Rainha Abelha&r.\\n\\nUma unidade absoluta de Abelha, tão grande que nem consegue se mover sozinha.\\n\\nAo encontrá-la, ela pedirá que você obtenha um certo Item para ela. Se você o fizer, receberá uma recompensa especial.\\n\\nAlém disso, agora que você a conheceu, pode negociar com ela (verifique o JEI para todas as trocas) e pode realizar os desejos de suas missões.\\n\\nPara avançar no Bumblezone, você precisará de Essência de Abelha, que você obtém ao fazer todas as 16 de suas missões.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_queen.png width:200 height:100 align:center}"
	]
	quest.5C040191740A53C8.title: "&5Vossa Alteza"
	quest.5C0F6B1C93A52113.quest_desc: ["Agora, este é o verdadeiro Coração do &c&lLaserIO&r! Os &cNós de Laser&r são onde os Cartões realmente irão para funcionar. \\n\\nEles moverão Itens de qualquer Inventário adjacente nas 4 Direções Cardeais e para Cima e para Baixo. Para mover para Inventários mais distantes, você precisará de um segundo &cNó&r e conectá-los com a Chave Inglesa, segurando Shift e clicando com o botão direito no 1º e clicando com o botão direito no 2º. \\n\\nVocê colocará os Cartões nos Slots da Direção correta e também pode colocar Overclockers de Nó lá para fazê-lo funcionar mais rápido."]
	quest.5C22E3103544B120.quest_desc: ["Para conectar a grande maioria da sua Rede ME, você precisará de alguns cabos. O &eCabos de Vidro de ME&f é o primeiro e mais básico tipo de cabo, e você o fabricará constantemente como o primeiro passo para criar os outros tipos de cabo.\\n\\nTanto os cabos de vidro quanto sua contraparte &eCoberta&f podem transportar até &e8 canais&r por uma única seção de cabeamento. Diferente dos cabos de vidro, os cabos cobertos podem ser posteriormente transformados em &eCabo ME Denso Coberto&f, capazes de transportar até 32 canais. No entanto, a maioria dos dispositivos 'multiparte', como Pontos e terminais, não pode ser conectada diretamente a Dense Cables, exigindo cabos de largura normal para formar uma conexão.\\n\\nTodos os cabos também podem ser fabricados com corante para colori-los. Cabos sem cor (de 'Fluix') podem se conectar a qualquer outra cor de cabo, mas, fora isso, cabos de cores diferentes nunca se conectarão uns aos outros."]
	quest.5C22E3103544B120.title: "Cabeamento Básico"
	quest.5C26EBA2F58F28F1.quest_subtitle: "Red Delicious Apple + Cherry"
	quest.5C2B30655A44227F.quest_desc: ["Oh, você achou que &5&lEternal Starlight&r faria você obter todos esses Metais da maneira mais fácil? \\n\\nHA! não seja bobo. Você terá que lutar contra Chefes, cavar na Lama e procurar por Chuvas de Meteoros!"]
	quest.5C2B30655A44227F.title: "&fMetais do &5&lEternal Starlight&r"
	quest.5C2C29ECA67F9B49.quest_desc: ["Com o Filtro Sem Vida, você nunca terá que se preocupar com a geração de qualquer Criatura em uma área de 25x25 Blocos. \\n\\nIsso é o suficiente para cobrir todas as distâncias em que as Criaturas surgem perto do jogador. Hostis ou Passivas. \\n\\nIsso inclui todos os Níveis Y também, acima ou abaixo do Pilão, então não precisa mais se preocupar em iluminar cavernas! \\n\\nNão há Lista Branca com este Filtro, ele impedirá a geração de cada Criatura."]
	quest.5C2C29ECA67F9B49.quest_subtitle: "Finalmente, paz e sossego."
	quest.5C2CF51D28F84CBE.quest_desc: [
		"Agora a luta de verdade começa, ele tem duas barras de vida e ambas precisam chegar a 0 para obter os Fragmentos do Caos. Não chegue muito perto ou ele vai te atingir com uma saraivada de Bolas de Fogo! (A propósito, em versões mais antigas, o Guardião do Caos podia até matar alguém no modo Criativo! Felizmente, não pode mais)"
		"{image:atm:textures/questpics/draconic/draconic_guardian.png width:150 height:100 align:1}"
	]
	quest.5C2CF51D28F84CBE.title: "Mate o Guardião do Caos"
	quest.5C335DBA0A7C23B5.quest_desc: [
		"Sem aumento de nível."
		""
		"Encontrado no 4º andar da &cLiga Kanto&r."
	]
	quest.5C335DBA0A7C23B5.title: "&3Elite dos Quatro Lance"
	quest.5C34376765740C16.quest_desc: ["O &cCogumelo Max&r cresce em Cavernas Exuberantes. \\n\\nEle será necessário para o &cPonto de Energia&r, além de poder criar alguns itens de comida para &cPokémon&r. \\n\\n&cDoce Dynamax&r, que aumentará o &cNível Dynamax&r daquele Pokémon, &cMel Max&r, que ativará um &cMovimento Max&r, ou &cSopa Max&r para &cGigamaxizar&f um &cPokémon&r!"]
	quest.5C34376765740C16.title: "&cCogumelo Max"
	quest.5C3FF43CF16BCF30.quest_desc: ["Com as Gemas de Fonte, você pode começar a criar as várias máquinas, criando &5Sourcestones&r."]
	quest.5C3FF43CF16BCF30.quest_subtitle: "Anteriormente \"Pedras Arcanas\""
	quest.5C3FF43CF16BCF30.title: "Pedra de Fonte"
	quest.5C47935A3B2877FF.quest_desc: ["O Mekanism oferece um Cabo de boa aparência para transferir sua energia.\\n\\nSe a máquina que você está conectando já puxa ou empurra energia, você não precisará configurar o Cabo. Caso contrário, você precisará de um &9Configurador&r para configurar o Cabo. Clicar com Shift e o botão direito mudará o Cabo para o modo de puxar ou empurrar."]
	quest.5C47935A3B2877FF.quest_subtitle: "Cano de Transferência de Energia do Mekanism"
	quest.5C47935A3B2877FF.title: "&9Mekanism: &aCabos Universais"
	quest.5C5546A5103BCF55.quest_desc: ["Este deveria disparar Químicos como &bFluidos&r ou Gases... mas não faz isso por mim. \\n\\nPelo menos pode conter 2 Melhorias! Essas funcionam!"]
	quest.5C5546A5103BCF55.title: "&b&lLançador Químico"
	quest.5C590DB2F3D935E5.quest_desc: ["O Reprocessador de Sementes pode converter sementes de essência de volta em essências."]
	quest.5C590DB2F3D935E5.quest_subtitle: "Reciclagem!"
	quest.5C6709350BEF4050.quest_desc: [
		"A Gosma de Brilho do Vazio é o terceiro nível de gosma adicionado pelo JDT e requer materiais do End para ser criada."
		""
		"Criações Desbloqueadas:"
		"- Celestigem"
		"- Chama do Vazio"
	]
	quest.5C6C4AD0F60BECCA.quest_desc: ["A &eKhopesh&r é a Arma e o Drop dos &eKoboletons&r. \\n\\nEla causa o mesmo dano que uma Espada de Ferro, mas não pode ser Encantada ou Reparada. \\n\\nAcho que eles não planejaram que você as usasse tanto assim..."]
	quest.5C6C4AD0F60BECCA.title: "&eKhopesh"
	quest.5C73247A48E72FB3.quest_desc: ["Se você quiser remover um &5Encantamento&r específico do &5Conjunto de Encantamentos&r, pode usar esta &bEstante&r em sua configuração de &5Encantamento&r! \\n\\nColoque um &5Livro de Encantamento&r, que você deseja colocar na lista negra, em um local vazio nesta &bEstante do Mar&r. \\n\\nEntão, quando você &5Encantar&r, este &5Encantamento&r não aparecerá em Itens ou Livros."]
	quest.5C73247A48E72FB3.title: "Remover &5Encantamentos&r do Conjunto"
	quest.5C7D9BCDF19B86BD.quest_desc: ["Impede que as coisas explodam."]
	quest.5C7D9BCDF19B86BD.quest_subtitle: "Seguro!"
	quest.5C83D5CDD980FD9A.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_snout.png width:100 height:150 align:center}"]
	quest.5C83D5CDD980FD9A.quest_subtitle: "Restos de Bastiões"
	quest.5C83D5CDD980FD9A.title: "Snout Armor Trim"
	quest.5C983A41886A2B75.quest_desc: ["Para voltar ao &2&lMundo Superior&r, podemos sair pelo mesmo caminho que viemos! \\n\\nUse o &9Coração das Profundezas&r em uma Estrutura de &8Ardosiabissal Reforçada&r. \\n\\nFelizmente, conseguimos uma dessas na parte inferior do &6Templo Ancestral&r."]
	quest.5C983A41886A2B75.title: "Lar, Doce Lar!"
	quest.5C990F7E5D345A6F.quest_desc: [
		"A Oferenda aos Deuses é uma estrutura multiblock feita de 1 Mesa de Oferendas e 36 Flores. Para fazer uma oferenda, você precisa de Espíritos do Chamado.\\n"
		"{image:atm:textures/questpics/natures_aura/offering.png width:295 height:150 align:center}"
	]
	quest.5C990F7E5D345A6F.quest_subtitle: "Oferecendo aos deuses um Banho de Pássaros numa Floresta de Flores"
	quest.5CAC395680027354.quest_desc: ["O &bInterdimensional Transmissor Sem Fio&r é uma versão aprimorada do &3Transmissor Sem Fio&r que tem alcance infinito, mesmo entre dimensões."]
	quest.5CAC395680027354.quest_subtitle: "Resumo: Wi-Fi bom"
	quest.5CAC395680027354.title: "&dInterdimensional Transmissor Sem Fio"
	quest.5CC9CB0911954215.quest_desc: ["Um &fNinho de &aCana&r funcionará em qualquer bioma do Mundo Superior e atrairá uma Abelha Pedreira ou uma Abelha de Junco."]
	quest.5CC9CB0911954215.quest_subtitle: "Atrai abelhas em qualquer Bioma do Mundo Superior"
	quest.5CC9CB0911954215.title: "&fNinho de &aCana"
	quest.5CCF573B67317591.quest_desc: ["As &bRaízes Brilhantes&r aparecem nas &bCavernas Floridas&r. \\n\\nElas não podem ser Escaladas e não dropam Comida... acho que são apenas para decoração."]
	quest.5CCF573B67317591.title: "&bRaízes Brilhantes"
	quest.5CCF92238B23EDC9.quest_desc: [
		"O &9Modern Industrialization&r é um mod semelhante ao &#D93D3DIC2&r e ao &#D93D3DGregTech&r em sua natureza, mas você deve progredir de forma diferente desses dois mods."
		""
		"Por meio destas quests, vou te guiar na fabricação das peças necessárias para a &#E8C843Estrela do AllTheMods&r e, mais tarde, para a &#43E898Armadura do Infinito&r."
	]
	quest.5CCF92238B23EDC9.quest_subtitle: "Ler vai ajudar"
	quest.5CCF92238B23EDC9.title: "&#A0DE45Bem-vindo ao &9Modern Industrialization&r"
	quest.5CD0E6F349F2F32D.quest_desc: ["Não tenha medo, isso não é um bicho-papão, é uma Edelwood totalmente crescida! \\n\\nA Árvore terá um Tronco de Edelwood Esculpido no topo e Galhos de Edelwood saindo dela, estes podem ser quebrados para obter Varetas de Edelwood. \\n\\nOs Troncos são ocos por dentro, espaço semelhante a um Caldeirão. Curiosamente, também pode conter Água como um Caldeirão!"]
	quest.5CD65553EF60029B.quest_desc: ["A Picareta do Caçador do Céu teleporta os blocos minerados diretamente para o inventário do jogador."]
	quest.5CD65553EF60029B.quest_subtitle: "Nível: &54"
	quest.5CD8D169181C7339.quest_desc: ["Estes três últimos itens são mais ou menos alguns brinquedos extras fornecidos pelo AE2 e não se encaixam necessariamente em nenhuma dessas árvores de missões.\\n\\nO &bCajado Carregado&f é apenas um cajado simples movido a energia que causa 3 corações de dano e consome 300AE por acerto. Ele também usa a mecânica de combate anterior à 1.9, o que significa que você pode clicar repetidamente com ele como nos velhos tempos.\\n\\nO &bManipulador de Entropia&f, quando &ousado&r em certos blocos do mundo, os derreterá no local, como areia em vidro e minérios de metal em barras de metal. Caso contrário, ele simplesmente acenderá um fogo no bloco.\\n\\nFinalmente, o &bCanhão de Matéria&f funciona de forma semelhante ao Aplicador de Cor como uma célula dedicada para conter itens de 'munição', como Bolas de Matéria e pepitas de ferro/ouro, que podem ser disparadas para causar dano a mobs ou quebrar blocos. Bolas de Matéria 'munição' mais pesadas em um Canhão de Matéria podem ser substituídas por &bBolas de Tinta&f, que aplicarão um efeito de respingo de tinta na face de qualquer bloco que for atingido. &bBolas de Tinta Luminescente&f são uma variante de bolas de tinta usadas exclusivamente pelo Canhão de Matéria, cujos respingos de tinta também emitem alguma luz uma vez presentes no mundo."]
	quest.5CD8D169181C7339.quest_subtitle: "Quente demais para a ATF"
	quest.5CD8D169181C7339.title: "As... Armas?"
	quest.5CE44C58A470E48E.quest_desc: ["&l&3Artifacts&r é um Mod maravilhoso que adiciona &l&3Artefatos&r que tornarão sua experiência no Minecraft muito mais fácil e divertida!\\n\\nTodos os &l&3Artefatos&r podem ser encontrados explorando, em arqueologia ou matando Mímicos!\\n\\nMímicos são encontrados em Acampamentos subterrâneos, parecendo Baús normais! Mas assim que você chegar muito perto, eles atacarão!"]
	quest.5CE44C58A470E48E.title: "&l&3Artefatos"
	quest.5CE7756D80E051CC.quest_desc: ["Normalmente, a &8Areia de Almas&r deixa você mais lento. Normalmente... \\n\\nCom a &8Surfista da Alma&r você andará normalmente sobre &8Areia de Almas &fe &fTerra de Almas&r. \\n\\nCom mais algumas, você andará ainda mais rápido sobre &8Areia de Almas &fe &fTerra de Almas&r do que sobre outros Blocos! \\n\\nEi, talvez caminhos de &8Areia de Almas&r não sejam mais uma má ideia..."]
	quest.5CE7756D80E051CC.quest_subtitle: "Buuuuuhhh!!!"
	quest.5CE7756D80E051CC.title: "&8Unidade Surfista da Alma"
	quest.5CF2A069A3CC4EF6.quest_subtitle: "Resina + Junco"
	quest.5CF2A069A3CC4EF6.title: "&fAbelha de Linha"
	quest.5CFBA24B3E0CDEDD.quest_desc: [
		"Enquanto segura seu Livro de Feitiços, você pode pressionar C para abrir a página de criação de feitiços. \\n\\nCada feitiço deve ter uma forma. Você começa com 3 formas básicas: Projétil, Autolançamento e Toque. \\n\\nQuanto ao Efeito, isso determina o que acontece quando você lança o feitiço. Você pode ter até 9 efeitos por feitiço. \\n\\nPara começar, você tem Dano e Quebrar. \\n\\nSelecione uma Forma e um Efeito, dê um nome ao seu feitiço e clique em criar!"
		""
		"{image:atm:textures/questpics/ars/spellbook.png width:200 height:150 align:1}"
	]
	quest.5D229FA3A5F92954.quest_desc: [
		"Os &4Munchers&r são semelhantes a quaisquer outros Mobs Hostis no &2&lUndergarden&r, mas os drops deste o tornam muito mais útil! \\n\\nO Muncher pode dropar &7Cloggrum&r e &bPepitas de Aço Gelado&r na morte."
		"{image:atm:textures/questpics/undergarden/undergarden_muncher.png width:100 height:100 align:center}"
	]
	quest.5D229FA3A5F92954.title: "&4Muncher&r"
	quest.5D404ED40C6C2690.quest_subtitle: "Forneça mais energia"
	quest.5D46EEC88D662443.quest_subtitle: "&f9 &cde Dano de Ataque"
	quest.5D4E51471F3939E0.quest_desc: [
		"Habilidades:"
		"- Explosão Aérea: Lança o jogador na direção em que está virado, consumindo durabilidade no processo, varinhas de nível superior lançam o jogador a uma distância maior. Nota: o jogador não sofrerá dano de queda enquanto estiver segurando a varinha."
	]
	quest.5D5563142917495A.quest_desc: ["&l&eFarmer's Delight&r é tudo sobre Cultivar e Cozinhar Itens de Comida! Também podemos usar esses mesmos Itens para Decoração e uso! \\n\\nO Fogão, Panelas e Frigideiras são perfeitos para uma Cozinha. \\n\\nOs Barris de Comida são ótimos para uma Despensa. \\n\\nAs coisas da Fazenda são ótimas para decoração externa e os Armários são perfeitos para qualquer lugar!"]
	quest.5D5563142917495A.title: "&l&eFarmer's Delight&r"
	quest.5D635B2021C98D41.quest_desc: ["Se você quiser lutar contra a &3Elite dos Quatro&r e o &5Campeão&r, você precisará ir até o Ginásio da Liga Kanto! \\n\\nEsta é uma torre gigante encontrada no &d&lEnd&r. Ela é feita de Púrpura, Pedra do End e tem uma Pokébola Laranja gigante na frente. \\n\\nO primeiro andar tem alguns Comerciantes do Pokemart, Enfermeiras e saques que você pode pegar. Os próximos andares têm cada um da &3Elite dos Quatro&r. O andar mais alto tem o &5Campeão&r!"]
	quest.5D635B2021C98D41.title: "Ginásio da Liga Kanto"
	quest.5D64250B940BC8FD.quest_desc: ["Ferro Comprimido pode ser usado para criar &3Armadura de Ferro Comprimido&r, é o mesmo que a Armadura de Ferro, mas com melhor Resistência da Armadura e Resistência a Repulsão.\\n\\nA armadura pode ser criada ou encontrada comumente em baús de tesouro."]
	quest.5D64250B940BC8FD.quest_subtitle: "Grande Resistência a Repulsão"
	quest.5D64250B940BC8FD.title: "Armadura de Ferro Comprimido"
	quest.5D71589555637DB0.quest_subtitle: "Alimente uma Abelha Dracônica com Minério de Anglesita"
	quest.5D71589555637DB0.title: "&fAbelha de Anglesita"
	quest.5D71ED16FD4E725A.quest_desc: ["Torna os Piglins Passivos (o mesmo que usar Armadura de Ouro), você só precisa colocar a Melhoria em uma peça."]
	quest.5D71ED16FD4E725A.quest_subtitle: "Máx: 1"
	quest.5D74D73092ACD2F2.quest_desc: ["Os &5Golems de Coral&r aparecem na &5Cidade Submersa&r e nos Oceanos depois de você ter derrotado o &5&lLeviatã&r. \\n\\nEles são semelhantes a seus parentes maiores: os &5Coralssus&r, mas têm menos &4Corações&r, com 110, e não podem ser montados por &5Deeplings&r. \\n\\nEles têm mais ataques que seus parentes, no entanto! Como pular em você e esmagar o chão ao seu lado. E pode te dar um tapa. \\n\\nNa morte, eles dropam Fragmentos de Coral Cristalizado, que podem ser transformados em Coral Cristalizado. Estes podem ser transformados no &5Sacrifício Abissal&r."]
	quest.5D74D73092ACD2F2.title: "&5Golem de Coral"
	quest.5D7B34761E8FD212.quest_desc: [
		"O &3Compressor Eletrostático&r gera muita pressão a partir de Quedas de Raios.\\n\\nPara mais informações, verifique a aba \"Informações\" no JEI.\\n"
		"{image:pneumaticcraft:textures/patchouli/electrostatic_compressor.png width:100 height:100 align:left fit:true}"
	]
	quest.5D7B34761E8FD212.title: "Pressão de Raios"
	quest.5D82340E9BED9C79.quest_desc: ["Estas relíquias podem ser encontradas no &dEnd&r!"]
	quest.5D82340E9BED9C79.title: "&dO End"
	quest.5D87088E8D71DB9B.quest_desc: ["Os Cristais IO funcionam como blocos que podem se conectar uns aos outros e mover energia entre si. Para vinculá-los, clique com Shift + Botão Direito com um Vinculador de Cristal para definir um e, em seguida, clique com o botão direito em qualquer Cristal que você queira conectar. Ao olhar para o Cristal, ele dirá Entrada do bloco ou Saída para o bloco. Entrada é aquele de onde você quer tirar OP e Saída para onde você quer que ele vá."]
	quest.5D87088E8D71DB9B.title: "Movendo OP"
	quest.5DC892BA79EB52EC.quest_desc: ["O &6Misturador&r pode fazer algumas Receitas diferentes, mas todas precisarão de uma &8Bacia&r abaixo dele! \\n\\nPodemos &6Misturar&r, isso combina &bLíquidos&f e &eItens&f em novos &eItens&r. Como Cozinhar! \\n\\n&6Fermentar&r pode combinar os &bLíquidos&f e &eItens&r certos para fazer Poções líquidas. Elas podem então ser coletadas em Garrafas Vazias para obter Poções. Você precisará de Calor de um &cQueimador de Blaze&r para &6Fermentar&r. \\n\\nPor último, há a &6Criação Automática sem Forma&r. Para o Jogador normal, isso pode ser uma declaração confusa, mas confie em mim, não é tão ruim. &6Criação sem Forma&r é uma Receita que pode ser feita com os ingredientes em qualquer padrão. \\n\\nComo Tingir Lã, o Corante e a Lã podem estar em qualquer lugar na Mesa de Criação. Ou até mesmo peças e padrões do Silent Gear!"]
	quest.5DC892BA79EB52EC.title: "&6Misturador Mecânico"
	quest.5DCDDC346359DF28.quest_subtitle: "Bálsamo + Carvalho Escuro"
	quest.5DD6631F5996BA71.quest_desc: ["As &9Rodas d'Água&r são geradores automáticos simples de &dEnergia Rotacional&r. \\n\\nSimplesmente coloque-as e faça a &9Água&r passar sobre elas em uma certa direção. Se fluir sobre ambos os lados, ela não se moverá, e a direção em que a &9Água&r flui determina para onde a &9Roda d'Água&r &dGira&r. \\n\\nA &9Roda d'Água&r normal tem apenas 1 Bloco de tamanho e fornece um pouco de Velocidade, mas com Unidades de Estresse mínimas. \\n\\nA &9Roda d'Água Grande&r ocupa uma área de 3x3 e concede mais Unidades de Estresse, mas a uma Velocidade menor. \\n\\nVocê pode usar ambas juntas para obter as mesmas Unidades de Estresse e Velocidade!"]
	quest.5DD6631F5996BA71.title: "&9Rodas d'Água"
	quest.5DDC15AAFD2CAF47.quest_desc: ["A &bArmadura de Diamante&r é a próxima na cadeia &l&2Vanilla&r, geralmente é aqui que começamos a Encantá-la também! \\n\\nRecomendo Proteção e suas várias formas, não precisamos ser exigentes com mods!"]
	quest.5DDC15AAFD2CAF47.quest_subtitle: "20"
	quest.5DDC15AAFD2CAF47.title: "&bArmadura de Diamante"
	quest.5DE3F2A96715BA2E.quest_desc: [
		"O &e&lSilo&r é um Multibloco feito para armazenar toneladas de apenas um tipo de &eItem&r, como uma Gaveta. \\n\\nVocê pode &9depositar&r o &eItem&r e suas duplicatas no Lado Superior ou no Lado Inferior, mas para &6extrair&r você precisará usar o Lado Inferior! \\n\\nEle pode armazenar 41.472 &eItens&r, mas apenas do mesmo tipo."
		"{@pagebreak}"
		"Primeiro colocamos um quadrado de Cercas de Madeira Tratada com uma &7Chapa de Ferro&r no centro."
		"{image:atm:textures/questpics/immersive/immersive_silo1.png width:125 height:100 align:center}"
		"Em seguida, fazemos um quadrado completo de &7Chapa de Ferro&r acima de nossas Cercas, deixando um espaço no centro oco. Faça isso 5 vezes!"
		"{image:atm:textures/questpics/immersive/immersive_silo2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_silo3.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_silo4.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_silo5.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_silo6.png width:100 height:100 align:center}"
		"Então, a camada final que é um quadrado inteiro de &7Chapa de Ferro&r, incluindo o preenchimento do Bloco central."
		"{image:atm:textures/questpics/immersive/immersive_silo7.png width:100 height:100 align:center}"
		"Depois disso, Clique com o Botão Direito na &7Chapa de Ferro&r do meio na segunda camada com nosso &6Martelo&r para criar nosso &e&lSilo&r!"
		"{image:atm:textures/questpics/immersive/immersive_silo.png width:100 height:125 align:center}"
	]
	quest.5DE3F2A96715BA2E.title: "&l&eSilo"
	quest.5DE45BC0258D1B0B.quest_desc: ["A &dEstante do End Perolada&r é uma &7Estante&r razoável, especialmente pelo preço. \\n\\nÉ criada combinando uma &dEstante do End&r com 4 &7Varas do End&r e 2 &3Pérolas do End&r. \\n\\nEla nos dará no máximo &aEterna 90&r, mas não é isso que queremos para o &5Encantamento&r máximo."]
	quest.5DE45BC0258D1B0B.title: "&dEstante do End Perolada"
	quest.5DE7C4FD5FA29236.quest_desc: ["Você não odeia quando está prestes a matar um Enderman e ele se teleporta? Bem, você não odeia, você ama! Você só está com raiva porque tem inveja! Você quer isso! \\n\\nE com o &5Cinto de Chorus&r você pode conseguir! Você se teleportará de um golpe que o mataria."]
	quest.5DE7C4FD5FA29236.quest_subtitle: "Cinto"
	quest.5DE7C4FD5FA29236.title: "&5Cinto de Chorus&r"
	quest.5DF26D712B643655.quest_subtitle: "Despeje Latão Derretido sobre um Ovo de Gerador de Abelha de Cobre/Zinco"
	quest.5DF26D712B643655.title: "&fAbelha de Latão"
	quest.5DFE3CB5B0130A7A.quest_desc: ["Há muita vida vegetal no topo do Rio Cintilante, em algumas você pode ficar de pé!"]
	quest.5E02AE661945306C.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.5E090C9BB4DAA5D4.title: "Nível: &aEnergizado"
	quest.5E0D78B7B2CF1729.quest_desc: ["Eu sei que é o Nível Wyvern, então por que há um item Dracônico aqui? Para chegar ao Nível Dracônico, você precisa de Injetores Dracônicos. Para obter Injetores Dracônicos, você precisará de Núcleos Dracônicos. Entende por que eles estão aqui agora?"]
	quest.5E0D78B7B2CF1729.title: "Núcleo Dracônico"
	quest.5E116409DC7D30BB.quest_desc: ["Você já devia conhecer Logística a essa altura! Esta Missão agora será dedicada a explicar o &3Configurador&r! \\n\\nSegurando Shift e rolando o scroll, você pode mudar o Modo do &3Configurador&r. \\n\\n&dChave Inglesa&r: vai soltar &5&lMáquinas&r e Blocos do &5&lMekanism&r ao usá-la neles. \\n&eGirar&r: vai simplesmente Girar a direção do Bloco. \\n&4Esvaziar&r: vai fazê-lo funcionar como um Coletor de Medidas. \\nO restante fará o &3Configurador&r interagir com &5Máquinas&r para alterar suas Configurações! \\n\\nSe você usá-lo em Tubos, ele vai mudar se eles Empurram, Puxam ou Ambos. Você pode usá-lo em Portas para definir Entradas e Saídas. E até em Caixotes para ativar a Auto-Exportação por baixo deles."]
	quest.5E116409DC7D30BB.quest_subtitle: "O Configurador"
	quest.5E116409DC7D30BB.title: "Logística do &5&lMekanism&r"
	quest.5E180764FBEE666B.quest_desc: [
		"Um Bloco muito único e útil adicionado pelo &6&lBumblezone&r, que raramente pode ser encontrado em algumas Estruturas, sendo a mais fácil a &5Flor Coberta de Vegetação&r! \\n\\nÉ um Bloco complicado, então ouça com atenção. A &5Flor&r é usada para Encantar Livros, ela tem Níveis que serão necessários para desbloquear e usar Encantamentos. \\n\\nPara obter Níveis mais altos, você precisará Alimentar a &5Flor&r com Itens ou XP. Então, você pode colocar um Livro ou Livro Encantado e selecionar um Encantamento para colocar nele."
		"{image:atm:textures/questpics/bumblezone/bumble_flower.png width:175 height:200 align:center}"
	]
	quest.5E180764FBEE666B.title: "&5Flor Cristalina"
	quest.5E191081662C2F1A.quest_desc: ["O &#6E6D6DMartelo de Forja&r funciona como o bloco de estação de trabalho do aldeão de &#A0DE45Modern Industrialization&r. Esse aldeão oferecerá uma grande variedade de trocas úteis."]
	quest.5E228ACA1B13AD04.quest_desc: ["Agora atira e bate!"]
	quest.5E24012A3D9B72A1.quest_desc: [
		"Itens não são as únicas coisas que podem ser armazenadas em células ME. &bCélulas de Armazenamento de Fluidos ME&f podem armazenar líquidos como água, lava e qualquer variedade de óleos e combustíveis de mods, para dar alguns exemplos."
		""
		"Note que todas as células de armazenamento, independentemente do que são projetadas para armazenar, diferem apenas em termos de seu invólucro; tanto as células de &6item&r quanto as de &bfluido&r usam o mesmo tipo de Componente de Armazenamento para serem feitas."
		""
		"Para fluidos, 1 byte equivale a 8 baldes (8000mb)."
	]
	quest.5E24012A3D9B72A1.title: "&eArmazenamento de &bFluidos"
	quest.5E287410EE969244.quest_desc: [
		"Os &9Estilhaçado&r aparecem em alguns Biomas no &3&lOutro Lado&r. \\n\\nEles agem como mini &9&lWardens&r, sendo Cegos e dependendo do &3Sculk&r para encontrar Inimigos. Eles também atacam todos os Mobs que não são de &3Sculk&r. \\n\\nOs &9Estilhaçados&r têm 50 &4Corações&r e batem bem forte! Então, cuidado para não atrair muitos. \\n\\nSe você conseguir matá-los, eles droparão &9Ossos de Sculk&r. Estes serão necessários para algumas Receitas."
		"{image:atm:textures/questpics/deepndark/dnd_shattered.png width:100 height:150 align:center}"
	]
	quest.5E287410EE969244.title: "&3Estilhaçado"
	quest.5E3263ACE170A8E3.quest_desc: ["A &dManopla de &eMaelstorm&r é feita com a &dManopla da Guarda&r e &eTempestade de Areia numa Garrafa&r em uma &4Bigorna de Fusão Mecânica&r. \\n\\nEsta é única de todas as Armas que eu vi de &4&lCataclysm&r. \\n\\nQuando você Segura o Botão Direito, um &dVórtice do &eVazio&r aparecerá onde você está mirando. \\n\\nO &dVórtice do &eVazio&r sugará todas as Entidades próximas, então, após alguns segundos, ele se fechará e explodirá! Causando Dano a todos perto dele."]
	quest.5E3263ACE170A8E3.title: "&dManopla de &eMaelstorm"
	quest.5E41363F9AE243F3.quest_desc: ["Você não pode alimentar sua base com Carvão para sempre! Se você tiver uma quantidade decente de recursos disponíveis, é hora de atualizar sua configuração de energia!\\n\\nEssas opções geralmente requerem um pouco de configuração, mas produzem energia suficiente para levá-lo longe em sua jogatina."]
	quest.5E41363F9AE243F3.title: "&b&lOpções de Energia de Meio de Jogo"
	quest.5E4BC0F59C90433A.quest_desc: ["O Sophisticated Storage permite que você aprimore seus Baús e Barris com metais para aumentar seu armazenamento! Você também pode adicionar melhorias para aumentar sua funcionalidade.\\n\\nEsses baús são como um Baú ou Barril vanilla, mas eles têm um slot para uma Melhoria de Armazenamento!"]
	quest.5E4BC0F59C90433A.quest_subtitle: "\"Baú Vanilla\""
	quest.5E4BC0F59C90433A.title: "Sophisticated Storage"
	quest.5E4FE420B6D2C97F.quest_desc: ["Compacta itens na mochila para sua receita 3x3."]
	quest.5E4FE420B6D2C97F.quest_subtitle: "Mais Opções de Filtragem"
	quest.5E4FE420B6D2C97F.title: "&eMelhoria de Compactação Avançada"
	quest.5E610C059737628B.quest_subtitle: "Até +3 de Altura de Passo"
	quest.5E63C78CDC44FF95.quest_desc: ["Rotten Blisterberries não podem ser arremessadas, mas quando transformadas em Blisterbombs, elas podem! \\n\\nVocê pode ir ainda mais longe e fazer Boomgourds, que agirão como TNTs que lançam Blisterberries para todo lado."]
	quest.5E63C78CDC44FF95.title: "Explosivos!!!"
	quest.5E6585F7627247E3.quest_desc: ["Quando aplicada como um upgrade a qualquer dispositivo compatível, como uma Interface ou um Ponto de Exportação, a &bCartão de Fabricação&f permite que o dispositivo em questão envie automaticamente suas próprias solicitações de fabricação para um item necessário (filtrado). As CPUs de Fabricação podem ser configuradas para responder apenas a essas solicitações para evitar a ocupação de CPUs destinadas a fabricações solicitadas pelo jogador.\\n\\nQuando o &eEmissor de Nível&f é atualizado com o Cartão de Fabricação, ele pode ser configurado para emitir um sinal de redstone para facilitar diretamente a fabricação, emitindo um sinal &odurante&r a detecção de uma tarefa de fabricação para o item especificado ou especificamente &opara&r fabricar o item. O último caso se aplicaria a situações em que a única coisa necessária para fazer um item é um sinal de redstone, sem sequer exigir um padrão de fabricação."]
	quest.5E6585F7627247E3.quest_subtitle: "Automação em forma de upgrade!"
	quest.5E6585F7627247E3.title: "&eCartão de Fabricação"
	quest.5E671F1F370DDE43.title: "Módulo de Autoalimentação Dracônico"
	quest.5E6D7C1D7957DD4D.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_forgotten.png width:100 height:150 align:center}"]
	quest.5E6D7C1D7957DD4D.title: "&aForgotten&r"
	quest.5E71F8A046C60346.quest_desc: ["Quem lhe disse que PneumaticCraft não era sobre gerar energia?\\n\\nO &3Pneumatic Dynamo&r permite que você transforme sua pressão em FE. Leia a dica de ferramenta ou o livro PNC:R para aprender como funciona."]
	quest.5E71F8A046C60346.quest_subtitle: "Pressão = Energia"
	quest.5E71F8A046C60346.title: "Gerando Energia"
	quest.5E750DB2244A67A1.quest_desc: [
		"O &6trilho Turnout&r é o primeiro resultado ao bater em um &6trilho&r com um Spike Maul. Ele pode ajudar a ir em duas direções, para frente e para o lado. Pode ser trocado com um Switch próximo ao &6trilho&r."
		"{image:atm:textures/questpics/railcraft/rail_turnout.png width:100 height:100 align:center}"
	]
	quest.5E750DB2244A67A1.title: "&6Trilhos Turnout"
	quest.5E766840DAB839A2.quest_subtitle: "Ash + Sugar Maple"
	quest.5E7CCDE9229A646A.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_allthemodium.png width:100 height:150 align:center}"]
	quest.5E7CCDE9229A646A.title: "&6Allthemodium&r"
	quest.5E7E35CCAF1C88EE.quest_desc: ["O &bPonto de Importação ME&f suga itens periodicamente de qualquer armazenamento externo para o qual o bus esteja voltado. Opcionalmente, pode ser filtrado para receber apenas certos itens do referido inventário."]
	quest.5E7E35CCAF1C88EE.quest_subtitle: "O aspirador de itens oficial da sua rede ME!"
	quest.5E7E35CCAF1C88EE.title: "&bPonto de Importação"
	quest.5E84A58C2EC65240.quest_desc: ["O &8Aço&r é inteiramente &cModificado&r. De forma alguma &2&lVanilla&r, apenas feito a partir de itens &2&lVanilla&r como Ferro e &0Carvão&r. \\n\\nComo fazemos isso? Basta escolher um Mod! \\n\\nInfusor Metalúrgico - &5&lMekanism&r \\nFundição de Liga - &a&lEnderIO&r \\nFornalha de Liga ou Alto-forno - &8&lImmersive Engineering&r \\nFundição - &6&lOritech&r \\nA Fundição - &c&lProductive Metalworks&r \\nAlto-forno - &6&lRailCraft Reborn&r \\n\\nTodos esses funcionam!"]
	quest.5E84A58C2EC65240.title: "&8Aço"
	quest.5E8D527DE9D7DD46.quest_desc: ["Com isto no seu Peitoral, você pode Planar! Como se estivesse usando uma Elytra (Mas sem o custo de Armadura). Eu não gosto de chamar de voar, mas sim de 'cair com estilo'."]
	quest.5E8D527DE9D7DD46.title: "Módulo de Voo Wyvern"
	quest.5E9AF8BB2C67DCCE.quest_subtitle: "Muitas maneiras de transportar líquidos"
	quest.5E9AF8BB2C67DCCE.title: "Transportando líquidos"
	quest.5EAD916C4F15335F.quest_desc: ["O &4Importador Mega&r tem 54 espaços para filtros, funciona 8x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.5EAD916C4F15335F.title: "&4Importador Mega"
	quest.5EB488C393B084C4.quest_desc: ["Uma continuação do &lChiseled&r, &4&lRechiseled&r! \\n\\nTudo neste Mod funciona dentro da Ferramenta Chisel, clique com o botão direito com ela para abrir sua GUI. \\nNa esquerda é onde você escolhe o design e no canto inferior direito é onde você coloca os Blocos. \\n\\nAcima, você pode visualizar o design em padrões definidos: apenas 1 Bloco, Blocos 3x1 ou uma Parede 3x3 daquele Bloco. Você também pode configurar a imagem para girar ou não girar clicando no botão! \\n\\nAo lado de onde os Blocos vão, você pode clicar no Chisel, fazendo isso aplicará o design selecionado a todos os Blocos em seu inventário que podem ser alterados. \\n\\nTambém não tem durabilidade!"]
	quest.5EB488C393B084C4.title: "&4&lRechiseled&r"
	quest.5EB7CE3A1DCD3E9B.quest_desc: ["É um &cÍmã&r."]
	quest.5EB7CE3A1DCD3E9B.quest_subtitle: "Cinto"
	quest.5EB7CE3A1DCD3E9B.title: "&cUniversal Attractor&r"
	quest.5EB87CE5F6DEFAAA.quest_desc: [" Nas profundezas do &cNether&r, entre as ruínas de &cBastiões&r, jaz uma &6relíquia&r que permite que você caminhe despercebido... a &6Máscara de Piglin&r. \\n\\n Com ela, até mesmo &6estranhos&r podem se misturar à sociedade caótica dos &6piglins&r, transformando &cinimigos&r em &2aliados&r inquietos. \\n\\n- &lPossui 3 habilidades:&r \\n\\n1. &eNeutralidade&r: \\n &6Piglins&r não irão mais te &catacar&r ao te ver, permitindo que você se &2mova livremente&r entre eles. \\n\\n2. &6Troca&r \\n Ao trocar, &6piglins&r podem recompensá-lo com &6múltiplos itens&r por uma única troca, &6aumentando&r o valor de cada negócio. \\n\\n3. &cSaque&r \\n &cInimigos derrotados&r têm a chance de soltar &6dentes de ouro&r, que podem ser usados para &6trocas&r com &6piglins&r ou derretidos em &eouro&r. \\n\\n Uma &6relíquia&r de &6ganância&r e &eouro&r... onde até os &cmonstros&r respeitam um rosto familiar."]
	quest.5EB87CE5F6DEFAAA.quest_subtitle: "Às vezes, a sobrevivência não é sobre lutar… mas sobre se ajustar."
	quest.5EB87CE5F6DEFAAA.title: "&cMáscara de Piglin&r"
	quest.5EC1B868720BF521.quest_desc: ["&8&lImmersive Engineering&r é sobre Máquinas Multibloco, Ferramentas divertidas e, claro, engenharia. \\n\\nNão se preocupe, você não precisará de 4 anos de faculdade para isso! Mas um Manual pode ajudá-lo a começar."]
	quest.5EC1B868720BF521.title: "&8&lImmersive Engineering"
	quest.5ECE56EAB6773769.quest_desc: ["Peixes (e &cPokémon&r peixes) não são atraídos por anzóis assustadores! Apenas anzóis assustadores que tenham iscas saborosas neles. \\n\\nPara pescar &cPokémon&r, precisaremos de &2Bolotas&r! \\n\\nDiferentes &2Bolotas&r dão efeitos diferentes para a pesca. Seja tornando um certo tipo de &cPokémon&r mais comum, dando melhores status ou até aumentando o nível dos &cPokémons&r. \\n\\nPara usá-las, segure as &2Bolotas&r na sua mão secundária ao pescar."]
	quest.5ECE56EAB6773769.title: "Isca de Pesca"
	quest.5ED0DA95BAE43D88.quest_desc: ["O último dos Prismas, bem, este é um &dCristal&r, mas você entendeu a ideia! \\n\\nPrimeiro, você precisará de uma Relíquia &eDivine Pact&r, que é encontrada em &b&lO Outro&r. \\n\\nEntão, você precisará de &3Fragmentos de Enderpearl&r, &5Ametista&r e Quartzo do Nether. Não se preocupe, fica mais difícil! \\n\\nAgora precisaremos de todos os tipos de Alma. Eu ensinei como obter Almas e &9Almas Corrompidas&r em outras Missões, agora vou ensinar sobre &dAlmas Encantadas&r. \\n\\nEncontre uma Alma Perdida voando pelo seu mundo, então jogue uma &bPoção de Aureal Arremessável&r nela! Então, ela se tornará uma &dAlma Perdida Encantada&r, mate-a! \\n\\nCom isso, você agora pode fazer o &dCristal&r, que pode ser aplicado a Ferramentas e Armaduras para dar-lhes Soulbound. Isso significa que quando você morrer, você reaparecerá com esses Itens em seu Inventário ainda."]
	quest.5ED0DA95BAE43D88.title: "&dCristal de Vínculo de Alma"
	quest.5EDB5A2D744CE415.quest_desc: ["A &4Laser Gatling&r é uma arma que você pode fazer com &4Witherite&r. \\n\\nUsando Redstone em seu inventário, você pode atirar Lasers que iniciam incêndios e causam 3 corações e meio de dano. \\n\\nEla dispara 50 Lasers por 1 redstone, o que eu acho um bom negócio."]
	quest.5EDB5A2D744CE415.quest_subtitle: "Direto de Fallout"
	quest.5EDB5A2D744CE415.title: "&4Laser Gatling"
	quest.5EE1DF1C8F0C1FF9.quest_desc: [
		"Depois de construir a &l&5Lightning Coil&r, podemos fazer um Raio atingir as &8Cercas de Aço&r, que se tornarão &cEnergia&r em seu próprio reservatório de &cEnergia&r. \\n\\nA mais &8Cercas de Aço&r, maior a chance de um Raio! \\n\\nSerá que podemos usar outros Mods para invocar Raios?"
		"{@pagebreak}"
		"Para aproveitar o poder do fenômeno mais devastador da Mãe Natureza, precisaremos começar com um &5Bloco de Bobina de Alta Tensão&r. Em seguida, coloque &5Acumuladores HV&r adjacentes ao &5Bloco de Bobina de Alta Tensão&r. Nos cantos, coloque &8Andaimes de Aço&r."
		"{image:atm:textures/questpics/immersive/immersive_lightning1.png width:100 height:100 align:center}"
		"Para a próxima camada, coloque outro &5Bloco de Bobina de Alta Tensão&r em cima do anterior. Adjacente a ele, haverá &eBlocos de Engenharia Leve&r. Nos cantos, serão apenas Cercas Tratadas simples!"
		"{image:atm:textures/questpics/immersive/immersive_lightning2.png width:100 height:100 align:center}"
		"Agora, precisamos de um terceiro &5Bloco de Bobina de Alta Tensão&r acima dos outros, e ao seu redor haverá 8 &6Blocos de Bobina de Cobre&r."
		"{image:atm:textures/questpics/immersive/immersive_lightning3.png width:100 height:100 align:center}"
		"Então, clique com o botão direito no &eBloco de Engenharia Leve&r na face frontal com um &6Martelo&r para convertê-lo na &5&lLightning Coil&r!"
		"{image:atm:textures/questpics/immersive/immersive_lightning.png width:100 height:100 align:center}"
		"Eu não fiz uma imagem para este passo, mas você precisará de &8Cercas de Aço&r em cima da &5&lLightning Coil&r para que um Raio a atinja!"
	]
	quest.5EE1DF1C8F0C1FF9.title: "&5&lLightning Coil"
	quest.5EE485880EA9FACF.quest_subtitle: "Nível: &63"
	quest.5EE7D5DE07A83C7D.quest_desc: ["&lTipo de Habilidade:&r Ativa\\n\\n&lFunção da Habilidade:&r\\n\\nDestaca minérios próximos com partículas verdes quando ativada.\\n\\n&4&lNOTA: ESTA HABILIDADE FOI DESATIVADA.&r&f"]
	quest.5EE945A1185E8336.quest_desc: ["&l&7Functional Storage&r adiciona &7Gavetas&r que podem conter várias pilhas de um item. Elas podem ser aprimoradas para conter ainda mais pilhas!\\n\\nIsso é ótimo para itens que você obtém em grande quantidade, como Pedregulho ou Sementes!"]
	quest.5EE945A1185E8336.quest_subtitle: "Armazenamento em Gavetas?"
	quest.5EE945A1185E8336.title: "&l&7Functional Storage&r"
	quest.5EEEB61899F66962.quest_desc: ["Se quisermos criar nossas &cPoke&rbolas favoritas, precisaremos usar o &6&lCreate&r! \\n\\nE tudo isso começa com a &7Liga de Andesito&r! \\n\\nSiga a própria página de missões do &6&lCreate&r para entender melhor como o mod funciona."]
	quest.5EEEB61899F66962.title: "Fabricando &cPoke&fbolas"
	quest.5F00A66CC1FE1F9F.quest_desc: ["Sinceramente, a única parte difícil desta receita é a Asa de Morcego, quantas vezes você mata Morcegos, e muito menos os cria? \\n\\nEsta é bem nova e não combina com Armadura, é usada apenas para o fim de jogo!"]
	quest.5F078A574A783B02.quest_desc: ["O primeiro item que você precisará para iniciar sua Flux Network é um &9Flux Plug&r.\\n\\nO Plug é usado para \"puxar\" energia do bloco ao qual está conectado. Além de um pequeno buffer, o Plug não armazena energia por si só, então não se preocupe em ele consumir toda a sua energia.\\n\\nSugere-se colocar o Plug em um bloco de armazenamento de energia como um Cubo de Energia. Ele pode se conectar a Cabos, Canos ou à saída de qualquer máquina produtora de energia.\\n\\nPara aprender como configurar sua primeira rede, confira a próxima missão!"]
	quest.5F078A574A783B02.quest_subtitle: "Apenas conecte!"
	quest.5F078A574A783B02.title: "Iniciando sua Rede"
	quest.5F080CFA1DC7F435.quest_subtitle: "Invocada usando um Ninho de Areia das Almas no Nether."
	quest.5F080CFA1DC7F435.title: "&fAbelha Fantasmagórica"
	quest.5F1218CF8EFC607B.quest_desc: [
		"&c&lLaserIO&r é a continuação do DireWolf da &lLogística&r do &a&lEnderIO&r."
		""
		"É tudo sobre mover itens via &cLasers&r! Quem não ama &cLasers&r?!"
		""
		"E tudo começa com o Chip Lógico."
	]
	quest.5F1218CF8EFC607B.title: "&c&lLaser IO"
	quest.5F1784E562C29B66.quest_desc: ["Crie um &5Ninho de Pedra do End&r e vá para o End para capturar uma dessas abelhas!"]
	quest.5F1784E562C29B66.quest_subtitle: "Ideal pra quem curte uma vibe... sem fim."
	quest.5F1784E562C29B66.title: "&fAbelha do &eEnd"
	quest.5F2AB0F9166A6AD5.quest_desc: [
		"Sem Aumento de Nível."
		""
		"O Item de Assinatura é um Diamante."
	]
	quest.5F2AB0F9166A6AD5.title: "&6Sucessora Maxima"
	quest.5F458D79D43D8842.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.5F4AA7E7D050C327.quest_subtitle: "White Poplar + Ceylon Ebony"
	quest.5F4F7637044BD4F1.quest_desc: [
		"O &2&lFermentador&r armazenará seus &eItens&r de Comida e, após um tempo, os transformará em Etanol. \\n\\nHá uma lista de Itens, que você pode encontrar no &6Manual do Engenheiro&r, de &eItens&r que podem ser colocados no &2&lFermentador&r pelas Portas na parte de Trás e no lado Esquerdo. \\n\\nSe você usar &6Garrafas de Mel&r, poderá &6Extrair&r as Garrafas pela Porta no lado Direito. \\n\\nO &2&lFermentador&r precisará de &cEnergia&r que virá de uma Porta no Topo do &2&lFermentador&r!"
		"{@pagebreak}"
		"Começo bem simples, faça um 'n' invertido com &8Andaimes de Aço&r e dentro dele coloque &bCanos de Fluido&r e no canto coloque um &eBloco de Engenharia Leve&r."
		"{image:atm:textures/questpics/immersive/immersive_fermenter1.png width:100 height:100 align:center}"
		"Acima do &eBloco de Engenharia Leve&r coloque outro. À direita dele, pule um Bloco, e coloque um &4Bloco de Engenharia de Redstone&r. À esquerda do &eBloco de Engenharia Leve&r colocaremos um 2x2 de Caldeirões."
		"{image:atm:textures/questpics/immersive/immersive_fermenter2.png width:100 height:100 align:center}"
		"Outro passo simples, apenas coloque &7Chapas de Ferro&r acima de todos os Caldeirões!"
		"{image:atm:textures/questpics/immersive/immersive_fermenter3.png width:100 height:100 align:center}"
		"Clique com o Botão Direito no Caldeirão entre o &eBloco de Engenharia Leve&r e o &4Bloco de Engenharia de Redstone&r com um &6Martelo&r."
		"{image:atm:textures/questpics/immersive/immersive_fermenter.png width:100 height:100 align:center}"
	]
	quest.5F4F7637044BD4F1.title: "&l&2Fermentador"
	quest.5F5120451BA5B2FE.quest_desc: ["Máquinas avançadas têm as mesmas capacidades de suas variantes simples, com a adição de área de trabalho configurável, mais slots de filtro e a necessidade de energia."]
	quest.5F56892CD904C40F.quest_desc: ["O quinto e último Tier padrão de Componente de Armazenamento do AE2, fornecendo &e262144&f bytes de armazenamento."]
	quest.5F56892CD904C40F.quest_subtitle: "x4^4"
	quest.5F56892CD904C40F.title: "&eComponente de Armazenamento de 256k"
	quest.5F5E43B3F51CAE9E.quest_desc: ["'Eles são magicamente deliciosos!' \\n\\nO &aChapéu Supersticioso&r concede a você um nível extra de Pilhagem para os Mobs que você matar! \\n\\nEle acumula com Encantamentos!"]
	quest.5F5E43B3F51CAE9E.quest_subtitle: "Cabeça"
	quest.5F5E43B3F51CAE9E.title: "&aChapéu Supersticioso"
	quest.5F6152CF085D75D6.title: "Reator (Básico)"
	quest.5F6ACDE014A61F46.quest_desc: ["Buffs:\\n\\n - Absorção II (3:00)\\n - Velocidade II (3:00)\\n - Resistência II (3:00)"]
	quest.5F6ACDE014A61F46.title: "&cMaçã de Tertium"
	quest.5F72C0C82F3C0310.quest_subtitle: "Nível: &c5"
	quest.5F7F753FD72BFBBF.quest_desc: ["Mais blocos adicionados por &l&7Railcraft&r? Estou começando a duvidar se é mesmo sobre Trens!"]
	quest.5F7F753FD72BFBBF.title: "Blocos Coloridos do &l&7Railcraft&r"
	quest.5F834F8C607A8B77.quest_desc: ["Você tem que encontrá-los em estruturas na &6&lBumblezone&r ou pode trocar com a &5Rainha Abelha&r para obter um! \\n\\nEnquanto o estiver usando, você pode segurar a Barra de Espaço para voar um pouco. \\n\\nExceto que, como uma &6A&8b&6e&8l&6h&8a&r, as Asas são muito pequenas para manter seu corpinho gordo fora do chão."]
	quest.5F8363EC8F4499B6.quest_desc: ["A &#25AFF5Fundição&r é uma máquina com aparência muito sofisticada. Tudo o que ela faz é aquecer o material e &cuni-los&r. Este será um passo importante para o seu progresso."]
	quest.5F8363EC8F4499B6.quest_subtitle: "Fazendo ligas"
	quest.5FA9BC0D8476D322.quest_desc: ["Alimenta você automaticamente com a comida na Mochila."]
	quest.5FB29F3F4DF17765.quest_desc: ["Às vezes você não quer que todos os Módulos movam várias pilhas de uma vez, então quando você quer que apenas 1 Módulo faça isso, use um Aumento! Isso não acumula com Upgrades, na verdade, os substitui."]
	quest.5FBA199E0B7F1585.quest_desc: ["O &9Octohost&r é na verdade 2 Mobs trabalhando juntos! Para te matar! \\n\\nEle possui o &9Symbiocto&r que controla o &9Afogado Hospedeiro&r. \\n\\nO &9Symbiocto&r tem 8 &4Corações&r e nenhuma Armadura. Quando está sozinho, ele apenas atira &0Tinta&r em você. Ao morrer, ele soltará &0Sacos de Tinta&r. \\n\\nO &9Afogado Hospedeiro&r age como um &9Afogado&r normal. Eles têm 10 &4Corações&r assim como 2 Pontos de Armadura. O &9Afogado Hospedeiro&r pode nascer com Armaduras e Armas que pode usar. \\n\\nQuando juntos, eles irão usar seus Ataques contra você ao mesmo tempo. O &9Symbiocto&r irá te atacar com &0Tinta&r enquanto o &9Afogado Hospedeiro&r usará Armas ou Punhos para te atingir."]
	quest.5FBA199E0B7F1585.title: "&9Octohost"
	quest.5FC88C5D97FFE44E.quest_desc: ["Se você está jogando com amigos, pode usar R neles para iniciar Batalhas e &3Trocar &cPokémon&r! \\n\\nVocê pode precisar mudar esse Atalho de Tecla se ele entrar em conflito. \\n\\nAlguns &cPokémon&r irão &bEvoluir&r depois de serem &3Trocados&r com outra pessoa. \\n\\nNão tem amigos? Quer dizer, não joga em Servidores? Então, não se preocupe, nós temos o &3Link Cable&r! \\n\\nUse este Item em um &cPokémon&r para \"&3Trocá-los&r\", o que os fará &bEvoluir&r!"]
	quest.5FC88C5D97FFE44E.title: "&bEvoluindo &fatravés da &3Troca"
	quest.5FC92F3794004A98.quest_subtitle: "Rippling Willow + Soul Tree"
	quest.5FCA6F5FE97780B7.quest_desc: [
		"&eGronglets&r são tecnicamente Blocos, não Mobs. Mas eu os amo demais para não incluí-los! \\n\\nEles aparecem em Árvores Grongle e emitem Ruído e Luz! Definitivamente perfeitos para decoração."
		"{image:atm:textures/questpics/undergarden/undergarden_gronglet.png width:100 height:100 align:center}"
	]
	quest.5FCA6F5FE97780B7.title: "&eGronglets&r"
	quest.5FD6A738754F6013.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.5FD88ED4937971D7.quest_subtitle: "Tuscarora Crepe Myrtle + Luck"
	quest.5FD88ED4937971D7.title: "Muda de Moonlight Magic Crepe Myrtle"
	quest.5FE507DAEE770507.quest_desc: ["Você não quer um &9Marido Triturador&r para &bGiz Azul Claro&r? Então você pode optar por um &aDjinni Triturador&r em vez disso. &aO Chamado de Ophyx&r é usado para invocar &aDjinnis&r. Isso inclui uma Esposa/Marido Demoníaco. &aDjinnis&r são capazes de Triturar minérios de forma mais eficiente que Foliots, mas não tão eficientemente quanto &cAfrits&r ou &9Marids&r. Eles também são capazes de triturar gelo sem derretê-lo."]
	quest.5FE507DAEE770507.quest_subtitle: "Um caminho alternativo para o azul claro"
	quest.5FE507DAEE770507.title: "&aChamado de Ophyx"
	quest.5FE631066CAB7397.quest_desc: ["Usado para prender e transportar mobs facilmente."]
	quest.6013C6B2E0B81D73.quest_desc: [
		"Do lado de fora das &6&lParedes da Colmeia&r e &6&lPilares&r você encontrará o que eu chamo de &6Creches-de-Abelhas&r.\\n\\nAqui haverá &6Blocos de Mel&r e Blocos de Cria de Favo de Mel! Estes aparecem com bebês &6A&8b&6e&8l&6h&8a&r em algum estágio dentro deles.\\n\\nVocê pode alimentá-los com: Garrafas de &bÁgua com Açúcar&r, &6Garrafas de Mel&r, ou Pão de Abelha. Tem 4 Estágios e após o 4º ser alimentado, um Bebê &6A&8b&6e&8l&6h&8a&r aparecerá. Às vezes &6Slimes de Mel&r também aparecerão!\\n\\nVocê pode levar o Bloco de Cria Vazio para a &5Rainha Abelha&r para reabastecê-lo!\\n\\nQuando você os alimenta o suficiente, você obterá a Proteção da Colmeia. Se você os remover, obterá a Ira da Colmeia.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_daycare.png width:200 height:100 align:center}"
	]
	quest.6013C6B2E0B81D73.title: "&6Creches"
	quest.601C719C8FD513F0.quest_desc: ["3 &cBarras de Netherita&r, 3 Amplificador de Alcance Sem Fio e um monte de &2chiques &eEngrenagens&r podemos obter um Amplificador de Alcance Infinito! \\n\\nA parte mais confusa são as Engrenagens. Não podemos fazer as Barras diretamente, precisamos misturar Pós e depois Fundir o resultado para obter as Barras.\\n\\nIsso não funciona entre Dimensões, desculpe!"]
	quest.60244F26B9ABED49.title: "&aParte de Armazenamento de Fluido de 1024B"
	quest.602A6CF9D5B66AD3.quest_desc: ["O &5&lCristalizador Químico&r é na verdade uma Máquina bem simples! Só precisamos de um &cQuímico &fe &aEnergia&r! \\n\\nE sim, este não é usado apenas para &lProcessamento de Minério&r! Bem, parte dele é... mas não tudo. \\n\\nBasta jogar um pouco de &7Lama de Minério Limpa&r no &5&lCristalizador&r e ele a transformará em &7Cristais de Minério&r. \\n\\nVocê também pode alimentá-lo com &dAntimatéria&r para fazer &dPastilhas de Antimatéria&r, ou &6Lítio&r para fazer &6Pó de Lítio&r!"]
	quest.602A6CF9D5B66AD3.title: "&5&lCristalizador Químico"
	quest.602C3E88D96F8843.quest_desc: ["Coloque um PCB Vazio Carregado no Tanque de Gravação com um pouco de Ácido de Gravação e um pouco de calor e você obterá um &3PCB Não Montado&r."]
	quest.602C3E88D96F8843.quest_subtitle: "Quase lá!"
	quest.6033ABA2088BA70C.quest_subtitle: "Sem Deriva de Voo"
	quest.603BEDD49070ECAD.quest_desc: ["&bCondensando&r é transformar de &bLíquido &fpara &cGás&r. &cDescondensando&r é transformar &cGás &fpara &bLíquido&r. \\n\\nO &c&lCondensentrador &bRotativo&r faz ambos! \\n\\nO &cGás&r entrará na Barra da Esquerda. Eles podem ser adicionados por &cTubos &fou &cTanques Químicos&r que você coloca nos Slots da Esquerda. \\n\\nOs &bLíquidos&r entrarão na Barra da Direita. Eles também podem ser adicionados com &bCanos &fou &bTanques de Fluido&r colocados nos Slots da Direita. \\n\\nQuando energizado, o &cGás&r se tornará &bLíquido&r, e o &bLíquido&r se transformará em &cGás&r. Eles trocarão de Barras e poderão ser retirados com &cTubos&f/&bCanos&r ou &cTanques Químicos&f/&bFluido&r."]
	quest.603BEDD49070ECAD.title: "&c&lCondensentrador &bRotativo"
	quest.604C003EE6B1CC6B.quest_subtitle: "Igual ao do vapor"
	quest.604C003EE6B1CC6B.title: "&5Máquina de Corte Elétrica"
	quest.605A5AC65BC7E864.quest_desc: ["O Pescador Marinho pode pescar automaticamente. Pode pegar peixes, tesouros, livros encantados e algumas outras coisas. Não pode pegar abelhas, no entanto, você terá que pescar manualmente para isso.\\n\\nDeve ser colocado acima de uma piscina de &9Água&r 3x3 (ou maior)."]
	quest.6063F4B7BE4D394C.quest_desc: ["Os Sender Modules moverão Itens no Slot de Buffer do Roteador para outro Inventário. \\n\\nO MK1 moverá apenas itens para Inventários no mesmo eixo XYZ do Roteador e com linha de visão direta. Se houver um bloco no caminho, o Remetente MK1 não enviará."]
	quest.60721C9B94B36C24.quest_desc: [
		"As &3Centopeias de Sculk&r são Mobs neutros e longos que aparecem no &3&lOutro Lado&r. \\n\\nElas têm 10 &4Corações&r e atacarão em grupo se Atingidas, como Lobos. \\n\\nElas dropam apenas &aXP&r e talvez Linha, então é melhor deixá-las em paz!"
		"{image:atm:textures/questpics/deepndark/dnd_centipede.png width:100 height:100 align:center}"
	]
	quest.60721C9B94B36C24.title: "&3Centopeia de Sculk"
	quest.607337D8AA20FA18.quest_desc: ["Todas as Árvores conectadas ao que é cortado, vêm junto."]
	quest.607337D8AA20FA18.title: "Lenhador de Árvores Wyvern"
	quest.6076D1DB438EB997.quest_desc: ["Receita muito simples, precisando apenas de &7Carvão&r, &cPó de Blaze&r e um &bBloco de Cristal Arcano&r. \\n\\n&7Carvão&r e &bCristal Arcano&r podem ser obtidos via Pedreiras, &6&lAbelhas&r ou &2&lMA&r. \\n\\n&cPó de Blaze&r pode ser obtido dos dois últimos Mods mencionados, ou de Fazendas e &b&lHNN&r. Existem muitas maneiras de obter &cPó de Blaze&r."]
	quest.6076D1DB438EB997.title: "&cPrisma de Fundição"
	quest.607D9B53C632DEDE.quest_desc: ["As &bVálvulas de Cano&r ajudam a classificar e parar o fluxo de &bFluido&r! \\n\\nQuando usadas com &bCanos de Fluido&r, elas farão com que o &bFluido&r vá apenas na direção das setas na &bVálvula de Cano&r. \\n\\nVocê também pode enviar um &4Sinal de Redstone&r para ela, o que interromperá completamente o fluxo de &bFluido&r!"]
	quest.607D9B53C632DEDE.title: "&bVálvula de Cano"
	quest.607E5EBE3696CC26.quest_desc: ["Não mudará seu Limite de Nível. \\n\\nSeu Item de Assinatura é um &eGirassol&r."]
	quest.607E5EBE3696CC26.title: "&aLíder de Ginásio Gardenia"
	quest.60850E717C747A78.quest_desc: ["Você já passou 3 meses estudando &oCódigo Galáctico&r para finalmente entender a linguagem da &5Mesa de Encantamento&r só para descobrir que era um monte de besteira? \\n\\nNão? \\n\\nEu também não, mas as &9Pistas de Encantamento&r são seu tradutor real para isso! \\n\\nCada &9Pista de Encantamento&r lhe dirá 1 &5Encantamento&r antes de você realmente usá-lo."]
	quest.60850E717C747A78.title: "&3Pistas de Encantamento"
	quest.6092335560810B6F.quest_desc: ["Agora estamos na &3Elite dos Quatro&r! Assim que derrotarmos esses caras, poderemos enfrentar a &5Campeã&r! \\n\\nO primeiro aumentará seu Limite de Nível para 59. \\n\\nSeu Item de Assinatura é o &3Pó de Prata&r."]
	quest.6092335560810B6F.title: "&3Elite dos Quatro Aaron"
	quest.6092490EC9008A05.quest_desc: ["O &4Destruidor&r é uma interface que quebrará automaticamente o bloco ao qual está conectado.\\n\\nVocê também pode configurá-lo para uma lista de permissão de blocos, o que é útil para automatizar certos processos, como fazer Casings no &6Create.&r"]
	quest.6092490EC9008A05.quest_subtitle: "Quebrando Blocos!"
	quest.609CA1ACFA981BD5.quest_desc: ["O &cKit de Roteamento&r é usado com os bilhetes de passagem."]
	quest.609CA1ACFA981BD5.title: "Roteamento do &cKit de Trilhos&r"
	quest.609D03E335CF32E2.quest_subtitle: "Nível: &d6"
	quest.60A4994078500F63.quest_desc: ["Celestigem é um novo material adicionado pelo JDT. A Celestigem é adquirida realizando a Propagação de Gosma em Blocos de Diamante usando gosma de nível três ou superior. O Minério de Celestigem é afetado por fortuna."]
	quest.60B52705049D1BA5.quest_desc: ["O &a&lLavadora Química&r é apenas para &7Processamento de Minério&r. \\n\\nComo o &9&lSeparador Eletrolítico&r, este só funciona com &cQuímicos&f/&bFluidos&r! \\n\\n&9Água&r (ou substituto da &9Água&r) irá na Barra da Esquerda! E a Lama de Minério irá na Barra ao lado. \\n\\nQuando recebe &aEnergia&r, o &a&lLavadora Química&r tornará a Lama Suja, Limpa! \\n\\nComo uma Máquina de Lavar!"]
	quest.60B52705049D1BA5.title: "&a&lLavadora Química"
	quest.60B985069E0E643E.quest_subtitle: "Magmática + Suor"
	quest.60B985069E0E643E.title: "&fAbelha Obsidiana"
	quest.60C27206F1414DD6.quest_desc: ["Graças a Newton, sabemos que para toda ação há uma reação igual e oposta. Basicamente, quando uma Flecha atinge um mob, a força do Mob se aplica à Flecha, o que a retardará. A menos que você tenha este Módulo. Ele não age como se todo mob fosse de papel, ele age como se todo mob não estivesse no caminho. As Flechas não desacelerarão após Perfurar um alvo."]
	quest.60C27206F1414DD6.title: "Módulo de Cancelamento de Imunidade de Projétil"
	quest.60C7BBFC8CA911FF.quest_desc: [
		"Sem aumento de nível."
		""
		"Encontrado no 2º andar da &cLiga Kanto&r."
	]
	quest.60C7BBFC8CA911FF.title: "&3Elite dos Quatro Bruno"
	quest.60CECAAE2D43EC6E.quest_desc: [" Nas profundezas dos lugares fraturados do &eEnd&r, onde o próprio tempo se quebrou uma vez, uma relíquia estranha pode ser encontrada... o &5Coágulo do Tempo&r. \\n\\n Este &6fragmento misterioso&r guarda ecos de momentos passados, permitindo que seu portador &6refaça&r seus &6passos&r como se estivesse reescrevendo o que acabou de acontecer. \\n\\n- &lPossui 1 habilidade:&r \\n\\n &dTransgressão&r: \\n Ao &6segurar&r a &6tecla&r de uso, você começa a rebobinar seu movimento através do tempo, &6retornando&r pelo seu &6caminho recente&r por alguns &6segundos&r. Quando o rebobinamento termina, a habilidade entra em &6tempo de recarga&r igual à &6duração&r em que foi &6usada&r. \\n\\n- Uma &6relíquia&r que desafia o próprio &dtempo&r... para aqueles rápidos o suficiente para reescrever seus próprios &5erros&r."]
	quest.60CECAAE2D43EC6E.quest_subtitle: "Alguns erros... não precisam ser permanentes."
	quest.60CECAAE2D43EC6E.title: "&5Coágulo do Tempo&r"
	quest.60D9F04E91171D16.quest_desc: ["Isso pode atuar como um Baú para suas Variáveis, ou pode ser realmente usado em uma rede avançada.\\n\\nSe você quiser redes avançadas, certifique-se de ler sobre elas na &eDinâmica da Integração&r."]
	quest.60ECCCAB66AAC05D.quest_desc: ["Os &eTransportadores Logísticos&r moverão &eItens&f e &eBlocos&r de um Inventário para outro! \\n\\nPara mover &eItens&r para &5Máquinas&r, no entanto, precisaremos alterar as Configurações dentro da &5Máquina&r. Elas estão no canto superior esquerdo da INTERFACE da &5Máquina&r, em Configurações de Lado. Elas precisarão ser configuradas para Ejeção Automática para Saída de &eItens&r. \\n\\nOs &eTransportadores Logísticos&r são criados com 2 &8Barras de Aço&r e 1 &aCircuito de Controle Básico&r. Você pode então combinar 8 &eTransportadores Logísticos&r com o próximo Circuito de Controle para atualizá-los. \\n\\n&a&lBásico&r: moverá 2 Blocos/Itens por 1 Bloco a cada Segundo. \\n\\n&c&lAvançado&r: moverá 32 Blocos/Itens por 2 Blocos a cada Segundo. \\n\\n&b&lElite&r: moverá uma pilha de Itens ou Blocos por 4 Blocos a cada Segundo. \\n\\n&d&lUltimate&r: moverá 2 pilhas de Itens ou Blocos por 10 Blocos a cada Segundo."]
	quest.60ECCCAB66AAC05D.quest_subtitle: "Itens"
	quest.60ECCCAB66AAC05D.title: "&eTransportadores Logísticos"
	quest.60FDCA2FDFE74056.quest_desc: [
		"É ROSA! \\n\\nAqui você encontrará Árvores Escarlates com suas folhas caídas empilhadas abaixo delas. Você também pode encontrar Cogumelos Luminosos aqui!"
		"{image:atm:textures/questpics/eternal/starlight_scarlet.png width:200 height:100 align:center}"
	]
	quest.60FDCA2FDFE74056.title: "Floresta Escarlate"
	quest.6106D2F6CEFFFC82.quest_desc: ["Ela aumentará seu Limite de Nível para 43. \\n\\nSeu Item de Assinatura é a &bPedra de Gelo&r."]
	quest.6106D2F6CEFFFC82.title: "&aLíder de Ginásio Candice"
	quest.6112956E19017D2D.quest_desc: ["Cabos Lógicos são diferentes de outros &e&lPipez&r ou &5&lcanos Meka&r. Os outros Canos agem como funis, os itens se movem de 1 Inventário, para dentro do Cano, e então para o 2º Inventário. Cabos Lógicos simplesmente pulam o intermediário, o que também pula muito lag. \\n\\nEles são apenas para conectar Importadores e Interfaces."]
	quest.61213012615619C5.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Defuma automaticamente os itens derrubados por abates."
	]
	quest.612157986673F815.quest_desc: ["Alimente &8A&6b&8e&6l&8h&6a&8s&r ou uma &8A&6b&8e&8l&6h&8a&r com qualquer coisa exceto &dFlores&r 48 vezes!"]
	quest.61217D80BFF8A858.quest_desc: ["O terceiro e último nível de &5Chumbo Ender&r chegou! Este é inquebrável e pode até vincular mobs aos Geradores de mobs. Vai exigir uma configuração de &d&lInfusão&r consideravelmente mais complicada. Precisaremos de pelo menos &a75 Eterna&r, &c85% Quanta&r, e entre &560-85% Arcana&r.\\n\\nVocê pode obter isso com 4 &9Estantes de Livro de Sculk Tocado pela Alma&r, 4 &9Estantes de Livro de Sculk Ecoantes&r, 2 &7Estantes de Livro de Pedra&r, e 2x Estante de Livros vanilla. Ah, e também precisa de uma Bruxa no Chumbo Ender usado para esta &d&lInfusão&r."]
	quest.61217D80BFF8A858.quest_subtitle: "Nada a ver com Occultism, juro"
	quest.61217D80BFF8A858.title: "&5Chumbo Ender Oculto"
	quest.6124C0E9E419694B.quest_desc: ["Atualize as Ferramentas de &7Cloggrum&r com &aBarras Esquecidas&r e um Modelo de Ferraria. \\n\\nEstas são as melhores Ferramentas que você pode obter, elas já vêm com Eficiência para Blocos do &2&lUndergarden&r. \\n\\nE a Espada e o Machado causarão mais dano a todos os Mobs do &2&lUndergarden&r, exceto à &cBesta Pútrida&r e ao &aGuardião Esquecido&r!"]
	quest.6124C0E9E419694B.title: "Ferramentas &aEsquecidas&r"
	quest.6134991F25B25B42.quest_desc: ["&lMontadores&r não apenas permitem que você fabrique &aitens mais novos&r, mas também melhoram o rendimento de alguns outros itens."]
	quest.6134991F25B25B42.quest_subtitle: "Mais que um fabricante"
	quest.6134991F25B25B42.title: "Juntando as coisas"
	quest.613AC4DF39E5621D.quest_desc: [
		"O Aglomerado Gazebuzz é um aglomerado de dezenas e dezenas de salas suspensas e desconectadas. \\n\\nEu não poderia listar tudo nas salas ou estaria digitando o dia todo! Mas posso resumir: há salas com &6Mel&r, Folhas, Saque e até armadilhas divertidas! \\n\\nVocê provavelmente deveria ter cuidado com elas, especialmente com &6Mel&r e Pinturas..."
		"{image:atm:textures/questpics/bumblezone/bumble_cluster.png width:200 height:100 align:center}"
	]
	quest.613AC4DF39E5621D.title: "Aglomerado Gazebuzz"
	quest.6140EAA6E042EF7C.quest_desc: ["O &6&lSkyhook&r funciona tanto como uma Ferramenta quanto como uma Arma. \\n\\nVocê pode simplesmente acertar Mobs com ele como se fosse uma Espada ou pode usá-lo para se locomover pela sua base! \\n\\nQuando você se aproxima de um &cFio&r (&6BT&r, &eMT&r, &5AT&r, Isolado, Cânhamo, &8Aço&r, &4Redstone&r), você pode Segurar o Botão Direito para se prender a eles. Então, você pode se mover para deslizar pelos &cFios&r! \\n\\nSe quiser usá-lo em &cFios&r ativos, você precisará de alguns Upgrades! Upgrades como: Motor de Alto Torque, Pega Isolada e Ganchos de Impacto Pesado. \\n\\nEle pode conter 2 Upgrades."]
	quest.6140EAA6E042EF7C.quest_subtitle: "Booker, pegue!"
	quest.6140EAA6E042EF7C.title: "&6&lSkyhook do Engenheiro"
	quest.61419D230687CBB5.quest_desc: ["Velocidade é a rapidez de um item em uma certa direção. Como nossas Flechas não são dos Guardiões da Galáxia, basicamente significa apenas a Velocidade de uma Flecha. A cada aprimoramento, leva menos tempo para a Flecha ir do seu Arco para o seu Alvo. Vem com o custo de um pouco de imprecisão."]
	quest.61419D230687CBB5.title: "Módulo de Velocidade de Projétil Wyvern"
	quest.6141DE779232C8AA.title: "&l&cRecompensa do Nether:&r&e Blazes"
	quest.6144202A97C6CD1C.quest_desc: ["A &bFacas de Corte de Quartzo&f, como a chave inglesa, vem nas versões de quartzo do nether e certus e é uma ferramenta de criação útil para se ter à mão.\\n\\nCabos também podem ser separados sem a necessidade de serem coloridos, anexando uma &bCable Anchor&f entre eles, criada com esta faca e fabricável até 50 vezes com a mesma faca antes que ela quebre.\\n\\nÂncoras de Cabo também podem ser usadas para criar &bCable Facades&f, permitindo que você disfarce cabos dentro de paredes, cobrindo-os com a face de um bloco arbitrário. Embora as receitas de fachada estejam ocultas no JEI, você ainda pode criá-las pegando qualquer bloco regular e cercando-o com 4 âncoras de cabo na grade de criação.\\n\\nAlém de criar âncoras, a faca de corte também tem outro uso: clicar com o botão direito com a faca abrirá uma pequena INTERFACE que permite criar &bPrensas de Nome para Gravador&f. Quando recebem um nome, essas prensas podem ser usadas dentro de um Gravador para renomear qualquer item de entrada com o nome da prensa. Duas dessas prensas podem ser concatenadas no gravador para renomear o item para o nome da prensa de cima, seguido pela de baixo."]
	quest.6144202A97C6CD1C.quest_subtitle: "Sob a faca"
	quest.6144202A97C6CD1C.title: "Cable Anchor"
	quest.614937A2F5823F3E.quest_subtitle: "Invocada usando um Nether Brick Nest"
	quest.614937A2F5823F3E.title: "&fAbelha Magmática"
	quest.61500C8F68509E5D.quest_desc: [
		"Na sua primeira visita aos &d&lPrados Florais&r, você pode nem notar esses amiguinhos escondidos na Grama. \\n\\nRootmins fingem ser Blocos de Grama com &dFlores&r na cabeça. \\n\\nSe você não estiver usando Armadura de Abelha, eles podem atirar Pellets de Terra em você quando passar. \\n\\nVocê pode trocar a &dFlor&r na cabeça deles Clicando com o Botão Direito com uma diferente!"
		"{image:atm:textures/questpics/bumblezone/bumble_rootmin2.png width:100 height:150 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_rootmin1.png width:100 height:100 align:center}"
	]
	quest.61500C8F68509E5D.title: "Rootmin"
	quest.615B9062FE8CCD36.quest_desc: ["Troca automaticamente para a ferramenta mais eficaz para o bloco que você está olhando."]
	quest.616364E6AE05C341.quest_desc: ["&bSais Minerais&r são feitos de... bem, Minerais. \\n\\nQualquer coisa minerada em alguma forma de Minério pode ser transformada em &bSal&r. Minérios Brutos, Barras, Gemas, todos se tornam &bSal Mineral&r! \\n\\nAté mesmo Unobtainium pode ser transformado em &bSal&r! Apenas, por favor, não faça isso, há tantas alternativas melhores."]
	quest.616364E6AE05C341.title: "&bSal Mineral"
	quest.616AE66BE7812E09.quest_desc: ["Existem muuuuuitos Mods diferentes para explorar! \\n\\nDesde aqueles no &2&lMundo Superior&r como Repurposed Structures até o &4&lCataclysm&r. \\nHá ainda mais em suas próprias Dimensões, como &9&lTwilight Forest&r, &2&lUndergarden&r, &6&lBumblezone&r e &5&lEternal Starlight&r. \\n\\nTodos esses Mods requerem a coleta de novos Blocos, luta contra Criaturas únicas e a melhor parte são as armas incríveis!"]
	quest.616AE66BE7812E09.title: "Exploração"
	quest.616B6046EF5DDF21.quest_desc: ["O Importador Elite tem 18 espaços para filtros e funciona 2x mais rápido."]
	quest.616CFD4078D67B51.quest_desc: ["Esteiras são outra maneira de transportar coisas. Elas funcionam com itens, entidades e até fluidos. Elas podem interagir com o mundo com Melhorias de Esteira.\\n\\nVocê pode melhorar as esteiras com Pedra Luminosa para torná-las mais rápidas, e com Plástico para impedir que peguem itens. "]
	quest.616F9B78B16B42A5.quest_desc: ["A receita para a &6Bobina de Tesla&r pode parecer complicada, especialmente em uma árvore de receitas, mas podemos simplificá-la!\\n\\nAs &7Chapas de Alumínio&r são muito simples, precisando apenas usar um Martelo em Barras ou na Prensa de Metal Multibloco.\\n\\nO &8Componente Mecânico de Ferro&r também é simples, apenas algumas Chapa de Ferro e um &6Barra de Cobre&r.\\n\\nO &eBloco de Bobina de Electro&r precisará de um monte de &eBarras de Electro&r cortados em Fios. &eElectrum&r é uma liga de &eOuro&r e Prata.\\n\\nO &6Componente Eletrônico Avançado&r é um conjunto completo de uso da Bancada de Engenheiro e &9Plantas&r. Sua Folha de Duroplast requer muita refinação e fermentação com Máquinas Multibloco!\\n\\nO último item, o &cAcumulador de AT&r, precisa de alguns itens simples como &8Aço&r, &7Chapa de Alumínio&r, &cÁcido de Redstone&r e &4Madeira Tratada&r. Ele também precisa de um item mais complicado chamado &8Barra de Grafite HOP&r."]
	quest.616F9B78B16B42A5.title: "&6Bobina de Tesla"
	quest.61768CFEDA041E4D.quest_desc: ["Depois de entrar na &6&lBumblezone&r, você pode precisar retornar ao &2Mundo Superior&r. Caso você tenha deixado seu fogão ligado! \\n\\nPara sair da &6&lBumblezone&r, você pode minerar para baixo ou para cima, passando pela &eCera de Abelha da Colmeia&r, para entrar no Vazio. \\n\\nEste Vazio não irá matá-lo, em vez disso, ele irá teleportá-lo de volta para onde você estava no &2Mundo Superior&r!"]
	quest.61768CFEDA041E4D.quest_subtitle: "Deixe-me sair daqui!"
	quest.61768CFEDA041E4D.title: "Escapando"
	quest.617695A9CA45D88F.quest_desc: ["Ao usar o &c&lLaserIO&r para &lLogística&r, você pode acabar com MUITOS Cartões. Com cada um ocupando um espaço em seu Inventário, pode ficar bem apertado. Eu gostaria que eles tivessem um armazenamento para Cartões... ah, espere, eles têm, é o Porta-Cartões! \\n\\nVocê pode armazenar vários Cartões nele e quando abrir um Nó de Laser, o Porta-Cartões também se abrirá como um segundo Inventário. Muito útil!"]
	quest.618411DCC5C1A13C.quest_subtitle: "Alimente uma Abelha Radioativa com Pó de Plutônio"
	quest.618411DCC5C1A13C.title: "&fAbelha de Cristal Uranita"
	quest.61847F47CCA225D9.quest_desc: ["Seguindo o mesmo padrão, estas fundem em 140 Ticks ou 7 Segundos.\\n\\nElas podem ser criadas com Fornalhas de &6Cobre&r ou Ferro e podem ser usadas para criar uma &eFornalha de Ouro&r."]
	quest.61847F47CCA225D9.title: "Silver Furnace"
	quest.618F1434757C8E69.quest_desc: ["&lGenerator's Galore&r adiciona Geradores muito simples. Os mais básicos agem como Fornalhas com o &3Aumento&r: Gerador. Eles pegarão Combustível e o transformarão em Energia! \\n \\nSim, você tem que começar com o &6Copper Generator&r."]
	quest.618F1434757C8E69.title: "&6Copper Generator&r"
	quest.61999669BDE127F9.quest_desc: [
		"Se você ainda não percebeu, fazer e refazer rituais repetidamente é muito desgastante para a durabilidade dos seus Gizes."
		""
		"Se você está preocupado com a quebra do seu Giz, mas não quer fazer todo o ritual para criar um novo giz novamente, então este ritual é para você!"
		""
		"Usando o poder de um &aDijinni&r, você pode reparar qualquer cor de Giz até o máximo!"
		""
		"Alternativamente, você poderia usar algo como a &aEternal Stella&r do mod Forbidden Arcanus para preservar permanentemente seus Gizes!"
	]
	quest.61999669BDE127F9.quest_subtitle: "Você quebra, &m_nós_&r Demônios consertamos!"
	quest.61999669BDE127F9.title: "Reparo de Giz"
	quest.61A22707DBC83818.quest_desc: ["O Ponto de Aacesso de armazenamento atua como um Controlador de armazenamento quando vinculado a ele, podendo receber ou enviar itens. Basicamente, um ponto de entrada para as Gavetas."]
	quest.61A8FAEC4FF18449.quest_desc: ["Eles podem ser usados para carregar itens em seu inventário, ou podem ser usados para aumentar a capacidade total de energia de um canal da &7Rede do End&r."]
	quest.61AD2207E770CD7F.quest_desc: ["Permite que você colete itens e experiência de mais longe."]
	quest.61AD2207E770CD7F.quest_subtitle: "Máx: 6"
	quest.61B479079DC1C69C.quest_desc: ["Permite que você pule mais alto do que com o Nível I."]
	quest.61B479079DC1C69C.quest_subtitle: "Máx: 1"
	quest.61BA2932EC86DA2E.quest_desc: ["Permite que você pule MUITO alto."]
	quest.61BA2932EC86DA2E.quest_subtitle: "Máx: 1"
	quest.61BE7882EE0E6FAF.quest_desc: ["O que rola escada abaixo \\nSozinho ou em pares... \\nRola sobre o cachorro do seu vizinho \\nO que é ótimo para um lanche \\nE cabe nas suas costas? \\nÉ Tronco! Tronco! Tronco!"]
	quest.61BE7882EE0E6FAF.title: "&6Troncos"
	quest.61C93ABE07742DCD.quest_desc: [
		"A Turbina a Vapor usa Vapor para gerar energia FE e EU. \\n\\nÉ uma construção de 3x2x2 apenas de Carcaça de Turbina a Vapor, e precisará de um Motor de Turbina dentro dela, e Vapor canalizado para dentro."
		"{image:atm:textures/questpics/railcraft/rail_turbine.png width:100 height:100 align:center}"
	]
	quest.61C93ABE07742DCD.title: "Turbina a Vapor"
	quest.61CC4CEE94D2B612.quest_desc: [
		"Aumento de nível para 34."
		""
		"Item de Assinatura é Lenço de Seda."
	]
	quest.61CC4CEE94D2B612.title: "&6Treinador Brendan"
	quest.61DA3D61D7103647.quest_desc: ["Os &eEnxofres Alquímicos&r podem ser feitos de praticamente qualquer coisa e podem ser transformados em praticamente qualquer coisa! \\n\\nHá alguns grupos diferentes de Itens em &eEnxofres Alquímicos&r, que podem ser mais bem explicados em outra Missão. \\n\\nHá 3 caminhos diferentes que você pode seguir com o processamento de &eEnxofres Alquímicos&r. 1. Fermentação e Digestão para fazer Niter. 2. Incubação para fazer esses Itens novamente e 3. Mudar o Item com Reforma."]
	quest.61DA3D61D7103647.title: "&eEnxofres Alquímicos"
	quest.61DCECE1FC38E151.title: "Reator (Nitro)"
	quest.61F265D9A5713A4D.quest_desc: ["Cada upgrade aprimora tudo, desde a quantidade que produz até o quanto pode armazenar e o que pode transferir para outros blocos! \\n \\nVocê precisará de um &6Copper Generator&r para fazer um Iron Generator, desculpe, odiadores de &6Cobre&r."]
	quest.61F265D9A5713A4D.title: "&fIron Generator"
	quest.62089E9E6D596DA7.quest_desc: ["&3O &bImolador&r é um &3Aniquilador&r aprimorado com um &bLingote de Ignítio&r dentro da &4Bigorna de Fusão Mecânica&r. \\n\\nEstes causam mais dano a Mobs com &bMarca Ardente&r afligida neles, então as &bLuvas Ardentes&r funcionam muito bem com ele! \\n\\nSe você tiver &3O &bImolador&r em cada mão, pode segurar o botão direito para invocar um &bGolpe Flamejante&r sob você. Isso causará dano a todos os Mobs nele e explodirá quando terminar, como uma despedida final!"]
	quest.62089E9E6D596DA7.title: "&3O &bImolador"
	quest.620913A1FF09255F.quest_desc: ["Estas 6 &cPoke&rBolas são arremessadas de uma maneira diferente de qualquer outra &cBola&r. \\n\\nAs &bBolas Pena&f, &bAsa&f e &bJato&r serão arremessadas muito mais longe que a &cPoke&rBola Normal. \\n\\nAs &bBolas Pesada&f, &bChumbo&f e &bGigatônicas&r não são arremessadas tão longe quanto a &cPoké&rBolas Normal. \\n\\nO 1.5x e 2x não são relacionados à distância, mas sim à Chance de Captura do &cPokémon&r!"]
	quest.620913A1FF09255F.title: "&cBolas&r que são arremessadas diferente"
	quest.6214530BEC461C9D.quest_desc: [
		"Agora que você tem &cPokemon&r, você precisa aprender a melhor forma de usá-los! \\n\\nO Padrão é (R) para lançar seu primeiro &cPokemon&r da Equipe para fora de sua &cPoke&rbola. Isso fará com que eles Vagueiem ao seu redor como um Cão Domesticado. \\n\\nEnquanto estiverem fora, eles Atacarão todos os Mobs Hostis e qualquer coisa que Atingir você ou que você Atingir. Mas se eles sofrerem Dano ou Desmaiarem, conta o mesmo como se estivessem em uma Batalha. \\n\\nConfira a próxima Página para ver como mudar e inspecionar sua Equipe."
		"{@pagebreak}"
		"O Botão que você usou para escolher um Inicial é como você pode ver e mudar sua Equipe. \\n\\nNa Esquerda, você verá a Imagem do &cPokemon&r, Nome (que você pode mudar), o Tipo, Gênero e Item Segurado. \\n\\nÀ Direita mostra sua Equipe, você pode Clicar no outro &cPokemon&r para inspecioná-los também. \\n\\nO Meio tem 3 Páginas, cada uma podendo mudar para ver novos Atributos."
		"{@pagebreak}"
		"Primeira Página: Mostra mais Atributos do &cPokemon&r! Yay! \\n\\nEla nos dá o Número da &cPok&fe&cdex&r, Espécie do &cPokemon&r, Tipo do &cPokemon&r novamente, o Dono, sua Habilidade e Descrição, e sua Experiência. "
		"{@pagebreak}"
		"Segunda Página: Nos dá os Golpes que o &cPokemon&r usa em Batalha. \\n\\nToque no Golpe para ver sua Descrição, Poder, Efeito e Precisão na parte inferior. \\n\\nVocê pode usar as setas à esquerda para mudar a ordem dos Golpes. Ou usar o botão à direita para trocar os Golpes."
		"{@pagebreak}"
		"Terceira Página: e última página, é sobre Atributos. Todos os Gráficos mostram a Vida (HP), Ataque (atk), Defesa (def), Velocidade, Defesa Especial (Sp.Def) e Ataque Especial (SP.Atk) do &cPokemon&r. \\n\\nAtributos nos mostram os Atributos atuais que o &cPokemon&r possui. IV são os Atributos com os quais o &cPokemon&r veio, enquanto EV mostra os Atributos que cresceram através de Batalhas ou Itens. \\n\\nOutros nos dá &dAmizade&r e Dynamax. &dAmizade&r é um Atributo muito importante!"
	]
	quest.6214530BEC461C9D.quest_subtitle: "Tenho que Pegar pelo menos um!"
	quest.6214530BEC461C9D.title: "Capture um &cPokemon&r!"
	quest.62161BDE9AAAA4BF.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_wayfinder.png width:100 height:150 align:center}"]
	quest.62161BDE9AAAA4BF.quest_subtitle: "Ruínas da Trilha"
	quest.62161BDE9AAAA4BF.title: "Ornamento de Armadura Wayfinder"
	quest.6220EDE42C813C1B.quest_desc: ["A pior parte sobre os &eAmuletos&r é que eles quebram! Por que esses Efeitos de Poção OP teriam que ter Durabilidade! \\n\\nBem, não se preocupe, &5&lApotheosis&r tem uma cura para isso... com &d&lInfusões&r! \\n\\nVocê precisará de &a100 Eterna&r, entre &c8.5% &fe &c13.5% Quanta&r, e entre &532.5% &fe &537.5% Arcana&r. \\n\\nVocê pode usar 10 &4Estantes Infernais Luminosos&r, 4 &6Estantes de Estabilidade Revestidas de Geodo&r, 2 &dEstantes Dracônicas do End&r e uma Caveira de Esqueleto! \\n\\nSim, algumas Caveiras e outros Itens além de &7Estantes&r dão estatísticas!"]
	quest.6220EDE42C813C1B.title: "&eAmuletos&r Inquebráveis"
	quest.6235B9923BE0AAEB.quest_desc: ["O Encantador é um bloco que permite adicionar encantamentos a itens encantáveis usando itens e essências."]
	quest.6235B9923BE0AAEB.title: "&bEncantador"
	quest.623796B1D7981E59.quest_desc: ["'Experimente também Terraria!'\\n\\nQuando equipado, você ganhará 5 corações extras! Ou 10 pontos inteiros de Vida! Somando um total padrão de 30 de Vida."]
	quest.623796B1D7981E59.quest_subtitle: "Cinto"
	quest.623796B1D7981E59.title: "&4Coração de Cristal&r"
	quest.62527F657474DD91.quest_desc: ["&c&lMinecraft com Mods&r não é barato, você vai precisar de MUITOS Itens. \\n\\nEntão vamos aprender como Cultivar Itens!"]
	quest.62527F657474DD91.title: "&lCultivo de Materiais"
	quest.6255E2FE6DD4084A.quest_subtitle: "Holly + Alder"
	quest.6256612D46C88C0C.quest_desc: [
		"&5Transformadores&r convertem uma faixa de energia em outra."
		""
		"&5Transformadores&r &#EBC471LV&r para &#DDE548MV&r: Converte energia &#EBC471LV&r em energia &#DDE548MV&r, possui 5 entradas e 1 saída."
		""
		"&5Transformadores&r &#DDE548MV&r para &#EBC471LV&r: Converte energia &#DDE548MV&r em energia &#EBC471LV&r, possui 1 entrada e 5 saídas."
	]
	quest.6256612D46C88C0C.quest_subtitle: "\"A liberdade é um direito de todos os seres conscientes.\""
	quest.6256612D46C88C0C.title: "&5Transformadores &eLV&f &5para &eMV"
	quest.6258F26293B9C1C1.quest_desc: ["O que o &9&lCrystalix&r nos dá, você pergunta? \\nEle nos dá Vidro! Todos os tipos diferentes de Vidro! Há o Normal, o Transparente e o com Borda. \\n\\nCom Borda é o padrão de Vidro do &2&lMinecraft&r. Ele tem bordas e pixels perto do canto para que você saiba que é Vidro. Transparente tem as bordas, mas não os pixels perto dos cantos, então o interior é todo transparente. Normal não tem bordas nem pixels, é inteiramente 100% transparente e de uma só cor. \\n\\nCada Vidro do &9&lCrystalix&r tem suas próprias propriedades também: Sem Sombra, Reforçado, Luminoso e Fantasma. \\n\\nSem Sombra afetará como ele reage aos Shaders e até mesmo à iluminação do &2&lMinecraft&r. Reforçado afetará a Resistência a Explosões. Luminoso afetará se ele emite Luz, ignora a Luz ou age como vidro normal, deixando a Luz entrar. Fantasma poderá mudar quem pode atravessar o Vidro, este tem o maior número de configurações."]
	quest.6258F26293B9C1C1.title: "&9&lCrystalix"
	quest.62622137648A4F56.quest_desc: ["Você não odeia ter que Minerar e depois Fundir seus Minérios com dois Itens diferentes? Bem, agora você pode ser mais preguiçoso do que nunca com o &7Aquecedor de Picareta&r!\\n\\nEnquanto estiver usando o &7Aquecedor de Picareta&r, os Minérios que você minerou serão automaticamente Fundidos!\\n\\Pode ser bom ter cuidado com isso se você quiser Processamento de Minério."]
	quest.62622137648A4F56.quest_subtitle: "Mãos"
	quest.62622137648A4F56.title: "&7Aquecedor de Picareta&r"
	quest.6263A27182B2CE3D.quest_desc: ["Algumas &5Máquinas&r são um pouco mais avançadas, o que significa que precisaremos de mais &cItens Avançados&r para criá-las! \\n\\nFalando em &c&lAvançado&r, elas usam os mesmos Materiais que as &5Máquinas&r de &c&lNível Avançado&r."]
	quest.6263A27182B2CE3D.quest_subtitle: "Realmente são melhores!"
	quest.6263A27182B2CE3D.title: "&5Máquinas&r Melhores"
	quest.6280748583C62E05.quest_subtitle: "Red Maple + Jungle"
	quest.62827AA1AD29A222.quest_desc: ["Os &aCabos Universais&r são usados para mover &aEnergia&r de &5Máquina &fpara &5Máquina&r! \\n\\nA maioria das &5Máquinas&r terá um lado padrão para receber &aEnergia&r, notificado pelo &aQuadrado Verde&r nelas. Isso pode ser alterado na INTERFACE da &5Máquina&r, nas Configurações de Lado. \\n\\nAs &5Máquinas&r também compartilharão a &aEnergia&r que têm com outras &5Máquinas&r próximas, se suas Configurações estiverem definidas para isso!\\n\\nOs &aCabos Universais&r são feitos com 2 &8Barras de Aço&r e um &4Pó de Redstone&r. Eles podem ser aprimorados combinando 8 do mesmo &5Tier&r com um &aCircuito de Controle&r! \\n\\n&a&lBásico&r: armazenará e moverá 3.2kFE por Tick. \\n\\n&c&lAvançado&r: armazenará e moverá 51.2kFE por Tick. \\n\\n&b&lElite&r: armazenará e moverá 409.6kFE por Tick. \\n\\n&d&lUltimate&r: armazenará e moverá 3.27mFE por Tick."]
	quest.62827AA1AD29A222.title: "&aCabos Universais"
	quest.62991D7431A48F6D.quest_subtitle: "Banana + Kapok"
	quest.62B29AEF8468750E.quest_desc: ["Espere, então nós recebemos menos &mDano&r &aEnergia&r de &6Fontes de Calor&r e ainda criamos &aEnergia&r com elas? Tô dentro! \\n\\nQuando você andar sobre &6Blocos de Magma&f, através do &6Fogo&f, ou na &6Lava&r, você ganhará &aEnergia&r em suas &a&lCalças do Meka-Traje&r. \\n\\nSe você tiver a &aUnidade de Distribuição de Carga&r em seu &a&lPeitoral do Meka-Traje&r, ela também Carregará as outras &a&lPeças do Meka-Traje&r."]
	quest.62B29AEF8468750E.quest_subtitle: "Calças"
	quest.62B29AEF8468750E.title: "&6Unidade de Gerador Geotérmico"
	quest.62B4A37CFDECA679.quest_desc: ["A Resina de Menril irá para 2 lados do Espremedor. Colocar uma Bacia de Secagem ao lado do Espremedor fará com que a Bacia de Secagem colete a Resina de Menril.\\n\\nApós 7,5 segundos, a Resina de Menril se transformará em um Bloco de Menril Cristalizado."]
	quest.62B5A84753ADFC35.quest_subtitle: "8 Blocos Rosa Escuro Secos"
	quest.62C32905C33E2D88.quest_desc: ["O &dOlho do Vazio&r levará você para a &dCidadela em Ruínas&r para lutar contra o &d&lGuardião do End&r."]
	quest.62C32905C33E2D88.title: "&dOlho do Vazio&r"
	quest.62C60FF24B2F7290.quest_desc: ["&bCristais Arcanos&r podem aparecer do Nível Y 14 a -40. \\n\\nÉ bastante comum; mas confie em mim, você precisará de muitos, então seja grato! \\n\\nComo os &bDiamantes&r, há um Nível Y em que eles aparecem com mais frequência, para os &bCristais Arcanos&r esse Nível Y é -13."]
	quest.62C60FF24B2F7290.title: "&bCristais Arcanos"
	quest.62D39F68DE6E44A4.quest_desc: ["&5Arcana&r é uma quantidade muito importante, ela aumenta a quantidade de &5Encantamentos&r que você obtém; e torna &5Encantamentos&r raros mais comuns. \\n\\nUm exemplo com Espadas seria, &5Julgamento&r é um &5Encantamento&r muito comum, mas &5Pilhagem&r é muito mais raro. \\n\\nO padrão de &5Arcana&r é &50%&r e o máximo é &5100%&r."]
	quest.62D39F68DE6E44A4.title: "&5Arcana"
	quest.62D572BAB055F56F.quest_subtitle: "Nível: &e1"
	quest.62DF58D36B739EA0.quest_desc: ["A &eWadjet&r é semelhante ao &eKobolediator&r, pois ela repousa dentro da &ePirâmide Amaldiçoada&r esperando que um Jogador se aproxime. \\n\\nA &eWadjet&r tem 450 &4Corações&r e, felizmente, não lhe dará Fadiga de Mineração! \\nEla tem muitos ataques, o mais básico é quando você está perto, ela vai balançar sua arma em você. Se você se afastar, ela pode jogar uma Tempestade de Areia em você ou derrubar Blocos de Areia do teto sobre você. \\n\\nVou ser honesto, não sei qual ataque é pior! \\n\\nNa morte, elas só soltarão Barras de Metal Ancestral."]
	quest.62DF58D36B739EA0.title: "&eWadjet"
	quest.62F33BBE7BDFE404.quest_desc: ["A Varinha de Teletransporte é outra queda da Monstruosidade Lunar, e apenas dela! \\n\\nVocê pode segurar o botão direito com a Varinha para iniciá-la, então, quando soltar, ela o teleportará para o Bloco que você estava olhando por último! \\n\\nHá um alcance, mas é bem longe. E há um tempo de recarga após o uso!"]
	quest.6300278B00A0FB50.quest_desc: ["Está no nome. \\n\\nToneladas de Itens são encontrados no subsolo, precisaremos minerá-los para Coletá-los! \\n\\nCada Item precisa de um certo Nível de Picareta para ser minerado. &7Pedregulho&r precisa de pelo menos uma &6Picareta de Madeira&r. Ferro precisa de pelo menos uma &7Picareta de Pedra&r. \\n\\nFerramentas Básicas explica isso com mais profundidade, mas você pode olhar para o topo da sua tela ao visualizar um Bloco para saber qual Nível de Picareta você precisa para minerá-lo!"]
	quest.6300278B00A0FB50.title: "&lMineração"
	quest.6309224455079059.quest_desc: ["&5&lMega Showdown&r! É um complemento de &c&lCobble&fmon&r que nos dá... um, dois, três, quatro! Quatro maneiras diferentes de apimentar as lutas de &cPokémon&r. \\n\\nTemos &bFormas Mega&f, &5Terastalização&f e &cDynamax&r, que mudam nossos &cPokémon&r enquanto lutam. Além dos &eMovimentos Z&r, que mudam os movimentos de luta dos nossos &cPokémon&r. \\n\\nTodos esses exigem que visitemos estruturas, exceto a &5Terastalização&r. \\n\\nTambém precisaremos de certos acessórios equipados para usá-los. Olhe para o seu inventário e, onde sua skin é mostrada no canto superior direito, haverá \"Abrir Tela de Acessórios\". Aqui é onde você colocará os itens para equipá-los."]
	quest.6309224455079059.title: "&5&lMega Showdown!"
	quest.6314B892B569A0A5.quest_desc: ["A Starlight! \\n\\nUma Dimensão onde é constantemente Crepúsculo, e não, você não pode mudar isso. \\n\\nHá dezenas de Biomas, Mobs, Chefes e até mesmo Blocos para encontrar! Você consegue descobrir todos eles?"]
	quest.6314B892B569A0A5.title: "Eternal Starlight"
	quest.631796E7615C04FA.quest_desc: ["O &2Caranguejo de Ametista&r vive nas Cavernas Exuberantes com os Axolotes. \\n\\nEle tem 1,200 &4Corações&r e é inicialmente neutro. Isso significa que ele não atacará primeiro, mas revidará. \\n\\nEle tem alguns ataques, um sendo apenas bater em você com suas garras. Ele também pode atirar Ametistas em você e se enterrar no chão. \\n\\nNa morte, ele soltará sua carne e conchas. Sua carne pode ser abençoada em um Altar de Ametista para ser melhor. As Conchas podem ser fabricadas juntas para fazer Ombreiras de Pedra Florescente, que têm estatísticas semelhantes ao Peitoral de Netherita, mas podem fazer habilidades semelhantes às do &2Caranguejo&r."]
	quest.631796E7615C04FA.title: "&2Caranguejo de Ametista&r"
	quest.632BC46928CC9A8C.quest_desc: ["O &9Espelho do Encantador&r aplicará um feitiço próprio quando usado. \\n\\nFeitiços lançados com este espelho têm desconto e ganham duração bônus adicional. \\n\\nPara aplicar um feitiço, use uma mesa de Escriba. Crie um feitiço sem usar uma forma."]
	quest.63362CC33B39C627.quest_desc: [
		"Mares Estrelados são enormes corpos de Água situados entre as Costas Quentes e a terra firme. \\n\\nEles guardam muitas maravilhas dentro deles e crescendo neles! \\n\\nEspero que você tenha trazido seus óculos de proteção!"
		"{image:atm:textures/questpics/eternal/starlight_starlitsea.png width:200 height:100 align:center}"
	]
	quest.63362CC33B39C627.title: "Mar Estrelado"
	quest.633D6361DA680C75.quest_desc: ["Misturar &#E6ED98Combustível Leve&r com Vapor resultará em &#DBE37FVapor Craqueado de Combustível Leve&r."]
	quest.6353A39CBEE599A0.quest_desc: ["Você gosta de combinar Inventários e criar uma forma de visualizar e interagir com todos esses Inventários com algumas &6Máquinas&r simples, semelhantes ao &b&lAE2&r e &7&lSophisticated Storage&r? \\n\\nEntão, você precisará de alguns &eLinks de Estoque&r! \\n\\nOs &eLinks de Estoque&r podem ser colocados em &eEmpacotadores&r para se conectar ao Inventário ao qual o &eEmpacotador&r está conectado. Quando colocado pela primeira vez, uma nova &eRede de Estoque&r será criada. \\n\\nEles podem se conectar a Baús, Barris e até &eCofres&r! \\n\\nVocê também pode Clicar com o Botão Direito em outro &eLink de Estoque&r com um &eLink de Estoque&r na mão para sintonizá-los na mesma &eRede&r. Quando o novo &eLink de Estoque&r for colocado em outro &eEmpacotador&r, seu Bloco de Inventário será adicionado à mesma &eRede&r. \\n\\nSe você quiser interagir com essas &eRedes&r, precisará de outros Blocos!"]
	quest.6353A39CBEE599A0.title: "&eLink de Estoque"
	quest.635620A03E3505BF.quest_desc: ["Eu não quero saber como você conseguiu isso."]
	quest.635620A03E3505BF.quest_subtitle: "Mas... Vacas não podem ser tosquiadas..."
	quest.635620A03E3505BF.title: "Couro"
	quest.635BA2C17458E9E6.quest_desc: ["Para uma receita tão simples, você na verdade obtém uma Máquina muito útil! \\n\\nSimplesmente coloque-a, (a forma como você a coloca muda para onde ela aponta, como um ejetor!) dê um pouco de Energia, e defina como ela funciona com uma &4Tocha de Redstone&r. \\n\\nSe estiver configurada para desativar, significa que ela desativará quando um &4Sinal de Redstone&r for enviado a ela. Em Pulso, significa que ela ativará sempre que um &4Sinal de Redstone&r for dado a ela. \\n\\nEstamos apenas procurando automatizar a &6&lEstrela&r, então não vou entrar em muitos detalhes, começaremos com uma Lente!"]
	quest.636848ED1115A0B3.quest_desc: [
		"Ratlins são Mobs pacíficos que podem aparecer na Superfície. \\n\\nNa morte, eles soltarão Carne de Ratlin, Couro e Musgo de Caverna. \\n\\nO último pode ser usado para procriá-los!"
		"{image:atm:textures/questpics/eternal/starlight_rat.png width:100 height:100 align:center}"
	]
	quest.636848ED1115A0B3.title: "Ratlins"
	quest.636854555AD75DC3.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Teleporta automaticamente os itens derrubados para o inventário vinculado à ferramenta. Shift + Clique com o botão direito da ferramenta em um inventário o vincula. Note que quando em uma enxada JDT, os itens derrubados pela habilidade de colheita automática da Farmland de brilho do vácuo / pulso sombrio são teleportados para o inventário vinculado, também clicar com o botão direito na Farmland de brilho do vácuo / pulso sombrio irá revinculá-los se o inventário vinculado da ferramenta tiver sido alterado."
	]
	quest.6374DDC15639E3C3.quest_desc: [
		"Sem aumento de nível."
		""
		"Item de Assinatura é &9Capa Discreta&r."
	]
	quest.6374DDC15639E3C3.title: "&7Archer, Admin. da Equipe Rocket"
	quest.637981B64BBE0D92.quest_desc: ["A &aEstação de Carregamento&r é um Bloco muito útil no início do jogo. \\n\\nÉ claramente usada para carregar Itens. Ou canalize Energia ou use Combustível de Fornalha para gerar Energia na forma de FE. \\n\\nEntão, você pode colocar qualquer Item que precise ser carregado no Slot mais à direita."]
	quest.637981B64BBE0D92.title: "&l&aCarregando Dispositivos"
	quest.63B0E39CA4B25A7E.quest_desc: ["A &dPasta Nutritiva&r é feita processando qualquer &eItem&r que dê Barras de Fome ao ser comido, através de um &d&lLiquidificador Nutricional&r. \\n\\nPense nele como um Liquidificador gigante! Mas não posso prometer que a &dPasta Nutritiva&r terá um gosto bom... \\n\\nO &a&lCapacete do Meka-Traje&r pode armazenar &dPasta Nutritiva&r e, com esta &7Unidade&r, ele alimentará você automaticamente quando você perder Pontos de Fome."]
	quest.63B0E39CA4B25A7E.quest_subtitle: "Capacete"
	quest.63B0E39CA4B25A7E.title: "&dUnidade de Injeção Nutricional"
	quest.63C95FDAA447CA47.quest_desc: ["A única receita que precisa do &3&lNível 2&r, o &7Prisma do Pisoteio Terrestre&r! \\n\\nVocê precisará de &7Dripstone&r, &7Dripstone&r e &8Sílex&r, juntamente com um &bBloco de Diamante&r! \\n\\nComo os outros Prismas, este precisará da Relíquia de &3Elementarium&r para ser feito. \\nComo o &cPrisma Ígneo&r, o &7Prisma do Pisoteio Terrestre&r pode ser usado com Ferramentas. Essas Ferramentas poderão minerar em uma Área de 3x3, em vez de apenas 1 Bloco minerado, elas minerarão 9!"]
	quest.63C95FDAA447CA47.title: "&7Prisma do Pisoteio Terrestre"
	quest.63CAD77A4488F2CE.quest_subtitle: "Picareta + Machado + Pá"
	quest.63DD7F5A4441ACE7.quest_desc: ["Glifos de Nível 2 exigem 5 níveis de experiência para serem feitos. \\n\\nEles também exigem um &9Livro de Feitiços de Mago&r para serem criados."]
	quest.63E4529AF8894018.quest_desc: ["&lModular Routers&r é um mod de logística. \\n\\nTudo começa com o Roteador! Então faça um! \\n\\nAlém disso, o Buffer é o único slot de item no Roteador por onde os itens entrarão e sairão. E ele precisará de um sinal de Redstone para a maioria dos módulos funcionar."]
	quest.63E4529AF8894018.title: "&lModular Routers"
	quest.63F5314A1072FA05.quest_desc: [
		"A &e&lSawmill&r funciona de forma semelhante à &7&lPrensa de Metal&r, usando &eEsteiras Transportadoras&r e necessitando de Itens extras. \\n\\nEla funciona em 2 estágios, primeiro descasca os Troncos. Se não tiver uma Lâmina de Serra dentro, ela apenas descascará os Troncos. O segundo estágio é cortar o Tronco em Tábuas, isso precisa de uma Lâmina de Serra. \\n\\nLâminas de Serra são feitas com muito &8Aço&r. Elas têm Durabilidade e para inseri-las, Clique com o Botão Direito nos Slots perto da parte de trás da Sawmill. Se desejar retirá-las, desligue a Sawmill com &4Redstone&r, e então segure Shift e Clique com o Botão Direito onde você as inseriu. \\n\\nVocê precisará fornecer &cEnergia&r na parte de cima do lado de trás, e pode &9Inserir &eItens&r através das &eEsteiras Transportadoras&r. Os &eItens&r sairão &6pelas&r mesmas &eEsteiras&r, mas a Serragem sai por uma Porta na frente da &e&lMáquina&r."
		"{@pagebreak}"
		"Faça uma forma de I com &8Andaimes de Aço&r (não se esqueça do &7Bloco de Engenharia Pesada&r) e preencha uma parte com &eBlocos de Engenharia Leve&r e a outra com &7Chapas de Ferro&r."
		"{image:atm:textures/questpics/immersive/immersive_saw1.png width:150 height:100 align:center}"
		"Coloque mais 3 &eBlocos de Engenharia Leve&r sobre seus companheiros inferiores. Adicione 1 &7Chapa de Ferro&r na &7Chapa de Ferro&r mais à esquerda e ao lado dela coloque um &4Bloco de Engenharia de Redstone&r. Ao lado da &7Chapa de Ferro&r de cima, precisaremos de outro &7Bloco de Engenharia Pesada&r. Não se esqueça de adicionar as Esteiras Transportadoras, elas são necessárias para construí-lo!"
		"{image:atm:textures/questpics/immersive/immersive_saw2.png width:100 height:100 align:center}"
		"Clique com o botão direito na &7Chapa de Ferro&r do meio com nosso Martelo!"
		"{image:atm:textures/questpics/immersive/immersive_saw.png width:100 height:100 align:center}"
	]
	quest.63F5314A1072FA05.title: "&e&lSawmill"
	quest.63F6F4EBCEB914B0.quest_desc: ["A &3Pressure Chamber&r é uma importante estrutura multibloco feita de &3Pressure Chamber Walls&r (As faces podem ser substituídas por &3Pressure Chamber Glass&r). A Pressure Chamber pode ser tão pequena quanto um multibloco de 3x3x3, ou tão grande quanto um de 5x5x5. Os blocos necessários para a de 5x5x5 são o que é preciso para completar esta missão.\\n\\nPara usar a Pressure Chamber, você precisará canalizar pressão para uma &3Pressure Chamber Valve&r usando os &3Pressure Tubes&r que você fez anteriormente, lembre-se de colocar um Security Upgrade na Pressure Valve. &lReceitas diferentes exigem diferentes quantidades de pressão&r.\\n\\nVocê precisará ser capaz de inserir e extrair itens de e para a Pressure Chamber, é aqui que as &3Pressure Chamber Interfaces&r entram em jogo. Azul do lado de fora significa que é para importar itens, enquanto que se dourado estiver do lado de fora, é para exportar itens, posicione um de cada em qualquer face."]
	quest.63F6F4EBCEB914B0.quest_subtitle: "Pressurizando!"
	quest.63F6F4EBCEB914B0.title: "A Pressure Chamber"
	quest.640D6ADA17709D3A.quest_subtitle: "Yellow Meranti + Kapok"
	quest.64141B720662B652.quest_desc: ["Bem-vindo ao &6&lRelics&r! \\n \\nO mod &6Relics&r é semelhante ao Artifacts, você obtém muitos itens únicos e poderosos por todos os Mundos. \\n \\nEles possuem muitas habilidades diferentes que são obtidas e aprimoradas através da &6Janela de Pesquisa&r (Segure Shift na relíquia). Lá você pode trocar &aXP Vanilla&r para girar novamente os atributos de suas habilidades, ver seu &eXP de Relíquia&r atual, ganho ao usar as &6Relics&r, e subir o nível de suas habilidades! \\n\\nCada &6rank&r aprimora ainda mais as &6habilidades&r, tornando seus efeitos mais fortes e eficientes. \\n \\nPara usar as Habilidades de &6Relíquia&r, o padrão é Alt Esquerdo."]
	quest.64141B720662B652.title: "&l&6Relics"
	quest.6431628BFD0A9386.quest_desc: ["Ele aumentará você para o 66. \\n\\n&dSementes Psíquicas&r são seus Itens de Assinatura."]
	quest.6431628BFD0A9386.title: "&3Elite dos Quatro Lucian"
	quest.6431A384DDFBF439.quest_desc: [
		"A &bFerramenta de Rede&f é uma ferramenta importante em todo o AE2, usada para exibir vários detalhes de uma rede na tela, como o consumo geral de energia e o armazenamento."
		""
		"Como um bônus adicional, ela também fornece seu próprio pequeno inventário usado para guardar &ecartões de upgrade&f, que pode ser acessado ao olhar para a tela de qualquer dispositivo atualizável para fácil substituição. No entanto, ela não pode girar blocos anexados à Rede ME como uma chave inglesa normal, apenas desmontá-los quando agachado."
	]
	quest.6431A384DDFBF439.title: "&eFerramentas de Rede"
	quest.64320561B2275D90.quest_desc: ["A chave para Capturar &cPokemon&r! A &cPoke&rbola! \\n\\nVocê pode usá-las apenas em &cPokemon&r Selvagens, seja na Natureza ou em Batalha. Na Natureza, apenas mire sua &cPoke&rbola em um &cPokemon&r, e Clique com o Botão Direito para Lançá-la! \\n\\nEm Batalha, você precisará escolher o Botão de Captura. Isso dará uma pausa na Batalha para permitir que você tente Capturá-los. \\n\\nDepois de Lançar a &cPoke&rbola, ela será consumida. Ou ela Capturará o &cPokemon&r e ele se tornará parte da sua Equipe ou será adicionado ao seu &9PC&r. \\n\\nSe a &cBola&r falhar em Capturá-los, nada acontecerá, a menos que você esteja em uma Batalha. Se falhar, você perderá seu Turno na Batalha. \\n\\nDiferentes &cBolas&r têm diferentes Taxas de Captura. Quanto maior, melhor! Além disso, &cPokemon&r mais fracos e &cPokemon&r Danificados são mais fáceis de Capturar."]
	quest.64320561B2275D90.title: "&cPoke&fbolas"
	quest.6434796EAAF2A4EC.quest_desc: ["Depois de completar todas estas Missões, você pode Clicar com o Botão Direito na &5Rainha&r para obter a Essência das Abelhas. \\n\\n&lComa-a!&r \\n\\nAgora você pode basicamente fazer qualquer coisa aqui. Você pode coletar &6Mel&r com segurança de todas as &eColmeias&r, &6Favos de Mel&r e &6Slimes de Mel&r. Você pode caminhar pelo Labirinto de Células sem a Ira da Colmeia, pode entrar no &5Pilar do Trono&r sem Fadiga de Mineração e pode andar sobre Cera Ancestral sem os efeitos horríveis. E quando você entrar em &6Mel Fluido&r ou Geleia Real, receberá efeitos incríveis. \\n\\nA melhor parte é que isso fica com você mesmo após a Morte! Agora você pode entrar no endgame!"]
	quest.643604ECFEE714D4.quest_desc: [
		"Aumento de nível para 81."
		""
		"Item de Assinatura é &cLaço do Destino&r."
	]
	quest.643604ECFEE714D4.title: "&7Chefe Giovanni"
	quest.6474FE12450A4A7D.quest_desc: [
		"O &5Pilar do Trono&r se parece com um &6&lPilar de Colmeia&r, mas este é bem decorado com &5Cristais&r, Teias e &6Favos de Mel&r em designs eloquentes. \\n\\nNo meio do &5Pilar&r está a Sala do Trono, onde você encontrará..."
		"{image:atm:textures/questpics/bumblezone/bumble_throne.png width:200 height:100 align:center}"
	]
	quest.6474FE12450A4A7D.title: "Pilar do Trono"
	quest.647A87E800C703C3.quest_desc: [
		"Meu Bioma favorito de longe! \\n\\nUma selva verde gigante com enormes árvores Gronglegrowth. \\n\\nNessas árvores você pode encontrar &eGronglets&r!"
		"{image:atm:textures/questpics/undergarden/undergarden_grongle.png width:200 height:100 align:center}"
	]
	quest.647A87E800C703C3.title: "Gronglegrowth"
	quest.64860340A5BEBAB9.quest_desc: ["As &eToalhas de Mesa&r podem ser usadas para exibir &eItens&r, ou para vender &eItens&r! \\n\\nPara montar uma Loja, siga todos os passos da Missão anterior: colocando &eLinks de Estoque&f, &eTickers de Estoque&r, e um Mob em um Assento ou &cQueimador de Blaze&r. \\n\\nAgora use uma &eToalha de Mesa&r para Interagir com o Mob ou &cQueimador de Blaze&r, isso vinculará a &eToalha de Mesa&r àquele &eTicker de Estoque&r. \\n\\nColoque a &eToalha de Mesa&r e você poderá colocar os &eItens&r que deseja vender em cima, e o preço abaixo. \\n\\nQuando alguém compra um &eItem&r, ele enviará uma mensagem para o &eLink de Estoque&r, que &eEmpacotará&f os &eItens&r comprados e receberá o preço."]
	quest.64860340A5BEBAB9.quest_subtitle: "Com Toalhas de Mesa"
	quest.64860340A5BEBAB9.title: "Lojas"
	quest.649167FC31EB916E.quest_desc: ["O &3Óleo Vegetal&r pode ser feito colocando culturas ou sementes em uma &3Planta de Processamento Termopneumático&r."]
	quest.649167FC31EB916E.quest_subtitle: "Óleo Melhor"
	quest.649167FC31EB916E.title: "Óleo Vegetal"
	quest.6497A255E427A5EB.quest_subtitle: "Balsam Fir + Bull Pine"
	quest.64A09E2E3EF16C31.quest_subtitle: "Banana + Teak"
	quest.64B04D1CBC923789.quest_subtitle: "Nível: &b4"
	quest.64C105E1E2F97900.quest_desc: ["Os Spike Mauls são usados em &6Trilhos&r normais para trocar seus modos. Muito útil para tentar fazer cruzamentos!"]
	quest.64C105E1E2F97900.title: "'Troque-os'"
	quest.64D0E66CB4FBEC82.quest_desc: ["Para começar, você precisará criar um &6Livro de Feitiços de Noviço&r! \\n\\nÉ aqui que você cria e armazena seus feitiços. \\n\\nPressionar a tecla &9C&r abrirá a página 'Criar um Feitiço'. À esquerda, há várias abas, mas as 3 principais são: Criação de Feitiço, Seletor de Cores e Familiares. \\n\\nEste livro de feitiços permitirá que você crie e use apenas Glifos de Nível 1. Para criar feitiços melhores, você precisará aprimorar seu Livro de Feitiços!"]
	quest.64D0E66CB4FBEC82.quest_subtitle: "Nosso Primeiro Livro de Feitiços"
	quest.64D0E66CB4FBEC82.title: "Livro de Feitiços"
	quest.64D34A6C3487C5DF.quest_desc: ["A &3Interface Aérea&r pode ser usada para reabastecer suas coisas pressurizáveis com pressão. Agora você pode usar sua Armadura Pneumática sem precisar recarregar!\\n\\nVocê precisará de uma dessas para criar a &6Estrela ATM&r."]
	quest.64D34A6C3487C5DF.quest_subtitle: "Pressão Sem Fio!"
	quest.64D6C395B6304F40.title: "&eParte de Armazenamento de Fluido de 65536B"
	quest.64E2E05B228EA53E.quest_desc: ["Os &3Tubos de Pressão Avançados&r são os melhores Tubos de Pressão disponíveis, capazes de suportar 20 bars de pressão!\\n\\nApesar de serem muito legais por si só, eles também podem ser usados em algumas receitas ainda mais legais."]
	quest.64E2E05B228EA53E.quest_subtitle: "Um Nível Totalmente Novo!"
	quest.64E85274D24FE394.quest_desc: ["Quando conectado ao seu sistema, o &9Monitor de Armazenamento&r exibirá o número atual de um item dentro da sua rede."]
	quest.64EED65F80A91D9E.quest_subtitle: "Nível: &b3"
	quest.64FEF31955CB158D.quest_desc: ["Bata em &dFlores&r com &eSopros de Pólen&r para gerar mais 8 &dFlores&r."]
	quest.64FF7118E29931C0.quest_desc: ["Antes de entrarmos nos muitos &eItens&r que podemos obter do &6Moinho&r, vamos falar sobre como usá-lo! \\n\\nPrimeiro, ele precisará de um pouco de &dPotência Rotacional&r, não se preocupe, ele só precisa de um pouco. \\n\\nEntão, você precisará Soltar o &eItem&r que deseja &6Moer&r, no topo do &6Moinho&r. Depois que for &6Moído&r, basta Clicar com o Botão Direito no &6Moinho&r para retirar seus &eItens&r. \\n\\nAgora, quais &eItens&r podemos obter do &6Moinho&r? Podemos obter Corantes de praticamente todas as Flores, podemos triturar &7Pedra&r em Cascalho ou outros Blocos de &7Pedra&r em Itens de Cascalho semelhantes. Você pode até obter Farinha de Trigo do Trigo!"]
	quest.64FF7118E29931C0.title: "&6Moinho"
	quest.6501A410F1543C70.quest_desc: ["O Fertilizante Místico funciona como Farinha de Osso, mas melhor. Ele faz crescer instantaneamente qualquer coisa em que é usado até a maturidade completa."]
	quest.6501A410F1543C70.title: "&dFertilizante Místico"
	quest.6518480251F0565A.quest_desc: ["Espere, se Paxels podem fazer Caminhos, arar a terra e remover a casca de Troncos, por que a &dMeka-Tool&r não pode! \\n\\nAh, espere, ela pode se você usar a &2Unidade de Agricultura&r. \\n\\nVocê precisará ativar qual função usar nas Configurações. Você não pode fazer Caminhos e Terra arada com o mesmo bloco de Grama! \\n\\nNão podemos usar esta unidade com a &7Unidade de Tosquia&r ou a &5Unidade de Teletransporte&r."]
	quest.6518480251F0565A.quest_subtitle: "Uai!"
	quest.6518480251F0565A.title: "&2Unidade de Agricultura"
	quest.6539582429A70EE8.quest_subtitle: "Oritech pode usar energia gerada pela maioria das fontes neste pacote"
	quest.6552E301C370D203.quest_subtitle: "&f7 de &cDano de Ataque"
	quest.6559C57A1A476489.quest_subtitle: "+5 de Velocidade de Ataque"
	quest.655BE42CD5BB9D82.title: "Módulo de Área de Efeito Dracônico"
	quest.655FA86A410CE27B.quest_desc: ["Pegando uma de nossas &9Tampas Azuis&r das missões anteriores, podemos fazer uma &9Tampa de Grande Bola&r. \\n\\nImplante 2 &cFragmentos de Bolota Vermelha&r em cima daquela &9Tampa Azul&r para fazer uma &9Tampa de Grande Bola&r. \\n\\nObviamente podemos usar isso para fazer uma &9Grande Bola&r, mas por que não uma &cBola&r ainda melhor que essa! \\n\\nEstou falando da &bGrande Bola de Fogo&r, não de uma Bola Maior..."]
	quest.655FB110E5F66DF0.quest_subtitle: "Alimente uma Abelha Ancestral com Gosma de Shadowpulse"
	quest.655FB110E5F66DF0.title: "&fAbelha de Liga Eclipse"
	quest.655FF7295B688354.quest_desc: ["O &9Clawdian&r é o miniboss de &9Acropolis&r. \\n\\nEles são lagostas gigantes que seguram um Machado ainda maior! \\n\\nEles têm 225 &4Corações&r e 12 Pontos de Armadura. \\n\\nEles gostam de usar seu Machado e seus Pés para te atacar. Desde balançar o Machado em sua direção para causar dano moderado, até esmagar o chão com o Machado para liberar uma Onda de Choque. Até pisar no chão para liberar uma Onda de Choque ainda maior e &9Ondas&r em sua direção! \\n\\nSe você se afastar demais, eles vão te perseguir, quebrando os Blocos no caminho! \\n\\nSe você conseguir matar um, ele vai soltar sua &9Garra&r! Meio gráfico, mas felizmente é apenas violência de fantasia!"]
	quest.655FF7295B688354.title: "&9Clawdian"
	quest.657B3116A6419420.quest_subtitle: "Sua Própria Alça!"
	quest.657DB994B029F61C.quest_desc: [
		"Quando a &3Estrutura de Calor&r é colocada em um recipiente contendo certos fluidos e resfriada o suficiente, ela transformará os referidos fluidos em itens."
		""
		"Transforma Plástico Derretido em Plástico."
		"Transforma Água em Gelo."
		"Transforma Lava em Obsidiana."
	]
	quest.6581D4AF1A6DE230.quest_desc: ["Demônios gostam de Velas. Eu acho.\\n\\nPara quase todo Ritual para invocar nossos amigos, você precisará de algumas Velas. Você pode criar a &aFaca de Açougueiro&r e matar alguns porcos, vacas, ovelhas, cavalos ou até mesmo as Lhamas do Comerciante para obter um pouco de &aSebo&r para fazê-las. Na verdade, você definitivamente deveria encontrar as Lhamas do Comerciante. Ouvi dizer que elas dão boas velas. &mEu totalmente não acabei de inventar isso&r.\\n\\nCaso contrário, Velas da Vanilla também funcionam!\\n\\n&9Cristais Sintonizados com Espírito&r também são usados em vários Rituais, então é melhor fazer alguns agora!"]
	quest.6581D4AF1A6DE230.title: "Preparando para um Ritual: &aVelas"
	quest.658D2E531DDB116C.quest_desc: ["Já está com suas joias bonitas? Dê ao seu &cPokémon&r um &eMovimento Z&r e estaremos prontos para usá-lo! \\n\\nTambém certifique-se de que seu &cPokémon&r conheça o movimento e que você não esteja usando nenhuma &bMegaevolução&r. Você não pode usar &bMegaevoluções&r com &eMovimentos Z&r. \\n\\nUma vez em batalha, abaixo de seus movimentos você terá a opção de usar um &eMovimento Z&r! \\n\\nIsso irá impulsionar ou mudar seus movimentos de qualquer forma."]
	quest.658D2E531DDB116C.title: "&eMovimentos Z&r em ação"
	quest.658DEAAD1E68E549.quest_desc: ["Estes blocos expandem o armazenamento de crafting do Núcleo Quântico. Eles aumentam efetivamente a quantidade de tarefas simultâneas que o Computador Quântico é capaz de executar. Eles também são necessários para fazer um Núcleo de Computador Quântico."]
	quest.658DEAAD1E68E549.title: "Armazenamento de Crafting Massivo: O Armazenamento de Computador Quântico"
	quest.659A903F97F93BE2.quest_subtitle: "Rápido e Simples"
	quest.659A903F97F93BE2.title: "O Pão da Vida"
	quest.65A529C8238E89F1.quest_desc: ["Graças ao &5&lMekanism&r, agora podemos fazer Armadura de &9Lápis-lazúli&r! \\n\\nÉ meio ruim, no entanto..."]
	quest.65A529C8238E89F1.quest_subtitle: "9"
	quest.65A529C8238E89F1.title: "&9Armadura de Lápis-lazúli"
	quest.65A7307F9858ECB5.quest_desc: ["Afeta a agressividade da abelha e a probabilidade de ela te picar. Esta é uma das características menos importantes, embora valha a pena não ter uma abelha agressiva quando você quiser trabalhar com uma no mundo. Existem 4 níveis disso: &aPassiva&r, &9Normal&r, &cHostil&r, &dAgressiva&r. Serei honesto, não sei exatamente o que cada nível de Temperamento faz. Tudo o que sei é que abelhas &dAgressiva&r VÃO te picar, mesmo que não sejam provocadas. Abelhas se tornarão menos agressivas se você alimentá-las com Guloseimas de Mel."]
	quest.65A7307F9858ECB5.quest_subtitle: "Parem de me picar já!"
	quest.65A7307F9858ECB5.title: "&4&lTemperamento"
	quest.65C147F5282E8FCD.quest_desc: ["O Carregador do Infinito é sua melhor opção para carregar Ferramentas do Infinito. Ele comporta &lluita&r FE, perfeito para as Ferramentas do Infinito.\\n\\nEle pode carregar outras coisas, também."]
	quest.65C8A43FEDBA3835.quest_desc: ["A &3Grade de Padrões&r permite que você imprima receitas em Padrões para sua rede.\\n\\nA maneira mais fácil de criar uma receita para um Padrão é procurar o item no JEI e clicar no botão '+' no canto inferior direito da receita. Isso colocará a receita na Grade.\\n\\nNo lado direito, o espaço superior é usado para armazenar Padrões em branco. Com um Padrão em branco dentro, você deve ser capaz de clicar na Seta abaixo para imprimir a receita no Padrão.\\n\\nVocê então vai querer colocar o Padrão em um &3Auto-fabricador&r!"]
	quest.65C8A43FEDBA3835.title: "&3Grade de Padrões"
	quest.65D89991A45BC042.quest_desc: ["Coloque uma Interface de Criação em uma mesa de trabalho e clique com o botão direito nela, isso lhe dará alguns slots para &bCartões de Variáveis&r. \\n\\nUsando o Programador Lógico, procure por &eReceita&r no canto superior esquerdo e crie uma para autocriação, depois salve-a em um &bCartão de Variável&r. Se uma receita &c&lexigir&r itens que precisam ser criados, crie uma receita para cada um deles e coloque tudo na Interface de Criação."]
	quest.65D89991A45BC042.quest_subtitle: "&l&cA&6U&eT&aO&bC&dR&9A&3F&0T"
	quest.65D993EB95726067.title: "Cuidado com o Templo"
	quest.65E2AF881709C896.quest_desc: ["Um dos materiais mais importantes que você precisará é a &3Pedra Reforçada&r, comece fazendo 32 usando Ferro Comprimido e um pouco de pedra normal."]
	quest.65E2AF881709C896.quest_subtitle: "Você vai precisar de muito disso"
	quest.65E2AF881709C896.title: "Pedra Reforçada"
	quest.65E733AACBE62EDB.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_ward.png width:100 height:150 align:center}"]
	quest.65E733AACBE62EDB.quest_subtitle: "Cidades Ancestrais"
	quest.65E733AACBE62EDB.title: "Ornamento de Armadura Ward"
	quest.65E76C4AD74338E4.quest_desc: [
		"Ainda sem Aumento de Nível? O que fizemos de errado?"
		""
		"Seu Item de Assinatura desta vez é um Direto Crítico."
	]
	quest.65E76C4AD74338E4.title: "&6Rival Wayne"
	quest.65FA86357BC60573.quest_desc: ["É hora de mover coisas de um lugar para outro. Aqui estão os passos:\\n\\n&l1.&r Coloque uma interface em um inventário (como um Baú ou um Tanque)\\n\\n&l2.&r Coloque um Importador ou um Exportador em outro inventário, dependendo se você quer puxar ou enviar coisas para ele.\\n\\n&l3.&r Conecte ambos com Cabos, coloque um Cartão Variável no Importador ou Exportador, e pronto!"]
	quest.65FA86357BC60573.quest_subtitle: "Movendo Coisas!"
	quest.6601450C63FEEE61.quest_desc: ["&bNível 3&r é o nível da Picareta de Ferro, ela minera a maioria dos minérios como Diamante, Esmeralda e Ouro."]
	quest.6601450C63FEEE61.title: "&bNível de Coleta 3"
	quest.6601ACCDDF6CA5FF.quest_desc: ["O Reator só pode conter 1 Bilhão de OP e, embora isso possa parecer um número distante, não será por muito tempo. Quando a Saturação de Energia atingir 100%%, aumentará muito o Calor, o que pode levar a um Colapso. Ele precisará de 500.000.000 OP para ativar e uma Válvula de Fluxo ajudará a limitar quanto OP entra e sai. (A propósito, 1 RF = 1 OP) Eles precisam de Redstone para ativar e podem ser usados tanto para adicionar OP quanto para retirar OP. Você precisará de saída de Energia para não entrar em Colapso, tente colocá-la em um Núcleo de Energia!"]
	quest.6601ACCDDF6CA5FF.title: "Um pontapé inicial"
	quest.66039B738CF0718A.quest_desc: ["&3Vibranium&r combinado com &6Allthemodium&r!"]
	quest.66039B738CF0718A.title: "Barra de Liga de &3Vibranium&r - &6Allthemodium&r"
	quest.6607E5CDB3D17D67.quest_desc: ["Não se preocupe, estas não vão pegar fogo!"]
	quest.6607E5CDB3D17D67.title: "Lã &l&bChipped&r"
	quest.6616A62426ED4D15.quest_desc: ["O Injetor precisa estar em um lado diferente de todos os Estabilizadores e deve compartilhar o mesmo Eixo que o Núcleo. É aqui que o OP precisará ser injetado! Para ativar e gerar OP, a Saturação de Energia precisa ser um pouco elevada. Saturação de Energia é a Energia armazenada e a Energia que em breve será gerada."]
	quest.6616A62426ED4D15.title: "Injetor de Energia do Reator"
	quest.661C072E48F8D41F.quest_desc: [
		"O &6Cobre&r é um dos minérios mais comuns que você pode encontrar, se não o mais comum, então por que não usar um monte de &6Cobre&r sobrando para aprimorar sua fornalha!"
		""
		"Fornalhas normais levam 200 Ticks para fundir 1 Item (20 Ticks = 1 Segundo), enquanto as &6Fornalhas de Cobre&r levam 180 Ticks."
		""
		"Elas podem ser transformadas em &7Fornalhas de Prata&r ou &fde Ferro&r."
	]
	quest.661C072E48F8D41F.title: "&6Fornalha de Cobre"
	quest.662DD269B027B6C8.quest_desc: ["Você não pode carregar sua &c&lMochila Acumuladora&r sem fio... mas pode carregá-la &ccom fio&r! \\n\\nSimplesmente conecte sua Antena de Carregamento à sua &c&lMochila Acumuladora&r e aproxime-se de quaisquer &cFios&r que transportam &cEnergia&r e parte dela virá para sua &c&lMochila&r."]
	quest.66324D7D0C51AEAC.quest_desc: ["A Melhoria Base é usada para criar os várias Melhorias em Productive Bees."]
	quest.66324D7D0C51AEAC.title: "&fMelhoria &6Base"
	quest.6647A9652EFDDCDF.quest_desc: ["Para resfriar a &#ADF0EEBarra Quente de Aço Inoxidável&r, basta colocá-lo em um &#56E3DFFreezer à Vácuo&r para transformá-lo em &#ADF0EEBarra de Aço Inoxidável&r utilizável."]
	quest.6648BC7D14233006.quest_desc: ["Aprimoramentos são semelhantes a Melhorias, mas para os Módulos individuais!"]
	quest.6648BC7D14233006.title: "&l&fAprimoramentos"
	quest.6667638252DB9C74.quest_desc: ["&8Símbolos&r são itens usados para modificar seus &eItens com Afixos&r do &6&lApotheosis&r; seja limpando &9Encaixes&r, adicionando mais &9Encaixes&r ou removendo o Nome! \\n\\nTodos são usados com seu Item em uma &8&lMesa de Ferraria&r, &9&lMesa de Reforja&r ou &6&lMesa de Aprimoramento&r."]
	quest.6667638252DB9C74.quest_subtitle: "Agora apenas Símbolos!"
	quest.6667638252DB9C74.title: "&mFrascos e&r &8Símbolos"
	quest.666EA8B8F13EB292.quest_desc: ["Este item é usado para capturar mobs para transporte ou armazenamento. Também é necessário para a &6Estrela ATM&r."]
	quest.666EA8B8F13EB292.title: "&dGema da Alma Vazia"
	quest.6674270897997BF7.quest_desc: ["Permite que você pule mais alto do que o normal e o torna elástico, proporcionando viagens mais rápidas.\\n\\nVocê só pode ter um nível desses Upgrades nas Perneiras de cada vez."]
	quest.6674270897997BF7.quest_subtitle: "Máx: 1"
	quest.6678AB58930F4B91.quest_subtitle: "White Willow + Aspen"
	quest.668C313FF46B6005.quest_desc: ["Adiciona uma INTERFACE de Fornalha à Mochila."]
	quest.668E99B93D0BC405.quest_desc: ["Temos nossas &bTampas&r e nossos &7Mecanismos&r, vamos finalmente fazer nossas &cPoke&rbolas! \\n\\nOs únicos itens extras que precisaremos são uma Tampa Vazia e uma &7Vara de Ferro&r. \\n\\nPodemos usar &6Implantadores&r, uma &7Câmara de Pressão&r ou uma &8Linha de Montagem&r para juntar tudo. Vamos lá, a essa altura você já deve saber como usá-los!"]
	quest.668E99B93D0BC405.title: "Finalizando nossas &cPoke&rbolas"
	quest.6690AEE064DC2A7C.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:"
		""
		"Aumenta a área minerada de uma vez. Quando instalada em ferramentas de nível superior, a área máxima minerada é aumentada. A área minerada pode ser configurada no menu."
	]
	quest.66A450CAC07232E1.quest_desc: ["Os &6Condutores Termodinâmicos&r moverão &6Calor&r. Sim, algumas &5Máquinas&r do &5&lMekanism&r usam &6Calor&r! Como a &6&lMáquina de Evaporação Térmica&r. \\n\\nA maioria dos &6Aquecedores&r terá Lados definidos para Saída de &6Calor&r! \\n\\nNão tenho certeza do que esses números significam, mas seguindo o padrão: mais caro, melhor!"]
	quest.66A450CAC07232E1.quest_subtitle: "Calor"
	quest.66A450CAC07232E1.title: "&6Condutores Termodinâmicos"
	quest.66AADD32A528A56D.quest_subtitle: "Tier: &63"
	quest.66B503EB65475B98.quest_subtitle: "Tier: &63"
	quest.66BAC2B478F9B119.quest_subtitle: "1/5"
	quest.66BAC2B478F9B119.title: "Parte Superior da &6&lEstrela ATM&r"
	quest.66C21934DAFFAC7F.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_tide.png width:100 height:150 align:center}"]
	quest.66C21934DAFFAC7F.quest_subtitle: "Dropado de Guardiões Anciões"
	quest.66C21934DAFFAC7F.title: "Ornamento de Armadura Tide"
	quest.66C52B137A4FF869.quest_desc: ["Esta é a Essência de Tier 4, feita combinando 4 Tertium com um Cristal de Infusão."]
	quest.66C52B137A4FF869.quest_subtitle: "Tier: &b4"
	quest.66C52B137A4FF869.title: "&9Imperium"
	quest.66D4256F79D5B30B.quest_subtitle: "Igual ao do vapor"
	quest.66D4256F79D5B30B.title: "&5Fornalha Elétrica"
	quest.66D85424EC74EDCC.quest_desc: ["A &9Grade Portátil&r é um sistema de armazenamento portátil que não está conectado a uma rede.\\n\\nEla permite que você interaja com um &9Disco de Armazenamento&r sem estar conectado a uma rede."]
	quest.66E78F599CD50579.quest_desc: [
		"O &#49C472Reator Nuclear&r permite processar recursos de nível mais avançado. Usaremos ele para gerar &#8F49C4Deutério&r e &#EB5266Trítio&r."
		""
		"Esta lista de recursos ajudará você a construir um Reator \"Grande\". Qualquer tamanho menor não é recomendado devido à velocidade e eficiência."
		"{@pagebreak}"
		"Os detalhes para fazer um reator eficiente são complexos demais para serem fornecidos aqui. Contudo, vou fornecer os melhores designs possíveis."
		""
		"Aqui está um design de &#49C472Reator Grande&r para produzir &#8F49C4Deutério&r."
		"{image:atm:textures/questpics/modernindustrialization/large_reactor.png width:100 height:100 align:center}"
		""
		"Este é o design de &#49C472Reator de tamanho Extremo&r para produzir &#EB5266Trítio&r."
		""
		"{image:atm:textures/questpics/modernindustrialization/largest_reactor.png width:100 height:100 align:center}"
	]
	quest.66E78F599CD50579.quest_subtitle: "Eles não explodem"
	quest.66E88F916B638B3B.quest_desc: ["Este pode ser um pouco confuso, existem alguns &5&eLivro de Feitiços Criativos&r! Mas o que queremos é do &d&lAllTheArcanist Gear&r. \\n\\nPara fazer este, precisamos criar o do &l&dArs Nouveau&r. Aquele &eLivro de Feitiços&r precisa de um &eLivro de Feitiços de Arquimago&r, uma &6&lEstrela ATM&r e alguns Itens extras. \\n\\nEle tem as mesmas configurações de um &eLivro de Feitiços de Unobtainium&r, mas tem Mana infinita e todos os Glifos desbloqueados! \\n\\nTodo o Poder dos Feitiços BWAHAHAHAHA!"]
	quest.66E88F916B638B3B.title: "&5&lLivro de Feitiços &eCriativo"
	quest.66ECC26BC81D0093.title: "Tier: &bBásico"
	quest.66FE4552E09B5EFF.quest_desc: ["Os Prismas são importantes para muitas das receitas do &6&lForbidden \\& Arcanus&r e outros Mods mais tarde! \\n\\nPara criá-los, precisaremos de &3Elementarium&r, que é encontrado em Templos da Selva, Pirâmides do Deserto e Ruínas Subaquáticas. \\n\\nAcho que seria mais fácil nos dizer onde você não pode encontrá-lo!"]
	quest.66FE4552E09B5EFF.title: "&3Elementarium"
	quest.6718043D0F2D1830.quest_desc: ["DireWolf foi solicitado a fazer uma adição de seus Cartões para funcionar com o &5&lMekanism&r e seus... outros estados da matéria. Tudo o que os Tubos Pressurizados podem mover, esses cartões também podem. Gás, Tipos de Infusão e Pigmentos."]
	quest.6718043D0F2D1830.title: "&5Cartão Químico"
	quest.6720F863B907A5F1.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Faz com que as Flechas de Poção disparadas pelo arco tenham um efeito Duradouro, aplicando efeitos em uma área ao longo do tempo."
	]
	quest.672134A1A620EEAB.quest_desc: ["Existem muitas maneiras de armazenar energia! \\n\\nTemos &c&lPowah&r Energy Cells. \\n&5&lMekanism&r Energy Cubes. \\n&3&lIntegrated Dynamics&r Energy Batteries. \\n&b&lAE2&r Energy Cells. \\n\\nCada uma delas pode ser aprimorada para conter ainda mais &cEnergia&r! \\n\\nSe isso não for suficiente, confira o &5&lMekanism&r ou o &5&lDraconic Evolution&r para Armazenamento de Energia Multibloco."]
	quest.67216EC5274F08B9.quest_subtitle: "Usado por Tosquiadores-pastores"
	quest.672AC964851832EB.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_swamp.png width:100 height:150 align:center}"]
	quest.672AC964851832EB.title: "&7Prata do Pântano&r"
	quest.672B69448F1D458B.quest_desc: ["O &#FAAD28Trocador de Calor&r é um paraíso para os amantes da Turbina dos &#4D7DFFExtreme Reactors&r. Essa máquina pode produzir uma quantidade surpreendentemente grande de Vapor."]
	quest.672B69448F1D458B.quest_subtitle: "Vapor vai brrr"
	quest.672CE0EC2DD0E704.quest_desc: ["Com &bDiamantes&r podemos fazer uma &bPicareta de Diamante&r! Ela pode minerar todos os Blocos &2&lVanilla&r, incluindo &5Obsidiana&r e &cDetritos Ancestrais&r. \\n\\nVocê também pode fabricar Armaduras e Armas... essas também."]
	quest.672CE0EC2DD0E704.title: "Ferramentas e Equipamentos de &bDiamante&r"
	quest.672F9CF5B0E626F1.quest_desc: ["Os &eEmpacotadores&r são a nova e muito importante &6Máquina&r para o &6&lCreate&r. Para usar praticamente tudo da Atualização, precisaremos de um &eEmpacotador&r. \\nCombine um pouco do nosso recém-encontrado &ePapelão&r para fazer um Bloco de Papelão. Não, ainda não são &eCaixas&r e certamente não fazem nada. \\n\\nBem, exceto para Criar nosso &eEmpacotador&r! O &eEmpacotador&r será então colocado sobre um Bloco com um Inventário, como um Baú ou Barril. Você saberá que está conectado quando um dos lados mudar para parecer uma parede. \\n\\nEntão, quando receber um &4Sinal de Redstone&r, ele puxará todos os &eItens&r do Inventário para um &ePacote&r! Mais sobre isso depois! \\n\\nOs &ePacotes&r podem ser retirados à Mão ou por uma &eCorreia&r. Você também pode enviar &ePacotes&r de volta para o &eEmpacotador&r para colocar os &eItens&r de volta em um Inventário. \\n\\nSe você colocar e nomear uma Chapa no &eEmpacotador&r, ele dará um Endereço a todos os &ePacotes&r que ele fizer."]
	quest.672F9CF5B0E626F1.title: "&eEmpacotadores"
	quest.6737CB17D562B134.quest_desc: ["Apenas um clicador simples que clica com o item que lhe é dado."]
	quest.67482ED4B18F828D.quest_subtitle: "Ferro + Cuco Neon"
	quest.67482ED4B18F828D.title: "&fAbelha de Ósmio"
	quest.674A6B0EDA0D348B.quest_subtitle: "Teak + Mangrove"
	quest.674F28BCA2E4A3C8.quest_desc: ["Ao mover itens, os Roteadores podem ser bem gananciosos, pegando cada item que conseguem colocar suas anteninhas! \\n\\nCom o Augment Regulador, você pode limitar o quanto é movido."]
	quest.6751F2651063B3A5.quest_desc: ["Cogumelos de Sangue podem ser encontrados em seus Pântanos. \\n\\nEles têm a forma de Árvores de Carvalho Escuro e são principalmente Brancos com apenas alguns blocos tendo manchas de Sangue neles!"]
	quest.6754612E9AD4B9C0.title: "Reator (Ardente)"
	quest.67704F7341EDCC49.title: "&bMochila de Diamante"
	quest.677365A816994C8B.quest_desc: [
		"O &9Transmissor de Jogador&r carregará os itens de um jogador sem fio. Você deve primeiro vinculá-lo a um jogador usando um &9Cartão de Vinculação&r. Este é o cartão básico que permite que o transmissor funcione apenas na mesma dimensão. Você pode atualizá-lo usando um &dCartão de Vinculação (Dimensional)&r em vez disso."
		""
		"Nota: Para obter uma Pérola Aérea de Jogador, use uma Pérola Aérea em um Zumbi ou Casca."
	]
	quest.677A701E06422CF3.quest_desc: [" Escondido entre as árvores mais densas dos biomas de &2Floresta&r e &2Tropical&r, o &5Manto Folhoso&r aguarda o aventureiro digno. Tecido de milhares de &2folhas&r vivas, permite que seu portador se mova como se fizesse parte da &2própria floresta&r. \\n\\n- &lPossui 2 habilidades:&r \\n\\n1. &aCamuflagem&r: \\n Mova-se livremente dentro de folhas de árvores, pouse com segurança sem &cdano de queda&r e &2regenere&r &cvida&r &o&flentamente&r enquanto estiver na &afolhagem&r. \\n\\n2. &2Dádiva do Bosque&r: \\n Ao enfrentar um &cdano fatal&r, as &2folhas ao redor absorvem&r o &cgolpe&r, protegendo o portador da &cmorte&r. A quantidade de folhagem consumida depende do &cdano&r recebido. \\n\\n- Uma &6relíquia&r da &2natureza&r e do &acrescimento&r… onde a própria floresta luta por seu &9guardião escolhido&r."]
	quest.677A701E06422CF3.quest_subtitle: "Às vezes, a própria floresta protegerá aqueles que ela favorece..."
	quest.677A701E06422CF3.title: "&2Manto Folhoso"
	quest.677C5D35DADA4A42.quest_desc: ["&cO Acoplador&r serve para conectar ou desconectar &7Carrinhos&r. Acoplamento é a frase para conectar &7Carrinhos&r. \\n\\nPode ser configurado com uma &4Pé-de-cabra&r para acoplar, desacoplar ou acoplar automaticamente. Precisa de Redstone para funcionar."]
	quest.677C5D35DADA4A42.title: "Acoplador do &cKit de Trilhos&r"
	quest.677D0E27CAD7B145.quest_subtitle: "Alimente uma Abelha Slime Rosa com um Balde de Gás Éter"
	quest.677D0E27CAD7B145.title: "&fAbelha de Gás Éter"
	quest.6786B08C30D26037.quest_desc: [
		"Se você quiser uma dessas, precisará primeiro de uma Abelha Mineradora Cinzenta."
		""
		"Quando a Abelha Mineradora Cinzenta estiver aconchegada em seu ninho, há uma chance de uma Abelha Nômade tomá-lo."
	]
	quest.6786B08C30D26037.quest_subtitle: "Aparece em um ninho que tem uma Abelha Mineradora Cinzenta"
	quest.6786B08C30D26037.title: "&fAbelha Nômade"
	quest.67884BFA27870CCE.quest_desc: [
		"&dO Chamado Desvinculado de Osorin&r é o segundo nível de &drituais sem demônios&r. O primeiro nível não é útil para a progressão, é usado apenas para reviver Familiares e transformar Vexes em Allays."
		""
		"Este ritual é usado para criar uma tonelada de blocos, itens e materiais raros que você talvez não consiga (ou seja difícil de) obter de outra forma."
	]
	quest.67884BFA27870CCE.quest_subtitle: "Para aqueles de nós menos inclinados a câmaras de teste"
	quest.67884BFA27870CCE.title: "&dO Chamado Desvinculado de Osorin"
	quest.67940C0774E73217.quest_desc: ["O &eRoteador de Itens&r irá &9Entrar &eItens&r e &6Sair&r para locais específicos com base na Filtragem definida em sua UI! \\n\\nEles podem ser configurados para &eCorreias&r, Caixotes ou outros Inventários."]
	quest.67940C0774E73217.title: "&eItem Router"
	quest.679E80EBB9A2AE7E.quest_desc: ["&bFluid Routers&r classificam e filtram &bFluidos&r que passam por eles. \\n\\nVocê precisará definir as configurações em sua interface para definir os Filtros e qual Lado. Depois de fazer isso, ele pegará todos os &bFluidos&r que entrarem e os enviará para onde estão configurados para ir!"]
	quest.679E80EBB9A2AE7E.title: "&bFluid Router"
	quest.67A0F6661D658A52.quest_desc: ["Isto pode ser encontrado em qualquer uma das 3 Missões anteriores, mas sempre aparecerá no Labirinto de Células (Cell Maze). \\n\\nEle o apontará para o &5Pilar do Trono&r mais próximo. Siga essa &5bússola&r!"]
	quest.67A2347534269528.quest_desc: [
		"&9Sploogies&r podem surgir raramente, mas quando o fazem, estão destinados a irritá-lo. \\n\\nEles atirarão cuspe em você (e farão ruídos de sucção nojentos), mas se você os acertar, eles fugirão; semelhante a um filhote de Piglin. \\n\\nEles só dropam Pedregulhos de Depthrock ao morrer."
		"{image:atm:textures/questpics/undergarden/undergarden_sploogie.png width:125 height:100 align:center}"
	]
	quest.67A2347534269528.title: "&9Sploogie&r"
	quest.67A3611F07575F71.quest_desc: [
		"Aumento de Nível para 58."
		""
		"O Item de Assinatura é Gema de Luta."
	]
	quest.67A3611F07575F71.title: "&aLíder Big Mo"
	quest.67A46ED73E488CEE.quest_desc: ["Os &dGearshifts&r funcionam de forma semelhante a uma &dClutch&r, conectando-se aos nossos Sistemas e sendo alimentados por &4Redstone&r. \\n\\nNo entanto, em vez de parar a &dForça Rotacional&r, o &dGearshift&r mudará sua Direção! \\n\\nSe estiver indo no &e&osentido horário&r para dentro do &dGearshift&r energizado, sairá no &9&osentido anti-horário&r, e vice-versa."]
	quest.67A46ED73E488CEE.title: "&dGearshift"
	quest.67A9329C05F98633.quest_desc: ["Honestamente, se você não precisa de mais &aEnergia&r e prefere estar o mais seguro possível com seu &2&lReator&r, então simplesmente delete-o! \\n\\nAh, sim, você me ouviu! Simplesmente delete o Vapor! \\n\\nEu sei que muitas coisas são importantes no &2&lMinecraft&r e geralmente é melhor guardar essas coisas em vez de jogá-las fora... \\n\\nMas o Vapor é praticamente só para as Turbinas fazerem &aEnergia&r. \\n\\nNão precisa dele? Então, Encane-o para uma Lixeira Suprema!"]
	quest.67A9329C05F98633.title: "Jogue fora!"
	quest.67AA59BD340FEC62.quest_subtitle: "Tier: &63"
	quest.67AFCBCE7AAC3089.quest_desc: [
		"Para fazer uma Turbina girar, precisaremos destes componentes &cobrigatórios&r:\\n\\n- &9Rotor Bearings&r são colocados em uma extremidade do eixo da turbina. Isso pode ser em qualquer face, mas dita de onde o eixo se projeta. Geralmente é colocado no centro da face inferior.\\n\\n- &eRotor Shafts&r se estendem de um Rotor Bearing até o lado oposto da turbina, até um único bloco de Carcaça da Turbina, criando o eixo para a Turbina.\\n\\n- &9Rotor Blades&r fazem o rotor girar. Elas são colocadas nos Eixos do Rotor e podem ter vários blocos de comprimento. Cada Lâmina pode lidar com uma certa quantidade de vapor e determina quantas são necessárias com base nas taxas de produção do seu reator.\\n\\nAqui está um exemplo de uma configuração de Eixo Vertical para uma Turbina, com a Bobina de Turbina de Chumbo no topo.\\n"
		"{image:atm:textures/questpics/extremereactors/maxbasicturbine.png width:100 height:150 align:1}"
	]
	quest.67AFCBCE7AAC3089.title: "Criando o Eixo da Turbina"
	quest.67B87570C340C243.title: "Melhorias de Armadura"
	quest.67C1FC2100E5A73C.quest_desc: [
		"Aumento de nível para 73."
		""
		"Pode ser encontrado aleatoriamente em &9Ginásios&r que geram em &a#minecraft:village&r"
	]
	quest.67C1FC2100E5A73C.title: "&aLíder Koga"
	quest.67C76EDD4BCCFF3F.quest_desc: ["Através do &bVínculo Superior de Strigeor&r podemos fazer uma &bGema de Alma Vazia&r. \\n\\nElas podem ser usadas para transportar Mobs com segurança, ou para fazer a &d&lAlma de Dragão&r. \\n\\nPessoalmente, acho que deveríamos fazer ambos!"]
	quest.67C76EDD4BCCFF3F.title: "&bGema de Alma Vazia"
	quest.67C7EF299BEC37DE.quest_subtitle: "Voo Criativo"
	quest.67CCEFEBA4D79429.quest_desc: ["O &ePacto Divino&r é o mais difícil de obter, você precisará procurar em Vilas de Piglins e Pirâmides Ancestrais em &b&lO Outro&r para encontrá-los! \\n\\nÉ usado para criar o Cristal de Vínculo de Alma e os Multiblocos de Fim de Jogo!"]
	quest.67CCEFEBA4D79429.title: "&ePacto Divino"
	quest.67D38E8A57949B34.quest_desc: ["As &3Mandíbulas de Sculk&r são Blocos que podemos encontrar nas &9Terras Profundas&r. \\n\\nQuando você acidentalmente anda sobre elas, elas te morderão, isso te arrasta para baixo e causa Dano quando você está preso nelas. \\n\\nVocê pode pegá-las usando Toque Suave."]
	quest.67D38E8A57949B34.title: "&3Mandíbula de Sculk"
	quest.67DBE6C59C0D9D1B.quest_desc: ["Esta é a Essência de Tier 4, feita combinando 4 Imperium com um Cristal de Infusão."]
	quest.67DBE6C59C0D9D1B.quest_subtitle: "Tier: &c5"
	quest.67DBE6C59C0D9D1B.title: "&4Supremium"
	quest.67DDFA6FB1F9EECA.title: "Ferramentas de &9Imperium"
	quest.67E7A9A65B14C933.quest_desc: [
		"Conseguimos &7Aglomerados de Minério&r? O que fazemos com um &7Aglomerado&r, queríamos &7Barras&r! \\n\\nPara começar, &4Esmague &fcada &7Aglomerado&f para obter 2 &7Pós de Minério Sujo&r. \\n\\nNão podemos &6Fundir &7Pó Sujo&r, isso estragaria a Fornalha! Então precisaremos &dEnriquecê-los&r para obter nosso &7Pó&r comum. \\n\\nE como de costume, &6Funda &fo &7Pó &fpara obter &7Barras&r."
		"{image:atm:textures/questpics/mek/mek_tier2_2.png width:250 height:50 align:center}"
	]
	quest.67E7A9A65B14C933.quest_subtitle: "Processamento de Minério Tier 2"
	quest.67E7A9A65B14C933.title: "&4Triturar &fe &dEnriquecer &fnossos &7Pedaços"
	quest.67FB03BE6685AFE1.quest_desc: ["Para começar uma guerra, precisamos primeiro declará-la! \\n\\nBrincadeira, nós vamos direto para os tiros! Sem essa de diplomacia por aqui! \\n\\nPara começar, atire em um Pillager com um &d&lRevólver&r. \\n\\nIsso iniciará o surgimento de novos e mais difíceis Pillagers!"]
	quest.67FB03BE6685AFE1.title: "Ataque e Defesa"
	quest.680E960554CEE76B.quest_desc: [
		"Esses belos &5&lCanyons&r cercados por &6&lParedes de Colmeia&r estão cheios de... você adivinhou! &5Cristais&r! \\n\\nO chão é feito de &eCera Esculpível&r enquanto o resto está cheio de pequenos &5Cristais de Mel&r e enormes &5Cristais de Mel Luminosos&r."
		"{image:atm:textures/questpics/bumblezone/bumble_canyon.png width:200 height:100 align:center}"
	]
	quest.680E960554CEE76B.title: "&5&lCanyons de Cristal"
	quest.680ECE3D8DCDC515.quest_subtitle: "&f13 &cde Dano de Ataque"
	quest.681A3F31FB242555.quest_desc: ["O &3Etanol&r pode ser usado para fazer Biodiesel."]
	quest.681A3F31FB242555.title: "Etanol"
	quest.682034C680FDEDC2.quest_desc: [
		"A &aMatriz de Indução&r do &9Mekanism&r é uma das melhores maneiras de armazenar sua energia.\\n\\nSe você está procurando o melhor armazenamento de energia que o Mekanism tem a oferecer, confira o capítulo de missão &aMekanism:&r &dReatores&r.\\n"
		"{image:atm:textures/questpics/mek/mek_induction_matrix_small.png width:125 height:150 align:center fit:true}"
	]
	quest.682034C680FDEDC2.title: "Mais Armazenamento de Energia"
	quest.6827836C8E675A94.quest_desc: ["Esqueletos têm variantes diferentes, assim como os Zumbis! \\n\\n&bErrante&r - aparecem em Biomas Frios. \\n&2Pantanoso&r - aparecem em Pântanos e Câmaras de Desafio. \\n&9Afundado&r - aparecem debaixo d'água em Recifes de Coral. \\n&aMusgoso&r - aparecem em Selvas."]
	quest.6827836C8E675A94.title: "&fVariantes de Esqueleto"
	quest.683B58B699D4D381.quest_subtitle: "Aparece em um ninho que tem uma Abelha de Faixa Azul"
	quest.683B58B699D4D381.title: "Abelha Cuco Neon"
	quest.683C260C854C5AA3.quest_desc: ["A &4Bigorna de Fusão Mecânica&r será necessária para fazer combinações de Itens do &4&lCataclysm&r. \\n\\nVocê pode colocá-la como uma Bigorna normal, mas esta não tem Durabilidade... felizmente! \\n\\nVerifique o JEI para Receitas, você coloca 1 Item no Slot Esquerdo e o outro no Slot do Meio para obter o produto final no Slot Direito."]
	quest.683C260C854C5AA3.title: "&4Bigorna de Fusão Mecânica"
	quest.68446510A1B0D9B8.quest_desc: [
		"As &bCavernas Floridas&r são mais parecidas com Cavernas Exuberantes do que com Cavernas normais. Digo isso pela abundância de PLANTAS! \\n\\nVocê encontrará Plantas crescendo do teto ao chão, Plantas crescendo do chão ao teto, Plantas crescendo na &9Água&r, e Plantas que nem estão Crescendo! \\n\\nO chão é coberto por &bPedra de Sculk Florida&r e até &bMusgo Florido&r. \\n\\nHá até Lagos de Água aqui, o único lugar onde você pode encontrar &9Água&r nesta &3&lDimensão&r."
		"{image:atm:textures/questpics/deepndark/dnd_cave.png width:200 height:100 align:center}"
	]
	quest.68446510A1B0D9B8.title: "&bCavernas Floridas"
	quest.68498ADEF9765F81.quest_desc: ["Para fazer Pedaços de Menril Cristalizado, você primeiro precisa colocar algumas Troncos de Menril em um Espremedor. Pule no Espremedor para transformá-las em Resina de Menril.\\n\\nVocê pode esvaziar o Espremedor dando-lhe um sinal de Redstone."]
	quest.684BB9D2F2AC87A6.quest_subtitle: "Wenge + Cocobolo"
	quest.6852BEFDD4DE4E4B.quest_desc: ["&9Estantes Profundas Tocadas pela Alma&r são uma melhoria para as &9Estantes Profundas&r. \\n\\nElas são Criadas com uma &bLanterna de Alma&r e 3 &3Blocos de Sculk&r. Você precisará de &5Toque Suave&r para pegar os &3Blocos de Sculk&r. \\n\\nEntão, podemos Criar nossa versão &9Tocada pela Alma&r. Elas darão muito mais &cQuanta&r, com &c15%&r! \\n\\nTambém aumenta a &aEterna&r máxima para &a75&r."]
	quest.6852BEFDD4DE4E4B.title: "&9Estante Profunda Tocada pela Alma"
	quest.685C4A646E092A82.title: "Armadura de Supremium &6Desperta"
	quest.68618D5F4FC2F331.quest_desc: [
		"Sem aumento de nível."
		""
		"Encontrado no 1º andar da &cLiga Kanto&r."
	]
	quest.68618D5F4FC2F331.title: "&3Elite dos Quatro Lorelei"
	quest.686B25F2E9D8CC97.quest_desc: ["Na época em que escrevo isto, é final de julho, então tenho cerca de 3 meses até o Halloween. Mas nunca é cedo demais para começar a ficar Assustador! Assim como a Spirit Halloween, podemos ficar Assustadores 3 meses antes de realmente começar. Desta vez, Clicando com o Botão Direito em uma Fornalha com o Spook-alator! Quando for a hora de começar a se preparar para o Dia de Ação de Graças, Clique com Shift e Botão Direito nelas para Des-Assustadorizar!"]
	quest.686B25F2E9D8CC97.quest_subtitle: "\"Isto é Halloween\""
	quest.6877F33323910716.quest_desc: ["O Armazenamento de Bolso Tier 4 tem 64 Slots para Itens e cada um comporta 1.048.575 Itens. Isso dá um total de 67.108.800 Itens. Saiam da frente, Mochilas, vocês foram substituídas! \\n\\nCusta apenas algumas Estrelas do Nether, o que em Modded, honestamente, não é caro pelo que você recebe!"]
	quest.6884E25641A1020C.quest_desc: ["A &5Biblioteca de Encantamentos&r é o maior armazenamento de &5Livros Encantados&r de todos os tempos! \\n\\nPara criá-la, você precisará de 4 &3Baús do End&r, 1 &5Mesa de Encantamento&r e 4 de qualquer uma das &7Estantes&r &d&lInfundidas&r: &4Estante Infernal Infundida&r, &bEstante de Livro Marinha Infundida&r e &9Estante de Livros Profunda&r. \\n\\nPara usá-la, você pode clicar com Shift e botão esquerdo em &5Livros Encantados&r ou trazê-los para o &9Slot Azul&r. Isso adicionará os &5Livros&r à &5Biblioteca&r. \\n\\nOs &5Livros&r são classificados por nome e mantidos em Pontos. Cada Nível de &5Livro Encantado&r determina o Nível, e isso se reflete em quantos &5Livros&r seriam necessários para obter esse Nível. Nível 1 é 1 Ponto. Nível 2 são 2 Pontos. Nível 3 são 4 Pontos. Nível 4 são 8 Pontos. \\n\\nCada &5Livro&r é armazenado até um máximo de 32768 Pontos, e eles podem ser extraídos clicando com o botão esquerdo no &5Livro&r armazenado. Cada clique adicionará outro Nível ao &5Livro&r no &6Slot Laranja&r. \\n\\nVocê pode clicar em diferentes &5Livros&r para adicionar ao &5Livro&r no &6Slot Laranja&r, semelhante a combinar &5Livros&r em uma Bigorna. \\n\\nO Nível máximo do &5Livro Encantado&r é determinado pelo Nível mais alto de &5Livro&r que você inseriu. Não importa se você tem 32000 Pontos, se você só colocou &5Afiação III&r, você só pode retirar &5Afiação III&r."]
	quest.6884E25641A1020C.title: "&5Biblioteca de Encantamentos"
	quest.6889EFC6CC291463.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		""
		"Repele mobs próximos quando ativado, tem um tempo de recarga."
	]
	quest.6893D537716AA748.quest_desc: ["&dEngrenagens&r (&dCogs&r) são o próximo Bloco necessário para usar &dForça Rotacional&r! Elas podem se conectar a &8Eixos&r ou outras &dEngrenagens&r para mover a &dForça Rotacional&r. \\n\\nExistem duas versões de &dEngrenagens&r: &dEngrenagens &rregulares e &dEngrenagens Grandes&r. Ambas agirão da mesma forma no sentido de &dForça Rotacional&r, mas também há algumas mudanças! \\nAs &dEngrenagens&r regulares podem se conectar a outras &dEngrenagens&r adjacentes a elas. Isso moverá a &dForça Rotacional&r em uma direção totalmente diferente. Quando isso acontece, a direção da segunda &dEngrenagem&r será invertida. Se a primeira &dEngrenagem&r estiver girando no &e&osentido horário&r, a segunda girará no &9&osentido anti-horário&r. \\n\\nAs &dEngrenagens Grandes&r são um pouco mais difíceis de usar do que as &dEngrenagens&r. Elas não podem se conectar a outras &dEngrenagens Grandes&r adjacentes, mas sim apenas a &dEngrenagens&r que estão na diagonal delas! \\n\\nA maioria das &6Máquinas&r precisará de &dForça Rotacional&r de &dEngrenagens&r conectadas. Você reconhecerá se a &6Máquina&r tem uma &dEngrenagem&r interna, que é o que deve ser movido para usar a &6Máquina&r."]
	quest.6893D537716AA748.quest_subtitle: "Eu só as chamo de Cogs"
	quest.6893D537716AA748.title: "&dEngrenagens&r!"
	quest.68972BA647FDCF8F.quest_desc: ["Se você conhece o &l&6Productive Bees&r, deve conhecer o LobsterJonn. Ele criou o &l&6Productive Bees&r e o &lGenerator's Galore&r (junto com muitos outros). O &6Gerador de Mel&r é uma boa maneira de conectar esses dois mods! O &6Gerador de Mel&r usa &6Mel Líquido&r para gerar Energia."]
	quest.68972BA647FDCF8F.title: "&6Gerador de Mel"
	quest.689F32883C4E9502.quest_desc: ["&4&lCataclsym&r é um mod que adiciona novos chefes, masmorras e, claro, saques! \\n\\nNão há um padrão certo de quais chefes matar primeiro, mas alguns são mais fortes que outros, e alguns dão saques que ajudarão contra os outros. \\n\\nConfira os Olhos para encontrar as Estruturas específicas que você precisará localizar!"]
	quest.689F32883C4E9502.title: "&4&lCataclysm"
	quest.68B0B3DAF1145191.quest_desc: ["Duas das primeiras coisas que você precisará para começar no AE2 são o &bCarregador&f e o &bInscritor&f.\\n\\nO &bCarregador&f, quando abastecido com energia, pegará &eCristais de Quartzo Certus&r e os carregará. Esses &eCristais de Certus Carregados&r podem então ser usados na produção de &eFluix&f, outro recurso importante no mod. Ele também pode ser usado para carregar qualquer item que armazene energia.\\n\\nO &bInscritor&f pode ser usado para transformar os vários cristais de quartzo do AE2 em sua forma de pó, mas, mais importante, é usado para fabricar &eCircuitos Impressos&f e &eProcessadores Especiais&f, como ficará mais claro na próxima missão."]
	quest.68B0B3DAF1145191.quest_subtitle: "Vamos por partes, ou não!?"
	quest.68B0B3DAF1145191.title: "&eComeçando pelo Inicio"
	quest.68B2D3B985FC1378.quest_desc: [
		"Uma Floresta brilhante e bela, cheia de Árvores Torreya e Vinhas."
		"{image:atm:textures/questpics/eternal/starlight_torreya.png width:200 height:100 align:center}"
	]
	quest.68B2D3B985FC1378.title: "Floresta Torreya"
	quest.68CE30097BADE20E.quest_desc: ["Clicar com o botão direito em um Ninho do tipo que você está procurando o apontará na direção de outro!"]
	quest.68CE30097BADE20E.title: "&fProcurando por &6Ninhos"
	quest.68DABFFB6B3E1A57.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_eye.png width:100 height:150 align:center}"]
	quest.68DABFFB6B3E1A57.quest_subtitle: "Stronghold"
	quest.68DABFFB6B3E1A57.title: "Ornamento de Armadura do Olho"
	quest.68DFFEA05553B67E.quest_subtitle: "Cloggrum + Frosty"
	quest.68DFFEA05553B67E.title: "Abelha de Aço Gelado"
	quest.68E6AE1B9EBCEFFF.title: "Maça de &3Vibranium"
	quest.68EAB0248989FC97.quest_desc: [
		"A &#EDD653&nFornalha a Vapor&r desbloqueia novos horizontes de progresso. Este será um multibloco essencial em seus futuros empreendimentos."
		""
		"Esse multibloco não apenas permitirá fabricar &7Barras de Aço&r, mas também processar &#696E60Óleo Sintético Bruto&r em &#494D43Óleo Sintético&r, que será usado posteriormente para &#36472ABorracha&r e outras coisas."
	]
	quest.68EAB0248989FC97.title: "&fO &eAlto-forno a Vapor"
	quest.68F92455A9483AD6.quest_desc: ["Você só verá esta missão se tiver usado Jet Boots.\\n\\nNão há como usar Jet Boots sem sofrer dano, nem tente..."]
	quest.68F92455A9483AD6.quest_subtitle: "Você achou que usar um Élitros era difícil?"
	quest.68F92455A9483AD6.title: "Jet Boots"
	quest.6904EC449FBEE387.quest_desc: ["Os &9Cabos&r são usados para conectar blocos e itens ao seu sistema.\\\\n\\\\nNo início, você pode se virar colocando blocos um ao lado do outro para conectá-los ao seu sistema, mas os Cabos permitem que você se expanda! Este é um item essencial para qualquer grande rede RS."]
	quest.6904EC449FBEE387.quest_subtitle: "Conectando o Sistema"
	quest.6904EC449FBEE387.title: "Cabos"
	quest.690B89D23134B624.quest_desc: [
		"Pegue seus gizes, desenhe seu ritual &dContato de Ronaza&r, e prepare-se para criar o GIZ DEFINITIVO*!"
		""
		"Em vez de carregar um conjunto completo de 16 gizes, você pode usar o &zGiz de Arco-íris&r para pintar uma Runa que muda de cor e conta como qualquer um deles!"
		""
		"&8*Não inclui o Giz de Fundação. Fabrique o Giz do Vazio para incluí-los&r"
	]
	quest.690B89D23134B624.title: "&zGiz de Arco-íris&r"
	quest.690CFF61CE787D43.quest_desc: ["Plástico é o principal recurso do &bIndustrial Foregoing&r, agora você tem acesso a algumas máquinas muito úteis!"]
	quest.690DB8BEF80617E5.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_utherium.png width:100 height:150 align:center}"]
	quest.690DB8BEF80617E5.title: "&cUtherium&r"
	quest.69201157ECFBB426.quest_desc: ["Eu sempre odeio quando tenho uma Fazenda de &5Endermen&r para XP ou Gemas de Apotheosis, mas acabo com todas essas &3Pérolas do End&r (hehe, acabo com, &3Pérolas do End&r). Agora você pode usar essas &3Pérolas do End&r para Energia com o &3Gerador do End&r. Você pode até fazer &aOlhos do End&r para ainda mais Energia!"]
	quest.69201157ECFBB426.title: "&3Gerador do End"
	quest.692183ACBB2AABF7.quest_desc: ["Relíquias são achados raros pelo seu Mundo &2&lMinecraft&r! \\n\\nElas podem ser usadas em sua &6&lForja&r, nos quadrados ao redor do slot central, estes se abrem mais à medida que você melhora os Tiers! \\n\\nOu você pode usá-las no &l&bClibano&r. \\n\\nAlgumas são apenas do Modo Criativo, não se preocupe, sabemos o quanto você ama seus Itens OP e estaremos procurando maneiras de adicioná-los!"]
	quest.692183ACBB2AABF7.title: "&lRelíquias"
	quest.692BC8AADCBF76C3.quest_subtitle: "Feito na Fundição de Ligas"
	quest.692BC8AADCBF76C3.title: "&fAbelha de Liga Energética"
	quest.69383DA579901E7E.quest_subtitle: "Deixe-me te fazer uma pergunta"
	quest.69396F87A09FBD85.quest_desc: ["Todas as Picaretas mineram no mesmo Nível de Mineração, então a única necessidade de aprimorar é para ser mais rápido e obter os Cajados."]
	quest.69396F87A09FBD85.title: "Picareta Caótica"
	quest.69439426534EBDC4.quest_desc: ["&bPunhos Flamejantes&r são outro Item que podemos fazer com &bIgnitium&r! \\n\\nÉ um Item de Curio que vai em suas Mãos. \\n\\nQuando usado, todos os ataques têm uma chance de dar ao alvo a &bMarca Flamejante&r. \\n\\nIsto diminui a Armadura e a Resistência da Armadura, e é ruim de conseguir do &b&lIgnis&r."]
	quest.69439426534EBDC4.title: "&bPunhos Flamejantes"
	quest.6950FC974624C6AA.quest_subtitle: "Tier: &63"
	quest.695889817162EFC7.quest_desc: ["&aEXP&r é muito importante para &5&lEncantamentos de Apotheosis&r! Cada &5Encantamento&r requer! (Por que você acha que eu dou em toda Recompensa?) \\n\\nCom &d&lInfusão&r podemos transformar &6Garrafas de Mel&r em &aFrascos de Encantamento&r. Na verdade, temos 3 &d&lInfusões&r diferentes para isso! Vai de 1 &aFrasco de Encantamento&r, para 8, para 32! \\n\\nPrimeiro, é para 1 &aFrasco&r e precisa apenas de 2 &9Ecos de Estantes de Sculk&r. \\n\\nSegundo, é para 8 &aFrascos&r e precisa de 5 &9Ecos de Estantes de Sculk&r e 1 &9Estante de Sculk Tocada pela Alma&r. \\n\\nPor último, é para 32 &aFrascos de Encantamento&r e precisará de 5 &9Ecos de Estantes de Sculk&f, 3 &9Tocadas pela Alma&f, e 1 &dEstante do End Dracônica&r!"]
	quest.695889817162EFC7.title: "Criando &aEXP&r?"
	quest.69642A3618E86DED.quest_desc: [
		"Para construir a estrutura do &aReprocessador&r, você precisará de muitas Carcaças. Isso também significa muito Cianeto.\\n\\nComece construindo uma estrutura oca de 3 blocos de largura, 3 blocos de profundidade e 7 blocos de altura. Esta é a estrutura.\\n\\nSe feito corretamente, você terá um espaço vazio no meio da face inferior e superior. Para as faces verticais, você pode usar &aVidro de Reprocessador&r ou uma das partes &aReprocessador&r necessárias, como a Porta de Energia, Controlador, etc.\\n\\nSe você quiser ver uma imagem de como a estrutura ficará, confira a próxima página!"
		"{@pagebreak}"
		"A estrutura do multiblock Reprocessador.\\n"
		"{image:atm:textures/questpics/extremereactors/reprocessorframe.png width:100 height:175 align:1}"
		"{@pagebreak}"
		"Um Reprocessador totalmente construído:\\n"
		"{image:atm:textures/questpics/extremereactors/reprocessorfull.png width:100 height:150 align:1}"
	]
	quest.69642A3618E86DED.title: "Construindo a Estrutura"
	quest.696A33E7D91A487E.quest_desc: ["&9Cindaria&r são Mobs de Água-Viva/Humana que protegem &9Acropolis&r. Eles são esverdeados/púrpura e transparentes. \\n\\nEles têm 60 &4Corações&r sem Armadura. \\n\\nEles também empunham o que parece um Guarda-chuva, mas na verdade é uma Arma mortal! \\n\\nSe você estiver muito perto, eles balançarão sua Arma para te atingir com ela. Se estiver mais distante, eles lançarão uma &9Lança de Raios&r em você. \\n\\n&9Lanças de Raios&r ricocheteiam nas Paredes, felizmente &9Acropolis&r não tem muitas delas! \\n\\nAo morrer, os &9Cindaria&r vão soltar &9Lacrima&r."]
	quest.696A33E7D91A487E.title: "&9Cindaria"
	quest.696E063016CAD1B9.quest_desc: ["Adiciona interfaces de criação para Bancadas de Trabalho Chipped à sua Mochila."]
	quest.6973A5923AF7BF05.quest_desc: ["O Exportador Elite tem 18 espaços para filtros e funciona 2x mais rápido."]
	quest.69986817D58AC8BE.quest_desc: ["Os Estabilizadores são o que formam o Campo de Contenção (Escudo de Força ao redor do Núcleo do Reator). Uma vez que o Escudo de Contenção chegue a 0 enquanto o Reator está ligado, ele começará um Colapso. Todos os 4 Estabilizadores precisam estar a alguns blocos de distância (5 ou mais) do Núcleo e precisam estar no mesmo Eixo que o Núcleo para funcionar. É também por aqui que você irá extrair OP do Reator, mas não muito!"]
	quest.69986817D58AC8BE.title: "Estabilizadores do Reator"
	quest.69A517AB8A801939.quest_desc: ["&0&lO Wither&r é um dos chefes mais difíceis de matar no &2&lMinecraft&r. Principalmente porque ele voa. E explode. E é rápido. Você entendeu. \\n\\nPara invocá-lo, coloque as 4 Areias das Almas em forma de T. Coloque os 3 Crânios de Esqueleto Wither no topo do 'T' e o &5Wither&r irá gerar. \\n\\nEle terá 300 &4Corações&r de Vida cheia, então começará a voar e atirar &0Crânios de Wither&r em você! \\n\\nSe você deixá-lo com metade da vida, ele se tornará invulnerável a projéteis como o &d&lEnder Dragon&r. Aqui você precisará começar a bater nele. \\n\\nQuando você matá-lo, ele deixará cair uma Estrela do Nether! \\n\\n(P.S. Se &0&lO Wither&r matar uma Criatura, ela deixará cair uma &0Rosa do Wither&r!)"]
	quest.69A517AB8A801939.title: "&l&8O Wither"
	quest.69B766907C1226C0.quest_desc: ["O &cDynamax&r precisa de um &cPonto de Energia&r a no máximo 20 blocos de distância da batalha. \\n\\nNão sei se são 20 blocos de distância de você, do seu &cPokémon&r ou daquilo que você está enfrentando... apenas fique perto de todos eles para ter certeza. \\n\\nVocê precisará de uma Estrela do Desejo e de um &cCogumelo Max&r para criar um."]
	quest.69B766907C1226C0.title: "&cPonto de Energia"
	quest.69B7DE2283B4EE6C.quest_desc: ["A &bUnidade de Co-processamento de Criação&f ajuda a acelerar os trabalhos de criação, permitindo que os provedores de padrões enviem itens para seus dispositivos conectados mais rapidamente ou trabalhem simultaneamente para fazer vários ingredientes necessários.\\n\\nA unidade de co-processamento base do AE2 fornece uma 'thread' de co-processador para auxiliar nisso, enquanto a unidade de co-processamento de &dMEGA Células&f fornece 4 threads em um único bloco."]
	quest.69B7DE2283B4EE6C.quest_subtitle: "Baixe mais núcleos de CPU"
	quest.69B7DE2283B4EE6C.title: "&eUnidade de CO-Processamento de Fabricação"
	quest.69EAC857B2CCB045.quest_desc: ["Derrotá-los aumentará seu Limite de Nível para 48. \\n\\nSeu Item de Assinatura é uma &dBola de Fumaça&r."]
	quest.69EAC857B2CCB045.title: "&7Comandante Mars e Jupiter"
	quest.69EE22CB4FF1E591.quest_desc: ["&aEngenhocas&r são muito difíceis de entender, mas basicamente é a arte de combinar diferentes Blocos e &6Máquinas&r em um sistema móvel. \\n\\nVocê precisará de &6Máquinas&r para realmente mover a &aEngenhoca&r, como &aChassi Linear&r, você precisará das &6Máquinas&r que você quer que funcionem, como &6Brocas&r, e você precisará de &aCola&r para manter tudo junto! \\n\\nUma vez que tudo esteja &aColado&r, deve se mover quando &dForça Rotacional&r for fornecida à &6Máquina&r móvel da &aEngenhoca&r."]
	quest.69EE22CB4FF1E591.title: "&a&lEngenhocas"
	quest.69F63F3B48E4344E.quest_subtitle: "Tier: &63"
	quest.6A07D09831428CB9.quest_desc: [
		"&4&lO Nether&r pode ser bem assustador, se você prefere viajar pelo &bMar&r, use &bEstantes de Livro Marinho&r! \\n\\nAs &bEstantes de Livro Marinhas&r são sua introdução à &5Arcana&r, elas dão &53% de Arcana&r e &a3 de Eterna&r. \\n\\nMelhor que &7Estantes&r normais, certo? \\n\\nVocê vai precisar de 16 para &d&lInfusão&r... bem, 15 para &d&lInfusão&r, 1 para ser &d&lInfundida&r! \\n\\nComo as &4Estante de Livros Infernais&r, eu te darei extras, apenas colete 11 agora!"
		"{image:atm:textures/questpics/apothic/enchant_seashelf.png width:100 height:100 align:center}"
	]
	quest.6A07D09831428CB9.title: "&bEstante de Livro Marinha"
	quest.6A1145678E80FB8E.quest_desc: ["Há tantos &5Encantamentos&r inúteis por aí, por que não tirar um pouco de Energia deles! O &bGerador de Encantamentos&r usa &5Livros Encantados&r para gerar Energia. O Nível e a Raridade dos &5Livros Encantados&r mudam a quantidade de Energia que você obtém deles."]
	quest.6A1145678E80FB8E.title: "&bGerador de Encantamentos"
	quest.6A1174845810C7A1.quest_desc: ["A &7&lEstação de Modificação&r é como nós vamos instalar nossas &7Unidades de Módulo&r em nossas Ferramentas e Armaduras. \\n\\nEla precisará de &aEnergia&r para operar, porque é claro que precisa. \\n\\nQuando você Clica com o Botão Direito em uma &7&lEstação de Modificação&r (energizada), ela abrirá sua GUI. Aqui podemos ver todo o nosso Inventário, incluindo Armadura e mão secundária. Nós também temos uma Tela e 2 Slots extras. \\n\\nOs 2 Slots extras são onde nossas &7Unidades de Módulo&r (Slot da Esquerda) e nossas Armaduras ou Ferramentas que queremos adicionar as &7Unidades de Módulo&r vão (Slot da Direita). \\n\\nAssim que ambos forem adicionados em seus Slots, eles colocarão automaticamente as &7Unidades de Módulo&r no &eItem&r. Se elas permanecerem no Slot, podemos visualizar as &7Unidades de Módulo&r instaladas no &eItem&r na Tela. \\n\\nSe você quiser remover uma &7Unidade de Módulo&r, clique nela na Tela e então aperte o Botão de Remover. \\n\\nQuando tivermos &7Unidades de Módulo&r instaladas, podemos apertar (\\\\) para abrir suas Configurações. Aqui podemos Ativá-las ou Desativá-las, e mais! "]
	quest.6A1174845810C7A1.title: "&l&7Estação de Modificação"
	quest.6A12188E50EAEB78.quest_desc: ["As &zFornalhas de Arco-íris&r irão fundir uma pilha de Itens de cada vez! \\n\\nPara criá-la, você precisará de um &zNúcleo de Arco-íris&r que precisa de 2 &cFornalhas de Netherita&r e todas as &zCores do Arco-íris&r em Vidro! \\n\\nEntão, você precisará de &zRevestimento de Arco-íris&r, que você obtém combinando quase todas as outras Fornalhas do mod. Você precisará de 2 delas para criar o &3&lDispositivo de Probabilidade Improvável&r."]
	quest.6A12188E50EAEB78.title: "2 &zFornalhas de Arco-íris"
	quest.6A18B971C3DB83AE.quest_subtitle: "Tier: &63"
	quest.6A1C0B17B22CE50F.quest_desc: ["O &9Amuleto de Impulso de Mana&r dá um impulso à mana máxima. \\n\\nO &6Amuleto de Regeneração de Mana&r dá um impulso à sua regeneração de mana."]
	quest.6A1C0B17B22CE50F.title: "Os Amuletos"
	quest.6A21228B0511FF85.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_thermal.png width:100 height:150 align:center}"]
	quest.6A21228B0511FF85.title: "&6Thermal Springstone&r"
	quest.6A25ED4059E224D2.quest_desc: [
		"A &#ED5585Destilaria&r é usada para destilar certos líquidos e obter saídas melhores e mais adequadas para nosso uso."
		""
		"Você deve &cbloquear&r a receita para obter o que deseja se uma única entrada produzir várias saídas. "
		""
		"Primeiro, clique no ícone de cadeado na interface, clique na seta e então no ícone &7'+'&r na receita desejada."
	]
	quest.6A25ED4059E224D2.quest_subtitle: "Bloquear a receita"
	quest.6A25ED4059E224D2.title: "&5Destilaria"
	quest.6A2AD67569F91F1F.quest_subtitle: "Tier: &c5"
	quest.6A2B2C5E2ADCE366.quest_desc: ["Sophisticated Backpacks oferece Mochilas aprimoráveis que podem usar filtros para adicionar recursos interessantes!\\n\\nAs Mochilas podem ser colocadas no seu slot de Curios das costas e podem ser tingidas."]
	quest.6A2B2C5E2ADCE366.quest_subtitle: "Inventários são muito pequenos"
	quest.6A2B2C5E2ADCE366.title: "Sophisticated Backpacks"
	quest.6A393C7A24899E3E.quest_desc: ["Colocar um Barra no Grader com um Catalisador de Grader dará ao material uma nota.\\n\\nQuanto melhor a nota, melhores são os atributos do material.\\n\\nA melhor nota é \"MAX\"."]
	quest.6A393C7A24899E3E.quest_subtitle: "O Testador de Materiais"
	quest.6A452BFC8A967C39.quest_desc: ["Usar estas &aGarras&r simplesmente faz você se sentir de uma certa maneira. Adrenalina bombeando, pensamentos cessando, força aumentando como nenhuma outra! \\n\\nCom &aGarras Ferais&r você atacará muito mais rápido com suas Armas ou Punhos."]
	quest.6A452BFC8A967C39.quest_subtitle: "Mãos"
	quest.6A452BFC8A967C39.title: "&aGarras Ferais&r"
	quest.6A46A9F04D2A0748.quest_desc: ["Direwolf é um nome sinônimo de Minecraft Modificado e &3&lJust Dire Things&r é uma de suas criações. \\n\\nEle gira em torno de Gosma, sim, eu sei, parece tentador!"]
	quest.6A46A9F04D2A0748.title: "&3&lJust Dire Things"
	quest.6A497B063CF32A5C.quest_desc: [
		"O &cOlho de Aranha Fermentado&r pode ser usado para aumentar a quantidade de mobs que &6PODEM&r nascer de um gerador.\\n"
		"Os mobs gerados são aleatórios, com uma quantidade máxima determinada pelo número.\\n"
		"Esse valor aumenta ou diminui em 1 para cada olho, até um máximo de 16."
	]
	quest.6A497B063CF32A5C.title: "&cContagem de Surgimento"
	quest.6A4D31194C4CE156.quest_desc: [
		"Melhorias Válidas:"
		"- Ore Miner"
		"- Lawnmower"
		"- Sky Sweeper"
		"- Tree Feller"
		"- Leaf Breaker"
		"- Auto Smelter"
		"- Hammer"
		"- Drops Teleporter"
		"- X-Ray"
		"- Instant Break"
	]
	quest.6A6CD8024A4E9075.quest_desc: ["No &b&lO Outro&r você encontrará &6Arvores de Bolotas&r, só que estas vêm com um tipo diferente de &6Bolotas&r! \\n\\n&6Bolotas&r de &6Allthemodium&f e &3Vibranium&f ! \\n\\nAs &6Arvores&r funcionam exatamente como &6Arvores de Bolotas&r normais: você pode colher as &6Bolotas Brilhantes &fda &6Árvore&r, derrubá-la para obter a Madeira e replantá-las para mais &6Árvore de Bolotas&r.\\n\\nDepois de coletar &6Bolotas&r de &6Allthemodium&f e &3Vibranium&f, você pode trocar com um Comerciante do Poké Mart pelo último, &5Unobtainium."]
	quest.6A6CD8024A4E9075.title: "&6Bolotas&r de Metal &6&lAllthemodium&r"
	quest.6A8E748B642DD16F.quest_desc: [
		"É aqui que o &bSal&r será mantido. \\n\\nO tipo de &bSal&r importa para o que você tentará Incubar. Se você quiser fazer Unobtainium, precisará de &bSal Mineral&r, se quiser Trigo, precisará de &bSal Vegetal&r, e assim por diante."
		"{image:atm:textures/questpics/theurgy/theurgy_vessel_2.png width:100 height:125 align:center}"
	]
	quest.6A8E748B642DD16F.title: "Recipiente de &bSal&r"
	quest.6A962535CD68713E.quest_desc: ["&e&lPipez&r se movem mais! \\n\\nTodas as Melhorias aumentam a quantidade que os &e&lPipez&r se movem e também oferecem mais opções para usar com o &e&lPipe&r. \\n\\nA Melhoria Básica permite a Ativação por Redstone com os &e&lPipez&r, para mudar a distribuição para: Mais Próximo Primeiro, Mais Distante Primeiro, Round-Robin, ou Aleatório, e adicionar Filtros.\\n\\nAs melhorias Melhorada, Avançada e Ultimate não oferecem nada novo, elas apenas movem mais!"]
	quest.6A9AE3514B5151C9.quest_desc: ["As &#CFB951Bobinas de Kanthal&r nos permitirão processar &#C356C4Titânio Bruto&r em &#DF9DE0Barras Quentes de Titânio&r. Este processo requer &#D49B70Solução Sulfúrica de Manganês&r."]
	quest.6ABDBE41880CFDA9.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os packs &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pack público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.6ADDFD55AD0DF7D4.quest_desc: ["Combinar &9Barras de Ridiculite&r com &cRossinite&r em um &aReprocessador&r criará &dBarras de Inanite&r.\\n\\nAgora podemos usá-los para fazer um bloco de &dInanite&r."]
	quest.6ADDFD55AD0DF7D4.title: "Inanite"
	quest.6ADE6F9E004055F7.quest_desc: [
		"Os Cristais de Tempo são um novo material adicionado por JDT. Eles crescem em Blocos de Drusa Cristal de Tempo, que são criados ao espalhar goo em Blocos de Drusa de Ametista ou Blocos de Cristal de Tempo.\\n\\nNO ENTANTO, o Bloco de Drusa de Cristal de Tempo deve coletar tempo do &9Mundo Superior&r, do &6Nether&r, e do &aEnd&r para poder crescer Agregados de Cristal de Tempo. Você NÃO PODE quebrar ou usar toque suave no Bloco de Drusa de Cristal de Tempo. Você deve usar um Trocador, Caixa de Papelão, ou Gadget de Cortar e Colar para movê-los.\\n\\nDepois de um tempo, o Bloco de Drusa de Cristal de Tempo vai &2ficar sem energia&r, e deverá fazer outra viagem para o &9Mundo Superior&r, &6Nether&r, e &aEnd&r."
		"{@pagebreak}"
		"Para automatizar esse processo, veja o vídeo linkado na imagem acima desta missão.\\n\\nE se a &2codificação de &zcores&r na página anterior não foi suficiente, adicionei uma imagem para ajudar você a identificar em qual estágio está cada Bloco de Drusa de Cristal de Tempo."
		""
		"{image:atm:textures/questpics/justdirethings/budding_time_crystal_reference.png width:250 height:125 align:center}"
	]
	quest.6ADE6F9E004055F7.quest_subtitle: "Tempo Louco"
	quest.6ADE6F9E004055F7.title: "Cristal de Tempo"
	quest.6AE0A69DB3CDBCAA.quest_subtitle: "Maçã-doce + Azaleia Florida"
	quest.6B00D5DBB3552F15.quest_desc: [
		"Tangleds são inimigos que surgem no Jardim Amaldiçoado. \\n\\nEles têm 10 Corações e atacarão dando tapas em você. Se você for atingido, receberá uma pequena quantidade de veneno. \\n\\nAo morrer, eles droparão Vinhas e Ossos, mas também gerarão uma Caveira de Tangled! \\n\\nAs Caveiras de Tangled agem de forma semelhante aos Vexes, voarão através de blocos e o atingirão. Elas têm apenas 5 Corações e, ao morrer, lhe darão elas como um Item."
		"{image:atm:textures/questpics/eternal/starlight_tangled.png width:150 height:100 align:center}"
	]
	quest.6B00D5DBB3552F15.title: "Tangled"
	quest.6B04FC81351CD1AB.quest_desc: ["Se você quiser acessar sua rede RS sem fio, precisará começar criando um &3Transmissor Sem Fio&r.\\n\\nVocê pode conectá-lo em qualquer lugar do seu sistema. Isso é necessário para usar &9Grade Sem Fio&r."]
	quest.6B04FC81351CD1AB.quest_subtitle: "O Século 21"
	quest.6B04FC81351CD1AB.title: "&5Acesso Sem Fio"
	quest.6B0CD6732BE0E819.quest_desc: ["Literalmente apenas Salto Impulsionado."]
	quest.6B0CD6732BE0E819.title: "Módulo de Salto Básico"
	quest.6B0D84B730C6C76C.quest_desc: ["As 16 Cores que o &2&lMinecraft&r te dá não são suficientes? \\n\\nBem, eu acho que você poderia ter mais 18! \\n\\n&l&cDy&6en&ea&ami&bcs&r nos dá mais 18 Corantes, todos os quais podem ser usados para os mesmos Itens e Blocos que os Corantes do &2&lMinecraft&r! \\n\\nVocê quer uma Vela &6Pêssego&r? Você pode ter uma! Você quer um Shulker &dBubblegum&r? Por que não! Você quer uma Cama &eFluorescente&r? Claro!"]
	quest.6B0D84B730C6C76C.title: "&l&cDy&6en&ea&ami&bcs&r"
	quest.6B1C06C753C10E44.quest_desc: ["O &3Configurador de Logística&r pode ser usado para configurar Estruturas Logísticas e Gadgets de Transferência."]
	quest.6B2027DA7AA6FF34.quest_desc: ["&9Powah&r é um mod de tecnologia focado em gerar, armazenar e transmitir &dEnergia&r. Variando de geração básica de FE a &aReatores&r que produzem &b250k FE/t&r, Powah tem tudo o que você precisa!\\n\\nPara começar, saia e minere um pouco de &aUraninita&r!"]
	quest.6B2027DA7AA6FF34.title: "&aBem-vindo ao &9Powah&r!!!"
	quest.6B2BD6F939136F50.quest_desc: ["A Plataforma Giratória é bem simples. A face superior com o quadrado &7Cinza&r será a parte móvel. \\n\\nAs outras faces são as &4Portas de Redstone&r, onde você dará um &4Sinal de Redstone&r para ativá-la. \\n\\nQuando ativada, ela girará qualquer Bloco que esteja anexado ao Topo. \\n\\nVocê pode precisar usar seu &6Martelo de Engenheiro&r nela para mudar como ela gira!"]
	quest.6B3BD54A34EB02C2.quest_desc: ["Os &aProvedores de Indução&r são colocados dentro da &a&lMatriz de Indução&r e aumentarão a quantidade de &aEnergia&r que ela pode receber e enviar. \\n\\nE sim, seus totais se somarão! \\n\\n&aProvedores de Indução Básicos&r: recebem e enviam 102.4kFE por Tick. \\n\\n&cProvedores de Indução Avançados&r: recebem e enviam 819.2kFE por Tick. \\n\\n&bProvedores de Indução de Elite&r: recebem e enviam 6.55MFE por Tick. \\n\\n&5Provedores de Indução Supremos&r: recebem e enviam 52.41MFE por Tick."]
	quest.6B3BD54A34EB02C2.quest_subtitle: "Transporte"
	quest.6B3BD54A34EB02C2.title: "&aProvedores de Indução"
	quest.6B40AF49F505A551.quest_desc: [" Escondido nas vastas extensões do &2Mundo Superior&r, os &cPatins&r aguardam o ousado &2aventureiro&r. Uma vez calçados, cada passo &cpuxa&r o portador para frente, transformando o movimento em um &cmomento imparável&r. \\n\\n- Possui 1 habilidade: \\n\\n &bAceleração&r: \\n Ao &ccorrer continuamente&r, o portador ganha gradualmente &bvelocidade de movimento&r, atingindo o &cbônus máximo&r após alguns &2segundos&r. Quanto mais rápido você vai, mais &2escorregadias&r as superfícies se tornam, adicionando tanto &cempolgação&r quanto &crisco&r. \\n\\n- Uma &6relíquia&r de &cvelocidade&r e &6momento&r… onde cada &apasso&r deixa um rastro de &cfogo&r para trás."]
	quest.6B40AF49F505A551.quest_subtitle: "Velocidade não é apenas uma habilidade… é um legado."
	quest.6B40AF49F505A551.title: "&cPatins"
	quest.6B511C8B572E8940.quest_desc: ["No canto inferior esquerdo da sua tela, você verá uma barra. Essa barra é sua reserva de mana! \\n\\nExistem várias maneiras de aumentar sua reserva de mana ou a eficiência de seus feitiços à medida que você progride no mod. Aprimorar seu Livro de Feitiços também pode aumentar sua mana!"]
	quest.6B511C8B572E8940.quest_subtitle: "Poder de Mago"
	quest.6B511C8B572E8940.title: "Mana"
	quest.6B5BC33667C782EC.quest_desc: ["O &dGolem do End&r guarda a &dCidadela Arruinada&r, bem, vários deles guardam. \\n\\nTecnicamente, você não precisa lutar contra eles para lutar contra o &dGuardião do End&r, mas você definitivamente deveria para obter o &dNúcleo do Vazio&r. \\n\\nO &dGolem do End&r tem 3000 &4Corações&r e os regenerará quando deixado em paz. \\n\\nEle tem alguns ataques, como ser capaz de socá-lo e esmagar o chão. Quando ele esmaga o chão, &dRunas do Vazio&r surgirão, ferindo qualquer Jogador ou Mob que as toque."]
	quest.6B5BC33667C782EC.title: "&dGolem do End&r"
	quest.6B671CB07D046BEC.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_diamond.png width:100 height:150 align:center}"]
	quest.6B671CB07D046BEC.title: "&bDiamante&r"
	quest.6B747129A85AA768.quest_desc: ["Agora ainda mais como o Funil de Absorção! \\n\\nO Módulo de Vácuo agora coletará Orbes de XP, bem como Itens. O que você faz com o XP é com você!"]
	quest.6B78378BC8036227.title: "Catalisador de Grader Tier 1"
	quest.6B7E13AB3BF2C5C8.quest_desc: [
		"A &6&lCaldeira Termoelétrica&r é construída de forma similar ao &2&lReator de Fissão&r, com a casca externa sendo apenas Carcaças, Vidro e Portas, enquanto o interior contém todas as coisas importantes! \\n\\nAs bordas da &6&lCaldeira&r precisarão ser de &6Carcaças da Caldeira&r. O Teto e o Chão podem ser feitos inteiramente de &6Carcaças&r, ou o meio pode ser feito com Vidro! \\n\\nAs Paredes são similares, apenas incluindo agora as &6Portas da Caldeira&r. \\n\\nO interior é onde ficam nossos &9Dispersores de Pressão&r e &6Elementos de Superaquecimento&r. \\n\\nPode-se deixar espaço entre o Teto e os &9Dispersores de Pressão&r para dar mais espaço para o Vapor. \\n\\nTambém podemos dar mais espaço abaixo dos &9Dispersores de Pressão&r e acima dos &6Elementos de Superaquecimento&r para dar mais espaço para a &9Água&r."
		"{@pagebreak}"
		"A &6&lCaldeira Termoelétrica&r não fará muito sozinha, ela precisará de algumas &6Portas&r para mover nossos &cQuímicos&f e &bFluidos&r para dentro para iniciá-la! \\n\\nPor enquanto, vamos focar em resfriar &6Sódio Superaquecido&r! Para isso, precisaremos de &6Sódio Superaquecido&r e &9Água&r dentro da &6&lCaldeira&r. \\n\\nAssim que o &6Sódio Superaquecido&r estiver dentro, a &6Temperatura&r da &6&lCaldeira&r começará a subir. Com a &9Água&r, o &6Sódio Superaquecido&r irá resfriar enquanto a &9Água&r ferverá e se tornará Vapor. \\n\\nQuanto mais alta a &6Temperatura&r, mais rápido a &9Água&r ferverá e o &6Sódio Superaquecido&r resfriará. Se quisermos/precisarmos de &6Calor&r extra, podemos &6Conduzir&r um pouco através dos &6Condutores Termodinâmicos&r. \\n\\nPodemos &6Conduzir Calor&r de &6Aquecedores Resistivos&r ou até mesmo de &2&lReatores de Fissão&r!"
		"{@pagebreak}"
		"Este Multibloco pode ser feito em qualquer tamanho disponível, não apenas no que é mostrado nas Imagens. As Imagens meramente mostram o menor tamanho que podemos fazer."
		"{image:atm:textures/questpics/mek/mek_boiler1.png width:100 height:75 align:center}"
		"{image:atm:textures/questpics/mek/mek_boiler2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_boiler3.png width:110 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_boiler4.png width:100 height:110 align:center}"
	]
	quest.6B7E13AB3BF2C5C8.title: "&6&lCaldeira Termoelétrica"
	quest.6B8040401B512E50.quest_desc: ["O &3&lC.D.C.&r (&3&lCâmara de Dissolução Química&r, não o Centro de Controle e Prevenção de Doenças) é outra &5Máquina&r usada apenas para &lProcessamento de Minérios&r. \\\\n\\\\nO &3&lC.D.C.&r vai precisar de &aÁcido Sulfúrico&r e &7Minério&r. \\\\n\\\\nO &7Minério&r deve ir no &4Slot Vermelho&r enquanto o &aÁcido Sulfúrico&r vai na &4Barra Vermelha&r. \\\\n\\\\nA &7Lama Suja&r finalizada aparecerá na &9Barra Azul&r!"]
	quest.6B8040401B512E50.title: "&3&lCâmara de Dissolução Química"
	quest.6B8F2E05429C185F.quest_desc: [
		"Uma vez derrotado, ele dropará EXP, um Coração de Dragão e, o mais importante, liberará os Fragmentos do Caos. Olhe para onde o Relâmpago vai cair e então minere abaixo dele. Lá você encontrará o Fragmento do Caos. Minere-o para receber 5 Fragmentos do Caos que podem ser transformados em partes menores dele!"
		"{image:atm:textures/questpics/draconic/draconic_shard.png width:150 height:150 align:1}"
	]
	quest.6B8F2E05429C185F.title: "Fragmento(s) do Caos"
	quest.6BA2BC09E23B34A9.quest_desc: [
		"Esta precisa de mais uma &9Pedra Sombria Polida Cinzelada&r, desta vez com 4 &7Runas&r e 4 &2Pedaços de Stellarite&r. \\n\\nEsta &6&lForja de Hefesto&r é a última do mod básico &6&lForbidden \\& Arcanus&r. \\n\\nClaro, ela tem o resto das Receitas e todos os espaços para Relíquias agora estão abertos!"
		"{image:atm:textures/questpics/forbidden/forbidden_tier4.png width:100 height:100 align:center}"
	]
	quest.6BA2BC09E23B34A9.title: "&6Forja &l&dTier 4"
	quest.6BB948F44B0950E8.quest_desc: ["A &3Pedra de Sculk&r aparece em quase todos os lugares, exceto nas &cColunas Nubladas&r. \\n\\nEla funciona como &7Pedra&r normal, em todos os sentidos. Você pode fundir as versões de Pedregulho para obter a &3Pedra de Sculk&r, que pode ser transformada em muitos outros Blocos de Construção. \\n\\nInfelizmente, não pode ser usada para fazer Ferramentas de Pedra... espere, o que você se importa, você matou o &9&lWarden&r! Por que você precisa de Ferramentas de Pedra?!?!?!"]
	quest.6BB948F44B0950E8.title: "&3Pedra de Sculk"
	quest.6BBC440BD0AD0E93.quest_desc: ["Algumas pessoas gostam de &9&lSilent Gear&r, enquanto outras gostam de &7&lTinker's Construct&r. \\n\\nEm vez de escolher entre eles, decidimos pegar o melhor de ambos os mundos usando &9&lSilent Gear&r e &c&lProductive Metalworks&r! \\n\\n&c&lProductive Metalworks&r mudará como obtemos nossos Itens &9&lSilent&r. Em vez de usar &9Plantas&r, agora precisaremos de &8Moldes&r e uma &c&lFundição&r. \\n\\nPara começar a fazer a &c&lFundição&r, comece com &cArgila Refratária&r."]
	quest.6BBC440BD0AD0E93.title: "&9&lSilent Gear&r e &c&lProductive Metalworks"
	quest.6BC0904E03683190.quest_desc: ["Cruze &8A&6b&8e&6l&8h&6a&8s&r para obter 8 novas &8A&6b&8e&6l&8h&6a&8s&r."]
	quest.6BC3CF8937DEDE89.quest_desc: ["Combine uma &cForja Infernal&r com um &dNúcleo do Vazio&r para fazer a &dForja &cdo Vazio&r! \\n\\nEla ainda é uma Picareta, com o mesmo Nível de Mineração e Velocidade. \\n\\nSó que agora podemos Clicar com o Botão Direito com ela, no chão para invocar &dRunas do Vazio&r em forma de leque, para ferir todos os Mobs com ela. \\n\\nEles realmente não se concentram muito na parte da Picareta, não é?"]
	quest.6BC3CF8937DEDE89.title: "&dForja &cdo Vazio"
	quest.6BC78AF7C9D93F11.quest_desc: ["Até mesmo versões Esmaltadas!"]
	quest.6BC78AF7C9D93F11.title: "Terracota &l&bLascasda&r"
	quest.6BD348735C27BB44.quest_desc: [
		"A &b&lMáquina de Engarrafar&r encherá qualquer &eItem&r que passar pela &eEsteira&r. \\n\\nUse as Portas na parte de trás para encher a &b&lMáquina&r com &bFluidos&r, você saberá que está funcionando quando o Tanque estiver cheio daquele &bFluido&r! \\n\\nEntão, quando um &bBalde&r, &bTanque&r ou qualquer &bArmazenamento de Fluido&r descer pela &eEsteira&r, ele será preenchido com aquele &bFluido&r. \\n\\nO &bBalde&r, &bTanque&r, ou o que for, então se moverá pelas &eEsteiras&r cheio daquele &bFluido&r! \\n\\nA propósito, como tudo na vida, a &b&lMáquina de Engarrafar&r precisará de &cEnergia&r nas Portas no topo da parte de trás!"
		"{@pagebreak}"
		"Para começar, faça um triângulo de &8Andaimes de Aço&r. Em seguida, preencha os buracos com &7Chapa de Ferro&r, &4Bloco de Engenharia de Redstone&r e um &eBloco de Engenharia Leve&r."
		"{image:atm:textures/questpics/immersive/immersive_bottler1.png width:100 height:100 align:center}"
		"Agora nós apenas adicionamos uma &eEsteira Transportadora&r na frente. Em seguida, adicione uma segunda &7Chapa de Ferro&r do outro lado, uma &bBomba de Fluido&r ao lado dela e um &eBloco de Engenharia Leve&r sobre o anterior!"
		"{image:atm:textures/questpics/immersive/immersive_bottler2.png width:100 height:100 align:center}"
		"Simplesmente &6Martele&r a &eEsteira Transportadora&r do meio e BOOM, pronto!"
		"{image:atm:textures/questpics/immersive/immersive_bottler.png width:100 height:100 align:center}"
	]
	quest.6BD348735C27BB44.title: "&b&lMáquina de Engarrafar"
	quest.6BEBE739EB97082A.quest_desc: ["O que o Ferro faz? \\n\\nArmaduras, mais ferramentas como Baldes e Tesouras, novos blocos como Funis e Caldeirões. \\n\\nO Ferro é muito importante. O que você deve buscar primeiro é uma Picareta de Ferro, para poder minerar &bDiamantes&r!"]
	quest.6BEBE739EB97082A.title: "A Era do Ferro"
	quest.6BEE3578BD2C713C.quest_subtitle: "Surge de um Ninho de Terra"
	quest.6BEE3578BD2C713C.title: "&fAbelha Cortadeira"
	quest.6BF6C7C04F26D8BA.quest_subtitle: "Black Ember + Árvore da Alma"
	quest.6BFD7854F078BF16.quest_subtitle: "Agarre isso"
	quest.6BFF78D4218DF1F2.quest_subtitle: "Fabricado na Forja de Hefesto"
	quest.6BFF78D4218DF1F2.title: "&fAbelha de Stellarite"
	quest.6C001E18093FC037.quest_desc: ["O Coletor de Plantas colhe plantas em sua área de trabalho. Plantas colhidas podem dar &#5919B6Lodo&r, que pode ser usado em um Refinador de Lodo. Quando fornecido com &bGás de Éter&r, o Coletor de Plantas replantará automaticamente as plantações.\\n\\nO Semeador de Plantas planta automaticamente plantações e mudas. Ele tem 9 slots de inventário codificados por cores, que correspondem às marcações coloridas no topo do Semeador de Plantas. A área de trabalho da máquina é dividida em 9 segmentos, que correspondem aos vários slots de inventário.\\n\\nAmbas as máquinas suportam Adicionais de Alcance."]
	quest.6C001E18093FC037.title: "Plantas"
	quest.6C14D1B60124C2B2.quest_desc: [
		"O &9Tunnel Bore&r é perfeito para colocar &6Trilhos&r automaticamente, especialmente sob montanhas ou colinas. \\n\\nEle precisará de 3 coisas para começar a funcionar: &9Cabeça de Perfuração&r, combustível como Carvão e &6Trilhos&r. Assim que tiver os 3, é só deixar ir! \\n\\nLembre-se de controlar os itens que entram nele!"
		"{image:atm:textures/questpics/railcraft/rail_tunnel.png width:100 height:100 align:center}"
	]
	quest.6C14D1B60124C2B2.title: "&9Tunnel Bore"
	quest.6C163E005351FF6D.quest_desc: ["O &cKit de Apito&r, quando ativo com Redstone, fará com que as &5Locomotivas&r acionem seus apitos."]
	quest.6C163E005351FF6D.title: "Apito do &cKit de Trilhos&r"
	quest.6C16670D16113DE9.quest_desc: ["Para automatizar a criação da &6&lEstrela ATM&r, precisaremos de &6Fragmentos de Estrela&r. Para obter &6Fragmentos de Estrela&r, precisaremos de &6Abelhas Estreladas&r. \\n\\nE, claro, para obter &6Abelhas Estreladas&r, precisaremos de &dAbelhas &aPatrick&r! Você pode obter raramente &dAbelhas &aPatrick&r pescando em Oceanos Quentes! \\nSe não quiser convertê-las, você também pode farmar &dEstrelas &aPatrick&r com elas."]
	quest.6C16670D16113DE9.title: "&dPatrick &aEstrela&r... Abelha?"
	quest.6C1BBA559963B3DF.quest_desc: [
		"O &aDicionário dos Espíritos&r serve como o Livro Guia para o &dOccultism&r. Você absolutamente precisará fazer isso se quiser continuar com o mod!"
		""
		"O Dicionário tem um guia no estilo de missões dentro dele, caso você prefira lê-lo em vez de fazer estas missões!"
		""
		"Você também precisará do livro para criar várias coisas no pacote, então você meio que tem que fazê-lo. :)"
	]
	quest.6C1BBA559963B3DF.title: "Pequeno Livro dos &cDemônios"
	quest.6C1F7A0B330B3F42.quest_desc: ["O &a&lPeitoral do Meka-Traje&r é um aprimoramento para o &5Peitoral de Unobtainium&r. \\n\\nEle precisará de alguns outros &eItens&r para ser aprimorado, como uma &dPastilha de Antimatéria&r, &aPastilhas de Polônio&r e até mesmo uma &dCélula de Indução Suprema&r! \\n\\nO &a&lPeitoral do Meka-Traje&r sem &aEnergia&r agirá como um &cPeitoral de Netherita&r. E com &aEnergia&r? Ele talvez bloqueie todo o Dano, exceto Dano Mágico, e usará &aEnergia&r em vez de Vida! \\n\\nPodemos colocá-lo em uma &7&lEstação de Modificação&r para adicionar &7Unidades de Módulo&r que podem aprimorá-lo! O &a&lPeitoral do Meka-Traje&r tem o maior número de &7Unidades de Módulo&r de toda a Armadura, então com certeza confira-as!"]
	quest.6C1F7A0B330B3F42.title: "&a&lPeitoral do Meka-Traje"
	quest.6C2C135B9B7B9402.quest_desc: ["&d&lInfusão&r é uma versão especial de &5Encantamento&r que, ironicamente, é usada para melhores &5Encantamentos&r. \\n\\nQuando a quantidade certa de &aEterna&r, &cQuanta&r e &5Arcana&r é alcançada, os &5Encantamentos&r oferecerão &d&lInfusão&r. \\n\\n(Para saber os Níveis necessários, você pode verificar no JEI ou seguir estas Missões)"]
	quest.6C2C135B9B7B9402.title: "&l&dInfusão"
	quest.6C3E88C02ED3C1F0.quest_desc: ["Seja através de Níveis, Itens, &3Trocas&r, ou quem sabe o quê! Para levar seu &cPokémon&r à próxima &bEvolução&r, funciona tudo da mesma forma. \\n\\nAssim que o &cPokémon&r estiver pronto, use (M) para abrir sua Equipe. \\n\\nAqui, visualize o &cPokémon&r e o Botão &bEvoluir&r estará abaixo da Imagem do &cPokémon&r. \\n\\nClique nele, e o &cPokémon&r irá &bEvoluir&r!"]
	quest.6C3E88C02ED3C1F0.title: "&bEvolua&r seu &cPokémon"
	quest.6C4B93FE64BD418D.quest_desc: ["Chegar ao &2&lUndergarden&r é semelhante a chegar ao &c&lNether&r. Você precisará criar um Portal. \\n\\nÉ da mesma forma e tamanho dos Portais do Nether, mas em vez de Obsidiana, você precisará de uma variante de Tijolos de Pedra. Tijolos de Pedra, Tijolos de Pedra com Musgo ou Tijolos de Deepslate. \\n\\nUma vez formado, você pode ativá-lo usando o Catalisador nele. "]
	quest.6C4B93FE64BD418D.quest_subtitle: "Fazendo o Portal"
	quest.6C4B93FE64BD418D.title: "The Undergarden"
	quest.6C57D64518FF22C0.quest_desc: ["O resto dos &5Encantamentos&r vem deste &8Tomo&r. \\n\\n&5Inquebrável&r... Eu realmente não sei o que mais..."]
	quest.6C57D64518FF22C0.title: "Tomos &8ETC."
	quest.6C5D61A704DC125A.quest_desc: [
		"Essa é engraçada; você pode encontrá-la, criá-la ou trocá-la.\\n\\nDepois, pode tingi-la da cor que quiser e, claro, usá-la na cabeça!\\n\\nAs &6A&8b&6e&8l&6h&8a&6s&r pensarão que você é uma Flor e o seguirão.\\n\\nTambém faz você parecer o Patolino em \"Duck Amuck\"."
		"{image:atm:textures/questpics/bumblezone/bumble_duckamuck.png width:100 height:100 align:center}"
	]
	quest.6C5F9D0D447EFB9C.quest_desc: ["Você acha que &l&2Vanilla&r era tudo o que tínhamos? \\n\\nA &6Armadura de Allthemodium&r tem mais Pontos de Armadura e Resistência de Armadura, além de proteção aumentada contra Magia e outros bônus sobre os quais você pode ler na Página de Missões de &6&lAllthemodium&r! \\n\\nAh, e você precisará de &cNetherita&r para criá-la."]
	quest.6C5F9D0D447EFB9C.quest_subtitle: "24"
	quest.6C5F9D0D447EFB9C.title: "Armadura de &6Allthemodium"
	quest.6C6F4EB5CBE2FBC2.quest_desc: ["A Vara de Adivinhação de Ferro é um pouco superior, sendo capaz de encontrar Minérios que uma Picareta de Ferro pode minerar! Então Diamantes, Redstone e Ouro."]
	quest.6C9191DA4B1039D6.quest_desc: ["Bagas de Menril dão a você Visão Noturna por um curto período de tempo quando comidas."]
	quest.6CA01DCE1F4A0EC3.quest_desc: ["O próximo estágio do mod requer a coleta de &3Óleo Cru&r. Este Óleo pode ser encontrado naturalmente na superfície do Mundo Superior."]
	quest.6CA01DCE1F4A0EC3.quest_subtitle: "O Caminho para o Plástico"
	quest.6CA01DCE1F4A0EC3.title: "Óleo Cru"
	quest.6CAD27627A3F8FD7.quest_desc: [
		"Agora finalmente chegamos ao Cerne do Mod, os &eAlchemical Sulfur&r! \\n\\nPara fazê-los, precisaremos de um Caldeirão de Liquefação, um Item, &dSal Ammoniac&r e um Aquecedor. \\n\\nO calor é explicado em outra Missão, mas você precisará do Braseiro Piromântico ou do Emissor de Fluxo Calórico sob o Caldeirão para aquecê-lo. \\n\\nEm seguida, o &dSal Ammoniac&r Líquido dentro dele. \\n\\nE, finalmente, o Item que você quer transformar em um &eAlchemical Sulfur&r. \\n\\nVocê saberá que está funcionando quando estiver borbulhando."
		"{image:atm:textures/questpics/theurgy/theurgy_lique.png width:100 height:100 align:center}"
	]
	quest.6CAD27627A3F8FD7.title: "Fazendo &eAlchemical Sulfur"
	quest.6CAD67D21E1EA861.quest_desc: [""]
	quest.6CAD67D21E1EA861.quest_subtitle: "&oAcesso remoto universal."
	quest.6CAD67D21E1EA861.title: "Emissor de &7&lNexium"
	quest.6CB8D3919B16784B.quest_desc: ["&9Ceraunus&r é a Arma Âncora que a própria &9&lScylla&r usa! \\n\\nCom apenas 2 &9Essência da Tempestade&r e 3 &9Lacrima&r podemos Criá-la! Só que em uma ordem diferente da que você usaria para &9Astrape&r. \\n\\nVocê pode balançar a Âncora como uma Maça, com um grande atraso. Ou usá-la para ataques especiais! \\n\\nSegure o Clique Direito para lançar a Âncora à sua frente. Quando ela atingir um Mob, ele receberá dano e será empurrado para trás. \\n\\nVocê também pode segurar o Shift e o Clique Direito para, ao invés de lançar a Âncora, lançar &9Ondas&r em uma linha à sua frente!"]
	quest.6CB8D3919B16784B.title: "&9Ceraunus"
	quest.6CC2B540EE37079E.quest_desc: ["Carimbe-as! \\n\\nConfira as missões de todas as &cPoke&rbolas para ver sobre o Carimbo de Borracha. \\n\\nVocê pode clicar com o botão direito no topo ou na mão do &6Implantador&r para dar a ele um item, como o Carimbo de Borracha. Então, quando estiver trabalhando, ele usará esse carimbo nos itens abaixo dele. \\n\\nOu você pode usar o &7Carimbador CNC&r! Uma máquina do &5&lMekanism&r que usa &cEnergia&r para fazer exatamente a mesma coisa, só que mais fácil."]
	quest.6CC5FE34778F0DFA.quest_desc: [
		"Você certamente terá itens demais jogando este modpack. É assim que funciona, e se você ainda não resolveu sua situação de armazenamento, o &dArmazenamento Dimensional&r pode ser a solução ideal para você!"
		""
		"Para começar com esta solução de armazenamento mágica, você precisará criar o &dAtuador de Armazenamento Dimensional&r e colocá-lo no mundo. Ele funciona como uma Caixa de Shulker, o que significa que se você o quebrar, não perderá nenhum dos itens armazenados dentro."
		""
		"Por padrão, ele tem 128 slots de armazenamento, com cada slot comportando até 16 pilhas de um item, exceto para itens com dados &5NBT&r. Estes não se empilharão e ocuparão um slot inteiro, então certifique-se de deixar esses itens de fora!"
		""
		"Se você não tem certeza de quais itens têm dados NBT, pode sempre conferir a missão \"NBT e Você\" na linha de missões de Armazenamento para mais informações sobre NBT!"
	]
	quest.6CC5FE34778F0DFA.title: "&c&mDemoníaco&r &dArmazenamento Mágico&r!"
	quest.6CCDEEDA2C99DA66.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os packs &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pack público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.6CCE920735187234.quest_desc: [
		"A &9&lTurbina&r é uma &5Máquina&r de pelo menos 5x7x5, mas pode ser expandida para conter mais Vapor e gerar mais &aEnergia&r! \\n\\nA estrutura da &9&lTurbina&r é feita de &9Carcaças da Turbina&r. O Chão e o Teto podem ser preenchidos com &9Carcaças da Turbina&r ou Vidro Estrutural. \\n\\nAntes de nos preocuparmos com as Paredes, vamos focar no interior! Essa é a verdadeira fonte de lucro! \\n\\nNo centro exato, a partir do Chão, é onde nossos &9Rotores&r serão colocados. Para a menor, precisaremos de 2! Então, anexe as &9Pás&r neles, 4 no total. \\n\\nAcima do &9Rotor&r mais alto, coloque nosso &9Complexo Rotacional&r e cerque-o com &9Dispersores de Pressão&r. \\n\\nA Camada acima do &9Complexo Rotacional&r será de &aBobinas Eletromagnéticas&r e, acima delas, estarão nossos &9Condensadores de Saturação&r. \\n\\nAgora podemos colocar nossas &9Portas&r e &9Dutos&r em nossas Paredes e preencher o resto com &9Carcaças da Turbina&r ou Vidro Estrutural!"
		"{@pagebreak}"
		"Felizmente, a &9&lTurbina&r é muito mais fácil de usar do que de Construir! \\n\\n&cEncane&r um pouco de Vapor para dentro através da &9Porta&r e ela deve começar a girar. A quantidade de Vapor que ela pode conter é determinada pelo tamanho total da Construção da &9&lTurbina&r. \\n\\nEntão os &9Rotores &fe as &9Pás&r começarão a girar por causa do Vapor subindo através da &9&lTurbina&r. Isso moverá o &9Complexo Rotacional&r, que move as &aBobinas Eletromagnéticas&r, gerando &aEnergia&r! \\n\\nA &aEnergia&r pode ser retirada por &acabos&r de nossa 2ª &9Porta&r. A quantidade de &aEnergia&r é determinada pela velocidade com que os &9Rotores &fe as &9Pás&r estão se movendo. Que, por sua vez, é determinada pela quantidade de Vapor que entra na &9&lTurbina&r. \\n\\nSe usarmos &9Condensadores de Saturação&r, obteremos um pouco de &9Água&r de volta do nosso Vapor. Podemos retirar esta &9Água&r pelos &9Dutos&r e mandá-la de volta para o nosso &2&lReator de Fissão&r! \\n\\nNós temos uma configuração na INTERFACE da nossa &9&lTurbina&r que é similar àquelas do &9&lSeparador Eletrolítico&r. Podemos escolher Despejar Excesso de Vapor, para tê-la constantemente funcionando na produção mais rápida de &aEnergia&r. Podemos Despejar Vapor, caso você queira se livrar dele, eu acho... ou Ocioso, que é o padrão! Se você usar um modo que não seja Ocioso, ela não reciclará &9Água&r do Vapor."
		"{@pagebreak}"
		"Este Multibloco pode ser feito em qualquer tamanho disponível, não apenas no que é mostrado nas Imagens. As Imagens meramente mostram o menor tamanho que podemos fazer."
		"{image:atm:textures/questpics/mek/mek_turbine1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine3.png width:110 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine4.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine5.png width:100 height:110 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine6.png width:100 height:120 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine7.png width:100 height:125 align:center}"
	]
	quest.6CCE920735187234.title: "&9&lTurbina"
	quest.6CD1720B76F47806.quest_desc: ["O &2&lBiogerador&r funciona pegando &2Bio Combustível&r, fazendo &2Bioetanol&r, e usando isso para &aEnergia&r! \\n\\nEste &2&lGerador&r foi fortemente nerfado, então é recomendado não usá-lo! \\n\\nIsso porque vocês, cabeças de vento, continuam fazendo enormes &aFazendas de Melão&r que consomem o TPS dos Servidores!"]
	quest.6CD1720B76F47806.title: "&2&lBiogerador"
	quest.6CD7D99AA102A5C3.quest_desc: ["&n&f&lLogística&r: \\nUm sistema de mover, gerenciar e armazenar itens ou recursos. \\n\\nNo Minecraft Modificado é bem parecido, mover itens! Com Mods você precisará de itens e aos milhares, caramba, se você quiser a &6&lEstrela&r, chega aos milhões! Então você precisará mover itens de fábricas, máquinas, fazendas e, especialmente, baús. É para isso que serve a &l&fLogística&r."]
	quest.6CD7D99AA102A5C3.title: "&lLogística"
	quest.6D09511D64DDC282.quest_desc: ["O &3&lWarden&r. O Chefe mais forte do &2&lMinecraft&r. Sabe aquele que os criadores declararam explicitamente que você não deveria matar? \\n\\nO &3&lWarden&r tem 500 &4Corações&r. Ele pode matar jogadores com dois golpes em uma armadura de &cNetherita&r completa. \\n\\nSe os jogadores estiverem perto dele, ele simplesmente os esmagará com os braços. Se detectado muito mais longe, ele atirará neles com seu &3Feixe Sônico&r. \\n\\nFelizmente ele é prejudicado por ser cego (ao contrário do Demolidor). Ele funciona unicamente através do Som e Olfato. Sim, se você estiver muito perto ele sempre será capaz de encontrá-lo. \\n\\nSe você fizer sons, ele pode ouvi-los e ir para onde você fez o som. Mesmo com &3Sensores de Sculk&r, se eles dispararem ele pode te encontrar! Se ele ouvir um ruído longe, ele pode afundar no &3Sculk&r para se teletransportar para mais perto do som! \\n\\nEntão, como o matamos? Você sempre pode tentar construir 23 blocos acima dele e acertá-lo com flechas. 23 blocos acima é muito longe para o seu Feixe Sônico! \\n\\nSe você conseguir matá-lo, ele deixará cair um monte de &3Sculk&r e itens do &3&lDeeper and Darker&r!"]
	quest.6D09511D64DDC282.title: "&3&lWarden"
	quest.6D0A876D4E4D35AB.quest_desc: ["Essência Criativa é necessária para criar a &6Estrela ATM&r."]
	quest.6D0A876D4E4D35AB.quest_subtitle: "Tier: &5Criativo"
	quest.6D0A876D4E4D35AB.title: "&5Essência Criativa"
	quest.6D124ACF4AE80490.quest_desc: ["Com Micromísseis você pode disparar explosões de longe! Agora ninguém pode escapar!\\n\\nEstes são necessários para criar a &6Estrela ATM&r."]
	quest.6D124ACF4AE80490.quest_subtitle: "Disparando Explosões de longe!"
	quest.6D14ACECD2084456.quest_subtitle: "Wenge + Carvalho"
	quest.6D1E8399AD39FFC8.quest_desc: ["A &7Máquina do Paradoxo&r pode, por um preço de muita Energia e &aFluido do Tempo&r, tirar uma Foto de blocos e entidades na área designada; depois, ela pode duplicá-la. \\n\\nMuitos Blocos e Entidades são bloqueados por configurações, então nada de duplicar Abelhas!"]
	quest.6D1E8399AD39FFC8.title: "&7Máquina do Paradoxo"
	quest.6D3B958E49AE7BDB.quest_desc: ["Fragmentos de Amuleto podem ser transformados em Amuletos ou Ovos Geradores. Eles são do Reliquary e raramente caem de suas respectivas criaturas. Alguns podem até ser fabricados! Pegue 2 e um Ovo normal e você poderá fabricar um Ovo Gerador."]
	quest.6D42D0102D1CBC19.quest_desc: ["As Brocas Adicionais são Afiação... só que para a &4&lBroca&r! \\n\\nAh, sim, e você pode ter 3 ao mesmo tempo, para poder empilhado."]
	quest.6D484150536536B9.quest_desc: [
		"Este ninho atrai &eAbelhas Cristalinas&r. Você precisará de Quartzo do Nether em vez de usar &6Guloseimas de Mel&r para atrair a Abelha."
		""
		"A maneira mais fácil de obter um bloco de quartzo é minerando-o com uma picareta de Toque Suave."
		""
		"Dica: O Latão tem a característica de Toque Suave ao fazer uma ferramenta Silent Gear."
	]
	quest.6D484150536536B9.quest_subtitle: "Atrai Abelhas Cristalinas no Nether"
	quest.6D484150536536B9.title: "&fNinho de Quartzo"
	quest.6D4FB6291CA8D1A6.quest_desc: ["As Árvores de Smogstem são muito mais grossas em suas metades inferiores, semelhantes às Árvores de Baobá na vida real! \\n\\nElas têm Folhas Azuis com Troncos Cinzas. \\nVocê pode encontrá-las em vários Biomas: Florestas de Smogstem, Florestas Densas e até em Pântanos de Cogumelos Índigo!"]
	quest.6D54B45CDA70FEAB.quest_desc: ["O &bCartão de Energia&f pode ser aplicado à maioria dos dispositivos recarregáveis, como Célula Portátil e Terminais Sem Fio (abordados mais tarde), para também aumentar &oseu&r buffer de energia."]
	quest.6D54B45CDA70FEAB.quest_subtitle: "Sinta a energia!"
	quest.6D54B45CDA70FEAB.title: "&eCartão de &aEnergia"
	quest.6D68D9941049E806.quest_desc: ["Este gerador irá, como o próprio nome sugere, fazer uso de &dSource&r como combustível. Para decidir qual criatura gerar, você precisará de um Containment Jar contendo a criatura na área."]
	quest.6D68D9941049E806.quest_subtitle: "Gerador do Ars Nouveau"
	quest.6D6E07564D8FDD8D.quest_desc: ["&aExtreme Reactors&r oferece Reatores multi-bloco que são completamente personalizáveis em tamanho, eficiência e mais.\\n\\nPara saber mais sobre como começar com Extreme Reactors, confira o capítulo de missões do mod!"]
	quest.6D6E07564D8FDD8D.quest_subtitle: "Reatores Personalizáveis!"
	quest.6D6E07564D8FDD8D.title: "&9Extreme Reactors: &aReatores"
	quest.6D738730B371B152.quest_desc: ["A &l&7Dimensão de Mineração&r é um mundo Superplano com absolutamente nada na superfície. \\n\\nAbaixo da superfície está quase todo tipo de Minério. \\n\\nA &7&lDimensão de Mineração&r não tem Cavernas, nem Geração de Mobs, e nada para atrapalhar seu caminho. É apenas tipos de Pedra e Minérios! \\n\\nA geração de minério difere pelo Nível Y e camada na &7&lDimensão de Mineração&r.\\n\\nEu recomendo montar uma Pedreira."]
	quest.6D738730B371B152.title: "&l&7Dimensão de Mineração"
	quest.6D75CF34957ECCD9.quest_desc: ["A Bateria de Energia permite que você armazene FE. Para transferi-la, você precisará de &6Interfaces de Energia&r."]
	quest.6D75CF34957ECCD9.quest_subtitle: "Armazenando Energia"
	quest.6D7D0A5313284B53.quest_desc: ["Ei, belas Botas! As &a&lBotas do Meka-Traje&r são um aprimoramento para as &5Botas de Unobtainium&r. \\n\\nNão, não apenas &5Botas de Unobtainium&r, você também precisará de uma &dPastilha de Antimatéria&r, &aPastilhas de Polônio&r e uma &dCélula de Indução Suprema&r! \\n\\nVocê realmente se importa com os atributos das Botas? Quem vai acertar seus Pés! Ah, sim, esqueci do Dano de Queda. \\n\\nBem, se não estiverem carregadas, elas protegerão o mesmo tanto que as &cBotas de Netherita&r... mas se estiverem Carregadas, usarão &aEnergia&r para proteger você. \\n\\nA &7&lEstação de Modificação&r é uma &5Máquina&r que podemos usar para adicionar &7Unidades de Módulo&r para aprimorar nossas &a&lPeças do Meka-Traje&r, incluindo as &a&lBotas&r. Estes aprimoramentos são similares a muitos Encantamentos!"]
	quest.6D7D0A5313284B53.title: "&a&lBotas do Meka-Traje"
	quest.6D81DF90E9C2C049.quest_desc: ["O Destruidor Elite tem 18 espaços para filtros e funciona 2x mais rápido."]
	quest.6D88C19F47D0D469.title: "Tier: &7Minúsculo"
	quest.6D95CB7906C0DC84.quest_subtitle: "Faia + Cacau"
	quest.6D9CFCD81A23BB3B.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Torna o jogador imune à lava."
	]
	quest.6DAA82B5F94AF9F8.quest_desc: ["A &9Jar of Light&r invoca uma fonte de luz flutuante que o segue. \\n\\nA &6Jarra do Vazio&r destrói os itens que você pega em troca de mana. Isso pode ser filtrado. \\n\\nPara adicionar ou remover um item a ser destruído pela jarra, use a jarra com o item em sua mão secundária, ou use um item na Mesa do Escriba com a jarra colocada sobre ela. \\n\\nA jarra deve estar na sua Barra de acesso rápido para funcionar."]
	quest.6DAA82B5F94AF9F8.title: "As Jarras"
	quest.6DAECA44E28DA9BA.quest_subtitle: "Beech + Birch"
	quest.6DB06E3984D0CF97.quest_desc: ["O Construtor Elite tem 18 espaços para filtros e funciona 2x mais rápido."]
	quest.6DB65926EE6D6C2E.quest_desc: ["Estes &cKits de Trilhos&r servem para alterar o momento com seus &7Carrinhos&r. \\n\\nOs &cKits de Transição&r mudam a velocidade da &5Locomotiva&r que passa, precisa de energia de redstone. \\nOs &cKits de Impulso&r acelerarão o &7Carrinho&r se energizados e desacelerarão o &7Carrinho&r se não energizados. \\nO &cKit de Controle&r dá um empurrãozinho aos &7Carrinhos&r, quando energizado mudará a direção em que empurra. \\nO &cKit de Aceleração&r mudará a velocidade de uma &5Locomotiva&r que passa para qualquer velocidade configurada, precisa ser energizado com redstone. \\nO &cKit de Lançamento&r literalmente lançará seu &7Carrinho&r!"]
	quest.6DB65926EE6D6C2E.title: "&cKits de Trilhos&r para mover &7Carrinhos&r"
	quest.6DBD81BA83B1D0A5.quest_desc: ["Ainda mais Potencial Operacional!"]
	quest.6DBD81BA83B1D0A5.title: "Capacitor Dracônico"
	quest.6DBF9CAB37B9BBF3.quest_subtitle: "Aumenta a Produtividade das Abelhas em 120%"
	quest.6DBF9CAB37B9BBF3.title: "&fMelhoria de &6Produtividade Alpha"
	quest.6DC1E08D019FD543.quest_desc: [
		"Nossos &7Cristais&r precisarão de ainda mais &lProcessamento&r! \\n\\nRepita os passos anteriores de fazer uma &6&lPlanta de Evaporação Térmico&r para criar &eSalmoura&r. \\n\\nUse um &9&lSeparador Eletrolítico&r para Separar o &eCloro &fda &eSalmoura&r. \\n\\nEm seguida, obtenha &bOxigênio&r colocando &9Água &fem um &9&lSeparador Eletrolítico&r. \\n\\nCombine o &eCloro &fe o &bOxigênio &fem um &a&lInfusor Químico&r para obter &3Cloreto de Hidrogênio&r! \\n\\nCom nosso &c&lInjetor Químico&r, podemos &cInjetar &fos &7Cristais&f com &3Cloreto de Hidrogênio&r para obter 2 &7Fragmentos de Minério&r de cada &7Cristal de Minério&r."
		"{image:atm:textures/questpics/mek/mek_tier4_3.png width:250 height:100 align:center}"
	]
	quest.6DC1E08D019FD543.quest_subtitle: "Processamento de Minério Tier 4"
	quest.6DC1E08D019FD543.title: "Fazendo mais &3Cloreto de Hidrogênio"
	quest.6DC826659699E638.quest_subtitle: "Combine um Ovo de Gerador de Abelha de Redstone com um Ovo de Gerador de Abelha de Electro"
	quest.6DC826659699E638.title: "&fAbelha Fluxita"
	quest.6DCDD55786025911.quest_desc: ["O Starlight Golem é o segundo Chefe no Eternal Starlight. \\n\\nEle está carregando na Forja do Golem esperando por um Jogador para lutar contra ele!"]
	quest.6DCDD55786025911.title: "&fMate o &bStarlight Golem"
	quest.6DF215923418F56F.quest_subtitle: "Alimente uma Abelha de Experiência com um Template de Superencantamento"
	quest.6DF215923418F56F.title: "&fAbelha de Super Experiência"
	quest.6E05B62A40D5A891.quest_desc: [
		"&3&lIntegrated Dynamics&r é tudo sobre &f&lLogística&r! É praticamente a definição de &lLogística&r."
		""
		"É tudo sobre mover, gerenciar e armazenar itens. Caramba, você pode nem precisar da Chave Inglesa para isso, é tão bem projetado! Pegue uma por precaução, no entanto."
		""
		"(Solução de tubos menos lagada, estes são recomendados)."
	]
	quest.6E05B62A40D5A891.title: "&3&lIntegrated Dynamics"
	quest.6E0624750DF8CD18.quest_desc: ["Não é mais possível criá-las, agora você precisa sempre aprimorar a &cNetherita&r para elas. \\nSim, isso salva Encantamentos e as repara!"]
	quest.6E0624750DF8CD18.title: "Ferramentas de &6Allthemodium"
	quest.6E08D4E6BC3FB99F.quest_desc: ["Os &5Deeplings&r são uma antiga raça de monstros marinhos que vivem e guardam a &5Cidade Submersa&r. Eles têm suas próprias classificações: Pescadores, Brutos, Sacerdotes e Feiticeiros. \\n\\nOs &5Deeplings&r são os mais básicos, tendo apenas 13 &4Corações&r e uma Lança de Coral. \\n\\nOs &5Pescadores Deepling&r são os próximos, eles têm 15 &4Corações&r e seguram uma Vara de Pescar com um &5Peixe-leão&r anexado. O &5Peixe-leão&r irá atacá-lo e dar-lhe Veneno, eles têm 6 &4Corações&r. \\n\\nOs &5Brutos Deepling&r têm 60 &4Corações&r e seguram uma Bardiche de Coral, que usarão para avançar em você na Água. \\n\\nOs &5Feiticeiros &fe &5Sacerdotes Deepling&r ambos têm 45 &4Corações&r e ambos seguram um Athame. Os &5Sacerdotes&r têm um ataque à distância que podem usar, enquanto os &5Feiticeiros&r não!"]
	quest.6E08D4E6BC3FB99F.title: "&5Deeplings&r"
	quest.6E093D16B12E12B3.quest_subtitle: "Mineradora de Chocolate + Escavadora"
	quest.6E093D16B12E12B3.title: "&fAbelha Pedreira"
	quest.6E0DF05DEF48D2EB.quest_subtitle: "Amêndoa + Caju"
	quest.6E0E13806F388D7E.quest_desc: ["Bem-vindo ao &aArs Nouveau&f! \\n\\nArs Nouveau é um mod de magia que permite criar feitiços personalizados com os diferentes Glifos feitos dentro do mod!"]
	quest.6E0E13806F388D7E.title: "Bem-vindo ao &aArs Nouveau&f!"
	quest.6E131A32A96D7BF5.quest_desc: ["O Refinador de Lodo pode usar &#5919B6Lodo&r para produzir coisas como Terra, Cascalho, Areia das Almas... o que quer que seja... verifique o JEI para o resto."]
	quest.6E15447FC3D678E0.quest_desc: ["O &bCartão de Imprecisão&f permite que um item filtrado seja correspondido independentemente de quaisquer metadados (NBT), como dano ou encantamentos, enquanto o &bCartão Inversor&f alterna o filtro em tais Pontos de ser uma lista de permissão para ser uma lista de bloqueio."]
	quest.6E15447FC3D678E0.quest_subtitle: "Os dois cartões de E/S restantes"
	quest.6E15447FC3D678E0.title: "&eFalando de Forma Flexível"
	quest.6E17595887A051C2.quest_desc: ["&l&2Minecraft Modificado&r nos apresenta a novas Profissões de Aldeões! \\n\\nMartelo de Forja: &5Industrialista&r \\n\\nCarregador: &bPesquisador de Fluix&r \\n\\nColmeia Avançada: &6Apicultor&r \\n\\nCafeteira: &9Engenheiro&r \\n\\nNúcleo Arcano: &dMago Suspeito&r \\n\\nMesa de Coleta: &aColetor&r \\n\\nLaminadora Elétrica: &eCondutor de Carrinhos&r \\nMáquina de Laminação Manual: &eFerroviário&r \\n\\nBancada de Engenheiro: &7Armeiro&r \\nEstandarte Branco: &7Equipador&r \\nBancada de Circuitos do Engenheiro: &7Eletricista&r \\nMesa de Trabalho do Engenheiro: &7Maquinista&r \\nPlataforma Giratória: &7Engenheiro Estrutural&r \\n\\nEstação de Carregamento: &4Mecânico de Pressão&r \\n\\nSerra: &8Carpinteiro&r"]
	quest.6E17595887A051C2.title: "Mais Profissões"
	quest.6E38CF6E7360E9CA.quest_desc: ["O &9&lWarden&r dropará alguns Itens, mas o &9Coração das Profundezas&r é o mais importante. \\n\\nPodemos usar o &9Coração das Profundezas&r em uma estrutura de &8Ardosiabissal Reforçada&r para obter nosso Portal para o &3&lOutro Lado&r. Não pode haver nenhum Bloco bloqueando a Estrutura do Portal, senão não funcionará. \\n\\nEle também dropa &9Carapaça do Warden&r e &9Fragmentos de Eco&r, ambos serão úteis para Criar outros Itens!"]
	quest.6E38CF6E7360E9CA.title: "&9Coração das Profundezas"
	quest.6E3AD764A67829CB.quest_desc: ["Como seu irmão inferior, o &bCristal de Infusão&r, o &cCristal de Infusão Mestre&r faz tudo o que o primeiro pode fazer também. \\n\\nEste apenas tem Usos Infinitos e pode aprimorar 4 Blocos de Essência para o próximo em forma de Bloco! \\n\\nEle requer &cSupremium&r para ser feito, mas confie em mim, vale a pena!"]
	quest.6E3AD764A67829CB.title: "&cCristal de Infusão Mestre"
	quest.6E3D53D1C4569A89.quest_desc: ["Permite bombear experiência entre você e a Mochila."]
	quest.6E3D53D1C4569A89.quest_subtitle: "Armazenando XP"
	quest.6E3D53D1C4569A89.title: "Melhoria de Bomba de &aExperiência"
	quest.6E4C3B87FABE9EFA.quest_subtitle: "Despeje Bronze Derretido sobre um Ovo de Gerador de Abelha de Cobre/Estanho"
	quest.6E4C3B87FABE9EFA.title: "&fAbelha de Bronze"
	quest.6E5954C257726F86.quest_desc: ["Filtrar por mod pode ser muito útil.\\n\\nPara usar, coloque um item de um certo mod, então ele mostrará o nome do mod, e aperte o botão Mais para adicioná-lo!"]
	quest.6E780D295717056D.quest_desc: ["A &cPedra do Fogo &firà &bEvoluir&r &cVulpix&r para &cNinetails&r, &cGrowlithe&r para &cArcanine&r, e Eevee para &cFlareon&r."]
	quest.6E780D295717056D.title: "&cPedra do Fogo"
	quest.6E7C4228CD2B6BB9.quest_desc: ["Este &4Pé-de-cabra&r tem alguns modos diferentes, cada um mudando o design de uma &5Locomotiva&r. Do padrão, que é descrito ao passar o mouse sobre o item em seu inventário, nenhum, que vai para &7cinza&r, &6H&r&5a&r&6l&r&5l&r&6o&r&5w&r&6e&r&5e&r&6n&r, que a torna assustadora, e &cN&r&2a&r&ct&r&2a&r&cl&r, que a torna festiva!"]
	quest.6E7DC2CDA7147743.quest_desc: [
		"Aumento de Nível para 84."
		""
		"O Item de Assinatura é um Totem da Imortalidade."
	]
	quest.6E7DC2CDA7147743.title: "&5Campeão Jax"
	quest.6E7DF4AF86A036EC.title: "&fProcessamento de Petróleo de Xisto"
	quest.6E819CCD57B15D54.quest_desc: ["Usando uma fundição, despeje &#4CE688Vibranium Derretido&r sobre um &#F2EB2EOvo de Gerador de Abelha de Allthemodium&r."]
	quest.6E819CCD57B15D54.quest_subtitle: "Verde como uma flor... talvez?"
	quest.6E819CCD57B15D54.title: "&fAbelha de &aVibranium"
	quest.6E901EF1CB411088.quest_desc: ["A &9Armadura do Warden&r é um aprimoramento direto da de &cNetherite&r. Basta usar um &9Molde de Ferraria do Warden&r, um &9Fragmento de Eco Reforçado&r e uma peça de &cArmadura de Netherite&r para fazê-la. \\n\\nCada peça tem 1 Ponto de Armadura a mais e 1 Ponto de Proteção de Armadura a mais em comparação com sua contraparte de &cNetherita&r. \\n\\nNo entanto, não há mais Resistência à Repulsão. \\n\\nPelo menos elas parecem muito mais legais do que as de &cNetherita&r! O &9Elmo&r tem chifres gigantes como o &9&lWarden&r e o &9Peitoral&r tem um ponto de coração."]
	quest.6E901EF1CB411088.title: "Armadura do &9Warden&r"
	quest.6E9041744C592573.quest_desc: ["Adiciona a habilidade de bombear líquidos da Melhoria de Tanque."]
	quest.6E970CF05B96EB20.quest_desc: ["Para danificar o Golem, você precisará desligar sua fonte de energia! \\n\\nPara fazer isso, você precisará Clicar com o Botão Direito nos Blocos de Energia quando eles ficarem azuis. \\n\\nVocê geralmente pode encontrar 2 nos cantos da sala do chefe e 2 acima dele!"]
	quest.6E970CF05B96EB20.title: "Desligando"
	quest.6E9782258731E444.quest_subtitle: "White Ipe + Sorte"
	quest.6EB53CDCB80D4B66.quest_desc: [
		"A &3Porta Pneumática&r age como uma porta automática que pode ser feita para abrir apenas para você!"
		""
		"{image:pneumaticcraft:textures/patchouli/pneumatic_door.png width:200 height:200 align:right fit:true}"
	]
	quest.6EBFA16D212A7B22.quest_subtitle: "O melhor de todos"
	quest.6EC289857CDC4969.quest_desc: [
		"Ents são outro Mob pacífico que surge na Superfície da Luz Estelar. Estes surgem nas florestas! \\n\\nEssas pequenas árvores podem dropar Gravetos, Bagas Lunares e Folhas Lunares ao morrer. \\n\\nVocê pode usar Bagas Lunares para procriá-los!"
		"{image:atm:textures/questpics/eternal/starlight_ent.png width:100 height:100 align:center}"
	]
	quest.6EC289857CDC4969.title: "Ents"
	quest.6ECDD26CCCBC07C3.quest_desc: [
		"Melhora direta da &cArmadura de Netherita&r, por isso manterá os &5Encantamentos&r. \\n\\nO conjunto completo de &6AllTheModium&r tem 24 Pontos de Armadura, 20 de Resistência de Armadura e 50% de Resistência a Repulsão. \\n\\nVocê acha que é só isso que eles dão? \\n\\n&6Elmos&r: &9Respiração Aquática&r, Imunidade ao &0Efeito de Escuridão&r do &3&lWarden&r e nenhum Dano de &7Élitro&r. \\n&6Peitoral&r: 50% de &dResistência a Dano Mágico&r e &cResistência ao Fogo&r. \\n&6Calças&r: &9Passos Profundos&r e Imunidade ao &0Wither&r. \\n&6Botas&r: Resistem a dano de queda, permitem que você ande sobre &bNeve Fofa&r e &cLava&r."
		"{image:atm:textures/questpics/allthemodium/all_armor_all.png width:100 height:175 align:center}"
	]
	quest.6ECDD26CCCBC07C3.title: "Armadura de &6Allthemodium"
	quest.6ED2CDD01659FD10.quest_desc: ["Este conjunto de armadura tem os mesmos Pontos de Armadura que o de Ferro, mas é melhor tanto em Resistência quanto em Resistência a Repulsão."]
	quest.6ED2CDD01659FD10.quest_subtitle: "15"
	quest.6ED2CDD01659FD10.title: "&7Armadura de Ferro Comprimido"
	quest.6ED61438A8A1EAA4.quest_desc: ["Witherite é um drop do &4O Presságio&r, ele sempre dropará 1 bloco que pode ser transformado em 9 Barras. \\n\\nWitherite é usado para criar 3 Armas e a &4Bigorna de Fusão Mecânica&r, que pode ser usada para combinar Itens do &4&lCataclysm&r!"]
	quest.6ED61438A8A1EAA4.quest_subtitle: "= Witherite"
	quest.6ED61438A8A1EAA4.title: "Wither mais Netherita = ...?"
	quest.6EE5BE5693E8ACE4.quest_desc: ["No &d&lO End&r, você encontrará o chefe final do &2&lMinecraft Vanilla&r: O &d&lDragão do End&r. \\n\\nO &d&lDragão do End&r tem 150 &4Corações&r. Além disso, ele regenera vida a partir dos &dCristais do End&r no topo de cada pilar de &5Obsidiana&r. Quebre-os enquanto ela estiver se curando neles para causar uma tonelada de dano. \\n\\nO &d&lDragão&r tem 2 modos. Voando e Pousando. \\n\\nAo voar, ela atirará &dBolas de Fogo de Dragão&r em você. Quando elas atingirem algo, gerarão o &dBafômetro de Dragão&r naquele local. Ela também pode colidir com você para jogá-lo muito longe! \\n\\nAo pousar, ela sentará acima do seu ninho de Rocha Matriz. Aqui ela é invulnerável a projéteis, então flechas não causarão dano, apenas ataques corpo a corpo! Ela também pode expelir &dBafômetro de Dragão&r na frente dela ao pousar. \\n\\nUma vez derrotada, o &dOvo de Dragão&r aparecerá acima do seu ninho! Coisas estranhas acontecem quando você clica com o botão direito nele e o faz cair sobre um bloco não completo."]
	quest.6EE5BE5693E8ACE4.title: "&d&lDragão do End"
	quest.6EE68EEFE388CF8A.quest_subtitle: "&f4 de &cDano de Ataque"
	quest.6EF206A0BD5BAC0A.quest_desc: ["&5Épico&r está finalmente subindo mais para o lado superpoderoso. \\n\\n&5Épico&r aparece após o &lNível de Mundo: &2Fronteira&r e é mais comum no &lNível de Mundo: &4Pináculo&r. \\n\\n&5Areias Arcanas&r são feitas usando &eItens&r &5Épicos&r em uma &c&lMesa de Desmanche&r."]
	quest.6EF206A0BD5BAC0A.quest_subtitle: "&5Épico"
	quest.6EF206A0BD5BAC0A.title: "&5Areias Arcanas"
	quest.6EFA73A4D01F0052.quest_subtitle: "&f7 de &cDano de Ataque"
	quest.6EFFF0DC80C1C8A3.quest_desc: ["Usando uma fundição, despeje &#F2EB2EAllthemodium Derretido&r sobre um &#944A12Ovo de Gerador de Abelha Ancestral&r."]
	quest.6EFFF0DC80C1C8A3.quest_subtitle: "Assim que nasce os bebês?"
	quest.6EFFF0DC80C1C8A3.title: "&fAbelha de &eAllthemodium"
	quest.6F152402756DA35E.quest_desc: [
		"Para fazer isso funcionar, coloque o Importador de Itens no Inventário de onde você quer que os Itens sejam retirados. Em seguida, coloque a Interface no segundo Inventário e conecte-os com Cabos Lógicos. Então, insira o Cartão Variável no Importador e mude-o como quiser. \\n\\nPode ser alterado para Importar Itens no Limite de Inteiro (Mais de 2 Bilhões)."
		"{image:atm:textures/questpics/logistics/id_item.png width:200 height:50 align:center}"
	]
	quest.6F152402756DA35E.title: "Importando &fItens"
	quest.6F183B06683D1213.quest_desc: ["A &#EBA844Barra Quente de Kanthal&r pode ser resfriado usando o &#6DC0F7Freezer à Vácuo&r."]
	quest.6F2E30BE5CF82C77.quest_desc: [
		"Sob a &9Água&r, novamente, temos a Fissura Subaquática. \\n\\nDentro dela você pode encontrar &7Cascalho Suspeito&r por toda parte."
		"{image:atm:textures/questpics/pokemon/find_underwater.png width:200 height:100 align:center}"
	]
	quest.6F2E30BE5CF82C77.title: "Fissura Subaquática Pré-histórica"
	quest.6F3602F5600A6221.quest_desc: ["Glifos de Tier 3 requerem 10 níveis de experiência para serem feitos. \\n\\nEles também requerem um &6Livro de Feitiços de Arquimago&r."]
	quest.6F3974CAAA555FD0.quest_subtitle: "Gerenciando esta RAM"
	quest.6F3B6275D2BBEA5B.quest_desc: ["&nForte&r \\n\\n&eElétrico&r \\n&cFogo&r \\n&5Veneno&r \\n&6Pedra&r \\n&7Aço&r \\n\\n&nVulnerável&r \\n\\n&2Grama&r \\n&bGelo&r \\n&bÁgua&r"]
	quest.6F3B6275D2BBEA5B.title: "&6Terra"
	quest.6F3C82072672FD17.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso em Modpacks AllTheMods. \\n\\nComo todos os packs &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pack público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.6F3D0A248B5A9CA2.quest_desc: [
		"As &bCélula de Armazenamento Espacial s&f são usadas para conter um volume definido cada uma, e vêm em três capacidades diferentes, permitindo um máximo de 2x2x2, 16x16x16 e &6128x128x128&r blocos de espaço. "
		""
		"Após a codificação, uma célula recebe uma seção de espaço dentro da &edimensão&f de armazenamento espacial, juntamente com um ID exclusivo correspondente à região alocada para a célula. Uma célula codificada ainda pode ser usada na &bPorta de E/S Espacial&r para recuperar quaisquer blocos e entidades armazenados. "
		""
		"A partir daí, quaisquer blocos contidos na região de espaço da célula ou em um &6ECE&r do mesmo tamanho do usado para a codificação inicial podem ser movidos de volta para o Mundo Superior ou para a dimensão espacial, respectivamente. Se houver blocos tanto na região espacial quanto no &6ECE&r, eles simplesmente trocarão de lugar."
	]
	quest.6F3D0A248B5A9CA2.title: "Célula de Armazenamento Espacial"
	quest.6F416275B6F6D8F0.quest_desc: ["Blisterberries aparecem em Smog Spires. \\n\\nComo crescem em uma área tão nojenta, algumas virão Podres. \\n\\nNão recomendo comer essas, talvez possam ser úteis para outra coisa!"]
	quest.6F57BE412A7BE84E.quest_desc: ["&9Almas Corrompidas&r são usadas para 2 coisas! \\n\\n1. Receita de criação com a &6Forja &l&dTier 4&r, com a qual não precisamos nos preocupar agora. \\n\\n2. Cultivar Edelwood! \\n\\nCultivar Edelwood funciona como a Muda para Edelwood, esta é a única maneira de obter Edelwood agora."]
	quest.6F57BE412A7BE84E.title: "&9Almas Corrompidas"
	quest.6F59C939D62FA6C8.quest_desc: ["&5Fragmentos Tera&r são drops raros ao derrotar &cPokémon&r selvagens. \\n\\nO tipo do &cPokémon&r determina o drop, então &cPokémon&r do tipo Normal droparão Fragmentos Tera Normal, e &cPokémon de Fogo&r darão &cFragmentos Tera de Fogo&r. \\n\\nTodo &cPokémon&r tem 10% de chance de dropá-los. Também há 1% de chance de todos os &cPokémon&r droparem um &5Fragmento Tera Estelar&r."]
	quest.6F59C939D62FA6C8.title: "&5Fragmentos Tera"
	quest.6F62B5510FA881CD.quest_desc: ["&7Ósmio&r é um Minério que surge abaixo do Nível Y 56. Seu Minério tem forma semelhante à &aEsmeralda&r com a Cor sendo um &bAzul-&7acinzentado&r! \\n\\nSerá útil para muitas das &5Máquinas&r usadas em &5&lMekanism&r! Então você precisará de muito! \\n\\nVocê também pode Criar &7Armadura &fe &7Ferramentas&r com ele! A &7Armadura &fe &7Espada&r têm os mesmos Pontos que a &cNetherita&r! Enquanto a &7Picareta&r é a mesma que uma &7Picareta de Ferro&r."]
	quest.6F62B5510FA881CD.quest_subtitle: "O Barra de Criação Base"
	quest.6F62B5510FA881CD.title: "&7Ósmio"
	quest.6F65216B13E9FFA9.quest_desc: ["Pegue um Bloco. Literalmente qualquer Bloco. \\n\\nTodo Jogador deveria saber que Blocos são os Blocos de construção da construção. Para realmente construir algo, você precisará de Blocos."]
	quest.6F65216B13E9FFA9.title: "Blocos!"
	quest.6F709652A2B88C78.quest_desc: ["O transmissor de energia fornece energia aos blocos dentro de seu alcance de trabalho, ele só pode aceitar energia pela parte inferior."]
	quest.6F71FD826C29C31A.quest_desc: [
		"Essa pode ser nova para quem está voltando de versões anteriores.\\n"
		"Ao usar um &9Ovo de Tartaruga&r em um &6Gerador&r, ele passará a gerar apenas versões bebês dos mobs contidos nele.\\n"
		"Isso só funciona com versões bebês dos mobs do &2Vanilla&r, não com mobs de mods."
	]
	quest.6F71FD826C29C31A.title: "Jovem"
	quest.6F76DA3BBAE8337B.quest_desc: ["A melhor Armadura que podemos obter de &6&lAllthemodium&r, &5Unobtainium&r! \\n\\nAgora com 100% de Resistência a Repulsão e atributos mais altos em tudo! \\n\\nTambém precisa de &3Armadura de Vibranium&r para ser feita."]
	quest.6F76DA3BBAE8337B.quest_subtitle: "40"
	quest.6F76DA3BBAE8337B.title: "Armadura de &5Unobtainium"
	quest.6F7AC41B703028CC.quest_subtitle: "Despeje Constantan Derretido sobre um Ovo de Gerador de Abelha de Prata/Cobre"
	quest.6F7AC41B703028CC.title: "&fAbelha de Signalum"
	quest.6F978C4D561F35EC.quest_desc: [
		"O Engarrafador tem dois usos: engarrafar mel e esmagar abelhas para obter genes.\\n\\nPara obter genes de abelhas, coloque um pistão acima do Engarrafador com um bloco de espaço entre eles.\\n\\nColoque a abelha em cima do Engarrafador e ative o pistão para esmagar a abelha em genes. A garrafa esmagada resultante pode então ser colocada em uma Centrífuga.\\n\\nNota: Certifique-se de ter garrafas no Engarrafador."
		"{image:atm:textures/questpics/bees/bottler.png width:100 height:150 align:1}"
	]
	quest.6F978C4D561F35EC.quest_subtitle: "Querida, Esmaguei as Abelhas"
	quest.6F978C4D561F35EC.title: "&fEngarrafador"
	quest.6FBAE89EE782DABA.quest_desc: ["Quando colocado e conectado com a &aFerramenta de Vinculação&r a outras Gavetas, o Controlador atua como um \"Hub\".\\n\\nSe você clicar duas vezes com o botão direito nele, todos os itens em seu inventário que têm um slot na rede de Gavetas serão puxados.\\n\\nAo clicar com o botão direito e shift no controlador com a mão vazia, você pode abrir a aba de melhorias, adicionar melhorias de armazenamento normais a esses slots para aumentar o alcance do Controlador. O alcance máximo é de 40 blocos para todos os lados, ou um cubo de 80x80x80."]
	quest.6FBAE89EE782DABA.quest_subtitle: "O Cérebro das Gavetas"
	quest.6FBE5B5D5027B32C.quest_desc: ["Usar este &7Chapéu&r faz seus bichos correrem como o vento! \\n\\nE é bem bonito também."]
	quest.6FBE5B5D5027B32C.quest_subtitle: "Cabeça"
	quest.6FBE5B5D5027B32C.title: "&7Chapéu de Cowboy"
	quest.6FBF112811FB707C.quest_subtitle: "Ash + Birch"
	quest.6FC4146E534C51DA.quest_desc: ["Você pode combinar um Molde de Melhoria de Netherita, um Elmo de Netherita e um &cChifre Monstruoso&r para fazer o &cElmo Monstruoso&r. \\n\\nEle tem os mesmos atributos, mas quando você está com metade da vida, ele Repelirá tudo perto de você e aumentará os atributos de defesa."]
	quest.6FC4146E534C51DA.title: "&cElmo Monstruoso"
	quest.6FC55CF56BE22866.quest_subtitle: "531.441 de Terra"
	quest.6FD4C60B547F4131.quest_desc: [
		"Melhorias Válidas:"
		"- Ore Miner"
		"- Ore Scanner &4&lDISABLED&r&f"
		"- Auto Smelter"
		"- Hammer"
		"- Drops Teleporter"
	]
	quest.6FD65139CD50A8C0.quest_desc: ["Isso é sequer possível?\\n\\nSe você deseja automatizar este processo, pode usar &eProductive Bees&r ou &aMystical Agriculture&r. Ou, eu acho, você poderia automatizá-lo com... explosões."]
	quest.6FD65139CD50A8C0.quest_subtitle: "Cansado de explodir coisas?"
	quest.6FEED25FFAC4101F.quest_desc: ["Usando o &aVínculo Superior de Strigeor&r, você pode criar Pasta Cinza. Passe isso em um pedaço de Giz Branco Impuro para criar Giz Cinza."]
	quest.6FEED25FFAC4101F.title: "&8Giz Cinza"
	quest.6FF04DD735346BED.quest_desc: ["Transforma Látex em Borracha Seca. Usa 750 mB de Látex e 500 mB de &9Água&r para produzir 1 Borracha Seca."]
	quest.6FFD0301AC8C83ED.quest_subtitle: "Usando menos energia"
	quest.6FFFAE334DFAAAAB.quest_desc: [
		"Como você provavelmente notou, os rituais tendem a ser... um pouco lentos. Mas não mais! Usando o &cConfinamento Permanente de Sevira&r, você pode criar a &bTigela Ritualistica de Iesnium&r. "
		""
		"Ao usar isso no lugar de uma Tigela Ritualistica Dourada, reduz muito o tempo que leva para realizar um ritual, diminuindo para um quarto do tempo original!"
	]
	quest.6FFFAE334DFAAAAB.quest_subtitle: "Rituais super-rápidos!"
	quest.6FFFAE334DFAAAAB.title: "Tigela Ritualistica de Iesnium"
	quest.700F346E3361E9AF.quest_desc: [
		"Agora que você tem &8Aço&r, pode melhorar suas &6Máquinas de Bronze&r, se quiser. "
		""
		"As &8Máquinas de Aço&r podem processar receitas de até &64 EU/t&r, e irão processá-las com o dobro da velocidade, desde que o consumo de energia não ultrapasse &64 EU/t&r. "
		""
		"Basicamente, elas são duas vezes mais rápidas que as &6Máquinas de Bronze&r e podem até desbloquear novas receitas."
		""
		"Para aprimorar uma &6Máquina de Bronze&r, crie uma &8Melhoria de Aço&r e aplique-a em uma &e&nBancada de Trabalho&r."
		""
		"Você também pode agachar e clicar com o botão direito em uma &6Máquina de Bronze&r com a melhoria para aplicá-la diretamente."
	]
	quest.700F3FF7C23D0C0F.quest_desc: ["A &5Célula do End&r armazenará energia para um canal em sua &7Rede do End&r. Para aumentar a capacidade de energia da rede, clique com o botão direito na Célula do End para abrir a interface e adicione uma &aBateria&r ou uma &9Célula de Energia&r para aumentar a capacidade geral."]
	quest.7032AC2B9066CC39.quest_desc: ["Coloque-o em um slot de addon e você terá mais espaço para colocar seus addons."]
	quest.7032AC2B9066CC39.quest_subtitle: "Mais addons!"
	quest.703BDCDC88DD813C.quest_desc: [
		"Melhorias Válidas:"
		"- Lawnmower"
		"- Sky Sweeper"
		"- Auto Smelter"
		"- Hammer"
		"- Drops Teleporter"
		"- Instant Break"
	]
	quest.7040CA41C0A3C2F2.quest_desc: [
		"&3Plantas de PCB&r EM PROMOÇÃO AGORA por 8 Esmeraldas. (Apenas por tempo limitado)."
		"{@pagebreak}"
		"(texto de espaço reservado de nova página)"
	]
	quest.7040CA41C0A3C2F2.quest_subtitle: "Obrigado Amadron!"
	quest.7040CA41C0A3C2F2.title: "&9Planta de PCB"
	quest.7044EAB5EDF32BBC.quest_desc: ["Quando conectado ao seu sistema, o &9Crafting Monitor&r permite que você veja quais itens estão atualmente na sua fila de criação.\\n\\nVocê precisará de um desses se quiser poder cancelar criações que não estão funcionando ou estão bugadas."]
	quest.7044EAB5EDF32BBC.title: "&3Monitorando a Autocriação"
	quest.7045F1A0E409CB8C.quest_desc: ["&lIron Furnaces&r é um Mod que melhora as &cFornalhas&r. \\n\\nCom o &c&lMinecraft com Mods&r você estará fundindo uma tonelada de coisas! Para economizar tempo (e TPS), use &cFornalhas&r melhores em vez de mais. \\n\\nQuanto melhor a &cFornalha&r, mais rápido elas fundem e mais elas fundem. \\n\\nElas também têm melhorias que podem mudar tudo, desde o combustível até a energia, o que elas fundem e a eficiência."]
	quest.7045F1A0E409CB8C.title: "&lIron Furnaces"
	quest.7060290E107D92AB.quest_desc: ["Muitas coisas precisarão de &cEnergia&r, incluindo alguns &eItens&r que não podem ser colocados no chão, como a &5&lRailgun&r! Então, como os carregamos? \\n\\nA Estação de Carregamento é a nossa solução para esse trabalho! \\n\\nSimplesmente &6Insira &cEnergia&r pela parte de trás ou de baixo, e estará pronta para carregar qualquer &eItem&r colocado dentro dela! \\n\\nIsso inclui &5&lRailguns&r, &cAcumuladores&r e coisas de outros Mods! No entanto, não pode carregar Blocos perto dela..."]
	quest.7080F026A37F1832.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods. \\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita. \\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.708129CB530BAC67.quest_subtitle: "Wild Cherry + Cacao"
	quest.7081E9BF44EFBCB0.title: "Módulo Grande de Capacidade de Escudo Caótico"
	quest.7084E47579D62B52.quest_subtitle: "Um circuito para fazer mais"
	quest.70902EF96F060672.quest_desc: ["Esta melhoria fará com que as Gavetas emitam um sinal de Redstone em todos os lados, com a força do sinal indicando o quão cheia/vazia ela está.\\n\\nPara Gavetas com múltiplos slots, a melhoria pode ser configurada para qual slot monitorar.\\n\\n0 - significa vazio.\\n15 - significa cheio."]
	quest.70A4E2B0491634FA.quest_subtitle: "Pinha + Banana"
	quest.70A82A5D17D558FB.quest_desc: ["A Espada de Energia só pode ser dropada pelo Starlight Golem. \\n\\nEla funciona como uma Espada normal, mas com o Botão Direito você pode avançar em direção a eles enquanto a balança, como o Genji do Overwatch! "]
	quest.70AD088336748892.quest_desc: ["Apenas um simples gerador a carvão."]
	quest.70B6C9409AE69284.quest_desc: ["A Nature's Compass te dá uma lista de biomas que você pode procurar.\\n\\nSelecione um bioma, depois aperte 'Search'. Você verá algumas informações no canto superior esquerdo, e a bússola apontará na direção do bioma.\\n\\nA Explorer's Compass funciona da mesma forma, mas para estruturas, em vez de biomas."]
	quest.70B6C9409AE69284.quest_subtitle: "Ajuda a Encontrar Biomas/Estruturas"
	quest.70B6C9409AE69284.title: "Bússolas para Busca"
	quest.70BF85E2D235BAD5.quest_desc: ["Jogar Voidflame Coal no Blaze Ember Fuel criará Unrefined Voidflame Fuel. Realizar um Goo Spread com goo de Tier Três ou superior converterá Unrefined Voidflame Fuel em Voidflame Fuel."]
	quest.70C404E5685E4E91.quest_desc: ["Apenas um simples colocador de blocos."]
	quest.70C7D92844089DEB.quest_desc: ["Como os outros Pingentes, este tem a chance de ferir seu atacante, só que com Raios! \\n\\nTambém faz com que, se você tiver a (falta de) sorte de ser atingido por um Raio, ele não te machuque."]
	quest.70C7D92844089DEB.quest_subtitle: "Colar"
	quest.70C7D92844089DEB.title: "&bPingente de Choque (Shock Pendant)&r"
	quest.70C878DB6AE413B2.quest_subtitle: "Magmatic + Carvão"
	quest.70C878DB6AE413B2.title: "&fAbelha de Enxofre"
	quest.70CDA5F1593DB4B2.quest_desc: [
		"A &eThe Cursed Pyramid&r aparece em desertos e é muito difícil não a ver. Uma pirâmide massiva com enormes pilares na entrada. \\n\\Entra e encontrarás armadilhas por toda parte, &eKoboletons&r e mini-bosses! \\n\\nNão te preocupes, também há Baús, Potes e até Areia Suspeita que precisarás para o..."
		"{image:atm:textures/questpics/cataclysm/cataclysm_pyramid.png width:200 height:100 align:center}"
	]
	quest.70CDA5F1593DB4B2.title: "&ePirâmide Amaldiçoada&r: Lar do &e&lRemanescente Ancestral&r"
	quest.70D2C5FAC661E01A.quest_desc: ["A &bEstante de Livro Marinha Forjada no Coração&r é outra melhoria para a &bEstante de Livro Marinha Infundida&r. \\n\\nÉ um pouco cara, mas dá muita &5Arcana&r! \\n\\nIsso será muito útil para &d&lInfusões&r posteriores que precisam de muita &5Arcana&r."]
	quest.70D2C5FAC661E01A.title: "&bEstante de Livro Marinha Forjada no Coração"
	quest.70DB76D3E7704E2C.quest_subtitle: "&f12 &cde Dano de Ataque"
	quest.70E4EBA7C9901007.quest_subtitle: "Tier: &b4"
	quest.70ED849A2EB44DEE.quest_subtitle: "Tier: &b3"
	quest.70F7B018CD61E946.quest_subtitle: "Dark Oak + Jungle"
	quest.70FAD4013FA8A14A.quest_subtitle: "Aumente a velocidade de processamento"
	quest.70FB4088084018D3.quest_desc: [""]
	quest.70FB4088084018D3.quest_subtitle: "Feito no Reprocessador"
	quest.70FB4088084018D3.title: "&fAbelha de Ludicrite"
	quest.70FD8856BFCD9AEE.quest_desc: [
		"O maior e mais perigoso &cMob da Podridão (Rot Mob)&r. \\n\\nEles têm 80 Corações, o que eu acho que se qualifica como um Miniboss. \\n\\nComo todos os &cMobs da Podridão&r, eles atacarão &2Stoneborns&r e &7Forgottens&r e droparão &cUtheric Shards&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotbeast.png width:100 height:100 align:center}"
	]
	quest.70FD8856BFCD9AEE.title: "&cRotbeast&r"
	quest.71055E7BBB337C4D.quest_desc: [
		"O &3&lMaledictus&r pode ser trazido de volta de Valhalla ou qualquer que seja a versão nórdica do Inferno, clicando com o botão direito na &3Cursed Tombstone&r. \\n\\nEle tem 8.400 &4Corações&r e Asas enormes.\\n\\nEle te atacará com seus 2 &3Annihilators&r e pode até mesmo te esmagar no chão com eles, criando uma Onda de Choque, é claro! \\n\\nSuas Asas permitem que ele manobre e realize muitos outros ataques. Ele pode avançar em sua direção, quebrando todos os Blocos em seu caminho ou até mesmo desviar de ataques! \\n\\nEle pode voar para o ar e de lá pode atirar em você com seu &3Cursed Bow&r ou descer com sua &3Soul Render&r. O &3Cursed Bow&r atirará 4 Flechas em você. Com sua &3Soul Render&r, ele trará uma chuva de &3Phantom Halberds&r sobre você."
		"{image:atm:textures/questpics/cataclysm/cataclysm_maledictus.png width:125 height:100 align:center}"
	]
	quest.71055E7BBB337C4D.title: "&3&lMaledictus"
	quest.710C7FEFAA6C0979.quest_desc: ["Versão aprimorada da Espada Wyvern."]
	quest.710C7FEFAA6C0979.title: "Espada Dracônica"
	quest.71128E508D810DDF.quest_desc: [
		"Melhorias Válidas:"
		"- Flecha de Poção"
		"- Explosão"
		"- Duradouro"
		"- Flecha Guiada"
		"- Fase"
		"- Flecha Yondu"
	]
	quest.711826BBCA832EE2.quest_desc: ["Todos os &8Moldes&r são feitos da mesma forma. Em outro sentido, quero dizer que são feitos do mesmo jeito. \\n\\nDerramando &8Aço&r sobre um Item em uma &8Mesa de Fundição (Casting Table)&r! \\n\\nComo fazemos &8Aço&r, você pergunta? Simplesmente derreta quaisquer Itens ou Barras de &8Aço&r. Ou você pode ligar 9 de &7Ferro&r com 10 de &0Carvão&r. \\n\\nA ligação ocorrerá quando a &c&lFundição&r estiver &6Aquecida&r e as quantidades corretas de diferentes &7Metais Líquidos&r estiverem nela. Esses dois &7Metais Líquidos&r se combinarão em um &7Metal Líquido&r!"]
	quest.711826BBCA832EE2.title: "&8Moldes"
	quest.7119F8C352D057BC.quest_desc: ["Agora estamos chegando na parte divertida! Os itens Raros chegam até a Élitros! Sim, eu pensaria que é melhor que Raro, mas não fui eu que fiz essa classificação."]
	quest.711DDD55CEC439E5.quest_desc: ["A &aEmerald Furnace&r, me pergunto se os Villagers trocarão por ela? \\n \\nEla funciona em 40 Ticks ou apenas 2 segundos para derreter! Pisque e você pode perder. \\n \\nEstas são criadas a partir da &bFornalha de Diamante&r e podem ser transformadas em uma &dObsidian Furnace&r."]
	quest.711DDD55CEC439E5.title: "&aEmerald Furnace"
	quest.712EB19B26D405DD.quest_subtitle: "Tier: &e1"
	quest.713006AB89E43C6D.quest_desc: [
		"O topo da imensa &9Acropolis&r é onde a &9&lScylla&r vai aparecer. Assim como o &d&lGuardião Ender&r, você só precisa estar perto para que ela apareça aqui. \\n\\nEla é um dos menores Chefes de &4&lCataclysm&r, com apenas cerca de 3 Blocos de altura. Além disso, no momento, ela tem 390 &4Corações&r e 12 Pontos de Armadura. Não se preocupe, ela será Fortalecida muito em breve! \\n\\nNão deixe que seu Tamanho ou a falta de Buffs de &6&lATMons&r façam você subestimá-la, ela tem alguns dos maiores Ataques de todos os Chefes daqui. \\n\\nEla pode usar sua &9Âncora&r, &9Ceranus&r, para puxá-lo para mais perto dela de longe, ou simplesmente balançá-la em sua direção para causar um dano enorme! \\n\\nEla pode lançar &9Lanças de Raios&r em você de suas Costas ou das Nuvens. Até pode saltar para o Ar e cair de volta, trazendo &9Raios de Relâmpago&r ao redor do local onde ela atingiu. \\n\\nIsso não é tudo! Ela também tem controle sobre a &9Água&r, permitindo que ela envie &9Ondas&r em sua direção ou até invoque &9Cobras Marinhas&r para morder você! \\n\\nQuando derrotada, ela soltará o Equipamento usual de Chefes, além de &9Lacrima&r e &9Essência da Tempestade&r."
		"{image:atm:textures/questpics/cataclysm/cataclysm_scylla.png width:100 height:100 align:center}"
	]
	quest.713006AB89E43C6D.title: "&9&lScylla"
	quest.713548E540B18E07.quest_desc: ["O Moonring Bow só pode ser dropado pela Lunar Monstrosity. \\n\\nEle atira Flechas como um Arco normal, mas Espigões de Chão surgirão na mesma direção que a Flecha foi!"]
	quest.713D3B3954E58C4A.quest_desc: [
		"O Nível 3 precisa de 26 Blocos de Barra de Draconium ao redor dele, envolvendo completamente o Núcleo, para ser feito."
		"{image:atm:textures/questpics/draconic/draconic_core_3off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_3on.png width:100 height:100 align:1}"
	]
	quest.713D3B3954E58C4A.quest_subtitle: "Armazena: 1.640.000.000 RF"
	quest.713D3B3954E58C4A.title: "Nível 3"
	quest.713EF442D59501BA.quest_desc: ["A Chain of Souls só pode ser criada a partir de drops do Tangled Hatred e da Lunar Monstrosity. \\n\\nÉ um gancho! Toque com o Botão Direito para enviá-lo e, assim que atingir algo, ele começará a te puxar. Então, você tem que clicar com o Botão Direito novamente para soltá-lo. \\n\\nTambém é necessário para a ATM Star!"]
	quest.71436F63681DC98D.quest_desc: ["Não importa o nível, tipo, raridade, etc. do &cPokemon&r, a &5&lBola Mestra&r irá capturá-lo (se ele já não tiver sido capturado). \\n\\nTambém é essencial para fabricar a &6&lATM Star&r!"]
	quest.71436F63681DC98D.title: "&5&lBola Mestra"
	quest.7143CE930D08F160.quest_desc: ["Área de Efeito é uma frase que a maioria dos Gamers conheceria. Basicamente, aprimora a área de trabalho da Ferramenta em que está. Picaretas com AdE 3x3 minerarão em uma área de 3x3. Espadas com AdE 3x3 matarão todos os mobs atingidos dentro dessa área. Quanto melhor o aprimoramento, maior a área. Não, não é acumulável!"]
	quest.7143CE930D08F160.title: "Módulo de Área de Efeito Básico"
	quest.71441DFA05FD73E5.quest_desc: [
		"Melhorias Válidas:"
		"- Mind Fog"
		"- Stupefy"
		"- Night Vision"
	]
	quest.71525B9B007ECD34.quest_desc: [
		"Sem aumento de nível. "
		""
		"Item de Assinatura é &8Pedra Negra&r."
	]
	quest.71525B9B007ECD34.title: "&7Archer, Admin. da Equipe Rocket"
	quest.7154D73516548149.quest_desc: ["&6&lAllthemodium&r é um mod adicionado especificamente pela &6Equipe AllTheMods&r para adicionar mais conteúdo após a Netherite! \\n\\nVocê precisará se aventurar por ele para obter alguns Itens necessários para a &6&lEstrela ATM&r. \\n\\nHá uma página de Missões agora que você pode seguir para isso!"]
	quest.7154D73516548149.title: "&l&6Allthemodium"
	quest.71581992E8E4C43E.quest_desc: ["Jogue alguns &8Crânios de Esqueleto Wither&r e uma &dEssência de Abjuração&r para fazer um &3Glifo&r de &8Wither&r! \\n\\nSe não funcionou, você pode precisar de mais &aEXP&r."]
	quest.71581992E8E4C43E.title: "&3Glifo de &8Wither"
	quest.715B86DC82EA636B.quest_desc: [
		"O &3Compressor de Líquidos&r cria pressão usando certos líquidos. Você pode colocar o combustível clicando com o botão direito do balde na máquina, bombeando o fluido para dentro, ou colocando um balde no slot superior na GUI."
		""
		"{image:pneumaticcraft:textures/gui/gui_liquid_compressor.png width:200 height:200 align:center fit:true}"
	]
	quest.715B86DC82EA636B.title: "Pressão de Líquidos"
	quest.715EC1B06585C141.quest_desc: ["&l&cAll&7The&fMons&r é um &6&lModpack ATM&r baseado em &l&cCobble&fmon&r! \\n\\nO objetivo ainda será a &6&lEstrela ATM&r como de costume, mas desta vez você precisará jogar através do &l&cCobble&fmon&r. \\n\\nComo o &c&lCobble&fmon&r (e seus complementos) é um mod tão grande e importante, ele ganha seu próprio Capítulo! \\n\\nSe você precisar aprender como passar pelo &c&lCobble&fmon&r, confira esse Capítulo; este aqui o guiará por todo o resto. Do &2&lVanilla&r até a &6&lEstrela ATM&r!"]
	quest.715EC1B06585C141.title: "&2&lMinecraft"
	quest.715F9F7107374299.quest_desc: ["Cristal Wyvern (Relé de Energia). Faz exatamente o mesmo que o Cristal Básico, apenas com mais Energia e mais Links."]
	quest.715F9F7107374299.title: "Cristal de Relé de Energia Wyvern"
	quest.71667FFC8011525C.quest_subtitle: "Magmática + Cortadeira de Folhas"
	quest.71667FFC8011525C.title: "&fAbelha de Carvão"
	quest.716F9AA2E9011F06.quest_desc: ["Ele não aumentará seu Limite de Nível. \\n\\nSeu Item de Assinatura é um &eRelógio&r!"]
	quest.716F9AA2E9011F06.title: "&7Chefe da Equipe Galáctica Cyrus"
	quest.716FF64ACF896D50.quest_desc: ["A &cArdósia Resinada&r substitui a &3Pedra de Sculk&r nas &cColunas Nubladas&r. \\n\\nFunciona exatamente como a &3Pedra de Sculk&r, só que mais Marrom."]
	quest.716FF64ACF896D50.title: "&cArdósia Resinada"
	quest.71766BD7321FCB13.quest_desc: ["Ótimo, outro &c&lInfusor Químico&r! \\n\\nCombine o &aÓxido de Urânio&r e o &7Ácido Fluorídrico&r para criar &aHexafluoreto de Urânio&r. \\n\\nAgora podemos processar o &aHexafluoreto de Urânio&r em uma &5&lCentrífuga Isotópica&r para finalmente obter nosso belo &2Combustível Fóssil&r."]
	quest.71766BD7321FCB13.quest_subtitle: "Nada como um pouco de urânio no café da manhã ☢"
	quest.71766BD7321FCB13.title: "&2Combustível Fóssil"
	quest.7177653B736AB10E.quest_desc: ["Podemos combinar &cDeutério&r e &aTrítio&r em um &c&lInfusor Químico&r para fazer nosso &5Combustível D-T&r. Também podemos simplesmente &ctransportar&r ambos os &cQuímicos&r para dentro do &c&lReator de Fusão&r e combiná-los dentro do &c&lReator&r. \\n\\nSe apenas &ctransportarmos&r o &5Combustível D-T&r, ele Injetará na taxa em que é &ctransportado&r. Mas se &ctransportarmos&r tanto o &cDeutério&r quanto o &aTrítio&r e os combinarmos dentro do &c&lReator&r, podemos escolher qualquer Taxa de Injeção que quisermos! \\n\\nTambém precisaremos de uma pequena quantidade de &5Combustível D-T&r dentro de um &eHohlraum&r e colocá-lo no &c&lReator de Fusão&r para a partida inicial. \\n\\nComo fazemos um &eHohlraum&r, você pergunta? Apenas &9Infunda &f4 &ePós de Ouro&r com 10mb de &0Carbono&r em um &9&lInfusor Metalúrgico&r para Criar o &eHohlraum&r. \\n\\nAh, espere, ele sai vazio. Jogue-o em uma &5Máquina&r que tenha &5Combustível D-T&r para enchê-lo. Então, coloque-o no Slot da INTERFACE do &c&lReator de Fusão&r, e está pronto!"]
	quest.7177653B736AB10E.title: "&5Combustível D-T&r"
	quest.7177E49BF9ECA5CF.quest_desc: [
		"O &3Compressor Térmico&r cria pressão usando calor! Coloque algo quente de um lado e algo frio do outro para criar pressão."
		""
		"{image:pneumaticcraft:textures/patchouli/thermal_compressor.png width:100 height:100 align:left fit:true}"
	]
	quest.7177E49BF9ECA5CF.title: "Pressão do Calor"
	quest.71869B1D81D6A7EF.quest_desc: ["A &2&lC.R.P.&r (&2&lCâmara de Reação Pressurizada&r) combina múltiplos &bFluidos &fe &cQuímicos&r com um &eItem&f para fazer novos &eItens &fe &cQuímicos&r! \\n\\n&bFluidos&r, muito provavelmente &9Água&r, vão na Barra mais à esquerda. &cQuímicos&r vão na Barra ao lado, e &eItens&r iniciais no &4Slot Vermelho&r. \\n\\nO &eItem&r finalizado aparecerá no &9Slot Azul&r e o &cQuímico&r finalizado estará na &9Barra Azul&r. \\n\\nA &2&lC.R.P.&r pode fazer alguns Itens como Itens de PEAD, &7Pólvora&r e &aEnxofre&r, e até &2Itens Nucleares&r!"]
	quest.71869B1D81D6A7EF.title: "&2&lCâmara de Reação Pressurizada"
	quest.7188DC06A28AE30E.quest_desc: ["Usar este &eGancho de Ouro&r aumentará o seu rendimento de experiência de inimigos derrotados!"]
	quest.7188DC06A28AE30E.quest_subtitle: "Mãos"
	quest.7188DC06A28AE30E.title: "&eGancho Dourado&r"
	quest.718A2040D868E09F.title: "&2Parte de Armazenamento de 1048m"
	quest.718DABA6C9E5982A.quest_desc: ["Concede ao jogador Visão Noturna quando usado."]
	quest.718DABA6C9E5982A.quest_subtitle: "Máx: 1"
	quest.719739C46C9296DB.quest_desc: ["Existem 3 maneiras de fazer a &bTampa da Grande Bola de Fogo&r. A mais simples é usando o &6&lCreate&r. \\n\\nColoque a &9Tampa de Grande Bola&r sob um &bBico&r para despejar o equivalente a um balde de &9Lava da Alma&r sobre ela. \\n\\nTambém podemos construir uma &dRefinaria&r colocando a &dRefinaria&r com 9 Estruturas de Máquina no padrão mostrado pelos destaques. \\n\\nApenas clique com o botão direito na &dRefinaria&r para ligá-la. Então, uma vez que a &cEnergia&r esteja ligada, a &9Lava da Alma&r tubulada e uma &9Tampa de Grande Bola&r seja colocada, poderemos fazer nossa &bTampa da Grande Bola de Fogo&r. \\n\\nSe contar baldes de fluido for muito difícil, faça uma Câmara de Pressão em vez disso. Lá você pode apenas combinar o &9Balde de Lava da Alma&r com a &9Tampa de Grande Bola&r para fazer a &bTampa da Grande Bola de Fogo&r."]
	quest.719739C46C9296DB.title: "Queimando nossa &9Tampa de Grande Bola"
	quest.7198ED7E97A256A4.quest_desc: ["A primeira Vareta de Adivinhação especial criada é a Vareta de Material Abundante! \\n\\nQuando você cria a Vareta com um &eAlchemical Sulfur&r de um Item, a Vareta será sintonizada com aquele Item. \\n\\nVocê pode ver a lista de Materiais Abundantes nas Tags, é grande demais para eu ler nas Missões."]
	quest.719D5CEB4217B734.quest_desc: [
		"É uma casa em forma de &8A&6b&8e&6l&8h&6a&r! \\n\\nUma Casa de &8A&6b&8e&6l&8h&6a&r! \\n\\nTem alguns saques muito simples, &6Mel&r, e às vezes um residente &8A&6b&8e&6l&8h&6a&r!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_house.png width:200 height:100 align:center}"
	]
	quest.719D5CEB4217B734.title: "Casa de &8A&6b&8e&6l&8h&6a&r"
	quest.71A1FD0772453B51.quest_desc: ["Você não odeia clicar com o botão direito em tudo? De ovelhas com tesouras a vacas com baldes? Estamos no século 21, deveríamos ter robôs para tudo! Ou pelo menos Roteadores para fazer tudo. \\n\\nCom o Módulo Ativador, ele agirá como se fosse você clicando com o botão direito nas coisas. \\n\\nVocê pode definir no que ele vai clicar com o botão direito, se ele vai Atacar ou Usar o Mob ou Bloco, se você clicar com Shift + Botão Direito, e quão perto eles precisam estar no Módulo."]
	quest.71AA40CB2948A8D7.quest_subtitle: "Blue Yonder + Árvore da Alma"
	quest.71B1B53A03A16296.quest_desc: ["As &bInterfaces de Fluido Portáteis&r são usadas com &aEngenhocas&r que estão usando &bTanques de Fluido&r. \\n\\nPara acessar os &bTanques de Fluido&r, você precisará de duas &bInterfaces de Fluido Portáteis&r, uma conectada à &aEngenhoca&r e outra conectada a &bTubos de Fluido&r. \\n\\nAs &bInterfaces de Fluido Portáteis&r precisarão de um espaço de 1 ou 2 Blocos entre um ponto de encontro para que funcionem. \\n\\nSe tivermos tudo isso, a &bInterface de Fluido Portátil&r conectada à &aEngenhoca&r irá parar a &aEngenhoca&r para pegar &bFluidos&r de entrada ou saída da segunda &bInterface de Fluido Portátil&r para adicioná-los aos &bTanques de Fluido&r dentro da &aEngenhoca&r."]
	quest.71B1B53A03A16296.title: "&bInterfaces de Fluido Portáteis"
	quest.71B6F013C8A60EB6.quest_desc: ["O &2Diminuidor de Copa&r e o &2Absorvedor Herbívoro&r são ambos formas simples e fáceis de gerar aura."]
	quest.71B6F013C8A60EB6.quest_subtitle: "Mais Aura!"
	quest.71B6F013C8A60EB6.title: "Criação de Aura"
	quest.71B72958B9F80355.quest_desc: ["Não se preocupe, não há mais drops nesta fase! \\n\\nAgora só precisamos criar! Crie a Lente da &3Morte Certa&r, com uma &bEspada de Diamante&r e um &5Livro Encantado de Afiação V&r. \\n\\nVocê pode obter os &5Livros Encantados&r no &5&lEncantador Rúnico&r! Sobre o qual você pode aprender mais em outra Missão!"]
	quest.71B72958B9F80355.title: "Lente do &4Assassino"
	quest.71C552678A0F649F.quest_desc: ["O &7Ósmio&r aparece ao redor da Deepslate e só precisa de Ferro para ser minerado, mas oferece estatísticas melhores que a &cNetherite&r!"]
	quest.71C552678A0F649F.quest_subtitle: "21"
	quest.71C552678A0F649F.title: "Armadura de &7Ósmio"
	quest.71C58666D4BC2508.quest_desc: ["Funciona como Pederneira e Aço!"]
	quest.71CF9E59F8F0B4A6.quest_desc: ["Estas &5Máquinas&r são ainda melhores que as &c&lAvançadas&r! \\n\\nUse &eItens&r do &b&lTier de Elite&r para fazer estas &5Máquinas&r!"]
	quest.71CF9E59F8F0B4A6.title: "&5Máquinas&r ainda melhores!"
	quest.71E1454990DEC451.quest_desc: [
		"Os &bGwibs&r são versões maiores e mais irritadas dos &bGwiblings&r. \\n\\nEles não têm Drops nem podem ser colocados em Baldes. Tudo o que eles oferecem é dor!"
		"{image:atm:textures/questpics/undergarden/undergarden_gwib.png width:100 height:100 align:center}"
	]
	quest.71E1454990DEC451.title: "&bGwib&r"
	quest.71E4FD61787DE299.quest_desc: [
		"Outro item que você só pode encontrar em Cidades Ancestrais é o &6Modelo de Ferraria de Allthemodium&r.\\n\\nPara obtê-lo, você precisará escovar Argila suspeita.\\n\\nVocê pode encontrá-la nos pisos da Cidade Ancestral.\\n"
		"{image:atm:textures/questpics/allthemodium/all_clay.png width:200 height:100 align:center}"
	]
	quest.71E4FD61787DE299.title: "&6Modelo de Ferraria de Allthemodium"
	quest.71FDF8CD953E46FC.quest_desc: ["HAHAHA eu te assustei com o item Criativo nas missões?\\n\\nNão se preocupe, você não precisará do item para terminar este capítulo, eu só queria te assustar\\n\\nEu posso me divertir às vezes..."]
	quest.7208CB011F6E2ACF.quest_desc: ["Podem ser encontradas em estruturas na &l&6Bumblezone&r ou trocadas com a &5Rainha Abelha&r! \\n\\nEstas Botas de Abelha Carpinteira são verdadeiramente incríveis, você pode correr pelas paredes ou pular mais longe de Tábuas de Madeira, Folhas e &6Blocos de Mel&r. \\n\\nAlém disso, enquanto segura Shift, as Botas minerarão o Bloco abaixo de você."]
	quest.7217BEFB0088A442.quest_desc: ["Ervas de Reviver são cultivadas em Cavernas Exuberantes e podem ser Plantadas em Terra Arada. \\n\\nErvas de Reviver Maduras também Droparão Flores de Vigor! \\n\\nVocê pode usar uma Erva de Reviver em um &cPokemon&r que Desmaiou para Revivê-los... mas eles se lembrarão disso e não de um jeito bom. Ou seja, você perderá &dAmizade&r. \\n\\nQue tal Fundi-la para obter &aPó de Cura&r ou usar isso para Criar um &aReviver&r melhor."]
	quest.722978AC0C1B2649.quest_desc: ["Item fácil para automatizar &9água&r infinita. \\n\\nPrecisa de mais &9água&r? Faça outro!"]
	quest.722978AC0C1B2649.quest_subtitle: "Pode ser usado como Refrigerante de Reator"
	quest.722978AC0C1B2649.title: "&9Água&r Infinita"
	quest.7231F6177EEF5BF0.quest_desc: [
		"Um monte de tubos coloridos perfeitos para transportar &6A&8b&6e&8l&6h&8a&6s&r ou você! \\n\\nO Ar Ventoso te levará a qualquer lugar nos Metrôs, até mesmo a salas cheias de saques!"
		"{image:atm:textures/questpics/bumblezone/bumble_subway.png width:200 height:100 align:center}"
	]
	quest.7231F6177EEF5BF0.title: "Metrô"
	quest.723E0CD3C8DD36B1.quest_desc: ["A Interface de Disco Elite tem 18 espaços para filtros e funciona 2x mais rápido."]
	quest.723F67A9C6993018.quest_desc: ["A &bInterface de Disco Ultra&r tem 36 espaços para filtros, funciona 5x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.723F67A9C6993018.title: "&bInterface de Disco Ultra"
	quest.7242F591DA474B37.quest_desc: ["&bFluidos &fe &bLíquidos&r não são os mais importantes em todos os aspectos do &6&lCreate&r, mas com sorte, você provavelmente irá encontrá-los de qualquer maneira! \\n\\nVocê precisará aprender o caminho difícil da &bLogística de Fluidos&r para usá-los e movê-los. \\n\\nE para começar, você precisará de &cCobre&r!"]
	quest.7242F591DA474B37.title: "&b&lLogística de Fluidos"
	quest.72489FB9D9A5A24B.quest_desc: ["Pode ser encontrado em estruturas na &l&6Bumblezone&r ou trocado com a &5Rainha Abelha&r! \\n\\nEstas Botas de Abelha Carpinteira são verdadeiramente incríveis, você pode correr pelas paredes ou pular mais longe de Tábuas de Madeira, Folhas e &6Blocos de Mel&r. \\n\\nAlém disso, enquanto segura Shift, as Botas minerarão o Bloco abaixo de você."]
	quest.72537968598AB884.quest_desc: ["Os &6Óculos de Engenheiro são perfeitos para vocês, sabichões. \\n\\nQuando usados, eles dirão praticamente tudo o que o Bloco ou a &6Máquina&r tem a dizer! \\n\\nStressometers dirão quanta Tensão é aplicada e quanta ela pode suportar. Speedometers dirão quanta Velocidade há em seu sistema. \\n\\n&dCaldeiras a Vapor&r dirão quão grandes, quanta &9Água&r e quanto Calor elas têm. \\n\\nOutras &6Máquinas&r, como &6Deployers&r ou &6Mechanical Presses&r, mostrarão quantas Unidades de Tensão estão sendo usadas."]
	quest.72537968598AB884.title: "&6Óculos de Engenheiro"
	quest.72569275EDE9FA23.quest_desc: ["Cruze 6 &6Slimes de Mel&r juntos com Açúcar."]
	quest.726A627BD7654E0C.quest_desc: ["Não há muita mudança de &cNetherita&r para &9Warden&r para estas Ferramentas. \\n\\nA Picareta é do mesmo Nível e mesma Velocidade. As Pás ainda podem fazer Caminhos e, novamente, mesma Velocidade. As Enxadas ainda podem fazer Terra Arada e também mesma Velocidade. \\n\\nA única mudança real é um Dano de Ataque maior para todas elas. \\n\\nCuriosamente, isso significa que as &9Enxadas do Warden&r têm Dano maior do que todas as Enxadas do &2&lVanilla&r!"]
	quest.726A627BD7654E0C.title: "&3Ferramentas do Warden&r"
	quest.7270FA5C48AF7280.quest_desc: ["A &3Armadura de Cursium&r é uma melhoria para a Armadura de Netherite. Combine um Equipamento de Netherite com um &3Lingote de Cursium&r e um &3Modelo de Melhoria de Cursium&r. Você pode Criá-los, não se preocupe! \\n\\nO &3Capacete de Cursium&r pode ser usado com a Tecla: C para ver Mobs através de Blocos! Como o Olho Espectral. \\n\\nO &3Peitoral de Cursium&r funciona como um Totem da Imortalidade embutido. Depois de morrer, você será salvo. Tem um Cooldown de 6 minutos, no entanto... \\n\\nAs &3Calças de Cursium&r funcionam com probabilidade... não tenho certeza de como isso funciona no &2&lMinecraft&r! \\n\\nAs &3Botas de Cursium&r permitem que você seja lançado para trás em um salto com a Tecla: V. Elas também reduzem o Dano de Queda em muito (mas não completamente!)"]
	quest.7270FA5C48AF7280.title: "&3Armadura Amaldiçoada"
	quest.72717D1135486D7F.quest_desc: ["Vamos coletar algumas sementes."]
	quest.72717D1135486D7F.quest_subtitle: "Mão na Mão 1, Bloco de Grama 0"
	quest.72717D1135486D7F.title: "Socar a Grama"
	quest.7276892E129A739B.quest_desc: ["Você acha que isso é tudo que o &5&lMekanism&r tem? Você nem faz ideia! \\n\\nMas antes de chegarmos lá, vamos preparar algumas &5Máquinas &fe &aEnxofre&r! \\n\\nTeremos um longo caminho pela frente."]
	quest.7276892E129A739B.quest_subtitle: "Acabamos por aqui!?"
	quest.7276892E129A739B.title: "&5&lMekanism: Reatores"
	quest.7277D695C4CB7840.quest_subtitle: "Feito com energizador"
	quest.7277D695C4CB7840.title: "&fAbelha de Cristal Niótico"
	quest.7279700A93E8630B.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_unobtainium.png width:100 height:150 align:center}"]
	quest.7279700A93E8630B.title: "&5Unobtainium&r"
	quest.728189EE56E5CAF7.quest_subtitle: "Feito na Fundição de Ligas"
	quest.728189EE56E5CAF7.title: "Abelha de Liga de Redstone"
	quest.7282DCB1547CEB63.quest_desc: [
		"O &#ED9553Bronze&r será o bloco de construção da &7&nEra do Vapor&r. "
		""
		"Cozinhar esse pó renderá as &#ED9553Barras de Bronze&r que usaremos adiante."
	]
	quest.7282DCB1547CEB63.title: "&#EDD653Bronze"
	quest.728BE1816DA23DC0.quest_desc: ["O Dragão do End é o Chefe que guarda O End. \\n\\nQuando você entra em um Portal do End, chegará à Ilha do End onde ele aparece. \\n\\nEle tem 200 Corações e pode atacar com Bolas de Fogo ou te atingindo. \\n\\nVocê terá que quebrar os Cristais do End nos pilares, pois eles o curam, para poder matá-lo! \\n\\nUma vez que você o mate, ele dropará: Essência Arcana, Shaderbags Épicos, Pele de Dragão, Escamas de Dragão de dois mods diferentes e um monte de experiência! \\n\\nEntão, o Portal se abrirá para que você possa retornar ao Mundo Superior, ou você pode encontrar um Portal do End para explorar as ilhas externas. Você também encontrará um Ovo de Dragão no Portal."]
	quest.728BE1816DA23DC0.title: "&fMate o &5Dragão &fdo &eEnd"
	quest.72917C96C322A922.title: "La Bee-da Loca"
	quest.7297391D026EE9A6.quest_desc: ["Quer algo empolgante e novo para gerar Energia? Que tal usar &dPoções&r para isso! É isso que o &dGerador de Poções&r faz, ele pegará suas &dPoções&r e gerará Energia a partir delas, dependendo de sua força e duração."]
	quest.7297391D026EE9A6.title: "&dGerador de Poções"
	quest.729DCB919A92B735.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_bolt.png width:100 height:150 align:center}"]
	quest.729DCB919A92B735.quest_subtitle: "Câmaras de Desafio"
	quest.729DCB919A92B735.title: "Ornamento de Armadura Bolt"
	quest.72A287DCAEEFE49F.quest_desc: [
		"Criar 8 dos mesmos Geradores 8x junto com um Conduto os combina em 1 Gerador massivo! Funciona da mesma forma que 64 geradores regulares, mas ocupa apenas o espaço de 1."
		""
		"Um Gerador Magmático 64x é necessário para criar a Estrela ATM."
	]
	quest.72A71E1D6D8996FD.quest_desc: ["Isso é código? Eu não sou um programador!? Eu só queria fazer essas missões! \\n\\nAqui você pode digitar uma Regex na Barra de Pesquisa e clicar no Botão de Mais para adicioná-la ao Filtro. Sempre que essa Regex aparecer, ela será filtrada."]
	quest.72AE56D34834D28E.quest_desc: ["Mais um do PneumaticCraft? Oh, este é o Gerador real, entendi. Assim como o Gerador Estabilizado Dracônico, você precisará de um Gerador Vanilla primeiro. Assim que tiver um, coloque um Spawner Extrator acima do Gerador e forneça abaixo de -0,5 Bars para fazê-lo funcionar. Quando terminar, ele lhe dará um Núcleo de Gerador cheio com qualquer criatura que estivesse nele e deixará você com um Gerador Vazio. Então use o Gerador Vazio para fabricar um Gerador Pressurizado e coloque o Núcleo de Gerador nele. (Para aprimorar o Núcleo, use uma Vacuum Trap para sugar as criaturas que irão para o Núcleo de Gerador). Depois de fazer isso, o Gerador agora precisará de Pressão para funcionar, ignora o Nível de Luz e é Ativado por Redstone."]
	quest.72AE56D34834D28E.quest_subtitle: "Gerador do PneumaticCraft"
	quest.72C09FD89C28B1EC.quest_desc: [
		"A &3Refinaria de Petróleo&r que faremos é um multibloco de 1x1x5 composto por 1 &3Controlador de Refinaria&r (na parte inferior) e quatro &3Saídas de Refinaria&r (em cima). Você precisará inserir Petróleo e calor para que isso funcione. Isso produzirá Diesel, Querosene, Gasolina e GLP. Colocar &3Revestimentos Térmicos&r nas laterais ajuda a mantê-la aquecida."
		""
		"{image:atm:textures/questpics/pneumaticcraft/oil_refinery.png width:300 height:150 align:center}"
	]
	quest.72C09FD89C28B1EC.quest_subtitle: "Agora estamos chegando a algum lugar"
	quest.72C09FD89C28B1EC.title: "Refinaria de Petróleo"
	quest.72C7698072BF0F1D.quest_desc: ["A &dManivela&r é a forma mais simples e pior de geração de &dEnergia Rotacional&r. \\n\\nQuando você segura o Botão Direito, ela se moverá no &e&osentido horário&r e se você segurar Shift + Botão Direito, ela se moverá no &9&osentido anti-horário&r. \\n\\nEla só fornece uma pequena quantidade de Unidades de Tensão e para depois que você solta o botão."]
	quest.72C7698072BF0F1D.quest_subtitle: "Energia Manual!"
	quest.72C7698072BF0F1D.title: "&dManivela"
	quest.72CE46D28C9E7452.quest_desc: ["A Mira de Precisão pode ser usada tanto na &5&lRailgun&r quanto no &d&lRevolver&r. \\n\\nCom o &d&lRevolver&r e a &5&lRailgun&r, você pode pressionar o Botão do Meio para usar a Mira, e então pode rolar para ajustar a magnificação."]
	quest.72D578686C47B154.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_red.png width:100 height:150 align:center}"]
	quest.72D578686C47B154.title: "&5Cristal de Luz Estelar Vermelho&r"
	quest.72D6265E35814927.quest_desc: ["A maioria dos jogos que possuem um sistema de Saúde e Dano, têm Quadros de Invencibilidade. Depois de sofrer Dano, você terá alguns Quadros de Invencibilidade para 1. Você não morrer instantaneamente por um ataque simples e 2. Dar tempo para você revidar. \\n\\nCom o &eColar de Cruz&r você ganha mais alguns Quadros de Invencibilidade. O que significa mais algumas chances de revidar!"]
	quest.72D6265E35814927.quest_subtitle: "Colar"
	quest.72D6265E35814927.title: "&eColar de Cruz&r"
	quest.72DB967E59EEA729.quest_desc: ["&3&lGlassential&r é um Mod muito importante para construção, mesmo para construções com propósitos! \\nNão é apenas Vidro normal, estes têm habilidades que podem ser lidas ao passar o mouse sobre o Item! \\n\\nComo o Vidro Etéreo, pelo qual você pode passar, mas os Mobs não. (Eu usei isso para minha Cúpula de Abelhas em 9sky!)"]
	quest.72DB967E59EEA729.title: "&3&lGlassential&r"
	quest.72DCD32EC59F8E9C.quest_desc: [
		"Onde quer que o &bGelo&r surja, o Espigão Congelado também surgirá! \\n\\nComo o Pilar Errodido, o &7Cascalho Suspeito&r surge dentro do espigão."
		"{image:atm:textures/questpics/pokemon/find_frozen_spike.png width:200 height:100 align:center}"
	]
	quest.72DCD32EC59F8E9C.title: "Espigão Congelado Pré-histórico"
	quest.72DCE154E1714890.quest_desc: [
		"Para ver as &6Serras Mecânicas&r sozinhas, confira a segunda Página! Esta fala sobre elas em &aEngenhocas&r. \\n\\nQuando movida em uma &aEngenhoca&r, a &6Serra Mecânica&r quebrará qualquer Árvore com a qual entrar em contato! Ela precisará atingir a base da Árvore e quebrar todos os Troncos na parte mais baixa da Árvore. \\n\\nUma vez que quebre esses Troncos, a Árvore inteira será derrubada em forma de Item. \\n\\nSe a &aEngenhoca&r tiver um Inventário, as partes da Árvore serão coletadas nele. Se não, a Árvore permanecerá na natureza... no chão."
		"{@pagebreak}"
		"A &6Serra Mecânica&r também pode realizar outras tarefas quando não usada em uma &aEngenhoca&r. Em vez disso, elas podem ser colocadas no chão e usadas com &dEnergia Rotacional&r. \\n\\nA &6Serra&r também pode derrubar Árvores que estão perto dela. Sim, elas ainda precisarão cortar os Troncos mais baixos. \\n\\nMas também pode ser usada como um &7Cortador de Pedra&r/Cortador de Madeira! Para usá-la assim, ela precisará ser colocada virada para cima, como o normal. \\n\\nEntão, podemos alimentá-la com Blocos de nossas Mãos (com a proteção correta) ou através de &eEsteiras&r. Troncos serão Descascados e Blocos de Pedra serão Cortados. \\n\\nSe o Bloco tiver várias Receitas através do Cortador, você pode Filtrar qual você quer colocando aquele Bloco no Filtro da &6Serra Mecânica&r."
	]
	quest.72DCE154E1714890.title: "&6Serra Mecânica"
	quest.72DDA413D73E3235.quest_desc: ["Estatísticas muito mais altas em tudo com o próximo na linha de Armaduras de &6&lAllthemodium&r, &3Vibranium&r! \\n\\nVocê precisará da &6Armadura de Allthemodium&r para criá-la."]
	quest.72DDA413D73E3235.quest_subtitle: "32"
	quest.72DDA413D73E3235.title: "Armadura de &3Vibranium"
	quest.72E7AE66F2A7C4C4.quest_subtitle: "Use fluido em máquinas"
	quest.72EA25D05C46D39A.quest_desc: ["&9Integrated Dynamics&r fornece um sistema simples de armazenamento de energia. As Baterias podem ser combinadas em uma grade de criação para aumentar o armazenamento geral!"]
	quest.72EA25D05C46D39A.quest_subtitle: "Baterias Incluídas"
	quest.72EA25D05C46D39A.title: "&9Integrated Dynamics: &bBateria de Energia"
	quest.72EC845C19645AFC.quest_desc: ["Os &3Trepadeiras de Sculk&r são a versão de &3Sculk&r das &4Vines Choronas&r. \\n\\nEles podem aparecer nas &bCavernas Floridas&r e &9Terras Profundas&r."]
	quest.72EC845C19645AFC.title: "&3Trepadeiras de Sculk"
	quest.72F57D77C3FB366D.quest_desc: ["Blocos de Menril Cristalizado podem ser transformados em Pedaços de Menril Cristalizado. Esses pedaços são o principal ingrediente de criação do ID."]
	quest.72F57D77C3FB366D.quest_subtitle: "O Principal Ingrediente de Criação"
	quest.72F57D77C3FB366D.title: "Pedaços de Menril Cristalizado"
	quest.72FADEAEE2DA03AF.quest_desc: [
		"O terceiro passo é para onde o &eEnxofre&r recém-modificado irá, o Pedestal de Resultado. Uma vez reformado, ele irá para cá."
		"{image:atm:textures/questpics/theurgy/theurgy_reform_3.png width:100 height:100 align:center}"
	]
	quest.72FADEAEE2DA03AF.title: "Passo 3: Pedestal de Resultado"
	quest.72FFD9E471242D68.quest_desc: ["O &7Aço Inoxidável&r requer mais &ccalor&r para ser fundido do que um forno normal. Devemos usar nosso &eAlto-forno Elétrico&r construído anteriormente."]
	quest.730130CCF1CF5119.quest_desc: ["Estas relíquias podem ser encontradas no &2Mundo Superior&r!"]
	quest.730130CCF1CF5119.title: "&2Mundo Superior"
	quest.7305EE0F7D73C231.quest_desc: ["Melhorias em Branco são a base de todas as habilidades. As habilidades são separadas em dois tipos, passivas e ativas.\\n\\nHabilidades passivas não requerem entrada ativa do jogador para funcionar, no entanto, habilidades ativas só funcionam quando acionadas por uma tecla de atalho que os jogadores definem no menu de configuração, e habilidades ativas consomem durabilidade/poder quando usadas. Quando instaladas em armaduras de nível superior, as habilidades ativas têm cooldowns reduzidos e as habilidades passivas têm efeitos maiores.\\n\\nA mesa de ferraria é usada para aplicar Melhorias às ferramentas e armaduras JDT. Segurar shift ao passar o mouse sobre as ferramentas ou armaduras JDT mostra quais Melhorias são Válidas."]
	quest.730F2D3329C4FF88.quest_desc: ["&nFermentação&r: \\nO processo químico pelo qual moléculas como a glicose são quebradas anaerobicamente. \\n\\nTambém conhecido como: &9Água&r e tempo mudam as coisas! \\n\\nPara usar o Tanque de Fermentação, coloque os Itens e o Fluido no Tanque e depois clique com Shift + Botão Direito para fechá-lo. \\n\\nDepois de um tempo, deve fermentar! É assim que transformamos &eAlchemical Sulfur&r em &3Nitrato Alquímico&r, que pode ser transformado em mais Itens!"]
	quest.730F2D3329C4FF88.title: "Tanque de Fermentação"
	quest.7310BBC4A90EDA9D.quest_desc: ["O &ePainel Portátil OIQ&r nos permite visualizar nosso &e&lSistema OIQ&r de qualquer lugar! \\n\\nClique com o Botão Direito com o &eItem&r para torná-lo seu! \\n\\nAgora você pode Clicar com o Botão Direito nele e definir uma Frequência de Rede para nosso &e&lSistema OIQ&r. \\n\\nBoom, tudo que o &ePainel OIQ&r faz, nós podemos fazer com este pequeno amigo!"]
	quest.7310BBC4A90EDA9D.title: "&ePainel Portátil OIQ"
	quest.73110103EF23BFDF.quest_desc: ["Uma mistura de &6Cobre&r e &7Zinco&r. \\n\\nNão é muito usado para muita coisa no &8&lIE&r... Você pode fazer Chapas com ele, eu acho..."]
	quest.73110103EF23BFDF.title: "&6Lingote de Latão"
	quest.731A70C25C2C7281.quest_desc: ["Itens obtidos com a Ferramenta em que isto está irão para o seu Baú do Ender. O do Minecraft, não um modificado."]
	quest.731A70C25C2C7281.title: "Módulo de Coleta do Ender"
	quest.731A8877EA474D67.quest_desc: [
		"Atravessando as vibrantes Terras Ruins, está o Pilar Errodido. \\n\\nCom isso, o &7Cascalho Suspeito&r surge dentro do pilar."
		"{image:atm:textures/questpics/pokemon/find_eroded.png width:200 height:100 align:center}"
	]
	quest.731A8877EA474D67.title: "Pilar Errodido Pré-histórico"
	quest.73201E591C2A40CC.quest_desc: ["Agora que você tem &6Fragmentos de Estrela&r, pode começar a fazer as diferentes partes para refazer nossas &6&lEstrelas&r! \\n\\nVocê precisará de 262 &6Fragmentos de Estrela&r no total para refazer 1 &6&lEstrela&r... espero que você tenha uma boa configuração de Abelhas!"]
	quest.73201E591C2A40CC.title: "&6Fragmentos de Estrela&r"
	quest.732DA855AFF62907.quest_desc: ["Centrifugar &8Carvão&r produzirá &7Pó de Carbono&r."]
	quest.73350AD668200E99.quest_desc: ["Esta é a Essência de Nível 2, feita combinando 4 Inferium com um Cristal de Infusão."]
	quest.73350AD668200E99.quest_subtitle: "Tier: &a2"
	quest.73350AD668200E99.title: "&2Prudentium"
	quest.7338CA23B27B2AF8.quest_subtitle: "&f12 &cde Dano de Ataque"
	quest.734411D931A8CDBF.quest_desc: ["O Devastador é um Miniboss que só aparece em Invasões mais difíceis. \\n\\nSe você não sabe o que são Invasões ou não entende a maneira atualizada, tudo bem, é para isso que servem as Missões! \\n\\nAo matar Capitães Saqueadores (aqueles que seguram Estandartes), você pode obter Poções Sinistras; quando você as bebe, recebe o Efeito Mau Presságio. Então, você pode andar perto de uma Vila e iniciar uma Invasão. \\n\\nAs Invasões gerarão Saqueadores, Defensores, Evocadores, Bruxas e Devastadores para lutar!"]
	quest.734411D931A8CDBF.title: "&fMatar um &7Devastador"
	quest.734A72A4C898BDFB.quest_subtitle: "Despeje Invar Derretido sobre um Ovo de Gerador de Abelha de Ferro/Níquel"
	quest.734A72A4C898BDFB.title: "&fAbelha de Invar"
	quest.734F61A03FFA13ED.quest_subtitle: "Abelha Creeper + Ferro"
	quest.734F61A03FFA13ED.title: "Abelha Radioativa"
	quest.73552A4BA0687962.quest_desc: ["Essas melhorias podem ser aplicados em ferramentas ou armaduras."]
	quest.7361BD20A6B95D14.quest_subtitle: "Tier: &63"
	quest.736F4A43EEBDD7B3.quest_desc: [
		"Os &3Agarrador de Sculk&r são Mobs pequenos, mas raivosos! \\n\\nEu os vi aparecerem nas &9Deeplands &fe &cCavernas Floridas&r. \\n\\nEles têm 6 &4Corações&r e droparão &3Pó de Alma&r ao Morrer."
		"{image:atm:textures/questpics/deepndark/dnd_snapper.png width:100 height:100 align:center}"
	]
	quest.736F4A43EEBDD7B3.title: "&3Agarrador de Sculk"
	quest.7377C657CED885AC.quest_desc: ["&2&lMystical Agriculture&r é um mod sobre agricultura, mas o que você está cultivando?\\n\\nPraticamente qualquer coisa, de Mel a Aço e Esqueletos Wither.\\n\\nVocê precisará fazer muita agricultura com este mod para fazer a &6&lEstrela ATM&r!"]
	quest.7377C657CED885AC.title: "&2&lMystical Agriculture"
	quest.737DC37E4310090C.quest_desc: ["As &8Esteiras de Corrente&r não farão muito sozinhas. Elas precisam de outra &8Esteira de Corrente&f, &8Correntes&f e &dEnergia Rotacional&r! \\nAs &8Esteiras de Corrente&r precisarão de outra &8Esteira de Corrente&r por perto para se conectarem a elas com &8Correntes&r. \\n\\nAs &8Correntes&r precisarão ser clicadas com o botão direito em uma &8Esteira de Corrente&r e depois o mesmo em outra que você queira conectar. \\n\\nUma vez que uma receba &dEnergia Rotacional&r, as &8Correntes&r se moverão na mesma Velocidade. Não se preocupe com a Direção, haverá 2 &8Correntes&r! \\n\\nQuando as &8Correntes&r estiverem se movendo, você pode se conectar a elas com uma &6Wrench&r para se mover com as &8Correntes&r, você pode pressionar Shift ou trocar de Item para sair da &8Corrente&r. \\n\\nVocê também pode colocar &ePacotes&r nelas, mas sem o &eItem&r descrito na próxima Missão, eles apenas darão voltas em círculo!"]
	quest.737DC37E4310090C.title: "&8Esteira de Corrente"
	quest.738022A90A534871.quest_desc: [
		"Para Fabricar nossas &bTampas&r, precisamos de Tampas Vazias, &6Fragmentos de Bolota&r e o equivalente a blocos do Lingote. \\n\\nAssim como usar a &8Linha de Montagem&r da missão anterior, ou &bBicos&r e &6Implantadores&r com o &6&lCreate&r, ou uma &7Câmara de Pressão&r."
		"{@pagebreak}"
		"Com o &6&lCreate&r, precisamos usar um &bBico&r para despejar 810mB do Lingote na Tampa Vazia. Isso equivale a 9 Lingotes. \\n\\nDepois, use o &6Implantador&r para bater na tampa com o &6Fragmento de Bolota&r para fazer nossa tampa!"
		"{@pagebreak}"
		"A &7Câmara de Pressão&r é do &8&lPneumatic Craft&r, assim como a &8Linha de Montagem&r. \\n\\nA &7Câmara de Pressão&r é uma máquina multibloco. Ela usa Paredes ou Vidro de Câmara de Pressão para compor a maior parte dela. Enquanto as Válvulas são o que recebe Pressão e as Interfaces inserem e retiram itens dos inventários. \\nSe a face Azul estiver fora da &7Câmara de Pressão&r, esta é a Entrada. Se for Laranja, então é a Saída!"
	]
	quest.7386A8433698946C.quest_desc: [
		"Selecione um item e este upgrade o procurará nas proximidades em baús ou no chão. Para encontrá-lo em baús, ele precisará do Upgrade de Rastreamento de Bloco e para encontrá-lo no chão, ele precisará do Upgrade de Rastreamento de Entidade.\\n"
		"{image:atm:textures/questpics/pneumaticcraft/item_search_upgrade.png width:200 height:200 align:center}"
	]
	quest.7386A8433698946C.quest_subtitle: "Máx: 1"
	quest.7388D8168AF78B9A.quest_subtitle: "Tier: &63"
	quest.7395B41685F4BC1A.quest_desc: ["O &3Compressor de Fluxo&r pode criar uma tonelada de pressão usando energia. Simplesmente bombeie um pouco de FE e ele começará a gerar alguma. Se você tiver FE de sobra, esta é provavelmente a maneira mais fácil de gerar pressão."]
	quest.7395B41685F4BC1A.quest_subtitle: "Energia = Pressão"
	quest.7395B41685F4BC1A.title: "Pressão da Energia"
	quest.739601B0C43B239B.quest_desc: ["Sim, elas podem fazer Corante Preto!"]
	quest.73AC47B946B9A388.quest_desc: [
		"Aumento de nível para 55."
		""
		"Item de Assinatura é Melhoria (esse é o nome completo)."
	]
	quest.73AC47B946B9A388.title: "&7Chefe Giovanni"
	quest.73B73870B29DFAD9.quest_desc: ["Um de nós! Um de nós! \\n\\nO &eChapéu de Aldeão&r faz com que os Aldeões acreditem que você é da mesma Vila, então eles se livram do Imposto de Forasteiro. As trocas com Aldeões ficam mais baratas."]
	quest.73B73870B29DFAD9.quest_subtitle: "Cabeça"
	quest.73B73870B29DFAD9.title: "&eChapéu de Aldeão"
	quest.73B8A70240E6070E.quest_desc: ["Encontre uma Vaca e clique com o botão direito nela com um Balde.\\n\\nSério, por que não há Touros?"]
	quest.73B8A70240E6070E.quest_subtitle: "Por que não há Touros no jogo?"
	quest.73B8A70240E6070E.title: "Ordenhar uma Vaca - Lucro"
	quest.73C70B15582958A5.quest_desc: [
		"O Ninho de &#962b00Terra&r pode ser colocado em qualquer bioma do Mundo Superior para atrair abelhas."
		""
		"Ele pode atrair a Abelha Mineradora Cinzenta, a Abelha Mineradora de Chocolate e a Abelha Cortadora de Folhas."
	]
	quest.73C70B15582958A5.quest_subtitle: "Qualquer Bioma do Mundo Superior"
	quest.73C70B15582958A5.title: "&fNinho de &#962b00Terra"
	quest.73C7479D929498AE.quest_desc: ["Raízes Grandes aparecem nos Tetos das Cavernas, como Frutas-luz. \\n\\nElas aparecem acima da &8Ardosiabissal&r! \\n\\nÀs vezes, pode ser na verdade uma Raiz de Energia que se parece e aparece como uma Raiz Grande."]
	quest.73C7F57B90731010.quest_desc: [
		"Uma Estrutura de Fonte maravilhosamente projetada com &6Mel&r e &bÁgua com Açúcar&r fluindo."
		"{image:atm:textures/questpics/bumblezone/bumble_fountain.png width:200 height:100 align:center}"
	]
	quest.73C7F57B90731010.title: "Fonte de &6Mel&r"
	quest.73D60868024FF907.quest_desc: ["O Fluido MK2! \\n\\nQualquer Fonte de Líquido próxima pode ser usada com este, não apenas as adjacentes."]
	quest.73E2A53A088AD29A.quest_subtitle: "11 Blocos Rosas Molhados"
	quest.73E6878553BA6908.quest_desc: ["Gosta de Caixas? O &5&lMekanism&r nos dá algumas! Só que estas são chamadas de &eCompartimentos (Caixas)&r. \\n\\nOs &eCompartimentos&r podem conter apenas um tipo de Item, mas armazenarão toneladas de Pilhas desse &eItem&r! \\n\\nVocê pode usar um &3Configurador&r na &eCaixa&r para configurá-la para Saída automática para o Inventário abaixo dela. \\n\\nSe houver um &eItem &fna &eCaixa&r, você pode clicar com Shift + Botão Direito para Travar aquele &eItem&r. \\n\\n&a&lBásica&r: comporta 64 Pilhas. \\n\\n&c&lAvançada&r: comporta 128 Pilhas. \\n\\n&b&lElite&r: comporta 512 Pilhas. \\n\\n&d&lUltimate&r: comporta 4.096 Pilhas."]
	quest.73E6878553BA6908.quest_subtitle: "Caixas"
	quest.73E6878553BA6908.title: "&eCompartimentos"
	quest.73EA326304C01C3B.quest_desc: [
		"Coloque um Importador no inventário do qual você quer que as coisas sejam puxadas. Em seguida, coloque a Interface no segundo inventário e conecte-os com Cabos Lógicos. Depois, insira o Cartão de Variável no Importador e altere-o como quiser.\\n\\nPode ser alterado para importar coisas no Limite de Inteiro (Mais de 2 bilhões)."
		"{image:atm:textures/questpics/logistics/id_item.png width:200 height:50 align:center}"
		"{image:atm:textures/questpics/logistics/id_fluid.png width:200 height:50 align:center}"
		"{image:atm:textures/questpics/logistics/id_energy.png width:200 height:50 align:center}"
	]
	quest.73EA326304C01C3B.quest_subtitle: "Importando"
	quest.73FC51144FC2DA52.quest_desc: ["Com esta &7Luva&r você roubará a vida de quaisquer inimigos que acertar!\\n\\nAh sim, desculpe, esqueci... bleh bleh blehhh!"]
	quest.73FC51144FC2DA52.quest_subtitle: "Mãos"
	quest.73FC51144FC2DA52.title: "&7Luva Vampírica&r"
	quest.73FF01D830A669AA.quest_desc: ["&4Aumento&r: Fundição transforma sua Fornalha de Ferro em um Alto-forno de Ferro! Agora ela só derreterá Minérios, mas com o dobro da velocidade! Sim, isso acumula com os efeitos de outros Aumentos e diferentes Tiers de Fornalha."]
	quest.73FF01D830A669AA.title: "&4Aumento&r: Fundição"
	quest.74015945716FD10A.quest_desc: ["O &3Funil Omnidirecional&r pode inserir itens de qualquer lado, além de poder ser atualizado para ser muito mais rápido que um Funil normal! Bom para quando não são necessários Tubos."]
	quest.74015945716FD10A.quest_subtitle: "Um funil configurável"
	quest.74130EB1E4B8586D.quest_desc: ["Usando o &aIhagan's Enthrallment&r, você pode sacrificar um Allay, Morcego, Abelha ou Papagaio para invocar uma &6Abelha Possuída&r. Ao derrotá-la, ela dropará Mel Amaldiçoado, o ingrediente principal para fazer Giz Laranja!"]
	quest.74130EB1E4B8586D.title: "&6Giz Laranja"
	quest.7413BB136EF9D6C5.quest_desc: ["A Bacia de Secagem Mecânica usa energia para secar"]
	quest.74200A48498DD7F8.quest_desc: ["O &e&lGerador a Energia Solar&r gerará &aEnergia&r ao ser exposto ao &bCéu&r durante o &eDia&r. \\n\\nÉ um &e&lGerador&r automático muito simples de usar, só a Criação deles que é chata! \\n\\nEles não gerarão tanta &aEnergia&r quanto os &b&lGeradores Eólicos&r (apenas durante o Dia), mas produzem mais em Rajadas e ocupam menos Espaço! \\n\\nEles foram melhorados e agora podem armazenar cerca de 40kFE!"]
	quest.74200A48498DD7F8.quest_subtitle: "Gera cerca de 60FE/t"
	quest.74200A48498DD7F8.title: "&e&lGerador Solar"
	quest.74285B2AC6E00D20.quest_desc: [
		"Aventurando-se pelas selvas você pode encontrar uma pequena depressão, essa depressão é a Toca Exuberante! \\n\\n&7Cascalho Suspeito&r surge dentro delas."
		"{image:atm:textures/questpics/pokemon/find_lush.png width:200 height:100 align:center}"
	]
	quest.74285B2AC6E00D20.title: "Toca Exuberante Pré-histórica"
	quest.74297A72584F5D7B.quest_subtitle: "Alder + Wild Cherry"
	quest.744842B2AED28344.quest_desc: ["Permite que você acesse o armazenamento da sua rede sem fio com uma interface de criação embutida."]
	quest.744AC6BD82FC2DEE.quest_subtitle: "&f36 &cde Dano de Ataque"
	quest.744DBE831C120B2F.quest_desc: [
		"Aquela rocha está se movendo? Ah, espere, não é uma rocha, é um &2Mog&r! \\n\\nOs &2Mogs&r podem ser acasalados com Pedregulhos de Depthrock e, ao morrer, podem dropar mais Pedregulhos ou Mogmoss! \\n\\nMogmoss pode ser usado em muitas receitas diferentes!"
		"{image:atm:textures/questpics/undergarden/undergarden_mog.png width:100 height:100 align:center}"
	]
	quest.744DBE831C120B2F.title: "&2Mog&r"
	quest.744E620B7DEBB483.quest_desc: ["O &#27CFF5Freezer à Vácuo&r será usado para resfriar &#E6AD1EBarras Quentes&r ou certos fluidos, garantindo melhores proporções dos itens que você já está produzindo."]
	quest.744E620B7DEBB483.quest_subtitle: "De Boa no Gelo"
	quest.7464CA1290B3474B.quest_desc: [
		"Melhorias Válidas:"
		"- Invulnerabilidade"
	]
	quest.746DE905D45A396C.quest_desc: [
		"&5&lO Leviatã&r é a razão pela qual as pessoas temem o Oceano. \\n\\nEla tem 6.400 &4Corações&r, dentes afiados e tentáculos fortes e é invencível fora da &9Água&r. \\n\\nEla tem uma vasta gama de poderes que usará contra você. Ela pode invocar &5Minas&r subaquáticas, disparar um &5Raio Atômico&r semelhante ao do Godzilla e até mesmo te morder. \\n\\nO pior vem dos &5vórtices&r! E não estou falando do &6&lDesenvolvedor do ATM&r! \\n\\nEla pode usar seus tentáculos para abrir um &5Vórtice de Água&r que sugará todas as Entidades próximas como isca para ela. Ela também pode invocar &5Lasers&r de &5vórtices&r no fundo do Oceano que dispararão para cima. \\n\\nQuando você a deixar com menos da metade da &4Vida&r, ela ficará enfurecida! Quando enfurecida, ela usará seus &5Lasers&r muito mais do que antes e atacará implacavelmente até que os Oceanos tenham apenas um ser nadando neles."
		"{image:atm:textures/questpics/cataclysm/cataclysm_leviathan.png width:100 height:100 align:center}"
	]
	quest.746DE905D45A396C.title: "&5&lO Leviatã&r"
	quest.747580F66BCFB9B0.quest_desc: ["A Pedra-chave é encontrada no centro do &bMegaroide&r. Você precisará de uma &bPicareta de Diamante&r ou melhor para minerá-la. \\n\\nCada uma dará apenas uma Pedra-chave. Felizmente, não precisamos de mais do que isso! "]
	quest.747B62A955D0C629.quest_desc: [
		"A &4Fábrica Ancestral&r fica nas profundezas do &2Mundo Superior&r. \\n\\nVocê encontrará muitos Itens de Redstone como Alavancas, Trilhos Elétricos e PEMs... me pergunto se eles serão úteis em breve? \\n\\nVocê também encontrará algumas Máquinas de Redstone tentando te matar! Como os &4Observadores &fe &4Rondadores&r! \\n\\nMesmo com o perigo, ainda há toneladas de Saques e Blocos que você pode roubar daqui, especialmente Redstone."
		"{image:atm:textures/questpics/cataclysm/cataclysm_factory.png width:200 height:100 align:center}"
	]
	quest.747B62A955D0C629.title: "&4Fábrica Ancestral&r: Lar do &4&lPresságio (The Harbinger)&r"
	quest.747BA0DB44A49A4F.quest_subtitle: "Maçã Red Delicious + Pera de Areia"
	quest.7485BCBE366501DF.quest_desc: [
		"Se quisermos ainda mais &7Minérios&r! Precisaremos de uma maneira melhor de &lProcessar&r nossos &7Minérios&r. Hidrogênio não funcionará, vamos tentar &3Cloreto de Hidrogênio&r. \\n\\nObviamente, para isso, precisaremos de &eCloro&r! \\n\\nOlhe na Missão da &6&lPlanta de Evaporação Térmico&r para aprender em mais detalhes como Criar o Multibloco, mas basicamente precisaremos de um. \\n\\nAlimente &9Água&f em uma &6&lPlanta de Evaporação Térmico&r para (lentamente) fazer &eSalmoura&r. \\n\\nJogue essa &eSalmoura&r em um &9&lSeparador Eletrolítico&r para obter &7Sódio&r e &eCloro&r! O &7Sódio&r é útil para o &2&lReator de Fissão&r... mas não para o &lProcessamento de Minérios&r!"
		"{image:atm:textures/questpics/mek/mek_tier3_1.png width:200 height:100 align:center}"
	]
	quest.7485BCBE366501DF.quest_subtitle: "Processamento de Minério Tier 3"
	quest.7485BCBE366501DF.title: "Fazendo &eCloro"
	quest.748A01B5607C475B.quest_desc: [" Escondido nas alturas rochosas dos &2biomas de Montanha&r, a &aBota Elástica&r aguarda aqueles que ousam pular além dos limites. Suas molas projetadas transformam cada pouso em um &6lançamento&r, transformando o movimento em &2fuga&r e &cataque&r. \\n\\n- &lPossui 1 habilidade:&r \\n\\n &bImpulso Elástico&r: \\n Um &6pulo agachado&r lança o &6portador da relíquia&r na &cdireção oposta&r ao seu olhar com força significativa. Cada &6pouso&r antes de parar completamente faz com que o portador &aquique&r em superfícies horizontais, &cnegando completamente o dano de queda&r. Para &5parar&r o efeito intencionalmente, segure a tecla de &6pulo&r ou &6agachar&r pouco antes de tocar o chão. \\n\\n- Uma &6relíquia&r de &2mobilidade&r e &fforça&r… onde cada &apulo&r é uma oportunidade de voar."]
	quest.748A01B5607C475B.quest_subtitle: "Cada passo pode se tornar um salto… se você souber como usá-lo."
	quest.748A01B5607C475B.title: "&aBota Elástica"
	quest.7493CDDE7861709C.title: "&fCarcaça de Máquina de &7Aço"
	quest.7496B2380A23FDC6.title: "Lenhador de Árvores Caótico"
	quest.74ACCEB6DC9EF6F7.quest_desc: ["A &dArma de Ombro de Assalto do Vazio &4(A.&4O.A.V.)&r é como a versão do Wither, mas melhor! \\n\\nAgora ela só dispara &dHowitzers do Vazio&r que causarão mais Dano e farão &dRunas do Vazio&r saírem do chão, na área que o &4Howitzer&r atingiu. \\n\\nSó ao custo do longo tempo de recarga, mas temos tempo para esperar. \\n\\nPode ser criada combinando o &4A.O.A.V.&r e um &dNúcleo do Vazio&r na &4Bigorna de Infusão Mecânica&r."]
	quest.74ACCEB6DC9EF6F7.title: "&dA.&4O.A.V. &d(Arma de Ombro de Assalto do &4Vazio)"
	quest.74AE214747A3DB1A.quest_desc: ["Aumenta a quantidade de pressão que as coisas podem suportar."]
	quest.74AE214747A3DB1A.quest_subtitle: "Aumente o volume!"
	quest.74B352457BF1541B.quest_desc: ["Se você é como eu, ou qualquer pessoa sã, você despreza a Neve Fofa. Felizmente, o &l&3Artifacts&r nos dá uma ferramenta para lidar com isso! Raquetes de neve! \\n\\nAs Raquetes de Neve permitirão que você caminhe com segurança sobre a Neve Fofa, assim como as Botas de Couro. Você também receberá um impulso de Velocidade ao caminhar sobre qualquer Neve!"]
	quest.74B352457BF1541B.quest_subtitle: "Pés"
	quest.74B3E4B62FA9565E.quest_subtitle: "Crie com uma Mesa de Oferendas"
	quest.74B3E4B62FA9565E.title: "&fAbelha do Céu"
	quest.74C715F8F24B8BAE.quest_desc: ["Mesma coisa, mas com opções de filtragem."]
	quest.74C715F8F24B8BAE.title: "Módulo de Coleta do Ender Filtrável"
	quest.74CD3FC35F245DF2.quest_subtitle: "Blue Yonder + Sol Cintilante"
	quest.74D4E51A6381DB24.title: "Padrão de Estandarte de Olhos"
	quest.74FC0DDDB91DB172.quest_desc: ["Para tornar a vida muito mais fácil, o AE2 fornece um conjunto completo de dispositivos para a manipulação de dados ME, ou seja, mover itens armazenados pelo mundo.\\n\\nA &bME Interface&f é um desses dispositivos. Como dispositivo de entrada, a Interface permite que qualquer item/fluido/etc seja canalizado externamente através dela, que é então automaticamente armazenado na Rede ME à qual a interface está conectada.\\n\\nComo dispositivo de saída, a Interface pode ser configurada para manter uma certa quantidade disponível de um item armazenado em estoque, da Rede ME para seu próprio inventário interno. Isso permite que os itens sejam recebidos por alguma fonte externa, como outro jogador ou algum cano."]
	quest.74FC0DDDB91DB172.quest_subtitle: "Nem entrada, nem saída… é tudo ao mesmo tempo!"
	quest.74FC0DDDB91DB172.title: "&bA Interface"
	quest.7503823ACDDB0491.quest_desc: ["Isto e o &aChapéu Supersticioso&r dão a você todos os amuletos da sorte de que precisa!\\nO &2Cachecol da Sorte&r dá a você um nível extra de Fortuna para suas Picaretas."]
	quest.7503823ACDDB0491.quest_subtitle: "Cachecol (Colar)"
	quest.7503823ACDDB0491.title: "&2Cachecol da Sorte&r"
	quest.750B6316267CF574.quest_desc: ["Quando suas Colmeias estiverem vagas e no escuro, você pode encontrar uma pequena abelha visitante, a Abelha Esquelética. \\n\\nVocê pode então alimentar sua nova visitante com uma &8Rosa de Wither&r para torná-la uma &8Abelha Withered&r."]
	quest.750B6316267CF574.title: "&8Bloco de Favo Withered"
	quest.752DD0BF36B70D88.quest_desc: ["As Fornalhas simplesmente não são rápidas o suficiente no &2&lMinecraft&r normal, então como você acha que elas vão se sair no Modded!?\\n\\nFelizmente, o &7&lFornalha de Ferros&r ajuda a acelerá-las bastante! \\n\\nEle também tem uma página de Missões, só está dividindo o espaço com o &c&lGenerator Galore&r."]
	quest.752DD0BF36B70D88.title: "&7&lFornalha de Ferros"
	quest.754500BB7FD8C413.quest_subtitle: "Tier: &b4"
	quest.754B8F1FBCD983C5.quest_desc: ["Os &eIndicadores de Ações&r podem ser configurados para a &eRede&r clicando com o botão direito no &eLink de Ações &fcom o &eIndicador de Ações&r na Mão. \\n\\nDepois, coloque o &eIndicador de Ações&r e dê a ele um &eGuardião de Ações&r, colocando um &cBlaze Burner&r ou um Mob em um Assento próximo. \\n\\nVocê saberá que eles são um &eGuardião de Ações&r pelo seu estereotipado Visor &aVerde&r. Agora podemos clicar com o botão direito no &eGuardião de Ações&r para ver e encomendar &eItens&r da nossa &eRede&r. \\n\\nQuando você encomenda &eItens&r, eles serão colocados em um &ePacote &fde um &eEmpacotador &fabaixo do &eLink de Ações&r."]
	quest.754B8F1FBCD983C5.title: "&eIndicador de Ações"
	quest.75560045ED084900.quest_desc: [
		"A maioria das sementes é simples de fazer, mas para fazer &9Sementes de Mob&r, você precisará ir ao Nether para pegar um pouco de &8Soulium&r. "
		""
		"Com a pedra e o minério que você encontrar, você precisará usá-los para fazer a &3Adaga de Soulium&r e os &3Jarros de Alma&r. Usando a adaga para matar mobs, você poderá coletar suas &balmas&r, que são usadas no Altar de Infusão para criar as respectivas sementes de mob. "
		""
		"Alternativamente, você pode encher Jarros de Alma dentro do &3Extrator de Almas&r inserindo um jarro e usando itens de mob para enchê-los. Por exemplo, adicionar Carne Podre dará uma porção de uma Alma de Zumbi."
	]
	quest.75560045ED084900.title: "Criando Sementes de Mob"
	quest.75619C7174C6703C.quest_desc: ["Centrifugar o Pó de Urânio nos dará alguns isótopos de Urânio que podem ser processados em varas melhores."]
	quest.75619C7174C6703C.title: "Centrifugando Pó de Urânio"
	quest.756628F4B7F79446.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_aramber.png width:100 height:150 align:center}"]
	quest.756628F4B7F79446.title: "&cAmaramber&r"
	quest.757B14D08A9A03C4.quest_desc: ["Assim como a maioria das máquinas Modded, as Fornalha de Ferros têm Configurações. As configurações podem ser encontradas clicando no canto superior esquerdo. Haverá as Entradas, Saídas e ativação de Redstone. A ativação de Redstone muda quando a Fornalha irá derreter. Os botões superiores determinam se ela entra ou sai automaticamente, o que significa que se moverá automaticamente para e de Inventários conectados. As caixas são de cada lado da Fornalha e determinam se ela Entra, Sai, faz ambos, Entra Combustível ou não faz nada. Isso importa para Itens sendo Canalizados para dentro ou para fora. O Vinculador de Configurações de Fornalha copiará todas essas configurações para outras Fornalhas!"]
	quest.757B14D08A9A03C4.title: "Configurações"
	quest.7580037DB8ADEB3C.quest_desc: ["Miau miau, eu sou uma Vaca..."]
	quest.7580037DB8ADEB3C.quest_subtitle: "Tier: &a2"
	quest.7588ADA67F348B0C.quest_desc: [
		"Aumento de nível para 76."
		""
		"Item de Assinatura é &bVivichoke&r."
	]
	quest.7588ADA67F348B0C.title: "&6Treinadora May"
	quest.75ACC8CF5873F92D.quest_desc: [
		"A Cera Ancestral Luminescente Branca, as Flores Brancas e '&7Cinza Claro&r' nos dizem que este é o Santuário Sempiterno Branco. \\n\\nO lugar todo parece de Vanilla e &6Mel&r, me deixando com fome. \\n\\nSiga as salas para encontrar a Essência Branca. \\n\\nVocê terá que lutar contra 6 Entidades de Cristal Cósmico. Todas têm 60 Corações e só recebem 1 de Dano de um golpe de qualquer arma."
		"{image:atm:textures/questpics/bumblezone/bumble_white1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_white2.png width:200 height:100 align:center}"
	]
	quest.75ACC8CF5873F92D.title: "&fSantuário Sempiterno Branco&r"
	quest.75AD0CEBC1335915.quest_desc: ["O &dReactor Controller&r é o coração do reator. Quando um reator é formado, você pode clicar com o botão direito no terminal para abrir a interface do reator.\\n\\nDependendo se é um reator &9Resfriado Passivamente&r ou um &eResfriado Ativamente&r, a interface mudará. Reatores Resfriados Passivamente são usados para produzir energia diretamente queimando combustível. Reatores Resfriados Ativamente usam o calor criado para vaporizar o refrigerante, que é então enviado para uma Turbina para criar energia.\\n\\nNa interface de um reator passivo, você pode ver e alternar o status e a ejeção de resíduos. Você também verá as temperaturas, quanto FE/t o reator está produzindo e quanto combustível o reator está queimando por tick."]
	quest.75AD0CEBC1335915.quest_subtitle: "O Coração do Reator"
	quest.75B14A09FE39EDDA.quest_desc: ["Você gosta das suas &aEngenhocas&r indo apenas em linha reta? Então, o &aCarro de Pórtico&r é perfeito para você! \\n\\nColoque os &aEixos de Pórtico&r na linha que você deseja que sua &aEngenhoca&r siga e dê a ela &dEnergia Rotacional&r. \\n\\nDepois, coloque seu &aCarro de Pórtico&r em cima do &aPórtico &fe do&a Eixo&r e ele se moverá junto. \\n\\nVocê pode &aColar&r Blocos e &6Máquinas&r em cima do &aCarro de Pórtico&r para que também se movam com ele! \\n\\nOs &aEixos de Pórtico&r podem ser parados com um &4Sinal de Redstone&r. Você também percebe como eles se parecem com aqueles postes de barbearia?"]
	quest.75B14A09FE39EDDA.quest_subtitle: "Barbershop Poles"
	quest.75B14A09FE39EDDA.title: "&aGantry Carriage"
	quest.75CBB5BD8C1DFEA1.quest_desc: ["A &8Bacia&r é semelhante ao &eDepósito&r, mas pode conter &eItens&r e &bFluidos&r. \\n\\nIsso será útil para usar o &6Misturador Mecânico&r para Misturar e Preparar. \\n\\nE com a &6Prensa Mecânica&r para Criar Automaticamente!"]
	quest.75CBB5BD8C1DFEA1.title: "&8Basin"
	quest.75CD4EE6A542D687.quest_subtitle: "Cristalina + Mineradora Cinzenta"
	quest.75CD4EE6A542D687.title: "&fAbelha de Cobre"
	quest.75CE67D3AA75C798.quest_subtitle: "Red Delicious Apple + Granny Smith Apple"
	quest.75D09040185B0E40.quest_subtitle: "Tier: &a2"
	quest.75D3F3C1D4A3EAA2.quest_desc: ["Para mover o calor que está sendo gerado pelo Tubo de Vórtice, faça alguns &3Tubos de Calor&r."]
	quest.75D3F3C1D4A3EAA2.quest_subtitle: "Temos o calor para mover :)"
	quest.75D3F3C1D4A3EAA2.title: "Movendo Calor"
	quest.75DD345164EE5CD9.quest_desc: [
		"&6High Speed Tracks&r são como &6Trilhos Reforçados&r, mas obviamente mais rápidos. Eles precisarão de &cKits de Trilho&r para ajudar a aumentar a velocidade! E cuidado nas curvas."
		"{image:atm:textures/questpics/railcraft/rail_speed.png width:150 height:100 align:center}"
	]
	quest.75DD345164EE5CD9.title: "&6High Speed Tracks"
	quest.75E4751F7A802A44.quest_desc: [
		"Que divertido! Uma lista de compras de &cQuímicos&r! O que somos, Walter White? \\n\\nPrimeiro, e mais importante, para o &aÁcido Sulfúrico&r, é o &eEnxofre&r! Minere um pouco e depois &bOxidize-o&r para obter &eDióxido de Enxofre&r. \\n\\nVamos precisar de um pouco mais de &bOxigênio&r, então vamos conseguir mais com um &9&lSeparador Eletrolítico&r alimentado com &9Água&r. \\nDepois, combine esse recém-encontrado &bOxigênio&r com o &eDióxido de Enxofre&r em um &c&lInfusor Químico&r para obter &cTrióxido de Enxofre&r. \\n\\nDeixe esse tal de &eEnxofre&r de lado por um momento até obtermos Vapor d'Água! Para obter Vapor d'Água, passe &9Água&r por um &c&lCondensentrador &bRotativo&r. "
		"{image:atm:textures/questpics/mek/mek_tier4_1.png width:200 height:100 align:center}"
	]
	quest.75E4751F7A802A44.quest_subtitle: "Processamento de Minério Tier 4"
	quest.75E4751F7A802A44.title: "Criando &aÁcido Sulfúrico"
	quest.75EE965CBA598FEA.quest_desc: ["A receita pode parecer confusa, mas confie em mim, é bem fácil. Crie qualquer &dTerminal Sem Fio&r e depois crie-os juntos para fazer o &dTerminal Sem Fio Universal&r. \\n\\nEle também manterá tudo o que você tinha no &dTerminal&r, como Padrões Estendidos, o que é muito útil para usar o &b&lAE2&r, mas não importa para a &6&lEstrela ATM&r!"]
	quest.75EE965CBA598FEA.title: "&dTerminal Sem Fio Universal"
	quest.75F0405FFAB9C080.quest_desc: ["Isto será necessário para o último Nível, o Nível Caótico. Espero que você tenha seguido o ramo de missões que explica como obter os Fragmentos do Caos!"]
	quest.75F0405FFAB9C080.title: "Núcleo Caótico"
	quest.75FE0B514448865B.quest_desc: ["Os upgrades vão diretamente para o Roteador e o Roteador pode conter 5 deles. Os upgrades afetam diretamente todos os Módulos que podem e geralmente podem se acumular!"]
	quest.75FE0B514448865B.title: "&lUpgrades"
	quest.7604D8B3C9FCCFD9.quest_desc: ["É hora de criar os 'Discos Rígidos' do Refined Storage. Para isso, precisaremos de uma &9Carcaça de Armazenamento&r que combinaremos com uma &6Parte de Armazenamento&r para criar um &9Disco de Armazenamento&r. Basta fazer o tamanho desejado da peça e combinar com uma Carcaça de Armazenamento para criar um disco.\\n\\nO &9Disco de Armazenamento&r é usado para armazenar seus itens virtualmente uma vez colocado dentro do &9Disk Drive&r. Ele precisa ser colocado em um &9Disk Drive&r. O Disco de Armazenamento não desaparecerá ao ser jogado no mundo."]
	quest.76062D375E4CC8DD.quest_desc: ["Já vimos Filtros e já vimos Round Robins, agora estamos vendo ambos! Isso é útil para manter os Itens em uma ordem selecionada, como ao fazer Sementes de Mystical Agriculture!"]
	quest.76064465104B1C28.title: "Módulo de Capacidade de Escudo Dracônico"
	quest.76071C22A73A2026.title: "&cFarmland de Tertium"
	quest.7617737FC179EA1A.quest_desc: ["A Armadura de &bAço Gelado&r é um pouco pior que a Armadura de Diamante, mas também oferece grande Resistência a Empurrões. \\n\\nNo entanto, ela também aplica um debuff de Velocidade, parece que não vamos nos mover muito!"]
	quest.7617737FC179EA1A.title: "Armadura de &bAço Gelado&r"
	quest.761D21C6FBD13EE1.quest_subtitle: "Alimente uma Abelha de Diamante com Peridoto"
	quest.761D21C6FBD13EE1.title: "&fAbelha de Peridoto"
	quest.762581CAE5F5DDC1.quest_desc: [
		"Um Mod de Magia, que chique! &d&lArs Nouveau&r é o Mod que usaremos para criar juntos &5Unobtainium&r e &6Allthemodium&r! \\n\\nO Aparelho de Encantamento é um multibloco usado para muitas receitas aqui atualmente. Comece com um Núcleo Arcano e coloque o Aparelho de Encantamento sobre ele. Em seguida, coloque Pedestais ao redor do Aparelho de Encantamento no mesmo Nível Y. \\n\\nEntão você pode colocar os Itens nos Pedestais em qualquer ordem, ter Fonte por perto, e colocar a Source Gem no Aparelho para começar! Então você terá criado seu Barra de Liga de &5Unobtainium&r-&6Allthemodium&r!\\n"
		"{ \"text\": \"LINHA DE MISSÕES ARS NOUVEAU\", \"color\": \"#55FF55\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"6AEDA2F9BEB57759\" } }"
	]
	quest.762B8309E1A31B99.quest_desc: ["Cada upgrade adiciona +0.5 de Defesa de Armadura e +1 de Tenacidade de Armadura."]
	quest.762B8309E1A31B99.quest_subtitle: "Máx: 4"
	quest.762C54C261ED5D29.quest_subtitle: "Teca + Mogno"
	quest.763A19067AEEF6D5.quest_subtitle: "+2 de Sorte"
	quest.763AE58CF620695E.quest_desc: ["Este &9Projeto&r, como muitos outros, pode ser Criado. \\n\\nO &8&lImmersive Engineering&r vem com seus próprios Padrões de Estandarte! \\n\\nVocê precisará de &9Projetos&r para criá-los, no entanto."]
	quest.763AE58CF620695E.title: "&9Projetos de Padrões de Estandarte"
	quest.763EB5C911D7E78C.quest_desc: ["Fim da linha para as Infusões de Criação, o Nível Caótico. Tudo pode ser criado uma vez que você está aqui. Não apenas as Ferramentas, mas também tudo o que você precisará para o Reator."]
	quest.763EB5C911D7E78C.title: "Nível Caótico"
	quest.763FB27929E053BE.quest_desc: ["Os &9Filtros de &8Melhoria&r são usados apenas em &b&lBombas Elétricas&r. \\n\\nAs &b&lBombas&r funcionarão da mesma forma, mas em vez de coletar &9Água&r, elas coletarão &9Água Pesada&r. \\n\\n&9Água Pesada&r será necessária como Combustível para o &2&lReator de Fissão&r!"]
	quest.763FB27929E053BE.title: "&8Melhoria de &9Filtro"
	quest.764609E41957DA69.quest_subtitle: "6.561 Blocos de Esmeralda"
	quest.7649D648A3688D4A.quest_desc: ["O Upgrade Puxador permite que as Gavetas puxem itens de qualquer lado."]
	quest.76516C997B63905A.quest_subtitle: "Tier: &b4"
	quest.7655E1C6C5E5469F.quest_subtitle: "Alcance: &a18&r Blocos"
	quest.7655E1C6C5E5469F.title: "&2Growth Accelerators de Prudentium"
	quest.7658C1C663394E85.quest_desc: ["Existem muitos comandos úteis no ATM. Aqui estão alguns:\\n\\n&e/sethome&r (nome da casa) | Permite que você defina um ponto de retorno para o qual pode se teletransportar usando /home (nome). Exemplo: /sethome fazenda - depois teleporte com /home fazenda.\\n\\n&e/spawn&r | Isso teletransportará você para o ponto de origem do seu Mundo Superior.\\n\\n&e/rtp&r | 'Teletransporte Aleatório' teletransportará você para um local aleatório no mundo.\\n\\nNota: Estes comandos possuem tempos de recarga e limites. Se desejar alterá-los, você pode editar o arquivo de configuração que pode ser encontrado aqui:\\n\\n - Para Singleplayer | &osaves/(nome do save)/serverconfig/ftbessentials.snbt&r\\n\\n - Para Servidores | &oworld/serverconfig/ftbessentials.snbt&r"]
	quest.76660075F254597E.quest_desc: ["O &#F5B758Melhoria Avançada&r adiciona &#EDE02F16 EU/t&r de uso máximo por melhoria."]
	quest.766C80E5D7B7A916.quest_subtitle: "Escolha um!"
	quest.766EEB89C6DF3575.quest_desc: ["A Stella Eterna pode ser usada para tornar um Item Inquebrável, combinando-o com o Item em uma Mesa de Ferraria. Ou você pode usá-la para criar Ferramentas de Liga! \\n\\nPrimeiro, você precisará de uma Forja de Nível 3 com muitos Materiais nela. \\n\\nDepois, você precisará de 3 Orbes Xpetrificados. Para obtê-los, você precisa alimentar um Buraco Negro com Itens. \\n\\nAlém disso, uma Peça de Stellarite que você precisa minerar! E um &6Barra de Allthemodium&r que é o mesmo."]
	quest.7671AFAA1EFD287F.quest_desc: ["Você quer automatizar lentamente &bAureal&r para sua &6&lForja&r? Então, você precisará de 2 &bBlocos de Cristal Arcano&r, &6Pedra Polida Arcana&r e &cPó de Mundabitur&r! \\n\\nColoque a &6Pedra Polida Arcana&r, depois em cima coloque ambos os &bBlocos de Cristal Arcano&r. \\n\\nQuando você tiver esta Estrutura de 1x3x1, clique com o botão direito nela com &cPó de Mundabitur&r para fazer o &bObelisco&r! \\n\\nVocê pode colocá-los, onde os Pedestais geralmente vão, no &6&lMultibloco da Forja&r para automatizar &bAureal&r!"]
	quest.7671AFAA1EFD287F.title: "&bObelisco de Cristal Arcano"
	quest.7678B5DD1339833E.quest_desc: ["O Painel Solar gera FE quando tem acesso direto ao sol. No entanto, você pode usar uma &7Lente de Ender&r para ignorar blocos em seu caminho."]
	quest.767E4FC03B6F6534.quest_desc: ["Barras de Invar são feitos com &7Ferro&r e &7Níquel&r. \\n\\nComo muitas dessas Ligas, elas não são úteis no &8&lIE&r."]
	quest.767E4FC03B6F6534.title: "&7Lingote de Invar"
	quest.768C07D1B5EB1FEB.quest_desc: ["Estes podem ser encontrados em Areia e Cascalho Suspeitos dentro de Ruínas de Oceano Frio."]
	quest.768C07D1B5EB1FEB.quest_subtitle: "Blocos Suspeitos de Ruínas de Oceano Frio"
	quest.769D5DE66D13B256.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
	quest.76A0592F4C294545.quest_desc: ["A Sawmill corta Troncos em Serragem e mais Tábuas do que você obteria na criação. A Serragem pode ser usada para fazer Papel.\\n\\n - Troncos de Fustic também lhe darão Fustic.\\n - Troncos de Pau-Brasil e Troncos de Logwood também lhe darão Hematoxilina."]
	quest.76A0592F4C294545.quest_subtitle: "Eu também faria"
	quest.76A0592F4C294545.title: "Serrando"
	quest.76B1C5AFC5D6B7CF.quest_desc: ["A Varinha do Tempo pode ser usada para acelerar blocos, de forma semelhante ao Tempo na Garrafa, até uma velocidade de x256. Ao contrário do TIAB, ela usa FE e Fluido do Tempo em vez de tempo armazenado como combustível, tornando muito mais fácil de reabastecer.\\n\\nEla está na lista negra para jogadores falsos, no entanto. Não queremos que você automatize ISSO."]
	quest.76B1C5AFC5D6B7CF.quest_subtitle: "&fPrima do Tempo na Garrafa"
	quest.76BF91F3D73B4E68.quest_desc: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, você está no modo de edição."]
	quest.76C63670624C3C56.quest_desc: ["O &c&lGenerator Galore&r nos dá toneladas de Geradores de Energia úteis e simples! \\n\\nAlguns podem até ser combinados entre si para serem mais poderosos. \\n\\nHá uma página de Missões para eles, só que estão dividindo o quarto com o &7&lFornalha de Ferros&r."]
	quest.76C63670624C3C56.title: "&c&lGenerator Galore"
	quest.76CA3D98A4772886.quest_desc: ["A &4&oSérie&r pode ter acabado, mas se você quiser continuar sendo o &5Campeão&r, precisará lutar para mantê-lo! \\\\n\\\\nAlgumas das pessoas que perderam para você antes estão voltando para se vingar, e pelo título de &5Campeão&r! \\\\n\\\\nSendo estes: &5Defesa de Título: Jax&f, &5Defesa de Título: Humberto&f, &5Defesa de Título: Milo&f, &5Defesa de Título: Solenk&f, &5Defesa de Título: Wayne&f, e &5Defesa de Título: Zeph&r. \\\\n\\\\nEstas são lutas opcionais, então infelizmente eles não possuem um Item de Assinatura. Em vez disso, eles Gerarão aleatoriamente em certos Biomas. (Dica: todos são biomas onde as Cidades do End podem Gerar). \\\\n\\\\nSe você derrotar todos eles, receberá o Título de Borrius!"]
	quest.76CA3D98A4772886.title: "Ainda o &5Campeão&r!"
	quest.76CBFA38D021AC95.quest_desc: ["Os &dMoinhos de Vento&r são um pouco mais complicados que as &9Rodas d'Água&r, mas também vêm com mais personalização e, claro, mais Velocidade e Unidades de Tensão! \\n\\nPrimeiro, você precisará do coração do &dMoinho de Vento&r, o &dRolamento do Moinho de Vento&r. Este Bloco enviará a &dEnergia Rotacional&r para fora dele. É também o que usaremos para ligar o &dMoinho de Vento&r! \\n\\nDepois, você precisará dos Blocos para fazer a parte do &dMoinho de Vento&r propriamente dita. Os Blocos se prenderão automaticamente ao &dRolamento&r, mas para o resto do &dMoinho de Vento&r você precisará de &aCola&r. Exceto as &dVelas do Moinho de Vento&r, essas se prendem automaticamente! \\n\\nTambém precisaremos de pelo menos 8 Blocos tipo &dVela de Moinho de Vento&r, que são as &dVelas de Moinho de Vento&r ou Lã. Quanto mais tivermos, mais rápido o &dMoinho de Vento&r gira! \\n\\nQuando tudo estiver pronto, basta clicar com o botão direito no &dRolamento&r com a Mão Vazia para iniciá-lo."]
	quest.76CBFA38D021AC95.title: "&dMoinhos de Vento"
	quest.76CDC18D7A208512.quest_desc: ["No &2&lUndergarden&r, &cCriaturas Putrefatas&r podem infectar você com &cUtherium&r. Em doses menores, esta infecção diminuirá com o tempo. Em doses altas o suficiente, ela não diminuirá, e terá que ser curada com &3Rogdorium&r, que só é encontrado nas profundezas das regiões de Dreadrock. Você pode consumi-lo ou infundir sua armadura com ele para afastar esta infecção. Eu até vou te dar um pouco de &3Rogdorium&r por conta da casa!"]
	quest.76CDC18D7A208512.title: "Aviso"
	quest.76CDF08465700AA2.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_silent.png width:100 height:150 align:center}"]
	quest.76CDF08465700AA2.quest_subtitle: "Cidades Ancestrais"
	quest.76CDF08465700AA2.title: "Ornamento de Armadura do Silêncio"
	quest.76CECFB244F39F18.quest_desc: [
		"Basta colocar um &3Importador de Energia&r em uma Fonte de Energia e conectá-lo a uma &3Interface de Energia&r com Cabos Lógicos! Coloque e edite os Cartões de Variáveis e você estará movendo Energia como um profissional! \\n\\nDevo dizer que encontrei problemas ao Importar ou Exportar para Flux Plugs e Points, então tenha isso em mente."
		"{image:atm:textures/questpics/logistics/id_energy.png width:200 height:50 align:center}"
	]
	quest.76CECFB244F39F18.title: "&3Importação de Energia"
	quest.76E94639E90FEB4E.quest_desc: [
		"Coloque algumas &eColmeias Avançadas&r vazias em uma área não iluminada. \\n"
		"As abelhas aparecerão com o tempo á noite."
	]
	quest.76E94639E90FEB4E.quest_subtitle: "Colmeias, sozinhas e no escuro, revelam grandes surpresas!"
	quest.76E94639E90FEB4E.title: "&fAbelha Esquelética"
	quest.76EA017B12E8F01B.quest_desc: ["Esta seção mostra diferentes maneiras de armazenar sua energia!"]
	quest.76EA017B12E8F01B.title: "&f&lArmazenando Energia"
	quest.76F14C2B866B4EAD.quest_desc: ["O &3&lOutro Lado&r é o local de nascimento do &3Sculk &fe das criaturas de &3Sculk&r, incluindo o &9&lWarden&r. \\n\\nAqui você encontrará muitos de seus primos distantes, mas não se preocupe, também há alguns pontos positivos no &3&lOutro Lado&r! \\n\\nHá muitos novos Blocos de Construção e Itens que podemos encontrar e &3Sculk&r por toda parte para obter toneladas de &aXP&r! \\n\\nEntão, prepare sua Enxada e aventure-se no &3&lOutro Lado&r!"]
	quest.76F14C2B866B4EAD.quest_subtitle: "Olá do..."
	quest.76F14C2B866B4EAD.title: "O &3&lOutro Lado"
	quest.76F675A898EAB4E8.quest_desc: ["O &dSal Ammoniac&r é uma parte crítica do &eAlchemical Sulfur&r, que é o que usaremos para fazer e reproduzir Itens. \\n\\nPara obter &dSal Ammoniac&r, precisaremos de um pouco de &9Água&r."]
	quest.76F675A898EAB4E8.title: "&dSal Ammoniac"
	quest.770C0975CA61CE46.quest_desc: ["Glacite pode ser encontrada nas profundezas das Florestas de Permafrost. \\n\\nPode ser usada para criar Armaduras e Ferramentas que ajudam contra o dano de Congelamento!"]
	quest.77145113CD5B26FB.quest_desc: ["Bagas de Fonte produzem mais Fonte do que outras fontes. \\n\\nIsso também converterá grama ou terra em Micélio em uma área de 3x3 ao seu redor. Também fará crescer cogumelos ao seu redor se o espaço estiver vazio."]
	quest.77145113CD5B26FB.quest_subtitle: "Gera Fonte de Comida Próxima"
	quest.7725CB7D0AE55180.quest_desc: [
		"Advanced AE é um addon para o Applied Energistics 2, que foca em melhorar a experiência do usuário sempre que você manuseia seu Sistema ME e em expandir as possibilidades dos sistemas de fim de jogo."
		""
		"De um Provedor de Padrão que pode enviar para lados específicos de uma máquina, a um computador multibloco que é capaz de executar trabalhos de crafting ilimitados, compartilhando coprocessadores entre esses crafts, e tudo mais."
	]
	quest.7725CB7D0AE55180.title: "Advanced AE"
	quest.772C65FC32AECD6B.title: "Padrão de Estandarte da Paz"
	quest.77382D4114E901CB.quest_desc: ["A &bPolia de Mangueira&r é usada para pegar e colocar Blocos de Fonte cheios de &bFluidos&r, sim, não apenas &9Água&r. \\n\\nPrimeiro, defina até onde a &bMangueira&r realmente desce ou sobe com o &8Eixo&r de um lado. Seja com uma &6Engrenagem&f, &8Eixo&r ou &dManivela&r, que é mais fácil. \\n\\nDepois, do outro lado da &bPolia de Mangueira&r, podemos colocar alguns &bTubos de Fluido&r. Com &bBombas Mecânicas&r, podemos escolher se a &bPolia de Mangueira&r pega Fontes de &bFluido&r ou as coloca. \\n\\nA &bPolia de Mangueira&r só tem um Inventário de 1.5 Baldes ou 1500mB, mas os &bFluidos&r podem ser &bCanalizados&r para outros Inventários ou &bTanques&r! \\n\\nSe a Fonte de &9Água&r for infinita, a &bPolia de Mangueira&r não removerá os Blocos de Fonte, mas continuará a retirar &bFluido&r. \\n\\nIsso também funcionará com Blocos de Fonte de &cLava&r, mas esses não são infinitos. Então você pode querer dar uma olhada no &c&lNether&r para isso, já que é praticamente infinito lá!"]
	quest.77382D4114E901CB.title: "&bPolia de Mangueira"
	quest.7744BEC5CD328262.quest_desc: ["Para minerar Blocos &bdebaixo d'água&r, você precisará deste Upgrade. \\n\\nEle também lhe dá Afinidade Aquática! (Isso significa que estar na &bÁgua&r não diminui sua Mineração.)"]
	quest.774D61FEFABEFD9A.quest_desc: [
		"As Minhocas Sonoras surgem ao pisar em &3Sculk Infestado&r nas &9Terras Profundas&r. \\n\\nElas são Mini chefes com 100 &4Corações&r. \\n\\nSe você chegar muito perto, elas te morderão, causando muito Dano! Mas se você for para muito longe, elas recuarão de volta para o chão. \\n\\nElas não dropam nada além de um pouco de &aXP&r, o que eu não acho que valha o trabalho."
		"{image:atm:textures/questpics/deepndark/dnd_worm.png width:100 height:200 align:center}"
	]
	quest.774D61FEFABEFD9A.title: "&3Minhoca Sonora"
	quest.775AB10F8196F27B.quest_desc: ["O &4Olho de Mec&r o levará à &4Fábrica Ancestral&r para lutar contra o &4&lPresságio (The Harbinger)&r."]
	quest.775AB10F8196F27B.title: "&4Olho de Mec&r"
	quest.775D176081DD75F5.quest_desc: [
		"Clicar com o botão direito em um Controlador de Turbina quando ele estiver totalmente construído mostrará a Interface da Turbina.\\n\\nAqui, você pode ver todas as estatísticas da Turbina. Passar o mouse sobre cada uma delas lhe dará mais informações sobre cada uma.\\n\\nNo canto inferior esquerdo, você terá 2 setas para controlar a &9Taxa de Fluxo&r. Isso controla a quantidade de vapor aquecido que é bombeada para a Turbina. Para saber quanto você deve definir, verifique a &dTaxa de Produção de Vapor&r do seu reator como ponto de partida. "
		"{image:atm:textures/questpics/extremereactors/turbineui.png width:200 height:150 align:1}"
	]
	quest.775D4E9974C70D5C.quest_desc: [
		"Em qualquer lugar que você encontrar uma Carvalho, poderá encontrar uma Carvalho Pré-histórico! \\n\\nAbaixo dos troncos haverá &7Cascalho Suspeito&r."
		"{image:atm:textures/questpics/pokemon/find_oak.png width:200 height:100 align:center}"
	]
	quest.775D4E9974C70D5C.title: "Carvalho Pré-histórico"
	quest.7766E66A14643F4D.quest_desc: ["O &6Despertar&r é uma adição relativamente nova ao &2&lMystical Agriculture&r. Através do &6Ritual do Despertar&r, você pode fazer &6Essência Despertada&r. \\n\\nEntão você pode combinar isso com Barras para obter este Bloco!"]
	quest.7766E66A14643F4D.title: "&6Bloco de Barra de Supremium Despertado"
	quest.7770F0D62457096D.quest_desc: ["Embora essas missões não abordem Drones, eles são incríveis! Pesquise sobre como usá-los se quiser."]
	quest.7770F0D62457096D.title: "Programando Drones"
	quest.7778937DF377C1B4.quest_desc: [
		"Esta é uma ótima opção para gerar &aEnergia&r automaticamente."
		""
		"A quantidade de &aEnergia&r que o &b&lGerador Eólico&r cria é baseada em seu Nível Y."
		""
		"Isso gera cerca de 90FE/t no nível do mar e o máximo que pode produzir é 360FE/t!"
		""
		"O &b&lGerador Eólico&r também precisará de &bCéu&r acima dele para funcionar, como um Sinalizador!"
	]
	quest.7778937DF377C1B4.quest_subtitle: "Que brisa suave!"
	quest.7778937DF377C1B4.title: "&b&lGerador Eólico"
	quest.7781133CB04584AA.quest_desc: [
		"Um nome muito chique para dizer \"caverna dentro de caverna exuberante\"! \\n\\nO &7Cascalho Suspeito&r surgirá sob a &9Água&r."
		"{image:atm:textures/questpics/pokemon/find_enhydro.png width:200 height:100 align:center}"
	]
	quest.7781133CB04584AA.title: "Ágata Enidro Pré-histórica"
	quest.779CA0C49F93C4F9.quest_subtitle: "59.049 Obsidiana"
	quest.77A8E8122870BBCE.quest_desc: ["Isto não é tecnicamente um Ovo Gerador, mas estou incluindo-o aqui de qualquer maneira, devido à sua capacidade de vincular criaturas a Geradores. Confira o capítulo do &5&lApothic Enchanting&r para saber mais sobre como obter este Lead."]
	quest.77A8E8122870BBCE.quest_subtitle: "Isso não é um Ovo Gerador!"
	quest.77B185799366ACD2.quest_desc: ["Para configurar o Filtro de Bloco, você só precisa clicar no Bloco que deseja evitar quebrar acidentalmente, com o Filtro de Bloco. \\n\\nCada Filtro pode conter apenas 1 Bloco, então se você quiser que Colmeias, Cabos, Baús, Fornos e Suportes de Poções não sejam mais destruídos acidentalmente, você precisará de 5 Filtros de Bloco. \\n\\nVocê pode trocar o Bloco nele simplesmente clicando em um Bloco diferente com ele."]
	quest.77B6A7151B3E5980.quest_desc: ["A &aMineração em Veio&r é um FTB Ultimine limitado. \\n\\nQuando Mineraramos Minérios ou Troncos, os blocos do mesmo tipo conectados a ele serão quebrados juntos. \\n\\nEconomizando muito tempo... mas nós também temos o FTB Ultimine... então. "]
	quest.77B6A7151B3E5980.quest_subtitle: "Tudo junto e Mis... Não quero."
	quest.77B6A7151B3E5980.title: "&aUnidade de Mineração em Veio"
	quest.77BE3D9D274F72F1.quest_desc: ["As &5Train Stations&r são os Blocos mais importantes para &5Trens&r! Precisamos delas para fazer &5Trens&f, desmontar &5Trens&r e Agendá-los! \\n\\nPara usá-las, você precisará selecionar um &7Trilho de Trem&r com elas. Segure a &5Estação de Trem&r na sua Mão e clique com o botão direito em um &7Trilho de Trem&r. \\n\\nEu não sei a distância máxima que uma &5Estação de Trem&r pode ser colocada, é pelo menos 10 Blocos! (Não tenho tanto espaço para testar). \\n\\nUma vez colocada, você pode Renomeá-la com a Barra de Texto no topo. \\n\\nVocê também pode Clicar em \"Criar Novo Trem\", para começar a fazer seu primeiro &5Trem&r. Depois de Clicar, um dos &7Trilhos&r aparecerá &9Azul&r, este é o &7Trilho&r em que você pode colocar &5Truques (Boogeys)&r. \\n\\nClique com o botão direito naquele &7Trilho&r com uma &5Carcaça de Trem&r para fazer um &5Truque&r, também conhecido como &5Rodas de Trem&r. Clique com o botão direito nas rodas para mudar seu design. Então você pode..."]
	quest.77BE3D9D274F72F1.title: "&5Train Stations"
	quest.77C6667B4C37589C.quest_desc: ["Os Upgrades de Máquina são usados para acelerar as máquinas da &aMystical Agriculture&r."]
	quest.77C9EE701F72586D.quest_desc: [
		"As &bCélula Portátil&f funcionam de forma idêntica às células normais, podendo ser inseridas em um baú ou drive e preenchidas adequadamente."
		""
		"No entanto, ao contrário das células normais, seu conteúdo também pode ser acessado de forma autônoma através do próprio item da célula, um pouco como uma mochila digital com sabor de ME."
	]
	quest.77C9EE701F72586D.title: "&eArmazenamento Portátil"
	quest.77D3546953550E39.quest_subtitle: "Pinheiro de Bull + Picea"
	quest.77DF4336700646D0.quest_desc: ["&4&lRadical Trainers&r é um Addon do &c&lCobble&fmon&r que nos dá &4Treinadores&r, mas também muda os Níveis que nossos &cPokemon&r podem alcançar... \\n\\nIsso é até que Derrotemos um certo &4Treinador&r! \\n\\nPara descobrir, você precisará de um &4Cartão de Treinador&r. Fabrique-os ou Troque por eles com um &4Associado Treinador&r. \\n\\n&4Associados Treinadores&r Aparecerão ao seu redor se você estiver Segurando seu &4Cartão de Treinador&r e não tiver uma &4&oSérie&r definida ou se estiver perto de uma Vila. Quando um estiver perto o suficiente, o &4Cartão de Treinador&r brilhará como se estivesse &5Encantado&r, e uma seta aparecerá acima dele em sua mão e apontará para o &4Associado Treinador&r. \\n\\nEsses Aldeões também podem lhe dar a &4&oSérie&r, que lhe dirá qual &4Treinador&r você precisa Derrotar para aumentar seu Limite de Nível. \\n\\nClique com o botão direito no &4Cartão de Treinador&r para ver quem eles são, e até Estatísticas sobre &4Treinadores&r anteriores que você Enfrentou!"]
	quest.77DF4336700646D0.title: "&bEvolução"
	quest.77F2271C45DB49BA.quest_desc: ["Este Módulo, quando colocado no Peitoral do &aMeka-Traje&r, lhe dará Voo Criativo. \\nVocê só precisa de alguns dos Itens mais caros do jogo para criá-lo!"]
	quest.77F241BEE9902751.quest_desc: ["O maior dos baús do Sophisticated Storage"]
	quest.77F241BEE9902751.quest_subtitle: "Tanto espaço para atividades!"
	quest.77F241BEE9902751.title: "&dBaú de Netherite"
	quest.77FB313845779AED.quest_desc: [
		"Agora use outro &a&lInfusor Químico&r para &a&lInfundir&r nosso Vapor d'Água e &cTrióxido de Enxofre&r. Agora temos nosso &aÁcido Sulfúrico&r! \\n\\nCanalize o &aÁcido Sulfúrico&r para um &3&lC.D.Q.&r para &3Derreter&r nossos &7Minérios &fcom &aÁcido&r. Isso nos dará &7Lama de Minério Suja&r, uma forma &cQuímica&r de &7Minérios&r. \\n\\n3 &7Minérios Brutos&r darão 2 Baldes de &7Lama de Minério&r e 1 &7Bloco de Minério&r dará 1 Balde de &7Lama de Minério&r. \\n\\nNão podemos andar por aí com &7Lama de Minério Suja&r, é vergonhoso! Precisaremos limpá-la! Inicie uma &a&lLavadora Química&r e coloque um pouco de &9Água&r (e detergente) nela. \\n\\nCada 5mb de &7Lama Suja&r será transformada em 3mb de &7Lama de Minério&r. \\n\\nAgora que nossa &7Lama&r está toda limpa, podemos colocá-la em um &5&lCristalizador Químico&r. Isso nos dará &7Cristais de Minério&r! Sim, diferentes de &7Fragmentos &fe &7Pedaços&r. Cada 200mb de &7Lama de Minério&r equivale a 1 &7Cristal&r."
		"{image:atm:textures/questpics/mek/mek_tier4_2.png width:300 height:50 align:center}"
	]
	quest.77FB313845779AED.quest_subtitle: "Processamento de Minério Tier 4"
	quest.77FB313845779AED.title: "Derretendo &7Minérios&f com &aÁcido &fe &5Cristalizando-os&r"
	quest.77FC692AC94D2EEF.title: "&l&9Recompensa do Mundo Superior:&r&e Creepers"
	quest.78099189ADEBE4B3.quest_desc: ["A &cFortaleza do Nether&r é uma estrutura obviamente no &c&lO Nether&r. \\n\\nÉ o único local de geração natural para &0Esqueletos Wither&r e &cBlazes&r. \\n\\nPrecisaremos dos &cBlazes&r para fazer &cPó de Blaze&r para os &aOlhos do Ender&r. \\n\\nOs &0Esqueletos Wither&r precisamos para invocar &0&lO Wither&r com seus &0Crânios&r."]
	quest.78099189ADEBE4B3.title: "&cFortaleza do Nether"
	quest.780E0163033CCD9B.quest_subtitle: "Tier: &b4"
	quest.78202A1CF5D86B94.quest_desc: ["O &9Banco de Energia&r do Powah.\\n\\nEstes também podem ser usados para aumentar a capacidade total de armazenamento de energia de suas &7Redes Ender&r sem fio."]
	quest.78215D704E6095B0.quest_desc: ["Você acha que &5&lMekanism&r e &l&7Modern Industrialization&r podem ter toda a diversão com seus conjuntos de armadura de fim de jogo? \\n\\nEsta &5Armadura Quântica&r tem status padrão semelhantes à &cArmadura de Netherita&r mas, como a &aMekaSuit&r, ela pode usar Energia como um escudo. \\nEla também tem melhorias que podem ser instaladas para te deixar ainda mais poderoso! Como Voo, Visão Noturna e até a capacidade de recarregar. \\n\\nMas a melhor parte é que ela pode ser Vinculada ao seu Sistema de Armazenamento! Então, você pode retirar Energia dele automaticamente e retirar qualquer Item dele, não importa onde você esteja. \\n\\nAlém disso, usar o conjunto completo pode impedir que a &aRadiação&r te mate."]
	quest.78215D704E6095B0.quest_subtitle: "Não vai te deixar totalmente invencível"
	quest.78215D704E6095B0.title: "Sistema ME como Armadura: A Armadura Quântica"
	quest.78311531069807DE.quest_desc: ["No &bApplied Energistics 2&r, toda Rede ME tem um certo número de &ecanais&f disponíveis, o que simplesmente significa quantos dispositivos em rede podem caber em toda a rede.\\n\\nComo regra geral, qualquer dispositivo que mais ou menos lida diretamente com dados ME (itens armazenados na rede) e realiza alguma forma de E/S ocupará um canal. Geralmente, componentes que se preocupam apenas com o armazenamento de energia interno da rede, como &eCélulas de Energia&f e &eInscritores&f, &onão&r ocupam canais.\\n\\nRedes sem um &bControlador ME&f são conhecidas como redes 'ad-hoc' e suportam um máximo de 8 canais."]
	quest.7834734E79E41A3A.quest_desc: ["Por favor, reconsidere jogar com o Mod &l&6Bumblezone&r se você sofre de alguma destas fobias: \\n\\nMelissofobia, Apifobia, Entomofobia, Aracnofobia, Tripofobia, Acrofobia, Claustrofobia e Cristalofobia. \\n\\nSe você sofre de Tripofobia, pode usar o pacote de recursos adicionado pelo &l&6Bumblezone&r para ajudar! Se for qualquer outra coisa, você está ferrado."]
	quest.7834734E79E41A3A.quest_subtitle: "Tenha cuidado de abelha!"
	quest.784466C3813AA506.quest_desc: ["Sempre quis pegar mobs? Nós... temos Gemas de Alma, Ferramentas de Aprisionamento de Mobs e Caçadores de Criaturas para isso.\\n\\nVamos ignorar isso por enquanto e focar na opção que o &5&lApotheosis&r oferece. O &5Chumbo Ender Frágil&r é a versão mais barata do &5Chumbo Ender&r, mas também a mais fraca e frágil. Ele só pode segurar animais e quebra após 8 usos."]
	quest.784466C3813AA506.title: "&5Chumbo Ender Frágil"
	quest.7846B7FFC3DD85C5.quest_desc: ["O &d&lAlterador de Fase Supercrítica&r (&d&lA.F.S.&r) transformará nosso &aPolônio&r em &dAntimatéria&r. \\n\\nPara fazer isso, precisaremos de &aPolônio&r, &aEnergia&r, um lugar para misturar ambos e um lugar para retirar a &dAntimatéria&r! \\n\\nEntão, precisaremos de uma &dPorta&r para cada uma dessas coisas! \\n2 &dPortas&r para &aEnergia&r nas laterais, 1 &dPorta&r para fornecer &aPolônio&r ao &d&lAFS&r, e a última para retirar nossa &dAntimatéria&r."]
	quest.7846B7FFC3DD85C5.title: "&dPortas do AFS"
	quest.784D6D11C4F41215.quest_subtitle: "&f6.5 &cde Dano de Ataque"
	quest.785951190FFDAA21.quest_desc: ["Aumenta o tamanho da pilha na Mochila em 4."]
	quest.785951190FFDAA21.title: "&eMelhoria de Pilha Nível 2"
	quest.786073B57C901DB7.title: "Padrão de Estandarte de Sinais de Mais"
	quest.7864C8F2CBC910CB.quest_desc: ["O &a&lCapacete Meka-Traje&r é, obviamente, a parte que vai na sua cabeça! Você precisará de um &dPellet de Antimatéria&r, &aPellets de Polônio&r, uma &dCélula de Indução Ultimate&r, e muito mais! \\n\\nEle serve como um Aprimoramento para os &5Capacetes de Unobtainium&r. Embora tenha muito menos Pontos de Armadura, ele funciona diferente dos &5Capacetes de Unobtainium&r. \\n\\nSe o &a&lCapacete Meka-Traje&r não estiver Carregado, ele funcionará com estatísticas semelhantes às de um &cCapacete de Netherita&r, mas aqui está a parte divertida! &a&lCapacetes Meka-Traje&r bloquearão todo o Dano (exceto Dano Mágico) e usarão &aEnergia&r. \\n\\nAlém disso, quando usado, ele exibirá em nosso HUD: nossas Coordenadas, &aEnergia&r dentro de nossa &a&lMeka-Traje&r, e substituirá os Pontos de Armadura por uma &aBarra de Energia&r. \\n\\nPodemos usar a &7&lEstação de Modificação&r para dar Aprimoramentos ao &a&lCapacete Meka-Traje&r, como mais &aEnergia&r para receber ainda menos Dano! Respiração Aquática, segurança contra &aRadiação&r, e até mesmo &eCarregamento Solar&r!"]
	quest.7864C8F2CBC910CB.title: "&a&lCapacete Meka-Traje"
	quest.78656C89EEE80DB5.quest_desc: ["Os &eTúneis de Latão&r funcionam como os &eTúneis de Andesito&r, mas com muito mais configurações! \\n\\nPrimeiro, agora temos Filtros! Estes são por lado: se você Filtrar o lado de Entrada, apenas aquele &eItem&r do Filtro será permitido passar pelo &eTúnel&r. Se você Filtrar os lados de Saída, então apenas aqueles &eItens&r sairão do seu lado. \\n\\nAgora também podemos alinhar os &eTúneis de Latão&r. Isso permitirá que eles recebam todas as mesmas Entradas, mas as Filtrem para &eEsteiras&r específicas! \\n\\nNo topo do &eTúnel&r, encontraremos a opção de mudar seus Modos de Distribuição. Não os explicarei em muitos detalhes, nossas Missões têm espaço limitado, em vez disso, vou resumir! \\n\\nDividir: dividirá as pilhas de &eItens&r igualmente por quantas &eEsteiras&r elas irão. Divisão Forçada: garantirá que cada &eEsteira&r receba uma quantidade igual, enquanto a Divisão normal pode pular algumas. Round Robin: alternará individualmente entre cada &eEsteira&r. Round Robin Forçado: não pulará alguns &eItens&r e, em vez disso, esperará, todos terão sua vez! Preferir Mais Próximo: enviará os &eItens&r para a Saída mais próxima. Aleatório: envia os &eItens&r aleatoriamente para diferentes Saídas. Sincronizar Entradas: só sairá quando todos os &eTúneis de Latão&r tiverem um &eItem&r esperando para Entrar."]
	quest.78656C89EEE80DB5.title: "&eTúnel de Latão"
	quest.787415570026FFAA.quest_desc: ["Estas melhorias adicionam encantamentos ao seu &4Destruidor&r.\\n\\nQuer saber por que você usaria isso? Imagine ter uma Pedreira ou Construtor bombeando Minérios com Toque de Seda para o seu sistema. Você pode ter um &bConstrutor&r colocando esses minérios, e então um &4Destruidor&r com &eFortuna&r para quebrá-los e obter ainda mais minérios brutos."]
	quest.787415570026FFAA.title: "Melhorias de Destruidor"
	quest.7878F190BC8ADC82.quest_desc: ["O melhor dos melhores. De Diamantes, à Estrela do Nether, ao Allthemodium. Esta Vareta encontra apenas os melhores Itens!"]
	quest.787E714014EC2C02.quest_subtitle: "Tier: &63"
	quest.78840993C7832E89.quest_desc: [
		"Melhorias Válidas:"
		"- Derrubador de Árvores"
		"- Quebrador de Folhas"
		"- Auto-forno"
		"- Teletransportador de Drops"
		"- Quebra Instantânea"
	]
	quest.78843287D1EB98E2.quest_desc: [
		"Aumento de nível para 81."
		""
		"Pode ser encontrado aleatoriamente em &9Ginásios&r que geram em &a#minecraft:village&r"
	]
	quest.78843287D1EB98E2.title: "&aLíder Clair"
	quest.788A7A2F1F438B64.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_cloggrum.png width:100 height:150 align:center}"]
	quest.788A7A2F1F438B64.title: "&7Cloggrum&r"
	quest.7895490EEBDCF601.quest_desc: ["O &eSítio Arqueológico&r é uma área rochosa repleta de blocos suspeitos. \\n\\nTambém há baús e vasos para saquear, mas os blocos suspeitos são mais legais!"]
	quest.7895490EEBDCF601.title: "&eSítio Arqueológico"
	quest.789AF6D0A6321945.quest_desc: [
		"O mais importante! O mais poderoso! O mais perigoso &l&3Artefato&r de todos!"
		"{@pagebreak}"
		"Não tenho certeza se devo explicar o que ele faz, é perigoso demais!"
		"{@pagebreak}"
		"Se você tem tanta certeza de que pode lidar com seu poder, talvez continue lendo..."
		"{@pagebreak}"
		"Ainda não é tarde para voltar atrás!"
		"{@pagebreak}"
		"Ok, eu avisei..."
		"{@pagebreak}"
		"Pressione Shift para ter uma chance de Soltar um Pum quando a &dAlmofada de Pum (Whoopie Cushion)&r estiver equipada."
	]
	quest.789AF6D0A6321945.quest_subtitle: "Único"
	quest.789AF6D0A6321945.title: "&dAlmofada de Pum (Whoopie Cushion)&r"
	quest.78B7FC6A868F5C4D.quest_desc: ["Você tem que encontrá-los em estruturas na &6&lBumblezone&r ou pode trocar com a &5Rainha Abelha&r para obter um! \\n\\nEnquanto o usa, você pode segurar a Barra de Espaço para voar por um pouco. \\n\\nExceto que, como uma &6A&8b&6e&8l&6h&8a&r, as Asas são pequenas demais para manter seu corpinho gordo fora do chão."]
	quest.78BCED8699ADEDF4.quest_desc: ["O &3Vidro à Prova de Som&r é feito combinando &3Pó de Alma&r e Vidro. \\n\\nEstes funcionam para abafar o Som, assim como a Lã! Se um &3Sensor de Sculk &fou &3Emissor&r tiver um cobrindo-os, eles não ouvirão os Sons. \\n\\nSó que através destes você pode ver!"]
	quest.78BCED8699ADEDF4.title: "&3Vidro à Prova de Som"
	quest.78BFDD3A9B996655.quest_desc: ["Um avanço considerável em relação ao &5Chumbo Ender Frágil&r. Agora, ele também pode segurar criaturas hostis e quebrará após 64 usos. Para obter isso, precisaremos de pelo menos &a45 Eterna&r, &c25% Quanta&r e &540% Arcana&r.\\n\\nIsso pode ser alcançado com 9 &bEstantes de Livro Marinha Cristalina&r ou, se preferir &4Estantede Livro Infernais&r, 9 &4Estantes de Livro Infernais Luminosa&r e 8 Velas (Dica: Você pode colocar até 4 velas em um único bloco)"]
	quest.78BFDD3A9B996655.title: "&5Chumbo Ender"
	quest.78CCD8075249E2B7.quest_subtitle: "Magmatic + Água"
	quest.78CCD8075249E2B7.title: "Abelha de Projétil de Vento"
	quest.78D1C97A542133D8.quest_desc: [
		"Aumento são Melhorias para Fornalha de Ferro Furnaces!"
		""
		"No canto superior direito da INTERFACE da Fornalha estará o botão para olhar a Seção de Aumento. Haverá um local Vermelho, Verde e Azul, cada um pode conter 1 de seus Aumentos coloridos."
	]
	quest.78D1C97A542133D8.title: "&lAumento"
	quest.78D8F40AA9568511.quest_desc: ["A Máquina de Rolar Motorizada é uma versão muito melhor da Máquina de Rolar Manual. \\n\\nVocê não precisa ficar olhando na máquina para criar coisas e ela criará todas elas automaticamente. \\n\\nO único problema é que precisa de energia!"]
	quest.78DA970F97002975.quest_desc: ["Barris são formas simples de armazenar &bFluidos&r. \\n\\nHá Barris de Madeira e Barris de Metal. Os de madeira só podem conter &bFluidos&r frios e à temperatura ambiente, não &bFluidos&r quentes ou Gases. Enquanto os Barris de Metal podem conter todos os tipos de &bFluidos&r e Gases. \\n\\nAmbos os Barris podem conter 12 Baldes de &bFluido&r. Eles automaticamente &9Entram&r pelo lado de cima e &6Saem&r pelo de baixo, mas isso pode ser alterado."]
	quest.78DA970F97002975.title: "Armazenando &bFluidos"
	quest.78DD2A3DFF6D1613.quest_desc: ["Com 2 &2Biocombustíveis&r, podemos fazer 1 &aSubstrato&r através da &2&lC.R.P.&r. \\n\\nBem... também precisaremos de &9Água&r e Hidrogênio na &2&lC.R.P.&r, mas então obteremos nosso &aSubstrato&r e também &dEthene Químico&r. \\n\\nPara fazer Pastilha de PEAD, precisaremos do nosso &aSubstrato&r, bem como transformar nosso &dEthene Químico&r em &dEthene Líquido&r. Podemos usar um &c&lCondensentrador &bRotativo&r para transformá-lo em &bLíquido&r! \\n\\nAgora jogue nosso &dEthene Líquido &fe nossos &aSubstratos&r na &2&lC.R.P.&r para fazer Pastilha de PEAD! \\n\\nPodemos então Criar 4 Pastilhas juntos para fazer uma Vara de PEAD ou &dEnriquecer&r 3 deles para fazer uma Folha de PEAD."]
	quest.78DD2A3DFF6D1613.title: "Usando tudo para transformar &2Biocombustível&r em PEAD"
	quest.78E40BDB0E54B638.quest_desc: ["Pode ser encontrado em estruturas na &6&lBumblezone&r ou trocado com a &5Rainha Abelha&r! \\n\\nSempre odiou ficar preso em &6Blocos de Mel&r? Ou mesmo quando o &ePólen&r te desacelera? Bem, não há necessidade de temer, pois as Perneiras de Abelha de Mel estão aqui! Elas o ajudarão a se mover melhor através desses Blocos. Quanto mais Armadura de Abelha você usar, mais fácil será a viagem! \\n\\nAlém disso, você pode passar através do &ePólen&r com Shift para coletá-lo!"]
	quest.78E51D22C16C4686.quest_desc: ["O Controlador de armazenamento também pode se conectar a outros armazenamentos sem fio, isso é possível usando a Ferramenta de Armazenamento, basta clicar com o botão direito no Controlador de armazenamento para vinculá-lo e clicar com o botão direito nos armazenamentos para conectá-los.\\n\\nO alcance para vinculação sem fio é o mesmo que o regular, 14 blocos de espaço."]
	quest.78E66F1DE42C747A.quest_desc: ["Os &9Fragmentos de Eco&r podem ser bem chatos de farmar, e ainda por cima precisaremos de muitos deles! Então, por que não ter uma maneira mais fácil de Farmá-los. \\n\\nCom a &d&lInfusão&r, podemos transformar 1 &9Fragmento de Eco&r em 4! \\n\\nPrecisaremos de &a70 Eterna&r, &c50% Quanta&r e &550% Arcana&r. \\n\\nPara conseguir isso, podemos usar 12 &4Estante de Livros Infernais Luminosos&r e 2 &9Estante de Livros Profunda&r, que não estejam &9Adormecida&r!"]
	quest.78E66F1DE42C747A.title: "&fInfinitos &9Fragmentos de Eco&f?"
	quest.78E94C386B1E7359.quest_desc: ["Geralmente você não consegue obter Ovos Geradores, mas é o mesmo com Geradores e aqui estamos! Existem algumas maneiras de obter Ovos Geradores, mas assim que conseguir, clique com o botão direito em um Gerador para mudar as criaturas que ele gera."]
	quest.78EC7D19BE24FE06.quest_subtitle: "Não explode"
	quest.78ECC28DD4BA9696.quest_desc: [
		"Embora você possa obter a maioria dos materiais do &dOutro Mundo&r usando Fogo Espiritual, você também pode usar &9Varas de Adivinhação&r para localizar esses materiais."
		""
		"Primeiro, você precisará sintonizar a Vara com o material que está procurando. Por exemplo, se você está em busca de &8Outra-pedra&r, pode usar a Vara em &aAndesito&r para ajudar a localizar a Outra-pedra no mundo."
		""
		"Uma vez sintonizada com um material, você pode segurar o botão direito com a Vara na mão, e uma partícula disparará na direção do material mais próximo ao qual está sintonizada."
		""
		"Você ainda precisará estar sob os efeitos do &3Terceiro Olho&r para poder colher o bloco do Outro Mundo."
	]
	quest.78ECC28DD4BA9696.quest_subtitle: "Caçando Materiais do &dOutro Mundo&r"
	quest.78ECC28DD4BA9696.title: "Ferramentas do Ofício: Vara de Adivinhação"
	quest.78FBB0C88182040E.quest_desc: ["Se você não joga Minecraft desde a 1.13, isso pode te confundir, mas você conhece as Bestas e a Perfuração. Elas têm um encantamento que permite que suas Flechas atravessem múltiplos alvos e causem dano continuamente. Este Módulo faz exatamente isso!"]
	quest.78FBB0C88182040E.title: "Módulo de Penetração de Projétil Wyvern"
	quest.78FC6687B5FD964F.quest_desc: [
		"A Bétula Pré-histórica surge onde quer que as Bétulas surjam. \\n\\nBem abaixo dos troncos da árvore haverá &7Cascalho Suspeito&r."
		"{image:atm:textures/questpics/pokemon/find_birch.png width:200 height:100 align:center}"
	]
	quest.78FC6687B5FD964F.title: "Bétula Pré-histórica"
	quest.78FEDE6FA4845585.quest_desc: ["Algumas &d&lInfusões&r precisam de quantidades muito, muito exatas de &aEterna&r, &cQuanta&r ou &5Arcana&r. \\n\\nPara obtê-las, você pode precisar de uma destas &7Prateleiras&r. \\n\\nCada uma diminui a quantidade de suas respectivas qualidades."]
	quest.78FEDE6FA4845585.title: "Quantidades &4Negativas&r"
	quest.7900A4836CC55428.quest_desc: [
		"A Matriz Montadora é um multibloco que pode conter efetivamente múltiplos Montadores Moleculares e Provedores de Padrão, tudo em um canal."
		""
		"A Matriz Montadora deve ser um cuboide de pelo menos 3x3x3 e no máximo 7x7x7. Ela requer as seguintes partes:"
		"- Bordas compostas de Armações da Matriz Montadora"
		"- Faces compostas de Parede/Vidro da Matriz Montadora"
		"- Interior composto de Núcleo de Padrão/Fabricador/Velocidade da Matriz Montadora"
		""
		"Uma Matriz Montadora válida deve conter pelo menos um núcleo de padrão e um núcleo de crafting. Ela deve ser completamente preenchida e não pode ser oca. Quando a Matriz Montadora é formada corretamente e energizada, as linhas na armação ficarão azuis."
		""
		"{@pagebreak}"
		""
		"Neste exemplo, faremos uma Matriz Montadora 7x7x7, focada principalmente no equilíbrio entre núcleos de crafting e de padrão."
		""
		"Faça as primeiras 43 Armações da Matriz Montadora e as primeiras 125 Paredes da Matriz Montadora. Eu darei 25 de cada como um presente nas recompensas desta missão (para alcançar um total de 68 armações e 150 paredes)"
	]
	quest.7900A4836CC55428.quest_subtitle: "Muitos Montadores Moleculares e Provedores de Padrão em Um Canal"
	quest.7900A4836CC55428.title: "Muitos Montadores em Um: A Matriz Montadora"
	quest.79110ACAAC8412EA.quest_subtitle: "Fabricação por Infusão"
	quest.79110ACAAC8412EA.title: "&fAbelha de Tertium"
	quest.791AE62ACACBD5BA.quest_subtitle: "Você vai abrir, fechar e abrir de novo, só porque está entediado"
	quest.792990DC06DB98F9.quest_desc: ["Pelo &2&lMundo Superior&r você pode encontrar Ruínas do Portal de &5&lEternal Starlight&r. Lá você pode desafiar o Guardião do Portal para uma luta! \\n\\nSe você vencer, ele lhe dará alguns Itens e com eles você poderá entrar no Portal para um mundo totalmente novo para explorar!"]
	quest.792990DC06DB98F9.title: "&5&lEternal Starlight"
	quest.7934873E784C4B3C.quest_desc: [
		"Isso parece familiar? \\n\\nAgora temos &7Fragmentos&r novamente. Antes de fazermos qualquer coisa com eles, precisaremos de &bOxigênio&r. \\n\\nJogue &9Água &fem um &9&lSeparador Eletrolítico&r para obter &bOxigênio&r. Então, &cCanalize&r esse &bOxigênio &fdo &9&lSeparador&r para o &b&lCâmara de Purificação&r. \\n\\nCom esse &bOxigênio&f, a &b&lCâmara de Purificação&r pode transformar seus &7Fragmentos &fem &7Pedaços de Minério&r. \\n\\nAgora, &cEsmague&r esses &7Pedaços&f para obter &7Pó Sujo&r. Então, &dEnriqueça &fesse &7Pó Sujo&f para obter &7Pó de Minério&r. \\n\\nE finalmente &6Derreta&r esse &7Pó&r, para obter nosso belo &lMinério Processado&r!"
		"{image:atm:textures/questpics/mek/mek_tier3_3.png width:250 height:100 align:center}"
	]
	quest.7934873E784C4B3C.quest_subtitle: "Processamento de Minério Tier 4"
	quest.7934873E784C4B3C.title: "&7Cristal&f, &7Fragmento&f, &7Pedaço&f, ETC"
	quest.7937DE650CABC1FF.quest_subtitle: "Funciona com combustível de fornalha"
	quest.7941938014E97A30.quest_desc: ["Você já quis voar em uma abelha?\\n\\nAs Abelhas Zangão aparecem naturalmente no mundo e podem ser usadas como montaria!\\n\\nFaça um &6Doce no Palito&r, coloque uma sela em uma Abelha Zangão e voe pelos céus!"]
	quest.7941938014E97A30.quest_subtitle: "Aparecem no Mundo Superior a partir de Ninhos de Abelhas Grande"
	quest.7941938014E97A30.title: "&fAbelha Grande"
	quest.795143471F31A64A.quest_subtitle: "Necessário para receitas de Laser"
	quest.7952DA35B4F5C598.quest_desc: ["O quê!? Um &7Balde&r não é suficiente? Uma Pilha de &7Baldes&r também não é suficiente? Então, amigo, você precisará de alguns &bTanques de Fluido&r! \\n\\n&bTanques de Fluido&r podem conter múltiplos &7Baldes&r de um &bFluido&r dentro deles e podem ser movidos como um &7Balde&r. Infelizmente, eles não podem colocar Blocos de Fonte. \\n\\nPara adicionar ou remover &bFluido&r, você precisará de &bCanos Mecânicos&r configurados para fazer uma coisa ou outra. \\n\\n&a&lBásico&r: comportará 32 Baldes de Fluidos. \\n\\n&c&lAvançado&r: comportará 64 Baldes de Fluidos. \\n\\n&b&lElite&r: comportará 128 Baldes de Fluido. \\n\\n&d&lUltimate&r: comportará 256 Baldes."]
	quest.7952DA35B4F5C598.quest_subtitle: "Pra que balde, né?"
	quest.7952DA35B4F5C598.title: "&bTanques de Fluido"
	quest.7953C87C488A2AF7.quest_desc: ["Permite que você voe como o Homem de Ferro.\\n\\nVocê só pode ter um nível dessas Melhorias nas Botas de cada vez. Cada nível usará mais pressão que o anterior.\\n\\nUse essas melhorias, não apenas as crie."]
	quest.7953C87C488A2AF7.quest_subtitle: "Máx: 1"
	quest.795A860668072830.quest_desc: ["{image:atm:textures/questpics/allthemodium/all_armor_vibarcane.png width:100 height:175 align:center}"]
	quest.795A860668072830.title: "&3Armadura Arcanista de Vibranium"
	quest.795B80BF12D23897.quest_desc: ["Está no nome, mas sendo um Encantamento de Tesouro nem todos saberão sobre ele. \\n\\nAo andar sobre &9Água&r com Botas encantadas com Caminhante Gélido ou &a&lBotas MekaSuit&r com as &bUnidades de Passos Gelado&7, a &9Água&r se transformará em &bGelo&r! \\n\\nO &bGelo&r não durará para sempre, porém, ele derreterá em breve! \\n\\nQuanto mais Passos Gelado, mais &bGelo&r!"]
	quest.795B80BF12D23897.quest_subtitle: "Fica frio aí!"
	quest.795B80BF12D23897.title: "&bUnidade de Passos Gelados"
	quest.796E922CA69BAE82.quest_desc: ["A &4Interface de Disco Mega&r tem 54 espaços para filtros, funciona 8x mais rápido e tem uma &eMelhoria de Pilha&r integrada."]
	quest.796E922CA69BAE82.title: "&4Interface de Disco Mega"
	quest.79886D63280DBBF3.quest_desc: ["Filtrar não é suficiente?!?! Você quer que os itens sejam destruídos?!?! Seu monstro!"]
	quest.79886D63280DBBF3.title: "Módulo de Incineração Seletiva"
	quest.799CC9FEEDE471B1.quest_subtitle: "Manga + Anis Estrelado"
	quest.79AD74A863EA43CB.quest_desc: ["A Flux Networks fornece uma maneira de armazenar a energia que você gera para sua rede!\\n\\nEstes armazenam enormes quantidades de energia no geral e podem ser atualizados para armazenar ainda mais!"]
	quest.79AD74A863EA43CB.quest_subtitle: "Armazenando Energia"
	quest.79AD74A863EA43CB.title: "Armazenamento Flux"
	quest.79AF63E77AD70A93.quest_desc: ["&7Estantes&r são seu ponto de partida, mas definitivamente não seu ponto final. Pelo menos não as &7Estantes&r normais. \\n\\nCom apenas &7Estantes&r normais, você só pode obter &aEterna&r até um máximo de 30. \\n(Explicarei os &5Níveis de Encantamento&r em breve, mas saiba que você precisa aumentá-los)"]
	quest.79AF63E77AD70A93.title: "O Máximo do &2&lVanilla&r é apenas o começo"
	quest.79BBCC1BEE90DBBB.quest_desc: [
		"&lTipo de Habilidade:&r Passiva"
		""
		"&lFunção da Habilidade:&r"
		""
		"Permite ao jogador enganar a morte, tem um tempo de recarga muito longo. Basicamente, um Totem da Imortalidade com tempo de recarga que não é consumido."
	]
	quest.79BEECD4E545793F.quest_desc: ["Fio Laminado funciona como Teias de Aranha... só que mais afiado! \\n\\nO Fio Laminado causará Dano e Lentidão a tudo que tentar passar por ele, incluindo nós! \\n\\nPodemos desmontá-lo com segurança com nossos &6Corta-fios de Engenheiro&r. \\n\\nOu podemos usar &6Fios&r &cLV&r para fazê-lo causar mais Dano e um Efeito de Atordoamento!"]
	quest.79C1105A84B8BF8F.quest_desc: ["Cartões Variáveis são necessários para iniciar Interações como Importar Itens. Você os colocará em um dos slots do Importador para adicioná-los.\\n\\nA partir daí, você pode editar tudo através do Botão +. Você pode alterar o quanto é Importado, qual Slot de Item, qual Canal, praticamente tudo com apenas esse Cartão.\\n\\nSe você está apenas querendo mover itens, nada muito extravagante, apenas coloque-o e talvez mude o Limite de quanto é movido."]
	quest.79C1105A84B8BF8F.title: "Cartões Variáveis"
	quest.79C4CF8D7312FC28.quest_desc: ["O melhor que o Vanilla tem! &5Netherita&r! Não se preocupe, você não precisará do Modelo de Ferraria para isso, apenas de muita &5Netherita&r. \\n \\nEla derrete um item a cada 5 Ticks, o que significa 4 Itens Derretidos por Segundo. Sim, não é mais T.F.S. (Segundos por Derretimento), agora é D.P.S. (Derretimentos por Segundo). \\n \\nCriada a partir da &dObsidian Furnace&r... espere, esta não é a Fornalha final?"]
	quest.79C4CF8D7312FC28.title: "&5Fornalha de Netherita&r"
	quest.79C652E3FCB88550.quest_desc: [
		"&5Gloompers&r são tecnicamente Passivos, mas eles têm um mecanismo de defesa contra você, então eu os considero Neutros! \\n\\nQuando atingidos, eles soltarão um Efeito semelhante a uma Poção Persistente. \\n\\nNa morte, eles soltarão suas Pernas (que são muito saborosas) e possivelmente Couro. \\n\\nEles também podem ser reproduzidos com Gloomgourds!"
		"{image:atm:textures/questpics/undergarden/undergarden_gloomper.png width:100 height:100 align:center}"
	]
	quest.79C652E3FCB88550.title: "&5Gloomper&r"
	quest.79C9875A1A494762.quest_desc: ["Se você prefere não usar &9Almas Corrompidas&r para cultivar Edelwood, pode contar com a Sorte! \\n\\nO Vendedor Ambulante tem a chance de vender Edelwood Crescente para você, que pode ser plantada para cultivar Edelwood. \\n\\nO Vendedor Ambulante é muito aleatório, no entanto, tente usar Tapetes de Vendedor para pelo menos saber onde ele vai aparecer!"]
	quest.79C9875A1A494762.quest_subtitle: "Vendedor A+"
	quest.79C9875A1A494762.title: "Comprando Edelwood"
	quest.79CA2F401982C04F.quest_subtitle: "Alimente uma Abelha Arcanus com um Bloco de Runas"
	quest.79CA2F401982C04F.title: "&fAbelha de Runa"
	quest.79D2617E01481281.quest_desc: ["Para começar com o AE2, você precisará minerar um recurso importante para o mod conhecido como &bQuartzo Certus&f. Você encontrará Cristais de Quartzo Certus em Meteoritos que você pode minerar para obter &ePó&f e &eCristais&f de &bQuartzo Certus&r."]
	quest.79D2617E01481281.title: "&bQuartzo Certus"
	quest.79D3055DE0EEA6B0.quest_desc: ["&d&lArs Elemental&r &cArmadura de Fogo&r!"]
	quest.79D3055DE0EEA6B0.quest_subtitle: "15"
	quest.79D3055DE0EEA6B0.title: "&cTraje de Piromante"
	quest.79D48F8F31B152C3.quest_desc: [
		"&c&lAviso: No momento em que este texto foi escrito, o Mewtwo é inobtível. Como resultado, o mod Industrial Foregoing Souls não tem utilidade neste momento.&r \\n\\n&bIndustrial Foregoing &#27AEB9Souls&r adiciona máquinas para permitir que você acelere outras máquinas.\\n\\nA &#27AEB9Base de Laser de Alma&r é o coração disso, funcionando de forma semelhante a uma Base de Laser de Fluido extraindo Gás Éter de um Wither. Ela usa &9Lente de Laser Azul&r para extrair &#27AEB9Almas&r de um &#27AEB9Mewtwo&r, que podem ser extraídas com &#27AEB9Tubos de alma&r, ou usadas com AE2. Estas &#27AEB9Almas&r serão usadas por &#27AEB9Conduto de Alma&r para acelerar blocos. Sim, eu sei que a maioria de vocês está acostumada a extrair &#27AEB9Almas&r de um &#27AEB9Warden&r, mas fala sério, tivemos que dar uma folga para aquela criatura.\\n\\nExtrair &#27AEB9Almas&r do &#27AEB9Mewtwo&r é um processo &4&ldoloroso&r para a criatura, o que significa que ela recebe dano do processo e pode até morrer por causa disso. Câmaras de Estase são altamente recomendadas, especialmente com melhorias para tornar a cura mais rápida."
		"{@pagebreak}"
		"Certifique-se de que haja um espaço de 3 blocos entre o chão e a &#27AEB9Base de Laser de Alma&r, assim:"
		"{image:atm:textures/questpics/industrialforegoing/soul_laser_gap.png width:100 height:100 align:center}"
	]
	quest.79D48F8F31B152C3.quest_subtitle: "Tem que ser rápido! (WIP)"
	quest.79D48F8F31B152C3.title: "&bIndustrial Foregoing &#27AEB9Almas"
	quest.79D6A251FE3761B3.quest_desc: ["Quando colocado em um bioma de pântano, o Ninho de Slime atrairá Abelhas de Slime."]
	quest.79D6A251FE3761B3.quest_subtitle: "Atrai uma Abelha de Slime em um Bioma de Pântano"
	quest.79D6A251FE3761B3.title: "&fNinho de &aSlime"
	quest.79E30114ED8870EE.quest_subtitle: "&f7 &cde Dano de Ataque"
	quest.79EF24E396779B9F.quest_subtitle: "Nível: &f2"
	quest.79FC674836B6340E.title: "Módulo de Salto Dracônico"
	quest.79FF12D7A4C8E821.quest_desc: [
		"Navegando pelos 7 &b&lMares de Açúcar&r está o perigoso &bNavio Pirata&r liderado pelo terrível Capitão. \\nNo Convés Inferior estão os Navegadores. \\nPerto das Armas no Porão de Carga fica o Contramestre. \\n\\nPor todo o &bNavio&r você pode encontrar o Saque das muitas aventuras dos Piratas!"
		"{image:atm:textures/questpics/bumblezone/bumble_pirates.png width:200 height:100 align:center}"
	]
	quest.79FF12D7A4C8E821.title: "&bNavio Pirata"
	quest.7A066DD274F970C2.quest_subtitle: "2/5"
	quest.7A066DD274F970C2.title: "Parte direita da &6&lEstrela ATM&r"
	quest.7A103577EAE7B3F1.quest_desc: ["Esta é a Essência Despertada de Nível 5, feita combinando 4 Pós Cognizant, 10 de cada Essência Elemental e 1 Bloco de Supremium em um Altar do Despertar."]
	quest.7A103577EAE7B3F1.quest_subtitle: "Nível: &c5 - Despertado"
	quest.7A103577EAE7B3F1.title: "&6Supremium Despertado"
	quest.7A16D2EB63359294.quest_desc: [
		"Cervos Aurora são animais de casco amigáveis que também vivem no frio. \\n\\nEstes Cervos não tentarão te machucar, mas se você ficar no caminho deles quando correm, pode sentir alguns Chifres. \\n\\nChifres que também podem ser dropados por eles na morte e podem ser usados como arma ou enxada! \\n\\nEles também podem dropar Couro ou Bife de Cervo Aurora."
		"{image:atm:textures/questpics/eternal/starlight_deer.png width:200 height:100 align:center}"
	]
	quest.7A16D2EB63359294.title: "Cervo Aurora"
	quest.7A1C117CA8FB7C31.quest_desc: ["Este é único!\\n\\nEm vez de encontrar Minérios, ele encontrará blocos de Ametista em Broto!\\n\\nChega de lutar para encontrar Geodos para você, bom senhor!"]
	quest.7A1E3E7E2DF17AD2.quest_desc: ["Primeiro, é a &8Lâmina de Serra&r. Ela é usada para cortar &2Árvores&r. Ela cortará cada Tronco e Folha na &2Árvore&r acima do Tronco que for cortado. \\n\\nSegundo, é a &8Lâmina Corta-rocha&r. Esta não pode quebrar &2Árvores&r, mas é usada como uma Picareta com Toque Suave. Ela quebrará Pedra e lhe dará Pedra em vez de Pedregulho. \\n\\nTerceiro é o &8Disco de Moagem&r. Ele não quebrará &2Árvores&r ou Pedra, mas sim &7Blocos de Metal&r! Bom para &8Andaimes de Aço&r e para raspar a Oxidação do &6Cobre&r!"]
	quest.7A1E3E7E2DF17AD2.title: "Munição para a &2&lSerra Elétrica&r"
	quest.7A271F425C3934CE.quest_desc: ["Atualmente, isso só pode ser criado cozinhando 2 &bSais de Planta&r para fazer 1 &bSal de Criatura&r. \\n\\nEsperançosamente, em atualizações mais recentes, poderemos matar mais criaturas vivas por &bSal&r!"]
	quest.7A271F425C3934CE.title: "&bSal de Criatura"
	quest.7A2B26CF0EDAA724.quest_subtitle: "Feito na Fundição de Ligas"
	quest.7A2B26CF0EDAA724.title: "&fAbelha de Aço do End"
	quest.7A3DD8CAD6A5692D.quest_subtitle: "Maçã Red Delicious + Bordo de Açúcar"
	quest.7A41038180C06B00.quest_desc: ["&cConectores&r são o que... bem, conectam! Eles conectam &cFios&r de Máquinas, para &cAcumuladores&r, para Geradores, de praticamente tudo! \\n\\nSe um &cConector &9Entra &fou &6Sai&r é determinado pela configuração do que ele está conectado! \\n\\nEles também têm seu próprio armazenamento interno de &cEnergia&r, o Nível de Voltagem determina quanto."]
	quest.7A41038180C06B00.title: "&cConectores"
	quest.7A4A07325C00A238.quest_desc: ["&9Slow&dpoke&r é muito similar ao &cCharcadet&r, ambos têm 2 &bEvoluções&r diferentes que podem obter com Itens. \\n\\Dando ao &9Slow&dpoke&r um &6Glarica Cuff&r, você obterá um &9Slow&dbro&r. \\n\\nUse uma &6Glarica Wreath&r em vez disso e você obterá um &9Slow&dking&r!"]
	quest.7A4A07325C00A238.title: "Itens de &bEvolução&r do &9Slow&dpoke"
	quest.7A4ABFCD12202A91.quest_desc: ["Potencial Operacional é a fonte de Energia do Draconic Evolution. A principal maneira (não a única) de mover OP é com os Cristais de Relé IO. Para realmente colocar OP nos itens, você precisará de uma Transferência de Energia."]
	quest.7A4ABFCD12202A91.title: "O que é Energia ou, como a chamamos, OP?"
	quest.7A514E27E1A7FE32.quest_desc: ["Diamantes também nos permitem criar alguns gadgets legais para nos ajudar a construir usando o mod &l&cBuilding Gadgets&r.\\n\\nEstas são ótimas ferramentas para ajudá-lo a construir bases maiores, ou para limpar espaço usando o &cDestruction Gadget&r."]
	quest.7A514E27E1A7FE32.title: "&l&cBuilding Gadgets&r"
	quest.7A579E233C69871F.quest_desc: ["&b&lHostile Neural Networks&r é tudo sobre simular Mobs para farmar seus Loots! \\n\\nNão há muito mais do que isso."]
	quest.7A579E233C69871F.title: "&b&lHostile Neural Networks"
	quest.7A615E2A152917AD.quest_desc: ["Para isso, você precisa de 2 &5Fornalhas de Netherita&r e 7 pedaços de vidro, cada um com a cor do Arco-Íris. &cVermelho&r, &6Laranja&r, &eAmarelo&r, &2Verde&r, &3Azul&r, &9Índig&r- &5Roxo&r, e &5Vi&r-&dMagenta&r. Sim! O Roy G. Bpm inteiro!"]
	quest.7A615E2A152917AD.title: "&zNúcleo de Arco-íris"
	quest.7A873E48E38B5C0E.quest_desc: ["As &8Máquinas de Aço&r usam o dobro de vapor comparadas às de &6Bronze&r, mas compensam com o dobro de velocidade."]
	quest.7A873E48E38B5C0E.title: "&fA Era do &7Aço"
	quest.7A89560F303A8BE6.quest_subtitle: "Nível: &63"
	quest.7A979BEB20C9591E.quest_desc: ["Pó de Flux pode ser automatizado usando &6Productive Bees&r!\\n\\nOvos de Geração de Abelha de Redstone podem ser convertidos em Ovos de Geração de Abelha de Pó de Flux usando uma Abelha de Obsidiana."]
	quest.7A979BEB20C9591E.title: "Pó de Flux Automatizado"
	quest.7A9AE63998BB41FF.quest_desc: [
		"Para determinar quando o &9Gerador&r vai gerar, ele escolhe um número aleatório entre o atraso de geração máximo e mínimo.\\n"
		"O Mínimo pode ser tão baixo quanto &620&r e tão alto quanto &632.767&r.\\n"
		"Cada pedaço de açúcar modifica o atraso mínimo para cima ou para baixo em &610&r."
	]
	quest.7A9AE63998BB41FF.title: "&fAtraso Mínimo de Geração"
	quest.7AB2FECE47F558F8.quest_desc: ["Stellagmite pode ser encontrada no subsolo na Starlight. \\n\\nFunciona como uma Pedra normal, podendo ser transformada em outros Blocos. \\n\\nSua versão Derretida funciona como um Bloco de Magma normal!"]
	quest.7AB52F600829F468.quest_desc: ["De um dos streamers de &2&lMinecraft&r mais conhecidos para outro, agora é hora de enfrentar o &b&lChosen Architect&r. \\n\\nNão deixe que todos esses sentimentos de amor e nostalgia por seus vídeos e Modpacks o impeçam de derrotá-lo. \\n\\n&cPokémon&r vem antes do amor, você já deveria saber disso a esta altura!"]
	quest.7AB52F600829F468.title: "&b&lChosen Architect"
	quest.7AD9DF3FFCB03495.quest_subtitle: "Nível: &a2"
	quest.7ADE214373DE135F.quest_subtitle: "Nível: &63"
	quest.7ADE27F9398D97F1.quest_desc: ["Esta não é diferente, por que você está verificando?"]
	quest.7ADE27F9398D97F1.quest_subtitle: "10"
	quest.7ADE27F9398D97F1.title: "Armadura de Abelha 2"
	quest.7AE1459B0B862737.quest_subtitle: "Você apenas o cria"
	quest.7AE1459B0B862737.title: "&fAbelha do Tempo"
	quest.7AE3C8134F5ED726.quest_desc: ["Aumenta o tamanho da pilha na Mochila em 16."]
	quest.7AE3C8134F5ED726.title: "&dMelhoria de Pilha Nível 4"
	quest.7AE502EDB73BD57A.quest_desc: ["O &4&lTriturador&r faz o que o nome sugere! Assim como todos os outros &4Trituradores&r de Mods... \\n\\nPodemos obter Pó de barras, &7Pedregulho&r de &7Pedra&r, e &2Biocombustível&r de &2Plantas&r! \\n\\nPó será necessário para muitas Receitas, então você definitivamente precisará disso. Especialmente para fazer &8Melhorias&r!"]
	quest.7AE502EDB73BD57A.quest_subtitle: "Ele Tritura Coisas."
	quest.7AE502EDB73BD57A.title: "&4&lTriturador"
	quest.7AE85F4FF4DDF4F2.quest_desc: ["O Moinho de Vento é outra opção que podemos usar com o Dínamo Cinético! \\n\\nEles começarão a se mover automaticamente e com sua velocidade obtemos Energia, então mais velocidade, mais Energia. \\n\\nComo conseguimos velocidade? Bem, para começar, ele precisa de espaço à sua frente para funcionar. Quanto menos blocos à sua frente, mais rápido ele vai! \\n\\nOutro fator na velocidade são as Velas do Moinho de Vento. Você pode adicionar 8 Velas do Moinho de Vento no total Clicando com o Botão Direito no Bloco do Moinho de Vento do meio com as Velas na mão."]
	quest.7AED8FD7FB023AD8.quest_desc: ["Para energizar &4&lO Harbinger&r, você precisará de uma Estrela do Nether, que você obtém ao matar o Wither. \\n\\nÉ uma mecânica &2&lVanilla&r que eu não deveria ter que explicar. \\n\\nAlém disso, está no Capítulo 1."]
	quest.7AED8FD7FB023AD8.quest_subtitle: "Energizando O Harbinger"
	quest.7AED8FD7FB023AD8.title: "Estrela do Nether"
	quest.7AEE4BE3AB41ED3E.quest_desc: ["Basta combinar uma &bPeitoral de Ignitium&r com um Elitro... simples assim!"]
	quest.7AEE4BE3AB41ED3E.title: "&bPeitoral de Ignitium com Elitro"
	quest.7AEFF81E7C8CF300.quest_desc: ["Usar Shift + Clique com o Botão Direito ao segurar uma ferramenta ou varinha JDT abrirá o menu de configuração onde o jogador pode configurar e alternar habilidades."]
	quest.7AF6C95816E82861.quest_desc: ["&#5B75D4Reagindo Quimicamente&r o &#8F49C4Deutério&r com &#AABBFAOxigênio&r nos dará &#9C51DBÁgua Pesada&r. Isso pode ser colocado de volta no &#45BF56Reator&r."]
	quest.7B0764DDE94E73D0.quest_desc: ["Em &2&lReatores&r maiores, precisaremos de um sistema de segurança mais avançado. \\nPara este, nosso &2&lReator&r precisará ter pelo menos 5 Blocos de largura. Isso dá 3 Blocos de largura para nossos 2 &2FRLA&r. \\n\\nColoque 1 de nossos &2FRLA&r no &2&lReator&r e configure-o para Temperatura Alta ou Dano Crítico. Em seguida, coloque o segundo a pelo menos 1 Bloco de distância, no mesmo Nível Y. O segundo precisará ser configurado para Ativação. \\n\\nAgora, vamos usar um pouco de &4Redstone&r! \\n\\nColoque um &4Repetidor de Redstone&r virado para fora do primeiro &2FRLA&r. Então, para onde o &4Repetidor&r está virado, coloque um Bloco que possa transmitir &4Redstone&r. \\n\\nNesse Bloco, coloque uma &4Tocha de Redstone&r na direção do segundo &2FRLA&r. \\n\\nDepois disso, coloque &4Pó de Redstone&r ao lado da &4Tocha&r, no mesmo Nível X/Z do segundo &2FRLA&r. E por último, coloque um segundo &4Repetidor de Redstone&r indo do &4Pó de Redstone&r e para dentro do segundo &2FRLA&r."]
	quest.7B0764DDE94E73D0.title: "Sistema de Segurança Avançado"
	quest.7B0CE182D3FE3035.quest_desc: [
		"Cansado de viajar por milhares de blocos atrás daquelas &eFlores&r específica para um Corante ou para suas Abelhas? \\n"
		"Seus problemas acabaram!"
		""
		"Com o poder do &cMystical Agriculture&f, agora você pode &aFabricar&r as &aFlores&r que precisa no conforto da sua base."
		""
		"Procure por elas no &eJEI&f para descobrir todas as receitas e dar adeus à jardinagem de exploração!"
	]
	quest.7B0CE182D3FE3035.quest_subtitle: "2 flores altas podem ser criadas com Essência do MA"
	quest.7B0CE182D3FE3035.title: "&fFlores Fabricáveis"
	quest.7B0DFA55B4D8B16D.quest_desc: [
		"&a&lTeletransportadores&r nos permitirão Teleportar para qualquer lugar em qualquer Dimensão, desde que a &5Máquina&r seja feita e &aEnergizada&r! \\n\\nAgora, como a fazemos e a energizamos? \\n\\nPrimeiro, para fazer o &a&lTeletransportador&r, precisaremos de 1 &aBloco de Teletransporte&f e 9 &aArmações de Teletransporte&r. \\n\\nO &aBloco de Teletransporte&r é o &aControlador&r principal do &a&lTeletransportador&r. É o Bloco que precisará de &aEnergia&r e, uma vez &aEnergizado&r, podemos abri-lo. Aqui podemos definir uma Rede semelhante ao &5Entreleportador Quântico&r, digite um nome e clique na Marca de Verificação para criar a Rede! \\n\\nAgora, quando outras &a&lEstruturas de Teletransporte&r ou &aBlocos de Teletransporte&r forem definidos para essa Rede (clicando na Rede nomeada em sua GUI), você pode usar o &a&lTeletransportador&r para, obviamente, se Teleportar para os outros &a&lTeletransportadores&r na mesma Rede. \\n\\nAgora sobre fazer a &a&lEstrutura de Teletransporte&r. Coloque uma &aArmação de Teletransporte&r em cada lado do &aBloco de Teletransporte&r. Acima deles, coloque mais 3 para fazer 4 Blocos de altura. Com 2 Blocos de espaço acima do &aBloco de Teletransporte&r, você pode colocar nossas últimas &aArmações de Teletransporte&r. \\n\\nAgora, quando Energizado e configurado, o &a&lTeletransportador&r estará pronto e você poderá atravessar qualquer portal colorido que apareceu! \\n\\n(Você pode mudar a Cor de cada um na INTERFACE do &a&lTeletransportador&r!)"
		"{@pagebreak}"
		"{image:atm:textures/questpics/mek/meka_portal1.png width:200 height:75 align:center}"
		"Coloque o &aBloco de Teletransporte&r com 2 &aArmações de Teletransporte&r ao lado dele."
		"{image:atm:textures/questpics/mek/meka_portal2.png width:150 height:125 align:center}"
		"Agora coloque &aArmações de Teletransporte&r sobre as anteriores."
		"{image:atm:textures/questpics/mek/meka_portal3.png width:100 height:125 align:center}"
		"Repita."
		"{image:atm:textures/questpics/mek/meka_portal4.png width:100 height:140 align:center}"
		"Agora, precisaremos de uma fileira inteira de &aArmações de Teletransporte&r para o topo."
		"{image:atm:textures/questpics/mek/meka_portal5.png width:110 height:150 align:center}"
		"Quando tudo estiver pronto, o Portal de sua escolha deverá aparecer assim!"
	]
	quest.7B0DFA55B4D8B16D.quest_subtitle: "Teletransporte no seu Melhor"
	quest.7B0DFA55B4D8B16D.title: "Portais Personalizados!"
	quest.7B1693793419B769.quest_subtitle: "Tília Prateada + Cerejeira"
	quest.7B1818D2C5C2BB18.quest_desc: ["A Picareta do Soulstrider pode ser usada para \"minerar em veia\" pedaços de minério."]
	quest.7B1818D2C5C2BB18.quest_subtitle: "Nível: &e5"
	quest.7B2008977702D0C8.quest_desc: ["Ao criar pressão em um Air Compressor, se você não tiver para onde a pressão ir, ela simplesmente desaparecerá. Certifique-se de ter para onde a pressão ir antes de criar alguma."]
	quest.7B2008977702D0C8.quest_subtitle: "O que aconteceu com RF ou FE?"
	quest.7B3613C01F0B1373.quest_desc: [
		"Para combinar &3Vibranium&r e &6Allthemodium&r, precisaremos nos aventurar em &l&cPowah&r! \\n\\nColoque o Orbe Energizante e, em seguida, coloque as Varas Energizantes voltadas para ele. As Varas Energizantes precisam ser colocadas em uma Fonte de Energia e enviarão Energia para o Orbe. A quantidade que cada uma retém e envia é determinada pelo Nível. \\n\\nColoque as Barras, 2 Corações de Piglich e um Bloco Comprimido de Cristais de Nitro X1 no Orbe (a ordem não importa). Então, quando 1 Bilhão de FE for colocado no Orbe através das Varas, estará pronto!\\n"
		"{ \"text\": \"LINHA DE MISSÕES POWAH\", \"color\": \"#55FF55\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"2A6EBEEBAB882679\" } }"
	]
	quest.7B385FD1CBE02C85.quest_desc: ["Se estivermos usando &9Água&r como &bRefrigerador&r, obteremos Vapor como subproduto! \\n\\nE agora, o que fazemos com ele?"]
	quest.7B385FD1CBE02C85.title: "Vapor"
	quest.7B3920DE6306A94A.quest_subtitle: "Mandarin + Kumquat"
	quest.7B40A9DAA119DE59.quest_subtitle: "Crystalline + Neon Cuckoo"
	quest.7B40A9DAA119DE59.title: "Abelha Menril"
	quest.7B447E986493AD6B.quest_desc: ["&7Óleo de Creosoto&r é um subproduto do &lForno de Coque&r. \\n\\nSeu uso principal será para fazer Madeira Tratada, um Bloco de Construção essencial do &8&lIE&r. \\n\\nVocê também precisará dele para um Fluido diferente mais tarde, nos preocuparemos com isso quando chegarmos lá."]
	quest.7B447E986493AD6B.title: "&7Óleo de Creosoto"
	quest.7B4AAC741F0A6073.quest_desc: ["Todo reator precisa de &9Varas de Controle do Reator&r e &9Varas de Combustível&r. Elas controlam como o combustível é inserido no reator.\\n\\nAs Varas de Controle são colocadas na face superior do reator. Você também pode ter mais de uma por reator, mas deve ter pelo menos 1. Normalmente, quanto mais você tiver, mais combustível o reator pode usar e queimar. Isso pode significar mais energia geral, mas ao custo de taxas de queima mais altas, dependendo da configuração do seu reator.\\n\\nPara cada Vara de Controle, você precisará de Varas de Combustível suficientes para se estender até a base do reator. Por exemplo, se seu reator tiver 5 blocos de altura, você precisará de 3 Varas de Combustível se estendendo de cada Vara de Controle.\\n\\nSe você clicar com o botão direito em uma Vara de Controle, poderá controlar quanto combustível é queimado no reator, inserindo ou retraindo as varas de combustível. Quanto mais você estender as varas, menos combustível será queimado."]
	quest.7B4AAC741F0A6073.title: "Varas de Controle do Reator"
	quest.7B4AF35313D7D779.quest_subtitle: "Nível: &64"
	quest.7B4AF35313D7D779.title: "&6Chassi de Máquina Supremo"
	quest.7B500E0577BDFF8F.quest_desc: ["&6Bronze&r é uma combinação de &6Cobre&r e Estanho. \\n\\nExistem dezenas de maneiras diferentes de fazer a liga, não vou te dizer a maneira certa de fazer isso."]
	quest.7B500E0577BDFF8F.quest_subtitle: "18"
	quest.7B500E0577BDFF8F.title: "&6Armadura de Bronze"
	quest.7B5A0BFD47D96BDE.quest_desc: ["Usado para capturar abelhas que estão voando ao redor.\\n\\nVocê pode usar uma &aMelhoria de Filtro&r para filtrar quais abelhas você quer capturar, bem como uma Melhoria de Abelha Bebê para capturar apenas abelhas bebês."]
	quest.7B5A0BFD47D96BDE.quest_subtitle: "Capture Abelhas"
	quest.7B5A0BFD47D96BDE.title: "&fApanhador"
	quest.7B5D34650BBD97D9.quest_desc: ["Muito raramente na Dimensão da Luz Estrelar, uma Chuva de Meteoros pode ocorrer. \\n\\nA maioria das vezes os Meteoros são pequenos e desaparecem antes de atingir o chão. \\n\\nMas alguns são maiores e sobrevivem, lá você encontrará Minério de Aethersent!"]
	quest.7B72CF322A3C985D.quest_desc: ["Uma &8Abelha Obsidiana&r polinizando um &4Ovo de Gerador de Abelha de Redstone&r irá convertê-lo em um &2Ovo de Gerador de Abelha de Pó de Flux&r."]
	quest.7B72CF322A3C985D.title: "&fAbelha de Flux"
	quest.7B758074DB4BD138.quest_desc: ["A &cPok&fe&cdex&r é uma ferramenta muito importante. Funciona como um Glossário para cada &cPokemon&r no jogo! \\n\\nSe um &cPokemon&r é enfrentado em Batalha, seu Nome, Imagem, Animação e Som aparecerão. \\n\\nSe um &cPokemon&r é Capturado, você obterá tudo isso mais: Tipo, Entrada, Habilidade, Altura e Peso, Atributos Base e Drops. \\n\\nHá uma Barra de Pesquisa onde você pode pesquisar por Nome, Habilidade e Drops. Então, se estiver configurado para Drops, você pode procurar por Bolas de Argila para ver qual &cPokemon&r Dropa isso ao Morrer. Ou se você quiser a Habilidade Identificar, adicione isso com o Filtro de Habilidade para ver qual &cPokemon&r tem Identificar."]
	quest.7B758074DB4BD138.title: "&cPok&fe&cdex"
	quest.7B76EC62E3F7E12C.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_aethersent.png width:100 height:150 align:center}"]
	quest.7B76EC62E3F7E12C.title: "&5Aethersent&r"
	quest.7B7D1F0CB326B28F.quest_desc: ["A &bPorta ME E/S&f permite que o conteúdo do armazenamento de uma Rede ME seja rapidamente rearranjado entre diferentes mídias de armazenamento, como células ME e contêineres externos conectados a Pontos de armazenamento.\\n\\nQuando uma célula é inserida em um slot de entrada à esquerda, a Porta de E/S pode ser alternada para esvaziar a célula em outros ME Storages ou preencher a célula (idealmente, particionada) com certos itens espalhados por outros armazenamentos."]
	quest.7B7D1F0CB326B28F.quest_subtitle: "Desfragmentação"
	quest.7B8811333BF8FAD4.quest_desc: ["O &6Cobre&r é um &7Minério&r como o Ferro. Apenas mais barato e mais comum! \\n\\nVocê precisará de uma &7Picareta de Pedra&r para minerá-lo. \\n\\nEu apenas o coloquei aqui em vez de depois da &7Picareta de Pedra&r por propósitos estéticos."]
	quest.7B8811333BF8FAD4.title: "&6Era do Cobre"
	quest.7B9486981786AC47.quest_desc: [
		"&lTipo de Habilidade:&r Ativa"
		""
		"&lFunção da Habilidade:&r"
		""
		"Remove permanentemente a IA de mobs próximos. Devido ao custo de poder, só pode afetar no máximo cinco mobs por ativação. Possui um tempo de recarga muito longo."
	]
	quest.7B9672C4FCFFB887.quest_desc: ["Esses &9Modelos&r podem ser criados e, nossa, como são baratos! \\n\\nSinais de Aviso são decorações muito simples que podemos fazer com &7Chapas de Metal&r, Corantes e este &9Modelo&r."]
	quest.7B9672C4FCFFB887.title: "&9Modelos de Sinais de Aviso "
	quest.7B9F5EEC76FDD0D4.title: "Módulo de Dano Dracônico"
	quest.7BC289DEF023FEAA.quest_subtitle: "Nível: &63"
	quest.7BC8F50A89A3BE1A.quest_desc: ["Estes são apenas usados para Conectar &cNós de Laser&r uns aos outros e a Conectores. Não são muito importantes, eu só queria manter o tema das Chaves Inglesas. \\n\\nFunciona como uma Chave Inglesa para outras Configurações!"]
	quest.7BCD4A425CF6199B.quest_desc: ["Depois de matar a Cabra da Misericórdia invocada do &9Xeovrenth Invocada&r, você se encontrará um &#4E2C00Essência da Crueldade&r mais rico. Combine isso com alguns &#4E2C00Grãos de Cacau&r para criar Giz &#4E2C00Marrom&r."]
	quest.7BCD4A425CF6199B.title: "&#4E2C00Giz Marrom"
	quest.7BCE96070C36D547.quest_subtitle: "&f7.5 &cde Dano de Ataque"
	quest.7BFC24607189B6D0.quest_desc: ["Faz você nadar mais rápido."]
	quest.7BFC24607189B6D0.quest_subtitle: "Máx: 1"
	quest.7BFE7DAF18981843.quest_subtitle: "Necessário para receitas de Broca"
	quest.7BFF76B27D398E62.quest_desc: ["Com uma seleção de itens muito estranha, podemos Fabricar o &8Carimbo de Borracha&r! \\n\\nCuriosamente, você não precisa do &6&lCreate&r para fabricá-lo, apenas para usá-lo. \\n\\nEu me pergunto qual é o símbolo que estamos carimbando nas coisas..."]
	quest.7C07D6A33F7ADB02.quest_desc: [
		"Esta é uma melhoria de Mochila para que você possa colocar sua Mochila na sua Mochila."
		""
		"Assim você pode ter sua Mochila na sua Mochila para quando precisar da sua Mochila na sua Mochila."
	]
	quest.7C07D6A33F7ADB02.quest_subtitle: "Mochilas nas suas Mochilas?"
	quest.7C0F7A1B3AB9A1A1.quest_subtitle: "Mais Opções de Filtragem"
	quest.7C0F7A1B3AB9A1A1.title: "&eMelhoria de Reabastecimento Avançada"
	quest.7C112EF6EA2BB232.quest_desc: [
		"Ainda sem aumento de nível, mas ei, você derrotou o &5Campeão&r!"
		""
		"Encontrado no último andar da &cLiga Kanto&r."
		""
		"&5Campeão Terry&r é a última pessoa a derrotar na &4&oSérie&r, mas isso não é tudo para a Região de Kanto..."
	]
	quest.7C112EF6EA2BB232.title: "&5Campeão Terry"
	quest.7C169A4A39F37FAC.quest_desc: ["Com a Colmeia vanilla, usaremos isso para criar uma &eColmeia Avançada&r. Pode ser de Carvalho ou qualquer tipo de madeira.\\n\\nAs abelhas entrarão e sairão delas e deixarão Favos de Mel no inventário. Você também pode inserir garrafas de vidro para obter Garrafas de Mel.\\n\\nPrecisaremos de muitos Favos de Mel para guloseimas!"]
	quest.7C169A4A39F37FAC.quest_subtitle: "Chega de tosquiar."
	quest.7C169A4A39F37FAC.title: "Colmeia Avançada"
	quest.7C1D407CF67786F6.quest_desc: ["&d&lArs Elemental&r Armadura de Ar!"]
	quest.7C1D407CF67786F6.quest_subtitle: "15"
	quest.7C1D407CF67786F6.title: "&fTraje de Aethermante"
	quest.7C2ED69E07988DF4.quest_desc: ["A Cadeira original do &2&lMinecraft&r, as escadas. \\n\\nBem-vindo ao &2&lMinecraft&r Modificado, temos muito mais do que apenas escadas para decoração. \\n\\nExistem dezenas de mods que adicionam decoração e ainda mais que adicionam itens que podem ser usados para decoração!"]
	quest.7C2ED69E07988DF4.title: "Decoração!"
	quest.7C3D763CF22D167A.quest_desc: ["O Carregador da Luz Estrelar pode \"encantar\" materiais com o encantamento \"Carregado de Estrelas\".\\n\\nUma estrutura deve ser construída com o Carregador da Luz Estrelar no meio, à vista do céu noturno. Ele só ganha Poder da Luz Estrelar durante a noite.\\n\\nA estrutura do Carregador deve ser colocada no meio de uma estrutura 7x7, com um Pilar em cada canto. Cada pilar deve ter uma \"Tampa do Carregador da Luz Estrelar\".\\n\\nEle também requer um catalisador de carregador por material."]
	quest.7C3D763CF22D167A.quest_subtitle: "\"Encantando\" Materiais"
	quest.7C3D763CF22D167A.title: "&dCarregador da Luz Estrelar"
	quest.7C3F65B5DAC7E57B.quest_desc: [" Nas profundezas do &eEnd&r, escondido entre ruínas antigas, jaz uma &6relíquia&r tecida da &9própria noite&r... o &5Manto da Meia-noite&r. \\n\\nEste manto muda com o &bcéu&r acima, tornando-se mais forte conforme a &9Lua&r atinge seu pico, e desaparecendo na sombra quando a escuridão assume o controle. \\n\\n- &lPossui 4 habilidades:&r \\n\\n 1. &dFase Lunar&r: \\n Seu &cdano&r e &2velocidade de ataque&r são bastante aumentados, mas seu &cpoder&r depende de quão próxima a &9Lua&r está de sua fase cheia. \\n\\n 2. &8Sombra&r: \\n Em &obaixa luz&r, o &omanto envolve&r você em &8escuridão&r, concedendo &linvisibilidade&r. Sair das &8sombras enfraquece&r este efeito por um &2&ocurto período&r&r, e os &cinimigos&r devem perder você de vista antes que ele possa ser usado novamente. \\n\\n 3. &7Constelação&r: \\n Receber &cdano&r pode invocar &zestrelas&r errantes ao seu redor. Estas &eestrelas&r podem se conectar em constelações, perturbando &cinimigos&r que as cruzarem, ou &cexplodir&r quando tocadas, causando &cdano&r a tudo por perto. \\n\\n 4. &eChuva de Estrelas&r: \\n Quando você atinge seus &cinimigos&r, há uma chance de invocar uma estrela cadente, criando uma &eonda de choque&r no impacto que causa &cdano&r e atordoa brevemente os alvos. \\n\\n- Uma &6relíquia&r ligada aos céus... e à &8escuridão&r entre eles."]
	quest.7C3F65B5DAC7E57B.quest_subtitle: "Nem todo poder vem da luz..."
	quest.7C3F65B5DAC7E57B.title: "&5Manto da Meia-noite"
	quest.7C4D8AA107780795.quest_desc: ["Usando o &aFluidificador&r, podemos combinar &dBlutonium&r com &eYellorium&r para criar &2Verderium.\\n\\nQuando usado como combustível em um reator, o &2Verderium&r produz &cRossinita&r como reagente. Nós precisamos disso!\\n\\nPara usar o &2Verderium&r como combustível, você precisará fazer &cPortas de Injeção de Combustível&r para o seu reator.\\n\\nNota: Você pode precisar esvaziar o combustível atualmente em seu reator, ou fazer um novo reator para este propósito."]
	quest.7C4D8AA107780795.title: "Rossinita"
	quest.7C4E4793DA887DE4.quest_desc: ["Baseado no mod original &eBig Reactors&r, &aExtreme Reactors&r permite que você construa Reatores multibloco personalizáveis!\\n\\nO elemento principal é, claro, o Urânio. Você precisará disso e de muito carvão e ferro para começar a construir.\\n\\nSe você se perder no caminho, consulte &aO Livro Extremo&r para obter ajuda!"]
	quest.7C4E4793DA887DE4.quest_subtitle: "Não é comestível... confie em mim"
	quest.7C4E4793DA887DE4.title: "Bem-vindo ao &9Extreme Reactors&r!"
	quest.7C54581562D2EA75.quest_desc: ["Módulos de Velocidade são divertidos, eles funcionam em quase tudo e os tornam mais rápidos! Espadas balançam mais rápido, Picaretas mineram mais rápido, Machados cortam mais rápido, Arcos disparam mais rápido, e Peitorais te deixam mais rápido. Quanto melhor o Módulo de Velocidade, mais rápido eles vão! (A propósito, bom momento para mencionar que a maioria dos atributos se acumula. 2 Módulos de Velocidade Básicos aumentam a Velocidade em 20%% então!)"]
	quest.7C54581562D2EA75.title: "Módulo de Velocidade Básico"
	quest.7C651B90A738323E.quest_desc: ["Não deve ser confundida com a Abelha Supremium Desperta."]
	quest.7C651B90A738323E.quest_subtitle: "Dracônica Fusão de Criação"
	quest.7C651B90A738323E.title: "&6Abelha Desperta"
	quest.7C687DCF71D77761.quest_desc: ["&c&lAvançado&r é a Melhoria para &a&lBásico&r. \\n\\nAs Máquinas &c&lAvançadas&r comportarão mais &eItens&f, moverão mais &eItens&r e terão mais Slots do que o &a&lTier Básico&r. \\n\\nAs &c&lAvançadas&r são feitas de &cLigas Infundidas&f, &cCircuito de Controle Avançado&f e geralmente &7Ósmio&r! \\n\\n&cCircuitos de Controle Avançados&r são feitos de 2 &cLigas Infundidas&r e um &aCircuito de Controle Básico&r."]
	quest.7C687DCF71D77761.title: "&c&lTier Avançado"
	quest.7C73740F1B515F2C.quest_desc: ["O &#C452C4Pó de Tungstênio&r precisa ser reduzido para uma variante muito menor para permitir seu processamento."]
	quest.7C758209D06ED0E3.quest_desc: ["Ao combinar uma &4Estante Infernal Infundida&r com um pouco de &ePedra Luminosa&r, podemos fazer &4Estantes Infernais Luminosos&r! \\n\\nElas têm a mesma &aEterna&r e &cQuanta&r, mas dão &53% de Arcana&r. \\n\\nIsso será útil em &d&lInfusões&r posteriores, como se quiséssemos usar 12 delas para &d&lInfusionar&r uma &9Estante ProfundaDormente&f em uma &9Deepshelf&r!"]
	quest.7C758209D06ED0E3.title: "&4Estante Infernal Luminoso"
	quest.7C7BD54624ED9AC2.quest_desc: ["Literalmente, apenas Voo Criativo. \\n\\nVocê não pode usar isso com a &cUnidade de Jetpack &7 e sim, isso usará &aEnergia&r para Voar! \\n\\nNas configurações, você pode aumentar a velocidade do seu voo também."]
	quest.7C7BD54624ED9AC2.quest_subtitle: "Armadura Corporal"
	quest.7C7BD54624ED9AC2.title: "&dUnidade de Modulação Gravitacional"
	quest.7C7C0D3D7FCB0297.quest_desc: ["Pode ser encontrado em estruturas na &6&lBumblezone&r ou trocado com a &5Rainha Abelha&r! \\n\\n&6A&8b&6e&8l&6h&8a&6s&r têm uma maneira bastante interessante de encontrar e se comunicar umas com as outras. Eu não sei como elas fazem isso, então vou apenas supor que suas Antenas dão e recebem sinais de rádio. \\n\\nEnquanto usa o Elmo de Abelha Sem Ferrão, você pode Agachar para destacar todas as &6A&8b&6e&8l&6h&8a&6s&r ao seu redor. \\n\\nAlém disso, enquanto o usa, veneno e náusea desaparecerão mais rápido."]
	quest.7C848C7011726470.quest_desc: ["O &cOlho Monstruoso&r o levará ao &cFerreiro de Almas&r para lutar contra a &c&lMonstruosidade de Netherita&r."]
	quest.7C848C7011726470.title: "&cOlho Monstruoso&r"
	quest.7C8CDD259495A31A.quest_desc: ["&eTúneis&r, no nível mais básico, cobrirão suas &eEsteiras&r. Isso fará com que os &eItens&r não possam ser pegos, e com sorte os Mobs não sairão. \\n\\nSe você colocar outra &eEsteira&r movendo-se perpendicularmente à &eEsteira&r em que o &eTúnel&r está, o &eTúnel&r filtrará 1 &eItem&r da Pilha de &eItens&r para a &eEsteira&r perpendicular, enquanto deixa o resto dos &eItens&r na primeira &eEsteira&r. \\n\\nSe houver apenas 1 &eItem&r, ele se moverá através do &eTúnel&r normalmente."]
	quest.7C8CDD259495A31A.title: "&eTúnel de Andesito"
	quest.7C90008081DEBECA.quest_desc: ["Você tem &eFerramentas&r e tem &aGemas&r... então como as combinamos? \\n\\nPrimeiro, certifique-se de que sua &eFerramenta&r tenha um &9Encaixe&r aberto. (Para mais informações sobre &9Encaixes&r, verifique a seção de Símbolos). \\n\\nSe houver um aberto, você pode combinar sua &eFerramenta&r e &aGema&r em uma &8&lMesa de Ferraria&r. \\n\\nSe você não estiver satisfeito com suas &aGemas&r atuais, talvez precise de uma Mesa diferente!"]
	quest.7C90008081DEBECA.title: "Aplicando &aGemas&r (e outros)"
	quest.7C9154EF6068BE27.quest_desc: ["Tecnicamente, você também pode usar o Triturador para transformar a &6&lEstrela ATM&r em 5 &6Fragmentos de Estrela&r... \\n\\nMas você precisará de 262 para fazer uma nova &6&lEstrela&r... \\n\\nEntão, por que você faria isso?"]
	quest.7C9154EF6068BE27.title: "Mas por quê?"
	quest.7C94F6AE2A793858.title: "&eParte de Armazenamento de 1024k"
	quest.7C9D9D1C054874A7.quest_desc: ["Sempre quis os &5Encantamentos&r mais perfeitos? Tipo, todos os status no máximo, todos os bons &5Encantamentos&r disponíveis? Então, você precisará destes! \\n\\nPrimeiro, são as 5 &9Estante de Livros Sculk Tocadas pela Alma&r e 5 &9Estante de Livros Sculk Ecoantes&r. Elas nos darão toda a &cQuanta&r e &5Arcana&r de que precisamos! \\n\\nEm seguida, é a &dEstante Profunda Dracônica&r que nos dará &a100 de Eterna&r, tanto em quantidade de &aEterna&r quanto no nível máximo. \\n\\nTerceiro, é a &6Estante de Livros de Estabilidade Encapsulada em Geodo&r, isso fará com que a &cQuanta&r não nos apunhale pelas costas com &5Encantamentos&r terríveis! \\n\\nPor último, é opcional, mas você deve adicioná-la, a &6Estante Profundade Tesouros Arcanos&r. Essa &7Estante de Livros&r nos permitirá obter &5Encantamentos&r que normalmente não conseguiríamos, como &5Reparo&r!"]
	quest.7C9D9D1C054874A7.title: "&6&lMelhor configuração de Encantamento"
	quest.7CA60DC31447E57A.quest_subtitle: "&f7 &cde Dano de Ataque"
	quest.7CB03F92F9ECEFFB.quest_desc: ["Felizmente, o &6&lApotheosis&r tornou a remoção de &9Encaixes&r das &eFerramentas&r muito mais fácil! \\n\\nAgora, em vez de ter que escolher entre salvar a &eFerramenta&r ou a &aGema&r, você pode manter ambos. \\n\\nUse o &aSímbolo da Retirada&r com uma &eFerramenta com Afixo&r em uma &8&lMesa de Ferraria&r e você separará a &aGema&r dela."]
	quest.7CB03F92F9ECEFFB.title: "&aSímbolo da Retirada"
	quest.7CB4D47ABC295B92.quest_desc: ["Ele destila poções. Muito parecido com um Suporte de Poções padrão, requer Pó de Blaze como combustível e usa garrafas. Ao contrário de um Suporte de Poções, no entanto, ele pode preencher automaticamente essas garrafas com água.\\n\\nAo contrário de outras missões onde dou uma breve visão geral da máquina, fornecerei uma configuração em outra missão para automatizar esta máquina, pois ela é bastante complicada e não intuitiva em algumas áreas."]
	quest.7CBAA67204CC258C.quest_desc: ["Não, o &9&lWarden&r não usa Espadas e Machados. Mas nós podemos! \\n\\nAmbos, a &9Espada do Warden &fe o &9Machado&r, são aprimoramentos de suas &cversões de Netherite&r com um &9Fragmento de Eco Reforçado &fe um &9Molde de Aprimoramento do Warden&r. \\n\\nCada um tem 1 &4Coração&r de Dano a mais e ainda mais Durabilidade! \\n\\nSim, o Machado ainda pode derrubar Árvores eficientemente."]
	quest.7CBAA67204CC258C.title: "&3Armas do Warden&r"
	quest.7CBAD1047B087803.quest_desc: [
		"Agora que você tem os &egrumos&r, usar um addon de fluido em uma centrífuga permitirá que você insira &aÁcido Sulfúrico&r nela. Quando &egrumos&r são processados com este ácido, você obterá gemas."
		""
		"Alternativamente, você pode usar &9Água&r para um rendimento menor."
		""
		"&l&o&nNota&r"
		""
		"Atualmente, algumas receitas que produzem pós ou pepitas estão quebradas."
	]
	quest.7CBAD1047B087803.quest_subtitle: "Centrifugar um grumo me dá gemas....?"
	quest.7CBAD1047B087803.title: "Girando até virar gemas"
	quest.7CBEBBCB9D95D11A.quest_desc: ["O &5Ovo Abissal&r também é um drop do &5&lLeviatã&r, porque aparentemente você matou uma grávida. \\n\\nColoque o &5Ovo&r no chão, então espere um pouco e você terá seu próprio bebê &5Leviatã&r. \\n\\nQuando ele chocar, você pode alimentá-lo com uma tonelada de Peixe Tropical para domá-lo. \\n\\nO &5bebê&r tem 1,200 &4Corações&r e pode se curar sendo alimentado com Peixe Tropical. \\n\\nUma vez domado, como o &eRemanescente Moderno&r, ele pode ser configurado com Shift + Clique com o Botão Direito para seguir, ficar ou vagar."]
	quest.7CBEBBCB9D95D11A.title: "Ovo Abissal"
	quest.7CC49360D07086B8.quest_desc: ["&o\"Usando Maquinaria Atômica altamente detalhada, podemos desmontar toda a Matéria ao nível molecular e mover essas moléculas através de comprimentos de onda específicos...\"&r Ah, qual é, isso é apenas Mágica! \\nCom 2 &5Entreleportador Quântico&r, podemos mover sem fio &eItens&f, &bFluidos&f, &cQuímicos&f, &6Calor&f e &aEnergia&r! \\n\\nPrimeiro, precisamos conectar os &5Entreleportador Quântico&r. Fazemos isso indo na Barra de Texto de um deles e digitando um nome de Rede. \\n\\nPode ser Números, Letras, Símbolos, qualquer coisa, apenas Digite e aperte o Botão de Verificação! Então, vá para o segundo &5Entreleportador Quântico&r e Clique no nome da Rede Definida. Agora eles estão conectados. \\n\\nDepois disso, conecte seus &bCanos&f, &cTubos&f, &aCabos&r, o que for, a um &5Entreleportador Quântico&r e coloque mais ou até mesmo uma &5Máquina&r no outro. \\n\\nQuando tudo estiver pronto, mude as Configurações Laterais para realmente mover nossas coisas. Não se esqueça de definir a Ejeção Automática!"]
	quest.7CC49360D07086B8.quest_subtitle: "Energia, Gases, Fluidos, Tudo Sem Fio."
	quest.7CC49360D07086B8.title: "&5Entreleportador Quântico"
	quest.7CC96CE9901F25BB.quest_desc: ["&l&5Forbidden and Arcanus&r é outro mod de magia, este girando em torno da estrutura Multibloco chamada Forja de Hefesto.\\n\\nPara fazê-la, siga as instruções na dica de ferramenta da forja! Uma vez feita, você pode alimentá-la com os 4 Materiais para energizar Rituais: Aureal, Almas, Sangue e Experiência.\\n\\nVocê também precisará atualizar a Forja através de Rituais (todos estes você pode encontrar no JEI)."]
	quest.7CD47C3C2F1223A1.quest_desc: [
		"Sem Aumento de Nível."
		""
		"O Item de Assinatura é Bolsa de Tinta."
	]
	quest.7CD47C3C2F1223A1.title: "&7Admin Shadow Marlon e Recruta"
	quest.7CE86300AF8E9BCA.quest_desc: ["Criar 8 dos mesmos Geradores juntos com um Fragmento de Eco os combina em 1 Gerador massivo! Funciona da mesma forma que 8 geradores regulares, mas ocupa apenas o espaço de 1."]
	quest.7CE86300AF8E9BCA.title: "8x Que negócio!"
	quest.7CF13A4941F608E5.quest_desc: ["De Vidro normal, a Vidro com Painéis, a até mesmo Mosaicos!"]
	quest.7CF13A4941F608E5.title: "&fVidro &l&bChipped"
	quest.7CFA92CC48D1E7E3.quest_subtitle: "Nível: &c5"
	quest.7CFEE836C68B3903.quest_subtitle: "&f7.5 &cde Dano de Ataque"
	quest.7D0AE6FCB0996218.quest_subtitle: "Teca + Ipê"
	quest.7D0F4EF83BA40D66.quest_desc: ["&nForte&r \\n\\n&9Dragão&r \\n&9Voador&r \\n&2Grama&r \\n&6Terra&r \\n\\n&nVulnerável&r \\n\\n&4Lutador&r \\n&cFogo&r \\n&6Pedra&r \\n&7Aço&r"]
	quest.7D0F4EF83BA40D66.title: "&bGelo"
	quest.7D159D333B2AC57E.quest_desc: [
		"500 Milhões de OP? Confere. Combustível? Confere. Calor a 2000 C? Confere. Apenas clique no botão de ativar e reze para que não entre em Colapso!"
		"{image:atm:textures/questpics/draconic/draconic_reactor_on_down.png width:200 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_reactor_on_up.png width:150 height:150 align:1}"
	]
	quest.7D159D333B2AC57E.quest_subtitle: "Agora nós rezamos e esperamos..."
	quest.7D159D333B2AC57E.title: "Ativando o Reator"
	quest.7D1A27CBF1508712.quest_desc: ["É um cubo, como todas as coisas devem ser."]
	quest.7D1A27CBF1508712.title: "&3Cubo Zygarde"
	quest.7D1D2A4E07E98709.quest_desc: ["Um simples quebrador de blocos que requer uma ferramenta para quebrar blocos."]
	quest.7D220876E8FF7AED.quest_desc: [
		"O &#65C2A6Desempacotador&r tem muitos usos, desde descompactar &#53E67BBlocos em Barras&r até &#53E67Breciclar partes&r de máquinas."
		""
		"&oVocê pode até conseguir Barras de Silício mais facilmente com ele.&r"
	]
	quest.7D220876E8FF7AED.title: "&fO &7Desempacotador"
	quest.7D279FC39DA5C630.quest_desc: ["Ainda não terminamos com nosso &cTrióxido de Enxofre&r! No entanto, precisaremos de um pouco de Vapor d'Água para processá-lo ainda mais. \\n\\nPara obter Vapor d'Água, podemos usar o &c&lCondensentrador Rotativo&r para transformar &9Água&r em Vapor d'Água! \\nMais &cInfusão&r! Combine nosso Vapor d'Água com nosso &cTrióxido de Enxofre&r para fazer &aÁcido Sulfúrico&r. \\n\\nBem, agora é um Ácido... mas não o correto... \\n\\nAh sim, precisaremos de &dFluorita&r, que podemos obter minerando minérios. Então, use a &3&lCâmara de Dissolução Química&r para diluir o &aÁcido Sulfúrico&r com &dFluorita&r para finalmente obter nosso &7Ácido Fluorídrico&r!"]
	quest.7D279FC39DA5C630.title: "&cTrióxido de Enxofre&r em &7Ácido Fluorídrico"
	quest.7D2F41DD9774DDA7.title: "Transportando itens"
	quest.7D359283625C1869.quest_desc: ["&4&lCataclysm&r é um Mod de aventura que se concentra em adicionar novos Chefes! E tudo que vem deles e ao redor deles! \\n\\nVocê encontrará as Estruturas por todo o &2&lMundo Superior&r, &4&lO Nether&r e &5&lO End&r. \\n\\nDentro haverá novos Mobs, Minichefes e Chefes muito difíceis. Você pode matá-los todos para obter novas Armas, Armaduras e Itens!"]
	quest.7D359283625C1869.title: "&4&lCataclysm"
	quest.7D40B80DBBC4E160.quest_desc: ["A Máquina de Laminação Manual será sua pequena máquina de criação para muitos materiais do railcraft! \\n\\nQuando você coloca a receita e ela pode fazer mais de 1, ela irá fabricar automaticamente enquanto você ainda estiver olhando para ela. Quando você sai da Máquina de Laminação enquanto ela está fabricando, ela abortará a fabricação e a colocará em seu inventário. \\n\\nVocê deve construir manualmente a última receita!"]
	quest.7D43016926E77150.title: "&9Armadura de Imperium&r"
	quest.7D52DD751DDADA1B.quest_desc: ["Os cabos básicos para transferir energia."]
	quest.7D57A14810BC0CBE.quest_desc: [
		"Assim que você usar as &bCinzas Ardentes&r no &bAltar da Chama&r, você obterá o &b&lIgnis&r. \\nEle tem 7.200 &4Corações&r e uma &bEspada &fe &bEscudo&r enormes. \\n\\nO &bEscudo&r bloqueará o dano que você causa e a &bEspada&r pode ser usada para fatiá-lo e esfaqueá-lo. Uma vez esfaqueado, você não pode se mover, apenas atacar.\\n\\nEle também pode pular em você, e quando o faz, ele bate seu &bEscudo&r no chão, criando uma Onda de Choque que lançará Blocos e você no Ar. Ele pode fazer o mesmo com sua &bEspada&r, só que sem a necessidade de pular.\\n\\nOutro ataque que ele tem são &bBolas de Fogo&r. Ele lançará 3 &bBolas de Fogo&r no Ar, e então elas serão enviadas voando em sua direção! Rebata-as de volta para ele como se fossem uma Bola de Fogo de Ghast. \\n\\nQuando você baixar a &4Saúde&r dele para cerca de 7.500 &4Corações&r, ele mudará de cor para uma &bcor Azul Claro&r. Agora ele atacará mais rápido, causará mais Dano e terá Roubo de Vida. \\n\\nSuas &bBolas de Fogo&r também não poderão ser refletidas e ele agora pode criar diferentes tipos de Ondas de Choque!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_ignis.png width:100 height:100 align:center}"
	]
	quest.7D57A14810BC0CBE.title: "&b&lIgnis&r"
	quest.7D67058592EE5958.quest_desc: ["O Canhão construirá as estruturas a partir de Esquemáticos, pegando materiais de baús próximos e usando pólvora como combustível."]
	quest.7D690A7D0FF6E328.title: "Catalisador de Niveladora Nível 3"
	quest.7D6B4AEF806AF62E.quest_desc: ["100% rápido demais! Tente não morrer!"]
	quest.7D6B4AEF806AF62E.quest_subtitle: "Máx: 1"
	quest.7D7983F39E6E818D.title: "Nível: &9Niotic"
	quest.7D7BD1458CF12021.quest_desc: ["É um Deserto, claro que há Cactos! \\n\\nOs Cactos, quando totalmente crescidos, podem dar Frutos no topo!"]
	quest.7D7DC3C695CD7236.quest_subtitle: "Tília Prateada + Abeto"
	quest.7D7E4C31DFE59E29.quest_desc: ["Estes Módulos são apenas para os Arcos do DE, ao contrário dos anteriores. O Módulo de Dano de Projétil aumenta o dano das Flechas disparadas pelo Arco. Alguns Módulos têm efeitos negativos, como estes que dão um pouco mais de Imprecisão aos Arcos. Todos eles podem se acumular!"]
	quest.7D7E4C31DFE59E29.title: "Módulo de Dano de Projétil Wyvern"
	quest.7D81F2381516204D.quest_subtitle: "Necessário para PCBs Acabados"
	quest.7D81F2381516204D.title: "Transistores"
	quest.7D88BBE64DC2A9D0.quest_desc: [
		"Sem Aumento de Nível... por que esta &4&oSérie&r dá a menor quantidade de Níveis?"
		""
		"O Item de Assinatura é Pedra do Crepúsculo."
	]
	quest.7D88BBE64DC2A9D0.title: "&7Ex-Admin Shadow Marlon"
	quest.7D972A3C4211EB26.quest_desc: ["&zCarvão de Arco-íris&r é obtido ao explodir uma &zFornalha de Arco-íris&r."]
	quest.7D972A3C4211EB26.title: "&zCarvão de Arco-íris"
	quest.7DA48EDCF28DBE03.quest_subtitle: "Ginkgo + Avelã"
	quest.7DA8ACE06DE8097F.quest_desc: ["&6Cobre&r é o Minério mais abundante no &2&lMinecraft&r e seu uso principal é para decoração. \\n\\nJá existem muitas variantes diferentes adicionadas pelo &2&lMinecraft&r, mas &l&bChipped&r não achou que era bom o suficiente! Então temos mais! \\n\\nAté variantes para as versões oxidadas. \\n\\nVocê pode fazer &aBlocos de Esmeralda&r falsos."]
	quest.7DA8ACE06DE8097F.title: "&6Cobre &l&bChipped"
	quest.7DABD82393713B5A.quest_desc: ["&c&lLuminax&r é um Mod muito simples. Você gosta de Luzes Coloridas? Você pode ter Luzes Coloridas. \\n\\nElas são todas de uma cor, sem Textura, e podem vir em diferentes Formas como Escadas ou Lajes ou até Chapas de Pressão! \\n\\nElas até funcionam com &l&cDy&6en&ea&ami&bcs&r!"]
	quest.7DABD82393713B5A.title: "&l&cLuminax"
	quest.7DAED14CEC4CDA51.quest_desc: ["&aNature's Aura&r é um mod de magia sobre usar e reabastecer a &aAura&r. Estas missões apenas abordarão alguns dos conceitos básicos.\\n\\nPara começar, faça um pouco de &eFibra Luminosa&r que é feita com &ePepitas de Ouro&r, &aFolhas&r e &aGrama&r. Clicar com o botão direito em qualquer folha com &eFibra Luminosa&r as transformará em &eFolhas Douradas&r.\\n\\nCertifique-se de ler o &aLivro da Aura Natural&r, você também pode usá-lo para mostrar como fazer os multiblocos em &aNature's Aura&r."]
	quest.7DAED14CEC4CDA51.title: "&eBem-vindo ao &aNature's Aura"
	quest.7DC8D8CAE84A7541.quest_desc: ["&b&lHostile Neural Networks&r é um Mod perfeito para quem precisa cultivar facilmente Drops de Criaturas. \\n\\nComeça com um &9Deep Learner&r e &bModel Frameworks&r. O &bModel Framework&r precisa ser configurado para uma Criatura clicando com o botão direito na Criatura com ele. \\n\\nEntão, coloque o &bFramework&r configurado no &9Deep Learner&r e comece a Matar!"]
	quest.7DC8D8CAE84A7541.title: "&b&lHostile Neural Networks"
	quest.7DD638E4111D66E7.quest_desc: ["A &8Carcaça de Armazenamento Avançada&r é necessária para criar &9Discos de Armazenamento&r de nível superior."]
	quest.7DD638E4111D66E7.title: "&8Carcaça de Armazenamento Avançada"
	quest.7DE2154159D273C3.quest_desc: [
		"A &3Armadura de Vibranium&r é uma melhoria para a &6Armadura de AllTheModium&r. \\n\\nRecebemos melhorias para cada status! Agora temos 32 Pontos de Armadura, 36 de Resistência da Armadura e 80% de Resistência a Repulsão. \\n\\nInfelizmente não recebemos novos efeitos e habilidades... mas recebemos mais &dResistência a Dano Mágico&r! Agora em 75%!"
		"{image:atm:textures/questpics/allthemodium/all_armor_vib.png width:100 height:175 align:center}"
	]
	quest.7DE2154159D273C3.title: "&3Armadura de Vibranium"
	quest.7DE2BE7BE664635D.quest_desc: ["Cada &7Mecanismo&r faz um nível diferente de &cPoke&rbola. \\n\\n&6Cobre&r faz as &cPoke&rbolas padrão, a &aSafari&r e a &dBola Cura&r. \\n\\n&7Ferro&r faz &9Grande Bolas&r e algumas outras como a &3Net&r e &bBola Mergulho&r. \\n\\n&eLatão&r faz &eUltra Bolas&r, &dBolas Amor&r e &6Luxo&r e um pouco mais. \\n\\nO &5Mecanismo de Bola Robusto&r fará &cBolas Sonho&r e &9Criatura&r!"]
	quest.7DE2BE7BE664635D.title: "&7Mecanismos"
	quest.7DF8583CAB36812E.quest_desc: [
		"Aumento de nível para 59."
		""
		"Item de Assinatura é &dDisco Duvidoso&r."
	]
	quest.7DF8583CAB36812E.title: "&7Chefe Giovanni"
	quest.7DFF18CFEB0B8DBE.quest_desc: ["Você vai querer começar a cultivar &aInferium&r assim que puder!\\n\\nEmbora não seja necessário para o cultivo dessas sementes, você também pode criar &eTerra de Cultivo de Essência&r que aumentará a velocidade de crescimento das sementes (especialmente Sementes de Inferium). No entanto, certas sementes exigirão que certas terras de cultivo sejam plantadas."]
	quest.7DFF18CFEB0B8DBE.title: "&aTerra de Cultivo de Inferium"
	quest.7E07C5A6FA6B6B1F.quest_desc: [
		"Depois de construir um &aReprocessador&r totalmente funcional, você pode injetar energia, água e &9Cianita&r para criar &dBlutônio&r."
		""
		"Isso pode ser usado como combustível para o seu reator e cria seu próprio resíduo chamado &9Magentita&r. "
	]
	quest.7E07C5A6FA6B6B1F.title: "Blutônio"
	quest.7E13007340A818C5.quest_desc: ["Esta é uma Tampa de Pilar Nível 1 para o Carregador da Luz Estelar."]
	quest.7E13007340A818C5.title: "Tampa de Pilar do Carregador da Luz Estelar Nível 1"
	quest.7E35ED5B30697722.quest_desc: ["Ever wanted the ultimate Quantum Computer setup? Well, here's a setup for you, focused on maximizing co-processing threads.\\n\\n218 Quantum Computer Structural Glass, 123 Quantum Computer Accelerators, 1 Quantum Computer Core, and 1 Quantum Computer Multi-Threader are what we need. This gives us a total of 8928 co-processing threads. Note that I did not include any storage here besides the core, as the 256M crafting storage from the core is plenty enough already. The Data Entangler quest is optional for a reason.\\n\\nGet 200 Q.C. Structural Glass and 100 Q.C. Accelerators, and I'll give you the rest, because I'm just as generous as the Apothic Enchanting chapter."]
	quest.7E35ED5B30697722.title: "The Ultimate Quantum Computer"
	quest.7E373212AE6B27D0.quest_subtitle: "Fabricação por Infusão"
	quest.7E373212AE6B27D0.title: "&fAbelha de Insanium"
	quest.7E39FB9F3E973009.quest_subtitle: "Não, não é um Químico do Mekanism, é Leite de Wither"
	quest.7E39FB9F3E973009.title: "Gás de Éter"
	quest.7E3B19796870C2B1.quest_desc: [
		"O &#9955EDReator Químico&r será uma das máquinas mais úteis para você daqui para frente. "
		""
		"Ele será usado para criar diversos produtos químicos."
	]
	quest.7E3B19796870C2B1.title: "&5Reator Químico"
	quest.7E3C84D7FCEC9D52.quest_desc: [
		"O menor &2&lReator de Fissão&r (funcional) que podemos fazer é 3x4x3. \\n\\nA base e a estrutura precisarão ser feitas de &2Invólucro do Reator de Fissão&r, enquanto o interior precisará estar Vazio ou conter &2Montagem de Varetas de Combustível&r ou &2Montagem de Varetas de Controle&r! \\n\\nO interior das paredes (não as bordas) pode ter nossas &2Portas do Reator de Fissão&r ou &2FRLA&r, e o resto pode ser preenchido com &2Vidro de Reator&r. \\n\\nAssim que nosso &2&lReator de Fissão&r estiver construído, podemos Clicar com o Botão Direito em qualquer lugar (exceto o &2FRLA&r) no &2Reator&r para abrir sua GUI."
		"{@pagebreak}"
		"Isso pode parecer bastante assustador para novos Jogadores, então vamos analisar lentamente para entender melhor! \\n\\nNa parte superior, podemos ver 4 Barras diferentes. É aqui que podemos ver a quantidade de &2Combustível Físsil&f, &bRefrigerante&f, &6Refrigerante Aquecido&f e &8Resíduo Nuclear&r. \\n\\nEntre as Barras, encontraremos o menu principal do &2&lReator&r. Ele nos informará se está ligado ou desligado, quanto &2Combustível Físsil&r está sendo usado a cada Tick, quanto a Temperatura aumenta a cada Tick e quanto Dano o &2&lReator&r sofreu! \\n\\nAbaixo de tudo isso, veremos 2 Botões! Um para ligar o &2&lReator&r, dizendo Ativar, e o outro para desligá-lo, dizendo SCRAM. Ao lado do Botão SCRAM, há uma pequena imagem para ajudar os Jogadores a saber se está ligado ou desligado. Verde quando ligado, Vermelho quando desligado. \\n\\nAbaixo desses Botões, veremos quão Quente nosso &2&lReator&r está e, abaixo, será exibida uma representação visual da mudança de Temperatura."
		"{@pagebreak}"
		"Fora deste menu, podemos Clicar na Aba Superior para abrir as Estatísticas. \\n\\nO Gráfico superior mostra quanto Calor pode ser retido antes que ocorra Dano, quanto espaço o &2Combustível&r tem dentro do &2&lReator&r, e quão Eficiente ele é no uso do Calor para consumir &2Combustível&r. \\n\\nO restante é baseado em quanto &2Combustível&r pode ser usado a cada Tick. Podemos definir um máximo na Caixa de Tipo. Também é configurado em mB por Tick! \\n\\nA outra Aba que podemos encontrar ao lado do menu principal é para nossa Temperatura! \\n\\nEla mostrará sua taxa de Dissipação, bem como a Unidade de Temperatura exibida. Podemos mudar a Unidade de Temperatura Clicando na Aba. Você provavelmente usará F (Fahrenheit) ou C (Celsius), mas também podemos usar K (Kelvin), R (Rankine) ou STP (Temperatura e Pressão Padrão)!"
		"{@pagebreak}"
		"FUSÕES! \\n\\nO &2&lReator de Fissão&r explodirá se atingir 250% de Dano. Quando explodir, ele quebrará Blocos, iniciará Incêndios e, o pior de tudo... espalhará &aRadiação&r! \\n\\nVamos evitar isso! \\n\\nO Dano aumentará quando a Temperatura ultrapassar 1.200K. Precisaremos usar &bRefrigerantes&r para manter essa Temperatura baixa. \\n\\nCertifique-se de que ele tenha um suprimento constante de &bRefrigerante&r e certifique-se de que a &bSaída de Refrigerante&r não crie gargalos. Se isso acontecer, mais &bRefrigerante&r não poderá ser usado e a Temperatura aumentará. \\n\\nVAZAMENTOS! \\n\\nVazamentos de &aRadiação&r também podem ocorrer se a Barra de &8Resíduo Nuclear&r estiver cheia. Isso espalhará &aRadiação&r ao redor do &2&lReator&r. Evite isso removendo constantemente &8Resíduo Nuclear&r e até mesmo usando &2FRLA&r para saber quando o &8Resíduo&r está cheio!"
		"{@pagebreak}"
		"Este Multibloco pode ser feito em qualquer tamanho disponível, não apenas o que é mostrado nas Imagens. As Imagens apenas mostram o menor tamanho que podemos fazer."
		"{image:atm:textures/questpics/mek/mek_fission1.png width:100 height:75 align:center}"
		"{image:atm:textures/questpics/mek/mek_fission2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_fission3.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_fission4.png width:100 height:110 align:center}"
	]
	quest.7E3C84D7FCEC9D52.quest_subtitle: "Dividindo 1 Elemento em 2"
	quest.7E3C84D7FCEC9D52.title: "&2&lReator de Fissão"
	quest.7E3DA4168D352B42.quest_desc: [
		"Prometo que este é o último Pântano de Cogumelos! \\nEstes Cogumelos parecem bem normais, a peculiaridade deles, no entanto, é o que vem deles! \\n\\nOs Véus! Definitivamente um Bloco de decoração útil."
		"{image:atm:textures/questpics/undergarden/undergarden_veil.png width:200 height:100 align:center}"
	]
	quest.7E3DA4168D352B42.title: "Pântano de Cogumelos Véu"
	quest.7E4367252A39BE6C.quest_desc: ["&c&lPowah&r é sobre poder! Gerar Energia como FE para usar Máquinas de outros Mods como &5&lMekanism&r ou &lIndustrial Foregoing&r! \\n\\nExistem diferentes Níveis que você terá que criar e, claro, precisaremos do último para a &6&lEstrela&r!"]
	quest.7E4367252A39BE6C.title: "&c&lPowah"
	quest.7E49C985A0433B20.quest_desc: ["&d&lArs Nouveau&r é um Mod de magia muito divertido e com ele traz seu próprio conjunto de Madeira! \\n\\nArchwood vem em 5 cores diferentes de árvores que aparecem na maioria dos Biomas, mas principalmente em seu Bioma Archwood!"]
	quest.7E49C985A0433B20.title: "&fTroncos de &d&lArs Nouveau&r"
	quest.7E57964F6AD5B060.quest_subtitle: "A Abelha Cortadora de Folhas pode estar com Sede"
	quest.7E57964F6AD5B060.title: "&fAbelha Chá"
	quest.7E7637DAD2C242CB.quest_subtitle: "Lariço Europeu + Abeto"
	quest.7E8CBDC0377013E0.quest_desc: [
		"Outra estrutura nas Terras Ruins, a Toca Chamuscada pelo Sol. \\n\\nEducadamente dentro da toca fica o &7Cascalho Suspeito&r."
		"{image:atm:textures/questpics/pokemon/find_sunscorched_den.png width:200 height:100 align:center}"
	]
	quest.7E8CBDC0377013E0.title: "Toca Chamuscada pelo Sol Pré-histórica"
	quest.7E90138B0A2C3210.quest_desc: ["As Árvores da Terra do Norte são árvores grandes e robustas nas Florestas de Permafrost. \\n\\nElas parecem Abetos, mas muito mais claras! Talvez sejam um Abeto albino. \\n\\nSuas mudas precisam ser plantadas na Terra, não na Grama, e em uma formação 2x2."]
	quest.7E92ED270C67FDE5.quest_desc: ["Quase todas as máquinas que você pode fazer no mod exigirão uma &9Carcaça Dielétrica&r.\\n\\nVocê precisará fazer a &bPasta&r primeiro, bem como algumas &aVaras&r para progredir!"]
	quest.7E92ED270C67FDE5.title: "Começando com Materiais Dielétricos"
	quest.7E9E03274A88347D.quest_desc: ["Aumenta o tamanho da pilha na Mochila em 2."]
	quest.7E9E03274A88347D.title: "&fMelhoria de Pilha Nível 1"
	quest.7EAFF64FFE8B5378.quest_subtitle: "Ferro + Suor"
	quest.7EAFF64FFE8B5378.title: "&fAbelha de Zinco"
	quest.7EB1C1AE52A0027F.title: "Módulo de Compensação de Gravidade de Projétil Caótico"
	quest.7EB97C0DDE60DED4.quest_desc: ["O melhor Arco do Draconic Evolution, também com mais slots para Módulos!"]
	quest.7EB97C0DDE60DED4.title: "Arco Caótico"
	quest.7EC7E12C0880F8F5.quest_subtitle: "Nível: &e5"
	quest.7EC8814940C4C3D7.quest_desc: ["Use este item para encolher. Útil para trabalhar na automação e também divertido no geral."]
	quest.7EC8814940C4C3D7.quest_subtitle: "Querida, eu me encolhi"
	quest.7EC8814940C4C3D7.title: "Dispositivo de Encolhimento Pessoal"
	quest.7EC89242980768B3.quest_subtitle: "Nogueira-pecã + Cereja Selvagem"
	quest.7ECA0633AF1AEC19.quest_desc: ["A &e&lSerraria de Precisão&r funcionará para \"reciclar\" &6Itens de Madeira&r. \\n\\nBasta dar-lhe um pouco de &aEnergia&r e jogar um &6Item de Madeira&r e esperar! \\n\\nEla transformará Camas em 3 &6Tábuas de Madeira&r e 3 Lãs. &6Portas&r em &6Tábuas de Madeira&r. E &2Troncos&f em 6 &6Tábuas&r em vez de 4! \\n\\nEla também transformará &7Gravetos&r em &6Serragem&r, que é necessária para a &6Caixa de Papelão&r!"]
	quest.7ECA0633AF1AEC19.title: "&e&lSerraria de Precisão"
	quest.7ECE00D12CFC50A4.quest_desc: ["A &bUnidade Toque Suave&r funcionará como um encantamento de Toque Suave para a &dMeka-Tool&r. \\n\\nMas não apenas a parte da Picareta, também a Pá e outras Ferramentas dentro da &dMeka-Tool&r! \\n\\nAssim, você pode pegar Pedra e Minérios, além de Grama e Micélio. \\n\\nNão podemos usar esta &7Unidade&r com a &dUnidade de Refinamento de Minério&r em uma &dMeka-Tool&r."]
	quest.7ECE00D12CFC50A4.quest_subtitle: "Bem delicado, por favor!"
	quest.7ECE00D12CFC50A4.title: "&bUnidade de Toque Suave"
	quest.7EDBE88A2CFAB353.quest_desc: [
		"As &#562FD6Montadoras&r são usadas para fabricar muitos componentes e máquinas. Elas conseguem realizar trabalhos de fabricação de forma automática."
		""
		"Também oferecem variantes &amuito mais baratas&r de algumas receitas que você já utilizou."
	]
	quest.7EDBE88A2CFAB353.quest_subtitle: "Você vai precisar de muitos"
	quest.7EDBE88A2CFAB353.title: "&5Montador"
	quest.7EDF2CC08FC774F9.quest_subtitle: "&f10 &cde Dano de Ataque"
	quest.7EE27C3908008E20.quest_desc: ["Se precisar estender seus &cNós de Laser&r por uma longa distância, tente usar Conectores! Basta usar a Chave Inglesa como de costume."]
	quest.7EEEEDD5FF31ACD3.quest_desc: ["A &eCalha Inteligente&r é uma &eCalha&r com opções de Filtro."]
	quest.7EEEEDD5FF31ACD3.title: "&eCalha Inteligente"
	quest.7EF57BBEAA4B6B08.quest_desc: ["Pensando em criar armazenamento virtual usando um mod como o &9Applied Energistics 2&r?\\n\\nEssas são ótimas maneiras de atualizar seu armazenamento, mas é importante falar sobre &eItens NBT&r e a melhor maneira de armazená-los.\\n\\nItens NBT são itens com tags extras anexadas a eles. Itens encantados, itens com durabilidade e mais. Estes são itens com tags NBT anexadas a eles. Por causa disso, eles geralmente não se acumulam.\\n\\nQuando você armazena muitos deles em um sistema de armazenamento como o AE2, corre o risco de criar problemas para seu save ou servidor.\\n\\nPor causa disso, é melhor armazená-los em Baús ou Sacos!"]
	quest.7EF873DCEB3B9D48.quest_desc: ["O último &lNível de Mundo&r, &lNível de Mundo: &4Pináculo&r. Para obtê-lo, você precisará Matar o &d&lDragão do End&r pelo menos uma vez e equipar toda a &eArmadura &fe &eFerramenta/Arma&r &5Épicas&r ou &6Mítico&r. \\n\\nAgora &5Épico&r e &6Mítico&r são mais comuns para &aGemas &fe &eFerramentas&r, além disso, temos mais probabilidade de obter gemas &zPerfeitas&r! Isso vem com a perda de &8Comuns&r e &aIncomuns&r, mas ei, quem sentirá falta deles! \\n\\nNo mesmo padrão de melhorias, obteremos 125% de Experiência Ganhada e um aumento de 100% na Sorte. \\n\\nOs &4Monstros&r receberão sua melhoria final, obtendo: 16 Pontos de Armadura, 20 de Resistência de Armadura, 25 de Perfuração de Armadura e 20 de Perfuração de Proteção."]
	quest.7EF873DCEB3B9D48.title: "&lNível de Mundo: &4Pináculo"
	quest.7EFBAF3E281D2EBE.quest_desc: [
		"O &aPonto de Armazenamento ME&f, quando voltado para algum contêiner de armazenamento externo, permitirá que o contêiner seja usado como se fizesse parte da Rede ME, permitindo que itens sejam retirados do contêiner ou inseridos nele puramente via ME. "
		""
		"Os Ponto de Armazenamento podem ser filtrados e receber prioridades específicas, de modo que itens específicos tentarão ir para o armazenamento anexado primeiro, no entanto, ele não moverá retroativamente quaisquer itens filtrados de qualquer outro lugar na rede para seu armazenamento anexado."
	]
	quest.7EFBAF3E281D2EBE.quest_subtitle: "O baú extra"
	quest.7EFBAF3E281D2EBE.title: "&aPonto de Armazenamento"
	quest.7EFBFF5D0DA018E7.quest_desc: ["Adiciona um filtro para itens que você deseja excluir automaticamente na Mochila."]
	quest.7EFBFF5D0DA018E7.quest_subtitle: ["Adiciona um filtro para itens que você deseja excluir automaticamente na mochila."]
	quest.7EFEE009212A4FD4.quest_subtitle: "Nível: &63"
	quest.7F076FC4F2187692.quest_subtitle: "&f8 &cde Dano de Ataque"
	quest.7F09F8F98C13F11B.quest_desc: [
		"O que é um Ritual Demoníaco sem um &cSacrifício&r! :D\\n\\nNa maioria das vezes, os Demônios gostam apenas de itens, então não tenha muito medo ainda. No entanto, se você tem uma Vaca favorita, pode precisar se preocupar. Desculpe, Mimosa.\\n\\n&aTigelas de Sacrifício&r são usadas para colocar itens necessários para Rituais. Elas podem ser colocadas em qualquer lugar dentro do Ritual, desde que não estejam cobrindo nenhum dos Gizes necessários. "
		""
		"Por enquanto, você só precisará de quatro, mas mais tarde precisará de mais de dez tigelas para cada ritual!\\n\\nA &6Tigela Ritualistica Dourada&r é usada no meio do Ritual para ativá-lo, e geralmente também precisa de um Livro de Vinculação para o Ritual nela."
	]
	quest.7F09F8F98C13F11B.title: "Preparando-se para um Ritual: &6Tigelas"
	quest.7F0B2D58361FB00E.quest_desc: ["Just Dire Things é um mod pau para toda obra. Just Dire Things adiciona uma nova mecânica de criação chamada Goo Spread, juntamente com máquinas que auxiliam na automação do Goo Spread e outras utilidades."]
	quest.7F0B2D58361FB00E.title: "Just Dire Things"
	quest.7F0F7111552F95A9.quest_desc: ["Ok, temos nosso &5Trem&r totalmente Montado, agora como o usamos? \\n\\nSe você estiver Controlando-o, precisará Clicar com o Botão Direito nos &5Controles do Trem&r. \\n\\nEntão, você pode Segurar W para avançar ou Segurar S para retroceder. Não, &5Trens&r não viram como Carros, eles apenas seguem os &7Trilhos&r. \\n\\nIndo para Frente você ganhará muita Velocidade, você pode ver na Barra que substitui sua &aBarra de Experiência&r. Para trás não dará tanta Velocidade. \\n\\nSe você estiver se aproximando de uma &5Estação de Trem&r e não se movendo na velocidade da luz, pode Segurar Espaço para parar o &5Trem&f na &5Estação&r. Isso é útil para desmontá-los ou até mesmo conectar mais &5Vagões&r."]
	quest.7F0F7111552F95A9.title: "Controlando seu &5Trem"
	quest.7F11ABFB2E21B7E4.quest_desc: ["Armadura é uma parte muito importante do &l&2Minecraft&r, é o que te protege de danos. \\n\\nPeças diferentes de Armadura dão diferentes Pontos de Armadura. Estes são o que determinam a eficácia da sua Armadura, quanto mais, melhor!\\n\\nA maioria das armaduras pode ser alterada para mais decoração com Acabamentos de Armadura, use uma peça de Armadura com um Acabamento de Armadura e um Item para colorir para mudar a aparência!"]
	quest.7F11ABFB2E21B7E4.title: "&l&bArmadura Básica&r"
	quest.7F124EAE153EFE7F.quest_desc: ["Agora temos a última Batalha da &4&oSérie&r. Apenas uma última Batalha com a &5Campeã Cynthia&r. \\n\\nEla não aumentará seu Limite de Nível, em vez disso, finalizará a &4&oSérie&r. Então, você poderá começar uma nova! Como a do &6&oATM&r."]
	quest.7F124EAE153EFE7F.title: "&4&oSérie&r Finalizada"
	quest.7F132BF6D4B5F803.quest_desc: [
		"Finalmente um Aumento de Nível. Para 37."
		""
		"O Item de Assinatura é Gema Voadora."
	]
	quest.7F132BF6D4B5F803.title: "&aLíder Alice"
	quest.7F187E291C3D5BA7.quest_desc: ["O Descarregador de Fluidos é exatamente o oposto do Carregador de Fluidos. Em vez de estar sobre o &6Trilho&r, ele está sob. Em vez de dar água às &3Locomotivas a Vapor&r, ele pega a água delas. Não sei por que você iria querer fazer isso, mas você pode!"]
	quest.7F187E291C3D5BA7.title: "Descarregador de Fluidos"
	quest.7F2D696AC9F4C4E4.quest_desc: [" Forjada a partir de &5camadas de cristal&r por um artesão visionário, a &5Bota de Vidro Lapidado&r carrega a memória de cada &cgota de líquido&r que já tocou. Seu poder permite ao portador caminhar sobre &cágua, lava&r ou &5veneno&r como se a superfície fosse vidro sólido. \\n\\n Enquanto a bota estiver equipada, ela também pode &carmazenar líquidos&r em seu buffer interno, permitindo que o portador escolha sobre qual líquido caminhar. Quanto mais líquido do mesmo tipo armazenado, mais rápidos os passos se tornam, transformando &csuperfícies lentas&r em um &5caminho ágil&r. \\n\\n- &lPossui 1 habilidade:&r \\n\\n &f&lVidro&r: \\n Esta &6relíquia&r funciona como um &5recipiente&r versátil para &9líquidos&r. Quando &6segurada&r, pode armazenar múltiplos &9tipos de líquido&r em seu &5buffer interno&r, permitindo que o &6portador&r escolha qual usar. \\n\\n Enquanto &6equipada&r, o &6portador&r pode se mover através de qualquer &9líquido&r armazenado dentro. O movimento é naturalmente mais &clento&r do que caminhar em &5solo sólido&r, mas quanto mais &9líquido&r do mesmo tipo armazenado, mais fácil se torna caminhar sobre ele, transformando superfícies de outra forma &4perigosas&r em um &acaminho estável e transitável&r. \\n\\n- Uma &6relíquia&r para aqueles que se recusam a afundar… e podem &9deslizar&r sobre qualquer líquido."]
	quest.7F2D696AC9F4C4E4.quest_subtitle: "Caminhe onde outros afundam e comande o fluxo dos líquidos!"
	quest.7F2D696AC9F4C4E4.title: "&bBota de Vidro Lapidado"
	quest.7F4963FCAE5337EC.quest_desc: ["Porque só lutar contra o &b&lIgnis&r não é difícil o suficiente, você terá que lutar contra o &bRevenant Aceso&r primeiro para obter as &bCinzas Ardentes&r. \\n\\nQuando as tiver, use-as no Altar de Fogo para invocar o &b&lIgnis&r."]
	quest.7F4963FCAE5337EC.quest_subtitle: "Reacendendo o Ignis"
	quest.7F4963FCAE5337EC.title: "&7Cinzas &cArdentes"
	quest.7F4B734CFB0F0306.quest_desc: ["Estes novos &7Carrinhos&r são semelhantes aos &7Carrinhos&r especiais do &2Vanilla&r. O &7Carrinho de Minas com um Tanque&r irá conter e mover qualquer Líquido nele. O &7Carrinho de Minas com uma célula de Energia&r irá, em vez disso, conter e mover Energia!"]
	quest.7F4B734CFB0F0306.title: "Novos Carrinhos"
	quest.7F53544DE1ED4C2A.quest_desc: ["A &cFornalha&r é o 2º bloco mais importante no &2&lMinecraft&r. A &6Bancada de Trabalho&r é mais importante, duhhh. \\n\\nA &cFornalha&r pode fundir itens para fazer novos itens (geralmente melhores)! Ela pode cozinhar comida, transformar &7Minérios&r em lingotes e fazer blocos inteiros novos. \\n\\nA &cFornalha&r precisa de combustível em seu slot inferior. Coisas como &6Madeira&r, &0Carvão&r, plantações e até &6Espadas de Madeira&r."]
	quest.7F53544DE1ED4C2A.title: "&cFornalha"
	quest.7F59941D62E672B0.quest_desc: [
		"Ocultismo oferece mais do que apenas Demônios para triturar seus minérios!"
		""
		"Existem Demônios que podem mover coisas para você, cortar madeira e muito mais!!"
		""
		"Existem também maneiras de invocar amigos legais conhecidos como &dFamiliares&r que dão buffs especiais e até lutam por você! Certifique-se de conferir os &dFamiliar Rituals&r no seu livro guia!"
	]
	quest.7F59941D62E672B0.title: "&dFamiliares"
	quest.7F67849DE9F700D8.quest_desc: ["&2Aumento&r: Velocidade faz com que sua Fornalha seja mais rápida! A &bFornalha de Diamante&r irá, em vez disso, derreter a cada 40 Ticks em vez de 80 Ticks. Ao custo do dobro do uso de Combustível."]
	quest.7F67849DE9F700D8.title: "&2Aumento&r: Velocidade"
	quest.7F6B66566C211735.quest_desc: ["&3Espeleotema Pontiagudo&r usada no gerador reduzirá a &csaúde máxima&r do mob gerado. Isso pode diminuir sua saúde em até 20%"]
	quest.7F6B66566C211735.title: "&5Saúde"
	quest.7F757CD6F8C57733.quest_desc: ["O Núcleo de Energia é um dos, se não o maior, banco de Energia de todo o Minecraft. E tudo começa com o Núcleo. Este é o centro e o coração do Multibloco do Núcleo de Energia (certifique-se de que esteja um pouco acima do chão). Ao colocá-lo, você pode ver sua GUI com: Guia de Construção, Nível Anterior, Próximo Nível e Montar Núcleo. Os Níveis determinam o quão grande e poderoso o Núcleo é. O Guia de Construção mostra como montar este Nível de Núcleo. Se você tiver todos os blocos necessários, pode pressionar Montar Núcleo e ele o criará automaticamente!"]
	quest.7F757CD6F8C57733.quest_subtitle: "Armazenamento de Energia Dracônica"
	quest.7F757CD6F8C57733.title: "Multibloco do Núcleo de Energia"
	quest.7F8DEDD0A54D1E11.quest_desc: ["Eu me pergunto o que os Ejetores fazem? \\nAcho que eles ejetam coisas... \\n\\nQualquer item no Buffer será jogado no chão. \\n\\nPoderia ser útil com algo como Botania!"]
	quest.7F8E50FA436DB4E6.quest_desc: ["&dAcionamentos de Corrente Encapsulados&r agirão de forma semelhante a &eCorreias&r, conectando &8Eixos&r uns aos outros em uma fileira. \\n\\nHá algumas diferenças, no entanto, como o fato de que &dAcionamentos de Corrente Encapsulados&r podem ser usados com uma &6Chave Inglesa&r para girar. Eles também precisam ser colocados diretamente ao lado de outros &dAcionamentos de Corrente&r para continuar &dGirando&r. \\n\\nComo as &eCorreias&r, no entanto, eles mantêm a mesma Velocidade e Unidades de Tensão que o &8Eixo&r original. Além disso, eles mantêm a mesma direção!"]
	quest.7F8E50FA436DB4E6.title: "&dAcionamentos de Corrente Encapsulados"
	quest.7F990FBC1A691020.quest_desc: ["Baús com Armadilha são iguais aos Baús normais, só que emitem um sinal de Redstone quando abertos e não podem ser combinados em 1."]
	quest.7F990FBC1A691020.quest_subtitle: "\"O que será que tem aqui dentro?\""
	quest.7FA85713C86166DA.quest_desc: ["Permite que você acesse sua fila de criação da rede sem fio."]
	quest.7FABB77A60E7962C.quest_desc: ["Ao infundir Obsidiana com &bDiamantes&r, podemos obter Pó de Obsidiana Refinada! \\n\\nEntão, podemos comprimir &7Ósmio&r nele para obtê-lo em forma de Barra. \\n\\nDepois disso, podemos transformar essas Barras em Armadura com status melhores do que até mesmo a &6Armadura de Allthemodium&r!"]
	quest.7FABB77A60E7962C.quest_subtitle: "31"
	quest.7FABB77A60E7962C.title: "&5Armadura de Obsidiana Refinada"
	quest.7FB12EC3A5888123.quest_desc: ["A &3Junção de Tubo&r lhe dá mais controle sobre o transporte de sua pressão, permitindo que você mova seus Tubos de Pressão em mais direções."]
	quest.7FB12EC3A5888123.quest_subtitle: "Não, vá por aqui!"
	quest.7FBB431AC055FE93.quest_desc: ["O Espectador Soulit é criado com uma Alma Aprisionada e um Olho de Aranha do Anoitecer. \\n\\nFunciona de forma semelhante a uma Câmera Adesiva de Tom Clancy's Splinter Cell. Você pode Clicar com o Botão Direito para enviar o Espectador e, após um tempo, poderá ver através dele. Você pode até se ver com ele! \\n\\nNão pode ser encerrado antes do tempo, então cuidado ao usá-lo. Ele também tem durabilidade e tempo de recarga."]
	quest.7FD3C1784F32F2AF.quest_subtitle: "Caótica Fusão de Criação"
	quest.7FD3C1784F32F2AF.title: "Abelha do Caos"
	quest.7FE273141D3DFFFD.quest_desc: ["O Fuzileiro é a unidade média dos novos Saqueadores! \\n\\nEles têm 12 Corações e nenhuma Armadura. \\n\\nSua arma de escolha é um &5&lCanhão Elétrico&r que é carregado pela Mochila Acumuladora que eles usam! \\n\\nNa morte, eles droparão &aEsmeraldas&r e &7Varas de Ferro&r."]
	quest.7FE273141D3DFFFD.title: "Fuzileiro"
	quest.7FE5864E59D7B827.quest_desc: ["As &#6784EBCarcaças&r controlam a quantidade de energia que pode ser fornecida a uma máquina. Conforme você adiciona melhorias à máquina, será necessário uma &#6784EBCarcaça&r de nível superior para aceitar mais energia. O nível da &#6784EBCarcaça&r também afeta quais cabos podem ser conectados a ela."]
	quest.7FE5864E59D7B827.quest_subtitle: "Bloco básico de construção"
	quest.7FE5864E59D7B827.title: "&5Carcaça de Máquina"
	quest.7FE969CB4B419FC6.quest_desc: ["Com um pouco de trabalho no Mekanism, esta máquina permite transferir qualquer coisa sem fio.\\n\\nVocê pode definir canais específicos para transferir itens individuais, energia ou até mesmo gases do Mekanism. É bem legal."]
	quest.7FE969CB4B419FC6.quest_subtitle: "Não funciona só para Energia"
	quest.7FE969CB4B419FC6.title: "&9Mekanism: &6Entreleportador Quântico"
	quest.7FF3EA602FE7A546.quest_desc: ["O &3Transmissor de Sculk&r é um Item muito raro que podemos encontrar nos Baús do &6Templo Ancestral&r. \\n\\nAssim que encontrar um, ele será seu Melhor Amigo! \\n\\nPara usá-lo, simplesmente Shift + Clique Direito em um Bloco que tenha uma GUI, pense em: Baús, Bancadas de Trabalho e Fornalhas. Então, o &3Transmissor&r será vinculado a esse Item. \\n\\nDepois disso, podemos usar o &3Transmissor&r para acessar remotamente aquele Bloco de qualquer lugar! \\n\\nPara desvincular o Bloco, Shift + Clique Direito no Ar com o &3Transmissor&r."]
	quest.7FF3EA602FE7A546.title: "&3Transmissor de Sculk"
	quest.7FF77463F2A0E210.quest_desc: ["Lama do Anoitecer só pode ser encontrada nos Pântanos Escuros. \\n\\nVocê pode fazer mais Blocos com ela!"]
