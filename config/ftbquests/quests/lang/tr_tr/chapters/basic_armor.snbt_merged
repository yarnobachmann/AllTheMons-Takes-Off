	quest.6B671CB07D046BEC.title: "&bElmas&r"
	quest.6C5F9D0D447EFB9C.quest_desc: ["Elimizdeki tek şeyin &l&2Vanilla&r olduğunu mu düşünüyorsun? \\n\\n&6AllTheModium Zırhı&r, daha fazla Zırh Puanı ve Zırh Sertliğine sahiptir. Ayrıca Büyüye karşı daha fazla Koruma sağlar ve &6&lAllTheModium&r Görev Sayfasında okuyabileceğin diğer güçlendirmelere sahiptir! \\n\\nBu arada onu üretmek için &cNetherit&r'e ihtiyacın olacak."]
	quest.6C5F9D0D447EFB9C.title: "&6AllTheModium Zırhı"
	quest.6ED2CDD01659FD10.quest_desc: ["Bu zırh seti Demir ile aynı Zırh Puanına sahip. Ancak hem Zırh Sertliği hem de Savrulma Direnci açısından daha iyidir."]
	quest.6ED2CDD01659FD10.title: "&7Compressed Iron Zırhı"
	quest.6F76DA3BBAE8337B.quest_desc: ["&5Unobtainium&r, &6&lAllTheModium&r'dan elde edebileceğimiz en güçlü Zırh! \\n\\nŞimdi 100% Savrulma Direnci ve her yerde daha yüksek özelliklerle! \\n\\nAyrıca bunu yapmak için &3Vibranium Zırhına&r ihtiyacın var."]
	quest.6F76DA3BBAE8337B.title: "&5Unobtainium Zırhı"
	quest.71C552678A0F649F.quest_desc: ["&7Osmiyum&r, Kayrak Taşı etrafında ortaya çıkar ve Kazmak için sadece Demir Kazma (ya da Demir kademesinde Kazma) gerekir. Ancak &cNetherit&r'den daha iyi özellikler verir!"]
	quest.71C552678A0F649F.title: "&7Osmiyum Zırh"
	quest.729DCB919A92B735.quest_subtitle: "Sınama Odaları"
	quest.729DCB919A92B735.title: "Şimşek Zırh Süslemesi"
	quest.72DDA413D73E3235.quest_desc: ["Sıradaki &6&lAllTheModium&r Zırhı olan &3Vibranium&r'la her şeyde çok daha yüksek özellikler! \\n\\nBunu oluşturmak için &6AllTheModium Zırhına&r ihtiyacın olacak."]
	quest.72DDA413D73E3235.title: "&3Vibranium Zırhı"
	quest.76CDF08465700AA2.quest_subtitle: "Antik Şehirler"
	quest.76CDF08465700AA2.title: "Sessizlik Zırh Süslemesi"
	quest.79D3055DE0EEA6B0.quest_desc: ["&d&lArs Elemental&r &cAteş Zırhı&r!"]
	quest.79D3055DE0EEA6B0.title: "&cPyromancer Kıyafetleri"
	quest.7ADE27F9398D97F1.quest_desc: ["Bu da pek farklı değil, neden kontrol ediyorsun?"]
	quest.7ADE27F9398D97F1.title: "Arı Zırhı 2"
	quest.7B500E0577BDFF8F.quest_desc: ["&6Bronz&r; &6Bakır&r ve Kalay'ın birleşimidir. \\n\\nBu alaşımı yapmanın onlarca farklı yolu var. Sana bunun yapımı için doğru yolu söylemeyeceğim."]
	quest.7B500E0577BDFF8F.title: "&6Bronz Zırh"
	quest.7C1D407CF67786F6.quest_desc: ["&d&lArs Elemental&r Hava Zırhı!"]
	quest.7C1D407CF67786F6.title: "&fAethermancer Kıyafetleri"
	quest.7F11ABFB2E21B7E4.quest_desc: ["Zırh, &l&2Minecraft&r'ın çok önemli bir parçasıdır. Seni zarar görmekten koruyan şeydir. \\n\\nFarklı Zırh parçaları farklı Zırh Puanları verir. Bunlar Zırhının etkililiğini belirleyen şeylerdir. Ne kadar çok o kadar iyi!\\n\\nÇoğu zırh, Zırh Süslemeleri ile daha fazla dekorasyon için değiştirilebilir. Görünümü değiştirmek için Zırh Süslemesi ile bir Zırh parçası kullan ve renklendirme için Eşya kullan!"]
	quest.7F11ABFB2E21B7E4.title: "&l&bZırhlar&r"
	quest.7FABB77A60E7962C.quest_desc: ["Obsidiyen'i &bElmas&r'lar ile aşılayarak İşlenmiş Obsidyen Tozu elde edebiliriz! \\n\\nSonrasında, &7Osmiyum&r'u içine sıkıştırarak Külçe formunu elde edebiliriz. \\n\\nBundan sonra, bu Külçeleri &6AllTheModium Zırh&r'dan bile daha iyi özelliklere sahip Zırhlara dönüştürebiliriz!"]
	quest.7FABB77A60E7962C.title: "&5İşlenmiş Obsidyen Zırh"
}
