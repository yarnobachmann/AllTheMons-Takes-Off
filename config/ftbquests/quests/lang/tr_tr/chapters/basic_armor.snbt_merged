{
	quest.004D61425172324F.quest_desc: ["&8Zincir Zırh&r Demir'den biraz daha kötü. &l&2Minecraft&r'daki ana kullanımı, bulunması zor olmasıydı. Sadece Ticaretlerden ve Yaratıklardan Düşürülerek elde edilebilir. \\n\\nTabii ki bu değiştirildi. Bu yüzden şimdi üretilebilir! Bu da onun amacını ortadan kaldırıyor..."]
	quest.004D61425172324F.title: "&8Zincir Zırh"
	quest.041ED280691BB05D.quest_desc: ["&9Froststeel&r, &2&lUndergarden&r'ın Soğuk Biyomlarında yaygın bir Cevherdir. "]
	quest.041ED280691BB05D.title: "&9Froststeel Zırhı"
	quest.074EC1E636CD6605.quest_desc: ["&cNetherit Zırh&r'ı, &l&2Vanilla&r'dan elde edebileceğin en iyi Zırh'tır. &bElmas&r ile aynı Zırh Puanına sahip ama daha fazla Zırh Sertliğine sahiptir. \\n\\nMuhtemelen bunu yapmak için &bElmas&r'a ihtiyacın olduğu içindir!"]
	quest.074EC1E636CD6605.title: "&cNetherit Zırh"
	quest.0ABB2264CBB82470.quest_desc: ["&d&lArs&r Zırhlarının, Demir Zırhı."]
	quest.0ABB2264CBB82470.title: "&5Arcanist Kıyafetleri"
